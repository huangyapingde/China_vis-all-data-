  "plot": "河北盗魁窦尔敦，善使虎头双钩，自仗武力，横行齐鲁间。先是窦尔敦与飞镖黄三泰，在李家店地方，因角\n技被挫，从此江湖间窦尔敦之威名大损，遂恼羞成怒，暗与黄三泰结不解。继往关外占据连环套山寨，日夜\n图报复。后知梁千岁有钦赐千里驹一乘，遂故遣部下往盗之，且留书署名飞镖黄三泰，蓄意欲藉此陷害黄三\n泰，初不知黄三泰已谢世也。时黄三泰子黄天霸，已得记名总兵之职。幸彭公知其为仇家诬陷，曲予成全，\n限期令黄天霸访拿。",
  "notes": "《盗御马》即《连环套》一剧，为武生戏中最著名最流行之靠把戏。京奉河北一带，每排为胄子，良以从前\n老黄三、余毛豹，及杨月楼、小楼父子等，均多擅长。因之“连环套”三字，益增声价。近来坤伶名角，如\n小兰英、赵紫云、露兰春等，亦皆以能演此剧为时髦，此剧名重一时，至于如次，当必有其特优之点。惟晚\n近积习都偷懒，只演《天霸探山》一场，而前之《围场·盗马·计陷》，后之《盗钩·比武》等幕，均节略\n不演，徒令观剧者，只窥见一斑，而不能见其全豹。每苦于无头脑，又无结束，况近来伶界思想逐步改进，\n历史上文武旧剧，多改排全本，观剧者眼光亦随之变异，故两载以来，屡承爱读戏考者来函切责，本考《连\n环套》脚本之必须增刊全本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四龙套、四校尉、四家将、二内侍、梁九公同上。"
        },
        {
          "character": "梁九公",
          "type": "引子",
          "text": "一片丹心，保大清，锦绣乾坤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梁九公上高台。"
        },
        {
          "character": "梁九公",
          "type": "念",
          "text": "统领禁军有数秋，满朝文武咱为头。九重宫关承恩沛，万国来朝五凤楼。"
        },
        {
          "character": "梁九公",
          "type": "白",
          "text": "咱家，梁九公，在大清驾前为臣。七岁净身，九岁入宫，伺候康熙老佛爷，蒙 圣恩，十分宠爱，封为太尉之职，管理三宫六院，内务府库，以及銮仪卫上驷 院，御马圈、奉宸院、侍卫处，并精捷营神机营等处，俱是咱家所管。可算得 是一人之下，万人之上。这且不言，今奉圣命，带领各营兵丁，在热河一带行 围射猎。看今日天气清和。 孩子们，"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "咋。"
        },
        {
          "character": "梁九公",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "梁九公",
          "type": "白",
          "text": "摆驾荒郊去者。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "咋。 中国京剧戏考 《连环套》【头、二本】 2 呔，校尉的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同允。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "摆驾荒郊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同允。〖泣颜回〗。众人同大转场。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "来此荒郊。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "启千岁：来此已是荒郊。"
        },
        {
          "character": "梁九公",
          "type": "白",
          "text": "吩咐撒下围场。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "千岁传令：撒下围场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（虎形上，跳舞，家将甲上，刺虎形死，下。豹形上，二家将同上，擒豹形，同下。鹿形上，三家将同上，"
        },
        {
          "character": null,
          "type": "text",
          "text": "捉鹿形，同下。兔形上，四家将持鸟枪同上，打兔形死，同下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大蒙古人、小蒙古人骑一骆驼同上。"
        },
        {
          "character": "小蒙古人",
          "type": "白",
          "text": "喂乐乐了喝，闷得闷得。"
        },
        {
          "character": "大蒙古人",
          "type": "白",
          "text": "噫拉噫拉哦闷得闷得。"
        },
        {
          "character": "小蒙古人",
          "type": "白",
          "text": "你头戴的是什么呦？"
        },
        {
          "character": "大蒙古人",
          "type": "白",
          "text": "是大皮帽子哦。"
        },
        {
          "character": "小蒙古人",
          "type": "白",
          "text": "你身上穿的是什么呦？"
        },
        {
          "character": "大蒙古人",
          "type": "白",
          "text": "是大皮袄套子哦。"
        },
        {
          "character": "小蒙古人",
          "type": "白",
          "text": "你手里拿的是什么呦？"
        },
        {
          "character": "大蒙古人",
          "type": "白",
          "text": "是烟袋和烟荷包哦。"
        },
        {
          "character": "小蒙古人",
          "type": "白",
          "text": "你骑的是匹什么呦？"
        },
        {
          "character": "大蒙古人",
          "type": "白",
          "text": "骑的是一匹大骆驼哦。"
        },
        {
          "character": "小蒙古人",
          "type": "白",
          "text": "你怎么不走哦？"
        },
        {
          "character": "大蒙古人",
          "type": "白",
          "text": "我要打他呦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大蒙古人打骆驼，大蒙古人、小蒙古人相拉，各骑一半，同跳舞，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四家将、四校尉抬虎皮、豹皮、鹿皮、兔皮同上。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "请千岁验看各兽。"
        },
        {
          "character": "梁九公",
          "type": "白",
          "text": "赏尔等每人银牌一面，再赐羊羔美酒，四营畅饮。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "谢千岁。"
        },
        {
          "character": "梁九公",
          "type": "白",
          "text": "孩子们。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "咋。"
        },
        {
          "character": "梁九公",
          "type": "白",
          "text": "摆驾回营。"
        },
        {
          "character": "二内侍",
          "type": "白",
          "text": "咋。 唗，众校尉，摆驾回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同允。〖江儿水〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四下手、四龙套、八头目、窦尔敦同上。"
        },
        {
          "character": "窦尔敦",
          "type": "点绛唇",
          "text": "武艺高强，英雄胆壮，镇山岗，坐地分赃，绿林美名扬。"
        },
        {
          "character": "窦尔敦",
          "type": "念",
          "text": "铁背熊腰胆包天，两膀膂力把泰山。压伏绿林英雄汉，坐地分赃镇连环。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "某，姓窦名尔敦，人称铁罗汉。自幼演习拳棒，霸占绿林，坐镇连环宝套，倒 也安然自在。也曾命人下山，打听买卖，未见到来，不知何故？ 喽罗的，伺候了。 中国京剧戏考 《连环套》【头、二本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "参见寨主。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "山下可有什么大宗的买卖？"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "大宗买卖，却倒没有；只是打听一桩新闻，特地报与寨主知道。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "有什么新闻？一一讲来。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "今有太尉梁千岁，蒙圣上赐他一匹青骔豹勒五花马，在热河一带行围射猎，好 不威严也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。探子比手式。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "赏你银牌一面，再探再报。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "谢寨主。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。窦尔敦三笑。"
        },
        {
          "character": "八头目",
          "type": "同白",
          "text": "寨主为何发笑？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "你等哪里知道，俺窦某有一家仇人，与某结下仇恨，已有二十余载，不料今日， 竟能得报了。"
        },
        {
          "character": "八头目",
          "type": "同白",
          "text": "但不知寨主的仇人，是哪一个？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "你等听到。"
        },
        {
          "character": "八头目",
          "type": "同白",
          "text": "寨主请讲。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "想俺窦某，自幼练习武艺，站在河间一带等处。可恨飞镖黄三泰，保镖为业， 只因手中缺乏，与俺指镖借银。那时是俺不允，他与俺就在李家店比试，是他 连发两镖，一枝被俺接住，一枝打落尘埃，不料那老儿，暗用甩头一子，也是 俺一时大意，竟将俺打倒在地。那时众家英雄，纷纷言道：窦某青春年少，竟 胜不过那五旬的老儿。那时俺满脸羞愧，气走河间，来在连环宝套，多蒙众位 贤弟，推我为尊，才有安身之地。至今算来，已有二十余载，常常挂念。方才 探子报到：梁太尉在此，行围射猎。俺今日独自下山，去至御营，将恩赐御马 盗来，推在三泰的头上，管叫他满门大小，死无有葬身之地。"
        },
        {
          "character": "八头目",
          "type": "同白",
          "text": "想那梁太尉，此番出京，所带兵丁不少。寨主一人前去，倘有不测，岂不是画 虎不成，反类犬也？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "有道是“不入虎穴，焉得虎子”，俺窦某此去断无妨碍。"
        },
        {
          "character": "八头目",
          "type": "同白",
          "text": "但不知寨主几时起程？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "即刻起程。"
        },
        {
          "character": "八头目",
          "type": "白",
          "text": "待吾等与寨主饯行。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "好，喽罗的，将宴摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "窦尔敦",
          "type": "西皮导板",
          "text": "将酒宴摆列在这分金亭上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦尔敦、四头目同坐，同饮酒。"
        },
        {
          "character": "窦尔敦",
          "type": "西皮原板",
          "text": "尊列为细听某叙一叙衷肠： 想当年在河间谁不尊仰， 持双钩压绿林坐地分赃。 可恨那黄三泰老儿狂妄， 仗金镖借银两欺压豪强。 俺二人在李家店比武较量， 他不胜某的双钩，发暗器把某来伤。 因此上弃河间来在了连环套上， 蒙列为推举某方趁心肠。 大丈夫不报仇枉活在世上， 非是俺窦尔敦鼠肚鸡肠。 饮罢了杯中酒换衣前往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦尔敦换衣。"
        },
        {
          "character": "窦尔敦",
          "type": "西皮原板",
          "text": "看过了文房宝某细写端详： 将要言写在了书信之上， 这封书就是他要命的阎王。 尊列位在山岗休得盼望，"
        },
        {
          "character": "窦尔敦",
          "type": "西皮摇板",
          "text": "将御马到了手即转山岗。 中国京剧戏考 《连环套》【头、二本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦尔敦下。"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "看寨主此去，一定成功，我等好好看守山寨便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "窦尔敦上。"
        },
        {
          "character": "窦尔敦",
          "type": "二黄摇板",
          "text": "大英雄为报仇独下山岗， 山遥遥路曲曲甚是凄凉。 又只见月无光松声响亮， 施展我飞毛腿直奔营房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦尔敦下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二更夫同上。"
        },
        {
          "character": "更夫甲",
          "type": "念",
          "text": "头上一撮缨，"
        },
        {
          "character": "更夫乙",
          "type": "念",
          "text": "我是神机营的兵。"
        },
        {
          "character": "更夫甲",
          "type": "念",
          "text": "白日管烧火，"
        },
        {
          "character": "更夫乙",
          "type": "念",
          "text": "夜里来打更。"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "伙计，今有梁千岁，奉旨出京，在热河一带，行围射猎，咱们打更守夜，须要 小心。"
        },
        {
          "character": "更夫乙",
          "type": "白",
          "text": "可不是嘛，只是天气寒冷得很呐！"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "天气寒冷，我们不怕，我方才喝了二两烧刀，身上倒很暖和。"
        },
        {
          "character": "更夫乙",
          "type": "白",
          "text": "好吓，怪不得你不冷，你穿了水皮袄，敢是挡寒，你猜我怎么样？"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "莫非你也喝了酒啦吗？"
        },
        {
          "character": "更夫乙",
