      "name": "万年青",
      "hangdang": "小生"
    }
  ],
  "plot": "东晋之时，有刘晨、阮肇二人，入山采药，迷路不得归。遇二女子引入仙洞，饲以胡麻脱粟饭，相与寝处数\n日，仍由二女子送出。及到家中，向之呱呱而泣者，今则皤然一老翁矣。团聚问讯，而家人嗃嗃，妇子嘻嘻，\n俱属孙曾辈。只此一来复之间，已经过七十余年。",
  "notes": "剧本所述，但言刘晨而不及阮肇，想系编排者之疏漏。自开幕至终场，既无唱工可听，亦无做工可观，名伶\n均不曾串演，各舞台经理，往往排在前三出，凡遇吉庆事，最为合宜，或开寿筵，或备喜席，堂唱宴会，恒\n多点用是剧，藉神祝贺之忱焉。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘晨上。"
        },
        {
          "character": "刘晨",
          "type": "引子",
          "text": "蟾宫摘桂高仙手，独占鳌头天下知。"
        },
        {
          "character": "刘晨",
          "type": "念",
          "text": "仙家寂静洞门闭，鹤伴孤云去复还。只有桃花留不住，跟随流水到人间。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "下官刘晨，当年与兄弟同伴，上京赴试。蒙主龙恩，钦点文武状元。绕道还乡， 行至天台山游玩山景，被猛虎冲散。多亏麻姑圣母，引进桃源洞，将瑞鹤二 仙，许配我兄弟二人为婚。成亲七日以后，别过仙姑归家。盼望天色尚早，就 此前行。"
        },
        {
          "character": "刘晨",
          "type": "吹腔",
          "text": "兄弟双双上帝京， 蒙恩钦赐状元郎。 深山猛虎来冲散， 得会仙姑转回乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘晨下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "康宁上。"
        },
        {
          "character": "康宁",
          "type": "数板",
          "text": "老迈年苍苍，身壮又安康。精神虽如旧，不觉两鬓白如霜，不觉两鬓白如霜。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "我乃刘府管家康宁是也。只因我家太老爷，出将入相，上朝未归，只得府门伺 候。"
        },
        {
          "character": "刘晨",
          "type": "内白",
          "text": "趱行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘晨上。"
        },
        {
          "character": "刘晨",
          "type": "吹腔",
          "text": "观不尽奇花美景， 一时行到自家门。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "那旁好像康宁，怎么这等年迈了。是与不是，待吾冒叫一声。 吓！那旁坐的，敢是康宁？"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "喂，你是何人，敢叫吾康宁。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "我是你主人刘晨回来了。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "胡说。我家太老爷，去有七十余年，哪还象你这样白面书生。休得乱道。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "你若不信，现有传家之宝玉虎坠，拿去看来。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "哎呀，果然是太老爷回来了。小人叩头。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "起来。太夫人呢？"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "现在后堂。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "请出堂来相会。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "是。 吓，永庆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "永庆上。"
        },
        {
          "character": "永庆",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "请太夫人出堂。"
        },
        {
          "character": "永庆",
          "type": "白",
          "text": "有请太夫人出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老旦上。"
        },
        {
          "character": "老旦",
          "type": "念",
          "text": "光阴容易催人老，两鬓斑白似银条。"
        },
        {
          "character": "老旦",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "恭喜太夫人。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "有何喜事？"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "太老爷回来了。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "哦，你家老爷回来了。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "哦，夫人。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "吓，康宁过来。想你家太老爷去有七十余年，岂是这等白面书生？"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "太夫人不信，现有玉虎坠为证。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "哦，当真是你太老爷回来了。"
        },
        {
          "character": "刘晨、夫人",
          "type": "同白",
          "text": "哎呀，（夫人）（相公）吓！"
        },
        {
          "character": "刘晨、夫人",
          "type": "同哭相思",
          "text": "幼年夫妇两离分， 到今日七十有余春。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "康宁叩见太老爷、太夫人。"
        },
        {
          "character": "永庆",
          "type": "白",
          "text": "永庆叩见太老爷、太夫人。"
        },
        {
          "character": "刘晨、夫人",
          "type": "同白",
          "text": "起来。"
        },
        {
          "character": "康宁、永庆",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "老爷可把以往之事，说来妾身一听？"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "夫人听来。"
        },
        {
          "character": "刘晨",
          "type": "唱",
          "text": "兄弟双双到汴京， 叩蒙圣主点头名。 游山玩景虎冲散， 瑞鹤二仙配为婚。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "夫人",
          "type": "唱",
          "text": "想夫君终日常忧闷， 喜得今日转回家门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘子上。"
        },
        {
          "character": "刘子",
          "type": "唱",
          "text": "朝罢归来喜盈盈， 只见书生坐中厅。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "迎接太老爷。"
        },
        {
          "character": "刘子",
          "type": "白",
          "text": "康宁，那是何人，敢与太夫人同坐？"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "那就是去了七十余载的太老爷回来了。"
        },
        {
          "character": "刘子",
          "type": "白",
          "text": "起过一边。 母亲在上，孩儿拜揖。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "儿吓，这就是你爹爹回来了，向前见过。"
        },
        {
          "character": "刘子",
          "type": "白",
          "text": "是。 爹爹在上，孩儿拜见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。刘子妇上，刘子、刘子妇同拜。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "不消。起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘孙上。"
        },
        {
          "character": "刘孙",
          "type": "念",
          "text": "簪缨世代，阀阅家门。"
        },
        {
          "character": "刘孙",
          "type": "白",
          "text": "爹爹，孩儿拜见。"
        },
        {
          "character": "刘子",
          "type": "白",
          "text": "罢了。见过你祖父。"
        },
        {
          "character": "刘孙",
          "type": "白",
          "text": "吓，这就是祖父，待孙儿拜见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。刘孙妇上，刘孙、刘孙妇同拜。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "不消拜了。"
        },
        {
          "character": "刘孙",
          "type": "白",
          "text": "谢祖父。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘曾孙上。"
        },
        {
          "character": "刘曾孙",
          "type": "念",
          "text": "鳌头独占先，宫花插鬓边。"
        },
        {
          "character": "刘曾孙",
          "type": "白",
          "text": "爹爹，孩儿拜揖。"
        },
        {
          "character": "刘孙",
          "type": "白",
          "text": "罢了。见过你曾祖父。"
        },
        {
          "character": "刘曾孙",
          "type": "白",
          "text": "是。 曾祖父在上，待曾孙儿拜见。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。刘曾孙妇上，刘曾孙、刘曾孙妇同拜。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "不消拜了。 吓，夫人，自我去后，康宁、永庆，可曾定配花烛？"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "自相公去后，妾身终日忧闷，未曾与他们完婚。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "下官今日回来，和夫人当面与他二人完成花烛，你看如何？"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "老爷言得极是。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "康宁，永庆。"
        },
        {
          "character": "康宁、永庆",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "自你太老爷去后，耽误你二人佳期。今日当着你太老爷太夫人之面，你二人拜 完花烛。"
        },
        {
          "character": "康宁、永庆",
          "type": "同白",
          "text": "哎呀，小人若大年纪，还拜什么花烛。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "就是一百岁，也要拜的。"
        },
        {
          "character": "康宁、永庆",
          "type": "同白",
          "text": "多谢太老爷、太夫人。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "来拜吓。"
        },
        {
          "character": "康宁",
          "type": "念",
          "text": "七十八来八十三，"
        },
        {
          "character": "永庆",
          "type": "念",
          "text": "白发齐眉配姻缘。"
        },
        {
          "character": "康宁",
          "type": "念",
          "text": "我好似前朝彭祖临凡世。"
        },
        {
          "character": "永庆",
          "type": "念",
          "text": "我好似庐山老母降下凡。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "来吓。"
        },
        {
          "character": "永庆",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "我二人同入洞房吓。"
        },
        {
          "character": "永庆",
          "type": "白",
          "text": "哦哟若大年纪，还入什么洞房。"
        },
        {
          "character": "康宁",
          "type": "白",
          "text": "这是千百年好事，不要装腔，随我来吓。哈哈，丢丑了，丢丑了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康宁、永庆同下。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "下官今日回来，与夫人相会一面，我要上朝献丹展帕，还要入山修炼。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "相公，你看儿孙满堂，享不尽荣华富贵，还要入山修炼怎的？"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "本当不去，犹恐有误仙子之言。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "但凭相公。"
        },
        {
          "character": "刘晨",
          "type": "念",
          "text": "要效张良去修仙，"
        },
        {
          "character": "夫人",
          "type": "念",
          "text": "夫妻恩爱重如山。"
        },
        {
          "character": "刘晨",
          "type": "念",
          "text": "昔日洞中遇仙子，"
        },
        {
          "character": "夫人",
          "type": "念",
          "text": "世上不觉七十年。"
        },
        {
          "character": "刘孙",
          "type": "念",
          "text": "焚香答谢天地德，"
        },
        {
          "character": "刘子、刘子妇",
          "type": "同念",
          "text": "世代缨冠荣无边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "富贵上。"
        },
        {
          "character": "富贵",
          "type": "念",
          "text": "常侍金枝玉叶人，时随凤体伴龙行。"
        },
        {
          "character": "富贵",
          "type": "白",
          "text": "咱家，穿宫内监，富贵是也。只因我主寿满百岁，满朝文武，有五世同堂，有 耄耋之寿者，大小官员，一概加封，大赦天下，亘古至今，世所罕有。正是春 膏降雨露，万姓尽欢声。这且不言，昨日我主传旨，命咱家打扫金殿，悬灯结 彩。这才是松柏长青天地久，福如东海寿南山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "富贵下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鹤松寿、永长春、福康太、万年青同上。"
        },
        {
          "character": "鹤松寿",
          "type": "念",
          "text": "紫云深处务光明，"
        },
        {
          "character": "永长春",
          "type": "念",
          "text": "带露奇花映月芬。"
        },
        {
          "character": "福康太",
          "type": "念",
          "text": "岁岁花开人不老，"
        },
        {
          "character": "万年青",
          "type": "白",
          "text": "满屋蟠桃庆至尊。"
        },
        {
          "character": "鹤松寿",
          "type": "白",
          "text": "鹤松寿。"
        },
        {
          "character": "永长春",
          "type": "白",
          "text": "永长春。"
        },
        {
          "character": "福康太",
          "type": "白",
          "text": "福康太。"
        },
        {
          "character": "万年青",
          "type": "白",
          "text": "万年青。"
        },
        {
          "character": "鹤松寿",
          "type": "白",
          "text": "今当我主寿满百岁，候驾临朝，同庆百龄。你我分班伺候。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小监、大太监引皇上同上。"
        },
        {
          "character": "皇上",
          "type": "引子",
          "text": "九天金阙千朵光，紫气祥云照万方。"
        },
        {
          "character": "鹤松寿、永长春、福康太、万年青",
          "type": "同白",
          "text": "臣等见驾吾皇万岁，圣寿无疆。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "鹤松寿、永长春、福康太、万年青",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": "皇上",
          "type": "念",
          "text": "忆自登基四海宁，满天星斗照乾坤。太平一统民安乐，数满百龄万寿春。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "寡人，大晋天子，国号永寿在位。寿命齐天，万民乐业，乃朕之洪福也。孤今 日寿满百岁，众卿衣冠齐整，莫非为寡人祝寿？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "正是。万岁请上，臣等拜寿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘子上。"
        },
        {
          "character": "刘子",
          "type": "白",
          "text": "臣启万岁，今有七十年前，刘晨回朝。已在午门候旨。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "哦，刘晨去有七十余年，杳无踪迹。今日回来，真乃罕见。来，宣他上殿。"
        },
        {
          "character": "刘子",
          "type": "白",
          "text": "领旨。 万岁有旨，宣刘晨上殿。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘晨上。"
        },
        {
          "character": "刘晨",
          "type": "念",
          "text": "且将仙界事，奏与我主知。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "臣刘晨见驾，吾皇万岁。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "卿家何不抬头？"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "不敢抬头。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "刘晨你去七十余年，还是这等白面书生。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "臣在深山过了七日，世上不觉七十余年。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "寡人不信。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "万岁不信，臣有长生丹、展仙帕为证。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "长生丹有何妙处？"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "将仙丹放在御酒内，饮入腹中，发白转黑，齿落重生。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "展仙帕呢？"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "展仙帕展开，霞光万道，瑞气千条。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "内侍看宴。寡人与众卿同饮。"
        },
        {
          "character": "内侍",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "鹤松寿、永长春、福康太、万年青",
          "type": "同白",
          "text": "谢万岁。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "刘卿将展仙帕，展开一观。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘晨展帕。三仙女同上。"
        },
        {
          "character": "三仙女",
          "type": "同吹腔",
          "text": "彩云边， 蓦地里嘉祥现。 满朝尽欢。 走金殿，寿筵前， 齐把那仙丹展帕，前来进献。 这是太平年，同庆寿绵绵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同笑。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "真果是仙人传授秘密妙方也。内臣看香案伺候，同谢天地。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍允。"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "臣启万岁：臣献丹已毕，还要入山修炼。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "卿既回朝，还要入山修炼何来？"
        },
        {
          "character": "刘晨",
          "type": "白",
          "text": "本当不去，犹恐有误仙子之言。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "既然如此，命光禄司大摆筵宴，众卿与刘卿饯行。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "领旨。朝事已毕，请驾回宫。"
        },
        {
          "character": "皇上",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引皇上同下。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}