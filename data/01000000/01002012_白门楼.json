{
  "script_id": "01002012",
  "title": "白门楼",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "吕布",
      "hangdang": "小生"
    },
    {
      "name": "貂蝉",
      "hangdang": "旦"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "陈宫",
      "hangdang": "老生"
    }
  ],
  "plot": "曹操攻吕布于下邳。吕布日与貂蝉饮酒取乐，不以军务为意，出兵屡败，怒责诸将不力，将士俱出怨言，拟\n投曹操。陈宫知之，屡欲入内谏劝，俱为内监所阻。吕布部下宋宪、魏续、侯成，盗布赤兔马，献于曹操。\n张辽撞门入，告吕布。吕布大惊，易马出战，大败。吕布知事急，亲自巡城。曹操又命军士决水以灌之，吕\n布军益乱。吕布至白门楼，饮酒解闷，醉倒楼中。宋宪乃盗其画戟，掷于城下，缚吕布降曹操。曹兵一拥而\n入，陈宫、张辽、貂蝉，为水所阻不得出，俱为曹兵所擒。陈宫见曹操，大骂，曹操斩之。吕布至，曹操爱\n其勇，欲收为爪牙，时刘备在坐，恐不利于己，乃以丁原、董卓故事动之，曹操意决，命斩吕布。吕布大骂\n刘备忘恩负义而出。张辽见曹操，谓“濮阳火太小，不得焚死汝，殊为憾事。”曹操大怒，下座，欲亲斩之，\n关羽出而解救，请免其死。曹操即亲释其缚，张辽感恩，遂降。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小军、刘备、关羽、张飞同上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "桃园义气结金兰，"
        },
        {
          "character": "关羽、张飞",
          "type": "同念",
          "text": "保定汉室锦家邦。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "大哥，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "贤弟，丞相发兵徐州，二位贤弟，同到辕门候令。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "大哥请。带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李典、乐进、许褚、曹洪同上，同起霸。"
        },
        {
          "character": "李典、乐进、许褚、曹洪",
          "type": "同点绛唇",
          "text": "杀气英豪，儿郎虎豹，军威号，地动山摇，要把狼烟扫。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "李典。"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "乐进。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "许褚。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "曹洪。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "乐进、许褚、曹洪",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "丞相攻取徐州，你我两厢伺候。"
        },
        {
          "character": "乐进、许褚、曹洪",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套引曹操同上。刘备、关羽、张飞同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "忆昔扶汉朝，威风把名标。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "谢丞相。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "汉室空有主，兵权吾为先。怀志冲霄汉，横行宇宙间。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操。今奉天子明诏，带领人马，扫荡徐州，可恨吕布战又不战，降又不 降，使君妙计安在？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请丞相发令，备当协力攻打徐州。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好，就命使君带领众将，攻打徐州，捉拿吕布满门，不得有误。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、张飞同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众位将军，"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "兵发徐州。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小太监上，貂蝉、吕布同上。"
        },
        {
          "character": "吕布",
          "type": "西皮二六板",
          "text": "每日里闲无事逍遥饮酒， 到今日称心愿得坐徐州。 只恨的曹操贼屡次入寇， 他那里兴人马来夺徐州。 狗奸贼要擒我怎能得够？ 某若是抖威风群贼命休。 内侍臣看过了琼浆美酒， 我二人只欢乐多饮几瓯。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "看酒。"
        },
        {
          "character": "貂蝉",
          "type": "西皮摇板",
          "text": "老王允定下了连环巧计， 我这里用假意谅他不知。 但愿得曹丞相大兵齐至， 破徐州俱擒去万事全休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布、貂蝉同吃酒。"
        },
        {
          "character": "陈宫",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫上。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "曹操领兵夺徐州， 迷恋宫闱吕温侯。 将身来在宫门口， 见了公公说从头。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "烦劳公公，通禀温侯：陈宫有本启奏。"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "原来是公台，请少待，咱家与你启奏。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "启娘娘：公台有本启奏。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "温侯酒醉，有本改日再奏。"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "是。 公台，温侯酒醉，有本改日再奏。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "这话是何人讲的？"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "娘娘讲的。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "昔日有个商纣王， 宠爱妲姬乱朝纲。 温侯学了前朝样， 蝉貂好比苏娘娘。 大着胆儿宫门闯，"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "公台，这是什么地方，你不想着活了？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "顺者昌来逆者亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "温侯请酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "忙将盗马事，报与温侯知。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "来此已是。哪位在？"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "原来是张将军，到此何事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "烦劳公公通禀，张辽有本启奏。"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "温侯酒醉，改日再奏罢。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "何人讲的？"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "娘娘讲的。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "闪开了！ 启温侯：大事不好了！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "吓，何事惊慌？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "今日侯成，将温侯赤兔马与画戟盗去了。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "吕布",
          "type": "扑灯蛾",
          "text": "闻言怒气发，怒气发， 不由人咬碎钢牙。 盗去画戟赤兔马， 赤手空拳怎战杀。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "貂蝉",
          "type": "扑灯蛾",
          "text": "温侯不必怒气发， 妾身有言听根芽： 温侯威名谁不怕， 无有戟马也胜他。"
        },
        {
          "character": "吕布",
          "type": "扑灯蛾",
          "text": "吩咐众将备战马， 生擒活捉把贼拿。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "来，吩咐备马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布下。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "温侯吓，事到其时，此去定被曹公所擒，可怪不得你妻子了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马夫上，备马。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "有请温侯上马。 （四小军、大将自两边分上。吕布上，李典、乐进、许褚、曹洪同上，会阵。刘备、关羽、张飞同上，开打。 众人同下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，陈宫上。"
        },
        {
          "character": "陈宫",
          "type": "念",
          "text": "眼观旌旗起，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "耳听好消息。"
        },
        {
          "character": "龙套",
          "type": "内白",
          "text": "那贼人马杀进城来。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "将军，那贼人马如潮水一般，如何是好？好，好，张将军抵挡一阵。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。李典、乐进、许褚、曹洪同上，会阵，开打，擒张辽同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉上。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "温侯，温侯，呵吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李典、乐进、许褚、曹洪同上，擒貂蝉同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈宫上。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "温侯，温侯，呵吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李典、乐进、许褚、曹洪同上，擒陈宫同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吕布上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "貂蝉，貂蝉，呀吓！"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "擒去陈宫、张文远， 抢去我妻女貂蝉。 心中有事难交战，"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "舍死忘生战一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李典、乐进、许褚、曹洪、刘备、关羽、张飞同上，擒吕布同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同上，曹操上，坐帐。李典、乐进、许褚、曹洪、刘备、关羽、张飞同上。"
        },
        {
          "character": "李典、乐进、许褚、曹洪、刘备、关羽、张飞",
          "type": "同白",
          "text": "吕布被擒。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "使君请坐，众将退下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李典、乐进、许褚、曹洪、关羽、张飞同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，带貂蝉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉上。"
        },
        {
          "character": "貂蝉",
          "type": "西皮摇板",
          "text": "刀枪剑戟擒住我， 霎时不绑去绳锁。 进得帐来忙跪落， 丞相宽恩是为何？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "貂蝉为何不抬起头来？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "谢丞相。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "貂蝉女好妙计盖世功果， 献连环搭救了汉室山河。 叫人来送貂蝉养老宫坐， 太平时也许她安然快乐。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "谢丞相。"
        },
        {
          "character": "貂蝉",
          "type": "西皮摇板",
          "text": "叩罢头来谢恩德， 养老宫中去快乐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布、陈宫同上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "貂蝉转来！"
        },
        {
          "character": "吕布",
          "type": "西皮二六板",
          "text": "见貂蝉不由我心如烈火， 骂一声狗淫妇无耻的贱婆： 你本是老王允许配与我， 为什么暗地里又许董卓？ 自那日打从在凤仪亭经过， 你那里使颜色将我勾活。 我为你丁建阳被我刺过， 我为你二次里又杀董卓。 直指望你那里真心待我， 又谁知狗淫妇里应外合。 恨不得这一足将你结果！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉下。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "有陈宫向前去忙把话说： 貂蝉女是假意臣已奏过， 反说我老陈宫疑心太多。 到如今君臣们带了枷锁， 才知道貂蝉女里应外合。"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "陈公台你不必埋怨于我， 大丈夫生和死有何惧却。 自追悔恋酒色一时之错， 既死在阴人手自听头落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布、陈宫同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "使君传我将令：老夫收吕布，帐下为将，顺吾者昌，逆吾者亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎吓且住，方才丞相要收吕布，言到：顺者昌，逆者亡。这便如何是好？ 二位贤弟快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同上。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "大哥何事？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相要收吕布为将，言到：顺者昌，逆者亡。若收了吕布，你我弟兄大事难成。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "大哥吓！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "大哥不必心内慌，"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "小弟言来听端详："
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "今日要收吕布将，"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "就提董卓、丁建阳。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "着着着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同下。曹操上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，带陈宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲押陈宫同上。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "徐州城内失了计， 猛虎离山被他欺。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "老夫陈宫，今已被擒，此番进帐，落个骂贼而亡！"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "到如今怨不得性命为贵， 吕奉先可算得将中之魁。 将身儿来至在贼营队内， 生和死我不怕任贼所为。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "下面站的可是陈宫？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓公台，别来无恙？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "曹操吓，曹操！俺陈宫若知你心术不正，那日在旅店之中，一刀将你杀死，焉 有今日。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "住口！我问你，在中牟县纵放，弃职同行，要相扶老夫，共谋大事，因何不别 而行？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "若问前情，你且听了：当初释放于你，因你身居骁骑，颇有机谋，心雄胆壮， 谋刺国贼未成，只身逃至中牟。我乃一力相助，指望同兴汉室，岂知你心性太 偏，疑心太重。可叹吕氏全家，无端惨死，我忠言相劝，你非但不知追悔，反 敢昌言：宁我负人。因此弃你而行。也曾题赠，赠你“奸雄”二字！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我心不正，难道不如那吕布？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "吕温侯心无谋智，却不似你诡计奸刁，聚结豺狼，强霸诸侯，并吞州郡，久必 生乱。看来这汉室山河，难出你奸雄之手。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你倒心怀大志，腹隐奇谋，怎么也有今日？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "只恨那吕布，他不听吾言，心无定见，酒色伤身；若能依我而行，但看在濮阳 城些小之计，烧得你焦头烂额。若不中你哭丧之计，今日还坐守濮阳，怎能遭 你毒手！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我且问你，今日之事如何？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "在徐州我一箭未曾将你射死，今被你擒，一死而已。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "是吓，倒是你留名于后，只是你还有老母、妻子。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "哎，我闻“治天下者不害人之亲”，老母妻子，凭你处置。俺拼一死，并无挂 念。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公台心性痴迷，你是归顺老夫，以顺天心，你意下如何？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "吓吓呸！俺心已定，若改前言，除非日从西起。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公台之意，老夫相从。 来，老母、妻子，送回许都，不可怠慢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，将陈宫推去斩了！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "多谢明公，生死无悔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人推陈宫同下。龙套甲拿头上。"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "斩首已毕。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将陈宫尸首，不可损坏，带回原郡，搭下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "带吕布！"
        },
        {
          "character": "吕布",
          "type": "内西皮导板",
          "text": "今日里在小沛大败一仗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套斜门同上。吕布上。"
        },
        {
          "character": "吕布",
          "type": "西皮慢板",
          "text": "似猛虎离山岗落了平阳。 自幼儿出母胎情性傲强， 灭却了董卓贼各霸一方。 到如今陷小沛身入罗网， 要活命除非是转世还阳。"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "俺好比夏后羿月窟遭殃， 某好比公叔段命丧沙场。 俺好比汉高祖兵败咸阳， 某好比三齐王命丧未央。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "没奈何进帐去哀求丞相， 屈膝跪低下头吕布归降。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "被擒吕布。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "抬起头来。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "谢丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你虎牢关的威风何在？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "天下英雄怎敌丞相？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "怎比丞相？"
        },
        {
          "character": "曹操",
          "type": "三笑",
          "text": "哈哈，哈哈，哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "刘使君！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫有意将吕布收留帐下，你看如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "杀也在丞相，放也在丞相，可记得丁董之故事乎？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "本当将你收留，恐学那丁、董之故事。 来，斩！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "刘使君，你今为上坐客，布为阶下囚，为何在一旁多言？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相传令，谁敢违抗？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "可记得辕门射戟之时乎？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "天长日久，备倒失记了。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "你且听听！"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "大耳贼——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "忘却了辕门射戟， 有袁术差纪灵将你来逼。 那时节全亏我射戟神力， 一杆戟唬退了猛将姓纪。 到今日忘前情反做仇敌，"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "某死后定将你生魂来逼。 某只得二次里屈膝跪地，"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "温侯，难道你还怕死么？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "将军吓！"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "某死后汉室中英雄还有谁？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套押吕布同下，三鼓。龙套甲拿头上付与张辽。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "烈烈英雄辈， 钢刀把命追。 宠爱貂蝉女， 昏迷在宫闱。 今日刀下死， 此时埋怨谁？ 人头搭在宝帐内， 开言大骂狗奸贼！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "下站何人？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "瞎了儿的狗眼，连你张老爷都不认识了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "原来是火烧濮阳的火头军。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "可惜吓，可惜！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可惜什么？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "可惜濮阳的火小；若是火大，将你这奸贼烧死，免却我君臣的后难。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "今日被擒，还是这样性傲。 来，斩了！"
        },
        {
          "character": "张辽",
          "type": "三笑",
          "text": "哈哈，哈哈，哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "抓回来！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "要斩就斩，何必多言？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你为何在辕门发笑？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "俺乃天下豪杰，死在你这奸贼之手，岂不可笑？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张将军，你若归顺老夫帐下，必然重用。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "岂与你这逆贼同党。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "张将军你若不降，你家中还有妻室老小，依靠何人？你要再思再想。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "要俺归降，依我三件大事。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哪三件？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "头一件将温侯死首，不可损坏；第二件将他尸首，要金井玉葬；第三件，要你 这奸贼亲自下位松绑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某家代劳。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "后帐摆宴，与众位将军同饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}