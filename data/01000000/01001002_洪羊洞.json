{
  "script_id": "01001002",
  "title": "洪羊洞",
  "alias": [
    "孟良盗骨；一名：三星归位"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "孟良",
      "hangdang": "净"
    },
    {
      "name": "焦赞",
      "hangdang": "净"
    },
    {
      "name": "程宣",
      "hangdang": "丑"
    },
    {
      "name": "赵德芳",
      "hangdang": "老生"
    },
    {
      "name": "杨继业",
      "hangdang": "外"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "柴夫人",
      "hangdang": "正旦"
    }
  ],
  "plot": "北宋，杨继业撞碑后，遗骸藏于洪羊洞中。杨继业托梦杨延昭，嘱其取回。杨延昭乃命孟良往取。焦赞耻不\n被命，乃瞒过杨延昭，暗随孟良。孟良至洪羊洞，正欲取骨，觉后有人声，疑是番将，黑暗中急以大斧砍之，\n焦赞竟死。孟良忽疑被砍者哀声不类番将，急将尸身抬出，于月光中细察之，则焦赞也。孟良念结义之情，\n悲痛引咎，誓不独生，乃以杨继业遗骨，付于降番之宋兵，嘱其逃回，交付杨元帅，孟良即自刎。杨延昭\n得信，惊悼成疾，将星现于郊外，被八贤王赵德芳是射，遂至不起。",
  "notes": "因杨延昭将星为赵德芳所射，故剧中赵德芳探病时，杨延昭万分惊骇，剧中有“你、你、你，你不该放雕翎\n射我的前心”句，一连几个“你”字，极难顿挫。贵俊卿演此剧，唱“洪羊洞”之“洞”字，调最佳。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上，二鬼卒同上。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "在生为大将，死后作忠魂。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "吾乃杨继业鬼魂是也。只因六郎前番命人盗取尸骸，乃是假的；真尸骨现在洪 羊洞，第三层石匣内。我不免去到宋营，托兆与六郎便了。"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "我杨家保宋主忠心秉正， 到如今尸骸骨不曾回程。 六郎儿他命人搬尸回郡， 这都是萧天佐以假为真。 叫鬼卒——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二鬼卒同允。"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "驾阴风宋营来进， 见了那六郎细说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、二鬼卒同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二更鼓。家院提灯上，杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄原板",
          "text": "为国家哪何曾半日闲空， 我也曾征过了塞北西东。 官封我节度使皇王恩重， 霎时间身不爽瞌睡朦胧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。杨继业、二鬼卒同上。三更鼓。"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "听谯楼打罢了三更时分， 进宋营见六郎细说分明。 叫鬼卒急忙的大营来进， 又只见我的儿瞌睡沉沉。 叫鬼卒将他的阴魂推醒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭惊醒。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "猛抬头又只见去世爹尊。 曾记得两狼山何等光景， 哪有个人死后又能复生。 父子们重相逢犹如破镜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭睡。四更鼓。"
        },
        {
          "character": "杨继业",
          "type": "二黄摇板",
          "text": "我的儿休贪睡细听分明："
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "儿前番盗父的尸骸回郡， 这都是萧天佐弄假成真。 父尸骸在北国洪羊洞， 望乡台第三层那才是真。 父本当与我儿多把话论， 怕的是天明亮难以回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下，二鬼卒同下。五更鼓。家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "元帅醒来。"
        },
        {
          "character": "杨延昭",
          "type": "二黄导板",
          "text": "适才间遇我父来到宋营，"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "醒来时不由我遍体汗淋。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "宣孟二爷进帐。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "孟二爷进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良上。"
        },
        {
          "character": "孟良",
          "type": "念",
          "text": "不听皇王诏宣，单听杨家令传。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟少礼，请坐。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "谢坐。 唤末将进帐，有何军情？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟有所不知，昨日三更，偶得一梦，只见我父与我托兆，言道前番盗骨，乃 是假的。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "真的呢？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "真骸骨，现在北国洪羊洞望乡台第三层，那才是真。我有意命贤弟，二下番营 盗骨，不知贤弟意下如何？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "末将好比元帅跨下之骑，扬鞭就走，停鞭即止，听元帅传令。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "好，贤弟听令："
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "我命贤弟到北番，"
        },
        {
          "character": "孟良",
          "type": "念",
          "text": "行走哪怕路途难。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "但愿盗得尸骨转，"
        },
        {
          "character": "孟良",
          "type": "念",
          "text": "凌烟阁上美名传。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "好，好一个“凌烟阁上美名传”。小心了！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、孟良同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "焦赞上。"
        },
        {
          "character": "焦赞",
          "type": "念",
          "text": "事不关心，关心则乱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "念",
          "text": "忙将机密事，报与老爷知。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启禀老爷：元帅令孟二爷，二下番营盗骨。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "前番盗过了。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "乃是假的。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "真的呢？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "在北国洪羊洞望乡台第三层，那才是真。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "起过了。 元帅元帅，这就是你的不是。想我弟兄二人，焦不离孟，孟不离焦。为何今日 差他一人前去？我自有道理。 家院，倘若元帅要问，就说我染病在床。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "夫人若问？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "就说我染病在床。带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院带马。"
        },
        {
          "character": "焦赞",
          "type": "西皮摇板",
          "text": "元帅做事差又差， 差了孟良不差咱。 家院带过爷的马， 这场功劳岂让他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院带马，焦赞、家院同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孟良上。"
        },
        {
          "character": "孟良",
          "type": "西皮快板",
          "text": "元帅昨晚得一梦， 遇见了白发老元戎。 他言道：前番盗骨乃是假，真骸骨现在北国洪羊洞， 望乡台上第三层。 马鞭催动我的马走龙， 盗回尸骨立头功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "焦赞上。"
        },
        {
          "character": "焦赞",
          "type": "西皮快板",
          "text": "宋王爷坐江山风调雨顺， 全凭着杨家将扶保乾坤。 孟仁兄施板斧狼烟扫尽， 俺焦赞施钢鞭保定乾坤。 催马加鞭往前进， 盗不转尸骨誓不回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程宣上。"
        },
        {
          "character": "程宣",
          "type": "念",
          "text": "生在南朝长在番，思想故土难得还。老母望儿不能见，儿想老母难上难。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "在下程宣。当年跟随老王，大战唐二虎，多蒙太后，不忍杀害，与我当一名更 夫，看守洪羊洞。就此走走，走吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良上。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "呔！你可是奸细？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "爷爷饶命，我不是奸细，我是这里的更夫。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "多谢爷爷。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我听你讲话，不像此地人氏。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "本不是此地人氏，乃南朝人氏。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "怎样到此？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "当年跟随老王，大战唐二虎，流落在此。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我且问你，洪羊洞今在何处？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "随我来，就在前面。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "你可想回转南朝？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "想倒想，就是缺少盘费。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "等你孟二爷回来，将你带回南朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良下。焦赞上。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "呔！可曾看见一红脸大汉过去？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "方才过去。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞下。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "哎呀，且住。我看这黑脸大汉，不是好人，定是刺杀孟二爷的。待我从小道而 去，与孟二爷送信，就此走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程宣下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "孟良",
          "type": "内西皮导板",
          "text": "北国有个洪羊洞，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良上。"
        },
        {
          "character": "孟良",
          "type": "西皮快板",
          "text": "千里迢迢路不通。 扬鞭催动马走龙， 只见它锁上又加封。 板斧劈开洪羊洞， 只见里面黑洞洞。 一进二进连三进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞上。"
        },
        {
          "character": "焦赞",
          "type": "西皮摇板",
          "text": "后面来了焦克明。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "且住，有大马在此，想是二哥在里面，待我进去吓他一下。 呔！拿奸细。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "看斧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良劈死焦赞。焦赞下。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "适才有人喊道“拿奸细”，被我一斧劈倒，待我拖出洞外看看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良看。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哎呀，不好了！"
        },
        {
          "character": "孟良",
          "type": "西皮摇板",
          "text": "一见贤弟丧了命， 怎不叫兄痛在心。 哭、哭一声焦贤弟， 叫、叫一声焦克明， 休怪佩仓下绝情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程宣上。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "二爷可曾看见一黑脸大汉？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "被我一斧将他劈死。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "早就该死。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "咳，你可认得他？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "他是煤炭店的老板。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "他就是三关的焦二爷，被我一斧将他劈死。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "你将焦二爷劈死，如何去见元帅？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "这个……程宣你可要回转天朝？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "想倒想回去，缺少盘费。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "这有散碎银两，还有匣儿一个，顶在头上，见了元帅，去掉匣儿，方可下跪。 倘若元帅问到，你说我另有公干去了。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "现有板斧为证，你快去收拾收拾。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "待我去收拾收拾行旅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程宣下。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "且住，焦赞一死，叫我有何脸面，去见元帅。也罢，不免拜谢圣恩，寻个自尽 了罢。"
        },
        {
          "character": "孟良",
          "type": "西皮摇板",
          "text": "走上前来拜君恩， 回头再谢元帅情。 可叹焦赞误丧命，"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "也罢，"
        },
        {
          "character": "孟良",
          "type": "西皮摇板",
          "text": "弟兄作鬼一路行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良用斧自刎，下。程宣上。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "二爷，咱们一同走罢。 呵呀，二爷怎么自刎了？ 吓，我明白了。孟二爷将焦二爷劈死，也无有脸面，去见元帅，故此自刎洪羊 洞。待我把他二人掩埋起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程宣埋。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "好呢，埋好了。哎呀，这里还有两匹马。待我骑上一匹，再拉上一匹，这叫做 富贵有余。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程宣哦喝下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "孟良盗骨无音信， 好叫本帅挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院引程宣同上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "少站一时。 启禀元帅：小番要见。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "传。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院允。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "小番，元帅传你，小心了。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "是。元帅在哪里，元帅在哪里？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哽，胆大小番，见了本帅，为何不跪？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "去掉盒儿，方可下跪。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来，将盒儿去掉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院去盒。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "“令公尸骨”。啊呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "见尸骨不由我泪双流， 怎不叫人咬指头。 鲜血淋淋尸骨透， 禀明了太君快把骨收。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "谢元帅。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "小人叫程宣。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "程宣，你奉何人所差？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "奉孟二爷所差。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "有板斧为证。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "将板斧收下。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你孟二爷他往哪里去了？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "哦喝，元帅。孟二爷前去盗骨，焦二爷暗地跟随，孟二爷一时失手，将焦二爷 劈死洪羊洞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "劈死洪羊洞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "听说焦赞丧番营， 汗马功劳一旦倾。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦赞一死，孟二爷他往哪里去了？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "哦喝，元帅。孟二爷将焦二爷劈死，无有脸面，来见元帅，他自刎在洪羊洞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "他自刎在洪羊洞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄导板",
          "text": "听说是二贤弟命丧北洲，"
        },
        {
          "character": "杨延昭",
          "type": "叫头",
          "text": "焦赞，孟良，哎呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "好似钢刀刺心头。 叫程宣到北国去般尸首，"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "程宣",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "一路上要小心及早回头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程宣下。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "一霎时腹内痛心血上呕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭吐。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "浑身上下冷溲溲。 家院搀扶我上房来走， 怕的是保宋室不能到头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院搀杨延昭同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引赵德芳同上。"
        },
        {
          "character": "赵德芳",
          "type": "引子",
          "text": "驾坐清宫，听笙歌，一派嘹亮。"
        },
        {
          "character": "赵德芳",
          "type": "念",
          "text": "紫金冠凤翅双飘，滚龙袍玉带围腰。凹面锏文武皆怕，上金殿扬尘舞蹈。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "本御赵德芳。只因内侍报道，御妹夫身染重病，因此孤王亲自前去探病。 内侍，吩咐御林军摆驾伺候。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "御林军走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同上。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "带马。"
        },
        {
          "character": "赵德芳",
          "type": "二黄原板",
          "text": "我本是玉金枝大宋后根， 保定了我叔父锦绣龙庭。 内侍报御妹夫身染重病， 因此上我这里亲自来临。 耳边厢又听得虎声盈盈，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "又只见那猛虎下山林。 左拿弓右搭箭射准虎影，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人追虎形同下。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "这也是那猛虎自送残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": "杨延昭",
          "type": "内白",
          "text": "搀扶了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保搀杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄慢板",
          "text": "我杨家保宋主心血用尽， 最可叹焦孟将他命丧番营。 宗保儿搀为父病房来进， 休得要惊动了年迈太君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳、大太监、四大铠同上。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "来至在郡马府忙下金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、大太监同下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "迎接千岁。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "宗保免礼且平身。 问宗保你的父何处养静？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "现在病房。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "带路。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "又只见御妹夫瞌睡沉沉。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "醒来。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "适才间在荒郊闲游散闷， 遇见了一官长放雕翎。 对准我前心射一箭， 险些丧了命残生。 猛然间睁开了昏花眼，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "嗳，"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "我面前站定了对头人。 我和你一无有冤二无有怨恨， 你、你、你，你不该放雕翎射我的前心。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "听罢言来才知情， 却原来那猛虎是他本命星君。 我与你好亲眷无有伤损， 休把孤当作了放箭之人。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "八千岁驾临门恕臣有病，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "宗保，"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "宗保儿上前去替父参君。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哎，御妹夫，这病体从何而起？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哎，"
        },
        {
          "character": "杨延昭",
          "type": "哭",
          "text": "贤爷吓！"
        },
        {
          "character": "杨延昭",
          "type": "二黄慢板",
          "text": "自那日朝驾归安然睡定， 三更时梦见了年迈爹尊。 臣前番命孟良尸骸搬请， 尽都是萧天佐弄假成真。 真尸骨在北国洪洋洞， 望乡台第三层那才是真。 二次里命孟良番营来进， 又只见焦克明他私自后跟。 老军报他二人在洪羊洞丧命， 去了我左右膀难以飞行。 为此事终日里忧成此病， 因此上臣的病重加十分，千岁爷吓！"
        },
        {
          "character": "赵德芳",
          "type": "二黄原板",
          "text": "御妹夫休得要珠泪淋淋， 哪有个人死后又能复生。 叫宗保到后堂急忙相请， 请出了儿的母与祖母娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "有请祖母、娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君、柴夫人同上。"
        },
        {
          "character": "佘太君",
          "type": "二黄摇板",
          "text": "听说宗保一声请，"
        },
        {
          "character": "柴夫人",
          "type": "二黄摇板",
          "text": "急忙上前问分明。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "我儿醒来。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "耳边厢又听得有人声音，"
        },
        {
          "character": "杨延昭",
          "type": "哭",
          "text": "娘吓！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "猛抬头又只见年迈娘亲。 老娘亲所生我兄弟七个， 到如今白发人反送了儿黑发的身，儿的娘吓，好不伤情！"
        },
        {
          "character": "柴夫人",
          "type": "哭",
          "text": "哎呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "柴夫人近前来夫有话论， 必须要早晚间侍奉娘亲。"
        },
        {
          "character": "杨宗保",
          "type": "哭",
          "text": "爹爹吓！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "宗保儿跪床前听父教训： 必须要秉忠心扶保乾坤。 柴夫人，宗保儿，将我搀定， 杨延昭离病床叩谢龙恩。 再不能与我主把狼烟扫尽， 再不能与我主在那万马军营。 叩罢头抽身起站立不稳，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四鬼同上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "我面前站定了许多鬼魂。 焦克明在一旁心怀愤愤， 那孟、孟、孟佩仓笑嘻嘻，拱手相迎。 小岳胜在一旁威风凛凛，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊，"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "猛抬头又只见去世爹尊。 老爹爹在阴曹慢慢相等， 等候了你六郎儿一路同行。 叩罢头来抽身起心血上奔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭吐，三吐。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "保重了。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "无常到万事休去见先人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭死，四鬼引杨延昭同下。佘太君、柴夫人、杨宗保同哭。赵德芳上。"
        },
        {
          "character": "佘太君",
          "type": "二黄摇板",
          "text": "一见我儿丧了命，"
        },
        {
          "character": "柴夫人",
          "type": "二黄摇板",
          "text": "怎不叫人痛在心。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "劝太君休得要珠泪淋淋， 这一付千斤担有我担承。 急忙忙将老帐二堂摆定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君、柴夫人同下。"
        },
