  "plot": "山西太原任原，绰号擎天柱（《缀白裘》称任金刚，脚本中称为赛金刚），在山东泰安州天齐庙内，摆设擂\n台。已将期满，迄无敌手。至是宋江、吴用探知彼期满之后，即将来平梁山，乃命燕小乙前去打擂。并命李\n逵、花荣、林冲、秦明、王英、戴宗、时迁及一班女将，潜行混入州城，暗中帮助接应。既而任原果被燕青\n打死。官军闻讯，四出追捕，亦被梁山众英雄战败，并射死其主将王宏而回。",
  "notes": "按是剧脚本始终均用吹腔，尚系乱弹真本。原分《缴令》、《遣将》、《下山》、《擂台》、《大战》、\n《回山》六折。此即其全本也。\n此剧系出《后水浒·征四寇》中，其第三回所谓“燕青智扑擎天柱”者，即指此也。谭叫天中年，以武生戏\n著称，故于此剧颇擅长。当光绪十年秋，第二次来沪，在刘惟忠所开新丹桂内，曾经奏演。惟因病后第一次\n登台，足软无力，致大为座客所嗤。而与后来在新新舞台所演之《盗魂铃》同一败兴，第不如新新舞台之甚\n耳。然当时新丹桂营业，已从斯江河日下。因而宾主遂生意见，时有龃龉。而叫天亦遂不安其位而去沪矣。\n是亦《燕青打擂》一戏上之掌故也，兹因述考而偶忆及此，故先拉杂书之。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴用、林冲、花荣、李逵同上。"
        },
        {
          "character": "吴用",
          "type": "念",
          "text": "石碣天文聚将星，"
        },
        {
          "character": "林冲",
          "type": "念",
          "text": "喑呜叱咤起风云。"
        },
        {
          "character": "花荣",
          "type": "念",
          "text": "义旗指处人皆服，"
        },
        {
          "character": "李逵",
          "type": "念",
          "text": "板斧双劈神鬼惊。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "智多星吴用，"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "俺豹子头林冲，"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "俺小李广花荣，"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "咱黑旋风李逵。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "今日大哥升帐，我等两厢伺候。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大吹场。四龙套、四下手、宋江同上。"
        },
        {
          "character": "宋江",
          "type": "点绛唇",
          "text": "水泊英豪，替天行道，兵符抱，胸藏韬略，威名四海遥。"
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "义胆忠肝盖世无，心怀报国有良图。他年若遂凌云志，笑煞黄巢非丈夫。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "大哥在上，我等参拜。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众位兄弟少礼，站立两厢。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "俺，及时雨宋江。只因杀了阎婆惜，逃上梁山。蒙众家兄妹，推我为山寨之主。 前日探子报到，有神州总制王宏，新得一将，名唤赛金刚任原，英雄无敌。 高搭擂台，夸下海口，要打尽天下英雄好汉。百日完满，就要带兵平定俺梁山。 也曾命燕青前去打探。等他到来，便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青上。"
        },
        {
          "character": "燕青",
          "type": "念",
          "text": "打听不平事，报与大哥知。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "参见大哥。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "少礼。我命你去至神州，打探任原之事如何？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "小弟奉了大哥之令，去至神州。果然有个任原，夸下海口，卖下浪言，摆设擂 台，百日完满，就要起兵剿我梁山。那时小弟，要想上得擂台，将那厮打倒。 奈无大哥将令，不敢造次。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "竟有这等之事？待咱去到神州，上得擂台，将那厮活活擒来，方显俺的手段也。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "贤弟休要卤莽，此事必须商议而行。 吓，军师，此事当以何策处置？"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "此事不难。待小弟遣众兄弟，潜往神州，先把任原打翻，那各路官兵，就不敢 正眼觑我梁山也。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "如此就请军师传令。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "遵命。 吓，列位弟兄，哪位愿到神州，将任原打倒？忠义堂挂红领赏。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "俺燕青愿往神州，若不将任原打下擂台，誓不为人！"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "好！燕青听令。"
        },
        {
          "character": "吴用",
          "type": "吹腔",
          "text": "燕青将，手段强， 神拿七十二，敢夸张。 此番去往神州府， 得胜回山，名播扬。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "燕青虽然武艺高强，但是他一人，恐怕独力难支。谁人愿去帮助者，一同挂红 领赏。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "二位哥哥在上，也不是俺李逵夸口：此番俺去到擂台，若不将那厮做汤羊儿一 般，一只手揪住他脑袋，一只手拎着他的鸾带，擒上山来，捽在这忠义堂上， 听凭二位哥哥发落，俺也誓不为人。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "好！李逵听令。"
        },
        {
          "character": "吴用",
          "type": "吹腔",
          "text": "黑旋风，甚凶勇， 两柄板斧染腥红。 下山去好一似黑煞神， 果是英雄。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "花荣、林冲听令。那王宏兵强马壮，他二人若打倒任原，岂肯干休必然有一场 厮杀。你二人可扮做客商模样，潜往神州，暗地帮助他成功者。"
        },
        {
          "character": "吴用",
          "type": "吹腔",
          "text": "有任原，太夸张， 拔山举鼎，号金刚。 你二人端的是人强马壮， 搅得他地乱天荒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦明、王英暗同上。"
        },
        {
          "character": "花荣、林冲",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花荣、林冲同下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "秦明、王英听令。你二人可扮做挑担脚夫，混入城中，暗地接应者。你二人呵！"
        },
        {
          "character": "吴用",
          "type": "吹腔",
          "text": "猛如虎，貌似狼， 乔装结束气昂昂。 饶你有官兵千百万， 管叫他，无计猖狂。"
        },
        {
          "character": "秦明、王英",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦明、王英同下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "传女将们上堂。"
        },
        {
          "character": "众上手",
          "type": "同白",
          "text": "女将上堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "顾大嫂、孙二娘、扈三娘同上。"
        },
        {
          "character": "顾大嫂、孙二娘、扈三娘",
          "type": "同白",
          "text": "大哥在上，我等参见。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "军师有差。"
        },
        {
          "character": "顾大嫂、孙二娘、扈三娘",
          "type": "同白",
          "text": "参见军师。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "众女将听令：你等可扮作乞婆，混入神州，接应众弟兄者。"
        },
        {
          "character": "吴用",
          "type": "吹腔",
          "text": "女将们，快登程， 去往神州护燕青。 若得成功回山转， 方显梁山娘子军。"
        },
        {
          "character": "顾大嫂、孙二娘、扈三娘",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "顾大嫂、孙二娘、扈三娘同下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "传令已毕。命戴宗扮做公差，时迁扮做花子，来往打探消息者。"
        },
        {
          "character": "吴用",
          "type": "尾声",
          "text": "四下埋伏了牢笼计， 管叫他插翅也难飞。"
        },
        {
          "character": "宋江",
          "type": "尾声",
          "text": "方显俺及时雨的威名， 天下知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江、吴用同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四英雄、任原同上。"
        },
        {
          "character": "任原",
          "type": "白",
          "text": "来此擂台，一同上擂。"
        },
        {
          "character": "任原",
          "type": "念",
          "text": "英雄上擂台，好汉两边排。打死不偿命，愿者请上来。大喊三声谁敢来，谁敢 来？"
        },
        {
          "character": "徒弟",
          "type": "白",
          "text": "启禀师父：天气尚早，打擂的还靡有来呢。"
        },
        {
          "character": "任原",
          "type": "白",
          "text": "好生看守擂台。"
        },
        {
          "character": "徒弟",
          "type": "白",
          "text": "咋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "任原下。四上手、花荣、林冲、燕青、李逵同上。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "来此已是擂台，果然有大言牌在此。待俺看来："
        },
        {
          "character": "李逵",
          "type": "念",
          "text": "打尽世间无敌手，争交天下我为魁！"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "放你娘的屁！待我将它打碎了。"
        },
        {
          "character": "徒弟",
          "type": "白",
          "text": "呔！你这黑脸贼，将我的大言牌打碎。你敢上来与我较量么？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我先打死你个王八肏的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵打倒徒弟。"
        },
        {
          "character": "徒弟",
          "type": "白",
          "text": "有请师父。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "任原上。"
        },
        {
          "character": "任原",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "徒弟",
          "type": "白",
          "text": "打擂的来了。"
        },
        {
          "character": "任原",
          "type": "白",
          "text": "闪开了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "任原起打，李逵败下。燕青上，起打，燕青打任原倒，李逵上，劈任原死。众人同上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "你为何将他劈死了？他那主帅闻知，怎肯干休？此祸闯得不小，你我同回山寨 去罢。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "怕他娘的什么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、四家将、王宏同上。"
        },
        {
          "character": "王宏",
          "type": "点绛唇",
          "text": "剑戟霜寒，冲冠气岸，长虹贯，立志除奸，霎时风云变。"
        },
        {
          "character": "王宏",
          "type": "念",
          "text": "剑气冲开斗牛光，刀枪耀日落星霜。踏平水泊擒晁盖，踢破梁山捉宋江。"
        },
        {
          "character": "王宏",
          "type": "白",
          "text": "本镇，王宏。也曾命任原摆下擂台。今已打了九十九擂，只有一擂未满。待等 完满，就授他为先锋之职，起兵攻打梁山。 左右，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启禀元帅：任将军被梁山贼寇打死了。"
        },
        {
          "character": "王宏",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "王宏",
          "type": "白",
          "text": "众将官，一齐追赶！"
        },
        {
          "character": "王宏",
          "type": "吹腔",
          "text": "任他轴走上焰魔天， 我铁骑如云赶上前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花荣、林冲、燕青、李逵同上。"
        },
        {
          "character": "众人",
          "type": "同吹腔",
          "text": "忙忙逃出神州去， 遥望梁山，转回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、四家将、王宏同追上。"
        },
        {
          "character": "王宏",
          "type": "白",
          "text": "呔，贼寇休走，俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起打。花荣、林冲、燕青、李逵同败下，王宏、众人同追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、秦明、王英、顾大嫂、孙二娘、扈三娘同上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "俺，"
        },
        {
          "character": "秦明",
          "type": "白",
          "text": "霹雳火秦明，"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "矮脚虎王英，"
