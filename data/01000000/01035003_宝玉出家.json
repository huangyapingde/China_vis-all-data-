{
  "script_id": "01035003",
  "title": "宝玉出家",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "贾宝玉",
      "hangdang": "小生，黑蓬头，金箍，紫金冠，丹青花褶，项围红斗篷，执尘尾"
    },
    {
      "name": "贾政",
      "hangdang": "老生，员外巾，石青帔，黪三"
    },
    {
      "name": "茫茫大士",
      "hangdang": "净，道人装，白蓬头，白满，绿开氅，执尘尾"
    },
    {
      "name": "渺渺真人",
      "hangdang": "外，僧人装，昆卢帽，虬髯，红褶子，执尘尾"
    },
    {
      "name": "稍水甲",
      "hangdang": "付"
    },
    {
      "name": "稍水乙",
      "hangdang": "丑"
    },
    {
      "name": "下书人",
      "hangdang": "杂"
    }
  ],
  "plot": "贾宝玉考中第七名举人，场后即随茫茫大士、渺渺真人出家。为尽父子之情，特至江岸拜辞贾政。时贾政自\n金陵乘舟北归，于途中得家书，知贾宝玉中举，场后走失。方闷卧船舱，仿佛见贾宝玉随一僧一道至，惊醒\n时去犹未远。众欲追之，贾政知其从仙人游，止勿追。",
  "notes": "《红楼梦》一书，为小说中之翘楚也。荣国、宁国两府之事实，有与无有不必论，而其叙述详明。前后印照，\n文情相生，允称杰作。贾宝玉一乳臭小孩，俨然为怡红院之主人翁，必欲如是鉴定者，以其善于用情耳。\n贾宝玉果真有情，而荣、宁两府之女子，焉知非含情脉脉，钟于一人之身？各房使唤婢女，屈指何止百数，\n无一非温文尔雅，令人一见留情。不然，贾宝玉亦何至出家，为忏悔之地耶？总之为情所误，不受束缚，必\n使脱离。贾宝玉初次乡试，即高中第七名经魁。少年科第，张大门楣，有不可限量者。乃顿然觉悟，榜发即\n行。父母妻妾，欲挽无从。当然涕泗滂沱，万分怜惜。而有识之士，别有见解，以为贾宝玉至此出家，即贾\n宝玉一身之幸福也。\n近来梅兰芳、欧阳予倩等，将《红楼梦》小说，摘取一段，编排戏剧者，不一而足。如《黛玉葬花》、《晴\n雯撕扇》之类。咸谓情致缠绵，有声有色。兹之《宝玉出家》，亦属名艺员手笔而观剧诸君，可以一扩眼界\n矣。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "火彩，刀跋。茫茫大士、渺渺真人引贾宝玉同上。"
        },
        {
          "character": "贾宝玉",
          "type": "念",
          "text": "世上劫灰万重烧，"
        },
        {
          "character": "茫茫大士",
          "type": "念",
          "text": "女娲补天也空劳。"
        },
        {
          "character": "渺渺真人",
          "type": "念",
          "text": "一朝悟道见真性，"
        },
        {
          "character": "贾宝玉、茫茫大士、渺渺真人",
          "type": "同念",
          "text": "太虚幻境走一遭。"
        },
        {
          "character": "茫茫大士",
          "type": "白",
          "text": "俺，茫茫大士是也。"
        },
        {
          "character": "渺渺真人",
          "type": "白",
          "text": "俺，渺渺真人是也。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "怡红院主人贾宝玉是也。"
        },
        {
          "character": "茫茫大士、渺渺真人、贾宝玉",
          "type": "同白",
          "text": "请了，请了！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "二位仙师，咱三人且到太灵幻境，谒见警幻仙姑去者。"
        },
        {
          "character": "茫茫大士",
          "type": "白",
          "text": "且慢。你是父母生长，肉身养育之恩，不可不报。你父亲现在常州江边船中。 我二人同你前去，叩别一番，再到太虚幻境不迟。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "有劳二位仙师了。"
        },
        {
          "character": "贾宝玉",
          "type": "二黄原板",
          "text": "生长绮罗花丛中， 男欢女爱享华荣。 大观园里锦绣地， 朝朝暮暮乐无穷。 十八年来抛岁月， 十二金钗半凋零。 父母生我恩义重， 蟾宫折桂成了名。 一朝悟道脱凡景， 叩别我父把仙界登。"
        },
        {
          "character": "茫茫大士、渺渺真人",
          "type": "同白",
          "text": "神瑛使者，随我来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "茫茫大士、渺渺真人同笑。茫茫大士、渺渺真人、贾宝玉同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾政上。"
        },
        {
          "character": "贾政",
          "type": "引子",
          "text": "扶柩归南，大事毕，转回顺天。"
        },
        {
          "character": "贾政",
          "type": "念",
          "text": "日月如梭去如风，人生一世枉劳形。富贵皆是前生定，到头只怕一场空。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "老夫贾政。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家丁、二院子同暗上，分两边站。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "金陵人氏，世居京师官居吏部郎中之职。前年钦命江南学政，科场已毕回朝交 旨。只因老母年迈，奏明终养。不幸老母寿终，将灵柩送回金陵下葬。大事已 毕。前日接到家信，且喜家产赏还，官复原职真，乃皇恩浩荡也！"
        },
        {
          "character": "下书人",
          "type": "内白",
          "text": "嗯哏！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下书人上。"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "小人与大人叩头。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "罢了。到此何事？"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "有家书呈上。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "呈上。下边伺候。"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下书人下。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "家信到来，待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政看。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "呵！宝玉得中七名举人，贾兰二百三十名举人。可喜呀可喜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政笑。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "这是祖宗有德，上天垂佑，家门之幸也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政笑。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "待我往下看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政看。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "吓！宝玉出场，怎么走失了？此事真乃奇怪。好一个有道明君，命地方官各处 寻找。这就不愁找着了。 家院！"
        },
        {
          "character": "院子甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "人役可齐？"
        },
        {
          "character": "院子甲",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "挑轿打道江岸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政起，上轿。吹六马令。众人同转场。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "禀大人：来至江岸。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "传稍水走上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "传稍水。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二稍水同上。"
        },
        {
          "character": "二稍水",
          "type": "同白",
          "text": "来了来了！ 稍水与大人扣头。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "罢了。将船向北进发。"
        },
        {
          "character": "二稍水",
          "type": "同白",
          "text": "遵命。 开船了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二稍水同拔锚。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "上得船来——"
        },
        {
          "character": "贾政",
          "type": "念",
          "text": "归心忙似箭，千里奔家乡。"
        },
        {
          "character": "贾政",
          "type": "二黄原板",
          "text": "坐舟中思姣儿心中烦恼， 不由我老贾政珠泪嚎啕。 实指望养姣儿终身有靠， 父子情半路途各奔一条。 叫稍公你与我摇橹泊棹， 又只见日西沉影挂树梢。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "家院，前面什么所在？"
        },
        {
          "character": "院子甲",
          "type": "白",
          "text": "常州地界。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "你看天色将晚，将船泊住，明晨早行。"
        },
        {
          "character": "院子甲",
          "type": "白",
          "text": "大人吩咐：将船泊住，明晨早行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二稍水同应，同下锚。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "家院，看酒来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政饮。〖吹牌子〗。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "将杯撤去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政睡。"
        },
        {
          "character": "贾宝玉",
          "type": "内二黄导板",
          "text": "出科场见仙师邀赴仙境，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火彩。茫茫大士、渺渺真人、贾宝玉同上。"
        },
        {
          "character": "茫茫大士",
          "type": "白",
          "text": "你父亲在官船以内。前去叩别，以报养育之恩。我二人在山前相候着。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "有劳仙师指引了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "茫茫大士、渺渺真人同下。扭丝。"
        },
        {
          "character": "贾宝玉",
          "type": "二黄摇板",
          "text": "叩别我老爹爹养育之恩。 迈步儿我且把官船来进， 又只见老爹尊盹睡昏沉。 急忙忙走上前忙跪定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阴锣。贾政惊醒。"
        },
        {
          "character": "贾政",
          "type": "二黄摇板",
          "text": "猛抬头又只见宝玉娇生。 你在那荣国府何等光景， 你、你、你为何出场来走失无踪？ 我本当下位来将儿抱定——"
        },
        {
          "character": "贾宝玉",
          "type": "回龙",
          "text": "尊一声老爹爹细听儿言："
        },
        {
          "character": "贾宝玉",
          "type": "二黄快三眼",
          "text": "吾的父养姣儿一十八年。 终日里多教诲恩重如山， 日餐高粱穿文绣高楼大厦自安然。 祖母太君千般爱， 阿娘抚养更周全。"
        },
        {
          "character": "贾宝玉",
          "type": "二黄原板",
          "text": "最不该终日游荡不把书念， 最不该姐妹丛中学缠绵。 最不该吟月歌风抛岁月， 最不该傍花随柳贪笑玩。 大比年立志把场进， 侥幸折桂中经元。 叩别严尊从此去， 太虚幻境为了仙。 我父不必常挂念， 这就是一子成佛，七祖升天。 叩罢头欠身起忙登江岸，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉叩头。贾政醒。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "我儿不要行礼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉走。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "宝儿慢走！"
        },
        {
          "character": "贾宝玉",
          "type": "二黄原板",
          "text": "父子们要相逢梦中团圆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "我儿慢走，为父赶你来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（茫茫大士、渺渺真人拉贾宝玉同急上，贾政追上。茫茫大士分。火彩。贾政坐。贾宝玉、茫茫大士、渺渺"
        },
        {
          "character": null,
          "type": "text",
          "text": "真人同上下场门高场。）"
        },
        {
          "character": "茫茫大士",
          "type": "白",
          "text": "贾大人莫要追赶。听小仙一言道来！"
        },
        {
          "character": "茫茫大士",
          "type": "念",
          "text": "各自归各界，仙凡从此分。我携顽石去，交与天上人。"
        },
        {
          "character": "茫茫大士",
          "type": "西皮二六板",
          "text": "世人愁肠听我讲， 儿女姻缘本无常。 女娲氏炼石补天上， 剩下顽石不曾伤。 千年万载变玉样， 投生人间做儿郎。 作了一段繁华梦， 大劫成灰不再扬。 小仙带他西天上， 仍作顽石归大荒。"
        },
        {
          "character": "茫茫大士",
          "type": "白",
          "text": "宝玉随我去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火彩。贾宝玉、茫茫大士、渺渺真人同下。四青袍、二院子、下书人同上。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "大人不知哪里去了？ 在这里！ 大人醒来！"
        },
        {
          "character": "贾政",
          "type": "西皮导板",
          "text": "我父子正相会二仙冲散，"
        },
        {
          "character": "贾政",
          "type": "西皮摇板",
          "text": "一霎时不见了所为哪般？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下书人扶贾政。"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "大人追赶何人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾政两看。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "我么？追的宝玉。"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "待我等追去。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "且慢！不必追了。听我一言道来！"
        },
        {
          "character": "贾政",
          "type": "西皮流水板",
          "text": "他本是含玉降了生， 上有字迹写通灵。 貌如冠玉原不俗， 过目成诵真聪明。 都只为太君心爱重， 左右不离小姣生。 今得经魁名成就， 弃我出家把仙界登。"
        },
        {
          "character": "二院子、下书人",
          "type": "同白",
          "text": "大人不必烦恼。去到荣国府，见了太太，再作道理。"
        },
        {
          "character": "贾政",
          "type": "白",
          "text": "好！开船回府。"
        },
        {
          "character": "贾政",
          "type": "三叫头",
          "text": "宝玉！我儿！孩儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}