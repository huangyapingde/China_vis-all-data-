{
  "script_id": "01040004",
  "title": "倒厅门",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "满堂娇",
      "hangdang": "小旦"
    },
    {
      "name": "张善",
      "hangdang": "老生"
    }
  ],
  "plot": "《西游记》中，往西方取经之玄奘法师唐三藏，相传俗姓陈，其父系一知县。上任时误雇盗船。至中途，被\n盗抛落江心，又强偕陈之妻小。顶陈之名，冒陈之官，捧檄至江右上任。陈妻以腹中有孕，冀留陈氏一点骨\n血。故暂忍辱，未即死。迨及临蓐，适蛟洪为患，该县人畜大半淹没，陈妻即将小儿生年月日，及其父母姓\n氏籍贯，写明大略，置之血儿胸腹，系儿于木板上，任其随流浮去。后儿得遇救，自小即茹斋好佛云。此即\n唐三藏陈玄奘坠地以前之概略。而此《倒厅门》剧中之陈奶奶殷氏即是唐三藏之母。腹中怀孕，所怀即是\n《西游记》中之唐僧。所称洪州知县陈光蕊之真身，即是唐三藏之父。现在冒充陈光蕊之刘洪，即是当初盗船\n中之强盗。盖殷氏既被胁，无奈只得忍从。既到县衙，不免想起丈夫，心酸欲哭，犹恐被人看出，故乘假官\n下乡查荒之日，潜至倒厅门内，私自啼哭。倒厅门者，县署中分别内外处之一座朝北反厅也。殷氏方私哭，\n适差头张善，因日前新官上任时。陈奶奶曾写给“机侯”二字，心中不解。特地进内衙求教。忽闻哭声，根\n询原由，二人遂一在门内，一在门外，告述真官被害，及将来产生遗腹时乞救之情。张善慨然立誓，遂允与\n殷信至京都，乞援于殷氏之父云。",
  "notes": "此剧为正旦、正生唱做兼备之苦情戏。各舞台大可注意排演之。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "满堂娇上。"
        },
        {
          "character": "满堂娇",
          "type": "引子",
          "text": "满怀心腹事，尽在不言中。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "奴家殷氏满堂娇，许配陈光瑞为妻。我夫妻收拾上任，行至九江口上，遇了贼 舡，被水贼刘洪，将我家老爷打落江心而死。贼人顶名冒替，来在洪州上任， 今日贼人出衙查旱去了，不免去到倒厅门上，痛哭一番我家老爷，表表夫妻之 情。"
        },
        {
          "character": "满堂娇",
          "type": "西皮原板",
          "text": "墙里栽花墙外开， 惹得蜜蜂将花采。 蜂见花儿朝下落， 花儿见蜂展放开。 蜜蜂好似陈光瑞， 花儿比我女裙衩。 夫妻正在风流处， 西北玄天降下雨来。 蜜蜂见雨腾空去， 花儿见雨掉下瓣来。 夫妻若要重相见， 除非是蜂儿重生花儿重开。 行行来在倒厅门， 痛哭几声转回府来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张善上。"
        },
        {
          "character": "张善",
          "type": "西皮摇板",
          "text": "大老爷打罢了退堂鼓， 又来了当差应役人。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "外助张善。我家老爷领凭上任以来，是我带领人役三班，迎接十里长亭，不知 哪个冒犯我家老爷。我家老爷大怒，传内班，打外班，传外班，打内班，看看 打到我张善头上来，多亏陈奶奶，轿内讲情饶恕不打。陈奶奶临行，留下“机 侯”二字，是我解它不开，今天老爷出门去查旱，不免去到倒厅门上，一来叩 谢深恩，二来领教“机侯”二字。"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "前任老爷把官下， 新官上任理民情。 文约不到传牌到， 传牌以上写得清。 上写着五柳胡须金丝面， 却为何赤脚蓬头血染红。 昨日里迎接十里亭， 怒恼老爷要动刑。 吩咐内班将外班打， 在外班头上也动刑。 眼看打着我张善， 多亏了奶奶讲人情， 临行留下“机侯”字， “机侯”二字解不清。 老爷出衙去查旱， 倒厅门上谢恩情。 行一步，来在了倒厅门上。"
        },
        {
          "character": "满堂娇",
          "type": "哭板",
          "text": "哭一声陈光瑞， 骂一声水贼刘洪仇人！"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "又听奶奶放悲声。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "啊？张善来到倒厅门上，里面痛哭为何呢？喃哈，是了，想必是我家陈奶奶， 拷打哪个丫鬟，在此当面不敢痛哭，来在倒厅门上，背哭几句，也是有的。也 罢，不免在此咳嗽一声。她有来言，我有去语。 响哈。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "外边何人咳嗽？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "外面张善。里面说话何人？"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "是你陈奶奶在此。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "不知陈奶奶在此。张善在门外与陈奶奶叩头。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "张善，你不在衙内侍奉你家老爷，你来在倒厅门上做甚？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "奶奶不知，昨日小人带领三班衙役，迎接我家老爷上任，也不知哪个冒犯我家 老爷，老爷吩咐内班打外班，外班打内班。眼看打着我张善头上，多亏你陈奶 奶讲情，临行留下“机侯”二字，也是我张善才浅，解它不清。今日老爷查旱 去了，来在倒厅门上，一来叩头谢恩，二来领教“机侯”二字。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "你是久在衙下，还是新入公堂呢？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "说什么久在衙下，新入公堂。是我侍奉三位老爷，全都高升了。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "既是侍奉三位老爷高升去了，你连这“机侯”二字，解它不清，怎样奉上？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "是，我是聪明一世，懵懂一时。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "好一个“聪明一世，懵懂一时”。你老爷新官上任以来，不知仓内粮有多少， 库内银有多少。官不报吏，吏不报民。这就是“机侯”二字。将话说明，是你 去罢。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "我家奶奶吊代字，想必是有心腹之事。也罢，不免在此门外且听几句，听她说 些什么。正是："
        },
        {
          "character": "张善",
          "type": "念",
          "text": "要知心腹事，且听口中言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张善下。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "张善，是你们去了，你们去了。"
        },
        {
          "character": "满堂娇",
          "type": "哭板",
          "text": "哭一声老爷陈光瑞， 恨只恨杀人强盗贼刘洪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张善上。"
        },
        {
          "character": "张善",
          "type": "唱",
          "text": "张善才行未两步， 又听奶奶放悲音。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "呵，张善将身未动，忽听我家陈奶奶，痛哭哭几声陈光瑞，那本是我家老爷名 讳，恨只恨杀人强盗刘洪，他是何人？也罢，不免在此咳嗽一声。她有来言， 我有去语。 呵哈！"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "外边是何人咳嗽？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "外即张善。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "张善，你还未曾去么？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "非是小人未去，我张善听见奶奶痛哭一声陈光瑞，那本是老爷名讳，恨只恨杀 人强盗刘洪，他又何人？"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "张善你听见了？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "小人听见了"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "哎呀不好了，我在里面痛哭几句，又被张善听去，不免说几句狠言大话，恐吓 于他，走了也未见得。 呀，说是张善。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "陈奶奶。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "你来在倒厅门上为何？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "适才言讲明白，一来叩头谢恩，二来领教“机侯”二字。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "你且住口！闻知你家老爷，不在衙下，你来到倒厅门上，不是采花，便是折柳。 不是杀官，便是夺印。等我家老爷回得衙来，对他言语，焉有你的命在？"
        },
        {
          "character": "张善",
          "type": "西皮摇板",
          "text": "忽听奶奶叫一声， 倒叫张善吃一惊。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "哎，我的陈奶奶，说我来在倒厅门上，不是采花，定是折柳，不是杀官，定是 夺印。等我家老爷回得衙来，对他言说，焉有我命？这这这便如何是好。哦呵， 是了，她拿大话恐吓于我，难道我无大话，畏吓他人不成么！ 奶奶不好了！"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "怎么样子？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "洪州堂上，出了三盗。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "哪三盗？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "天生一盗，地生一盗，洪州堂上一盗。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "天？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "神盗。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "地？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "鬼盗。"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "洪州堂上？"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "出了杀人的强盗！"
        },
        {
          "character": "满堂娇",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "满堂娇",
          "type": "西皮摇板",
          "text": "忽听张善把话明， 倒叫满堂吃一惊。 有心要把实话讲， 怕是张善走漏风。"
        },
        {
          "character": "张善",
          "type": "西皮摇板",
          "text": "奶奶有话你请讲， 我张善不是走风的人。"
        },
        {
          "character": "满堂娇",
          "type": "西皮摇板",
          "text": "画龙画虎难画骨， 知人知面不知心。"
        },
        {
          "character": "张善",
          "type": "西皮摇板",
          "text": "张善这里跪流平， 尊声过往神灵听： 我若把那风声走， 死在千军万马营。"
        },
        {
          "character": "满堂娇",
          "type": "西皮摇板",
          "text": "见张善把誓盟， 细听满堂说分明： 洪州堂不是姓陈——"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "姓什么？"
        },
        {
          "character": "满堂娇",
          "type": "唱",
          "text": "不是你陈老爷，"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "他、他是何人？"
        },
        {
          "character": "满堂娇",
          "type": "唱",
          "text": "他是杀——"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "“杀”什么？"
        },
        {
          "character": "满堂娇",
          "type": "唱",
          "text": "杀人强盗贼刘洪。"
        },
        {
          "character": "张善",
          "type": "白",
          "text": "我家老爷家住哪里？"
        },
        {
          "character": "满堂娇",
          "type": "西皮导板",
          "text": "你老爷家住四川地，"
        },
        {
          "character": "满堂娇",
          "type": "西皮慢板",
          "text": "他本是两榜进士公。 万岁见他文才好， 才命他洪州来安民。 依我就打旱路走， 你老爷要从水路行， 老爷差人把船雇， 船家耽误大事情。 刘洪水贼来得慢， 你老爷一见把气生。 上船来打他四十板， 刘洪恼恨在心中。 大船行在江心内， 他向你老爷要金银。 你老爷新官来上任， 哪有金银与贼人。 强贼刘洪心怀恨， 他将你老爷打江心。 你老爷江心丧了命， 贼人逼我要成亲。 满腹冤情对你讲， 你千万莫要走漏风声。"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "一见奶奶把话明， 倒叫张善恼在心。 有朝贼人犯我手， 杀他一刀问一声。 陈老爷江心丧了命， 家中还有什么人？"
        },
        {
          "character": "满堂娇",
          "type": "西皮原板",
          "text": "家中还有太夫人， 太老爷朝中做公卿。"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "太老爷京城做公卿， 为何不写信到京城？"
        },
        {
          "character": "满堂娇",
          "type": "西皮摇板",
          "text": "有心要把家书写， 无人送书走一程。"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "奶奶你把家书写， 张善送书走一程。"
        },
        {
          "character": "满堂娇",
          "type": "西皮原板",
          "text": "有句话儿不好讲， 讲出好说不好听。"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "奶奶有话且请讲， 就死在阴曹对谁明。"
        },
        {
          "character": "满堂娇",
          "type": "西皮原板",
          "text": "也是怀胎我身有孕， 是男是女不知情。 若要生下花大姐， 母女悬梁在倒厅； 若要生下男儿后， 何人搭救出火坑？"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "奶奶身上有了孕， 是男是女不知情。 奶奶生下花大姐， 张善不管闲事情； 奶奶生下陈门后， 我张善搭救出火坑。"
        },
        {
          "character": "满堂娇",
          "type": "西皮原板",
          "text": "出火坑来出火坑， 二人久后拜门生。"
        },
        {
          "character": "张善",
          "type": "西皮原板",
          "text": "奶奶错把话来讲， 哪有书班拜门生！"
        },
        {
          "character": "满堂娇",
          "type": "西皮原板",
          "text": "叫张善坐上受我拜， 再叫张善听分明： 家书送在京城地， 你叫我父快发兵。 若要发兵来到此， 好救奴家出火坑。"
        },
        {
          "character": "张善",
          "type": "西皮原板",
