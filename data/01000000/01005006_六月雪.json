{
  "script_id": "01005006",
  "title": "六月雪",
  "alias": [
    "斩窦娥；一名：羊肚汤"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "窦娥",
      "hangdang": "正旦"
    },
    {
      "name": "蔡母",
      "hangdang": "老旦"
    },
    {
      "name": "禁婆",
      "hangdang": "丑旦"
