{
  "script_id": "01002003",
  "title": "祭长江",
  "alias": [
    "祭江"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "孙尚香",
      "hangdang": "正旦"
    }
  ],
  "plot": "赵云截江夺斗后，孙夫人独居江东。后关羽、张飞遇害，刘先主兴师大伐东吴，被陆逊用火攻之计，连营七\n百余里尽付一炬，先主仅以身免，赖赵云救往白帝城暂避。孙夫人在吴闻信，误谓先主已死，不胜悲痛，乃\n请于国太，欲往江边祭奠，以尽夫妇之谊，国太允之。夫人至江边，易白衣冠望西号哭，竟投江而死。后人\n相传孙夫人投江后，上帝嘉其贞洁，封为枭姬。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "孙尚香",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四御林军、二宫女、孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "二黄慢板",
          "text": "曾记得当年来辞君， 棒打鸳鸯两离分。 叹皇叔遭不幸龙归海境， 不由奴日夜里珠泪淋淋。 内侍臣摆驾江边来进， 清风一去未亡人。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "祭礼摆下，着衣更换，两厢退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四御林军同下。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "设祭长江岸，举目望西川。梦魂何日见，"
        },
        {
          "character": "孙尚香",
          "type": "叫头",
          "text": "夫君，先主！"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "空自珠泪涟。"
        },
        {
          "character": "孙尚香",
          "type": "二黄导板",
          "text": "孙尚香在江边心中酸疼，"
        },
        {
          "character": "孙尚香",
          "type": "三叫头",
          "text": "夫君，先主！啊呀！"
        },
        {
          "character": "孙尚香",
          "type": "回龙",
          "text": "尊一声汉皇叔细听分明："
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "好夫妻恶姻缘悲哀告禀， 凭空中便见听一点心诚。 可叹你大英雄出身被困， 可叹你结桃园义共死生； 可叹你破黄巾声名未重， 可叹你虎牢关方显成名； 可叹你舍徐庶卧龙三请， 可叹你水镜庄得一贤伦； 可叹你当阳道夏口夜奔， 可叹你全仗着诸葛先生； 可叹你跳檀溪险些丧命，我的夫吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下锣。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "可叹你入虎穴东吴招亲。 为报仇在猇亭遇见陆逊， 又谁知那小贼果有才能。 你不该七百里连营扎定， 烧死了众儿郎百万雄兵。 人报道你在白帝城丧命， 那时节得凶信魂魄离身。 实指望破奸曹狼烟扫尽， 又谁知天不助命归天庭。 我本当得此信寻个自尽， 又恐怕我母亲不放离分。 叹人生在世间如同照镜， 夫已死我岂肯独自贪生。 因此上备祭礼江边来进， 但愿你魂灵儿早归天庭。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且住。想皇叔一死，我在东吴苦守无益。不免拜谢母后养育之恩，投江自尽了 吧。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄摇板",
          "text": "江水滔滔波浪滚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水旗同上。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄摇板",
          "text": "尚香拜别养育恩。 辞别了老母后寻自尽， 不如一死见夫君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香、四水旗同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上，四水旗引龙王同上。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "玉旨下，跪。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "听宣读。诏曰：孙尚香为夫投江，尽节一死，玉帝垂怜，封为枭姬娘娘。旨意 读罢，望诏谢恩。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "圣寿无疆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙王下。孙尚香换衣。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "众神将，保我朝见玉帝去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香、四水旗同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}