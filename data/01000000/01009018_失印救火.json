          "character": null,
          "type": "stage",
          "text": "金祥瑞丢印匣。"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "哎呀哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白槐摸脚。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "扎了小人的脚了。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "你真会做工，我的印匣，丢在这里；你的人在那里，怎么会打了你的脚了？"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "怪到小人我不痛了。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "依你之见，该怎么样子呢？"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "依小人之见，太爷那颗印信，可曾带来？"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "带来了。"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "与他装在匣儿里面，也就无事了。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "哏，打量着，与他把印装在里面，也就无事了。门子，门子！"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "叫门子作什么？"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "叫他来包印吓！"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "小人就会包印，何必叫他。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "哈哈，包印你也会，两头出坏主意你也会！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金祥瑞拿印，交。"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "哽咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金祥瑞惊。白槐包印。"
        },
        {
          "character": "白槐",
          "type": "白",
          "text": "太爷，包好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白槐下。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "我倒不信，待我摇一摇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白简、众人同上。"
        },
        {
          "character": "白奇",
          "type": "白",
          "text": "开箱用印。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "白简",
          "type": "白",
          "text": "本院救火已熄，贵县护印有功，本院打本进京，保举官职高升。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "老大人前去救火，卑职倒大大地吃了一惊。"
        },
        {
          "character": "白简",
          "type": "白",
          "text": "将仇爱川一案，提在本院台前审问。"
        },
        {
          "character": "金祥瑞",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "白简",
          "type": "白",
          "text": "吩咐掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}