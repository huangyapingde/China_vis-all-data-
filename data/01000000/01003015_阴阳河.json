{
  "script_id": "01003015",
  "title": "阴阳河",
  "alias": [
    "赏中秋；一名：地府寻妻；一名：西川奇闻"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "张茂深",
      "hangdang": "老生"
    },
    {
      "name": "李桂莲",
      "hangdang": "旦"
    },
    {
      "name": "店家",
      "hangdang": "丑"
    }
  ],
  "plot": "山西代州商人张茂深，将往四川经商。与妻李桂莲，饮赏中秋。醉后即在月下交欢，以是秽犯月宫。未几张\n茂深出门，李桂莲即得暴疾，失魂三月，盖为鬼府所勾摄也。张茂深抵四川，一日信步至阴阳界口，见妻在\n河边担水甚苦，大疑。回店间问诸逆旅主人，主人告以此妇名李桂莲，已嫁鬼役，即居河畔。张茂深念知果\n妻，哀痛欲绝，因再往寻之。叩门入，夫妻相遇，悲愕万状。正抱持痛哭，忽鬼役归，见之大怒。李桂莲讳\n之为兄，并以他语给之，鬼役始释然，并置酒款待。席间，鬼役言有公事将往代州，张茂深乃托道之归。",
  "notes": "此剧尚有第二本《还阳》一剧，为花旦之跌扑戏，惜今无演之者。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张茂深上。"
        },
        {
          "character": "张茂深",
          "type": "西皮流水板",
          "text": "一日离家一日深， 好似孤雁宿寒林。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "我，张茂深，山西代州人氏。来到四川，贩卖绸缎为生。来到此地，天色甚早， 找一店房歇下便了。"
        },
        {
          "character": "张茂深",
          "type": "西皮锁板",
          "text": "催鞭打马往前行， 不觉来到店房门。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "来此店房。 吓，店家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "念",
          "text": "孟尝君子店，千里客来投。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "莫非有客住店。 哎，客官敢是住店？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "正是住店。可有上房？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "现有上房。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "将马带过。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，将马带过。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "吓，店家，这有银子二百两，包袱一个，存在柜上。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，存在柜上。请问客人尊姓？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "在下姓张。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，张客人。银子二百两，包袱一个，存在柜上摆好了。没有请问客人大号？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "草字茂深。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，张茂深客人。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "请问店家尊姓？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我与客人同姓。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，与我同姓？巧得很。请问大号？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我叫小二，人人都叫我张小二。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，张小二店家，府上是哪里？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我是此地人氏，开爿客店。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "好得很。请问店家，此地乡风如何？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我们此地乡风与别的地方大不相同。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "怎样大不相同？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我们此地做生意，要分上半天下半天。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "怎样要分上半天下半天？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "上半天做生意，一概而论；下半天做生意，柜台上要摆盆水。来人买东西，将 钱丢在水盆里头，钱要漂在水上，那就是鬼，东西不卖与他；钱要在水下，将 东西卖与他。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，还有这样的乡风。如此我要到外面游玩游玩，行与不行？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "行是行，出了店门，朝南走，一条大路，走到那里，有一个石牌坊，那就是阴 阳界。界这边，都是做买卖的，又热闹又好玩。千万不要到阴阳界那边去，那 是一个鬼地。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦哦，是是。我记下了。我要到外面去游玩游玩。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "客人要到外面游玩游玩，我在这里预备饭，你就回来。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "我就回来的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家下。张茂深出门。"
        },
        {
          "character": "张茂深",
          "type": "西皮流水板",
          "text": "适才店家对我讲， 此地乡风不一样。 将身来在大街上， 来来往往看端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深坐。"
        },
        {
          "character": "李桂莲",
          "type": "内西皮导板",
          "text": "屈死鬼在阴曹泪流满面，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李桂莲上。"
        },
        {
          "character": "李桂莲",
          "type": "西皮锁板",
          "text": "来了我冤鬼魂李氏桂莲。 将身来在大街前， 阴曹受罪实可怜。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "我，屈死鬼魂李桂莲，乃山西代州人氏。配夫张茂深。是因八月十五日，夫妻 二人，饮酒赏月。饮到中间，我夫妻二人，欢乐一场，不想冲撞月宫。月宫将 我拿到阴曹受罪，挑水百日。百日一满，才得放我还阳。今日天色尚早，挑水 便了。"
        },
        {
          "character": "李桂莲",
          "type": "西皮二六板",
          "text": "八月十五月儿圆， 夫妻欢乐在床前。 一步儿来至在大街上，"
        },
        {
          "character": "张茂深、李桂莲",
          "type": "同白",
          "text": "哎，（她、她、她）（他、他、他）好像我（妻李桂莲）（夫张茂深），怎么 来到此处？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你可是我妻？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三锣，行弦。李桂莲下。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哎呀，且住。我见一妇人挑水，好像我妻李桂莲，怎么来到此处？也罢，不免 赶上前去，看她身落在何处？"
        },
        {
          "character": "张茂深",
          "type": "西皮紧板",
          "text": "不顾生死往前奔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深抢背，下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李桂莲上。"
        },
        {
          "character": "李桂莲",
          "type": "西皮锁板",
          "text": "适才来在大街前， 好像我夫到此间。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "适才在大街之上，看见青石板上，坐的我夫张茂深，他怎么来到了此处？我与 他阴阳相隔，难以见面了。"
        },
        {
          "character": "李桂莲",
          "type": "西皮紧板",
          "text": "我足下行走大街上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深上。三锣，行弦。李桂莲下。"
        },
        {
          "character": "张茂深",
          "type": "西皮紧板",
          "text": "果然我妻李桂莲。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哎呀，且住。看这妇人，果然是我妻。不知她、她、她往哪里而去。也罢，回 到店房，问过店家，再做道理。"
        },
        {
          "character": "张茂深",
          "type": "西皮快板",
          "text": "急急走来往前行， 一步来在店房门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深进门。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "店家，店家，店家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "想必张客人回来了。 哎吓，这是怎么样？张客人，张客人，张客人！"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦哦，店家。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "你是怎么样了？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哎呀，店家，适才我去到阴阳界前游玩，见一妇人，头上戴的花花朵朵，身上 穿的绫罗缎匹，挑了一担水，这个妇人，她是什么人？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，你方才去游玩，看见一妇人，头上戴的花花朵朵，身上穿的绫罗缎匹，挑 了一担水。那不是人。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "不是人是什么？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "她是个鬼。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哎呀，不好了！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "什么事？什么事？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你说那个是鬼吓？你也是个鬼！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哎，我是人，怎么是鬼？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，你是人吓？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我本来是人。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你是人？往前走三步。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，往前走三步。一、二、三。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "往后退三步。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，还要退三步。三、二、一。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "还要痰嗽一声。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，还要痰嗽一声。哽哼！"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "慢来，我要摸摸。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "摸摸干什么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深摸店家。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "不错，是人。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "怎么是人了？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你身上有骨头。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "人能没有骨头？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "是人，是人。店家把这个女子，告诉我听听。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "客人不要害怕，我来告诉你：这个女子，跟客人同乡。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "怎么？跟我同乡？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，同乡。娘家姓李，叫李桂莲。只因八月十五，夫妻饮酒赏月，吃醉了酒， 二人开起心来了。夫妻二人，到了房里，关了房门，忘了关窗，正在月宫出来， 照到房里。他二人正在床上开心取乐，冲撞月宫。月宫叫阎王，将她拿到阴 曹，白日挑水，晚上受罪。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你是怎么知道的？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我告诉你：此地有个鬼头，名叫倪木，他是个鬼差，常常到我这里来吃酒。我 们要好得很，故而跟他拜了把兄弟。有几天没有来，一下子他又来呢。我问他 这几天你到哪里去了？他说他到山西代州，有公事拿人去的。我问他拿什么人？ 他就说拿的李桂莲，把她的事情，都告诉我。这个倪木，看这个女子白天挑 水，晚上受罪，他看她可怜，把她弄到家里，配了夫妻。每日晚上回去，拿块 砖，往房上一撩。这个女子轻轻出来开门。都是他告诉我的。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，有这等事？我要去看看。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "她是一鬼，你是一人，怎么好去看？看不得的。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "我一定要去看，不要紧的。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "客人去不得的。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "我一定要去。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "去不得，去不得！"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "我要去的，我要去的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深下。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哎呀，他是一人，那是一鬼，两下见面，定归不好。我看他一定不见回来了。 哎呀，他要不回来，还有二百两银子，一个包袱呢，摆在柜上，这怎样好吓？ 我们开店的，总不能埋没人家的银钱。倘若他不回来，有人到山西代州，姓张 叫张茂深，有名有姓，都好找。把他家下人找来，把银子交与他，这不结了么？ 我劝世上人，千万不可埋没人家的银钱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张茂深上。"
        },
        {
          "character": "张茂深",
          "type": "西皮二六板",
          "text": "倪木做事太莽撞， 淫占我妻为哪般？ 将身来在阴阳界， 不由我一阵阵心惊胆寒。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "来此已是这个门，待我拿块乱石撩来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李桂莲上。"
        },
        {
          "character": "李桂莲",
          "type": "西皮二六板",
          "text": "耳边厢又听得乱石响， 倒叫我桂莲着了忙。 我这里将门来开放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深、李桂莲见面，李桂莲招张茂深进门。"
        },
        {
          "character": "李桂莲",
          "type": "西皮二六板",
          "text": "你是何人到此方？"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "你是什么人来到我家？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "我、我、我姓、姓、姓张，叫、叫、叫张茂深。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "哦，你是我夫张茂深。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你、你、你是什么人？"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "我是你妻李桂莲。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你是我妻李桂莲？打鬼打鬼！"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "夫吓，不要害怕，我是你妻李桂莲。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，当真是我妻？"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "当真。"
        },
        {
          "character": "张茂深、李桂莲",
          "type": "同白",
          "text": "哎呀！（妻）（夫）吓！"
        },
        {
          "character": "张茂深",
          "type": "哭板",
          "text": "听说我妻把话讲， 怎不叫人痛心肠？"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "夫吓，怎么来到此地？"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "来到此地，贩卖绸缎为生。出来游玩，看见我妻你了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪木上。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "开门开门！"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "外面什么人？"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "那就是鬼头倪木回来了。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哎呀，这怎么好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深乱跑。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "不要紧的，把你藏在桌子底下。不要害怕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张茂深藏。李桂莲开门。倪木进门。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "哪里有生人味？"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "没有生人味。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "没有，我就要搜。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "不要搜。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "要搜要搜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪木拉张茂深出。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "这是什么人？"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "他是娘家的哥哥。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "不错，我、我、我是她娘家的哥哥。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "哦，娘家的哥哥，不是外人，请下来。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "哥哥你下来。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "我不下来，他要害我的。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "我跟你是亲戚，哪有害你的道理？请下来。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，你不害我，待我下来。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "啊，大舅子。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "吓，亲戚。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "家里的，既然你哥哥到了，我们是亲戚，总要款待款待，我去打酒去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪木下。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "哎吓夫吓！倪木打酒前来，千万不可饮他的；倘若吃了，你就不能还阳了。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "是是是，我记下了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪木上。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "哎呀不好了，阎王叫我有差事去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪木进门。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "你我这个酒吃不成了，阎王命我山西代州有公事去了。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，你也要到山西代州？我也是代州人氏，我也想回去，这便怎么好？"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "哦，你也想回去？不要紧，你跟我一块去。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "你在阴间，我在阳间，怎么好带？"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "不要紧，你闭上眼睛，随住我的风走，就到了你家了。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哦，我记下了。"
        },
        {
          "character": "倪木",
          "type": "白",
          "text": "你们两人分别分别，就要赶路了。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "哎呀，夫吓！此番回去，千万把我尸首，不可损坏。百日一满，我夫妻还要团 圆。"
        },
        {
          "character": "张茂深",
          "type": "白",
          "text": "哎呀，妻吓！此番回去，把你的尸首，我不埋葬就是了。"
        },
        {
          "character": "李桂莲",
          "type": "哭板",
          "text": "听说儿夫要起程， 怎不叫人痛伤心？ 哭一声我的夫难得相见，我的夫吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪木三冲开，倪木、张茂深同下。"
        },
        {
          "character": "李桂莲",
          "type": "哭板",
          "text": "哭一声我的夫张茂深，我的夫吓！ 一见儿夫把路引， 怎不叫人泪双淋。 将身来在孤庙内， 百日还阳又重生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李桂莲下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}