{
  "script_id": "01014008",
  "title": "雪杯圆",
  "alias": [
    "柳林相会；一名：怀古回家"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "莫怀古",
      "hangdang": "生"
    },
    {
      "name": "傅氏",
      "hangdang": "老旦"
    },
    {
      "name": "莫文禄",
      "hangdang": "娃娃生"
    }
  ],
  "plot": "莫怀古幸得义仆莫成代死，销声匿迹，避居河北。妻傅氏在家，无从知代死之事，以为莫怀古真死，将莫成\n尸首，营葬在蓟州西门外柳林内，茹苦含辛，家居度日。莫成子莫文禄，亦依在身畔。正值清明佳节，携带\n莫文禄，至柳林扫墓。当时严氏失势，冰山溶解；总兵戚继光写书通知，莫怀古遂作归乡计。行经柳林，见\n墓碑大书“太常寺正卿莫公怀古之墓”，有老妇在墓前哭祭；仔细一认，确系发妻傅氏。遽上前招呼，傅氏\n大惊，诧为遇鬼；莫怀古从头至尾，细细告之，始转悲为喜。而莫文禄在旁窃听，痛其父死于非命，抢地呼\n天，悲不自胜，几欲与莫怀古为难。夫妻二人再三劝慰，抚为养子，藉以报答成恩。",
  "notes": "剧本出于《一捧雪》、《审头刺汤》之后。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "恼恨奸贼理不该， 苦苦害我为哪般。 莫成替我把命染， 思想起来泪涟涟。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "在下莫怀古，钱塘人氏。只因那年，进京求取功名，多亏严府提拔，官居太常 寺正卿之职。恼恨汤勤，搬动是非。是我弃官逃走，被严府校卫，将我拿获， 解到蓟州。幸喜莫成，替我丧命，是我逃在河北避难。昨日戚贤弟有书到来， 叫我前去。看前面已是蓟州，不免马上加鞭。"
        },
        {
          "character": "莫怀古",
          "type": "二黄原板",
          "text": "一日离家一日深， 莫怀古在马上自己思忖： 我心中只把那汤勤来恨， 大不该害得我一家离分。 多亏了小莫成替我丧命， 有雪艳刺汤勤才把冤伸。 我这里紧加鞭催马前进，"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "远远望见蓟州城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "傅氏上。"
        },
        {
          "character": "傅氏",
          "type": "引子",
          "text": "身居店房，远离家乡。"
        },
        {
          "character": "傅氏",
          "type": "念",
          "text": "老爷当年去求官，被人陷害丧黄泉。不嫌千里路途远，要到蓟州走一番。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老身傅氏。老爷莫怀古，官居太常寺卿之职；不料被人陷害，命染黄泉，埋葬 在蓟州西门以外，柳林之内。是我带领文禄，前去坟茔祭奠。前面离蓟州不远， 看天色不早，正好趱路。 文禄哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄上。"
        },
        {
          "character": "莫文禄",
          "type": "念",
          "text": "忽听一声唤，急忙到跟前。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "参见奶奶！"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "文禄，你看天色不早，就此趱路。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "走呀——"
        },
        {
          "character": "傅氏",
          "type": "二黄慢板",
          "text": "有傅氏带文禄忙把路上， 思想起当年事好不悲伤。 叹儿夫在京都求官得赏， 官居着太常卿身列朝堂。 到后来遭不幸一旦命丧， 落下了我一人好不凄凉。 将身儿来至在柳林观望， 又只见一坟茔细看端详。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "“太常寺卿莫公之墓”。哎呀老爷呀！"
        },
        {
          "character": "傅氏",
          "type": "二黄摇板",
          "text": "见坟茔不由人泪双抛， 叫一声老爷听根苗： 实指望在朝居官好， 又谁知中途无下梢。 可怜我千里迢迢把你寻找， 老爷呀——"
        },
        {
          "character": "傅氏",
          "type": "二黄摇板",
          "text": "我心中好一似万把钢刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "催马加鞭到柳林， 不知坟茔何处存。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "来此已是柳林，不知莫成坟茔，现在哪里？待我下马找寻找寻。 “太常寺卿莫公之墓”。"
        },
        {
          "character": "莫怀古",
          "type": "三叫头",
          "text": "莫成！掌家！莫成呀！"
        },
        {
          "character": "莫怀古",
          "type": "二黄导板",
          "text": "见孤坟好叫人珠泪双掉，"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "不由得一阵阵哭嚎陶。 可怜你为我把命丧了， 万古流芳美名标。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "呀！你是何人，来在我家坟茔啼哭呀？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "此乃是我家坟茔，怎么说是你家的呀？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "分明是我家的坟茔么！你怎么前来冒认？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "且住。看此人讲话，好似我妻傅氏。待我向前冒叫一声。 呀！你莫非是傅氏么？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "呀！你是我何人，敢叫我“傅氏”？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "为丈夫莫怀古在此。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "打鬼！打鬼！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "何言“打鬼”？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "我丈夫已死多年，岂不是鬼？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "贤妻休得害怕，为丈夫并不曾死。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "我家老爷，有两处贵相。你可有么？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "什么贵相？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "我家老爷，脑后有一肉枕，又有三台骨。我若一摸，便知分晓。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "我今现有。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "待我摸来。"
        },
        {
          "character": "傅氏",
          "type": "叫头",
          "text": "老爷！"
        },
        {
          "character": "莫怀古",
          "type": "叫头",
          "text": "夫人！"
        },
        {
          "character": "傅氏",
          "type": "叫头",
          "text": "我夫！"
        },
        {
          "character": "莫怀古",
          "type": "叫头",
          "text": "贤妻呀！"
        },
        {
          "character": "傅氏",
          "type": "叫头",
          "text": "老爷呀！"
        },
        {
          "character": "傅氏",
          "type": "二黄摇板",
          "text": "一见老爷来到了， 不由妾身泪滔滔。 回头便把老爷叫， 妾身言来听根苗： 雪艳妹子哪里去了？"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "蓟州堂上一旦抛。"
        },
        {
          "character": "傅氏",
          "type": "二黄摇板",
          "text": "问声莫成今何在？"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "他替我一命赴阴曹。"
        },
        {
          "character": "傅氏",
          "type": "二黄摇板",
          "text": "问老爷如今往哪里去？"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "戚贤弟有书把我邀。"
        },
        {
          "character": "傅氏",
          "type": "二黄摇板",
          "text": "如此一同齐就道，"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "同到蓟州走一遭。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "这是何人？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "这就是文禄。 来，见过你家爷爷。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "参见爷爷。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "我家爹爹，哪里去了？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你家爷爷，骑马先行；你的爹爹，挑负行李，尚在后面。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "待我看来。怎么还不见到来？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你当真要你家爹爹么？你随我来—— 这坟茔之中，就是你家爹爹！"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "哎呀！爹爹呀！"
        },
        {
          "character": "莫文禄",
          "type": "唱",
          "text": "听说爹爹命丧了， 眼望坟茔泪双抛。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老爷，妾身欲将文禄孩儿，认在你我的名下，作为螟蛉义子。不知老爷，意下 如何？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "夫人前去问来。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "文禄，我欲将你，认在我二老的名下，作一螟蛉。不知你意如何？"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "如此爹娘请上，受儿一拜！"
        },
        {
          "character": "莫怀古、傅氏",
          "type": "同白",
          "text": "不须拜了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "夫人，你看前面，已是蓟州，你我就此前往。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "但凭老爷。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "儿呀，与你母亲带马！"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}