{
  "script_id": "01012003",
  "title": "高平关",
  "alias": [
    "借人头"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "高行周",
      "hangdang": "净"
    },
    {
      "name": "高怀德",
      "hangdang": "小生"
    },
    {
      "name": "高怀良",
      "hangdang": "小生"
    }
  ],
  "plot": "五代末高行周，镇守高平关，兼有怀德、怀良二子，勇武异常，随同守护，远近颇畏惮之。后周柴荣，屡攻\n不能克。柴荣之军师苗训，知赵匡胤父与高行周有亲谊，请柴荣下其家属于狱，逼令赵匡胤往取高行周之头，\n以赎百口。高行周素善观天文，是日夜观星象，见己星为客星所掩，知赵氏必兴。明日忽报赵匡胤至，高\n行周大惊，知必有异，令众将迎之入。赵匡胤哭诉来由，高行周闻之，略无难色，但问赵匡胤何以报德，赵\n匡胤立书笔证，许厚封其子怀德、怀良官，高行周嫌报施太轻，怒掷赵匡胤所书证据于地，谓：高与赵本世\n戚，必以汝妹为吾媳，聘吾女为汝妻方可，否则惟坐视而已。赵匡胤不得已，俱允之。高行周乃公服自刎，\n赵匡胤遂割取其头，归报柴荣，于是高平乃为后周有。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "龙套、高行周同上。"
        },
        {
          "character": "高行周",
          "type": "点绛唇",
          "text": "奉命镇守，扫灭全寇，名九州，官封王侯，爵禄皇恩厚。"
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "忆昔当年逞豪强，五龙二虎逼彦章。老夫先蹋金角椅，才得官封东鲁王。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "老夫高行周，在刘怀王驾前为臣，官拜东鲁王之位。只因昨晚夜观天象，只见 赤须龙压定了白虎大堂。想那赤须龙，乃是河东匡胤，那白虎乃是老夫本命星 君。本当不助他成功，难免五雷之罪。正是："
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "大国州来小国州，单枪匹马几时休。算来把刀项上去，为国尽忠不到头。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "来，传众将进帐。"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "众将进帐。"
        },
        {
          "character": "四将",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "参见大王！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "谢老大王！吓，老大王二十余载，未曾升坐大堂，今日升坐大堂，为了何事？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "想老夫年迈，难掌高平，将印信付与你等执掌，意下如何？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "吾等不敢。还有二位少爷。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "好一个仁义四将！帐外听令。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同下。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "来，传二位少爷进帐。"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "二位少爷进帐。"
        },
        {
          "character": "高怀德、高怀良",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀良同上。"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同白",
          "text": "参见爹爹！"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "儿是怀德！"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "正是怀德。"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "儿是怀良！"
        },
        {
          "character": "高怀良",
          "type": "白",
          "text": "是怀良。"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "儿吓！"
        },
        {
          "character": "高行周",
          "type": "西皮导板",
          "text": "擂鼓三通坐虎堂，"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "怀德！"
        },
        {
          "character": "高怀德",
          "type": "叫头",
          "text": "爹爹！"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "怀良！"
        },
        {
          "character": "高怀良",
          "type": "叫头",
          "text": "我父！"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "儿吓！"
        },
        {
          "character": "高行周",
          "type": "西皮慢板",
          "text": "怀德、怀良站立在两旁。 昨夜晚为父夜观天象， 只见那赤须龙压定了白虎大堂。 你道那赤须龙就是哪个？ 他就是河东的赵……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀良同惊。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "一个“赵”字未出口， 两个冤家着了忙。 罢罢罢罢，将“赵”字按下不讲， 怀德、怀良听端详。"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同白",
          "text": "吓，爹爹二十一载，未曾升坐白虎大堂；今日升坐大堂，为了何事？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "为父年迈，难掌高平，欲将印信，付与尔等执掌。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "孩儿年幼。"
        },
        {
          "character": "高怀良",
          "type": "白",
          "text": "儿年小。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "可知道为父与祖先报仇之事？"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同白",
          "text": "孩儿不知。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "尔等不知，听为父道来："
        },
        {
          "character": "高行周",
          "type": "西皮慢板",
          "text": "黄巢起义灭大唐， 将唐主赶至在西岐美良。 程敬思四路颁兵将， 沙陀国颁来了年迈李王。 飞虎山又收了打虎小将， 那娃娃虽年幼武艺高强。 灭了黄巢朱温丧，"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "又反了水贼王彦章。 大太保领雄兵不能抵挡， 在山后颁请了我的父王。 儿祖父中了那水贼计上， 在无缨枪下一命亡。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "为父在后花园中，跑马射箭，家院报道，儿祖父命丧水贼之手。为父闻听此言， 人不及甲，马不及鞍，直奔水贼的营盘，高声叫骂。那水贼出得营来，头戴 乌云盔，身穿乌油甲，手持丈八铁篙。他见了为父，哈哈哈大笑！"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同白",
          "text": "他笑爹爹为何？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "他笑为父“上马没有拳头大，下马无有磕膝高。回去吃三年乳奶，再来与你父 报仇！”为父闻听此言，提枪就刺。那贼用铁篙抵住，吾二人连仗数十回合， 不分胜负。那时为父心生一计，打马就败。那贼紧紧追赶，为父回头一看，只 见那贼的马头，连住为父的马尾；为父的马尾，连住那贼的马头。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "父亲可慌？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "不慌。"
        },
        {
          "character": "高怀良",
          "type": "白",
          "text": "可忙？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "也不忙。在腰中取出祖先的铜锤，叫道“水贼照打！”"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "为父就是铜锤打， 石敬唐就是铁锏伤。 铜锤打，铁锏伤， 打得那贼吐红光。 五龙二虎逼贼丧， 为父才拜东鲁王。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "怀德拜印！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗，四将同上。高怀德拜印。高怀良哭。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "怀德拜过高平印， 怀良一旁放悲声。 手掌手背都是肉， 一样儿子两看承。 怀良你拜尚方剑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀良拜剑。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "带管三千鹞子兵。 弟兄二人把高平镇， 再叫众将听分明。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "唉，众位将军，明日午时三刻，有一红脸大汉，他若进得关来，将枪头朝内； 他若出得关去，将枪头朝外。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "他是老大王什么人？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "他是老夫昔年的好友，尔等记下了。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同下。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿吓，为父有一言，尔等解来。"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同白",
          "text": "爹爹请讲。"
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "昔日楚汉两争强，陈平无计问张良。霸王不听范增语……"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "尔等可解？"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同白",
          "text": "尔等不解。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "无用的东西，出帐去吧！"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同白",
          "text": "儿遵命。"
        },
        {
          "character": "高怀德",
          "type": "西皮摇板",
          "text": "爹爹一言出了唇，"
        },
        {
          "character": "高怀良",
          "type": "西皮摇板",
          "text": "倒叫孩儿解不明。"
        },
        {
          "character": "高怀德",
          "type": "西皮摇板",
          "text": "人来带过马能行，"
        },
        {
          "character": "高怀德、高怀良",
          "type": "同西皮摇板",
          "text": "去到关前看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀良同下。"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "怀德！怀良！吓吓吓吾的儿吓！"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "怀德、怀良上高平， 父子相逢再不能。 人来与爷掩门进， 咬定牙关等时辰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀良同上。"
        },
        {
          "character": "高怀德",
          "type": "西皮摇板",
          "text": "怀德拜了高平印， 怀良拜过剑一根。 人来带路把关进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀良同上城。"
        },
        {
          "character": "高怀德",
          "type": "西皮摇板",
          "text": "看是何人到来临。"
        },
        {
          "character": "赵匡胤",
          "type": "内西皮导板",
          "text": "不分昼夜离淮庆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮慢板",
          "text": "天牢内辞别了二老双亲。 在中途遇崔龙将我盘问， 多亏了曹二弟一家满门。 在午门又遇见老将杨衮， 那老儿虽年迈武艺皆能。 铜锤下不伤俺玄郎性命， 郭王爷赐宝刀二下高平。 我这里催青鬃马往前进，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "又只见鹞子岭扎下大营： 上写着东鲁王让了帅印， 有怀德和怀良执掌高平。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "那老儿他倒有隔山照镜， 就知道俺玄郎要杀他人。 不杀他人回淮庆，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "天牢内还有那二老双亲。 明知道山有虎伤人性命， 学关公斩蔡阳夜奔古城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        },
        {
          "character": "高怀德",
          "type": "西皮摇板",
          "text": "我看此人好貌相， 看他好像赵玄郎。 人来与我忙追上，"
        },
        {
          "character": "高怀良",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "高怀良",
          "type": "西皮摇板",
          "text": "爹爹降罪何人当？ 人来带过马能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀良同下城。"
        },
        {
          "character": "高怀良",
          "type": "西皮摇板",
          "text": "见了爹爹说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀良同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "长锤，高行周上。"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "昨晚一梦大不祥， 梦见吾主刘怀王。 手挽手儿游地藏， 君臣们对坐叙叙家常。 醒来打开梦书看， 午时三刻一命亡。 闷恹恹坐至在白虎大堂， 等等等等，等候了河东赵玄郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "过了头关到二关， 满营将士不敢拦。 手搭凉棚用目看， 上面坐的将一员。 认得他是高鹞子， 昔年大战狗鸡滩。 手持宝刀往上砍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤拔刀砍，高行周拦。"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "祖先铜锤朝下拦！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "下跪敢是香孩儿？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "正是侄男。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "进得关来，为何宝刀出鞘？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "伯父威严甚重，故而宝刀出鞘。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "把刀入鞘，一旁坐下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "谢伯父。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤坐。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿爹娘可好？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "儿爹娘好。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿在江湖可好？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "儿在江湖好，敢劳伯父动问。伯父、伯母可好？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "唔，为伯父不来问儿，你也不来问伯父、伯母！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "儿上得关来，被伯父占了先了。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "好一个“占先”二字。 且住，人道赵匡胤有九五之尊。老夫幼年，学就麻衣神相，不免与他相上一相。 他若有九五之尊，老夫助他成功；他若无有九五之尊，要想出高平，万万不 能。 香孩儿，把燕毡帽，齐眉按定了。"
        },
        {
          "character": "高行周",
          "type": "西皮慢板",
          "text": "高行周坐虎堂用目观望， 看一看河东的赵玄郎。 丹凤眼卧蚕眉，帝王之相， 到后来他必定坐镇家邦。 问玄郎到此间因为何故？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮慢板",
          "text": "在伯父台前问安宁。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "问什么安来问什么宁， 伯父心中明如灯。 杀了刘王就该走， 为什么二次到高平。 高平怎比燕京地， 老夫怎比刘怀君。 左有天吉和天庆， 右有刘安和刘明。 四员虎将我不表， 怀德、怀良杀人精。 休提老夫年纪迈， 还有三千鹞子兵。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "那老儿他倒有隔山照镜， 就知道俺玄郎要杀他人。 不杀老儿回淮庆，"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "回去拜上儿的爹娘。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "想起爹娘书一封。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "爹娘有书信一封，伯父请看。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤呈书。"
        },
        {
          "character": "高行周",
          "type": "西皮慢板",
          "text": "拆书信，观风景， 一字字一行行上写分明： 书信到此无别论， 借你的人头表一表人情。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "世上别的俱已借， 借了人头怎为人？ 问玄郎杀伯父因为何故？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "天牢内搭救我二老双亲。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "你有一双亲父母， 怀德、怀良无父亲。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "伯父助儿把功成， 怀德、怀良我看承。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "吾儿本是将门子， 岂用你赵家来看承？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "我有一妹赵美容， 愿许怀德配为婚。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "说此话你就把手割下！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "伯父说话欠聪明。 天地日月轮流转， 全凭两膀定乾坤。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "走关西来走关东， 这句话儿解不明。 你若解开其中意， 老夫助儿把功成； 你若不解其中意， 要出高平万不能。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "走关西来走关东， 这句话儿解不通。 低下头来暗思想，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "想是伯父要合同。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "侄儿上得关来，未带文房四宝。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "白虎堂现有。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请伯父离位。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "待老夫离位。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周下位，赵匡胤砍。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "动手还早！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "赵玄郎立虎堂魂飞天外，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮慢板",
          "text": "二次里下高平鬼使神差。 对伯父施一礼虎堂来踹， 手提着羊毫笔仔细写来： 头辈祖名赵霸父子员外， 二辈祖赵怀亲颇有家财； 三辈祖名赵保随唐挂帅， 一杆枪挣下了免死金牌。 吾的父赵洪恩皇堂现在， 我的母窦氏女曾受过皇王封来。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "我的妹赵美容八字癸亥， 秋八月十五日降下裙钗。 我赵门与高家结下亲爱， 但愿得他夫妻到老和谐。 我这里写合同媒妁不代， 老伯父拿去观自刎头来。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "见合同写得是倒也慷慨， 赵玄郎巧机关老夫解开。 我两家结亲事名扬四海， 少画押无媒证怎把亲抬？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "那老儿虽年迈聪明还在， 赵玄郎用巧计被他解开。 提羊毫就写柴子耀，"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "张广远、罗元威颇有家财；"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "不好！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "施守能、施守信英雄尚在，"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "亦不要！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "还有个苗先生八字安排。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "这不要那不要把儿难坏， 老伯父要何人自己讲来。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "董家桥打五虎几人结拜， 谁是兄谁是弟说个明白。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "董家桥打五虎三人结拜， 还有个郑子明未曾写来。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "问玄郎郑子明在也不在？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "在西门与崔龙见过阵来。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "他二人见一阵谁胜谁败？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "他二人见一阵不分将才。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "昨夜晚观星斗霞光无在， 郑子明老苍龙降下凡来。 叫玄郎写郑恩老夫心爱，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "提笔就写郑英才。 昔日打马过金桥， 偶遇先生八卦高。 他把我八字安排好， 说我后来有九朝。 有九朝来坐九朝， 伯父近前听封号： 七岁孩儿戴纱帽， 九岁女儿入皇朝。 一封合同忙写好， 老伯父拿去看自把头招。"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "一见合同魂不在， 一张纸换下人头来。 叫玄郎你把颜色卖， 袖儿内藏合同神鬼难猜。 叫玄郎你把上关路带，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "伯父到哪里去？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "前去见过你那两个兄弟。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓，伯父，想我那两个兄弟，如狼似虎，如何能舍得伯父？伯父舍了罢！"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "吓吓吓，我的儿吓！ 父子们要相逢梦里再来。 叫玄郎你把上房路带，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓，伯父，到哪里去？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "二堂辞别儿的伯母。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎吓伯父吓，想伯母与伯父乃系恩爱夫妻，如何能舍得伯父？伯父舍了罢！"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "哎哎哎，吾的妻吓！ 夫妻们要相逢转世再来。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "哎，玄郎上得关来，全凭何物？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "青铜宝刀。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "借刀一用。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刀不离手。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "铜锤抵换。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刀换锤。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "锤换刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、高行周换刀、锤，高行周砍。"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "开刀先杀赵匡胤！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "想是伯父变了心。"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "非是伯父变了心， 怕你日后忘了恩。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "伯父助儿把功成， 怀德讨饭我看承。"
        },
        {
          "character": "高行周",
          "type": "西皮摇板",
          "text": "真龙天子开了恩， 吾儿讨饭他看承。 耳旁听得天鼓响， 口口叫道白虎星。 罢罢罢罢，休休休休， 学一个霸王自刎头！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周自刎。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "一见伯父尸不倒， 想是伯父讨封号。 有朝玄郎登大宝， 封你白马大英豪。 宝刀一举人头掉， 郭王台前报功劳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤砍高行周头，下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}