{
  "script_id": "01011014",
  "title": "洛阳桥",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "蔡襄",
      "hangdang": "小生"
    },
    {
      "name": "夏得海",
      "hangdang": "丑"
    },
    {
      "name": "青袍甲",
      "hangdang": "副净"
    }
  ],
  "plot": "状元蔡襄，为母酬愿，舍金建造洛阳桥于海滨，桩不得入，乃想入非非，妄欲遣人下海，至龙宫投文。公役\n夏得海，因姓名与下得海谐音之故，误自应承，强被差遣，不得已乃拼命轰饮，醉卧海滩。不意竟然为海神\n引去，导至水晶宫，而见龙王，并承款待，卒于文书上批一醋字，盖指廿一日酉时可以破土见桩之意。夏得\n海醒后，喜极，即往复命。蔡襄即如其言，于廿一日动工，桩果得入土。以是，桥遂得落成。自此以后，则\n扮演三百六十行等杂戏，以为落成庆。",
  "notes": "前清同治初，宫中每喜观灯彩戏，盖其时孝钦爱戏之智识，尚甚幼稚，犹之寻常妇稚，只知看闹顽戏，而不\n知看做工戏也。此《洛阳桥》即灯戏中之一，相沿已久，当时坤班中即已盛演。其剧情纯系荒诞不经之举，\n徒博热闹耳。惟夏得海下海前一段唱做，仍一本昆派，尚有定程，余则均可随意增减，大略为其怪诞荒唐，\n诚不值识者一哂。海上各舞台茶园，每逢阴历新年，则必盛演此剧，其意盖本于元宵灯节，金吾不禁之旧例\n焉。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八云童、四仙童各执宝同上，韦陀、龙女、大士同上。"
        },
        {
          "character": "大士",
          "type": "细点降",
          "text": "佛法天花，日展光华，是我家烧丹砂，九流归释家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大士上高台。〖小吹打〗。"
        },
        {
          "character": "大士",
          "type": "念",
          "text": "道法宽宏舍利家，讲经说法雨天花。吾敕门中传弟子，谁知此道真情雅。"
        },
        {
          "character": "大士",
          "type": "白",
          "text": "吾乃慈悲大士是也。只因下界，有一孝感，名唤蔡襄，为母抱恙，许下愿心。 如今母病痊愈，他欲为母酬愿，在于东海之上，建造洛阳长桥，以便商贾来往。 真乃普施恻隐，奈他独立难持，吾不免助他一臂之力。 善才、龙女听者。"
        },
        {
          "character": "善才、龙女",
          "type": "同白",
          "text": "菩萨。"
        },
        {
          "character": "大士",
          "type": "白",
          "text": "命你二人，化作民间子女模样，驾一小舟，去至东海边上，来来往往，诱惑世 间这些刻薄绅商，贪官污吏，尔等口中言道：岸上诸色人等，各将金银抛下， 如若掷得我肌，即允佳偶。这些刻薄愚人，闻听此言，见色迷心，方好抛弃金 银，帮助孝感，早为工钱。不得迟误。"
        },
        {
          "character": "善才、龙女",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "善才、龙女同下。"
        },
        {
          "character": "大士",
          "type": "白",
          "text": "众童儿驾起祥云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。〖尾声〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蔡襄引四青袍同上。"
        },
        {
          "character": "蔡襄",
          "type": "引子",
          "text": "萱恙复原，建长桥，酬谢心愿。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "下官蔡襄。今奉母命，前往海边祭奠水神。 来，祭礼可曾齐备。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "皂役上。"
        },
        {
          "character": "皂役",
          "type": "白",
          "text": "禀老爷：祭礼人役俱已齐备。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "吩咐下面，即刻起程。"
        },
        {
          "character": "皂役",
          "type": "白",
          "text": "即刻启程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八执事、伞夫自两边分上，同绕场。〖牌子〗。众人同挖门。设香案。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "祈江海一切龙主潮神，怜俺蔡襄一点孝念，建桥之时，但愿风息浪静早为工竣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡襄焚表。海巡上，接表下。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "众人役打道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四游人同上。"
        },
        {
          "character": "游人甲",
          "type": "念",
          "text": "春城无出不飞花，"
        },
        {
          "character": "游人乙",
          "type": "念",
          "text": "寒食东风御柳斜。"
        },
        {
          "character": "游人丙",
          "type": "念",
          "text": "日暮汉宫传蜡烛，"
        },
        {
          "character": "游人丁",
          "type": "念",
          "text": "轻烟散入五侯家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四游人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "采莲船。善才、龙女同上。"
        },
        {
          "character": "龙女",
          "type": "西皮导板",
          "text": "离却了莲台下凡尘，"
        },
        {
          "character": "龙女",
          "type": "西皮慢板",
          "text": "霎时变化凡人形。 驾舟前行哄愚拙， 帮助蔡襄孝感心。 可叹世人未知音， 抛弃多少金和银。 但愿建桥早工竣， 不枉点化一片心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四游人同上，同抛金银。云童引吕洞宾跨鹤同上，吕洞宾看。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮二六板",
          "text": "站立云霄观分明， 只见那诸士乱纷纷。 个个心中都侥幸， 恨不得一掷便着玉人身。 看得我洞宾忆蘋蘋， 略施小术指迷津。 免却诸生费金银， 待我来点石为金劝世人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕洞宾掷金，下。聚宝库出彩。"
        },
        {
          "character": "龙女",
          "type": "西皮摇板",
          "text": "可叹世人入迷津， 洞宾也欲起凡心。 施法点石化为金， 难解奴的假和真。 我今奉了菩萨命， 聚得金银复旨音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "善才、龙女同下。四游人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蔡襄、四青袍同上。"
        },
        {
          "character": "蔡襄",
          "type": "引子",
          "text": "奉老母严命，安桥梁，何日工竣。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "下官蔡襄，只因为母酬愿，至此建造洛阳长桥。怎奈水深浪溜，难安桥梁。未 知可有人下得海去？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "有，小的夏得海。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "啊，你下得海么？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "小的夏得海。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "好。赏你五两纹银。有公文一角，去至东海龙宫内投递。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "多谢老爷。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "夏得海，来来来。你上哪里去？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "伙计，我好造化。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "造化什么？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "今日老爷升堂，说道夏得海，你来你来，赏你五两银子，有公文一角，到东门 龙王庙焚化。伙计你等着。我去去就来。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "慢着慢着，夏得海。你听错了。老爷差你下海去。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "什么下海去。我却不信。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "你若不信，且看公文便知。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "不错，待我看来。 呈东海龙宫投递。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "是不是？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "难道当真叫我下海去么？"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "快些下海去吧。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "不要玩啊。待我去回禀老爷。 启禀老爷：这角公文，还是叫小的，到东门龙王庙焚化呢？还是叫小的上东海 龙宫内投递？"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "东海龙宫内投递。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "哎呀老爷不要玩啊。小的名字叫夏得海，是不会水性的。连阴沟里面，也不曾 去过。叫我怎样下得海去？"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "胡说。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "哎呀老爷啊，哙，伙计，待我回回老爷啊。"
        },
        {
          "character": "蔡襄",
          "type": "念",
          "text": "拜上了龙君早退潮。这回不怕风浪高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡襄、四青袍同下。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "哎呀老爷啊老爷…… 你们都进去了。哎呀我的妈啊！ 咳，官差不自由，只得走这遭。"
        },
        {
          "character": "夏得海",
          "type": "吹腔",
          "text": "自把那爹娘恨， 恨爹娘取错了名， 缘何不将人伦整。 论为人，也须要整三纲，全五伦。 何不叫我上得上来，锄得地， 也学取黄粱圣有基。 我言不顺时，言不顺时， 错听了，忙答应。 何不叫我读得书，写得字， 也取皇家俸禄，归那买臣。 啊，只把那柴薪运。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "咳。好笑我的妈啊。生了我出来，或猫或狗，桌椅板凳，满堂红琉璃灯，都可 以取得名字，实实的无有，就是料壶马桶，也好当得名字。偏偏叫了什么夏得 海。咳。我好恨啊。"
        },
        {
          "character": "夏得海",
          "type": "吹腔",
          "text": "他独独里叫什么夏得海。 下得海，愁只愁那黄泉一口，怎生样吞。 那鱼兵虾鳖生奸计。 还有那夜叉海鬼， 摆下了迷魂阵，摆下了迷魂阵。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "咳。我下海去，不怕别的啊。"
        },
        {
          "character": "夏得海",
          "type": "吹腔",
          "text": "我愁只愁那癞头鼋， 他张着嘴来龇着了牙， 伸出头来露着了爪， 把我的残生一口儿吞。 我的尸骸葬在那鱼腹心。 哎呀妻子哪里去哭夫君， 儿子哪里去认爹尊。 田园产业尽被他人吞。 撇得我家难奔命难存。 家难奔命难存。"
        },
        {
          "character": "店家",
          "type": "内白",
          "text": "卖酒啊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "一荡子走到这儿来了。待俺上这酒搂，喝了熏熏大醉，就是下海死了，做个醉 鬼，倒也有名。 呔。卖酒的！"
        },
        {
          "character": "店家",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "念",
          "text": "酒楼檐前三尺布，飘来飘去招主顾。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "啊，是哪个？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "原来是夏得海。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "你家儿子叫夏得海。你家儿子叫夏得海。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "怎么今日这等着恼？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "老头子，我且问你，你知道我家老爷，为官如何？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "你家老爷为官清正，万民感仰。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "咳。老头子，他如今糊涂到底了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "怎么糊涂？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "他今日也造桥，明日也造桥，竟把这条桥造到我身上来了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "怎么说，你身上也只好顶石碑，哪里能造桥啊？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "唔，你这个老忘八！我是说吧，你听啊。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "你讲吧我听啊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "他坐在公堂之上，言道，下官蔡襄，为母酬愿，建造洛阳长桥。怎奈水深浪溜， 难安桥桩，不知可有人下得海去，那是我站在旁边，认得叫我。我说有，小 的夏得海。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏得海跪。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "起来起来。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "谁来跪你。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哈哈哈。我只道跪我。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "告诉你的。老爷说道，赏你纹银五两。有公文一角。上东海龙宫投递。那时我 只道，叫我到东门龙王庙焚化，哪里晓得叫我下海龙宫投交。此去必是有死无 生。我的妈啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏得海哭。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "夏得海你不要哭，我先前见过有人下海去的。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "怎么去的？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "看他一直到了海边，上了船，打了蓬，只见他唿喇喇一阵旋风，竟把那只船， 一刮刮到海窝子里头。只见他滴溜溜滴溜溜下去了。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "那时你可曾见他滴溜溜滴溜溜上来呢？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我单见他下去，没有见他上来。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "呀呸。这么还是要死的啊。哎呀我的妈啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏得海哭。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "不要哭。倒是吃酒。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "本是来吃酒的。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "吃些什么菜？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "不论。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "倒是醉鲤鱼罢。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "不吃。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "醉虾如何？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "也不吃。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "醉螃蟹如何？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "呸。老东西。你怎把海里头东西叫我吃。我如今吃他，等一会他吃来吃我了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "都不吃，倒是咸菜罢。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "倒也使得。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "啊伙计拿酒来。 夏得海你吃酒。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "来来来，你陪我喝杯罢。请。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "请。干。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "咳。倒是闷酒喝不惯。我们来行个酒令罢。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "有道是无三不行令。你我两个人，怎好行令呢？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "不要紧。我们来行个珍珠倒卷帘。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "什么叫珍珠倒卷帘。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "我只要正说，你便倒念，说得过就是。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "说不过呢？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "罚酒一大杯。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "好的好的。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "我来了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "来啊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "珍珠。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "珠珍。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "玛瑙。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "瑙玛。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "珊瑚。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "瑚珊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "水井。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "井水。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "哎，井水怎样卖人家的钱。来来来，罚酒一大杯。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我吃我吃。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "我们再来。我们再来。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "再来。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "如今要说得快。来来来。韩信。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "信韩。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "萧何。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "何萧。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "张良。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "良张。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "霸王。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "王霸。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "王霸真是我。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我是真王八。小畜生，你开我的心。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "老忘八。来来来，罚你酒，喝了再来。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我说不过你，不来了。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "我闻得你的妙音甚好。请唱一个听听。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我是老猫声。不受听的。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "不必太谦，唱罢。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "啊。听着。 唔唔唔。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "这是什么意思。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "这叫曲意。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "领教。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "催命归来。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "哎呀老爹，待我回去。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "你说催命鬼来了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哎。这是曲头啊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "啊老爹，这个曲头，下回少唱。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "为什么啊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "把我的魂都唬掉了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "就不唱。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "你来喝杯酒，待我来唱你听。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "老爹听了。"
        },
        {
          "character": "夏得海",
          "type": "吹腔",
          "text": "想人家，养儿孙， 必竟要按些买卖。 在公门，当什么的差， 那犹如欠下了狼虎债。 差着也要走，唤着也要来。 为只为公文，把我的残生就断送哉。 老爹， 想人生在世总是空， 到头来如梦中。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "不错。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "老爹，明日我的妈来找我，你怎样回答呢？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "就说你下海去了。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "完了完了。不是这样说法。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "怎样说法。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "那七八十的老人家，听她儿子下海去了，她这个日子，怎么过呢？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "哪。"
        },
        {
          "character": "夏得海",
          "type": "吹腔",
          "text": "说你儿，昨日在我这店中， 咳，可怜他含悲饮数盅， 再不来沾美酒，再不来捧玉盅。 咳，为只为公文，把我的残生来断送。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是啊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "这样喝法不爽快。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "怎样吃法？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "我来喝个白龙挂。我把嘴张开了，你把酒来灌，灌得我煞渴。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "好，待我来灌。 啊伙计，拿酒来啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下锣。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "吃得倒也好看。啊。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "哎呀，不喝了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "再来再来。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "等一同下海去，还要喝水。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦。不吃算帐。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "把这银子，放在你店中，酒钱你算了去。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "余多呢？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "等我儿子来拿。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "你儿子要是不来呢？"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "你当我的孙子。你拿去用。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "不要胡闹。下海去死罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家下。"
        },
        {
          "character": "夏得海",
          "type": "数板",
          "text": "好酒。慌慌走，走慌慌。一走走到海滩上。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "啊，四面汪洋都是水，叫我如何来下。如何来下？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏得海睡下场台口。二海巡同上。"
        },
        {
          "character": "二海巡",
          "type": "同念",
          "text": "海鬼海鬼，头上两个傀儡。头顶太行山，脚踏四海水。"
        },
        {
          "character": "二海巡",
          "type": "同白",
          "text": "我乃巡海夜叉是也。今日无事，去往海上巡视巡视。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏得海喘。"
        },
        {
          "character": "二海巡",
          "type": "同白",
          "text": "哪里生人气？ 啊，怎么海滩之上，睡着一个汉子？待我看来。 啊，怀揣公文一角，不免引他去见龙君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二海巡同走圆场。传点。"
        },
        {
          "character": "二海巡",
          "type": "同白",
          "text": "启龙君：海滩之上，睡着一汉子，怀揣公文一角，前来投递。"
        },
        {
          "character": "龙王",
          "type": "内白",
          "text": "有请。 （二海巡同唤夏得海，夏得海醒。四水族、四太监引龙王同上，夏得海见礼。入坐。设宝库出彩。丑上，跳 牙笏，加官上，排字扮戏唱，下。）"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "啊贵差，小神将原文批回，烦驾拜复状元爷，细详原文，行事就是。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "承蒙龙王厚意。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "公务在身，不敢久停。告辞了。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "不敢强留。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙王、四水族、四太监同下。二海巡送夏得海到原处，二海巡同下。夏得海醒。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "嗳唷好睡啊。哎呀，怎么还是在沙滩之上。呵呵。有了。待我在怀中摸摸公文， 可曾遗失。哈哈。还好还好，趁此天色尚早，不免赶紧回去，回复老爷。走 啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡襄、四青袍同上。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "启禀老爷：小的夏得海，奉差东海公干，批回原文呈上。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "啊，怎么添上一个“醋”字？哦哦是了。莫非龙神有灵，点化我蔡襄，择选二 十一日酉时下桩安堍。神圣啊神圣，真乃有灵也！"
        },
        {
          "character": "蔡襄",
          "type": "西皮摇板",
          "text": "酬龙君和潮神有灵有验， 怜蔡襄不辞劳一点孝心。 但愿得廿一日风平浪静， 到那日兴工程酬愿建桥。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "啊，夏得海，命你早备人役，即日兴工。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏得海允。"
        },
        {
          "character": "蔡襄",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡襄下。"
        },
        {
          "character": "夏得海",
          "type": "白",
          "text": "开工。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放水晶炮。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（八仙同上，同过桥，同下。蔡襄、四青袍同上，过场，同下。三十六行同上，同演，同下。猪龙形暗上，"
        },
        {
          "character": null,
          "type": "text",
          "text": "坍桥，下。八水妖同上。将军令。八水妖同下。江猪海母龙上。）"
        },
        {
          "character": "江猪海母龙",
          "type": "点绛唇",
          "text": "雾销安，朗月照光残，闷五散，烧炼金丹，玉貌花容惭。"
        },
        {
          "character": "江猪海母龙",
          "type": "白",
          "text": "吾乃江猪海母龙是也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水族上。"
        },
        {
          "character": "水族",
          "type": "白",
          "text": "报：今有海滩之上，建一洛阳桥长桥，挡住我们洞府，请令定夺。"
        },
        {
          "character": "江猪海母龙",
          "type": "白",
          "text": "呔，众小妖，决动四海之波，淹灭者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八水妖同允。众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大士暗上，到桥口看。"
        },
        {
          "character": "大士",
          "type": "白",
          "text": "天灵灵，地灵灵，众神将安在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众天将同上。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "菩萨有何法谕？"
        },
        {
          "character": "大士",
          "type": "白",
          "text": "今有猪龙作乱，淹灭众生。尔等速急前去降妖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大士下。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八水妖同上，同会阵，同开打。众神将摆阵同上，擒猪龙形同下。"
        },
        {
