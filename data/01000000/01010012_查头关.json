{
  "script_id": "01010012",
  "title": "查头关",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "尤春风",
      "hangdang": "旦"
    },
    {
      "name": "苏里烟",
      "hangdang": "丑"
    },
    {
      "name": "刘唐建",
      "hangdang": "小生"
    }
  ],
  "plot": "汉太子刘唐建，奉太后命，出关追驾，途经尤家关，在关外歇息，拴马而睡。适番女将尤春风，带同番将苏\n里烟，夜出查关，见远处有红光如火，尤春风因遣苏里烟往查。见一年少蛮子，露宿在彼。留心细察，又见\n蛇攒七窍。尤春风素读南朝书，知系贵相，当即令苏里烟唤醒盘问，始知即汉太子。尤春风乃留之入关，乞\n以身事，并先索封。刘唐建乃漫封为昭阳正宫。后刘唐建不愿居此，借故遁去，又为二关二姑娘所获，亦然\n私留索封，即《逃关·二关》等剧是也。",
  "notes": "《查头关》亦单称《头关》，系《赶三关》之一，昆剧中名《宿关》，后本又有《逃关·二关》等剧。本剧，\n亦大半从昆剧中脱胎而出。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建上。"
        },
        {
          "character": "刘唐建",
          "type": "西皮摇板",
          "text": "家中奉了母亲命， 去往京城走一程。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "俺，刘唐建。奉了母亲之命，去往京城迎接父亲。天色甚早，就此马上加鞭。"
        },
        {
          "character": "刘唐建",
          "type": "西皮摇板",
          "text": "我这里催马往前进， 去往京城迎父亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尤春风、丫鬟同上。"
        },
        {
          "character": "尤春风",
          "type": "念",
          "text": "把守窑萁关，儿郎心胆寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤春风坐。"
        },
        {
          "character": "尤春风",
          "type": "念",
          "text": "头打三股辫，两耳坠金环。行走风摆柳，坐下似天仙。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "咱家尤春风。奉老都督将令，把守关口。今日查关日期。 丫头，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟允。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "传苏里烟进帐。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "姑娘传苏里烟进帐。"
        },
        {
          "character": "苏里烟",
          "type": "内白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟上。"
        },
        {
          "character": "苏里烟",
          "type": "数板",
          "text": "上河流水嘘唎嘘唎嘘，下河流水哗啦哗啦哗，二人盖了一个破瓦扎，动也不敢 动，拉也不敢拉，动一动，嘘唎嘘唎嘘，拉一拉，哗啦哗啦哗，嘘唎嘘唎嘘， 哗啦哗啦哗。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘在上，苏里烟摩礼角。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哎，往日施的什么礼？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "往日施的官礼。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "今儿个呢？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "今日施的蒙古礼。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "还施官礼。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘在上，苏里烟有礼。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "对了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘传我，有何屁放？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，有何话讲？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我们该去查关了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我们昨天查过了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么？昨天吃过饭，今天吃不吃？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "饭天天要吃。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "关天天要查。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "查关去。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "打个亮子。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，打亮子。"
        },
        {
          "character": "尤春风",
          "type": "南梆子导板",
          "text": "尤春风打坐在牛皮宝帐，"
        },
        {
          "character": "苏里烟",
          "type": "南梆子慢板",
          "text": "有鞑子我这里手提着灯笼。"
        },
        {
          "character": "尤春风",
          "type": "南梆子慢板",
          "text": "在宝帐我领了都督将令， 去到那窑萁关查看分明。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "押不得。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "又怎么呢？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "押不得押不得。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤春风、苏里烟、丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建上。"
        },
        {
          "character": "刘唐建",
          "type": "西皮摇板",
          "text": "扬鞭催马往前进， 举目抬头看分明。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "来到什么所在，待我下马看来。 哦呀，前面关门封锁，不免打一瞌睡便了。正是："
        },
        {
          "character": "刘唐建",
          "type": "念",
          "text": "一觉放开心地稳，梦梦沉沉到阳台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建睡。尤春风、苏里烟、丫鬟同上。"
        },
        {
          "character": "尤春风",
          "type": "西皮快板",
          "text": "急急走来往前行，"
        },
        {
          "character": "苏里烟",
          "type": "西皮快板",
          "text": "不觉来到是关门。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "到了，姑娘。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "查关去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "赫，姑娘查关来了！小鞑子们要不要钱，要钱我要抽头的。这边小鞑子们，穿 住裤子睡，不要露出零碎东西。姑娘查关来了！ 姑娘，查好了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你在哪里查的？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "在关里查的。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "咳，关里自己人，查什么！关外查去！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哎呀姑娘，关外我怕一个老头子。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你这个小伙子，怎么怕一个老头子？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不是那个老头子。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么老头子？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "这个老头子，四条腿一根尾巴，张开了大嘴，啊唔一口，是那个老头子。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "这是老虎吓！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不错的，是这个东西。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你腰里带的什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我刀里带的腰。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "吓，腰里带的刀！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不错，腰里带的刀。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "它给你一口，你与它一刀。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "慢慢，我来想想：它给我一口，我拔出刀来，与它一刀。来不及了，我倒死了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "好好查关，姑娘赏你个媳妇。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，好好查关，姑娘跟我作媳妇。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不不不是的，姑娘赏我一个媳妇。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "对了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "把谁赏与我？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "把这个丫头赏与你。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我瞧瞧好不好。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你瞧瞧去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哎呀，姑娘我不要！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "怎么不要？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我们是亲戚。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么亲戚？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我们姑表亲。我是姑子养的，她是婊子养的。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "你不要我，我还不愿意跟你呢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "好好的查关，姑娘有赏。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哽，待我查关了。 姑娘了不得了！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "关外起了火了！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "怎么，有了火了？待我看看。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘看看。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你远看——"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "是火。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "近取——"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "一个小蛮子打睡。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "把他马先盗过来。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "待我盗马。 姑娘，马盗过来了，你瞧瞧。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哎吓，好马！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "好马。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "好骡头！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "好骡头。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "好颜色！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "好颜色。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你再看看！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "一根马尾没有。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "小蛮子有矛子。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不解裤子，怎么看见人家瞭子？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦哦哦，矛子矛子。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "盗去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "待我盗矛子。 姑娘，矛子盗来了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "把这个小蛮子叫醒呢。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "待我叫去。 哎吓，可了不得了！小蛮子眼睛里头有一条红虫子出来了，出来呢！扒在这边 眼睛里去了。出来呢，扒在鼻子里去了。出来呢，扒在耳朵里去了。出来呢， 扒在嘴里去了。出来呢，出来呢！不好了，扒在屁股眼子里去了！ 姑娘了不得了！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "这个小蛮子，眼睛里头，有一条红虫子，一回出来，扒在鼻子里去；一回出来， 攒到耳内；一回攒到嘴内，一回攒到屁股眼里头，没有了！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "那是蛇攒七窍。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "蛇攒七窍，怎么一回事？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "蛇攒七窍，真龙天子。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "蛇攒六窍呢？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "连中三元。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "蛇攒一窍呢？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "蛇攒一窍吓，不晓得了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "蛇攒一窍，姑娘怎么会不知道了？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦哦哦，姑娘不知道。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "快把小蛮子叫醒了吧！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "呔！小蛮子醒来！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "呔！看枪！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "拿过来吧！把我的马杆，都偷了去了。 姑娘，叫醒了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "问他家住哪里，姓甚名谁？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "那一小蛮子，姑娘问你家住哪里，姓甚名谁。说明白了，还你枪马。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "说明了还俺枪马？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哽，还你枪马。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "刘唐建",
          "type": "西皮导板",
          "text": "开言便把户长称，"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我打你，你开口骂人！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "哎，怎么骂你吓？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "你骂我是混账。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "你听错了，我说的是户长，一户之长，哪一个骂你混账？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，户长，不是混账。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "不是混账。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我们这里不叫户长。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "叫什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我们这里叫押户。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "怎么叫押户？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我这里一押，你那里一户。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "刘唐建",
          "type": "西皮慢板",
          "text": "去掉了户长把押户称。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "对了。"
        },
        {
          "character": "刘唐建",
          "type": "西皮慢板",
          "text": "家住在赤手托空县， 谎家庄上有家门。 我的父名叫谎员外， 我的母吃斋又动荤。 若问俺的名和姓， 云端里说话雾里听。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘，问来了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "怎么说？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘听了！"
        },
        {
          "character": "苏里烟",
          "type": "西皮导板",
          "text": "开言便把户长称，"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哽，你怎么骂我混账？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不是骂人，他那里称户长，是称呼人。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我们这里不叫户长。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我们这里不叫户长，叫押户。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哦，叫押户。你说你的。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "苏里烟",
          "type": "西皮慢板",
          "text": "去掉了户长把押户称。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他家住哪里？"
        },
        {
          "character": "苏里烟",
          "type": "西皮慢板",
          "text": "家住在赤手托空县， 谎家庄上有家门。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他姓甚名谁？"
        },
        {
          "character": "苏里烟",
          "type": "西皮慢板",
          "text": "他父名叫谎员外， 母亲吃斋又动荤。 若问他的名和姓， 云端里说话雾里听。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哎呀，苏里烟，你让人家攒了！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "咳，多大的手，好攒我？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哎，让人家谎驱了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘，我怎么让他骗了？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你想哪里有个赤手托空县？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，没有的。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哪里有什么谎家庄？什么谎员外？他母怎么吃斋又动荤？要问他的名姓，什么 “云端里说话雾里听”？让人骗了！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "怎么，他骗的我了？哦，没有这个事。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哽，没有这回事？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘，这怎么好？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "苏里烟，你跟他说去：你说姑娘住在两国交界，看过满汉四大奇书，无有一样 不知，哪样不晓。你叫他快说真名实姓，如若不然，你就拔出刀来，你就吓唬 吓唬他。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，是了。 那一小蛮子，我家姑娘住在两国交界，看过满汉四大奇书，无有一样不知，哪 样不晓。你快说出真名实姓，如若不然，我要拔出刀来，我就这一刀，吓唬你 的！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "如此听了！"
        },
        {
          "character": "刘唐建",
          "type": "西皮快板",
          "text": "家住在大国长安地， 紫禁城内有家门。 我的父名叫汉元帝， 我的母名叫赛昭君。 若问我的名和姓， 刘唐建就是我的名。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，是这个，早说好不好。 姑娘，问来了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "住在哪里吓？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "他住在啊国啊的……"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哦，大国长安地。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "对了。他是他子……"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "紫禁城内有家门。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "对了，他父名叫一块地。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "呸！汉元帝！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不错。他母名叫吃大饼。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "呸！赛昭君！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "对呢。要问他的名和姓，他叫不要脸。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "呸！他名叫刘唐建！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "你瞧，姑娘都知道，要我问干什么？让我着了半天的急。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他说话不真，你传话不明。你把小蛮子拉进来，我亲自问他。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，我拉去。 那一小蛮子，兔子说话不真，老子说话不明。姑娘叫你亲自上前答话。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "俺不去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "你不去，我就要拉了。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "俺不去，俺不去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我要拉了。跟我来，跟我来，跟我来！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哽，你那里干什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我拉住小蛮子了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你看看拉住谁呢？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哎吓，拉错了。姑娘他不进来，怎么好？有了，我吓唬吓唬他。 那一小蛮子，你还不进来，我就要一刀！"
        },
        {
          "character": "尤春风",
          "type": "南梆子导板",
          "text": "一见小将容貌齐，"
        },
        {
          "character": "尤春风",
          "type": "南梆子慢板",
          "text": "不由我一阵阵心内发迷。 走上前来拉住小将手， 我与你牛皮帐细说端的。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "苏里烟，倒茶去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，我倒茶去。 小蛮子，我倒茶去，不许你动一动；你要动一动，是个王八蛋杂种！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟下。"
        },
        {
          "character": "尤春风",
          "type": "西皮快板",
          "text": "走上前来忙跪定， 我主封我哪一宫？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟上。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "茶来了，姑娘喝茶。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我不喝，与小蛮子喝了吧。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "这么好的茶，给他喝？我漱漱口才给他喝。 小蛮子喝茶。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "我不喝茶。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "喝一点吧。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "一点点也不喝。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "不喝？ 姑娘，他不喝。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "赏与你喝吧。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "多谢姑娘！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "回来，当着我的面喝。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，当面喝。姑娘，方才我走到半路上，一下子跌了一个跟头。哎吓，姑娘， 这个茶洒了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "装烟去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，装烟去。 小蛮子，还是不许你动；你要动一动，我回来要你的命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟下。"
        },
        {
          "character": "尤春风",
          "type": "西皮快板",
          "text": "走上前来双膝跪， 千岁封我哪一宫？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟上。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "烟来呢。姑娘抽烟。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我不抽，给小蛮子抽。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "烟又与他抽。 小蛮子抽烟。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "哎呀，烫了我的嘴了！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘给你抽烟。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "我在礼的不抽烟。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "抽一口。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "一口也不抽。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘，他不抽。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "不抽罢了。你遛遛马去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "遛过了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "喂马去。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "喂过了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哎吓，你外头绕个弯去吧！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，叫我绕个弯儿。 姑娘，绕过了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "吓，要大大的绕个弯儿！"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，让我大大的绕一个弯儿。 哎，姑娘，我看见了，小蛮子搂住姑娘呢！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哦，小蛮子搂住我，你生气吓？再搂我一搂。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我不生这个气。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你在这里干什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "伺候姑娘。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "不用你伺候，你走不走？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我不走。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你不走我就杀了你。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘你不要杀了我。我不走，这出戏也唱不完。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟下。"
        },
        {
          "character": "尤春风",
          "type": "西皮快板",
          "text": "走上前来忙跪定， 千岁封我哪一宫？"
        },
        {
          "character": "刘唐建",
          "type": "西皮快板",
          "text": "有朝一日登龙位， 封你朝阳作正宫。"
        },
        {
          "character": "尤春风",
          "type": "西皮快板",
          "text": "千岁台前把我封， 叩罢头来谢罢恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟上。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "看见了，看见呢！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "看见什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘跪在小蛮子跟前。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "没有吓。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘腿上泥是哪里来的？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哦，腿上泥吓……苏里烟吓，你看见嘘嘘哈没有？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "没有吓，在哪里？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "在哪里？在哪里？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "唗，飞了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "姑娘会变戏法。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你认识他不认识他？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我不认识。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他是小皇上。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "他是黄鳝？在鱼摊上。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他是主子。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "肚子？肉店里。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他是大王。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "大黄？药店里头。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "呸！他是一国的小皇。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，他是一国的小王吓！你方才跪在那里干什么？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他封我了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "拿鸡罩来扣你了？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "干什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "你不是要疯了么？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "唬，我讨的封了。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "封你什么？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "封我一宫。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "叫他封我一宫。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "男人哪有封宫的？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "你东宫，我西宫，走水路是你，走旱路是我。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "不要胡说了。叫他封你官吧。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "封我一个官吧。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "主子，封他一个官吧。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "苏里烟听封。"
        },
        {
          "character": "刘唐建",
          "type": "西皮快板",
          "text": "有朝一日登龙位， 封你这么大……"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "多多大？"
        },
        {
          "character": "刘唐建",
          "type": "西皮快板",
          "text": "这么大一个大杂种。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "我杀了你！不要你封！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "干什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "他封我一个大杂种！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哦，他骂你杂种？我来问问他。 主子，封不封但凭与你，为什么骂他杂种？"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "哪一个骂他杂种？封他把总。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哦，不是骂你，你听错了，人家封你把总。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，不是杂种？再来。"
        },
        {
          "character": "刘唐建",
          "type": "西皮快板",
          "text": "有朝一日登龙位， 封你一个……"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "刘唐建",
          "type": "西皮快板",
          "text": "封你一个大把总。"
        },
        {
          "character": "苏里烟",
          "type": "西皮快板",
          "text": "叩罢头来谢龙恩， 多蒙主子将我封。咙咚呛！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "干什么？"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "皇帝登基，撞钟擂鼓。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "还没登基，不用钟鼓。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "哦，你们后台登基去吧。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "万岁请。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "娘娘请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建、尤春风同下。"
        },
        {
          "character": "苏里烟",
          "type": "白",
          "text": "咦，他们走了，我也走了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏里烟下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}