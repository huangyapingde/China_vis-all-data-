{
  "script_id": "01014012",
  "title": "摘缨会",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "唐狡",
      "hangdang": "武生"
    },
    {
      "name": "连尹襄老",
      "hangdang": "丑"
    },
    {
      "name": "徐妃",
      "hangdang": "旦"
    },
    {
      "name": "先蔑",
      "hangdang": "净"
    }
  ],
  "plot": "春秋时，楚国养由基与斗越椒在清河桥赛箭，射死斗越椒，楚庄王遂一鼓而灭斗氏。班师回都，论功行赏，\n大宴群臣于渐台。楚庄王以内乱克平，又除去极恶大憝，心中无限欣喜。特宣宠妃姜氏上台，送群臣酒，以\n表敬礼之心，籍售牢笼之术。姜妃姿容曼妙，体态轻盈，见之者不禁目眩神夺。而姜妃初无容心，挨次斟酒。\n至一小将前，轻启朱唇，微扬玉手，献觞劝酌。如此天仙化身之美人，立在身伴，闻其香泽，魂魄早为之\n飞越。适值怪风骤起，灯火尽行扑灭。霎那之顷，小将执其又软又滑之柔荑，一再抚摩。虽不能真个销魂，\n得与绝世美人有肌肤之亲，亦属一桩大快事。以为黑暗之中，决无人见，不料姜妃心灵手敏，趁势搅断其冠\n缨。循步至楚庄王前，耳语以故。楚庄王急传命，与宴百官，所有冠缨，一一摘下，交纳前来，浑在一处，\n是会即名摘缨会。再命点齐灯火，君臣尽欢而散。回宫后，姜妃仍请查缉，楚庄王笑解之，曰：“酒后猖狂，\n事所恒有。并非真心调戏，不必介怀。”卒置不究。后晋国兴兵伐楚，楚庄王御之。被围不解，已岌岌可\n危。有唐狡者，单身冲入，勇不可当。擒获晋国主将，转败为胜。问其何故舍命相救，则云某即昔年戏妃之\n人，王不加罪，缘是以报。可见楚庄王能容忍小忿，爱惜将士，宜其兴楚国，霸诸侯，为春秋时赫赫有名之\n英君也。",
  "notes": "按《东周列国演义》，载称楚庄王伐郑，连尹襄老部下，副将唐狡，自请率领本部百人，先行开路。所至力\n战，当者辄靡，大军因之毫无阻滞。王问之，逐明言戏妃不罪，愿出死力以报恩。欲厚赏之，唐狡不肯以罪\n人邀赏，遁去不知所往。今剧本如是云云，不知编排者何所依据。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。〖牌子〗。四太监、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "引子",
          "text": "坐镇荆襄，成霸业，威服列邦。"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "战国纷纷意不合，争夺疆土动干戈。威服邻邦成霸业，太平安固锦山河。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤，楚王熊旅。恼恨斗越椒，兴兵犯上，欲夺孤王社稷。幸喜皇天保佑，灭却 老贼，奏凯回朝。众家功臣，须得分功论赏。 内侍，宣众功臣上殿！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "大王有旨，众功臣上殿！"
        },
        {
          "character": "众将",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同上。"
        },
        {
          "character": "众将",
          "type": "同念",
          "text": "扫灭狼烟干戈靖，卷旗息鼓享太平。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "参见大王。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众卿少礼。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "将臣等宣上殿来，有何军情议论？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "且喜干戈宁靖，奏凯还朝。孤今日大排筵宴，庆贺功臣，与众卿痛饮。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "多谢大王。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "内侍，看宴侍候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水龙吟〗。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "内侍，宣徐娘娘上渐台。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "大王有旨：宣徐娘娘上渐台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐妃上。"
        },
        {
          "character": "徐妃",
          "type": "念",
          "text": "忽听大王宣，迈步上银安。"
        },
        {
          "character": "徐妃",
          "type": "白",
          "text": "参见大王。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "梓童少礼，速登渐台。 内侍，看酒。 吓，众卿，今日与众卿饮宴，快乐非常。欲命徐妃，与诸卿进酒一杯，以取君 臣同乐。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "臣等有何德能，敢劳娘娘进酒。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤心已定。 梓童进酒。"
        },
        {
          "character": "楚庄王",
          "type": "西皮原板",
          "text": "君臣对坐饮琼浆， 分功论赏古之常。 周文王造灵台与民欢畅， 孤今日宴群臣喜洋洋。 一霎时狂风起灯光无亮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡调戏徐妃，徐妃去唐狡盔缨，上台付耳。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "呵！"
        },
        {
          "character": "楚庄王",
          "type": "西皮原板",
          "text": "叫梓童回宫去孤有主张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐妃下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "且慢掌灯。今日之宴，非比寻常。众卿各将盔缨摘下，就名为摘缨大会。若无 盔缨者，罚酒三觥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍取各盔缨，呈。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "掌灯！"
        },
        {
          "character": "楚庄王",
          "type": "笑",
          "text": "呵哈哈哈哈！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "内侍将宴撤下，众卿各退朝房。退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王下。众将同下。唐狡比式。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "咳。险呐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、徐妃同上。"
        },
        {
          "character": "徐妃",
          "type": "西皮摇板",
          "text": "适才殿上进酒浆， 胆大狂徒起不良。 宫娥带路后宫往， 等候大王问端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "西皮摇板",
          "text": "宴罢了文武臣神清气爽， 问梓童因何故面带彷徨？"
        },
        {
          "character": "徐妃",
          "type": "白",
          "text": "启大王：适才殿上，那胆大狂徒调戏妾身。不知大王怎样发落？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤念他酒醉，一概不究。"
        },
        {
          "character": "徐妃",
          "type": "白",
          "text": "他调戏国母，就该将他问斩。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "梓童，吓。"
        },
        {
          "character": "楚庄王",
          "type": "西皮正板",
          "text": "劝梓童休得要把本奏上， 听孤王把前情细说端详： 都只为斗越椒兴兵犯上， 只杀得众将官死故逃亡。 天降下养由基英雄小——"
        },
        {
          "character": "楚庄王",
          "type": "西皮二六板",
          "text": "将， 清河桥比箭法老贼身亡。 因此上奏凯回分功论赏， 就有那无名辈酒后癫狂。 孤本当查姓名将他捆绑， 怕的是杀功臣遗笑邻邦。 劝梓童将此事休挂心上， 劝梓童把此事付与汪洋。 宫娥女掌红灯后宫往，"
        },
        {
          "character": "楚庄王",
          "type": "西皮摇板",
          "text": "孤与你同偕老日久天长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。四龙套、先蔑同上。"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "吾，晋国大司马先蔑。今奉晋侯之命，带领人马，攻伐楚邦。 众将官，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。四龙套、先蔑同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、连尹襄老同上。"
        },
        {
          "character": "连尹襄老",
          "type": "念",
          "text": "晋楚常争斗，何时得罢休。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "老夫连尹襄老。今有晋国先蔑带兵前来，大王命我为前战先行。 左右侍候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡上。"
        },
        {
          "character": "唐狡",
          "type": "念",
          "text": "摘缨得活命，未能报国恩。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "唐狡，无令进帐何事？"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "今有晋国先蔑，兴兵前来。末将不才，情愿攻打头阵。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "你小小年纪，怎是那先蔑的对手？"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "元帅说那里话来。自古道，有志不在年高，无志空活百岁。元帅你好小量人也。"
        },
        {
          "character": "唐狡",
          "type": "西皮摇板",
          "text": "英雄惯出少年将， 一人能当百万郎。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "本帅正要出兵，你在帐中絮絮叨叨。 来，叉出帐去！"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡下。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "众将官，人马可齐？"
        },
        {
          "character": "众",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "先蔑、四龙套同上。对阵。"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "来将通名受死。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "我乃楚国先锋官，连尹襄老是也。"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "无名小辈，放马过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "连尹襄老败下，先蔑追下。四龙套、四大铠、二将、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "西皮紧板",
          "text": "旌旗不住空中飘， 个个儿郎杀气高。 同心竭力把贼扫， 旗开得胜转还朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "连尹襄老上。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "参见大王。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "可曾与晋兵见过阵来？"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "会过一阵，大败而回。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同转场。四龙套、先蔑同上。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "胆大先蔑，我国何曾亏负你等。每每侵犯吾国疆土，是何理也？"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "吾奉晋主之命，带领倾国人马，要与尔平分疆土。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "一派胡言！放马过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王败下。三将接战，同败下。先蔑追下。楚庄王上，先蔑追上，楚庄王下，先蔑下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "唐狡上。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "俺，唐狡。今有我主与晋兵交战，待我登高一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王上，先蔑打，楚庄王下，先蔑下。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "且住。前面败的我主，后面乃是先蔑追赶。此时若不搭救，等待何时？ 唉！先蔑休走，你老爷来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡耍刀，下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王上，先蔑上，刺楚庄王落马。唐狡上，起打，先蔑下。四龙套同上，开打，同下。楚庄王看。"
        },
        {
          "character": "楚庄王",
          "type": "西皮摇板",
          "text": "孤被先蔑挑下马， 忽然闪出年少娃。 满营将官俱败下， 孤王怎么就不认识他？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "先蔑上，唐狡追上，打，擒先蔑，下。连尹襄老上。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "吓。爱卿，孤的马呢？"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "大王的马，叫先蔑扎死啦。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "你的马呢？"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "我的马？昨夜就跑啦！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿家，摆驾回营。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王、连尹襄老同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、连尹襄老、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "小将立功劳，孤王喜心梢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "先蔑擒到。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "押上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刀斧手押先蔑同上。"
        },
        {
          "character": "楚庄王",
          "type": "西皮快板",
          "text": "战鼓不住咚咚打， 先蔑老儿听根芽： 适才阵前威名大， 此时为何被孤拿？ 人来与孤忙绑下， 立斩人头正军法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刀斧手推先蔑同下，斩。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "小将军到。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡上。"
        },
        {
          "character": "楚庄王",
          "type": "西皮快板",
          "text": "一见小将喜心下， 孤王言来听根芽： 适才蒙你来救驾， 你就是孤王救苦救难观世音、活菩萨。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "小将军，孤与你素不相识，你为何舍命救我？"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "大王可记得，摘缨会之故事乎？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "啊，哈哈，呀！想当年摘缨会之时，孤若查明将他问斩，孤家焉有今日？ 呵，小将军，孤今封你统兵大元帅，参理朝政。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "谢大王。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "慢着。今日他为元帅，正管我一头。不免与大王说明，替我讲个情儿。 臣启大王：想臣那日出兵之际，小将曾来讨令，老臣因他年幼，将他叉出帐去。 今日他为元帅，老臣正他所管，臣恐公报私仇，求大王做主。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "这有何难。小将军，今将襄老拨在你帐下听用。倘有差错，按军法从事。"
        },
        {
          "character": "连尹襄老",
          "type": "白",
          "text": "好，好！倒闹了个倒讬。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "后帐摆宴，与小将军贺功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
