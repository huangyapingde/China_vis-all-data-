{
  "script_id": "01006013",
  "title": "孝义节",
  "alias": [
    "索庙"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "孙尚香",
      "hangdang": "正旦"
    },
    {
      "name": "吴国太",
      "hangdang": "老旦"
    },
    {
      "name": "门神甲",
      "hangdang": "丑"
    },
    {
      "name": "门神乙",
      "hangdang": "生"
    }
  ],
  "plot": "此剧系《别宫祭江》之后，孙尚香鬼魂还宫，托兆吴后，自言投水之后，尸向西逆流，在芜湖关旁，已蒙上\n帝嘉我节烈，敕封为枭姬娘娘，受世人祭享。但虽受封，却无庙堂可以凭式。吴后乃许为立庙云。",
  "notes": "按前过枭矶祠，相传为孙夫人之祠庙。但此“枭”字甚不雅观，其确系孝姬而讹为枭矶乎？抑本系枭矶而流\n传附会为孝姬乎？还请致诸孙尚香。一笑。此剧二黄摇板甚多，为青衫之唱工重头戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "点绛唇",
          "text": "沧海连江，乾坤浩荡，虽受职，哪有庙堂，何处受祭享！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上高台。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "大孝能感天，节义须周全。神光照水府，慧眼望西川。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "吾乃孙氏尚香灵魂是也。配夫玄德，在西蜀为君。只因荆州失陷，在白帝城晏 驾。幸喜阿斗接位。奴在东吴，投江尽节一死。蒙上帝怜悯，敕封为神。奈无 庙堂，谁来祭祀？今去托兆母后，建造庙堂，重名于世。 众水卒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "随我同往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下高台。"
        },
        {
          "character": "孙尚香",
          "type": "西皮导板",
          "text": "驾神风急冲开长江波浪，"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "灵光照齐护拥孝姬娘娘。 我本是千金女皇宫生长， 今方见世间人名利奔忙。 蒙敕封并无有"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "坐位神像，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "长寿宫托母兆建造庙堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、吴国太同上。"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "夫本是炎汉家辅国大将， 小孙策寿命短少年夭亡。 孙仲谋霸江东独把业掌， 汉江山分三国俱想称皇。 魏天时吴地利人和气旺， 为荆州叹我婿白帝城亡。 尚香儿全节义祭夫亲往， 儿百步母枕忧难解愁肠。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "本后吴氏。长子孙策，少年夭亡。次子孙权，虎踞江东。幼女尚香，配夫玄德， 西川为帝。只为荆州，被陆逊火烧连营，叹我儿婿，身丧白帝城中。女儿亲 往江边祭奠，怎么还不回宫？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "太后大事不好了！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "郡主投江已死！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "你才怎讲？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "郡主投江而亡！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "吴国太",
          "type": "西皮导板",
          "text": "儿为夫尽节死鱼肠埋葬，"
        },
        {
          "character": "吴国太",
          "type": "三叫头",
          "text": "尚香！我儿！哎儿吓！"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "比前朝汉昭君不舍刘王。 夫身丧妻尽节虽有榜样，"
        },
        {
          "character": "吴国太",
          "type": "哭",
          "text": "哎呀！"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "恐难效孟姜女受职表扬。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "内臣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监允。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "郡主投江，可有人搭救？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "难以救起。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "报与主公知道。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。"
        },
        {
          "character": "吴国太",
          "type": "三叫头",
          "text": "尚香！我儿！儿吓！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "为娘若知你有此尽节之心，我也不要你江边祭奠去了吓！"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "要尽节也应该对娘直讲， 讨祭奠投江死魂灵渺茫。 天保佑儿命在免娘痴想，"
        },
        {
          "character": "吴国太",
          "type": "哭",
          "text": "儿吓！"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "宫娥们扶本后即归龙床。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女搀吴国太同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二门神同上。"
        },
        {
          "character": "门神甲",
          "type": "念",
          "text": "上苍有旨意，"
        },
        {
          "character": "门神乙",
          "type": "念",
          "text": "看守宫门庭。"
        },
        {
          "character": "门神乙",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "门神甲",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "门神乙",
          "type": "白",
          "text": "奉了玉帝敕旨，看守宫门。远远望见，孙氏尚香来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "二黄摇板",
          "text": "水晶宫与阳间一般模样， 也有这银銮殿画角雕梁。 众神将且肃静休要声嚷， 比不得水府内任儿猖狂。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "尊神请了。"
        },
        {
          "character": "二门神",
          "type": "同白",
          "text": "到此何事？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "尊神吓！"
        },
        {
          "character": "孙尚香",
          "type": "二黄摇板",
          "text": "奴虽受玉帝封魂魄飘荡， 哪一处是我的神位庙堂？ 乘夜来见我母待求方向， 托一兆不久停即出宫墙。"
        },
        {
          "character": "二门神",
          "type": "同白",
          "text": "只许你一人进去，休要惊吓于她。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": "孙尚香",
          "type": "二黄摇板",
          "text": "你等在宫门外隐身休闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。"
        },
        {
          "character": "孙尚香",
          "type": "二黄摇板",
          "text": "二尊神请让路暂息张扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。二门神同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引吴国太同上。"
        },
        {
          "character": "吴国太",
          "type": "二黄原板",
          "text": "恨的是陆伯言智足谋广， 火攻计烧连营鸡犬难藏。 大限到在数灾难逃罗网， 尚香在吴国内未离兰房。 将身儿且坐在龙凤锦帐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": "吴国太",
          "type": "二黄原板",
          "text": "闷恹恹只想我幼女尚香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上。"
        },
        {
          "character": "孙尚香",
          "type": "二黄摇板",
          "text": "在生前常出进宫人随往， 今见母孤单单躲躲藏藏。 欲开言老年人心散神恍， 跪御榻音声细忍住凄惶。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后醒来！"
        },
        {
          "character": "吴国太",
          "type": "二黄导板",
          "text": "空负我数十年儿女娇养，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "吴国太",
          "type": "二黄摇板",
          "text": "听姣音真是我幼女尚香。 见儿面方把我愁眉展放，"
        },
        {
          "character": "孙尚香",
          "type": "回龙",
          "text": "人命大关系重岂能谎谈。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "尽节死阴灵魂水府路上， 未报答哺乳恩难舍亲娘。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "吴国太",
          "type": "反二黄慢板",
          "text": "听儿言似空中霹雳下降， 娘好似燕衔泥枉费心肠。 为荆州献儿计恨你兄长， 甘露寺娘见面相儿招夫郎。 今尽节不尽孝娘谁供养？"
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "老娘亲缺甘旨还有兄王。 尽节烈以图了后人钦仰， 儿不是枭鸟心天大仓娘。"
        },
        {
          "character": "吴国太",
          "type": "反二黄慢板",
          "text": "古今来女生时面生外向， 但不知儿尸首漂流何方？ 阴灵魂既见娘直言话讲， 寻着你尸和首好去奔丧。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "儿的尸向西方逆水漂上， 蒙上帝敕封我孝姬娘娘。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哦，儿封为孝姬娘娘？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿的尸首呢？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄原板",
          "text": "女阴魂想西川独自难往， 尸现在芜湖关江北路旁。"
        },
        {
          "character": "吴国太",
          "type": "反二黄原板",
          "text": "孝义心感天地上帝旌奖，"
        },
        {
          "character": "孙尚香",
          "type": "反二黄原板",
          "text": "虽敕封并无有寺院庙堂。"
        },
        {
          "character": "吴国太",
          "type": "反二黄原板",
          "text": "娘传旨建庙堂儿受祭享，"
        },
        {
          "character": "孙尚香",
          "type": "反二黄摇板",
          "text": "谢母后天地恩日月寿长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄摇板",
          "text": "睁眼看月光隐日出浮山，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。二宫女同上。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "太后醒来！"
        },
        {
          "character": "吴国太",
          "type": "二黄导板",
          "text": "见姣儿诉衷肠平日一样，"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "醒来！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哎呀，儿吓！"
        },
        {
          "character": "吴国太",
          "type": "二黄摇板",
          "text": "宫娥女惊醒了大梦一场。"
        },
        {
          "character": "吴国太",
          "type": "哭",
          "text": "儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女搀吴国太同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}