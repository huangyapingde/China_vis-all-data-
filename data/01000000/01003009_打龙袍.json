{
  "script_id": "01003009",
  "title": "打龙袍",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "李后",
      "hangdang": "老旦"
    },
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "宋仁宗",
      "hangdang": "小生"
    },
    {
      "name": "灯官",
      "hangdang": "丑"
    },
    {
      "name": "王延龄",
      "hangdang": "老生"
    },
    {
      "name": "陈琳",
      "hangdang": "丑"
    }
  ],
  "plot": "包拯既知李后事，欲将情由奏明宋仁宗，因先令军民在宫外演放花灯，请上同往观看，并预吩咐扮演《清风\n亭雷打张继保》等杂剧，以动上意。包拯乃乘机将李后之事奏上，宋仁宗初犹未信，反含怒回宫。及召陈琳\n询问，陈琳将二十年前狸猫换主之事，一一奏知，并言有寇准题诗罗帕为证。其时后宫忽报刘太后自尽，上\n乃益信，即命包拯代驾迎接李后还宫，遂得母子团聚。李后因怒宋仁宗二十年来，生身之母，流落民间，竟\n绝不知晓，不孝如此，何以君临天下？遂赐紫金棍与包拯，令其责帝。包拯因臣无打君之理，乃以打龙袍塞\n责，故剧名云云。",
  "notes": "按此剧本出裨官。考《宋史》宋仁宗为李宸妃所生，而刘后抚为己子，与杨淑妃共养之，并无狸猫换主事。\n宋仁宗接位，刘太后垂帘十余年，颇称贤明。李后以明道元年，卒于宫，亦未流落民间，且较刘后先死年余。\n惟终李后与刘太后之世，宋仁宗讫未知为李出。且李卒，刘后强欲以宫人礼治丧于外。观此则刘之嫉抑宸\n妃，确无疑义。虽史未明载，恐此中亦不无暧昧也。\n此剧以《断太后》为前后本，全演者本连称《断后龙袍》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗上，太监上。"
        },
        {
          "character": "宋仁宗",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "平顶冠纱一鲜花，太阳一出照硃砂。南大一带朝北斗，孤是万民第一家。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤，大宋天子仁宗在位。自孤登基以来，风调雨顺，国泰民安。今当早朝。 内臣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监允。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "闪放龙门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "念",
          "text": "忙将包拯事，奏与万岁知。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "臣王延龄见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "包拯回朝，已在午门候旨。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "传旨宣包拯上殿。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "万岁有旨，包拯上殿。"
        },
        {
          "character": "包拯",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "忽听万岁宣一声， 陈州来了放粮臣。 撩袍端带吾就上龙廷， 品级台前臣见君。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣包拯见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包相平身。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "放粮之事，奏与朕知。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣有散粮表章呈上。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗看表。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "哦呵呀，原来包卿之功。内侍，光禄寺大排御宴，与包卿贺功！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢。臣出朝之时，在午门许下花灯大会，今日请万岁，午门观灯！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家前行，寡人随后。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "万岁爷准了臣的本， 他怎知国太受苦情。 午门外巧改扮花灯彩， 暗地打动有道君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。"
        },
        {
          "character": "王延龄",
          "type": "西皮摇板",
          "text": "辞别万岁下殿往， 去到午门看端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄下。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "内侍摆驾回龙庭， 明日早朝观花灯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗、太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "灯官上。"
        },
        {
          "character": "灯官",
          "type": "念",
          "text": "奉了包相命，午门扮花灯。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "在下灯官是也。奉了包相之命，扮齐各样的花灯。远远望见圣驾来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监、宋仁宗、包拯、王延龄同上。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "参见万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "将灯名报上来。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "咋！列位："
        },
        {
          "character": "灯官",
          "type": "数板",
          "text": "休要吵、休要闹，细听我把灯名儿报一报：报的是：一团和气灯、和合二圣灯、 三阳开泰灯、四季平安灯、五子夺魁灯、六国封相灯、七财子路灯、八仙过 海灯、九子十成灯、十面埋伏灯。这个灯，不算灯，那旁来了一套灯。若问此 灯什么名，昭君打马出雁门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灯上，下。"
        },
        {
          "character": "灯官",
          "type": "数板",
          "text": "灯又来了！看罢了一层又一层，吕布、董卓大闹凤仪亭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灯上，下。"
        },
        {
          "character": "灯官",
          "type": "数板",
          "text": "灯来了！看罢了一套又一套，那旁花灯又来到。亲父母也要孝，晚父母也要孝。 为人双亲若不孝，清风亭雷打张继保！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灯上，下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "哎吓！胆大的灯官，扮这样不忠不孝的灯。校尉，将扮灯官拿下！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢！万岁，为何将扮灯官拿下？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "扮这样不忠不孝的灯，故而将他拿下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "慢说不忠不孝之灯，就是不忠不孝之人，我朝现有。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "奏来，寡人将他碎尸万段！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣不敢冒奏龙颜。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "恕卿无罪。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "就是万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "听罢言来怒气生， 藐视寡人为何情？ 内侍摆驾回龙庭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗下。"
        },
        {
          "character": "王延龄",
          "type": "西皮摇板",
          "text": "回头埋怨小包拯。 有本就该当殿奏， 为什么扮灯藐视君？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师吓，"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "恩师休要胆怕惊， 学生言来听分明： 自古道忠臣我就不怕死， 怕死的人儿他就不忠臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王延龄同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、宋仁宗上。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "内侍摆驾金殿进， 唤上包拯问根原。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "包拯拿到。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押上殿来！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "万岁有旨，将包拯押上殿来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "忽听万岁宣包拯， 午门外来了有罪臣。 大摇大摆我就忙把龙廷进， 问我一言答一声。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "包拯作事太屈情， 不该扮灯藐寡人。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "陈州放粮转回京， 赵州桥前路难行。 偶遇狂风吹轿顶， 来了个瞎婆把冤伸。 为臣再三来盘问， 才知道国太受苦情。 亲生之母你不认， 犯法就是头一名！"
        },
        {
          "character": "宋仁宗",
          "type": "西皮快板",
          "text": "卿家得下疯魔病， 来在金殿欺寡人。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "休道臣得下了疯魔病， 国太的言语我记得清。 万岁若是不相信， 那景阳宫，问一问二十年前的老陈琳。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监押包拯同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "内侍，金牌宣，银牌召，宣亚父陈琳上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "万岁有旨：金牌宣，银牌召，亚父陈琳上殿！"
        },
        {
          "character": "陈琳",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": "陈琳",
          "type": "内西皮导板",
          "text": "金牌宣来银牌召定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈琳上。"
        },
        {
          "character": "陈琳",
          "type": "西皮流水板",
          "text": "景阳宫来了老陈琳。 万岁且把金殿进， 朝王驾来问安宁。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢陈琳见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "亚父平身，赐坐。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "陈琳谢坐！二十年未曾宣诏奴婢，今日宣诏，有何国事议论？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "小王有一事不明，要请亚父台前领教。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "何事不明，何为“领教”二字？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "请问亚父，小王乃何人所生？那宫所养？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢不敢冒奏。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只管奏来，寡人不罪于你。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "我主乃李娘娘所生，刘娘娘所养。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "往下奏来！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏：只因癸未年间，李娘娘身怀我主；宫中有一刘娘娘，与内侍郭槐，姑表 之亲。他二人定下一计：老王面前，讨下收生代劳旨意，将狸猫剥去皮尾，替 换我主。奏知老王，道李后产下妖魔鬼怪。老王大怒，将李后推出斩首。多亏 满朝文武保奏，死罪以免，活罪难饶，将李后打在冷宫受罪。他二人一计不成， 又生二计，道冷宫不清，约定八月十五日，火焚冷宫。火光一起，李娘娘不 知生死存亡。此事已隔二十余载，今日为何又来提起？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只因包拯回朝，见过国太。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "既是国太还在，有老王游玩御花园，赐与李后黄罗手帕，上有寇老先生题诗句 为证。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "诗句怎道？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏："
        },
        {
          "character": "陈琳",
          "type": "念",
          "text": "春风得意花前蕊，秋月杨辉桂一枝。天降紫微接宋后，未知生龙并雌雄。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "己是包拯回朝，为何不在金殿？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只因巧扮花灯，藐视寡人，将他斩首。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "陈琳",
          "type": "西皮二六板",
          "text": "万岁要斩斩奴婢， 午门赦回有功臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包拯赦回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "日落西来又转东， 水流千遭归海中。 百尺高竿得活命， 千层浪里又复生。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁不斩之恩！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿言国母还在，有何为证？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "黄罗丝帕为证，万岁请看。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来："
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "春风得意花前蕊，秋月杨辉桂一枝。天降紫微接宋后，未知生龙并雌雄！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "着着着！"
        },
        {
          "character": "陈琳",
          "type": "西皮摇板",
          "text": "亲生之母你不认， 国外道你无道君！"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "不是亚父来提醒， 险些斩了有功臣。 内臣与孤忙搀定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗拜陈琳。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "拜你如同拜先人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同上。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "刘娘娘自尽，郭槐拿到！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "绑上殿来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭槐上。"
        },
        {
          "character": "郭槐",
          "type": "白",
          "text": "原来是一党奸臣在此！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "你这奸贼，当年苦害国太！殿前武士，推出斩首！"
        },
        {
          "character": "郭槐",
          "type": "白",
          "text": "住了！我乃老王托孤之臣，谁人敢斩？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "你道寡人斩你不得？武士将他碎尸万段！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠押郭槐同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿，怎样迎接国太？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "准备龙车凤辇，迎接国太回朝。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "吩咐摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "李后",
          "type": "内西皮导板",
          "text": "龙车凤辇进皇城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监、王延龄、陈琳、包拯、宋仁宗、李后同上。"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "御街上来了我受苦之人。 赵州桥前遇包拯， 二十载冤仇报得清。 观不见汴梁城花花美景， 观不见汴梁城老小子民。 来至在午门外下了车轮， 又听得文武臣把我来迎。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "王延龄见驾，国太千岁！"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "王延龄在朝中忠心秉正，"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢陈琳见驾，国太千岁！"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "二十年才见得老陈琳！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "包拯见驾，国太千岁！"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "赤胆忠心包文正，"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "平身！"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "你是哀家活命恩人。 待等大事安排定， 将你官职往上升。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。二宫女引皇后同上。"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "儿臣见驾，国太千岁！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "回宫去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "皇后下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿，国太双目不明，如何是好？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "天地堂哀告上苍，天赐光明，也未可知。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "摆驾天地堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监、宋仁宗、李后、王延龄、陈琳、包拯同上。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤，大宋天子仁宗在位，只因母亲双目不明，望上苍恩赐光明！"
