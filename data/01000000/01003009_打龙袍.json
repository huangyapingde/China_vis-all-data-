        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监、宋仁宗、李后、王延龄、陈琳、包拯同上。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "儿臣见驾，母后千岁！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "昏王吓！"
        },
        {
          "character": "李后",
          "type": "西皮二六板",
          "text": "儿在朝，娘在窑，儿不查阅， 世界上哪有这无道昏君！ 哪一个生来，哪一个养， 哪一个是儿的生身的娘亲？ 亲生之母你不认， 反把仇人当娘亲。 内侍看过紫金棍，"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "包卿！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "李后",
          "type": "西皮二六板",
          "text": "你与我责打无道君！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "在宫中领了国太命， 背转身来自思忖： 自从盘古到如今， 哪有臣子敢打圣明君？ 万岁爷龙袍你就忙脱定， 包文正打龙袍如同打君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗脱袍，王延龄持袍，包拯打。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "好一个忠心包爱卿， 打龙袍犹如打昏君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍与包拯插帽。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "包拯近前听封赠："
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯跪。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "我封你太子太保入朝门。 内侍看过金档翅，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍插翅。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "再赐你上方剑一根。 三宫六院你代管， 五府六部任你行。 哪一家公子公孙他不遵命， 先斩后奏你照剑施行！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢国太！"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "叩罢头来谢罢恩，"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "龙国太待我好恩情！ 赐我一双金档翅， 又赐我上方剑一根。 三宫六院我代管， 那五府六部任我行。 哪一家残臣他不遵我的命？ 我押定了满朝文武、大小官员、公子公孙，谁敢不遵，我照剑施行！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "本后回朝，内帘官、外帘官，加升三级。光禄寺大摆筵席，与包卿贺功！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "摆驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
