          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "母后醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李后睁眼。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "皇儿！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "母后！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "众卿！"
        },
        {
          "character": "众人",
