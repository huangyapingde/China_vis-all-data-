  "title": "白马坡",
  "alias": [
    "斩颜良"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "颜良",
      "hangdang": "净"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    }
  ],
  "plot": "考玄德既失小沛下邳，兄弟夫妇失散，投奔青州袁绍。关公则觅兄不得，暂降曹操之后，未几，袁绍即命大\n将颜良，往攻曹操。颜良既抵白马坡，所向无敌，连败操军数阵，既斩宋宪、魏续，又战败徐晃。曹操势大\n挫，随营诸勇将，竟无一人能退颜良者。不得已，乃用程昱语，往请美髯公至退敌（时关公美髯之名方新得\n诸汉帝天语之褒赏）。且暗寓借刀杀刘备之计于袁绍也。关公既至，与曹操并马观兵后，关公从土山冲下，\n未交一合，即斩颜良于马下，遂解白马之围，曹操即表奏献帝，授关公以汉寿亭侯之爵。",
  "notes": "三国演义，第二十五回“救白马曹操解重围”即此剧出处，后本即《挂印封金》。剧中情节，与演义大致相\n同，科白亦什有六七，本诸演义原句，如关公与曹操立马土山，观看颜良军势时，关公所称“土鸡瓦犬”，\n“插标卖首”等语及终剧时曹操闻关公称誉翼德猛勇之状，异常惊怕，即令诸将，皆书名袍角襟底以记等处\n皆是。惟开场刘备饯送颜良时，已有孙乾出场，及关公斩颜良以前，多出许褚一场战败，又多朱灵、路昭二\n将之战死，此数处皆为演义所无。此剧脚本甚佳，于关公斩颜良之先，容于不前，颇得纡徐潆回之势，烘衬\n映带之法，而使关公神威，亦自照耀流露于庄严雄肃之中，盖皆袭用演义原本，深得行文之法，故有此绝妙\n容势也。惟须得善演者，以威静而不松懈之做工演之，方足显其剧本之佳。历数诸伶工，自当以王鸿寿为最，\n赵如泉唱做亦原不恶，惟扮相不称，故不能如王亦儒雅亦威肃，英风凛凛，使人见之常穆然长往也。近时\n夏月润，亦常扮演此等关公戏，然圆睁怒目，挺胸凸肚，但见其形容虎虎而已，实不知其何所可也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "青梅煮酒忆奸曹，炎汉家社稷倾倒。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "东驰西走路重重，时不遇人叹困龙。独对青山思自德，老天何不随英雄？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤，刘备。自徐州失散，家小不知存亡，幸我逃脱，在袁绍帐下为将，暂且安 身，欲想借兵破曹。今袁绍拜大将颜良，以为先锋，进取白马坡地方，特来把 盏送行。正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "借人篱下易，举头世上难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾上。"
        },
        {
          "character": "孙乾",
          "type": "念",
          "text": "待等时运到，风云天地宽。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "启主公：颜良将军到。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吩咐伺候把盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。颜良上，马夫、四龙套同上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，颜将军，刘备在此把盏贺功。"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "有劳使君。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "看酒。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "酒在。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "将军请饮此酒，但愿此去，马到成功，立斩曹操首级，以安天下。"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "非是颜良夸口，此去白马坡前，必斩曹操首级，以散恶气，方算英雄。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哈哈，将军之言，真乃威壮也！"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "使君，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "将军。"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "俺只恨沮授在袁公台前，说俺勇而无谋，不可任为先锋，今日幸有使君，识俺 是个英雄，可为有了知己，此去到了白马坡前，我战死沙场方休！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备惊。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，将军，有勇有谋，何出此不利之言？"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "大丈夫临阵，不死即伤，有何惧哉？"
        },
        {
          "character": "颜良",
          "type": "西皮快板",
          "text": "使君说话真奥妙， 何况孟德小儿曹。 辞别使君跨虎豹， 白马坡前立功劳。"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良、马夫、四龙套同下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，颜良情性浮躁，临行出此不利之言，袁绍此番起兵，恐成画饼也。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "指望河北泰山靠， 借他兵将兴汉朝。 颜良此去多浮躁， 十万雄兵恐徒劳。 天意不灭贼曹操， 先锋用了假英豪。 且回营帐再计较， 埋没英雄恨难消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "俺曹丞相麾下，探事官军是也。探得袁绍命大将颜良，以为先锋，统领大兵十 万，来攻白马坡，飞报丞相知道。 呔，马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "许褚、张辽、夏侯惇、徐晃、朱灵、路昭、宋宪、魏续、程昱同上，曹操上。"
        },
        {
          "character": "曹操",
          "type": "点绛唇",
          "text": "文韬武略，辅相汉朝，比周召，谋奸计巧，攻灭英雄如销草。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "朝朝虎帐令谈兵，宇宙纷纷何日平？宰相诸然陈画饼，安然霖雨沐苍生。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操。闻得袁绍起兵前来，谋反许昌，特此统领兵将，前来白马坡地方扎 营，以观动静，曾命探子哨探，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "打探军情事，报于丞相知。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报，探子告进。 丞相在上，探子叩首。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "探听袁绍人马如何？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "袁绍命大将颜良为先锋，统领大兵十万，来犯白马坡，特此报知。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "赏你金牌，再去哨探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，分赴随营将官听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓，点名。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将官，颜良乃河北名将，今为先锋前来，休得视为小敌，听我号令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖玉芙蓉〗。报子上，"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "颜良讨战。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众位将军，颜良讨战，何将出马？"
        },
        {
          "character": "宋宪、魏续",
          "type": "同白",
          "text": "丞相，我二人情愿出马，立斩颜良。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好，须要小心。"
        },
        {
          "character": "宋宪、魏续",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋宪、魏续同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "宋宪、魏续，乃吕布手下之勇将，此番出马，定斩颜良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操看。三冲头。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报：宋宪、魏续，被颜良刀劈马下！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哦呦呦，可叹二位将军，命丧颜良之手。 不知何人，能敌颜良？"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "丞相但放宽心，末将无才，情愿立斩颜良。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军出马，留心在意。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐晃下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "徐晃出马，不知胜负如何？且听一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三冲头。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启丞相：徐晃被颜良砍伤左膀，败回营来。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "快快抬往后营，好好医治。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲抬徐晃同上，同下。许褚、张辽、夏侯惇、朱灵、路昭同惊。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎，幸喜伤了左膀，不致伤命，颜良如此英雄，连伤数将，这便怎么处？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "禀丞相：程昱保举一人，能敌颜良。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "所举何人？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "非关公不可。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我也知非他不可，恐他立功便想辞去。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "想刘玄德若往，必投袁绍，今若使关公斩了颜良，袁绍必疑刘玄德而杀之矣。 玄德既死，关公又何所往哉？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哈哈哈，这是借关公之手，以杀玄德矣！程昱定计，亦算奇能。 张辽听令，命你速去请关公前来，退敌颜良。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "想我曹营，岂无敌战颜良之人，何必去请关公！俺许褚情愿出马，去战颜良！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "许褚既要出马，我与你带领兵将，在土山之上观战，以助将军之威，须要小心 在意。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "丞相但放宽心，俺定斩颜良之首级，献于丞相帐下，告辞去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "许褚虽然英雄，恐亦不能胜过颜良。 众将官，随我去到白马坡上，观战去者。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "英雄虽然非袁绍， 地广兵强将也良。 许褚此去须防保， 不可大意要心劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "颜良、马夫、四龙套同上。"
        },
        {
          "character": "颜良",
          "type": "西皮摇板",
          "text": "力斩二将血染草， 徐晃左膀已中刀。 银盔照日如虎唬，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、四龙套同上。"
        },
        {
          "character": "许褚",
          "type": "西皮摇板",
          "text": "来了许褚将英豪。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "呔，来将可是颜良？"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "然也！"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "你可知俺许褚的威风么？"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "无名之辈，倒也不晓。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "呔你且听了！"
        },
        {
          "character": "许褚",
          "type": "西皮摇板",
          "text": "蹲退二牛你可晓？"
        },
        {
          "character": "颜良",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "颜良",
          "type": "西皮摇板",
          "text": "村夫蠢子汉一条。"
        },
        {
          "character": "许褚",
          "type": "西皮摇板",
          "text": "河北番寇敌来到，"
        },
        {
          "character": "颜良",
          "type": "西皮摇板",
          "text": "要拿曹操试宝刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良、许褚同比刀，许褚败下，颜良追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操、程昱、夏侯惇、朱灵、路昭、四龙套同上。"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "杀声遥天红日淡， 金鼓声敲心胆寒。 统领众将往土山，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操上山。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "但愿斩将奏凯旋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚上，颜良追上，同起打，许褚下，颜良追下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "只见许褚刀法乱， 怕的失机丧残生。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你看许褚刀法乱了，夏侯惇快快出马救护。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "夏侯惇",
          "type": "西皮摇板",
          "text": "提枪出马去助战， 好比蛟龙浪里翻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇下。"
        },
        {
          "character": "关羽",
          "type": "内西皮导板",
          "text": "金勒马嘶坐雕鞍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫、四飞旗同上，张辽上，关羽上。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "正气冲霄日光寒。 弟兄三人徐州散， 为保皇嫂顺曹瞒。 身在曹营心在汉， 不知兄王驾可安？ 孟德请我去助战， 正好立功报效还。 旌旗一面黄河岸，"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关公到了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下山。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "迎接将军上土山。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军请上土山。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相请。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。关羽、曹操同上山。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相唤某，不知有何军情？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "只因颜良连斩宋宪、魏续二将，徐晃亦被刀伤左膀，此人勇不可当，特请将军 前来退敌。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "容某观看，便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那边颜良同许褚杀来了，请将军观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、颜良同上，同起杀，许褚下，颜良下。许褚、颜良同打上，夏侯惇上，救许褚同下，颜良追下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "河北人如此勇猛，如何是好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "以我观之，如土鸡瓦犬耳。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "土鸡瓦犬兵十万， 有名无实不足观。 马到成功即刻斩， 丞相尽可放心宽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、夏侯惇同上。"
        },
        {
          "character": "许褚、夏侯惇",
          "type": "同白",
          "text": "启禀丞相：颜良猛勇非常，不能取胜。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站过一旁。 朱灵、路昭听令，快去敌住颜良，不许冲动土山人马。"
        },
        {
          "character": "朱灵、路昭",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱灵、路昭同下。颜良、四龙套同上。"
        },
        {
          "character": "颜良",
          "type": "西皮导板",
          "text": "人似天神刀光闪，"
        },
        {
          "character": "颜良",
          "type": "西皮快板",
          "text": "杀死曹营众将官。 鞭头一指云雾散，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良、四龙套同走阵势。"
        },
        {
          "character": "颜良",
          "type": "西皮摇板",
          "text": "大骂曹操敢下山！"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "死曹操，你敢下得山来，与俺交战三合，便算好汉！ 众将官，人马排开，缓缓歇息，侍候抢山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良、四龙套同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀将军，你看麾盖之下，绣袍金甲，手持大刀，真乃天神也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我观颜良，如插标卖首耳！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "分明卤葬死蠢汉， 插标卖首儿一般。 若遇英雄即便斩，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "只恐将士心胆寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良上，朱灵、路昭同上，颜良斩朱灵、路昭。朱灵、路昭同下。"
        },
        {
          "character": "颜良",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可怜二将，又死于颜良之手，似此无人去敌，如何是好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相休惊，某虽不才，愿去万军之中，取颜良首级，来献麾下。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "吓将军，军中无戏言，公不可忽略。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远你小看某家，只今别了丞相，看某家立斩此人。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "非是关某敢斗胆， 熟读《春秋》志不凡。 精神贯日扶炎汉， 气吞群雄社稷安。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽卸袍。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "辞别丞相跨雕鞍， 除去奸恶何足难？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。颜良、四龙套同上。"
        },
        {
          "character": "颜良",
          "type": "西皮摇板",
          "text": "曹操被俺杀破胆， 放心勒马在倚骖。 若按争杀谁个敢？"
        },
        {
          "character": "颜良",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "谁敢来？谁敢来？"
        },
        {
          "character": "颜良",
          "type": "西皮摇板",
          "text": "气度昂昂似泰山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上，斩颜良。颜良、四龙套同下。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "赤兔追风快如电， 青龙偃月血饱餐。 颜良已斩兵将散， 报效曹公第一番！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "遥望刀光这一闪， 颜良为何落雕鞍？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将，你们可曾看见关公斩颜良么？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "我等俱已看见。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看得可真？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "明明白白，看见刀落颜良首级。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哈哈哈，我好喜也！颜良已死，袁绍袁绍，你命休矣！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "这等神勇世上将， 马走刀落人头翻。 捧酒下山迎好汉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下山。关羽上。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "丞相虎威得胜还。 插标卖首请亲看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽献颜良头，四龙套同惊。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "贼呀！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "须发放动眼上翻。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "拿去悬示军前。 看酒来，将军暂饮此酒，以贺大功！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。关羽接酒，谢天地，坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军真乃神人也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某何足道哉。我三弟张翼德，于万马军中取上将之首级，如探囊取物一般！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同惊。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎吓众将官，从今以后，若遇张翼德，不可轻敌，恐怕忘记，快取笔墨过来， 写于袍角衣襟以记之。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "笔墨在此。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "各将快快写好了。 颜良已灭，河北兵将败走，我今保奏关将军，进爵汉寿亭侯之职，请到大营设 筵贺功。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "摆弄堂。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}