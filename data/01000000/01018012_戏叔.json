{
  "script_id": "01018012",
  "title": "戏叔",
  "alias": [
    "叔嫂反目"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "潘金莲",
      "hangdang": "花旦"
    },
    {
      "name": "武松",
      "hangdang": "小生"
    },
    {
      "name": "武大",
      "hangdang": "丑"
    }
  ],
  "plot": "武松自景阳冈打虎后，阳谷县令爱其勇健，拔为捕盗都头，常川在衙门当差。路遇兄长武大，谈及别后事情，\n始知武大已娶潘氏金莲为妻，寄居此地。而习卖炊饼之业，以图糊口。邀武松至家中认嫂，潘氏性本淫荡，\n见武松气象魁梧，堂堂一表，不禁怦然心动。怂恿兄弟同居，便于照应。武松性情爽直，并不疑有他故。\n一诺无辞，遂下榻焉。从此早出夜归，习以为常。一日公务已毕，随至下处，而武大尚未返家，潘氏自忖趁\n此时机，可以遂我私愿，预备酒肴，强邀武松对饮，于眉目送情之外，复用言语勾挑，以为年轻小叔，定然\n识趣。殊不知武松一义侠男儿，岂肯为乱伦之事，悻悻然离坐而起。潘氏恼羞成怒，俟武大入门，反哭诉武\n松无礼于嫂，尽情调戏。武大不信为真，武松亦不言其故。匆促间取出行李，仍往衙门中歇宿焉。",
  "notes": "是剧即《义侠记》中，《别兄》之前一出，系花旦唱做兼全之重头戏，颇有价值，谅能合观剧者之心理。惟\n后半截丑角插科打诨处，较之《义侠记》中，稍有异点。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲上。"
        },
        {
          "character": "潘金莲",
          "type": "吹腔",
          "text": "痴男子假装乔， 我馋涎一缕怎能熬？"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "奴家，潘金莲。自从那日一见了武二，奴就看上他了。"
        },
        {
          "character": "潘金莲",
          "type": "吹腔",
          "text": "奴常把眼角传情，话头勾引， 他却撇清装假。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "他只做不知，我今日浸得一壶凉酒在此。"
        },
        {
          "character": "潘金莲",
          "type": "吹腔",
          "text": "待他今日来家后， 奴用心引调， 任他是铁汉也魂消， 须落得我圈套。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松上。"
        },
        {
          "character": "武松",
          "type": "引子",
          "text": "挥汗归来罢早衙，何日成名扬天涯。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "吓。叔叔回来了么？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嫂嫂！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔今日回来甚早。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "我公门无事，早回家，问哥哥可曾歇下。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "你问你哥哥？还没有回来。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "没有回来，待我向县前去寻他。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "吓叔叔！他是个做生意的人，你到哪里去寻他？且到家中坐了，等他到来就是 了。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "既然如此，嫂嫂请！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲、武松同进门坐。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好热的天。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔你身上穿的是几层衣服？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "两三层。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "这样热天，哪里穿这许多？你看做嫂嫂的，穿得这等单薄。也罢。待我与你解 下来晒晒吧。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "不消。俺武二日在官府是穿惯的，不劳嫂嫂费心。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "穿惯的？好性儿吓。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "这桌上是什么？"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "这是奴家浸得一壶凉酒，待等叔叔回来解渴的。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "既有酒，等候哥哥回来，一同吃罢。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "哪里等得及？待我与叔叔先吃一杯。等他回来再吃罢。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "如此多谢嫂嫂。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔是海量，大杯罢。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好。竟是大杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲斟酒递。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔请酒。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "放在桌儿上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲放杯，看。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "多蒙嫂嫂所赐，武二立饮干。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔后生家，不要吃单杯，吃个双杯罢。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嗳，有酒待武二吃便了。什么单双？"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔，我说的是酒啦。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "我原说的是酒吓！干！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "好量吓。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "我才忘了，待武二借花献佛，回敬嫂嫂一杯。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "奴家不会吃酒，半杯罢。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "就是半杯。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "取来。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "闪开，待我放在桌儿上。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "呵。又要放在桌儿上。固执得紧。 多谢叔叔！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "我武二在此，多谢嫂嫂。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "呵呀，好说。叔叔请坐。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嫂嫂请坐。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "待我关上了门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲关门。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "青天白日，为何将门关上了？"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "关了门，稳便些。叔叔请坐。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嫂嫂请坐。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔今日无人在此。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "无人在此便怎么？"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔吓！"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "我要问你家， 闻说你在东街，背地里恋烟花。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嗳，哪有此事！"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "你缘何不说知心话， 何不唤她来家？"
        },
        {
          "character": "武松",
          "type": "古轮台",
          "text": "我是个风虎云龙， 怎肯向平康入马？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲跷脚。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔！"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "你在客邸孤单，少年狂放， 只怕你心头不似嘴喳喳。"
        },
        {
          "character": "武松",
          "type": "古轮台",
          "text": "我原非虚话。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "我不信。"
        },
        {
          "character": "武松",
          "type": "古轮台",
          "text": "不信是时且待兄长还家， 把咱行事，试将来问他，可知真假。"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "休说那冤家。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嗳。夫妻，说什么冤家。"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "这风流话， 若还知道，怎嫌他？"
        },
        {
          "character": "武松",
          "type": "古轮台",
          "text": "嗟呀！好叫人悬望巴巴， 这时候不见兄归家。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔再请饮一杯。"
        },
        {
          "character": "武松",
          "type": "古轮台",
          "text": "嫂嫂，你且暂停杯盏， 况天气炎热。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔往哪里去？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "闪开！"
        },
        {
          "character": "武松",
          "type": "古轮台",
          "text": "只索向门外，临风潇洒。"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "到如今把机关用尽， 怎肯轻轻抛下？ 叔叔，且同消夏， 怎生忒不通达？"
        },
        {
          "character": "武松",
          "type": "古轮台",
          "text": "只为奔驰劳顿， 心慵意懒，好难禁架。"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "此意你知么，伊休诈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲持杯饮酒，武松看。"
        },
        {
          "character": "潘金莲",
          "type": "古轮台",
          "text": "叔叔，半杯残酒饮干咱。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "住了。这酒是哪个吃的？"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "是叔叔吃的。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "是我吃的，取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松接酒泼。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "呵呀呀，啐啐啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松怒。"
        },
        {
          "character": "武松",
          "type": "扑灯蛾",
          "text": "我怪你忒丧心，怪你忒丧心， 羞耻全不怕。 有眼睁开看， 俺武二特地详察！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔！"
        },
        {
          "character": "武松",
          "type": "扑灯蛾",
          "text": "走来，我是含牙戴发， 顶天立地丈夫家， 怎肯做败伦伤化！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嫂嫂！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "嗯。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "你不要想差了念头吓！我哥哥倘有些风吹草动，武二这双眼睛，认得你是嫂嫂， 这拳头吓——"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "拳头便怎么？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "却不认得你是嫂嫂！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "呵呀武二，你不要夸口吓！"
        },
        {
          "character": "武松",
          "type": "扑灯蛾",
          "text": "我非夸，是从打虎手儿滑。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "啐啐啐！"
        },
        {
          "character": "潘金莲",
          "type": "扑灯蛾",
          "text": "笑伊直恁村，笑伊直恁村， 不辨真和假。 酒后聊相戏， 怎便将人叱诧。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "武二。你将我当做什么人看待吓？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "不过是嫂嫂罢了！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "可又来！"
        },
        {
          "character": "潘金莲",
          "type": "扑灯蛾",
          "text": "常言道：叔嫂如娘大， 好一个知轻识重丈夫家。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "哟！"
        },
        {
          "character": "潘金莲",
          "type": "扑灯蛾",
          "text": "只会把至亲欺压！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲笑。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "叔叔！"
        },
        {
          "character": "潘金莲",
          "type": "扑灯蛾",
          "text": "才涂抹， 从今两意莫争差。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲抱武松腰，武松推。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "武松",
          "type": "尾声",
          "text": "这场家丑堪羞煞！"
        },
        {
          "character": "潘金莲",
          "type": "尾声",
          "text": "自恨当初错认了他。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "吓叔叔！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好没廉耻！"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "啐！蠢才！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲下。"
        },
        {
          "character": "武松",
          "type": "尾声",
          "text": "嗳呀哥哥呀， 只恐终须作话把！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武大上。"
        },
        {
          "character": "武大",
          "type": "念",
          "text": "清晨出去犹嫌晚，下午回来汗未消。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哥哥回来了？"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "兄弟回来哉！家里坐。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "兄弟！"
        },
        {
          "character": "武大",
          "type": "五更转",
          "text": "你甚时来家里？"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "可曾吃点心来。若是不曾吃，呵，哥盘里，还有两个烧饼，拿去吃了罢！"
        },
        {
          "character": "武大",
          "type": "五更转",
          "text": "敢是点心见你尚未吃， 缘何频问你多不应？"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "哦，我晓得哉。想是嫂……"
        },
        {
          "character": "潘金莲",
          "type": "内白",
          "text": "嫂什么？"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "不是吓，我要扫扫地呀！兄弟。"
        },
        {
          "character": "武大",
          "type": "五更转",
          "text": "敢是嫂嫂跟前慢待着你？"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "哦喝是了。"
        },
        {
          "character": "武大",
          "type": "五更转",
          "text": "莫非你受了官司气？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "咳。本县太爷，何等待我，什么官司气？快把我的行李拿来，俺不住在这里了！"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "兄弟呀！"
        },
        {
          "character": "武大",
          "type": "五更转",
          "text": "你若是怪我，我就先赔礼。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "做阿哥的跪下哉！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哥哥请起！"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "哪个得罪了你？你对我说明，哥哥才能起来。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哥哥起来，我说便了。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "你肯说，我就起来。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呵呀，哥哥吓！"
        },
        {
          "character": "武松",
          "type": "五更转",
          "text": "你若问起根由， 与你装些幌子。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "你从哪里来呀？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "方才兄弟在县前回来，多蒙嫂嫂浸得一壶好酒，饮酒中间，说什么“单”呐 “双”吓。哥哥吓，哥哥！"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "我今天做成的饼，是三十三个，乃是个单，两个三十三，就是六十六，岂不是 个双？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松推武大倒。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松下。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "嗳哟哟，二官人怒气冲冲去了，道是为着煞个事情？待我叫出老婆来问问看。 哈，我那贤妻！拙荆！内人！老婆娘吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲上。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "呀啐！你还是勾魂，你还是叫命呐？"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "一个气出，一个气进。我且问你：二官人为了何事，怒气冲冲的呀？"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "啐！只为你！"
        },
        {
          "character": "潘金莲",
          "type": "五更转",
          "text": "那蠢才不争气， 累奴家吃了亏。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "谁欺负你，对我说。我定不与他干休！"
        },
        {
          "character": "潘金莲",
          "type": "五更转",
          "text": "情知只有武二来家里， 见他冒暑归来，备些酒浆茶水。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "无茶有水，是个好意。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "可是好意！"
        },
        {
          "character": "潘金莲",
          "type": "五更转",
          "text": "谁想他不太仁，将奴戏，"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "这话我不信，我那兄弟，吃酒打老虎是他的本等。况他正直无私，向不喜爱妇 人。你要知道他，还是个童男子。还靡有出过身子呢。这话我算是靡有听见。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "大郎吓！"
        },
        {
          "character": "潘金莲",
          "type": "五更转",
          "text": "也无颜在此，必要迁居矣。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "自家的兄弟，哪有不住在屋里的？"
        },
        {
          "character": "潘金莲",
          "type": "五更转",
          "text": "若要兄弟同居，"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "潘金莲",
          "type": "五更转",
          "text": "还我休书一纸。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "你住了罢！开口休书，闭口休书，就是个兄弟，住在一处，又有什么要紧？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲哭。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "天吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲拍桌。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "还我休书来！"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "说说她又哭起来了。是了，我明日叫兄弟搬出去就是了。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "武大",
          "type": "念",
          "text": "花消纷碎恨难禁，"
        },
        {
          "character": "潘金莲",
          "type": "念",
          "text": "可恨狂徒强逼人。"
        },
        {
          "character": "武大",
          "type": "念",
          "text": "堪信路遥逢马利，"
        },
        {
          "character": "潘金莲",
          "type": "念",
          "text": "方知日久见人心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲下。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "我把你个臭花娘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲上。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "你骂哪一个呀？"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "我说你的花样。"
        },
        {
          "character": "潘金莲",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘金莲下。"
        },
        {
          "character": "武大",
          "type": "白",
          "text": "我把你个臭骚毯养的吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武大下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}