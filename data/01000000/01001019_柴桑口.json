{
  "script_id": "01001019",
  "title": "柴桑口",
  "alias": [
    "孔明吊丧"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "周循",
      "hangdang": "小生"
    }
  ],
  "plot": "三国时人才辈出。蜀有诸葛亮，吴有周瑜。周瑜虽多智而稍不及诸葛亮，用兵设计，常为诸葛亮所破。周瑜\n器量狭小，深以诸葛亮出己上为耻。荆州之役，被诸葛亮所窘，败至巴邱，得诸葛亮书，诮其失策。周瑜大\n恚，呕血死。诸葛亮只身往吊之于柴桑口，痛哭祭奠。吴营诸将皆感动，心虽仇之而莫能害之也。诸葛亮祭\n毕返，周瑜子周循至，急调诸将追诸葛亮，欲得而甘心。诸葛亮见周循至，笑责其追杀奠客，何太无礼。周\n循不悟，挺枪直刺，张飞怒而杀之，吴兵大败归焉。",
  "notes": "或谓孔明此行，全出于伪，余谓非也。周公瑾亦当世英雄，天不假年，破曹未竟，惺惺惜惺惺，此孔明之一\n腔怜才热泪，所以迸涌而出，不得自已也。虽然，归途中得一庞士元，则又未始非孔明此行为汉家延揽人才\n之初意也。惟周循追杀一段，按之《三国演义》，并无其事。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "引子",
          "text": "身挂帅印，统雄兵，扫荡烟尘。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "本帅姓鲁名肃，字子敬。前者三江夏口周都督一死，吴侯挂我为帅。今乃周都 督开吊之期，尤恐众将前来吊祭。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四吴将同上。"
        },
        {
          "character": "四吴将",
          "type": "同白",
          "text": "启禀都督：孔明过江吊祭。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哦，孔明过江吊祭。"
        },
        {
          "character": "四吴将",
          "type": "同白",
          "text": "何不将他拿下，与都督报仇。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "且慢。想那孔明过江，必有能将跟随，你等看我眼色行事。两厢伺候。退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四吴将同下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、赵云同上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不知先生驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "久违教益，如有所忘。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "此事何劳先生亲自驾临。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "故旧之谊，聊表鄙意。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "肃真乃钦佩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "先灵供奉何处？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "现在后堂。前面带路。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有劳大夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、鲁肃同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，诸葛亮、鲁肃、赵云同上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "见陵寝不由人泪如雨降， 想遗容倒叫我寸断肝肠。"
        },
        {
          "character": "诸葛亮",
          "type": "叫哭",
          "text": "哎，都督吓！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "可怜你钟山秀青年在望， 可怜你美英雄一旦夭亡。 可怜你兢业业一生空禳， 可怜你忙碌碌半世奔忙。 实指望灭曹瞒安乐共享， 又谁知大数到已作魍魉！"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "“呜呼公瑾，不幸夭亡；修短由天，人岂不伤。 我心实痛，酹酒一觞；君其有灵，享我蒸尝。 从此天下，与谁相商。呜呼痛哉，伏维尚享。”"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎，都督吓！想你英雄盖世，一代传人，贯精忠于日月，秉赤胆于东方，不幸 一旦身亡。哎，好不遗恨人也。"
        },
        {
          "character": "诸葛亮",
          "type": "反二黄慢板",
          "text": "你是个创业的忠贞良将， 你是个振东方豪杰贤良。 谁似你天生成高致雅量， 谁似你文武略气宇轩昂？ 谁似你年弱冠兵权独掌， 谁似你兴霸业扶弱抑强？ 奸曹操统雄兵如风似浪， 只唬得众儿郎束手要降。 若非你怀大志陈兵相抗， 用机谋杀得他弃甲丢枪！ 到如今少得遂太平景象， 转瞬间天不佑大厦断梁。 抛得吾孤人儿将谁依傍，将谁依傍？都督吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四吴将同上，同打把。鲁肃拦下。"
        },
        {
          "character": "诸葛亮",
          "type": "反二黄原板",
          "text": "抛得吾独一人谁作商量？ 吾和你好一比伯仲情况， 吾和你好一比鸡黍范张。 望阴魂鉴吾这虔诚祭享， 泪汪汪捧玉樽享受蒸尝。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "呜呼公谨，不幸夭亡。呜呼痛哉，伏维尚享！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "到如今奸曹在你先自丧， 抛得吾无前后好不悲伤！"
        },
        {
          "character": "诸葛亮",
          "type": "哭",
          "text": "吓！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "思至此只哭的咽喉气丧，"
        },
        {
          "character": "鲁肃",
          "type": "二黄摇板",
          "text": "见先生只哭得我好悲伤。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生不必啼哭，保重身体要紧。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "咳，看此光景，泪出肺腑，纵有千言万语，一时难禁！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "破曹之事，仰仗先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "列公既以奸曹为念，亮当谨记于心，同力破曹为上。告辞。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "后帐备得水酒，与先生同饮。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "原当领受，奈公务在身。公谨哪，你若有灵，须鉴吾心哪！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "心问口口问心牢骚千丈，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四吴将自两边分上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "有万篇诉不尽腹内悲伤。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "送先生。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "送千里终须别何劳过让， 试看吾一帆风雨洒康庄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、诸葛亮同下。四龙套、周循同上。周循祭灵。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "何人前来吊祭？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "诸葛先生前来吊祭。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "为何不将他拿下，与我父报仇？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他祭了又哭，哭了又祭。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "几时去的？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "方才去的。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "待我将他赶上！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "且慢，那孔明用兵如神，又有赵云跟随，若是动手，又恐他变。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "不必拦阻，众将官，追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、周循同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "非是我笑他人无有志量， 怎知我袖儿里暗有形藏。 遇不着智谋人心中惆怅，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞统上。"
        },
        {
          "character": "庞统",
          "type": "西皮摇板",
          "text": "纵有那托天手难逃我掌。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "好吓，你将我周都督气死，来到灵前，假意吊孝，明欺我东吴无人。来来来， 我与你分个上下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吓，原来是凤雏先生！"
        },
        {
          "character": "庞统、诸葛亮",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吓，凤雏，我量你计谋不能尽用，足下何不投一明君，不负生平所愿。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "我意欲投一明君，没有引见之人。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "先生吓，吾今此来，实为老兄。吾观孙仲谋，不能重用足下。吾主宽仁厚义， 不负生平所学。我已修下荐书，趁便既往荆州，共扶汉业，名垂千古，岂不美 哉？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "多蒙先生举荐，我当照行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内呐喊声。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "哎呀，后面尘土冲天，东吴追兵来也。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不妨，我自有敌他之兵。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "后日再叙，告辞了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞统下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "想人生荣与枯得失难量， 际风云显奇谋姓字名扬。 远望着白泛泛滔天波浪，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "张翼德驾小舟迎接先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "搭了扶手。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、赵云同上船。周循、鲁肃、四龙套同上。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "舟中敢是诸葛先生？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "然也。你乃何人？"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "俺乃周都督之子，名唤周循。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "到此何干？"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "闻得先生前来吊祭，特地前来谢孝。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "既为谢孝而来，为何持戈相向？"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "这个……请先生过船，有话相商。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吾要过船，这恐怕小性命，也要随你父去也。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "众将官，杀！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！我把你这小奴才，来在长江追杀奠客，本当一箭将你杀死，念你乃是犯孽 身重之人，便宜你这王八肏的！三军的催舟。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哦，先生。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、赵云、诸葛亮同下。"
        },
        {
          "character": "周循",
          "type": "白",
          "text": "且住。今日到被他们羞辱一场，待我投江一死罢！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "且慢。你我回至柴桑，整顿人马，再与都督报仇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}