{
  "script_id": "01002001",
  "title": "李陵碑",
  "alias": [
    "两狼山；一名：苏武庙"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "杨继业",
      "hangdang": "老生"
    },
    {
      "name": "杨延昭",
      "hangdang": "末"
    },
    {
      "name": "杨延嗣",
      "hangdang": "净"
    }
  ],
  "plot": "宋辽失和，使杨继业征之。杨继业兵困两狼山，遣子七郎求救于元帅潘洪。潘洪不发一兵，且杀七郎以报私\n仇。杨继业久困无援，夜梦七郎冤魂，醒后大疑。使子六郎突围出，己则单身杀至苏武庙，气力不加，见李\n陵碑，大骂一场，竟撞碑死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延嗣上。"
        },
        {
          "character": "杨延嗣",
          "type": "引子",
          "text": "赤胆忠心，只落得，青史名标。"
        },
        {
          "character": "杨延嗣",
          "type": "白",
          "text": "我乃七郎阴魂是也。只因那日回朝颁兵，可恨潘洪将我射死芭蕉树上。不免前 去与我父托兆。 众鬼卒，宋营去者！"
        },
        {
          "character": "杨延嗣",
          "type": "二黄导板",
          "text": "我杨家保宋主忠心秉正，"
        },
        {
          "character": "杨延嗣",
          "type": "二黄原板",
          "text": "东西征南北剿哪得安宁。 金沙滩打一仗父子被困， 老爹爹他命我回朝颁兵。 潘洪贼想起了打子仇恨， 他将我绑芭蕉乱箭穿身。 叫鬼卒驾阴风宋营来进， 见了那老爹爹细说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延嗣下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "二黄导板",
          "text": "金乌坠玉免升黄昏时候，"
        },
        {
          "character": "杨继业",
          "type": "回龙",
          "text": "盼姣儿不由人珠泪双流，我的儿吓！"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "命七郎回大营颁兵求救， 为什么此一去不见回头？ 莫不是潘仁美又下毒手， 怕的是我的儿性命难留。 含悲泪进宝帐双眉愁皱， 西北风吹的我遍体飕飕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "听谯楼打罢了二更时分， 杨延昭倒做了巡营之人。 迈步儿且把那宝帐来进， 又只见老爹爹瞌睡沉沉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延嗣上。"
        },
        {
          "character": "杨延嗣",
          "type": "二黄原板",
          "text": "听谯楼打罢了三更时分， 半空中来了我七郎阴魂。 叫鬼卒驾阴风宝帐来进， 又只见老爹爹瞌睡沉沉。 我这里将他的忠魂惊醒，"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "猛抬头又只见七郎姣生。 我命你回大营颁兵求救， 为什么哭啼啼头带雕翎？ 恨不得下位去将儿抱定，"
        },
        {
          "character": "杨延嗣",
          "type": "二黄原板",
          "text": "老爹爹休贪睡细听分明： 金沙滩打一仗父子被困， 老爹爹命孩儿回朝颁兵。 潘洪贼想起了打子仇恨， 他将我绑芭蕉乱箭穿身。 回头来又对六兄论， 小弟言来听分明： 高堂老母要你孝敬， 莫学小弟不孝顺。 我本当与六兄多谈多论， 又恐怕天明亮难回天庭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延嗣下。"
        },
        {
          "character": "杨继业",
          "type": "二黄导板",
          "text": "适才间梦见了七郎来临，"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "又只见六郎儿瞌睡沉沉。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "六郎儿醒来！"
        },
        {
          "character": "杨延昭",
          "type": "二黄导板",
          "text": "适才间梦见了七弟来临，"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "又只见老爹爹面前存。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹，适才睡梦之中，观见七弟浑身是血，头带雕翎。不知是何缘故？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "为父亦得此兆。这才是“梦梦相同，必有凶险”。我亦有意，命你回朝探听七 弟下落。不知我儿意下如何？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹年迈，孩儿放心不下。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "为父虽然年迈，倒也康健，只管前去。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿不去！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿吓，为父倒有父子之情，难道你无手足之义么？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹不必如此，孩儿去就是了。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "辞别爹爹跨金蹬， 不分昼夜去颁兵。"
        },
        {
          "character": "杨延昭",
          "type": "哭",
          "text": "爹爹，我父，啊呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "杨继业",
          "type": "二黄摇板",
          "text": "六郎上了马能行， 好不叫人痛伤心。 悲悲切切大营进， 父子相会再等来生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "耶律休上。"
        },
        {
          "character": "耶律休",
          "type": "白",
          "text": "俺奉太后之命，巡营了哨。就此前往。呔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "何人挡住某家去路？"
        },
        {
          "character": "耶律休",
          "type": "白",
          "text": "俺乃耶律休，要你的狗命！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "一派胡言！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、耶律休同开打，耶律休败下，杨延昭下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "且住，且喜逃出虎口，不免回朝便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、四老军同上。"
        },
        {
          "character": "杨继业",
          "type": "反二黄慢板",
          "text": "叹杨家秉忠心大宋扶保， 到如今只落得瓦解冰消。 恨胡儿打来了连环战表， 他要夺我主爷锦绣龙朝。 贼潘洪在金殿挂了招讨， 我父子倒做了马前英豪。"
        },
        {
          "character": "杨继业",
          "type": "反二黄原板",
          "text": "金沙滩双龙会一战败了， 只杀得血成河鬼哭神号。 我的大郎儿吓，替宋王把忠尽了， 二郎儿短剑下命赴阴曹。 杨三郎被马踏尸骨难找， 四、八郎在番邦无有下梢。 五郎儿在五台修真学道， 七郎儿被潘洪箭射芭蕉。 只剩下六郎儿东征西剿， 可怜他又尽忠，又尽孝，身披盔甲、马不停蹄，东荡西剿，昼夜杀砍，为国勤 劳。 可怜我八个子把四子丧了，我把四子丧了，我的儿吓！ 一家人只落得死无下梢。 恨萧营报前仇又打战表， 请我主赴两狼摆一摆枪刀。 这潘洪二次里挂了招讨， 我父子做先行逢山开路，遇水安桥。 黄道日不发兵不把贼剿， 黑道日命父子去把兵交。 为国家哪顾得黄道黑道， 我父子一马当先杀进了贼巢。 头一阵得了胜回营禀报， 狗奸贼将人马扎定了城濠。 传一令将胡儿斩杀尽了， 斩不尽杀不绝不许回朝。 二次里闯贼巢入了圈套， 我父子困焦牙入了笼牢。 我也曾命六郎回营去了， 可怜我为国家，秉忠心，年迈苍苍，困两狼，里无粮，外无草，盼兵不到、盼 子不归，我这老残生，就不能还朝！我的儿吓！"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "饿吓！"
        },
        {
          "character": "杨继业",
          "type": "反二黄原板",
          "text": "饥饿了你就该战马斩倒，"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "冷吓！"
        },
        {
          "character": "杨继业",
          "type": "反二黄原板",
          "text": "身冷了拆帐篷用布裹包。"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "雁来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业射雁。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "杨继业",
          "type": "反二黄原板",
          "text": "宝雕弓打不着空中飞鸟， 弓折弦断为的是哪条？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "胡儿把战马绞倒！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "杨继业",
          "type": "反二黄摇板",
          "text": "恨胡儿把我的战马绞倒， 下由我年迈人怒上眉梢。 叫老军抬过了定宋刀，忙把路找。 寻一个避风所再作计较。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、四老军同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}