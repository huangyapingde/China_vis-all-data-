          "type": "内白",
          "text": "表大老爷到！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。李平儿上。张元秀让座。中军进茶。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "我说你是谁呀？"
        },
