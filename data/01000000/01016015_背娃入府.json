          "character": "中军",
          "type": "白",
          "text": "喴！"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "我说你是个什么奏的，你这么喴呀喴的。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "此乃是侯爷的虎威。"
        },
