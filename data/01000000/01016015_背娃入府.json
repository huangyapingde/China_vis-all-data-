        },
        {
          "character": null,
          "type": "stage",
          "text": "李妻上。张元秀出迎，进，坐。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "我说你是谁呀？"
        },
        {
          "character": "张元秀",
