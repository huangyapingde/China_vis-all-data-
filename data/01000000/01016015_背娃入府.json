          "type": "白",
          "text": "正是。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "我说你大，还是他大？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "他大，我小。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "还是你怕他，还是他怕你？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "自然是我怕他。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "你怕他，你怕我不怕？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "也怕。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "你怕就结了吗，什么叫做也怕。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "我全怕。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "你怕就好，我来使唤使唤你。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "咋。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "你走过来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "哦，我走过来。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "真可以的，真听说，你再走过去。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "再走过去。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "你站着，把嘴张开。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "哦，把嘴张开。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "你说话。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "我可实在不能了。"
        },
        {
          "character": "李平儿",
          "type": "白",
          "text": "我看你也是不行啦，咱们回来再说话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李平儿下。"
        },
        {
          "character": "李妻",
          "type": "内白",
          "text": "表大太太到。"
        },
        {
