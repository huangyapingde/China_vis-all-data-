        },
        {
          "character": "李妻",
          "type": "白",
          "text": "你做了官啦，你怎么头上戴一个料斗子呀？"
        },
        {
          "character": "张元秀",
          "type": "白",
          "text": "此乃是侯帽。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "哦，是猴儿帽吓。"
        },
        {
          "character": "张元秀",
