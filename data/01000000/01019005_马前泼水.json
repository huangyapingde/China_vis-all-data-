    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张公道上。"
        },
        {
          "character": "张公道",
          "type": "念",
          "text": "生意兴隆通四海，财源茂盛达三江。"
        },
        {
          "character": "张公道",
          "type": "白",
          "text": "吾，张公道，乃是个货郎儿。闻听人言，吾的街坊朱买臣，做了官了，今日在 长街夸官游街，好不威严。不免前去看看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔氏上。"
        },
        {
          "character": "张公道",
          "type": "白",
          "text": "那厢不是朱大嫂么？"
