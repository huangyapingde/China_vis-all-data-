        {
          "character": "朱买臣",
          "type": "白",
          "text": "我姓朱。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "姓舒？"
        },
        {
          "character": "朱买臣",
          "type": "白",
          "text": "姓朱。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "姓居？"
