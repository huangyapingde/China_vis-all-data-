        {
          "character": "崔氏",
          "type": "白",
          "text": "可有中人？"
        },
        {
          "character": "张三",
          "type": "白",
          "text": "也没有。"
        },
        {
          "character": "崔氏",
          "type": "白",
          "text": "可有媒人？"
