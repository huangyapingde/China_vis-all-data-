{
  "script_id": "01038009",
  "title": "湘江会",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "钟无盐",
      "hangdang": "刀马旦"
    },
    {
      "name": "吴起",
      "hangdang": "武净"
    },
    {
      "name": "魏灵公",
      "hangdang": "生"
    },
    {
      "name": "齐景公",
      "hangdang": "丑"
    },
    {
      "name": "晏婴",
      "hangdang": "外"
    }
  ],
  "plot": "按剧本从吴起出场，自述本为鲁臣，因使命至齐，受齐妃钟无盐之计，至父母俱被鲁国诛杀，因去齐自立，\n常怀报仇之心。至是，适魏侯灵公，因心耻为齐所压服，特邀集诸小邦，及各国仇齐之诸公族大夫，以和好\n为名，请齐景公来赴湘江大会，以便临时见机行事。吴起亦在被邀之列。讵知齐景公携夫人钟无盐同来，颇\n难下手。会次，吴起借举出与钟无盐争论，既而吴起自恃善箭，遂欲与钟无盐比射。钟无盐让吴起先射，三\n箭三中，确非寻常。岂知钟无盐多狡诈，射至第三箭，竟将魏侯射死，遂大哗。双方各露刃相杀，卒被钟无\n盐保护齐侯，冲杀而去。众小邦徒折一魏侯，于事终无济，卒无如齐何也。呜呼强权！",
  "notes": "《湘江会》一剧，为战国时吴起欲报仇，拟乘魏侯召集诸侯，与齐景公湘江大会之时，借比射行刺之一段故\n事。向时徽班中演唱颇盛。乃武二花（即油脸）与刀马旦之重头戏。事出《列国志》中，惟剧本中人名事实，\n多有先后羼讹而。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠引吴起同上。"
        },
        {
          "character": "吴起",
          "type": "引子",
          "text": "统领貔貅，终日戈矛相争斗，为报冤仇，血战怎罢休！"
        },
        {
          "character": "吴起",
          "type": "念",
          "text": "幼习韬略在胸中，两膀能开百力弓。怀恨冤仇钟无盐，一心要灭齐景公。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "某，鲁国吴起。以在鲁定王驾前为臣，进贡与齐邦。可恨钟无盐，暗用诡计， 道某有顺齐伐鲁之心。鲁定王此时大怒，将我一双爹娘斩首。某家带领人马， 反到盖国山，自立为王，召集英雄，以报父母冤仇。只因魏王有书前来，接某 家前去赴会。正合吾意。 众将，人马撤至教场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "旗牌，吩咐众将开操！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "众将开操！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠同操演。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠同允。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "兵发魏邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、纪燕同上。〖牌子〗。四文堂、四大铠、吴起同上。"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "我道是谁，原来是吴驸马。领兵何往？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "我道是谁，原来是纪千岁。领兵何往？"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "魏邦有书接我赴会。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "某家正为此事。两队人马合为一处。 众将官，人马合为一队，兵发魏邦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、魏灵公同上。"
        },
        {
          "character": "魏灵公",
          "type": "引子",
          "text": "坐镇魏邦，威风不可当。"
        },
        {
          "character": "魏灵公",
          "type": "念",
          "text": "曾记当年临潼会，一十七国怕子胥。景公收了钟无盐，众家低头惧魏邦。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "孤，魏灵公。只因齐邦为上，我国为下，年年进贡，每岁出朝，并无一礼回答。 是孤心怀不忿，为此特请众位王爷到来，共伐齐邦。也曾命人前去相请，未 见到来。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "一马走尽天涯路，单传世间书回言。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启爷：众位王爷驾到。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有请众位王爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。孙操、纪燕、吴起同上。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "吓，众位王爷！"
        },
        {
          "character": "孙操、纪燕、吴起",
          "type": "同白",
          "text": "魏王请！"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "众位王爷驾到，未曾远迎，有罪！"
        },
        {
          "character": "孙操、纪燕、吴起",
          "type": "同白",
          "text": "岂敢。某家来得冲忙，魏王恕罪！"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "孙操、纪燕、吴起",
          "type": "同白",
          "text": "魏王相邀，有何见教？"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "众位王爷有所不知，只因齐景公收了钟无盐，压定我们一十一国，每年进贡， 并无一礼回答。是孤心怀不忿，特请众位王爷到来，共伐齐邦。不知众位王爷 意下如何？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "魏王何不下书一封，请他君臣前来，定下湘江大会。酒席筵前，一股擒拿，岂 不是好？"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "此计甚好。 来，浓墨伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗，〖吹打〗。魏灵公写书。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "传旗牌。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "有书一封，去到齐邦投递。正是："
        },
        {
          "character": "魏灵公",
          "type": "念",
          "text": "书去人也去，"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "人回信也回。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "后帐摆宴，与众位王爷接风。"
        },
        {
          "character": "孙操、纪燕、吴起",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "晏婴上。"
        },
        {
          "character": "晏婴",
          "type": "念",
          "text": "待漏五更寒，披衣上银銮。东方天未晓，明月满阑干。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "下官晏平仲。昨日魏王有书到来，候主登殿启奏便了。香烟蔼蔼，圣驾临朝， 待我朝房伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晏婴下。〖吹打〗。太监引齐景公同上。"
        },
        {
          "character": "齐景公",
          "type": "引子",
          "text": "回国齐起显奇能，江山同乐太平春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晏婴上。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "晏平仲见驾，愿主千岁！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "齐景公",
          "type": "念",
          "text": "当年大战在洪昌，临潼会上住楚邦。桑园收下钟无盐，一十一国共服降。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "孤，齐景公在位。今当早朝。 卿家上殿，有何本奏？"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "臣启主公：昨日魏王有书前来，请主龙目观览。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "呈上来，待孤观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。齐景公看。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "原来魏王接孤前去赴会。卿家，孤王还是去如不去？"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "诸公宣钟国母上殿，查看八卦内面吉凶如何？"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "如此卿家传宣她上殿。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "领旨。 主公有旨：宣钟国母上殿。"
        },
        {
          "character": "钟无盐",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟无盐上。"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "环佩响叮当，上殿见君王。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "妾妃见驾，愿大王千岁！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "谢坐。宣妾妃上殿，有何国事议论？"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "梓童有所不知，昨日魏王有书前来，请孤前去赴会。特宣梓童商议，孤王还是 去如不去？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "大王，待妾妃查看八卦上吉凶如何。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "前去查来。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "领旨。 看香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监抬桌。钟无盐问卜卦。"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "摇动金钱响，神鬼站四方。叩问吉凶事，异在此卦上。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "神圣在上，弟子钟无盐，保主赴会，有凶降凶，有吉降吉。单单测测，测见测， 单见单，行人一去不回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监抬桌回。"
        },
        {
          "character": "钟无盐",
          "type": "西皮摇板",
          "text": "八卦上面查吉凶， 湘江会上箭射龙。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "梓童查看八卦，吉凶如何？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "有吉无凶。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "好吓！就命梓童挂帅，田论、关素贞为先行，将房披挂，教场伺候。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟无盐下。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "内侍传旨：命田论、关素贞披挂，教场伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐景公下。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "田论、关素贞披挂，教场伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "田论、关素贞同上，同起霸。"
        },
        {
          "character": "田论",
          "type": "念",
          "text": "双翅威风脑后飘，"
        },
        {
          "character": "关素贞",
          "type": "念",
          "text": "胸中韬略逞英豪。"
        },
        {
          "character": "田论",
          "type": "念",
          "text": "左搭弯弓秋月样，"
        },
        {
          "character": "关素贞",
          "type": "念",
          "text": "右搭狼牙箭几条。"
        },
        {
          "character": "田论、关素贞",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "田论",
          "type": "白",
          "text": "田论。"
        },
        {
          "character": "关素贞",
          "type": "白",
          "text": "关素贞。"
        },
        {
          "character": "田论",
          "type": "白",
          "text": "千岁发兵，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引齐景公、钟无盐同上。"
        },
        {
          "character": "齐景公",
          "type": "念",
          "text": "领兵下教场，"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "保主赴湘江。"
        },
        {
          "character": "钟无盐、田论、关素贞",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "钟无盐、田论、关素贞",
          "type": "同白",
          "text": "早已齐备。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "催动人马。"
        },
        {
          "character": "钟无盐、田论、关素贞",
          "type": "同白",
          "text": "众将催动人马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牌子。众人同走圆场。"
        },
        {
          "character": "钟无盐、田论、关素贞",
          "type": "同白",
          "text": "前道为何不行？"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "来此桑园。"
        },
        {
          "character": "钟无盐、田论、关素贞",
          "type": "同白",
          "text": "人马列开！"
        },
        {
          "character": "钟无盐",
          "type": "西皮摇板",
          "text": "人马来往桑园径， 此去尤恐有伤损。 坐立马上传将令， 田论、关素贞听分明： 一半人马桑园径， 一半人马随后跟。 倘若前去有伤损， 你保大王回御营。 大小三军往前进， 湘江会上显奇能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、魏灵公同上。"
        },
        {
          "character": "魏灵公",
          "type": "念",
          "text": "计就月中擒玉兔，谋成日里捉金乌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启爷：齐邦君臣到。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "吩咐摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四校尉同摆队。四文堂、田论、关素贞、钟无盐、齐景公同上。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "皇兄吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐景公、魏灵公同笑。众人同下，同上。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "不知皇兄驾到，未曾远迎，有罪。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "岂敢。来得鲁莽，御弟恕罪。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "相邀到来，有何见谕？"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "皇兄有所不知，只因二国不和，屡动干戈，请皇兄到来，与二国和好，免得众 将受刀枪之苦。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "正是御弟仁德之心。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "宴齐。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "看宴，待我把盏。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "不消。摆下就是。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "将宴摆开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗，〖牌子〗。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "御弟，这湘江会上，难道你我不成？"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "有陪客。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "有何人？请来相见。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "来，请孙驸马。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "请孙驸马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙操上。"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "慢着慢着，来的敢是孙驸马？"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "你我在哪里会过，直至如今？"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "在洪昌一别，直至如今。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "湘江会上有你在内？"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "有某在内。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "有你在内，那就热闹了。"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "少时赐你个大热闹。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "还有何人？"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "还有秦国纪千岁。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "吓，那老儿他也来了？"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "好吓，请来相见。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "有请纪千岁。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "请纪千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪燕上。"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "慢着。来的敢是御屁？"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "你敢是放松？"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "吓，你怎么叫我放松？"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "你怎么叫我御屁？"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "御弟。你不知道，你我上了年纪，牙关不得关风，所以丢去了一个“御屁”来 了。这湘江会上，有你在内？"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "有某在内。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "不觉你今老了！"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "呔！老只老了头上发，项下须，胸中韬略却也不老。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "喂，你看我说了一个“老”字，他就闹了半天。哦着了，他是个好奉承的人， 待我来奉承他两句岂不是好。 御屁，你虽然年纪大了些，你的样子犹如十七八岁的小娃娃一般。"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "十七八岁小娃娃一般。"
        },
        {
          "character": "纪燕",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "当真不老！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "湘江会上，有了你越加热闹。"
        },
        {
          "character": "纪燕",
          "type": "白",
          "text": "少时与你一个大大的热闹。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "孤家喜的是大热闹。 还有何人？"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "还有吴起。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐景公摇头。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "大王你敢是怕他？"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "不是怕他，那娃娃有些势压。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "来，请吴驸马。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "请吴驸马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴起上。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "吴驸马！"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "钟国母！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "吴将军！"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "钟娘娘！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "吴起！"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "丑丫头！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "娘娘命你鲁国行孝，这又来在魏邦，所为何事？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "你不提起鲁国行孝则可，提起鲁国行孝，令人可恼！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "敢是恼着你娘娘么？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "你且听着！"
        },
        {
          "character": "吴起",
          "type": "西皮摇板",
          "text": "五湖名扬贯九州， 百万儿郎狁貔貅。 一十二国某为首， 后出无盐丑丫头。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "当初一十八国不分上下，后出伍子胥临潼斗宝，力举千斤铜鼎，占去一国，下 剩一十七国。后出红袍武星，力劈五国，下剩一十二国，不分上下。只因齐王 在桑园收下你这丑丫头，手执春秋大棒，压定一十一国。年年进贡，每岁来朝。 只因我主鲁定公缺少二载未曾进贡，命某造下铜头铁垒宝刀金弓进贡。你国 有人开得此弓者，年年进贡，每岁来朝；若是无人开得此弓，这就下而代上。 你国文武，犹如泥塑木雕一般。谁想闪出你这丫头，问道“吴起吴起，此弓还 是文开，还是武开？”某家答曰：“文开怎讲，武开怎说？”你这丫头道： “文开药红毡铺地，摆酒一席。一边饮酒，一边开弓；若是武开，人要披甲，马 要加鞍。”某家答曰：“罢罢罢，你就武开！”谁知你这丫头，纵上马来，手 执春秋大棒，将某打下马鞍，问道：“吴起吓吴起！你还是愿生愿死？”某家 答道：“蝼蚁尚且贪生，为人岂不惜命？”齐王见喜，此时将玉银公主招为驸 马。某家在你国奉君一载，我国义我双亲一年。谁知你暗修小柬一封，下与吾 主鲁定王，道某有顺齐伐鲁之意。鲁定王大怒，将某一双父母，押下城楼。某 家一马来至城边，一双父母人头落地。是某下得马来抱头痛哭。玉银公主见某 家眼中无泪，道某吴起是个铁打的心肠。那时她拔剑自刎而亡。可叹玉银公主， 自刎身亡。那时闪得某家有家难安，有国难投。只得带领人马，这反到盖国 山，自立为王。今魏王修书接某家赴会。湘江大会之上，不想你君臣也来了！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "娘娘来者不怕，怕者不来。我且问你，湘江会上何物当先？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "百步之外立一高杆，高杆之上，悬挂杏黄旗一面，金钱一枚，马鞭一根，头一 箭箭射马鞭落地，第二箭箭射金钱落地，第三箭箭射杏黄旗。你若射得此箭， 送你君臣回去；你若射不着此箭，你君臣想回去那就万万不能！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "今在哪里？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "御营教场。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "多少路途？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "五里之遥。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "带路！"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "众将官，摆队教场！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹打。众人同走圆场。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "吴起，来此教场，谁家先射？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "某家先射。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "娘娘先射。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "慢慢，梓童，我国射了，岂就没有了他的分？让他先射你后射更好。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "吴起，你娘娘先射，那就没有了你分。让你先射！"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": "吴起",
          "type": "西皮导板",
          "text": "湘江会好比那一盘棋，"
        },
        {
          "character": "吴起",
          "type": "西皮快板",
          "text": "一着高来一着低。 吴起站在军队内， 杀人的虎眼观仔细： 将台上坐的是齐天子， 无盐保驾不远离。 那旁站的田论将， 娃娃武艺不见奇。 关素贞提刀站此地， 谅她难敌俺吴起。 二人武艺哪在意， 丑妇丫头是好的。 转面来叫声纪千岁， 燕国驸马听端的： 湘江会比不得临潼会， 鞍前马后莫远离。 倘若吴起失了计， 你保魏王坐社稷。 金枪插在皮囊里，"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "吴起",
          "type": "西皮快板",
          "text": "铁胎弯弓手内提。 开弓先射齐天子，"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "呔！吴起敢使暗箭！"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "仔细了！"
        },
        {
          "character": "吴起",
          "type": "西皮快板",
          "text": "丑鬼丫头着了急。 满满搭上朱红扣，"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "好箭！"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "不见好。"
        },
        {
          "character": "吴起",
          "type": "西皮快板",
          "text": "箭射马鞭不远离。 开弓放出二枝箭， 正中金钱不差移。 两膀用起千斤力， 三枝箭中了杏黄旗。 翻身上了马坐骑， 谅他插翅也难飞。"
        },
        {
          "character": "田论",
          "type": "白",
          "text": "田论告箭。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "你年小。"
        },
        {
          "character": "关素贞",
          "type": "白",
          "text": "关素贞告箭。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "你腰软。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "妾妃告箭。"
        },
        {
          "character": "齐景公",
          "type": "白",
          "text": "着了着了！"
        },
        {
          "character": "齐景公",
          "type": "数板",
          "text": "嘻嘻哈哈，看来你是老作家，照着他人射一箭，看他害怕不害怕。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "钟无盐",
          "type": "西皮导板",
          "text": "湘江会上用目觑，"
        },
        {
          "character": "钟无盐",
          "type": "西皮快板",
          "text": "刀枪剑戟摆得齐。 燕国孙操世无比， 纪燕手提打将锤。 二位老将不在意， 内有吴起是好的。 回言叫声田驸马， 关素近前听仔细： 湘江会比不得棋盘会， 鞍前马后莫远离。 倘若娘娘失了计， 你保大王坐华夷。 金枪插在皮囊里，"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "匹夫你打点了！"
        },
        {
          "character": "钟无盐",
          "type": "西皮快板",
          "text": "宝刀弯弓手内提。 满满搭上朱红扣， 满营三军笑嘻嘻。 推弓放出一枝箭， 箭射金钱不着移。 三枝雕翎来搭起，"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "怎么不射？"
        },
        {
          "character": "钟无盐",
          "type": "西皮快板",
          "text": "猛然一计在心里。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "丫头为何停箭不射？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "非是娘娘停箭不射，你娘娘要射鲤鱼并行。"
        },
        {
          "character": "吴起",
