{
  "script_id": "01038004",
  "title": "珍珠衫",
  "alias": [
    "中秋赏月"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "周兰英",
      "hangdang": "花旦"
    },
    {
      "name": "陈商",
      "hangdang": "小生"
    },
    {
      "name": "薛妈妈",
      "hangdang": "彩旦"
    }
  ],
  "plot": "商人蒋兴哥娶妻周兰英，蒋兴哥外出久不归，陈商谋占周兰英，买通薛婆，计诱周兰英失身。",
  "notes": "蒋兴哥妻子王三巧《珍珠衫》一戏，其用意系形容王婆蚁媒之可恶。凡今社会中人不可不引以为鉴，而深恶\n痛绝之也。盖陈大郎之见色思淫，其干法犹有可，而薛妈妈之设计陷害王三巧，则真百死不足以蔽辜也。若\n无薛妈妈，则陈大郎虽色胆如天，只能妄想，胡敢冒昧。全在薛妈妈借中秋赏月为名，用酒灌醉，方足行其\n淫凶极恶之实在也。然后本报应昭彰，薛妈妈与陈大郎，卒置之极刑。为恶者亦何所益，而必干如是十恶不\n赦之事耶。世之为青年妇女者，其视此辈恶婆，当绝之如蛇蝎也可。此剧大概，为少年暮色贪欢肉欲之事，\n观者须当引为大戒也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈商上。"
        },
        {
          "character": "陈商",
          "type": "引子",
          "text": "花发春心动，彩蝶飞舞惹思情。"
        },
        {
          "character": "陈商",
          "type": "念",
          "text": "逢春三月桃花放，遇夏荷花满池塘。秋饮金菊黃花酒，冬来腊梅开云香。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "在下姓陈，名商，字大郎，乃是徽州新安县人氏，年方二十四岁，娶妻平氏， 父母早已双亡故去，是我来到襄阳，做买卖为生。现住城外，薛妈妈店房居住， 这两日心头闷闷，不免去到大街游玩便了."
        },
        {
          "character": "陈商",
          "type": "西皮摇板",
          "text": "人生在尘世间富贵穷通， 论公商贺生计大不相同。 带领了许多民成本为重， 我不免到大街细看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈商下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引周兰英同上。"
        },
        {
          "character": "周兰英",
          "type": "西皮摇板",
          "text": "叫丫鬟带路把楼上， 上得楼来观其详。 大街之上人来往， 买卖人儿好风光。 初言我把丫鬟叫， 再叫丫鬟细听我详。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "奴家周兰英，乳名三巧，配夫蒋兴哥为妻。自因我家官人，去到广东，收讨账 目，家中之事，托奴照管。想官人去了半年有余，无有音信回来，思想起来， 叫奴好不愁闷人也。"
        },
        {
          "character": "周兰英",
          "type": "西皮慢板",
          "text": "周兰英在绣楼自思自想， 思想起奴的夫好不久长。 他去到广东城前去讨账， 家中事托靠奴一人承当。 想官人想得我懒把花戴， 想官人想得我懒上牙床。 在绣楼把官人用目来望， 不知他何日里转回家乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈商上。"
        },
        {
          "character": "陈商",
          "type": "西皮原板",
          "text": "走过了许多的大街小巷， 观见了许多的买卖客商。 行一步我在那十字街旁， 见一位美娘子盖世无双。"
        },
        {
          "character": "周兰英",
          "type": "西皮原板",
          "text": "楼下边站定了青春少年， 不放心再把他仔细观看。 好像我大官人一样一般， 我若与他一处成就婚配， 我二人做一对到老姻缘。 丫鬟带路急忙把绣楼来下， 但愿得奴丈夫早早回迁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周兰英、陈商同做身段。周兰英下。"
        },
        {
          "character": "陈商",
          "type": "西皮原板",
          "text": "一见娘行回房去， 倒叫小生好心急。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "哎呀且住，适才观见那一女子，生得十分好看，与我眉来眼去，我二人不能到 在一处，如何是好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈商想。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "这这这这……有了，我不免回转店房，问过店妈妈，再做道理。就此走走。 来此已是。吓妈妈，开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛妈妈上。"
        },
        {
          "character": "薛妈妈",
          "type": "念",
          "text": "孟尝君子店，千里客来投。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "那一位陈客人回来了。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓店妈妈，哈哈哈哈哈哈！"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "陈客人请坐。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "店妈妈请坐，哈哈哈哈哈哈！"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "陈客人你到哪里去了？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "我到大街之上，游玩去的。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你到大街上游玩去了，你这无用饭那。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "妈妈，今天我不要用饭了，多谢妈妈好意。哈哈哈哈哈哈！"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "好说。吓陈客人，我看你今天回得店来，这样欢喜不尽，必是办了什么好买卖 了罢？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "无有什么好买卖。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "不对不对，一定有事。哦，想是你得了发财票了罢？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "也无有。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "无有，你有什么事，对我说说成不成。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "此事说将出来，还要妈妈费心办理。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "什么事情，先对我说明白。我能办理，我呀必与你办理就是。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓，妈妈有所不知，是我清早起来，去到大街游玩，行在十字街前，有一高大 楼房，那是何家住宅？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "哦，你问的是十字街前那一高大的住房，提起此大大有名，他父蒋世泽，原是 随他丈人，在广东贩卖珠宝为生，此人亡故了。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "现下他家还有什么人那？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "听我对你说，如今那就是他的儿子，在外做买卖了。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "这就是了。吓，妈妈，他儿子叫什么名了？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "他儿子叫蒋兴哥。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "哦，叫蒋兴哥。吓，妈妈，我来问你，此人如今可在家中？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "如今不在家中。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "哦，不在家中。好好，实在巧的巧的。吓，妈妈，他到哪里去了？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我晓得他到哪里去了？你这个人，说话怎么这样多呐，你不成是到这里来探访 来了罢？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓，妈妈，今日无事，你我谈谈心哪。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "谈心三言两语，你问这么明白，做什么？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "无有别事，妈妈请讲。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "此人去到广东讨账去了。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "讨账去了，好好好，实在好。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我看你今天出门，你许看见鬼了么？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "这是什么说，吓，妈妈，还要问你。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "有什么话，快快地说，我还有别的事哪。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "妈妈，他家中楼上，有一女子是他何人？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "哈哈，说来说去，问到这里来了，我明白了。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "妈妈，明白什么？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你无有转好念头，你怎么会看见她在楼上哪！"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "无意而看见的。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "哦，无意而看见的，你问人家做什么？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "我看她生得好看，我要问上一问。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我对你说罢，她叫周兰英，外号做王三巧，她就是蒋兴哥老婆，你看看人家穿 的衣裳，全是珠子的，此地可算一个大户之家，你明白不明白。你再要出去， 少到那里游玩去。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓，妈妈，他家之事，你怎么全晓得？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你问我，我不说。我要不晓得，你怎么去呀？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "哈哈哈哈哈哈，真乃是好女子，好佳人那，哈哈哈哈哈哈！"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你们老爷看，我一说，她马上就是好女子。 我来问你，说了半天，你打算怎么样那？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "我对你直说了罢：那一女子，与我眉来眼去，我二人有此意见，不能到在一处， 如何是好？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我晓得，别对我说。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓，妈妈，还要你做做好事。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我做什么好事？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "还要妈妈为利，与我介绍介绍。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我把你个小王八蛋，你把老娘当作什么人哪？我开店，我还给你们拉皮条，操 杀唔的个娘啊！唔个小店，出门在外，好好做生意，年纪轻轻的，还不学好去， 学吊膀子，快快别处住吧，再要说这话，我马上报告包打听，将你送到济良 所里头去，什么东西，气死我了！"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "观见妈妈恼了，这便如何是好？有了，我这现有玉镯一支，送与妈妈罢，此事 也就完了。 吓，妈妈，方才是我的不是了，妈妈不必见怪。我这里现有玉镯一支，奉送妈 妈。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我不要，我不要。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "妈妈收下罢。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你的东西，我怎么好要哪？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "收下罢。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "不要，不要，我拿过来了，哈哈哈哈哈哈，我与你闹着玩的。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "妈妈，我是胆小人，不会玩笑，妈妈请坐。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "坐下坐下，我对你说，这件事，我与你办成就是。但一件。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我若到她说，她要问，你是我的什么人，我是你的什么人，我怎么说呢？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "可也是呀，有了，如若不然，我拜在妈妈的门下。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "那如何使得。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "使得了。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "使不得，使不得。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "使得了，妈妈转上，受见一拜。"
        },
        {
          "character": "陈商",
          "type": "西皮摇板",
          "text": "妈妈转上儿拜见， 如同亲生一样般。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "好了，好了，哈哈哈哈哈哈，这个你就放心了罢，有什么大事，全有我哪。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓妈妈，你我一同前去。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你这个小子，真来不及了，你别急呀，马上你不能去，你先在店内等等我，我 还要想个法子，到她家里去，将事办好，再叫你去。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓妈妈，我一样前去呀。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我办好了，我来叫你，你在后门进去，你先在后面等我，我这就走。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "妈妈快快去罢。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我走了，你可别出去，店内无人照看。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "全有我哪，妈妈放心罢。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我走了。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓妈妈回来。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "你办成了无有？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你这小子，来不及了，我还无转身，哪就办成了，下去罢。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "快快的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈商下。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "这小子先前进店来，是个老实人，他如今做出这个无情之事，还叫我与他办理， 我怎么去说呢，我要不去罢，他又拜在我的门下为子，我与他办不成这事， 也对不起我那儿子，我必得想个法子，到她家里去。有了，我想今日乃是八月 中秋，我买点水果，打点高粱酒，与她玩月。一来玩月，二来用酒将她灌醉， 也好行事，我就是这个主意。天气不早，就此走走也。"
        },
        {
          "character": "薛妈妈",
          "type": "西皮慢板",
          "text": "闲无事我在这家中闷坐， 陈相公他叫我与他说合。 此一去到她家巧言变化， 这一对管叫她两家共和。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛妈妈下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周兰英上。"
        },
        {
          "character": "周兰英",
          "type": "念",
          "text": "自未一件事，长挂一片心。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "奴家周兰英，自因我家官人，出外讨账，去了日久，无有音信来到，我在那绣 楼之上，探望官人，不想街前，来了一位俊俏才郎，我看此人，与我家官人相 同，我二人不能到在一处，叫奴时时在心，想今日乃是中秋节之日，家家户户， 男男女女，俱都玩月，交欢一处，想奴一人在家，闷闷不乐，想起官人来， 叫奴好不伤心人也。"
        },
        {
          "character": "周兰英",
          "type": "西皮慢板",
          "text": "叹春光都付与多愁多病， 奈何天辜负了美景良辰。 可怜奴无家雁霜天只影， 好比那萍和梗一样飘零。 花如烟柳如雾落红成阵， 这焦桐却为何弹不成声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛妈妈上。"
        },
        {
          "character": "薛妈妈",
          "type": "西皮摇板",
          "text": "行一步来到了她家门首， 我见了王三巧细说根由。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "来在此地，我来叫门。 开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "妈妈到此何事？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "你去对你们少奶奶说，我来了。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "晓得了。 禀大奶奶：薛妈妈来了。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "请她进来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "妈妈请你进去。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "大娘子在哪里？"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "妈妈到了，请坐。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "坐下坐下。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "妈妈到此何事？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "今天乃是中秋节，你家官人不在家，我也无有事，买了点水果，与你玩月来的。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "想我家官人，不在家中，你我一处，饮酒玩月叫他晓得，那还了得。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "不要紧，你也是女子，我又是个坤角，使得了。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "使得的？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "使得了。 丫鬟姐，你不要在这伺候，你去后面，找别人玩去罢。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "别玩笑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "来来，我与你满上。大娘子请酒。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "妈妈请。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我说这个，大娘子，你丈夫出外去了多少日子了？"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "去了半年有余了。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "去了半年多了，你就不想他哪？"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "我、我、我、我、我、我是不想他的呀！"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "不想他好，你可别哭。来来，吃酒罢。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "吓妈妈，我这酒不能多用。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "来来，再吃一杯。大娘子请。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "妈妈请。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "请。我这爱说话，我还要问问你，当真地想你丈夫不想哪？"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "吓妈妈呀！"
        },
        {
          "character": "周兰英",
          "type": "西皮原板",
          "text": "奴的夫去讨账无有音信， 每日里思官人好不伤情。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "大娘子，不要难过，请来吃酒。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "妈妈请。"
        },
        {
          "character": "周兰英",
          "type": "西皮原板",
          "text": "往日里饮酒酒不醉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周兰英吐。"
        },
        {
          "character": "周兰英",
          "type": "西皮原板",
          "text": "心中有事酒醉人。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "大娘子，再用一杯罢"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "我、我、我、我、我、我不吃了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周兰英大吐。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "唔唔唔唔。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "不吃了。我搀你上床去，好不好？"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "妈妈搀我来。 唔唔唔唔。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "看，吐的我一身。好了，大事成功。叫我儿子去。 那小子出来罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈商上。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓妈妈，办好了无有？"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "办好了，快去罢，玩一下子就出来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈商入帐子。小过门。"
        },
        {
          "character": "薛妈妈",
          "type": "白",
          "text": "我的妈妈，我也难过起来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈商出帐子。"
        },
        {
          "character": "陈商",
          "type": "白",
          "text": "吓妈妈，我要走了。"
        },
        {
          "character": "薛妈妈",
