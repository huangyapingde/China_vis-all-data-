          "text": "禀知小姐：老奴要见。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "少上一时。 禀大奶奶：院公要见。"
        },
        {
          "character": "周兰英",
          "type": "白",
          "text": "叫他进来。"
