        {
          "character": "秦琼",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "秦好汉！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "不敢！"
        },
        {
          "character": "秦琼、单雄信",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "听兄台讲话，也不像此地人氏。"
