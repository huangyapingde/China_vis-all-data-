          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哽哼。什么人？"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "哦，亲家遇亲家，"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "礼多人不差。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "亲家是我儿，"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我儿是亲家。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "一点亏也不吃。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "什么事情？"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "你去问问里面两个客人，可要买锏？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "他们不洗衣裳，不要碱。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "这是两军阵前打战的霹雳双锏。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "买卖成功，你我二八扣。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "我还没有拿着，你去问问看，要不要。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "二位可要买锏？"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "当面言价。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "里面说呢：要当面言价。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "晓得了。 二爷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼睡。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "他走到哪里困到哪里！待我来骗他。伙计们摆饭！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "店主东，哪里有饭吓？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王老好丢锏。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "你怎么呢？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "揝揝我的脚了！"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "锏在这里，会揝你的脚了！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "里面怎样言讲？"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "要当面言价。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哦，走走。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "到哪里去？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "当面言价。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "你进去，我不进去。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "一同进去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼拉王老好。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "你拉住我干什么？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "我怕你跑了。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "你该我的钱，怎么怕我跑了？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你跑了，我吃哪一个？"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "那么你算吃定我呢！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哽，你猜着了。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "你与我去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼进店。"
        },
        {
          "character": "王老好",
          "type": "白",
          "text": "哎呀，慢着，你看一个马快，两个强盗，他们要打起来，我不要吃人命官司， 待我溜了吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王老好下。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "二位请坐。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "此锏可是卖的？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "放下我等观看。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "沉重的紧。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "不妨事。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "放下了。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "桌子压坏了！"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "此锏可会耍？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "略知一二。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "耍来我等观看。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "酒家带他下面用饭。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "吃饭去。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哦，吃饭去，走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、酒保同下。"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "贤弟，你我做绿林买卖，怕的何人？"
        },
        {
          "character": "谢映登",
          "type": "白",
          "text": "怕的秦琼。"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "我看此人好像秦琼。"
        },
        {
          "character": "谢映登",
          "type": "白",
          "text": "等他到来，用言语打动于他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "二位，这个人，吃了五百馒首，半担米，半个猪。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "白",
          "text": "上在我二人账上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "多谢二位酒饭。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "可曾用饱？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "无非充饥而已。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "耍来我等观看。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "此地狭小。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "酒家可有宽阔之处？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "后面宽阔。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "带路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒家允。众人同走圆场。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "耍来我等观看。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "献丑了。"
        },
        {
          "character": "秦琼",
          "type": "西皮摇板",
          "text": "站在庭前用目斜，"
        },
        {
          "character": "秦琼",
          "type": "西皮快板",
          "text": "上面坐的二军家。 认得他人是响马， 无有批票怎能拿？ 此地若有历城县， 定把二人送官衙。 到如今说什么刚强话， 讲什么浪言把自夸。 拤头去尾将锏耍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼耍锏。"
        },
        {
          "character": "秦琼",
          "type": "西皮摇板",
          "text": "反被二位取笑咱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "请坐。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "听兄台讲话，不像此地人氏。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "本不是此地人氏。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "哪里人氏？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "山东历城县人氏。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "山东历城县，我有一好友，兄台可知？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "提起此人，大大的有名！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "姓秦名琼，字叔宝。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "秦琼，此人落魄的紧。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "人有穷富，但讲何妨？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "在下就是秦琼。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "哦，原来秦二哥！失敬了！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "岂敢。请问二位尊姓大名？"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "在下王伯当。"
        },
        {
          "character": "谢映登",
          "type": "白",
          "text": "在下谢映登。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哦，原来王、谢二位贤弟，失敬了！"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "岂敢。二哥为何这等狼狈？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "二位贤弟非知：只因愚兄解押一十八名江……"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "哽。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "绿林的好汉，到天堂州交纳。只为天气炎热，中途路上，伤了一名。那蔡大老 爷不与批票回文，故而被困在此。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "这有何难？拿小弟的名帖前去，叫那蔡知州，与二哥批票回文就是。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "多谢二位贤弟。"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "来，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保允。"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "拿我名帖，叫那蔡知州，速付批票回文前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保允，下。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "二哥，前日老伯母寿诞，有份厚礼，可曾收下？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "但不知从哪道而来？"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "打从那黑……"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "收下了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "启二位：批票回文在此。"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "二哥，批票回文在此，这有散碎银两，与为路费。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "二位贤弟的银两，我秦琼怎能用得？"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "敢是嫌轻不成？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "如此，愧领了。"
        },
        {
          "character": "秦琼",
          "type": "西皮摇板",
          "text": "二位贤弟赠我银， 来生犬马报你恩。 心中恼恨单雄信， 不该拐我马能行。 有朝犯在秦琼手， 打一锏来问一声。 二位贤弟响马放， 纵有大祸我当承。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        },
        {
          "character": "王伯当、谢映登",
          "type": "同白",
          "text": "酒家，酒钱在此，我等去也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯当、谢映登同带马，同下。酒保下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}