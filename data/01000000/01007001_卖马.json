        {
          "character": "秦琼",
          "type": "白",
          "text": "但不知打从哪道而来？"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "打从那黑……"
        },
        {
          "character": "秦琼",
          "type": "白",
