{
  "script_id": "01012005",
  "title": "打銮驾",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "马妃",
      "hangdang": "旦"
    }
  ],
  "plot": "剧称宋仁宗嘉佑帝因陈州旱荒三载，发国币赈济。先命外戚马龙前往，讵马龙自恃系西宫宠妃马氏之兄，估\n世作弊，克扣皇粮。至万余石之巨。旋被灾民叩阍告发，帝怒甚。即招马龙回，另旨特简包拯为放赈钦使。\n并令包拯查办前任私扣币粮事。包拯初辞不拜命，继而为十家朝官，交章竭力保荐，咸谓此事非包拯不办。\n包拯力辞不得已，乃始奉诏就任。讵意马妃闻讯，知包拯素铁面无私。若令成行，则包拯必彻底查清，兄之\n前程，将必倾覆。即与己亦殊有密切关系，恐从此或失宠，亦难逆料。因即多方设计，私有意中伤之。当包\n拯将出京之前夕，马妃知包拯必经御街前行，乃向皇后处诳借銮驾半副，僭乘而出，专侯包公至某处，则己\n即伪为皇后，令銮仪抄迎其前，已当包拯去路。包拯遥见卤簿，即返道回避。如是者三数次，盖欲迫使包拯\n必从禁中御街行也。迨包拯至御街，则銮驾又蓦地突出其前。包拯至此已不及避，乃只得下舆跪迎道旁，并\n叩头谢闯銮驾不敬罪。马妃方故意盘诘。冀得索瘢寻寡，以入包拯罪。不意忽为包拯从役识破，告包拯知，\n谓系马妃假扮。包拯乃大怒，即麾令向前，将銮驾打退，且追逐入禁。马妃见势不佳，遂一不做二不休，只\n索控词。回宫哭诉诳帝。包拯心中虽担忧，然事已至此，骑虎难下。只得假装疯魔随往面帝而已。",
  "notes": "此剧颇有趣味，惜近不多见。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "引子",
          "text": "一片丹心，保宋主，锦绣龙庭。"
        },
        {
          "character": "包拯",
          "type": "念",
          "text": "黑暗暗乌纱盖顶，明亮亮玉带随身。上金殿君王见喜，下朝班文武皆尊。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老夫包拯，宋室为臣，官拜龙图阁大学士，兼理开封府尹。只因陈州干旱三载， 圣上令马国舅前去散粮，谁想他克扣皇粮万担。众百姓告下御状，万岁令老 夫前去查明此事。是我连退数本不去，十家保官上殿，保我出京，游街三日， 前去放粮。 王朝马汉，人役可齐？"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "具已齐备。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吩咐外厢开道。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "外厢开道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上。"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "忆昔当年赴科场，"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "在二堂辞别了我的嫂娘。 上京时打从在定远县过， 走山西和太原一路奔忙。 太行山遇贼人打贿击掌， 我得中他人头送上公堂。 山岗上辞别了刘贼响马，"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "不分昼夜到科场。 三篇文章做得好， 试官点我状元郎。 跨马游街把官闯， 偶遇见宫娥彩女笑一场。 宋王爷道我的面貌丑， 贬去了试官，摘去了状元郎。 多亏了恩师王丞相， 他带我包拯二次见君王。 大喝一声你就往前闯， 游街三日去放粮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马妃、二宫女同上。"
        },
        {
          "character": "马妃",
          "type": "引子",
          "text": "金龙盘玉柱，彩凤绕画梁。"
        },
        {
          "character": "马妃",
          "type": "念",
          "text": "头戴珠翠彩凤冠，身穿锦绣滚龙衫。陪王伴驾皇王宠，执掌西宫伴君眠。"
        },
        {
          "character": "马妃",
          "type": "白",
          "text": "哀家马氏，兄长马龙。只因陈州干旱三载，圣上命我兄长前去放粮，不想他克 扣军饷。圣上二次有命，命包拯前去放粮。我想此人铁面无私，恐他查明此事， 与我兄长不便，是我今早在正宫国母台前，讨下半副銮驾，去到御街，与黑 贼作对。 宫娥，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女同允。"
        },
        {
          "character": "马妃",
          "type": "白",
          "text": "吩咐銮仪走上！"
        },
        {
          "character": "宫女",
          "type": "同白",
          "text": "銮仪走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "銮驾自两旁分上。"
        },
        {
          "character": "马妃",
          "type": "白",
          "text": "摆驾御街！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "马妃",
          "type": "西皮导板",
          "text": "兄长做事太不成，"
        },
        {
          "character": "马妃",
          "type": "西皮慢板",
          "text": "不该克扣众黎民。 圣上又命包文正， 铁面无私不容情。 宫娥摆驾御街进， 单等南衙小包拯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、四青袍、王朝、马汉同上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "适才离了文华殿， 辞别两班文武官。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "銮驾挡道！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "转道！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "只见銮驾御街挡， 娘娘为何出宫廷？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、四青袍、王朝、马汉同下。"
        },
        {
          "character": "马妃",
          "type": "西皮摇板",
          "text": "满江撒下千丝网， 哪怕鱼儿不上钩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、四青袍、王朝、马汉同上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "包拯生来不怕人， 他是君来我是臣。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "銮驾挡道！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "转道！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "三番两次把道挡， 倒叫包拯解不明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、四青袍、王朝、马汉同下。"
        },
        {
          "character": "马妃",
          "type": "西皮摇板",
          "text": "宫娥摆驾后街进， 我看包拯哪里行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、四青袍、王朝、马汉同上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "在金殿奉王命谁敢违抗， 黑暗暗出朝堂亚赛阎王！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "銮驾挡道！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "转道！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "转道不及！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "住轿！"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "御街落下一只凤，"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "好一似雀鸟离却山林。 上打黄罗伞一把， 下有彩旗数十根。 左旁抱定玉儿印， 宫娥彩女两边分。 右边抱的尚方剑， 押定满朝文武臣。 天大地大皇王大，"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "见君不参有罪人。 包文正撩袍忙跪定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女同笑。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "宫娥彩女笑连声。 是是是来明白了， 笑俺包拯黑脸人。 人来看过爷的无价宝， 遮住包拯黑面人。 走向前，忙跪定， 头不敢抬来眼不敢睁。"
        },
        {
          "character": "马妃",
          "type": "西皮摇板",
          "text": "明明知道将他问， 你是何臣说分明。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "娘娘把臣忘记了， 臣是南衙小包拯。"
        },
        {
          "character": "马妃",
          "type": "西皮摇板",
          "text": "不在朝中把君奉， 来在御街为何情？"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "陈州干旱三年正，"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "树无枝叶草无根。 万岁爷闻之心不忍， 命国舅散粮安黎民。 谁想国舅心太狠， 克扣皇粮数万倾。 众百姓告下冤枉状， 万岁爷二次宣包拯。 在金殿连推数道本， 十家保官保定了为臣。"
        },
        {
          "character": "马妃",
          "type": "西皮摇板",
          "text": "十家保官哪一个？ 快对哀家说分明。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "头一家保官王丞相， 第二家保官八贤君； 第三家保官陈世美， 第四家保官老陈琳； 第五家保官是寇准， 第六家保官佘太君； 第七家保官吕蒙正， 第八家保官老赵斌； 第九家保官郭阁老， 第十家保官陈翰林。 在御街闯了娘娘道， 望娘娘开了天地恩。"
        },
        {
          "character": "马妃",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "马妃",
          "type": "西皮摇板",
          "text": "听一言来怒气声， 闯了御街罪非轻。 哀家上殿奏一本， 管叫黑头挂午门。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "听一言来心内惊， 苦苦作对为何情？ 包拯正在为难处，"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "王朝禀事。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "又听王朝报一声。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "王朝，此地什么所在？焉敢大呼喊叫！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "启禀相爷：她不是正宫主母，乃是西宫马娘娘。在正宫主母台前，讨来半副銮 驾，来在御街前，与我爷作对。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "尔可看得真？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "看得真。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "见得明？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "见得明。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老爷的考程？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "小人的性命！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "老龙正在沙滩困， 忽听春雷响一声。 开言便把王朝叫， 老爷言来你是听： 上打黄罗伞一把， 下打彩旗数十根。 忙将銮舆一齐打，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、龙套同打銮驾，马妃、宫女同下，王朝追下。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "有什么大过爷担承！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引马妃同上。"
        },
        {
          "character": "马妃",
          "type": "白",
          "text": "且住，实指望来在御街，与黑贼作对，谁知又被黑贼看破，将銮驾打碎，这便 怎么处？呵呵有了，我不免上殿奏他一本。包拯啊保证，管叫你命丧黄泉！"
        },
        {
          "character": "马妃",
          "type": "西皮摇板",
          "text": "宫娥女摆驾上金殿， 见了万岁奏根源！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马妃、宫女同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "骂声贱妃哪里行， 老爷赶你午朝门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝上。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "启禀相爷：马妃上殿奏本去了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "听说贱妃把本伸， 倒叫包拯心内惊。 大大的棺木买一口，"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "要棺木何用？"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "盛你老爷的死尸灵。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "老爷是清官，可以上殿奏得本。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "歪戴乌纱袍撒带， 假装疯魔去见君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}