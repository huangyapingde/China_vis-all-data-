    }
  ],
  "plot": "按艾子诚，生小失父，仅知父名文仲，因与北村陈姓争斗，失手伤人，惧罪远避，十八载杳无音讯。继而母\n亦病故，艾子诚治母窀穸事毕，遂出寻父。辗转三年，迄无音讯。而盘川则已罄，寻至奉天马家山地方，为\n人工作，挣得些少川资，始再前进。讵意行不多路，忽遇拦路盗，将其包裹行囊一股脑儿都劫去。艾子诚至\n此，真似路走尽头，遂急匆匆入深林，欲觅一死。岂知心急慌忙，忽撞入一少年女子怀中，致将该少女撞跌。\n乃为老少男妇一干人所围住，或责或打，闹得艾子诚气上加愤，真个求死不得。谁料事有奇巧，盖此地有\n一客籍富翁周某，本亦宁河县人，夫妻旅居马家山，已二十馀年，以垦植森林采木致富。惟夫妻半百，膝下\n只有一女，名素秋，颇干练有须眉气。二老本欲遄返故里，谋继嗣续，以从周素秋言遂将择一赘婿。是日，\n夫妇女儿三口，率同一个养童，正在林中游观，并邀到同乡王木匠，在此商议。托王木匠留意佳婿。周素秋\n独自散步，因被艾子诚撞倒，乃围住盘问之下，艾子诚方将籍贯事故，一一说明。而王木匠忽惊忽叹，终又\n相抱大哭。盖王木匠即是艾子诚之父艾文仲也。于是彼此说明，诧为奇遇。周老遂招艾子诚为婿。试思如此\n穷途颠沛，忽得佳妇巨产，父子团聚，非孝之诚能至此哉。",
  "notes": "此剧宗旨醇正，词曲清新，为陕省醴泉卢搢卿原编，临潼孙仁玉先生改排。于旧教育中，寓新教育之精神。\n处处切合时事，最为改良风俗之利导。二君以年来世风不古，道德沦亡，竟至有倡非孝公妻之论调者，因取\n直隶宁河县艾子诚千里寻父一事，排成节目，登场奏演。俾见之者知所观感，信天道好善，纯孝者毕竟有善\n报也。剧中大概情节，与昆剧《寻亲记》相仿佛。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚贫装束背包裹上。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "三载离家寻父去， 东西南北无消息。 千辛万苦向谁叙， 盼的是父子团圆无消息。"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "小生艾子诚，直隶宁河县人。尝闻母言：父名文仲，昔年与北村陈百万，为争 闲气，失手打伤。误为已死，因此逃避在外一十八载，杳无音信。前年老母病 故，埋葬已毕，我便出门寻父。于今三年，仍无消息。路途缺少盘费，前在奉 天地方，为人作工，挣了几串盘缠，只得再向前去了。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "想父母养育恩山岳并重，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老马贼、小马贼戴红髯持刀同上。"
        },
        {
          "character": "老马贼、小马贼",
          "type": "同白",
          "text": "咱家马贼是也。"
        },
        {
          "character": "老马贼",
          "type": "白",
          "text": "伙计，前边过去一个客人，你我一同赶上前去，看有甚么财喜。"
        },
        {
          "character": "小马贼",
          "type": "白",
          "text": "速快赶上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老马贼、小马贼同下。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "受尽了千般苦不变初衷。 我这里整行装忙赶路径， 寻不见生身父永不回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老马贼、小马贼同上。"
        },
        {
          "character": "老马贼、小马贼",
          "type": "同白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚作惊颠。"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "我、我向前边去。"
        },
        {
          "character": "老马贼、小马贼",
          "type": "同白",
          "text": "拿的甚么东西？还不与我留下。如其不然，定送你的狗命！"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "莫、莫、莫拿甚么。"
        },
        {
          "character": "老马贼",
          "type": "白",
          "text": "伙计，拿包裹来看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小马贼抢去包裹看。"
        },
        {
          "character": "小马贼",
          "type": "白",
          "text": "这是银子。"
        },
        {
          "character": "老马贼",
          "type": "白",
          "text": "拿上走。 不准你声张，好将你的狗命留下。再要呐喊休想活命！ 拿上走！"
        },
        {
          "character": "小马贼",
          "type": "白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老马贼、小马贼同下。"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "哎呀不好。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "怨苍天你为何尼人太甚， 挺孤身走天涯千里寻亲。 中途路遇强盗银钱抢尽， 是何人怜念我客路孤贫。"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "这却怎处？这却怎处？前边不远就是树林，不免去到那里，自寻短见。便是这 个主意了。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "艾子诚来灰了心， 银钱抢的无分文。 我只得去向树林寻自尽， 阴曹府等候父的鬼阴魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚急下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "布树林景。周仁全、康氏、周素秋同上。"
        },
        {
          "character": "周仁全",
          "type": "唱",
          "text": "流落他乡二十年，"
        },
        {
          "character": "康氏",
          "type": "唱",
          "text": "金钱暗掷卜呈还。"
        },
        {
          "character": "周素秋",
          "type": "唱",
          "text": "含情欲说心中事， 鹦鹉前头不敢言。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "老夫周仁全，直隶宁河县人。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "奴家康氏。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "钗裙周素秋。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "贤妻！"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "官人。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "自从那年移居马家山中，迄今二十馀载，虽然置有森林，足以自养，但你我年 将半百，膝下只有一女。思想起来，好不教人灰心。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "官人请听！"
        },
        {
          "character": "康氏",
          "type": "唱",
          "text": "自从你我来此地， 二十年光阴一瞬息。 专务森林为生理， 也还足食又丰衣。 虽然无有男孩子， 女儿也算掌上珠。 我劝你及早回故里， 把森林一概换朱提。 但能疏财并仗义， 百年之后留口碑。 若有儿子不争气， 无子还胜有子嗣。 还乡为女择佳婿， 有个半子也可依。 夫君莫要错主意， 安排诸事定归期。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "爹爹请听！"
        },
        {
          "character": "周素秋",
          "type": "唱",
          "text": "适才的话儿听一遍， 孩儿脸上好羞惭。 二老爹娘同抱憾， 膝下缺少好儿男。 男儿贵来女儿贱， 女儿不值半文钱。 曾记得古来有俗谚， 却把孩儿身价添： 生女勿悲酸， 生男勿喜欢。 看起来男儿女儿女儿男儿何分辨， 只要把家业能保全。 缇萦上书救父难， 木兰替父守边关。 这样女儿真罕见， 一样青史把名传。 英吉利女王坐金殿， 荷兰国女王掌朝权。 女儿能管人千万， 难道不能续香烟？ 这家产就教儿照管， 我管保二老不饥又不寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仁全笑。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "你娘儿俩，讲得都是呀！"
        },
        {
          "character": "周仁全",
          "type": "唱",
          "text": "听罢言来喜气洋， 你母女真算有主张。 是我心中一思想， 旧日的风俗要改良。 自己的女儿自己养， 却向族中要远房。 假若莫有亲族党， 还向外姓要儿郎。 不亲的男儿把福享， 亲生的女儿受凄惶。 这些人心中真迷惘， 这些事做的太荒唐。 这产业就教我儿掌， 只于儿快招一个好东床。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "哦，就是这个话儿。自己现有女儿，却要下个远房侄儿，或要下个外姓男儿， 好好的一份家业，却让于外人执掌。自己的亲生女儿，却一点不能沾染。这个 道理，真不妥当。我想来木匠王师父，既是咱的乡党，又是你的朋友，你就可 以托他与女儿择个佳婿。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "好好好，今天便请他来，与女儿择个佳婿，二来请他与森林评个价值。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "唵，何必这样急荒吗？走着就是了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童跑上。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "木匠王师父来了。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "妙极妙极，你说我们在林中游玩，也就请他到林中叙话。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童引艾文仲同上。"
        },
        {
          "character": "艾文仲",
          "type": "唱",
          "text": "幼年性情太卤莽， 打伤人命奔他乡。 又凭手艺把身养， 不觉两鬓白似霜。"
        },
        {
          "character": "周仁全、康氏",
          "type": "同白",
          "text": "王兄到了。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "王伯到了。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哦到了，你们一家团聚，好兴趣呀！"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "你今日来得凑巧。我有要事相托。一来托你于小女择个佳婿，招赘了我便要依 靠。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "要请我当红叶，那我还能推辞？"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "二来托你于森林评个价值，拍卖了我便要回乡。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哎哟！那老哥未免拍滞了。常言说到处是吾家。况且这奉天仍是我中国，何必 回到本县才叫回到故乡？"
        },
        {
          "character": "周仁全、康氏",
          "type": "同白",
          "text": "你先试评量评量。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "不要紧，评量评量。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仁全打木，艾文仲看木。周素秋惊。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "哎呀母亲，你看那边一位少年，踉踉跄跄，跑向林中来了！"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "哦，他有甚么跑向林中来了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康氏、周素秋同立树后向内看。"
        },
        {
          "character": "艾子诚",
          "type": "内唱",
          "text": "挣下了盘费被贼抢，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚上。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "还不知父亲在何方？ 我看来今生无希望， 碰死在树林一命亡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周素秋微前挡艾子诚，艾子诚碰周素秋胸膛。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "哎呀我的妈呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周素秋倒。康氏扶周素秋，枕臂上。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "这倒怎了？"
        },
        {
          "character": "周仁全、艾文仲",
          "type": "同白",
          "text": "这是何故？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童拉艾子诚，打一拳。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "哪里这个光棍，睁的眼在裤裆，为何急急忙忙碰倒我家姑娘？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "我寻死哩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童打艾子诚。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "我把你这嘴，打的照后长上哩！你寻死寻了个巧妙，往姑娘怀里寻死来了！"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "我冒碰哩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童踢艾子诚一脚。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "你才做了个鬼！你冒碰哩？你怎不往我怀里碰？偏偏往我姑娘怀里碰哩！是碰 去软和诌和吗？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "人莫运气了，寻死都寻下乱子来了。"
        },
        {
          "character": "周仁全、艾文仲",
          "type": "同白",
          "text": "莫要打，莫要打！"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "哎哟哎哟。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "真该打，真该打！看把娃碰成甚么样子了！"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "不必生气，不必生气。听他的口音，像是咱们的乡党。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "是呀，听他的口音，像是咱们的乡党。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "这一相公，你是哪里人氏，因为何事来寻自尽？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚跪。"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "老伯请听呀！"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "我儿怎么样？"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "不要紧了，不要紧了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周素秋立，看，气指艾子诚。家童握拳。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "我把你……"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童退。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "我生长直隶宁河县，"
        },
        {
          "character": "周仁全、艾文仲",
          "type": "同白",
          "text": "果然是咱们的乡党。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "儿呀，他才是咱们的乡党。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "乡党就该碰人吗？"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "早说你是宁河人，少挨两疙瘩子。"
        },
        {
          "character": "周仁全、艾文仲",
          "type": "同白",
          "text": "住在哪个村子？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "艾家村里有家园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲惊起。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哦！你就是艾家村人氏？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仁全向康氏。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "他居住艾家村，更是近乡党了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康氏向周素秋。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "他姓艾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周素秋以拍自掩。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "怪道来可爱的。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "你离我才十里路，我就在精尻子洛家住着哩！"
        },
        {
          "character": "周仁全、艾文仲",
          "type": "同白",
          "text": "因为何事来寻自尽？"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "生世来未曾见父面，"
        },
        {
          "character": "周仁全、艾文仲、康氏",
          "type": "同白",
          "text": "原是孤儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周素秋向台下。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "原是莫爹的娃，唵真可怜！"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "你想必是个墓生子。"
        },
        {
          "character": "周仁全、艾文仲",
          "type": "同白",
          "text": "往下讲来！"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "家母常常对我言。"
        },
        {
          "character": "周仁全、艾文仲",
          "type": "同白",
          "text": "说些甚么？"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "说我父打伤陈百万，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲惊起。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲坐。周仁全、康氏互相。"
        },
        {
          "character": "周仁全、康氏",
          "type": "同白",
          "text": "哎哟遭吓人命了！"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "怎么遇下这事？不知道怎了来？"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "你爸还是个半斤面。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "快快往下讲来！"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "误为已死逃外边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲惊喜。"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "我对苍天发誓愿， 寻不见我父不回还。 十五岁离家未回转， 奔走风尘已三年。 艰难困苦都受遍， 才从直隶到奉天。 所带的金银都用完， 无奈了受苦挣盘川。 被贼人抢得无一串， 莫路儿寻死在树林间。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "照这说来，你名叫什么？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "名叫艾子诚。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "你父可是艾文仲？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "你母亲可姓李？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "你左邻可是张家？右邻可是王家？"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "正是的。你老人家怎么如此清晰？"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "儿呀，你向何处去寻父亲！我不是王居义，我便是你父艾文仲！"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "哦，你就是我父亲？"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哦，我便是你父亲！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲、艾子诚相看。周仁全向康氏。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "这真凑巧，才是他的儿子！"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "怪道来是一个模样！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周素秋向台下。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "唵他儿子比他老子还心疼。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "真是一个壳子壳下的。"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "儿的父！"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "父的儿！"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "我的父亲呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚跪向艾文仲。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哎我的儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲、艾子诚、周仁全、康氏、周素秋、家童同擦泪。"
        },
        {
          "character": "艾文仲",
          "type": "唱",
          "text": "为父当年做事错， 与人争斗少斟酌。 犯了王法忙逃躲， 东奔西窜无下落。 家丢你母人一个，"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "我母亲已经去了世了。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哎我的贤妻呀！"
        },
        {
          "character": "艾文仲",
          "type": "唱",
          "text": "时刻挂念泪如梭。 又恐怕仇家来寻我，"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "陈百万并莫有死。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "谁晓得他莫有死呀！"
        },
        {
          "character": "周仁全、康氏、周素秋",
          "type": "同白",
          "text": "才是虚惊！"
        },
        {
          "character": "艾文仲",
          "type": "唱",
          "text": "无奈匿迹在山河。 本姓原名齐改过， 但凭手艺度生活。 欲修书信恐招祸， 累我儿千里受奔波。 三年寻问辄相左， 不料到此巧遇合。 孝心坚定终不挫， 如此男儿实无多。 待我把诸事安排妥， 父子们一路回宁河。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲搀艾子诚起。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "难为了我儿了！"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "难为父亲了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲捉艾子诚手相向擦泪。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "哎我好伤情也！"
        },
        {
          "character": "周仁全",
          "type": "唱",
          "text": "可羡他有个小娇生， 我只有一个女花童。 纵然间女儿能孝敬， 有了事想要靠她万不行。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "哎我好伤心也！"
        },
        {
          "character": "康氏",
          "type": "唱",
          "text": "常言说有女不绝门， 这也是勉强自宽心。 纵然间女儿能孝顺， 她焉能万里以外来寻亲？"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "哎我好羞好恸也！"
        },
        {
          "character": "周素秋",
          "type": "唱",
          "text": "说甚么男女平等又平权， 女与男到底不一班。 我说我抵个男儿汉， 他二老常为莫儿心痛酸。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "哎我这心里才难过的说不成了呀！"
        },
        {
          "character": "家童",
          "type": "唱",
          "text": "我今年已经二十八， 还莫有娶下娃他妈。 光光有个娃他爸， 娃他爸怎能一个生娃娃？"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "可怜我莫有男孩儿，只守着个女孩儿。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "可怜我只有女孩儿，再莫有个男孩儿。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "可怜我是个女孩儿，不是个男孩儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周素秋以袖自掩。"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "我若是个男孩儿，而今都娶下媳妇了，何用他二老作难哩？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童以袖自掩。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "可恨我是个男孩儿，不是个女孩儿。我再是个女孩儿，而今也有了女婿了。也 热热火火的过活去了，何至于要这个光棒吗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾文仲笑。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "我儿不啼哭了。必因我们父子啼哭，惹得他一家伤心。待为父劝解劝解。"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "哦，父亲劝解劝解。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "哈哈哈，周兄周嫂，不必伤心。你只有女孩儿，我却有男孩儿，莫有女孩儿。 我看来就将我这男孩儿，许配你那女孩儿，侪们两家，合成一家。我给儿过活， 你给女过活，都有了儿了，都有了女了。岂不是两全其美吗？"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "好呀！这儿能孝顺父亲，必能孝顺岳父！"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "是呀，这儿能孝顺母亲，必能孝顺岳母！"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "快和女儿商议！"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "快和女儿商议！"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "女儿而今就照你那主意，就给你招赘那个女婿，就教你承受这份家产，你的意 下如何？"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "唔，把人几乎碰死了，还给他一个媳妇，再给他一份家产，恐怕人见了姑娘都 往怀里碰去了！"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "你说走着碰着么？碰上了，还说嗄哩！"
        },
        {
          "character": "周素秋",
          "type": "白",
          "text": "太便宜了他了。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "这是天怜孝子，故意留下的便宜教占哩！世上作非孝论的，立仇父会的，万古 占不了这便宜。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "索性叫人家把便宜占了去吧！"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "这个便宜索性教这个孝子占了去呀！"
        },
        {
          "character": "周仁全",
          "type": "唱",
          "text": "老哥的话儿我应允，"
        },
        {
          "character": "康氏",
          "type": "唱",
          "text": "两家人成了一家人。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "儿呀，快快拜过你那岳父！"
        },
        {
          "character": "艾子诚",
          "type": "白",
          "text": "哎岳父呀！"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "从今后还要岳父常指教，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚叩头。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "儿快快拜过你那岳母！"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "还要岳母把心操。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚叩头。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "你把人家几乎碰死，也给人家叩头谢罪！"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "还要小姐同行孝，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚叩头。周素秋藏树后露半面。"
        },
        {
          "character": "康氏",
          "type": "白",
          "text": "你看羞死了，连回礼都不知道回礼。"
        },
        {
          "character": "艾文仲",
          "type": "白",
          "text": "再给你这哥哥也叩个头！"
        },
        {
          "character": "艾子诚",
          "type": "唱",
          "text": "还要大哥受唠叨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艾子诚叩头。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "这把我烧燎死呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童还礼。"
        },
        {
          "character": "周仁全",
          "type": "白",
          "text": "而今请到家中，安排酒宴，与亲家贺喜，与儿婿洗尘呀！"
        },
        {
          "character": "周仁全、康氏、艾文仲、艾子诚",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仁全、艾文仲、康氏同下。周素秋回头看见艾子诚微笑，下。艾子诚下。家童顿足。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "哎哎哎！我后悔到哪一日呀！早知道一碰便能成亲，老老早里都碰了，何至于 教人家碰下走了呀！"
        },
        {
          "character": "家童",
          "type": "唱",
          "text": "早知道一碰事能成， 老早里多多的碰一碰。 而今想碰还不得碰， 碰不上还怪我的命儿穷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家童下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}