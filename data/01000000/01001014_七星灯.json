{
  "script_id": "01001014",
  "title": "七星灯",
  "alias": [
    "孔明求寿"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "姜维",
      "hangdang": "末"
    },
    {
      "name": "司马懿",
      "hangdang": "净"
    }
  ],
  "plot": "三国，诸葛亮伐魏，至六出祁山，心血日耗，自知不久，以后事嘱托诸将。姜维谓用祈寿之法，挽回天命。\n诸葛亮乃设七星灯，终日步罡踏斗以禳之。司马懿仰观星象，知诸葛亮不久人世，又不敢深信，使夏侯霸领\n兵探之。不料魏延误认劫寨，匆匆奔至帐中报信，将本命灯踏灭。诸葛亮掷剑叹曰：生死有命，不可挽也。\n姜维欲斩魏延，诸葛亮止之，乃告以：司马懿非劫寨，但探我生死耳。后诸葛亮嘱后事，死于军中。司马懿\n闻诸葛亮死，蜀军撤退，遂起兵追赶。姜维等以诸葛亮之偶像推出，吓退司马懿，蜀军退回西川。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "安排脂粉计，耻笑司马懿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "忙将机密事，报与丞相知。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你回来了？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "小人回来了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "脂粉钗裙可曾送去？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "送去了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那司马懿见礼物便怎么样？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "我说：“丞相见你停兵不战，送你脂粉裙钗，穿在身上，往丞相处拜他几拜， 丞相就可收兵。”"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他说些什么？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "他说道：“取笑由他，各有用兵之计。”"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吓，这是司马懿说的！后来呢？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "小人还在他营中，饮过宴来。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "如此说来，他还款待你的？酒席筵前，说些什么？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "他问道丞相饮食如何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你是怎么回答的？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "小人说道：“丞相饮食减少。”"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唗！退下！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且住。指望送去脂粉钗裙，耻笑那司马懿，不想被旗牌将机关泄漏，这大事休 矣！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢板",
          "text": "仰面朝天自己嗟叹， 司马懿可算得将中魁元。 送脂粉和钗裙不恼可赞， 反与那旗牌官酒食来餐。 有刚有柔是好汉， 我诸葛要学他难上加难。 先帝爷下南阳君臣见面， 受深恩定扭转汉室江山。 博望坡烧曹兵初次交战， 借东风助周郎火烧战船。 用火攻烧藤甲南蛮丧胆， 谁不知诸葛亮计能扭天。 到如今遇司马两下会战， 葫芦谷设地雷定下机关。 我料他父子们定遭此难， 又谁知天不随也是枉然。 一霎时急得我遍体是汗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮吐。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢板",
          "text": "怕的是大数到性命难全。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同上。"
        },
        {
          "character": "众将",
          "type": "同二黄摇板",
          "text": "忽听帐内闹声喧， 忙到帐内看分明。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "丞相为何这等模样？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "列为将军有所不知，老夫昨夜仰观天象，见北斗昏暗，看来老夫性命休矣！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "丞相自幼精习奇门之法，何不在此高搭玄台，祝告上苍，保得阳寿，也未可知。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不知天意如何？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "哽。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏延听令。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "何令？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领一哨人马，巡营撩哨，以防司马，无令不许擅入！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "姜维听令。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你在中央戊已土，高搭玄台，上用七星黑旗一面，安明灯七盏，却是老夫本 命之灯，不可打熄；倘若打熄，大事难成。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "末将知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "三寸气在千般用，一旦无常万事休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二白龙套引司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "二黄导板",
          "text": "一霎时玉兔升星明朗见，"
        },
        {
          "character": "司马懿",
          "type": "二黄原板",
          "text": "又听得营棚内打罢初更。 叫三军掌银灯把高岗来进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿上山。"
        },
        {
          "character": "司马懿",
          "type": "二黄原板",
          "text": "虎目圆睁看分明： 观东方甲乙木，木旺生火， 观南方丙丁火，火能克金。 正西方亢金龙昂然坐定， 观北方壬癸水，水见壬庚。 在北斗口内仔细看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮星、魏延星拿黑旗自两边分上，诸葛亮星、魏延星碰头，自两边分下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "司马懿",
          "type": "二黄原板",
          "text": "见北斗主星黑暗不明。 那诸葛本是七星保命， 算就了五丈原必落此星。 叫三军把高岗下听我号令，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二白龙套同喝。"
        },
        {
          "character": "司马懿",
          "type": "二黄摇板",
          "text": "若见那灵官走定是孔明。 四更时分造战饭， 五更一打要交兵。 此一番一个个用力战胜， 回营中奏皇封都是功臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、二白龙套同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜维捧灯上，打扫玄台。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "有请师父！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢板",
          "text": "为国家把我的心血用尽， 都只为先帝爷托孤之恩。 执宝剑上玄台难以扎挣， 险些儿把老夫跌倒埃尘。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "上苍吓！亮在乱世，隐居隆中。蒙先帝三顾之恩，任幼主托孤之重。统众六出 祁山，讨贼不果。将星欲落，阳寿已终。虔诚祝告上苍：假我数年，扶持汉室， 上报先帝托孤之恩，下免万民一切之苦。神明在上，鉴我此心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮烧表三道。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "诸葛亮不敢扭天行， 为的是吾主锦乾坤。 拜北斗和南斗赐我阳寿， 执簿官掌笔庚留下人情。 中央戊已深深拜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮看。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "北斗星光渐渐明！ 纵然拜起主星台北斗， 不知生死若何论？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。魏延急上。"
        },
        {
          "character": "魏延",
          "type": "二黄摇板",
          "text": "司马懿父子来踹营， 报与丞相得知情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延熄灯。诸葛亮执剑上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "想是我大限有一定， 魏延打熄本命灯。 将宝剑插在尘埃地，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维上。"
        },
        {
          "character": "姜维",
          "type": "二黄摇板",
          "text": "丞相为何发雷霆？"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "我今拜灯整六天， 看看七日大功全。 恨魏延他把我本命灯扑暗， 我的性命就在顷刻间。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎吓，贼子吓！"
        },
        {
          "character": "姜维",
          "type": "二黄摇板",
          "text": "我师父拜斗六天整， 看看拜起本命星。 为何将灯来打熄？ 想是贼子起反心！ 手执宝剑将你砍，"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "你不能！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "将军息怒慢稍停。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏延你慌慌张张走进帐内，跑上玄台，可是司马命人前来骂阵么？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领本部人马，抵敌司马来将，无令休来见我。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "恨小非君子，无毒不丈夫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "姜维搀我下玄台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维搀诸葛亮同下玄台。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "姜维与我快些请， 后帐快请李大人。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "有请李大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李福上。"
        },
        {
          "character": "李福",
          "type": "二黄摇板",
          "text": "忽听丞相唤一声， 急忙进帐问分明。"
        },
        {
          "character": "李福",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "李福",
          "type": "白",
          "text": "唤我进帐，有何军情？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "李大人吓，我今病已沉重，不久于人世。有遗表一道，烦劳大人，去往成都， 转奏后主，意下如何？"
        },
        {
          "character": "李福",
          "type": "白",
          "text": "丞相差遣，愿去不辞。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "姜维看表过来。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "搀扶了。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "圣上吓！念臣鞠躬尽瘁，死而后已！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "对着西川深深拜， 拜谢后主爵禄恩。 羞愧难见刘先主， 李大人你速速转奏奔都城！"
        },
        {
          "character": "李福",
          "type": "二黄摇板",
          "text": "辞别丞相跨金镫， 不分昼夜奔都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李福下。"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "姜维！"
        },
        {
          "character": "姜维",
          "type": "叫头",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "姜伯约！"
        },
        {
          "character": "姜维",
          "type": "叫头",
          "text": "师父！"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "将军吓！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄快三眼",
          "text": "我和你虽是将帅，却有那师徒之义，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "必须要学师父扶保乾坤。 我命该活七十四， 祭东风损去十年春。 烧藤甲又损我十年寿， 到如今五十四岁命归阴。 我死后要依我三件要事， 一桩桩一件件牢记在心。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "这头一件？"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "第一件满营中休要举哀挂孝，"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "第二件？"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "第二件必须要缓缓移营。"
        },
        {
