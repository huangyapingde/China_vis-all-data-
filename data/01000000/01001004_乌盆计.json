{
  "script_id": "01001004",
  "title": "乌盆计",
  "alias": [
    "奇冤报；一名：定远县"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘世昌",
      "hangdang": "老生"
    },
    {
      "name": "张别古",
      "hangdang": "丑"
    },
    {
      "name": "赵大",
      "hangdang": "丑"
    },
    {
      "name": "包拯",
      "hangdang": "净"
    }
  ],
  "plot": "北宋，绸商刘世昌，投宿客店，店主赵大夫妇，窥其行囊沉重，顿起不良，设计将刘世昌药死，砍为肉酱，\n杂以泥土，团成乌盆。事隔数年，毫无破绽。适有张别古至赵大处讨草鞋钱，赵大坚不与钱。天网恢恢，卒\n以乌盆与之。张别古取盆回来，忽有鬼声自盆出，诉冤甚苦，张别古持盆至包拯处首告，包公准之，签提赵\n大，一鞠而服。",
  "notes": "剧中反二黄一段，鸣咽悲凉，最为动听。此剧普通只唱诉冤一段，惟谭贝勒必演全本。服毒一场，绕场跌扑，\n煞费力量。近贵俊卿亦演全本，纯仿谭派。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张别古上。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哽唬。"
        },
        {
          "character": "张别古",
          "type": "数板",
          "text": "年迈时衰，老来无子实难挨。妻丧早，命应该。只落得，奔忙劳碌打草鞋，打 草鞋。"
        },
        {
          "character": "张别古",
          "type": "念",
          "text": "人老曲腰把头低，树老焦梢叶儿稀。茄子老了一斗子，倭瓜越老越好吃。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "老汉张别古，打草鞋为生。这两天，生了一场毛病，没有出去做买卖。今日病 好了，一个钱没有。我想起城南赵大，欠我两双草鞋钱，不免前去要了来，也 好度日。就此走走。待我出了门，关上门，我再锁上门。门呢，门呢，你好好 看住我的门，不要叫羊吃了我的被窝。走了走了，再也不能小了，若是小了， 可是费了事了。 说话之间到呢，哎吓，这个房子，怎么翻盖呢？还是搬了家了？待我再来看看： “损德堂赵”，是他的堂名，待我来叫叫看。赵大，赵大……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "念",
          "text": "忽听叫赵大，胆战又如麻。纵然将事发，我有钱也不怕。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "是谁？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "赵大，赵大……"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "原来是老小子。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "吓，他哪里抢得来的钱，穿得这么好。 是我。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你做什么来的？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我找你有两句话讲。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "有话在这里讲么？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不在这里讲，在哪里讲？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这里风大，吹了我的舌头。在我会客厅里讲去。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有了钱，就有了会客厅了。我不认识，你头里走。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "跟我走进大门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古允。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "进二门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古允。"
        },
        {
          "character": "赵大",
          "type": "stage",
          "text": "中国京剧戏考 《乌盆计》【后本】 2"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "走穿廊，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古允。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "哦，过游廊，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古允。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "抬起脚来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小心黄鼠狼。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你们这里狼都不少。你还到的了到不了呢？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "就算到了罢。跟我进来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哦，这个地方都不错，好像一只戏台。吓，待我来坐一会。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "哎，走开，这个地方，你也好坐的么？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "坐坐也不要紧。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "木能生火，你可晓得烧了你的屁股。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你坐怎么不烧的？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我是福大量大。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我坐在哪里？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你坐在地下。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哦，我就坐在地下。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "有什么话说？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你前几天，拿了我两双草鞋，没给钱，今天你该给我了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "什么？我头上戴的什么？我身上穿的什么？脚底下蹬的什么？我会欠你的草鞋 钱？你胡说乱道！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎吓，发了财，他全忘呢。有了。 赵大爷你听错呢，不是你欠我的草鞋钱，是你的伙计，拿我两双草鞋，没给钱， 写在你帐上呢。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这句话对了。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有钱给了我。我好去。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "钱呢，我告诉你，都用铁丝穿起来了，为你还开串，不成。没有钱。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有银子没有？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "银子都浇了银山了。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有票子没有？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "票子有两张当票子。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "当票子我也无钱赎。我就是讨饭，你也给我一个讨饭的家伙。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你跟我到盆库里去。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "吓，盆亦有了库了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我大爷有钱。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你里头走。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "跟我来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你这两天都好，没生毛病。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你不要胡说。到了，你瞧，上中下三层。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你把上层的与我一个。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "上层是进卖的，你不能用。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "中层的与我一个罢。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "中层是公伯王侯使的，你不能用。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "下层的与我一个罢。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "下层的是来路客商使的，你不能用。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "那么着，我在大堆里挑一个罢。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这倒可以使得，我替你捡一个。我告诉你这个盆，一窑烧的，这一个，它还有 个名字。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "它叫什么名字？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "它叫个乌盆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌上。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "这个名字倒不错。 中国京剧戏考 《乌盆计》【后本】 3"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你去吧。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你们这里廊太多，我弄不清楚。你把我带出去。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "好，你跟我出来。好呢，算到呢。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "吓，我去了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你回来，你回来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "回来干什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你到了外头，有那小姑娘、小小厮，买两个来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "要小姑娘、小小厮，做什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小姑娘服侍你大奶奶。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "小小厮呢？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "服侍我大爷。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哦。有了两个钱，真会出花头。有呢，待我来拿他开开心。 大爷小姑娘都没有，有一个小小子。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小小子在哪里？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你远看。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "近看。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "就是你吓？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "咳，不错。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "呸，我没有钱与你买棺材。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我作你们家里活祖宗吓。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你滚出去吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大关门，下。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "吓，老天哪，老天！我想赵大与我一样之人，为何他就会发起财了？嗳： 莫道东风常向北，北风也有向南时。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "张别古！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "吓，哪里有人叫我？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "哎，老丈！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎呀，不好，盆说的话呢！"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "老丈不必胆怕惊， 我有言来你是听。 休把我当作妖魔论， 我本是屈死一亡魂。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "嗳。"
        },
        {
          "character": "张别古",
          "type": "二黄原板",
          "text": "他那里叫一声张别古， 倒叫我年迈人糊里糊涂。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎呀，且住。常言说得好：少年见鬼，还有三年；老来见鬼，就在眼前。不好， 拿起盆来走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌挡张别古。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我打这边走，我打那边走。不好，鬼打墙。"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "忙将树枝摇摆定，"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎吓，好大的风吓！"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "对准了老丈撮灰尘。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎吓，好大的砂土！"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "我和你素无冤旧又无恨， 望求老丈把冤伸。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不好，弄的我鼻子里，嘴里，耳朵里，眼睛里，都是些黄土泥。拿起来走吓。"
        },
        {
          "character": "张别古",
          "type": "二黄摇板",
          "text": "急急忙忙往前进， 不觉来到城隍庙门。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "吓，说话之间，到了城隍庙呢。我听人说，城隍老爷顶灵的，待我进去许个愿， 叫这鬼不跟我才好。就是这个主意，就此走走。"
        },
        {
          "character": "张别古",
          "type": "数板",
          "text": "我一进庙来，恭身下拜。尊一声城隍老爷细听明白：只因赵大该我的钱财，我 去要债。他没有钱，给了我一个盆，折了债。这个盆，它是个妖怪。半路途中， 中国京剧戏考 《乌盆计》【后本】 4 说起话来。望神圣与我遮盖，明日里猪头三牲、豆腐白菜，我一齐买来，我 一齐买来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "好好，愿也许呢，待我来叫叫看。 乌盆。 城隍老爷真灵了。鬼也不跟我，待我回去放好。我连吃饭都没钱，哪里有钱还 原？不好，城隍老爷闹起来，比鬼还凶。待我退掉他吧。"
        },
        {
          "character": "张别古",
          "type": "数板",
          "text": "二次进庙，恭身下拜。尊一声城隍老爷细听明白：只因赵大不该我钱财，我也 没去要债。这个盆，它不是妖怪。半路途中，没有说出话来。望神圣不要与我 遮盖，明日里猪头三牲、豆腐白菜，不能买来，不能买来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "城隍老爷，我方才说的话吓，算拉倒呢。好好，愿也退掉呢，待我来叫叫看。 乌盆。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不好，又来呢。拿起来走吓。"
        },
        {
          "character": "张别古",
          "type": "二黄摇板",
          "text": "急急走来急急行， 不觉来到自己门。"
        },
        {
          "character": "张别古",
          "type": "白",
