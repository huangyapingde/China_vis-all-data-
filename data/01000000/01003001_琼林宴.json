        {
          "character": null,
          "type": "stage",
          "text": "土地下，樵夫上。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "缺少扁担，待我用拐杖变来。"
        },
        {
          "character": "樵夫",
          "type": "念",
          "text": "一变二变，扁担出现。"
