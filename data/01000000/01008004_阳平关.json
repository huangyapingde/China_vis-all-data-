          "character": null,
          "type": "stage",
          "text": "黄忠、张著同下。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "但看曹兵鼠窜逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云勒枪立。曹操、曹洪、许褚、四龙套同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "前队因何不行？"
        },
        {
          "character": "曹洪、许褚",
          "type": "同白",
          "text": "启主公：远远望去，只见蜀营大开，旗鼓全无，只有赵云一人，单枪匹马，立 于营外，日已黄昏，我兵还是杀进，还是退去，请令定夺。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操望。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此就是赵云有计，快些退兵，快些退兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云摆枪。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "放箭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同放箭，曹操、曹洪、许褚、四龙套同下。黄忠上，看望，大笑。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "曹兵去了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "追赶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封、四龙套同上。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "二位，刘封在此。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "小将军为何而来？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "军师命我来此，虚张声势，且喜曹操弃粮而逃，二位同我搬他粮草，检他军器， 好去报功。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "有理。 老将军，"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "可笑那老曹瞒他是伤弓鸟，"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "将军，"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "他见我不怕他怎不胆落魂销。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "赵云、黄忠",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
