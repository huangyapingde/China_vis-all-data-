{
  "script_id": "01009011",
  "title": "雁门关",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "呼延必显",
      "hangdang": "小生"
    },
    {
      "name": "潘洪",
      "hangdang": "净"
    }
  ],
  "plot": "北宋《杨家将说传》（即《金枪传》）载：潘洪专权卖国，在朝倚仗国丈之尊，专与忠良作对。杨继业父子\n八人，为当时柱石良将。潘洪因杨七郎在擂台与其子潘豹比武，将潘豹打死，于是结下深仇。阴嗾贺朝进朋\n比为奸，多方设计陷害。暗与萧邦通款，密召萧番寇边南犯。己在金殿甘言哄帝，乞得招讨之职，故意辟荐\n杨氏父子为先锋，直隶己麾下，盖即暗执陷害杨氏父子之权于掌中也。既出师，故令杨继业父子，以寡师出\n敌众寇。任其受困两狼，卒至粮尽援绝而殁。杨氏一门，除六郎、延德外，死者死，亡者亡，丧害殆尽，皆\n潘一人之力也！后为六郎晋京，在真宗前哭告御状，真宗大怒，乃命呼必显，赍旨往雁门关拿解来京。此剧\n即呼必显先用计借阅兵事，赚得帅印在手，并遣去其爪牙贺某，然后开旨擒潘洪，霎时打入囚车。盖取迅雷\n不及掩耳之法，以出其不意，非如是则恐其拔扈不测，事正有所难料也。",
  "notes": "此剧小生于赚印点卯、开旨擒潘等时，神色须敏捷变化，忽柔忽刚，不可失诸呆板，方为合作。后本即《调\n寇审潘》之《清官册》也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四大铠、四将、押旨官、呼延必显同上。"
        },
        {
          "character": "呼延必显",
          "type": "念",
          "text": "金殿领圣命，捉拿叛逆臣。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "本爵扫殿侯呼必显。今奉圣命，去到雁门关捉拿老贼潘洪。 众将官，雁门关去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套引潘洪同上。"
        },
        {
          "character": "潘洪",
          "type": "引子",
          "text": "奉王命威镇边关，那胡儿胆战心寒。"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "战鼓鸣锣响仓仓，继业父子困两狼。可叹我儿死得苦，七郎芭蕉乱箭亡。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "老夫，太尉潘。宋室为臣，官拜天下都招讨兵马大元帅。所生二子，长子潘强， 次子潘豹。只因那日我儿潘豹，在天齐庙摆下百日擂台，打了九十七擂，不 料继业老儿，纵子行凶。上得擂台，将我儿潘豹打死。那时节老夫闻听此言， 与那杨继业抓袍夺带，上殿面圣。好个有道圣上，不见罪我等，反与我二家解 和。那时节老夫修下书信，叫那北国胡儿，前来夺取宋室天下。是老夫在金殿 讨下帅印，单点杨继业父子，与为前站先行，那老儿连退数本不去。内有八主 千岁，与他杨家作保，统领大兵。来在这雁门关下，黄道日不叫他父子出马， 黑道日叫他父子出兵，他父子又偏偏得胜而回。那时节老夫传下将令，命他父 子，将胡儿人马斩尽杀绝，方许进关。我想那胡儿人马，犹如潮水一般，一时 焉能斩尽杀绝。他父子情急无奈，杀一阵败一阵，败至两狼山下，内无粮草， 外无救兵。命他七子，前来搬兵。那时老夫想起打子仇恨，命贺朝进将那七郎 诓下马来，用酒劝醉，绑在芭蕉树上，传齐弓箭手，这哗啦啦，射了他一百单 三箭而亡，到如今只剩杨六一人，这、这、这小畜生，他往哪里去了！看帅字 旗无风自动，必有军情。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "龙虎台前出入，貔貅帐内传唤。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启太师：圣旨下。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "何人押旨前来？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "扫殿侯呼必显。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "呼必显这娃娃，他也出京了。吩咐摆队相迎。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同摆队，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四大铠、四将、押旨官、呼延必显同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四红龙套、中军、潘洪同上，四白龙套、四大铠、四将、押旨官、呼延必显同上，众人同下。四红龙套、"
        },
        {
          "character": null,
          "type": "text",
          "text": "中军、潘洪同上，呼延必显捧旨上，潘洪拜旨。）"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "太师请上，待小官大礼参拜。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "你一路而来，多受风霜之苦，不拜也罢。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "哪有不拜之理。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "从命了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延必显拜。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "来，与钦差看座。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "且慢，太师在此，哪有小官的座位。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "有话叙谈，哪有不坐之理。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "请问钦差，我主驾安？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "我主安泰。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "满朝文武可好？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "满朝文武，俱有手本问候太师金安。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "有劳他们挂念。请问钦差，还是金殿接旨，还是在午门接的圣旨？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "金殿接旨。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "既是金殿接旨，为何不开读？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "内封外发，不敢开读。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "如此同拆同读。 中军，香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军允。潘洪拜旨，拆开。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "头一道圣旨：“发饷银十万，犒赏三军。” 钦差，我主乃是有道明君。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "本来是有道明君。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "愿吾皇万岁万万岁！ 第二道圣旨：“追回上方宝剑。” 啊？想这上方宝剑，乃是军中命脉，焉能追回？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "无非是弃旧而换新。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "中军，命贺朝敬带领四十名长枪手，护送宝剑进京。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "下面听者，太师有令：命贺朝敬带领四十名长枪手，护送宝剑进京。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套押剑同下。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "三道圣旨：“后宫娘娘，有密旨前来，问候老太师金安。” 啊，钦差，自盘古以来，只有臣问君安，哪有反礼而行？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "想太师与娘娘乃骨肉之情，理当一问。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "愿娘娘千岁千千岁！"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "请问太师，小官一路而来，观见五里一墩，十里一铺，还是我国要路，还是他 国辖地？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "乃是吾国的要路。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "既是我国要路，倘若胡儿兴兵前来，一时焉能得到？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "老夫有白牌前去，呼唤即到。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "如此借老太师虎威一观。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "只是不足钦差美观。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "中军，白牌进见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "白牌进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "忽听传白牌，急忙到帐来。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见太师。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "罢了。这有白牌，命你调齐四路总兵，辕门听点。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "白牌出辕门，"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "调齐四路兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "后帐摆宴，与钦差接风。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "到此就要叨扰。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "钦差请。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "太师请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（旗牌上，安定邦、黄信、四下手、周虎、黄龙自两边分上，分上马，同下。旗牌、安定邦、黄信、周虎、"
        },
        {
          "character": null,
          "type": "text",
          "text": "黄龙同上。）"
        },
        {
          "character": "安定邦、黄信、周虎、黄龙",
          "type": "同白",
          "text": "提调我等有何军情？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "辕门听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安定邦、黄信、周虎、旗牌同下。"
        },
        {
          "character": "黄龙",
          "type": "白",
          "text": "啊！为何马失前蹄？"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "乃是骡马。"
        },
        {
          "character": "黄龙",
          "type": "白",
          "text": "骡马焉能上得阵，回营换马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄龙、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、中军、潘洪同上，旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "众将辕门伺候。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "传他等进帐。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "众将进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。安定邦、黄信、周虎同上。"
        },
        {
          "character": "安定邦、黄信、周虎",
          "type": "同白",
          "text": "参见太师。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "安定邦、黄信、周虎",
          "type": "同白",
          "text": "提调我等有何军情？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "圣上发饷银十万，犒赏你等，望空一拜。"
        },
        {
          "character": "安定邦、黄信、周虎",
          "type": "同白",
          "text": "我主乃有道明君，愿吾皇万岁万万岁！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "可曾到齐？"
        },
        {
          "character": "安定邦、黄信、周虎",
          "type": "同白",
          "text": "俱已到齐。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "中军吩咐起鼓听点。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "鼓棚，起鼓听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。潘洪点卯。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "前营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同允。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "后营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同允。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "左营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同允。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "右营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同允。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "大将听点。安定邦。"
        },
        {
          "character": "安定邦",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "周虎。"
        },
        {
          "character": "周虎",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "黄信。"
        },
        {
          "character": "黄信",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "黄龙。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "未到。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "啊？老夫初点大卯，黄龙不到，其情可恼！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "启禀元帅：天气炎热，营盘调远，挨挤不上，望元帅宽限二卯。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "吩咐起鼓，连点二卯。"
        },
