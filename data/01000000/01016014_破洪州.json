{
  "script_id": "01016014",
  "title": "破洪州",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "穆桂英",
      "hangdang": "旦"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "萧天佐",
      "hangdang": "净"
    },
    {
      "name": "杨延昭",
      "hangdang": "老生"
    }
  ],
  "plot": "宋、辽失和，会兵于九龙谷，聚集杨家将，大破其天门阵。法术之广，功劳之多，推穆桂英为最。穆桂英系\n杨延昭之媳，杨宗保之妻。其时辽将萧天佐，围困洪州，真宗封穆桂英为元帅，杨延昭即日交代印信，派杨\n宗保为先行官。升座点名，杨宗保三次失卯，而与萧天佐第一阵交锋，又属败仗。穆桂英深恐军法不严，不\n能服众，意欲斩之以徇。杨延昭得报，惊惶无措，赶紧送书求赦。穆桂英重以乃翁之情面，只得应允，命小\n校重责四十军棍，以折其桀骜之气。口虽传令，而心实痛焉，不敢以夫妻之私恩，而废国家之公法也。穆桂\n英亲自出战，刺死萧天佐，遂解洪州之围。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、仙童、湘女、穆桂英同上。〖点绛唇〗。"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "今奉师命下山林，胸怀妙计破天门。统领貔貅为元帅，扶保宋世锦乾坤。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "本帅，穆桂英。今奉仙师之命，带定法宝，大破天门。特奉圣恩，挂我为帅。 左右，兵马可曾齐备？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "左仙童，将卯簿呈上，吩咐击鼓听点。"
        },
        {
          "character": "仙童",
          "type": "白",
          "text": "吩咐击鼓。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "前营。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "后营。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "左营。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "右营。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "左仙童。"
        },
        {
          "character": "仙童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "右湘女。"
        },
        {
          "character": "湘女",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "先行。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "先行未到。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "本帅初次点卯，先行竟自不到。本帅再点二卯。"
        },
        {
          "character": "仙童",
          "type": "白",
          "text": "击鼓。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "前后营。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "左右营。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "左仙童。"
        },
        {
          "character": "仙童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "右湘女。"
        },
        {
          "character": "湘女",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "先行。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "先行未到。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "吓。本帅连点二卯，先行仍敢不到。再点三卯。"
        },
        {
          "character": "仙童",
          "type": "白",
          "text": "击鼓。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "前后左右营。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "左仙童。"
        },
        {
          "character": "仙童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "右湘女。"
        },
        {
          "character": "湘女",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "先行先行。"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "先行不到。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "本帅连点三卯，先行不到，将误卯牌挂起。先行到来，叫他报门而进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "离了天波府，来此是宋营。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "吓！误卯牌高挂，待我报门而进。 报：先行告进。参见元帅。"
        },
        {
          "character": "仙童",
          "type": "白",
          "text": "先行到。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "下面跪的敢是先行？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "末将不敢。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "为何不抬起头来？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆桂英看。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "吓！下面说话的，好像我们那一口子他呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保转面。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "上面说话的，好像我们那一口子她呀。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "转堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、仙童、湘女同下。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "闹了半天，我当是谁，原来是你呀。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "闹了半天，敢情是你呀。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "既然是你，可就好打交道了。 升堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、仙童、湘女同上。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "我说先行。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "我说自古以来，还是元帅伺候先行，还是先行伺候元帅？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "自然是先行伺候元帅。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "既然是先行伺候元帅，本帅连点三卯不到，是何道理？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保跪。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "末将在天波杨府，辞别太君，披挂来迟。望祈元帅恕罪。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "我且问你，既为先行，可知做先行的道理？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "末将既为先行，是怎生不晓？"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "先行先行——"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "步步先行。"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "逢山开路——"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "遇水叠桥。"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "逢山开路三千里——"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "遇水叠桥八百州。"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "一颗先锋印——"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "本是无价宝。"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "今日颁给你——"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "要把狼烟扫！"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "与你一支令——"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "上马报军校！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保下。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "众将官，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。四龙套、四上手、仙童、湘女同下。穆桂英趟马，下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、杨宗保同上。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "元帅有令：命洪州城，准备大小船只四十号，渡口听用，不得有误！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同允。杨宗保、四上手同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四番将、萧天佐同上。〖点绛唇〗。"
        },
        {
          "character": "萧天佐",
          "type": "念",
          "text": "生在番邦力无穷，能征惯战震辽东。辽邦大将某出众。要夺宋室锦江红。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "俺，辽邦大将萧天佐。奉了太后将令，带领人马，夺取宋室天下。是俺在九龙 峪口，摆下天门大阵。宋兵不敢前来。前面已是洪州。 巴鲁儿，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。四下手、四番将、萧天佐同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖大吹打〗。四龙套、四上手、杨宗保、仙童、湘女、穆桂英同上。穆桂英下马，四龙套、四上手、杨宗"
        },
        {
          "character": null,
          "type": "text",
          "text": "保、仙童、湘女、穆桂英同上船，同大转场，同下船。穆桂英上马。）"
        },
        {
          "character": "杨延昭",
          "type": "内西皮导板",
          "text": "人马纷纷如潮涌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌、杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "洪州城又来了十家总兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭转场。穆桂英坐帐。杨延昭坐。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唤宗保。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "既是你妻挂帅，为何不来通报？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "这……孩儿通报不及，望爹爹恕罪。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "传先行。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "既父帅交印，为何不来禀报？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "末将禀报不及。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "传宗保。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你去问你妻子：还是先行国法，还是先论家法？"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "传先行。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "父帅怎样传令下来？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "父帅问道：还是先论国法，还是先论家法？"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "军务为重，自然是先论国法，就请父帅交印便了。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唤宗保。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你妻怎样言讲？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "我妻言道：军务重大，自然要先论国法，就请父帅交印罢。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看遮面旗伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。杨延昭拜印。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唤宗保。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你对你妻子言讲：洪州城十家总兵，为父也在其内。看是哪家该在此伺候，哪 家不该在此伺候？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "父帅言道：洪州城十家总兵，父帅也在其内，看是哪家该在此伺候，哪家不该 在此伺候。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "论其正理，十家总兵，俱该在此伺候。念在父帅年迈，免了罢。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唤宗保。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你妻怎样言讲？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "她言道：论其大理，十家总兵，俱该在此伺候。念在父帅年迈，免了罢。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "奉王旨意统貔貅，南征北战十数秋。今日交卸皇家印，直落得儿媳面前免伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。探子上。"
        },
        {
          "character": "探子",
