        {
          "character": null,
          "type": "stage",
          "text": "吕禄、吕产同上。"
        },
        {
          "character": "吕禄、吕产",
          "type": "同白",
          "text": "臣等见驾，愿太后千岁！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "吕禄、吕产",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "吕后",
          "type": "念",
          "text": "鸣凤丹阳百鸟惊，山河一统享太平。可知威武不知怯，还归女娲治乾坤。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "孤乃高皇帝正宫吕后是也。汉皇晏驾，惠帝无嗣，故而哀家垂帘听政，以安社 稷。幸而群臣拱服，诸侯畏惧，正是："
        },
        {
          "character": "吕后",
          "type": "念",
          "text": "女娲补天手，权作没朝人。"
        },
        {
          "character": "吕禄",
          "type": "白",
          "text": "臣启千岁：方今诸侯逞强，国政衰弱，吕氏宗族，俱是贫寒，伏乞太后，大封 吕氏宗族为王，以壮宗谱，而固根本，愿太后察之。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "正合我意，归班候旨。"
        },
        {
          "character": "吕禄",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "内侍，看文房四宝伺候。"
        },
