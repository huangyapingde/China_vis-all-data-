          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "旨意一道，命二卿即往大封同姓宗族，明日齐赴未央宫饮宴。"
        },
        {
          "character": "吕禄、吕产",
          "type": "同白",
          "text": "领旨。请驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人自两边分下。"
        }
