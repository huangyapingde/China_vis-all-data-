        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈宫上。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "今日里在城头开口相闹， 骂得那曹孟德羞愧难熬。 吕温侯领雄兵出城征讨， 但愿得来取胜共杀奸曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众小军、张辽、高顺、吕布同上。〖水底鱼〗。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "参见温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "先生请坐。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "告坐。温侯今日出阵胜负如何？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "不分胜败。吾看众曹将不足介意，必须赚取曹操，方为莫大之功。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "陈宫有计献上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "计将安出？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "濮阳城中有一富豪田氏，叫他往曹营诈降，说温侯残暴不仁，民必大怨，今日 温侯在两军阵前，观见你军，心惊胆怕，连夜同陈宫众将往黎阳去了。城内无 人，只有高顺一人，兵丁无几，曹操必然相信。若是进兵入城，参谋自有妙计 擒之。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "如此就烦先生唤来。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "领命。"
        },
        {
          "character": "陈宫",
          "type": "念",
          "text": "计就擒玉兔，谋成捉金乌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "且住。久闻典韦之勇，今日一见，名不虚传。"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "久闻说双戟将典韦名号， 今日里在战场果称英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫上，二田氏同上。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "这里来。"
        },
        {
          "character": "二田氏",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "安排下擒猛虎牢笼计巧， 赚取那曹孟德来入火巢。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "田氏唤到。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "唤他进来。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "过来，见过温侯。"
        },
        {
          "character": "二田氏",
          "type": "同白",
          "text": "是。 温侯在上，小人叩头。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "二田氏",
          "type": "同白",
          "text": "呼唤小人，有何吩咐？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "只因曹兵十分猖獗，城池旦夕必破。命你等诈降曹操，赚他入城，吾自有计擒 之。你等可愿去否？"
        },
        {
          "character": "二田氏",
          "type": "同白",
          "text": "一城百姓皆得全生，我等赴汤蹈火也是情愿。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "好。听我道来。"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "你就说吕温侯不行正道， 每日里与众将大醉豪醄。 幸喜得与陈宫黎阳去了， 擒高顺夺濮阳就在今朝。"
        },
        {
          "character": "二田氏",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "田氏甲",
          "type": "西皮摇板",
