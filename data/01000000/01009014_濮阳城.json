  "title": "濮阳城",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "陈宫",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "吕布",
      "hangdang": "小生"
    },
    {
      "name": "田氏甲",
      "hangdang": "末"
    },
    {
      "name": "田氏乙",
      "hangdang": "丑"
    }
  ],
  "plot": "陈宫自捉曹放曹一役离曹操潜逃之后，安顿老母妻子讫，旋即投布共事。至是，吕布弃兖州据濮阳，曹操以\n全力进逼，吕布虽勇，然欲大挫操兵，亦殊非易事。幸得陈宫谋，遣濮阳富民田氏，授之计，令往曹营伪报\n密信言吕布在濮如何残酷暴民，民皆怨怒，今幸与陈宫潜往黎阳，城中空虚，小民等愿引大军入袭取，以出\n水火等语。遂赚得曹操坠其计，因有此胜。然陈宫具此谋略，不能择木而栖，徒兴吕布共事，卒为吕布累，\n身操擒，与吕布同殒于白门之役，鸣呼惜哉！",
  "notes": "大错每见村夫子，手持竹根旱烟管，鼻架黄铜老花眼镜，与村中牧童田仓团集一处，曲膝围坐，口角津津然\n涎沫四飞，以高谈《三国志》时，必历举曹操败史，而连类以出之曰，潼关过马超、赤壁遇周郎、宛城遇张\n绣、濮阳遇吕布。语时，且必轩轩然眉举目张，若犹代马超、吕布辈贾其余勇，而甚幸曹操屡屡遭此败者，\n是可知火烧濮阳之役，因亦《三国志》中，一至有名之战阵，而人人皆知，毋待详考者也。唯人第知为曹操\n受创于吕布，不知实陈宫之谋也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "典韦、李典、乐进、夏侯惇、夏侯渊同上。〖点绛唇〗。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "典韦。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "李典。"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "乐进。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "夏侯惇。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "李典、乐进、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "主公升帐，两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四文堂、四大铠引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "队伍雄威气轩昂，统领三军夺濮阳。"
        },
        {
          "character": "典韦、李典、乐进、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "堂堂将才是英雄，赫赫威名镇帝都。森森剑戟如霜雪，个个儿郎胆气粗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操，汉室为臣，职受平西大将军。可恨陶谦，接连贼寇杀我全家。此仇 不共戴天。因此领兵扫荡徐州。杀的他亡魂丧胆。眼见城池旦夕必破，不道吕 布小儿占夺濮阳等处，勇不可挡。故则与刘备假顺人情，暂为允和。老夫统领 大兵复夺濮阳。 众位将军！"
        },
        {
          "character": "典韦、李典、乐进、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "典韦、李典、乐进、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "兵发濮阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "典韦、李典、乐进、夏侯惇、夏侯渊同允。〖泣颜回〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈宫上。"
        },
        {
          "character": "陈宫",
          "type": "引子",
          "text": "智谋胸藏，按韬略怀扬志量。"
        },
        {
          "character": "陈宫",
          "type": "念",
          "text": "干戈纷纷绕，四海乱离迁。龙争虎斗日，谁胜第为先。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "下官姓陈名宫字公台，向为中牟县令。只因董卓弄权，故此弃官挂印与曹操逃 走同谋举义。谁知他心怀奸诈，行事不端，我又弃他回归故里，安顿老母妻子。 复投温侯帐下，以为参谋效用。前番施下一计，占取瓦城等处，今闻曹操前 来夺濮阳，今番一战，不知谁胜谁输，事难定准也。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "陈公台坐宝帐自叹自恨， 想起了从前事好不心焦。 只因那董卓贼横行霸道， 挟天子欺诸侯害民奸豪。 曹孟德行刺他机谋泄了， 四下里画图形捉拿奸曹。 行至在中牟县被我拿到， 在二堂苦哀告求情恕饶。 我见他有忠心把国来保， 因此上弃县印与他奔逃。 好一个吕伯奢恩情厚道， 谁知他起疑心全家不饶。 旅居中我有心将他杀了， 又恐怕人笑我无义儿曹。 因此上投温侯兴兵征讨， 我有意除奸佞扶保汉朝。 但愿得此一战把曹退了， 那时节整雄兵共灭奸曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "忙将军中事，报与智谋人。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启参谋：今有曹操请爷城楼会话。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "曹操请我城楼会话，无非顺说于我。待我用一篇言语打动于他，若他退兵而走， 我再计夺东城一带地方。正是："
        },
        {
          "character": "陈宫",
          "type": "念",
          "text": "全凭三寸舌，打退曹瞒兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、典韦、李典、乐进、夏侯惇、夏侯渊、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "领雄兵好一似泰山压倒， 剪除了吕奉先吾心安劳。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫领兵夺取濮阳，闻听陈宫现在吕布帐下，以为参谋。此人足智多谋，韬略 最广，向有故交之情。为此差人前去知会与他，约他在城楼会话顺说于他，若 得弃吕归曹，这濮阳唾手可得。就此催动人马。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "我爱那陈公台机谋甚好， 可惜他保吕布叛逆儿曹。 守城将你快把信来通报， 你就说曹孟德来会故交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上城。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有请参谋。"
        },
        {
          "character": "陈宫",
          "type": "内西皮导板",
          "text": "又听得濮阳城人嘶马闹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫上。"
        },
        {
          "character": "陈宫",
          "type": "西皮慢板",
          "text": "坐城头扶垛口往下观瞧。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "仁兄久别了。"
        },
        {
          "character": "陈宫",
          "type": "西皮慢板",
          "text": "白龙骑坐的是奸贼曹操，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公台你出此言有失故旧之情。言重言重。"
        },
        {
          "character": "陈宫",
          "type": "西皮慢板",
          "text": "一派的假殷勤袖里藏刀。 今日里领人马何事来到？ 说明了我和你再把兵交。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公台呀！"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "你本是大义汉凌云志浩， 又何必出恶言辱骂本曹。 往日里蒙你的恩义甚好， 到如今重相逢喜上眉梢。 我曹操纵言些行事不道， 陈公台量宽宏休放心梢。 我爱你智谋广神机奥妙， 为什么助反贼名姓水漂。"
        },
        {
          "character": "陈宫",
          "type": "西皮二六板",
          "text": "曹孟德休得要花言语巧， 我心中似明月照你心梢。 行刺那董卓贼机关泄了， 四下里画图形捉拿奸曹。 逃至在中牟县被吏拿到， 在二堂苦哀告求我恕饶。 我看你有忠心把国来保， 因此上弃县令同你奔逃。 吕伯奢他待你情高义好， 谁叫你杀全家寸草不饶。 在旅店我本当将你杀了， 普天下他道我无义儿曹。 你若是念故交把兵来退， 我和你守疆界不犯边壕。 你若是不退兵各摆战道， 霎时间管叫你片甲难逃。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "陈公台说此话令人可恼， 讲什么守边界不犯边壕。 我曹操不过是替天行道， 奉皇命扫狼烟同扶汉朝。 吕奉先他本是豺狼虎豹， 你枉把忠义名会与儿曹。 倘若是擒吕布城池献了， 回朝去管叫你玉带紫袍。"
        },
        {
          "character": "陈宫",
          "type": "西皮快板",
          "text": "汉献帝好一似婴儿怀抱， 曹孟德比王莽不差分毫。 除董卓霸朝纲又有曹操， 你将鹿指为马秦邦赵高。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "骂一声陈公台说话蹊跷， 濮阳城弹丸地何在心梢。 叫三军齐努力把城困好， 指日间濮阳城化为海潮。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "好言语好奸贼将我欺藐， 他把我陈公台不放心梢。 叫三军把擂石往下倾倒， 咫尺间管叫你尸不回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "叫众将勒转马忙回营道， 夺不转濮阳城誓不回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、典韦、李典、乐进、夏侯惇、夏侯渊、四文堂、四大铠同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张辽上，起霸。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "张弓双箭射虎豹，胸出奇才按六韬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高顺上，起霸。"
        },
        {
          "character": "高顺",
          "type": "念",
          "text": "旌旗闪闪光日月，队伍纷纷列枪刀。"
        },
        {
          "character": "张辽、高顺",
          "type": "同白",
          "text": "俺，"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "张辽。"
        },
        {
          "character": "高顺",
          "type": "白",
          "text": "高顺。"
        },
        {
          "character": "张辽、高顺",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "温侯升帐，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人、旗牌引吕布同上。〖点绛唇〗。"
        },
        {
          "character": "张辽、高顺",
          "type": "同白",
          "text": "参见温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "张辽、高顺",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "吕布",
          "type": "念",
          "text": "虎牢关前战诸侯，名扬四海贯九州。画戟赤兔谁敢斗，何惧曹操统貔貅。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "某，姓吕名布字奉先。自灭董卓之后随处飘游。幸得陈宫言无不准，攻无不取。 因此得了濮阳一带等处，以作久远之计。且喜兖州已取，只有东阿甄城等处 未能克下。今联曹操领兵前来复夺濮阳，为此整顿戈矛意欲交锋，曾命探子打 听，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "曹兵讨战。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "曹兵来得骁勇，众将官，想那曹操远来必然倦乏，趁此机会杀他个措手不及。 抖擞精神奋勇当先。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众小军、李典、典韦、夏侯惇、夏侯渊同上。〖急急风〗。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "李典。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "典韦。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "夏侯惇。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "众位请了，奉主公将令，攻打吕布。来！杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布、众人同上。会阵。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "吕。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "吕什么？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "吕布，来将通名。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "典。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "典什么？"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "典韦。呔！吕布儿啊！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "黄脸贼！"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "今日天兵到此，还不下马归顺。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "你就是蛟龙，能起多大风浪？"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "小螳螂焉能攻动俺的车轮？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "你是怎讲？"
