        {
          "character": "典韦",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "且住。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "敢是怯战？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "非是俺怯战，今日天色已晚，两下收兵，明日再战。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "谁家先收兵？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "两下一齐收兵。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "来者君子，"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "不来小人。"
        },
        {
          "character": "典韦、吕布",
          "type": "同白",
          "text": "收兵！"
