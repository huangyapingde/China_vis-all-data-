        {
          "character": "典韦",
          "type": "白",
          "text": "焉能攻动俺的车轮！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "名将会过多少！何惧小小儿曹。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "何惧小小儿曹。"
        },
        {
          "character": "吕布",
          "type": "念",
          "text": "画杆龙蛇动，"
        },
        {
          "character": "典韦",
          "type": "念",
          "text": "双戟称英豪。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "典韦",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "摇旗呐喊马嘶吼， 杀气腾腾冲牛斗。 虎牢关前威风抖， 谁人不知吕温侯。"
        },
        {
          "character": "典韦",
          "type": "西皮摇板",
          "text": "双戟典韦谁不畏， 交锋打仗鬼神愁。 劝儿早早来束手， 免得钢刀杀儿头。"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "劝儿不必夸海口，"
        },
        {
          "character": "典韦",
          "type": "西皮摇板",
          "text": "倾刻尸横血水流。"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "三军紧紧擂战鼓，"
        },
        {
          "character": "典韦",
          "type": "西皮摇板",
          "text": "天惨地昏雾云愁。"
