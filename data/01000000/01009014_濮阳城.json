        {
          "character": "曹操",
          "type": "白",
          "text": "喜得陈宫不在此城，天助我成功也！吩咐众将披挂整齐，黄昏之时随我入城。 休得声张，掩营而进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
