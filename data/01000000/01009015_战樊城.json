{
  "script_id": "01009015",
  "title": "战樊城",
  "alias": [
    "杀府逃国"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "伍尚",
      "hangdang": "老生"
    },
    {
      "name": "费无极",
      "hangdang": "净"
    },
    {
      "name": "伍奢",
      "hangdang": "外"
    },
    {
      "name": "武城黑",
      "hangdang": "武净"
    },
    {
      "name": "敖绛士",
      "hangdang": "丑"
    }
  ],
  "plot": "战国时，楚相国伍奢，为太子建传。因直谏楚平王，被佞臣费无极进谗陷害。楚平王怒，下之狱，将杀之。\n费无极以伍奢有二子伍尚、伍员，在樊城镇守。伍员且有举鼎力，虑不除终必复仇，为后患。因思一网尽之。\n逼令伍奢在狱中修书，招其二子至。二子在樊城得书，伍尚则欲往，伍员则力阻不可，谓必被害。继而议\n定，伍尚往以尽孝，伍员留以任复仇。及往，伍尚果与父同遇害。费无极见伍员抗命不进京，知必报复，急\n遣武城黑率师往捕。及遇，被伍员一箭射中，大惊而退，不敢穷追。而伍员由是得脱身投吴去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、伍员同上。"
        },
        {
          "character": "伍尚",
          "type": "念",
          "text": "四面狼烟尽，"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "共享太平春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟请坐。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长请坐。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "你我镇守樊城。父母在京。未知安否？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "吉人自有天相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "敖绛士上。"
        },
        {
          "character": "敖绛士",
          "type": "念",
          "text": "离了京都地，来此是樊城。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "京中下书人求见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启禀二位老爷：京中下书人到来。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "书信先进。来人候传。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "书信呈上，人暂退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "敖绛士允，下。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "书信在此，二位老爷请看。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "待我看来。 “不孝儿伍尚、伍员开拆”。 哦。乃是爷娘家书到来。贤弟观看。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长请看。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "同拆同观。"
        },
        {
          "character": "伍尚",
          "type": "西皮慢板",
          "text": "未曾拆书两泪淋， 纸上相逢父子情： 平王思念临潼会， 修宴琼浆赏功臣。 因此为父修书信， 伍尚、伍员转帝京。 外加走字多准备， 骏马十匹少留停。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "伍尚",
          "type": "西皮慢板",
          "text": "看罢书信心中喜，"
        },
        {
          "character": "伍员",
          "type": "西皮慢板",
          "text": "伍员心中自猜疑。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "有座。吓。贤弟看来。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "“外加走字多准备，骏马十匹少留停。”"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "吓。乃是“逃走”二字。兄长，书信上面，言语慌惚，必须传下书人问个明白。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "来，传下书人进见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "下书人走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "敖绛士上。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "参见二位老爷。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "罢了。太老爷在京可好？"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "安泰。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "太夫人可安？"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "健康。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "你叫什么名字。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "小人叫敖绛士。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "哦。敖绛士。你还是新近相府，还是久在相府？"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "小人是新进相府。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "朝中可有什么事情。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "没有什么事情。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "这书信还是太老爷交付于你，还是由内而发。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "乃是太老爷交付与我。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "叫我弟兄进京何事？"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "无非是加官授爵。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哦。也不过是加官授爵。哼哼！退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "敖绛士下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "吓，兄长，听下书人言语慌张。不进京为妙。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟说哪里话来。为臣尽忠，为子尽孝。哪有不进京的道理？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "有道是将在外，君命有所不受。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟。"
        },
        {
          "character": "伍尚",
          "type": "西皮慢板",
          "text": "贤弟说话不中听， 有辈古人听分明： 昔日有个商纣君， 宠爱妲己害忠臣。 文王羑里监囚禁， 伯邑考粉身留美名。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长吓！"
        },
        {
          "character": "伍员",
          "type": "西皮慢板",
          "text": "兄长说话欠思论， 怎把古人比今人： 文王监囚天注定， 伯邑考自投丧残生。 既是平王——"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "恩义盛， 就该有圣旨到樊城； 既然爷娘修书信， 为何有“逃走”二字书后明。 小弟稳坐樊城郡， 愿做不忠不孝人。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "听他之言不进京， 背转身来自沉吟： 有道是长子遵父命， 或生或死听天行。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟听你之言，一定不去了。待愚兄一人进京，倘有不测，贤弟也好作一准备。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长一人进京，弟放心不下。命一家将跟随。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "但凭贤弟。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "家院。唤家将走上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "家将走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "念",
          "text": "身在相府地，但凭军令行。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "参见二位老爷。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "有何吩咐？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "命你跟随大老爷进京，倘有甚事，速报我知。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "几时启程？"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "即刻启程。看衣换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚换衣。"
        },
        {
          "character": "伍尚",
          "type": "西皮原板",
          "text": "在头上去下了乌纱顶， 身上脱下紫罗衿。 叫家将备过了马能行， 你老爷即刻就登程。"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "一封书信到樊城， 拆散了弟兄两离分。 叫家院拿过酒一樽， 我与兄长——"
        },
        {
          "character": "伍员",
          "type": "西皮二六板",
          "text": "来饯行。 登山涉水多劳顿， 一路风尘转帝京。 若是父母多吉庆， 在双亲台前问安宁； 倘若爷娘遭不幸， 报仇二字属伍员。 兄长且饮此杯酒， 一路平安早到京。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "用手接过酒一樽， 背转身来谢神明。 走上前来礼恭敬， 愚兄言来听分明： 倘若父母遭不幸， 你是伍家报仇人。 辞别贤弟跨金蹬。 不分昼夜奔都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、家将、敖绛士同下。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "兄长上马两泪淋， 不由子胥痛在心。 机谋二字安排定， 稳坐樊城等信音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、家将、敖绛士同上。"
        },
        {
          "character": "伍尚",
          "type": "西皮摇板",
          "text": "过了一程又一程， 青山绿水面前存。 无心观看路旁景， 披星戴月奔帝京。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、家将、敖绛士同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引费无极同上。"
        },
        {
          "character": "费无极",
          "type": "引子",
          "text": "独霸朝纲，威震四方。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "俺费无极。是我劝逼伍奢修信，招伍尚、伍员回京，一同正法。老夫也曾命人 下书樊城，未见回报。 伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "敖绛士上。"
        },
        {
          "character": "敖绛士",
          "type": "念",
          "text": "忙将樊城事，报与丞相知。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "罢了。命你下书伍尚伍员，可曾来京？"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "伍尚一人来京，伍员镇守樊城。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "下面领赏。"
        },
        {
          "character": "敖绛士",
          "type": "白",
          "text": "谢丞相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "敖绛士下。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "定是伍奢卖弄笔墨。待我上殿参奏一本。 来，开道上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同喝，四龙套、费无极同走圆场。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "臣费无极见驾，大王千岁！"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "卿家有何本奏？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "今有伍尚私自来京，望吾主定夺。"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "伍尚私自来京，将他父子斩首。领旨下殿。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "遵旨。 校尉的，打道相府。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "带伍尚父子。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍奢、伍尚同上。"
        },
        {
          "character": "伍奢",
          "type": "西皮摇板",
          "text": "一见我儿到帝京， 不由为父胆战惊。 外加走字书后写， 骏马十匹少留停。 我儿枉把诗书念， 逃走二字解不明。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "一见爹爹把儿怪， 孩儿言来听开怀： 只望平王加官赏， 谁知今日投网来。 含悲忍泪法场上， 骂声无极狗肺才： 生时不能食尔肉， 阴曹地府追尔的魂来。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "来，将伍家父子开刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允。斩。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "且住。还有伍员镇守樊城。待我上殿再奏一本。 来，打道上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允，四龙套、费无极同走圆场。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "参见大王千岁！"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "卿家有何本奏？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "伍奢父子午门斩首，还有伍员镇守樊城。吾主裁夺。"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "命武城黑带三千人马，去到樊城，捉拿伍员，来京问罪。下殿。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "领旨。 来，打道回府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允，四龙套、费无极同走圆场。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "传武城黑进见。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "武城黑进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武城黑上。"
        },
        {
          "character": "武城黑",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "罢了。命你带领三千人马，去到樊城，捉拿伍员来京。"
        },
        {
          "character": "武城黑",
          "type": "白",
          "text": "得令。"
