        {
          "character": "费无极",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、费无极同下。"
        },
        {
          "character": "武城黑",
          "type": "白",
          "text": "众将官走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上。"
        },
        {
          "character": "武城黑",
          "type": "白",
          "text": "俺，武城黑。奉了平王旨意，前去樊城捉拿伍员。 来，兵发樊城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同允，四下手、武城黑同下。"
        }
      ]
