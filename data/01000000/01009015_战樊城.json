          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "参见二老爷，大事不好了！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "大老爷与老太爷，在京一同斩首。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "一同正法。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "二老爷醒来。"
        },
        {
          "character": "伍员",
          "type": "西皮导板",
