{
  "script_id": "01028007",
  "title": "困曹府",
  "alias": [
    "割瘤讨封"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "曹彬",
      "hangdang": "小生"
    },
    {
      "name": "张氏",
      "hangdang": "旦"
    },
    {
      "name": "华佗",
      "hangdang": "末"
    }
  ],
  "plot": "赵匡胤（即宋朝太祖）少年时喜动而不喜静，家庭不能管束。自大闹御勾栏之后，背父母，离乡井，无一日\n宁居。小说家所谓“闯关东，走关西”者是也。然而捉拿之榜文到处悬挂，匡胤又生有肉瘤，易于辨认。住\n宿曹彬家，与曹彬闲步关前，欲借此脱身，几为关吏所缚，幸曹彬嫂张氏误认为丈夫归来，上前呼唤，方不\n致入于陷阱。张氏羞耻殊甚，回房自缢。将及夜半，其灵魂直至赵匡胤榻前，陈诉枉死情由。赵匡胤感念救\n命之恩，封为华山老母，世世飨人间福食。又梦中见华佗仙师，将肉瘤割净，且为之用药医治，绝无踪迹，\n更属欣喜无限。翌日，乃与曹彬定计，诳出关门焉。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹彬引赵匡胤同上。"
        },
        {
          "character": "曹彬",
          "type": "二黄摇板",
          "text": "打开玉笼飞彩凤，"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "蹬断金锁走蛟龙。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子迎上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟请。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长请坐。家院，准备酒饭伺候。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子摆酒。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "酒饭到。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长请酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟，时才在关前，被崔浩那厮，差人捉拿于我。若非嫂嫂张氏，叫我一声丈 夫，愚兄险遭不测。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "此乃是仁兄洪福，有道是吉人自有天相也。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟呀！"
        },
        {
          "character": "赵匡胤",
          "type": "顶板原板",
          "text": "说什么吉人有天佑， 细听我赵玄郎诉说根由： 恨只恨崔浩贼要下毒手， 他与我一定要做下对头。 他命人在四门紧紧把守， 要害我赵玄郎他方罢休。 幸遇着张氏嫂嫂将我打救， 因此上逃性命才得回头。"
        },
        {
          "character": "曹彬",
          "type": "二黄摇板",
          "text": "兄长不必泪双流， 小弟言来听从头： 得饮酒来且饮酒， 待等明日做良谋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬睡。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "听一言来心内忧， 倒叫某家皱眉头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起更鼓。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟！睡熟了。咳！想我赵玄郎半生落魄，屡遭凶险，不知何日才是我出头之 日！思想起来，好不烦闷人也！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄慢板",
          "text": "赵玄郎坐书房心中纳闷， 二相公心无事瞌睡沉沉。 无奈何推纱窗强把心散， 真乃是中秋月，星星朗朗，朗朗星星，月到中秋，万里无云分外的光明。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "走金桥曾遇着先生苗训， 那先生排八卦会算子平。 俺玄郎将八字从头推算， 他算我到后来有九五之尊。 周文王全凭着三兄四弟， 俺玄郎也要仗四海宾朋。 且喜得今日里逃了性命， 跳龙潭出虎穴脱了残生。 恨不得挺长枪刺落玉兔， 用金钩钩出了红日东升。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏上。"
        },
        {
          "character": "张氏",
          "type": "二黄原板",
          "text": "谯楼上打罢二更尽， 走到堂前看分明。 悄悄儿来在窗门外， 暗地里听他说原因。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "奴家张氏。时才关前遇一红脸大汉，颇似我家丈夫。是我向前叫了他一声，被 官军将奴赶去。既然是我丈夫归来，为何不见到来？方才邻舍陈家伯伯言到， 有一红脸大汉，在二相公书房安歇。是奴家暗自出房，来在此地，听他说些什 么。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "且住！想我赵匡胤，今日在关前，被官军盘问。若非被张氏嫂嫂叫了我一声丈 夫，我命休矣。看将起来，真真的难得呀难得！哎咦，什么难得？此人乃是旁 人的妻子，倘若是我的妻子，既然叫人一声丈夫，我便一刀将她杀死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏倒跌，急跑下。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "张氏生来太奇情， 错把旁人叫夫君。 我前思后想心烦闷， 又听得谯楼上打三更。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华佗上。"
        },
        {
          "character": "华佗",
          "type": "二黄摇板",
          "text": "在洞中奉了玉帝令， 割除肉瘤救真龙。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "吾乃华佗是也。只因大宋天子赵匡胤身生肉瘤。崔浩命人，各处严拿与他。吾 今奉了上帝敕旨，前去为他割除肉瘤，以救危难。就此走走。"
        },
        {
          "character": "华佗",
          "type": "二黄摇板",
          "text": "天下纷纷刀兵乱， 无人执掌锦江山。 大宋真龙身遭难， 去到曹府走一番。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "来此已是。看他熟睡，待我与他医治起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。华佗用刀割瘤，敷药。赵匡胤看。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你是何人？莫非前来行刺么？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "非也。贫道乃是汉室华佗。今日特来，为主公割除肉瘤，以救危难。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "原来是华先生到了，多蒙医治，感恩非浅！"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "臣前来讨封。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "封你为药圣真人。去往华山归位去吧。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "华佗",
          "type": "二黄摇板",
          "text": "三呼万岁谢皇恩， 去到华山且修真。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华佗下。张氏魂上。"
        },
        {
          "character": "张氏",
          "type": "二黄摇板",
          "text": "飘飘荡荡风一阵， 来了张氏一鬼魂。 将身且把书房进， 万岁台前诉详情。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "张氏鬼魂。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "前来做甚？"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "多蒙你救驾之恩，理应封赠。你且听了。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "玄郎开言加封赠， 张氏嫂嫂听详情： 关前蒙你救我命， 理当加封受隆恩。 华山老母加封你， 安受香烟称正神。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "谢主隆恩。"
        },
        {
          "character": "张氏",
          "type": "二黄摇板",
          "text": "谢过皇恩忙站定， 去到华山为正神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏下。"
        },
        {
          "character": "曹彬",
          "type": "二黄导板",
          "text": "时才间朦胧方睡醒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬看。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "曹彬",
          "type": "二黄摇板",
          "text": "又只见红日自东升。 迈步且出书房门， 去到后堂看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬下。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄导板",
          "text": "昨夜晚三更得一梦，"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "华佗技艺果然精。 我这里急忙来观定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤看。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "肉瘤不见喜吟吟。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "昨夜三更时分偶得一梦，梦见华佗前来，将我的肉瘤割掉。肉瘤已去，我今日 定可出关也！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "人言华佗艺道精， 话不虚传果然真。 今日去到关前论。 看崔浩把我怎样行？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬上。"
        },
        {
          "character": "曹彬",
          "type": "二黄摇板",
          "text": "时才家院报一信， 张氏嫂嫂命归阴。 将身且把书房进， 尊声兄长听分明。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "启禀兄长：我那张氏嫂嫂昨夜三更十分悬梁自尽了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "听罢言来吃一惊， 张氏为我丧残生。 但愿得灵魂儿早归仙境， 我纵死黄泉也感你的大恩。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟，愚兄想得一计，可以逃出虎口。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长有何妙计？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "烦劳贤弟将愚兄捆绑起来，上了枷锁，去到衙前投首。但不知贤弟意下如何？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长说哪里话来！想那崔浩与兄长夙有冤仇，今日他命人四下查访捉拿兄长。 今日兄长不去逃生，反去送死。此事断断使不得！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟有所不知。想那崔浩，虽然与我有仇，但是他并未见过我面，只知愚兄身 有肉瘤。今日愚兄肉瘤已去，纵然见我，他又岂奈我何？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "话虽如此，还要兄长三思，免得后悔。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟不必多虑，愚兄自有言语回答于他。我有一言，贤弟听了！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮二六板",
          "text": "手挽手儿把话论， 尊一声贤弟听分明： 曾记得当年在原郡， 幼习武艺共刀兵。 也是我家道甚贫困， 浪荡江湖四海飘零。 弟兄们结拜在飞龙岭， 好似一母同胞生。 恨崔浩与我有仇恨， 苦苦要害我命残生。 昨日关前幸逃命， 多亏张氏救我的恩。 烦贤弟你且将我捆， 去到关前通姓名。 谅他不识我赵匡胤， 改名换姓诈他们。 今日我肉瘤无踪影， 他定放我去逃生。 倘若一朝得侥幸， 统领兵马杀仇人。 若将崔浩来拿定， 千刀万剐不留情。 贤弟休得多议论， 你且大胆放宽心。 来来来，将枷锁与我齐上捆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤带枷锁。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "去到衙前把话论。"
        },
        {
          "character": "曹彬",
          "type": "西皮摇板",
          "text": "玄郎果是英雄汉， 足智多谋胆包天。 二人一同去冒险， 哪怕虎穴与龙潭。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "叫贤弟与我把路带， 大胆前去走一番！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、曹彬同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}