    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花云上。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "杀败了呀，杀败了！实指望逃往金陵，搬兵求救。不料那贼，暗放乱箭，身受 重伤。我主呀，万岁！臣不能保全江山社稷了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扑灯蛾〗。陈友杰上，杀，下。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "我身受重伤，不能征战，不免叩谢圣上爵禄之恩，自刎了罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云自刎。四龙套、陈友谅同上。"
        },
        {
          "character": "陈友谅",
          "type": "白",
          "text": "花云已死，尸身不倒，可称忠勇双全，受孤家一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        },
        {
          "character": "陈友谅",
          "type": "白",
          "text": "歇兵三日，攻打采石矶头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
