{
  "script_id": "01010013",
  "title": "双断桥",
  "alias": [
    "断桥亭"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "白素贞",
      "hangdang": "旦"
    },
    {
      "name": "许仙",
      "hangdang": "小生"
    },
    {
      "name": "小青",
      "hangdang": "旦"
    }
  ],
  "plot": "白氏既在金山下，被法海用天兵杀败，大受惩创，偕小青逃归西湖。一路自怨自艾，而心中恋恋，仍惦念许\n仙官人，不能一刻忘情，百结柔肠，哀伤欲绝，其一片真诚恳挚之情，真足以反衬许仙之薄倖无心肝也。行\n经断桥，忽然腹痛欲裂，寸步不能行，盖以心中忧郁万分，已惊动天元，胎震震然欲分娩矣。适许仙袖法海\n金钵至，小青见之，怒甚，欲挥剑斩之，赖白氏再三劝阻得免。白氏乃且泣且诉，历数许仙之不义，仍令偕\n归。小青在侧，按剑怒目，不平实甚焉。",
  "notes": "《双断桥》，亦即昆剧之中《断桥相会》也，在《水漫》之后，《产子合钵》之前。原本义妖小说《白蛇传\n》中之事实，固人人皆知者。\n此剧去白氏之一段唱工，须唱得哀怨动听，如猿啼巫峡，鹤唳缑山，方为合作。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "白素贞",
          "type": "内白",
          "text": "哎哎呀！"
        },
        {
          "character": "白素贞",
          "type": "内西皮导板",
          "text": "被天兵杀得我无处逃走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白素贞上，前扑后捽。小青上。"
        },
        {
          "character": "白素贞",
          "type": "西皮原板",
          "text": "止不住泪珠儿点点血流。 这才是虎难描反成为狗， 主仆们倒做了泼水难收。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三锤。白素贞坐下。"
        },
        {
          "character": "白素贞",
          "type": "西皮慢板",
          "text": "金山寺与法海一处争斗， 只杀得主仆们头破血流。 好容易出罗网方得逃走，"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "罢了，青儿姐吓！"
        },
        {
          "character": "白素贞",
          "type": "西皮慢板",
          "text": "恨许仙骂法海无义贼囚！"
        },
        {
          "character": "小青",
          "type": "西皮慢板",
          "text": "端阳节你不该多贪药酒， 纱罗帐谁叫你自逞风流。 尊娘娘得撒手且自撒手， 许官人他本是惹祸根由。"
        },
        {
          "character": "白素贞",
          "type": "西皮导板",
          "text": "青儿姐你不要羞言出口，"
        },
        {
          "character": "白素贞",
          "type": "西皮慢板",
          "text": "纱罗帐是图他一时风流。 到如今怀揣着许门之后， 十个月要产生何处收留？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "哎唷哎唷！"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "娘娘怎么样了？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "青儿，一霎时腹内疼痛起来，想必是娃儿分娩。你我主仆，该在哪里存身？"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "你我回上灵王府去罢。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "前面带路。"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "晓得。 哎呀，娘娘大事不好了。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "慌张为何？"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "灵王府为天兵火化。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "怎么说？"
        },
        {
          "character": "白素贞",
          "type": "西皮滚板",
          "text": "薄命的女姣娥， 点点珠泪落。 王府被火化， 何处藏身躲？ 偶遇天兵将， 杀得我魂魄落。 官人不见面， 恩爱如刀割。 仰面把天叫， 可说是天吓天吓，我的老天爷吓！"
        },
        {
          "character": "白素贞",
          "type": "西皮慢板",
          "text": "自幼儿百草山从来修炼， 修炼了千百年带路神仙。 在高山我不听兄长相劝， 我一心到西湖去把景观。 灵王府与青儿一处交战， 用法宝收来了使女丫鬟。 她与我到西湖许郎见面， 也是我与许郎前世姻缘。 多亏了许官人搭船借伞， 小青儿为媒证正配良缘。 端阳节用药酒原形出现， 吓死了许官人命染黄泉。 长寿山盗灵芝白鹤交战， 雄黄阵险些儿一命难全。 多亏了观音母救苦救难， 南极星赠灵芝放我回还。 许官人病体好许下香愿， 金山寺去降香惹下祸端。 那法海留官人不放回转， 那法海他不该拆散姻缘。 也是我到金山法海变脸， 也是我气烦恼水漫金山。"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "娘娘，前面就是断桥亭，你我主仆二人，到着那里，再作道理。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "青儿姐，是你挽我来吓。"
        },
        {
          "character": "白素贞",
          "type": "西皮紧板",
          "text": "举来了天兵将与我交战， 韦陀爷降魔杵切断眉肩。 行来在断桥亭用目观看，"
        },
        {
          "character": "白素贞",
          "type": "西皮摇板",
          "text": "主仆们倒做了千难万难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣。许仙上。"
        },
        {
          "character": "许仙",
          "type": "西皮原板",
          "text": "老和尚他赐我金钵一口， 断桥亭见我妻必做对头。 行一步来至在断桥路口，"
        },
        {
          "character": "许仙",
          "type": "西皮慢板",
          "text": "见青儿吓得我两鬓汗流。 见娘子我只得哀哀叩首，"
        },
        {
          "character": "许仙",
          "type": "白",
          "text": "娘子，嗳呀，嗳呀娘子吓！"
        },
        {
          "character": "许仙",
          "type": "西皮原板",
          "text": "尊娘子放开怀莫结冤仇。"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "小青",
          "type": "西皮快板",
          "text": "见许仙不由人气冲牛斗， 细思想你本是惹祸根由。 我在这断桥亭招你头首，"
        },
        {
          "character": "白素贞",
          "type": "西皮哭板",
          "text": "说是你、你、你慢、慢、慢、慢着。"
        },
        {
          "character": "白素贞",
          "type": "西皮原板",
          "text": "拦住了青儿姐莫要动手， 许官人做此事你、你、你、你好无来由。 我本当断桥亭招你头首，"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "你慢来！"
        },
        {
          "character": "白素贞",
          "type": "西皮慢板",
          "text": "念起了夫妻情一笔勾销。"
        },
        {
          "character": "白素贞",
          "type": "西皮滚板",
          "text": "白氏泪如梭， 官人听我说： 听了法海言， 说妻是妖魔。 无心害你， 你反害我。"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "白素贞",
          "type": "西皮慢板",
          "text": "断桥亭把官人怀中抱搂， 似你这无义人何处收留！ 自从你金山寺降香去后， 老和尚他把你锁在后楼。 奴愁你茶和饭不随你口， 哪一夜不等你鼓打更楼。 和青儿到金山山门等候， 那法海与为妻做下了对头。 他举来了天兵将与妻争斗， 韦陀爷降魔杵打断了眉头。 尊官人手摸胸思前想后， 谁的是谁的非天在上头。"
        },
        {
          "character": "许仙",
          "type": "西皮原板",
          "text": "自那日到金山降香之后， 老和尚他将我锁在后楼。 想娘子见一面不能得够， 每日里在后楼加上忧愁。 尊娘子得撒手且自撒手， 好夫妻哪有个结下的冤仇？"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "娘娘，休要听贼子之言，待我将他杀了罢！"
        },
        {
          "character": "白素贞",
          "type": "西皮原板",
          "text": "许官人你看到什么时候， 那青儿她与你做下对头。 来来来随为妻连连叩首， 念起了娘子面将他收留。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "青儿姐，看在娘娘跪前跪后，你将官人他、他、他饶了罢！"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "看在娘娘，我不杀他就是。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "青儿请起。"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "娘娘请起。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "大家同起。嗳唷嗳唷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白素贞坐下。"
        },
        {
          "character": "许仙",
          "type": "白",
          "text": "娘娘怎么样了？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "官人，一霎时我腹内疼痛，想是娃儿分娩。你我夫妻，该在哪里安身了？"
        },
        {
          "character": "许仙",
          "type": "白",
          "text": "前面就是姐丈家中，你我夫妻，到在那里，再作道理。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "挽我来。嗳唷嗳唷！"
        },
        {
          "character": "许仙",
          "type": "白",
          "text": "娘子怎么样了？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "这个么……"
        },
        {
          "character": "白素贞",
          "type": "哭头",
          "text": "可说是许官人、许郎夫，你、你、你害得我好苦也！"
        },
        {
          "character": "白素贞",
          "type": "唱",
          "text": "这就是倒叫我难以出口， 纱罗帐自图你一时风流。 到如今怀揣着许门之后， 此一去见姐丈未必收留。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "官人挽我来。"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "你还了得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}