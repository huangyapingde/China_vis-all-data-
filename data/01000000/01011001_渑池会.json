          "character": "赵胜",
          "type": "白",
          "text": "大王虽有蔺、廉二人保驾，无奈嬴秦虎狼之地，奸雄并峙，臣愿保太子居邯郸， 再着代州守关将李牧，统领大军，离渑池三十里外屯扎，提防不虞之变，方 可万全。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "平原君之言正是。寡人此去，以三十日为期，倘若不归，卿可效楚国故事，即 立太子为君，以绝秦人之念，全我赵氏社稷，就于代州掣回李牧，一同行事去 者。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "赵王",
          "type": "念",
          "text": "一将有余蔺杰士，百身奠赎楚怀王。"
        },
        {
          "character": "蔺相如",
          "type": "念",
          "text": "今番同赴渑池会，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "文武方知赵国强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "发点。司马梗、司马错、公子悝、秦王、胡伤、魏丹、莘戎、王讫、蒙鳌、四校尉同上。"
        },
        {
          "character": "秦王",
          "type": "西皮快板",
          "text": "怀志称雄一统天， 无奈群英急难剪。 觑他们，似鹰鹯， 怎当孤机谋险，文臣偏偏，武将勇当前。 虎视耽耽会今贤， 有谁敢把他技殿。"
        },
        {
          "character": "秦王",
          "type": "念",
          "text": "冠裳不是晋文会，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "机谋须防鲁定臣。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "寡人为争卞和之璧，故于渑池之地，名为约会，暗实劫杀，择于今日开筵。正 是："
        },
        {
          "character": "秦王",
          "type": "念",
          "text": "安排打虎牢笼计，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "擒拿惊天动地人。"
        },
        {
          "character": "龙套",
          "type": "内同白",
          "text": "赵王到！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。四太监、四师军、李兑、赵胜、廉颇、传豹、蔺相如、赵王同上。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "大王请。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "多蒙君王勿吝玉趾，使稷不胜增光。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "岂敢。既是君王使命，敢不如约。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "君王之言，足见亲情之爱。 来，看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。安席。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "上宴。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "皇兄请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "寡人闻得君王善于音乐，故而携有宝瑟在此，烦君与孤一奏，幸勿吝教。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵王羞。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "这……寡人虽为消遣之具，今逢场作乐，不妨当筵一奏。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "取宝瑟过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦王捧上与赵王。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "污耳。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵王抚瑟。秦王、众人大笑。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "妙吓，孤闻赵之始祖，列侯好音，今日君王抚瑟，真乃不失家传也。 御史过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子悝允。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "可将今日之事，载之于简。"
        },
        {
          "character": "公子悝",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子悝持简书。"
        },
        {
          "character": "公子悝",
          "type": "白",
          "text": "“秦二十七年春三月，秦君与赵王会于渑池，秦君令赵王鼓瑟。”"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦王、众人同大笑。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "妙吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "蔺相如",
          "type": "白",
          "text": "寡君闻大王善于秦声，臣谨奉盆缶。请大王击之，以相欢乐，你请吓。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "唔。"
        },
        {
          "character": "蔺相如",
          "type": "白",
          "text": "吓，大王之意，敢谓秦之强乎？喏，今五尺之内，相如得以颈血溅污大王耳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔺相如猛上前。"
        },
        {
          "character": "秦众人",
          "type": "同白",
          "text": "呔，何敢无礼！"
        },
        {
          "character": "蔺相如",
          "type": "白",
          "text": "呔，谁敢来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "蔺相如",
          "type": "白",
          "text": "请吓！"
        },
        {
          "character": "秦众人",
          "type": "同白",
          "text": "这厮委实厉害。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "哈哈，逢场取乐，有何不可，取来寡人一击。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵王、众人同大笑。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "够了够了！"
        },
        {
          "character": "蔺相如",
          "type": "白",
          "text": "御史亦当上前，载之于简。"
        },
        {
          "character": "传豹",
          "type": "白",
          "text": "“赵于十九年三月间，赵王秦王，会于渑池，赵王令秦王击缶。”"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵王、众人同大笑。〖牌子〗。"
        },
        {
          "character": "秦众人",
          "type": "同白",
          "text": "大王今日惠顾，当割赵之五城，献与吾君为寿！"
        },
        {
          "character": "廉颇",
          "type": "白",
          "text": "也好，某闻礼尚往来，吾王便割五城与秦，汝主不可不报，亦须以咸阳呈献吾 主为寿。"
        },
        {
          "character": "秦众人",
          "type": "同白",
          "text": "你是廉颇？"
        },
        {
          "character": "廉颇",
          "type": "白",
          "text": "然也。"
        },
        {
          "character": "秦众人",
          "type": "同白",
          "text": "众将拿下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人各归各边，同起打，同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、李牧同上。"
        },
        {
          "character": "李牧",
          "type": "白",
          "text": "俺，代关守将李牧。奉大王旨意，统领大兵扎驻渑池会，提防不虞，适闻信炮 连天，必有他变。 来，迎上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李牧下。廉颇上，起打，蒙鳌上，李牧上。"
        },
        {
          "character": "蒙鳌",
          "type": "白",
          "text": "来者何人？"
        },
        {
          "character": "李牧",
          "type": "白",
          "text": "大将李牧。"
        },
        {
          "character": "蒙鳌",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒙鳌、廉颇战下。秦王上桌。廉颇、李牧同上。"
        },
        {
          "character": "廉颇、李牧",
          "type": "同白",
          "text": "呔，敢是惧战？"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "慢着慢着，寡人已知二位将军英勇，从今以后，愿与你两国和好，决不再动干 戈。"
        },
        {
          "character": "廉颇、李牧",
          "type": "同白",
          "text": "便动干戈，何惧于汝！若要收兵，须要禀知吾主。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "就烦将军面你主答话。"
        },
        {
          "character": "廉颇、李牧",
          "type": "同白",
          "text": "有请大王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四文官、蔺相如、赵王同上。秦王下桌。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "吓，王兄。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "怎么说？"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "你我原为和好而会，不料诸将致动干戈，寡人无以解释，愿将吾孙异人为质， 与王兄从此结为唇齿，永不相犯，皇兄意下如何？"
        },
        {
          "character": "蔺相如",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "先生为何大笑？"
        },
        {
          "character": "蔺相如",
          "type": "白",
          "text": "臣笑大王今日，可为知时务也。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "君王既愿罢息干戈，真乃二国生民之幸，寡人自当遵命。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "如此容孤归国，即遣吾孙异人来质，君王相别，容孤一拜。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "寡人也有一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦王、赵王同下马。〖牌子〗。"
        },
        {
          "character": "赵王",
          "type": "白",
          "text": "告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵王、四文堂、四文官、廉颇、李牧同下。"
        },
        {
          "character": "秦众人",
          "type": "同白",
          "text": "臣启大王：和好足矣，何必又以王孙纳质于赵，是何理也？"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "赵国文有相如，武有廉颇、李牧，势难钦服。孤今日纳质于他，稳住其心，方 好用兵。"
        },
        {
          "character": "秦众人",
          "type": "同白",
          "text": "大王远见，臣等不及。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "就此人马回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}