        {
          "character": "苏三",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": "苏三",
          "type": "西皮二六板",
          "text": "这堂官司未用刑， 玉堂春这里才放宽心。 出得察院用目睁，"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "看大人好似王金龙。 是他就该将奴认，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同喝。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "王法条条不容情。 走上前说两句知心话， 看他知情不知情： 玉堂春好比花中蕊。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "哽。公子比作何来？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "大人哪！"
        },
        {
          "character": "苏三",
          "type": "西皮快板",
          "text": "王公子好一似采花的蜂。 想当初花开多茂盛， 飞过来飞过去采了奴的小花心。 到如今花开不结正， 奴也不见三郎的身。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "快快出院去罢！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "含悲忍泪出察院， 看他把我怎样行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三哭，下。门子甲上。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "刘大人到。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "臬台上。"
        },
        {
          "character": "臬台",
          "type": "白",
          "text": "参见大人。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "年兄少礼。"
        },
        {
          "character": "臬台",
          "type": "白",
          "text": "传卑职过衙为了何事？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "只有苏三一案，烦劳大人审问，必须要谅情一二。"
        },
        {
          "character": "臬台",
          "type": "白",
          "text": "卑职照律条而断。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "这个，当凭于你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王金龙下，四龙套同下。四青袍同上。"
        },
        {
          "character": "臬台",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "臬台",
          "type": "白",
          "text": "身为八府巡按，作出此事，你头上这顶乌纱，捏在我手。 来，开道回衙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同允。臬台、四青袍同下。"
