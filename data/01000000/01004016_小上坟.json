{
  "script_id": "01004016",
  "title": "小上坟",
  "alias": [
    "禄敬荣归"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘禄敬",
      "hangdang": "丑"
    },
    {
      "name": "萧素贞",
      "hangdang": "花旦"
    },
    {
      "name": "二青袍",
      "hangdang": "丑"
    }
  ],
  "plot": "刘禄敬入都应试获售，听鼓京华，欲归不得。历久始得县缺。其妻萧素贞在家，以刘禄敬久客不归，杳无音\n信，疑已物故。而家况萧条，亲朋绝迹，不得已以针黹制度日，誓守柏舟。刘禄敬莅任时，念及糟糠，顺道\n一省庐墓。时值清明，见道旁一素妆女子，携麦饭纸钱，在荒冢累累间，痛哭祭扫。审之貌似己妻，大疑。\n乃遣散仆从，趋问姓氏，果己妻也。不禁涕泪纵横，上前相认。萧素贞见其老态龙钟，不敢深信。刘禄敬乃\n缕述家中琐事，言之凿凿，不差毫厘。萧素贞疑团始释，相抱大哭，各诉离衷，悲喜交集，即携手登舆赴任\n而去。",
  "notes": "此剧情节尚佳，与《桑园会》悲欢离合之情相等，毫无淫荡可鄙之处。不解梨园中编剧者，何以不用须生、\n青衫，而以小丑、花旦演之，遂致积习相沿，人人目为淫戏也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "两青袍引刘禄敬同上，六幺令。"
        },
        {
          "character": "刘禄敬",
          "type": "念",
          "text": "受得苦中苦，方为人上人。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "下官，刘禄敬。钦奉圣命，回家祭祖。 左右，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "两青袍同允。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "打道回府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "萧素贞",
          "type": "内白",
          "text": "苦吓！"
        },
        {
          "character": "萧素贞",
          "type": "内唱",
          "text": "萧素贞正在房中我便抽身起，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧素贞上。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "回头来带上了两扇门。 我今日里不往别处去， 一心心要上刘家的新坟。 正走之间泪满腮， 想起了古人蔡伯喈： 他上京中去赶考， 一去赶考不回来。 一双爹娘都饿死， 五娘子抱土筑坟台。 坟台筑起了三尺土， 从空中降下一面琵琶来。 身背着琵琶描容相， 一心心上京找夫回。 找到京中不相认， 哭坏了贤妻女裙钗。 贤惠的五娘遭马踹， 到后来五雷轰顶是那蔡伯喈。 正走之间抬头望， 来到了刘家新坟台。 坟前摆下了千张纸， 公公婆婆哭起来。 奴家哭到了伤心处，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "两青袍引刘禄敬同上。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "来了我为官受禄人。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "哭一声儿夫刘禄敬，"
        },
        {
          "character": "青袍",
          "type": "同白",
          "text": "呵！"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "禀老爷的话：刘家坟上，有一妇人，在此啼哭。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "哦呵且住，想我刘家坟上，哪有什么妇人在此，哭哭啼啼，哦哦哦其中必有原 故。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "原故。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "来，住轿。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "老爷撤料。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "你们前去问那妇人：因何在此哭哭啼啼？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青袍甲允。"
        },
        {
          "character": "青袍",
          "type": "白",
          "text": "那一妇人：因何在此哭哭啼啼？"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "萧素贞这里把头抬， 尊一声老爷你哪里来？"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "京中来。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "坟前里没有关王庙， 坟后里没有接官亭。 坟东里没有放马场， 坟西里没有陷马坑。 又不通南北共大道，我的爷吓， 你为何到我刘家的新坟？"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "来，你们对那妇人言道：说你老爷是清官到了，有何冤枉，叫她亲口诉来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青袍甲允。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "那一妇人：我家老爷是清官到了，有何冤枉，亲口诉来。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "听说一声清官到，"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "你这妇人，有何冤枉，一一诉来。有你老爷与你作主。"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "容禀。"
        },
        {
          "character": "青袍",
          "type": "同白",
          "text": "老爷吃饼。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "唗。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "我有心状告无人写， 口诉的状词句句真。 头一状不把别人告， 告的是公婆二双亲。 终日里打来每日里骂，我的爷吓， 打骂着奴家实实的难忍。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "世间哪有不是的公婆？公婆打骂，古之常理。头状不准，二状诉来。"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "容禀。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "老爷吃粽子。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "第二状不把别人告， 告的是娘舅李大公。 他每日三次我家走， 挑唆我公婆二双亲。 终日里打来每日里骂， 打骂着奴家逼我改嫁人。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "世间之上，哪有这等公婆。我却不准，三状诉来。"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "三状我就不告了。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "来，你去对那妇人言道：说你老爷准了状了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青袍甲允。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "那一妇人：我家老爷准了状了。"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "怎么着，你老爷准了我的状了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青袍甲允。"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "如此还要告。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "三状不把别人告， 告的是儿夫刘禄敬。"
        },
        {
          "character": "二青袍",
          "type": "同白",
          "text": "呵！"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "提老爷杂讳。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "下去。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "要伺候老爷。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "没有你们的事。赏你两张军用钞票，到兰芳里去把老虫跳。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "老爷回府，还是乘轿、骑马？"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "全不用，我有黄包车，下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二青袍同下。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "我的爷吓！ 上三年有封家书到， 上写着儿夫命丧东京城。"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "为官这里怒气冲， 骂一声娘舅李大公： 我在京中恩待你， 三百两银子书一封。 埋没了我银子是小事， 你不该说我命丧东京城。 圣上赐我上方剑， 先斩我娘舅李大公。 叫一声贤妻你认一认， 认认你亲夫刘禄敬。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "指望你是清官到， 原来你是个糊涂虫。 公案之下伸双手， 人皮包着畜类精。 槽头挽着逍遥马， 少鞍无髻你也认不成。 你若对得上三桩宝， 你是我亲夫转家门； 你若对不上三桩宝， 你就公子王孙，你也认不成。"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "贤妻打我我不恼， 贤妻骂我我不嗔。 将她当做裙钗女， 桩桩件件记得清。 宝贝放在尘埃地， 叫一声贤妻你来认分明。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "拿起乌绫看一看， 四四方方好乌绫。 拿起梨花照一照， 八月十五放光明。 拿起花鞋对一对， 千针万线我做成。 哎，宝贝乃是真宝贝， 禄敬还是假禄敬。"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "宝贝本是真宝贝， 禄敬本是真禄敬。"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "我亲夫上京去， 乃是十七、八岁的念书人。 到如今，你回来， 满脸上长胡须好不愁人。"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "上京时，我的妻， 年方二八的女裙钗。 到如今，我回来， 满脸的长皱纹好不丑人。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "有皱纹，无皱纹，与你何干？"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "有胡须，无胡须，与你何论？"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "既是我的亲夫到， 还有几桩大事情： 家住哪州并哪县， 哪里庄上有家门？ 爹姓甚来娘姓甚， 兄弟同胞有几人？ 娶的妻子谁家女， 妻子叫得甚芳名？"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "家住山东即墨县。 刘家庄上有家门。 爹爹就是刘员外， 母亲吃斋行善人。 上无兄来下无弟， 只有我禄敬一个人。 娶的妻子萧家女， 她的名字叫素贞。"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "听说是我亲夫到， 奴家随你到接官亭。"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "为官的这里头里走，"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "后面随着萧素贞。"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "忙将乌纱整一整，"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "头上摘下孝白绫。"
        },
        {
          "character": "刘禄敬",
          "type": "唱",
          "text": "只说是夫妻难相认，"
        },
        {
          "character": "萧素贞",
          "type": "唱",
          "text": "今日相逢在接官亭。"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "回去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禄敬、萧素贞同哭。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "娘子，你我分别多年，你在家中，何人照应于你？"
        },
        {
          "character": "萧素贞",
          "type": "白",
          "text": "待我来看。 哦，正厅上洋装打扮，戴金丝眼镜的，小白脸儿，照应我的。"
        },
        {
          "character": "刘禄敬",
          "type": "白",
          "text": "承蒙照应。明天请你坐汽车，吃大餐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禄敬、萧素贞同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}