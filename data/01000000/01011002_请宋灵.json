      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四黑龙套同上，岳飞上。"
        },
        {
          "character": "岳飞",
          "type": "引子",
          "text": "帐下站立千员将，统领雄兵百万郎。"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "志气凌云冲霄汉，赤胆忠心扶江山。龙凤旌旗空中展，丹心一点斗牛寒。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅，姓岳名飞字鹏举，宋室驾前为臣。可恨朝中奸佞张邦昌等，将二圣献于 番营。俺蒙后宫娘娘，恩赐龙凤旌旗二面，扫灭金囚。正是："
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "老天随人愿，迎请二圣还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张宪、施全、王贵、牛皋、汤怀、郑怀、何元庆同上。"
        },
        {
          "character": "张宪、施全、王贵、牛皋、汤怀、郑怀、何元庆",
          "type": "同念",
          "text": "柳荫拴战马，虎帐尽谈兵。"
        },
        {
          "character": "张宪、施全、王贵、牛皋、汤怀、郑怀、何元庆",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "圣旨下。"
        },
        {
          "character": "岳飞",
