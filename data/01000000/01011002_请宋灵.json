        {
          "character": "丞相",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "胆大小番，擅敢前来窥探，看剑！"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "且慢，有道是“两国相争，不斩来使”。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "好吓！好一个“两国相争，不斩来使”！小番，你到此则甚？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "奉狼主之命，正要送驾前来，不想二圣双双碰头而死。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "你才怎讲？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "双双碰头而死。"
        },
        {
          "character": "岳飞",
          "type": "三叫头",
          "text": "二圣！我主！哎吓！"
        },
        {
          "character": "岳飞",
          "type": "西皮导板",
          "text": "听一言不由人魂飞飘荡，"
        },
        {
          "character": "岳飞",
