        },
        {
          "character": "大太监",
          "type": "白",
          "text": "圣旨下跪，听宣读诏曰：命岳飞带领众将，扫灭金囚，迎请二圣回朝。旨意读 罢，望诏谢恩。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "万岁万万岁！ 有劳公公奉旨前来，后堂留宴。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "朝命在身，不敢久停。告辞。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "奉送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、大太监同下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官，校场听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。"
        }
      ]
    },
