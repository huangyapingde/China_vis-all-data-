        {
          "character": "岳飞",
          "type": "白",
          "text": "哦，国太还在。今在何处？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "已在大营之外。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "押下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丞相下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官，随本帅迎接国太！"
