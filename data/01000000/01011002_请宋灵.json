        {
          "character": "国太",
          "type": "白",
          "text": "卿家你来迟了。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "臣该万死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张宪、施全、王贵、牛皋、汤怀、郑怀、何元庆同跪。"
        },
        {
          "character": "岳飞",
          "type": "西皮二六板",
          "text": "罪臣岳飞无忠信， 含悲忍泪跪营门。 奉命前来把驾请， 身经血战万马营。 不想二圣归天境， 枉费罪臣一片心。 国太且把后帐进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太后下。岳飞、张宪、施全、王贵、牛皋、汤怀、郑怀、何元庆同起"
        },
        {
          "character": "岳飞",
          "type": "西皮散板",
          "text": "暂忍恨怒问详情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丞相上。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "小番，二圣晏驾，何不将皇灵送来？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "我国狼主言道：要元帅亲自迎请皇灵，方尽君臣之礼。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "哦，要本帅亲自迎请皇灵？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "小番，回去对你狼主言道：要本帅亲自迎请皇灵不难，叫你国狼主与文武大小 官员，俱要身穿重孝，迎接城外，准备降表，年年进贡，岁岁来朝；如若不然， 将你金邦踹为齑粉！"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "元帅吩咐，无不依从。元帅此番前去，不要这样打扮。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "要怎样打扮？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "必须换了便衣。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "我国狼主被元帅吓破了胆呢！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "你才怎讲？"
        },
        {
          "character": "丞相",
          "type": "白",
          "text": "吓破了胆呢！"
        },
        {
          "character": "岳飞",
          "type": "笑",
          "text": "哈哈哈吓，哈哈哈！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "滚出帐去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丞相下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "且住，那贼叫本帅亲自迎请皇灵，必有奸诈。 牛皋听令：命你带领人马，埋伏城外，以防不测。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "张宪、何元庆，身穿重孝，随本帅迎请皇灵，吓吓吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、四绿龙套、四上手、哈迷蚩同上，完颜木罕上。"
        },
        {
          "character": "完颜木罕",
