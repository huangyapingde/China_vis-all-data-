        {
          "character": "梁宽、赵衢",
          "type": "同白",
          "text": "如此待我二人进帐便了。 参见公子。我二人接驾来迟，望公子恕罪！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "二位将军少礼。 杨参谋，某欲起兵报仇，尚祈参谋指教。"
        },
        {
          "character": "杨阜",
          "type": "白",
          "text": "启公子：某的妻子死在临洮，尚未安葬。俺要在公子台前告假一月，望公子允 准。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "你一月之后，即速归来。 二位将军，好好看守城池。"
