        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "准备窝弓擒猛虎， 安排香铒钓鳌鱼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
