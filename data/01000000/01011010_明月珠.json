{
  "script_id": "01011010",
  "title": "明月珠",
  "alias": [
    "花园赠珠"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "小姐",
      "hangdang": "旦"
    },
    {
      "name": "公子",
      "hangdang": "小生"
    },
    {
      "name": "丫鬟",
      "hangdang": "旦"
    }
  ],
  "plot": "此剧系从昆剧《花园赠塔》剧翻演而出。本系《珍珠塔》弹词中事实，惟亦稍有不同处。全剧颇极简略，并\n无曲折。仅倩丫鬟彩屏，往请公子到园，当面赠以明珠一颗，并嘱努力试事，冀得高掇巍科而已。",
  "notes": "全剧以表情为主，按剧本尚无淫亵之处，洵得情之正者。惟演者至表情处，每易流入《遗翠花》、《花田错\n》等一种情形。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "小姐",
          "type": "内二黄导板",
          "text": "叫彩屏掌银灯西厢月下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟掌灯引小姐同上。"
        },
        {
          "character": "小姐",
          "type": "二黄慢板",
          "text": "耳旁里忽听得鼓更起发。"
        },
        {
          "character": "丫鬟",
          "type": "二黄慢板",
          "text": "满天上雾沉沉云霄雾下， 花园里寂静冷露满桃花。"
        },
        {
          "character": "小姐",
          "type": "二黄原板",
          "text": "将身儿坐至在花园以下， 奴好比西施女半点不差。"
        },
        {
          "character": "丫鬟",
          "type": "二黄原板",
          "text": "见小姐坐花园双目泪下， 倒叫我作奴婢暗自嗟呀。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "彩屏姐，你家解元爷到此为何？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我家解元爷到此，一为头上功名，二为这个。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "婚姻之事。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "太老爷怎样吩咐？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "太老爷朝事慌忙，将府下大小之事，托付老夫人掌管。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "老夫人待解元爷如何？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "老夫人待解元爷好吓。"
        },
        {
          "character": "丫鬟",
          "type": "二黄慢板",
          "text": "老夫人待解元十分俊雅， 要完婚除非是自挣乌纱。"
        },
        {
          "character": "小姐",
          "type": "二黄原板",
          "text": "叫彩屏你说的哪里之话。 难道说新秀才不娶浑家？"
        },
        {
          "character": "丫鬟",
          "type": "二黄原板",
          "text": "想当年缇莹女到老不嫁， 难道说你也要白鬓白发？"
        },
        {
          "character": "小姐",
          "type": "二黄原板",
          "text": "小彩屏讲的我伤心之话， 倒叫我低下头难把泪擦。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "姑娘不必痛哭，今天十四，明天十五，就是解元爷入场之日。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "解元爷现在那里安身？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷现在东亭书馆安身。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "奴家有意，命人将他请来，月下相谈，你看如何？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这命何人去请？"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "命你去请。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "晓得了晓得了。哎呀呀，不去了，不去了，我不去了。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "彩屏为何去而复返？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "非是我去而复返，倘若老夫人知道，那时我定讨没趣，我才不去了。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "彩屏吓！"
        },
        {
          "character": "小姐",
          "type": "二黄原板",
          "text": "我本是姑表亲必真不假， 老夫人她知道大理不差。"
        },
        {
          "character": "丫鬟",
          "type": "二黄原板",
          "text": "有张生戏莺莺西厢月下， 穿针的小红娘就是奴家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "小姐",
          "type": "二黄原板",
          "text": "将身儿坐在了西厢月下， 等表兄他到来细说根芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子、丫鬟同上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷请吓。"
        },
        {
          "character": "公子",
          "type": "二黄原板",
          "text": "今夜晚夜明灯竹簾高挂， 倒叫我读书人喜在心间。 我这里正行走用目观看， 彩屏姐你不走所为哪桩？"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "走吓。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "不要走了，来到了。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "待我进去。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "慢着，待我与你通禀一声。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "好吓，你与我通禀一声。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "启禀小姐：解元爷到。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "说我这里有请。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "她倒不出来了。待我自己进去罢。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "哎呀呀，解元爷不用请，他自己进来了。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "哎彩屏姐。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "彩屏过来，对他说道，我这里修书不及，未完花烛，还是姑表兄妹相称。叫他 稳重些。还要往下站。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "哎解元爷。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "哎，彩屏姐。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我家姑娘说道，修书不及，未完花烛，还是姑表兄妹相称。叫你放稳重些，还 要往下站。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "哦，叫我往下站。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "往下站。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "我就往下站。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "还要往下站。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "啊，还要往下站，哦哦哦。"
        },
        {
          "character": "公子",
          "type": "二黄原板",
          "text": "见表妹说的是真情实话， 倒叫我大张口无有话答。 她本是千金女必真不假， 况且那我也是宦门根芽。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "彩屏与解元爷看坐。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "有坐。请问表妹，一向可好？"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "有何德能，敢劳表兄动问，请问表兄可好？"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "有劳表妹承问。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "请问表兄，几时入场赴试？"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "今天十四，明天十五，就是我入场之日。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "此去可得会元？"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "虽然不得中，不落于人后。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "好一个虽然不得中，不落于人后。 彩屏过来，花园之中，姑娘未带什么含心之物，带来明月珠一颗，送与解元爷 带进场去，文章不中，宝上便取。来来来，付珠过去。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷，我家姑娘言道：花园之中，未带什么含心之物，今有明月珠一颗，赠 与解元爷带进场去，文章不中，宝上便取。来来来，付珠过去。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "彩屏姐，观见此宝明晃闪闪，日后必中花中之连。彩屏姐，就说我谢赠珠之恩。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷，谢过小姐赠珠之恩。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "彩屏对我表兄说道：叫他回到东亭书馆安身，明天好去得中花中之连。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷，我家姑娘言道：请回东亭书馆安身，明天好去得中魁元。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "就说我告辞。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷告辞。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "奉送。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐奉送。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "奉送。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "小姐",
          "type": "白",
          "text": "奉送。"
        },
        {
          "character": "小姐",
          "type": "二黄原板",
          "text": "解元爷只生得十分好看， 赛过了小潘郎那等容颜。"
        },
        {
          "character": "公子",
          "type": "二黄原板",
          "text": "见表妹只生得十分好看， 一霎时引得我骨软酥麻。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐吓。"
        },
        {
          "character": "丫鬟",
          "type": "二黄原板",
          "text": "解元爷只生得难描难画，"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷吓。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "丫鬟",
          "type": "二黄原板",
          "text": "我姑娘只生得闭月羞花。"
        },
        {
          "character": "小姐",
          "type": "二黄原板",
          "text": "但愿得我表兄鱼龙变化，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小姐下。"
        },
        {
          "character": "公子",
          "type": "二黄原板",
          "text": "准备着三杯酒帽插宫花。 适才间与表妹一同讲话， 恨不能将表妹搂抱在怀。"
        },
        {
          "character": "丫鬟",
          "type": "二黄原板",
          "text": "解元爷你不要心慌意乱， 要完婚除非是头带乌纱。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "公子",
          "type": "念",
          "text": "站立妆台遇佳人，"
        },
        {
          "character": "丫鬟",
          "type": "念",
          "text": "解元此去跳龙门。我姑娘绣阁常在耳，"
        },
        {
          "character": "公子",
          "type": "念",
          "text": "准备红花报好音。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "好一个“准备红花报好音”。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "彩屏姐请吓。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "解元爷请吓。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "请吓。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "请吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "小心了。"
        },
        {
          "character": "公子",
          "type": "笑",
          "text": "哈哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}