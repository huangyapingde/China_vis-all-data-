{
  "script_id": "01027011",
  "title": "战潼台",
  "alias": [
    "刘高抢亲"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘智远",
      "hangdang": "武生"
    },
    {
      "name": "岳彦真",
      "hangdang": "末"
    },
    {
      "name": "岳存训",
      "hangdang": "小生"
    },
    {
      "name": "朱文杰",
      "hangdang": "丑"
    },
    {
      "name": "朱温",
      "hangdang": "净"
    }
  ],
  "plot": "唐昭宗初即位，沧州节度使王铎，入京朝贺。归途为汴梁节度使朱温所劫，欲聘其女为媳。然王铎之女，已\n许字于同台节度使岳彦真之子岳存训。畏朱温之强，勉强应允。朱温命其弟朱义，子友珍，同至沧州抢亲。\n王铎暗遣使者，通信于同台。岳彦真父子，商议要截于牛路。帐下裨将刘智远，自请为先锋，尽力抵御，保\n全此城。从此刘智远为同台诸将士所钦敬，名重一时云。",
  "notes": "是剧出于《五代残唐演义》，改头换面，随意编排。案刘智远，小字寄奴，即五代时之汉高祖，既得天下，\n始改名为暠（音缟字上声），演义均称“刘高”，实依惯传讹之弊。战潼台一事，正史上无此明文。王铎系\n僖宗时之宰相，中和元年二月，同平章事。二年正月，为诸道行营都统。若沧州节度使，无从查考。惟朱温\n曾为同华（今陕西同州华州）节度使。可知小说家，恒多臆造。不足尽信也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "岳彦真上。"
        },
        {
          "character": "岳彦真",
          "type": "西皮摇板",
          "text": "旌旗不住空中摆， 本镇坐守在潼台。 将身且坐室帐外， 三、六、九日把兵排。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训上。"
        },
        {
          "character": "岳存训",
          "type": "念",
          "text": "且将抢亲事，进帐说端的。"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "我儿少礼，一旁坐下。"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "多谢爹爹。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "我儿进帐，有何军情？"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "可恨朱温，霸占了孩儿的亲事。孩儿意欲在中途路上前去抢亲，不知爹爹意下 如何？"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "我儿前去，无人保护，为父放心不下。"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "我营中有一火头军，名唤刘高，此人颇有胆量。若命此人前去，保定孩儿，料 然无事。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "我儿将他唤进帐来，待为父看过。"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "遵命。 刘高进帐！"
        },
        {
          "character": "刘智远",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远上。"
        },
        {
          "character": "刘智远",
          "type": "念",
          "text": "君子生平志不平，掌中无剑怎杀人？伸手要取天边月，只恨足下不生云。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "俺，姓刘名高字智远，乃延安人氏。在总爷营中，当了一名火头军。闻听总爷 呼唤，不知为了何事？待吾进帐，问个明白。 报，刘高告进，参见总爷！ 吓，少爷！"
        },
        {
          "character": "岳彦真、岳存训",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "唤小人进帐，有何吩咐？"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "你家少爷，要在中途抢亲，无人保护。今欲命你前去，你可有此胆量？"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "小人有此胆量。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "既然如此，就命你前去，一路之上，须要小心在意。倘若抢得亲回，本镇定有 重赏。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "多谢总爷提拔。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "只是一件。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "此番前去，万万不可杀人。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训摇手。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳彦真下。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "但不知少爷几时起程？"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "此事不可迟延，即刻起程。与爷带马！"
        },
        {
          "character": "岳存训",
          "type": "西皮摇板",
          "text": "帐中奉了爹爹命， 去至中途要抢亲。 刘高与爷把马顺， 但愿此去把功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训、刘智远同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、二英雄、四青袍随轿同上，朱文杰上。"
        },
        {
          "character": "朱文杰",
          "type": "西皮摇板",
          "text": "老爷出世谁不怕， 一路之上把人杀。"
        },
        {
          "character": "朱文杰",
          "type": "白",
          "text": "俺，大将军有八面的威风，我是小将军，只有四面威风。俺，朱文杰，奉了吾 叔父之命，前去抢亲。且喜亲事到手。 众将官，人马就此缓缓而行。"
        },
        {
          "character": "朱文杰",
          "type": "西皮导板",
          "text": "小将军奉命出宝帐，"
        },
        {
          "character": "朱文杰",
          "type": "西皮原板",
          "text": "带领着大小众儿郎。 未曾出营大炮响， 刀枪剑戟赛秋霜。 此一番奉命把亲抢， 他那里见了我如见虎狼。 他把我请至在二堂上， 满汉筵席摆列在中央。 干鲜果品一齐上， 珍馐美味让我先尝。 头一碗上的是——"
        },
        {
          "character": "朱文杰",
          "type": "西皮二六板",
          "text": "榴丸子， 二一碗上的是炒蟹黄； 三一碗上的是米粉肉， 四一碗上的是炝大肠； 五一碗上的是炸鱼片， 六一碗上的是羊肚汤； 这烧黄二酒就足了我的量，"
        },
        {
          "character": "朱文杰",
          "type": "西皮摇板",
          "text": "那一旁来了送死郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远、岳存训同上，同起打。朱文杰、四下手、二英雄、四青袍同败下。刘智远、岳存训同追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。刘智远上。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "且住！想我临行之时，总爷叫道：此番抢亲，不许杀人。我若不杀人，这亲事 焉能到手？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训上。"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "刘高，亲事不能到手，如何是好？"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "嗳呀少爷吓！我家总爷，不许我杀人。若不杀人，这亲事是怎能到手？"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "刘高，你只管杀人。有你少爷替你担待！"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "如此，你就闪开了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、二英雄、四青袍、朱文杰同上，同起打。刘智远杀朱文杰，夺花轿同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、朱温同上。"
        },
        {
          "character": "朱温",
          "type": "念",
          "text": "辕门战鼓响，儿郎报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "少爷被潼台小将杀死，亲事抢了去了！"
        },
        {
          "character": "朱温",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "朱温",
          "type": "白",
          "text": "众将官，杀奔潼台！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱温、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "岳彦真上。"
        },
        {
          "character": "岳彦真",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训上。"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "我儿回来了？"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "亲事可曾到手？"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "花轿已被孩儿抢了来了。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "亲事到手。我儿后堂歇息去罢。"
        },
        {
          "character": "岳存训",
          "type": "白",
          "text": "儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训下。探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "朱温带兵，攻打潼台。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "岳彦真",
          "type": "西皮摇板",
          "text": "忽听探马报一声， 倒叫本镇吃一惊。 朱温人马甚凶勇， 围困潼台为何情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远上。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "叩见总爷。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "罢了。刘高，你此番保得少爷抢亲，可曾杀人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训暗上，摇手。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "小人不曾杀人。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "刘高，你若是杀了人，你就说杀了人。本镇也不加罪于你。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训摇手。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "小人确实不曾杀人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳存训下。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "你既然不曾杀人，去到后营，烧火喂马去罢！"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "遵命。 且住！想我刘高，保得少爷抢亲而回，乃是一场功劳。有功不赏，反叫我后营 烧火喂马。嗳呀苍天吓，天！刘高！也不知前世里，怎样得罪了这马王菩萨？ 我在此吃粮，终无出头之日。不免我进得帐去，辞了口粮，投奔他方去罢！ 启总爷：小人要辞粮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳彦真低头不语。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "吓！启总爷：小人要退伍辞粮。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "胆大刘高，想那朱温，他不发人马，你也不辞粮。今日朱温，带领人马，围困 潼台，你就要辞粮。是何道理？"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "启总爷：小人不才，愿出城会那朱贼！"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "你乃小小一名火头军，岂是那朱温的对手？"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "总爷，你好小量人也！"
        },
        {
          "character": "刘智远",
          "type": "西皮摇板",
          "text": "总爷你把人小量， 海水怎能用斗量？ 朱温纵有千员将， 一人能挡百万郎！"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "本镇不曾见过你的武艺，命你去到校场，观看你的刀马如何？"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "只是小人，无有盔铠。"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "赏你半副盔铠，校场去者。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "谢总爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远下。"
        },
        {
          "character": "岳彦真",
          "type": "西皮摇板",
          "text": "将身且往校场上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳彦真上桌。"
        },
        {
          "character": "岳彦真",
          "type": "西皮摇板",
          "text": "观看刘高演刀枪。"
        },
        {
          "character": "刘智远",
          "type": "内西皮导板",
          "text": "豪杰校场试刀马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远上。"
        },
        {
          "character": "刘智远",
          "type": "西皮快板",
          "text": "英雄落魄在天涯。 头戴盔、身披甲， 抖擞威风气力加。 好似蛟龙把海下。 好似猛虎出山窪。 跨马提刀我耍一耍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远耍刀花。"
        },
        {
          "character": "刘智远",
          "type": "西皮快板",
          "text": "总爷传令就动杀法！"
        },
        {
          "character": "岳彦真",
          "type": "白",
          "text": "命你带领五百人马，出城抵挡朱温。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "谢总爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远下。"
        },
        {
          "character": "岳彦真",
          "type": "西皮摇板",
          "text": "刘高生来真胆大， 压赛当年李哪吒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳彦真下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、二将、朱温同上。四下手、刘智远同上，同对阵，同起打。朱温败下，刘智远追下。"
        }
      ]
    },
    {
      "scene_id": 7,
