        {
          "character": "家童",
          "type": "白",
          "text": "我该叫你什么？"
        },
        {
          "character": "张振",
          "type": "白",
          "text": "你叫我张家大爷。"
        },
        {
          "character": "家童",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "张振",
          "type": "白",
          "text": "什么东西。"
        },
