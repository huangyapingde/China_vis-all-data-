{
  "script_id": "01010015",
  "title": "荐诸葛",
  "alias": [
    "徐庶走马荐诸葛"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "徐庶",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "小生"
    },
    {
      "name": "下书人",
      "hangdang": "丑"
    }
  ],
  "plot": "徐庶因犯杀人罪，改名单福。初投刘表不得志，旋归刘备为军师，屡败曹操。至是，曹操已探得单福即徐庶\n化身。用程昱谋，招徐母至，令作书召徐庶来归。徐母不之诈，反辱骂曹操，且掷砚投击，欲激曹操怒以求\n死。曹操仍用程昱语，非特不罪，反优待之，旋被程昱诱得亲笔书，遂仿冒字迹，伪作徐母招徐庶归曹操书，\n投送刘备。徐庶本纯孝，得书后，寝食不安，急辞刘备欲往。刘备知不可留，乃设宴饯送。刘备不忍离别，\n复令军士砍伐树木以期可以远望。徐庶因此感激无地，复回马举荐诸葛亮于刘备而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "引子",
          "text": "八卦阴阳有准，胸中判断无错。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "只为不平天涯走，袖内阴阳断不差。八卦暗藏天地理，要与皇叔定邦家。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "山人姓徐名庶字元直，只为在家路见不平，将凶人刺死，逃亡在外，已二十余 年。改名单福，投在刘皇叔驾下。多蒙皇叔十分宠爱，拜为参谋。得了樊城地 界，这也不表。天色尚早，不免进帐问我主金安。"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "自幼儿在家中将人刺死， 到樊城保皇叔驾坐金阶。 都只为臣保主忠心不改， 君有仁臣有义难以分开。 但愿得我老母福寿康泰， 那时节焚清香答谢天台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "忆及当年叙英雄，争破黄巾立大功。弟兄失散古城会，虎牢关前定邦家。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤，刘备。前日多得单福先生妙计，得了樊城。又恐曹操心怀不服，兴动大兵 前来，我朝并无人马抵敌。军校，"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有请先生并三位将军进帐。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有请先生并三位将军进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "执掌丝纶起凤毛，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "全凭六略并三韬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "曾破黄巾兵百万，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "东灭孙权北灭曹！"
        },
        {
          "character": "徐庶、关羽、张飞、赵云",
          "type": "同白",
          "text": "主公宣召，一同进帐。主公在上，臣等参见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "少礼，一同坐下。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢坐。启主公：宣山人进帐有何军事议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "多蒙先生妙计得了樊城，又恐曹操心怀不服，兴动大兵前来，我朝并无人马抵 敌。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "我主但放宽心，山人早已算就。曹操有下书人前来，命哪位将军把守营门？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "如此，三弟听令："
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "命你把守营门。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "得令。 领了大哥令，把守在营门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下书人上。"
        },
        {
          "character": "下书人",
          "type": "念",
          "text": "为人不怕死，前来下战书。"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "嗳，"
        },
        {
          "character": "下书人",
          "type": "念",
          "text": "来得不凑巧，遇着黑脸老。"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "人人说道：张飞杀人不眨眼，这书信怎得上去？哦，有了，不免作个金蝉脱壳 之计，将书藏在帽内。 三千岁在上，小人叩头。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你是哪里来的？"
        },
        {
          "character": "下书人",
          "type": "白",
          "text": "曹……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿住了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟拿住了什么？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿住曹营奸细。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军，"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "有顶帽儿赏与你们。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "启三千岁：有书信一封。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿来！ 启大哥：有书信一封。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呈上来吓！ 上写着“徐庶开拆”。我道曹营打战表，原来是徐庶家书。先生，想我营中并 无姓徐之人。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣启主公：此乃是臣的家书。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "既是先生家书，拿去请看。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公、三位将军同拆。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "老母在上，恕孩儿不孝之罪也！"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "有徐庶接家书心如刀绞， 不由人心悲切眼泪巴巴。 上写着八旬母亲笔谕札， 晓谕了徐庶儿不孝娃娃： 在家中为不平将人刺死， 别萱堂离故土久不回返。 多亏了徐康儿孝心第一， 每日里在膝前侍奉无差。 遭不幸你兄弟一命罢休，"
        },
        {
          "character": "徐庶",
          "type": "哭",
          "text": "兄弟吓！"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "只哭得为娘的两眼昏花。 曹丞相差校尉将娘拿下， 他说儿在新野逆犯国法。 传一声进帐去与娘共话， 那时节为娘的怎肯顺他！ 一霎时发雷霆绑娘去杀， 多亏了程昱侄苦苦保下。 望娇儿早回来与娘共话， 迟延了又恐怕命染黄沙。 我本当辞主公前去救母， 刘皇叔待山人如同一家； 我若是保主公不去救母， 只恐怕不孝名传遍中华。 左一想又一想无计无法， 我只得坐一旁珠泪洒洒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生看了书信，为何双眼流泪？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣启主公：只因老母在曹营有难，故而双眼流泪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "既是伯母有难，理当搭救。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公大事未成。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "怎奈刘备福薄德浅，不能成其大事。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "待臣救母之后再来扶助。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生可算忠孝双全！但不知几时起程？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "即日起程。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟听令。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "何令？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "长亭摆宴与先生饯行。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "百万军中战长江，久不兴兵破襄阳。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "老母修书儿悲切，"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "偶遇高人不久长。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "相烦竭力来保主，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "准备人马动刀枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "小将生来胆气冲，要与我主立大功。哪怕曹营兵百万，难当常山赵子龙！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺，赵云。奉了大哥将令，长亭设宴与先生饯行。 人来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "打道长亭。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "吓！ 启爷：来此长亭。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公、先生驾到，速报俺知。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、徐庶同上。"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "手挽手送先生出大营， 难舍难分我的先生。"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "实指望保主公大事早成， 俺徐庶倒做了失信之人。"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "这都是汉刘备福分浅薄， 难留你徐先生在此间。"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "劝主公你那里龙心放下， 到后来总有那一家能人。"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "纵有能人有何用？ 要比你徐先生万万不能。 叫四弟看过了皇封御宴， 我与先生来饯行： 马跳檀溪孤遭困， 中途路上遇先生。 我爱先生阴阳准， 我爱先生用兵能。 老伯母来了书和信， 先生要做忠孝人。 今日长亭无别敬， 一斗水酒敬先生。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "多谢主公！"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "徐庶接酒心胆惊， 转过身来谢苍天。 指望与主同一殿， 半途而断何不周全？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": "关羽",
          "type": "二黄原板",
          "text": "关某敬酒泪双流， 尊声先生听我言： 弟兄当年结义在桃园， 誓愿同死与共生。 先生救母速请转， 需要言行莫食言。"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "二将军敬酒敢不尊， 吓得山人战兢兢。 背地私下来盘算， 后来不久为神明。 大义参天谁不敬， 俺徐庶比他万不能！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "叫人来——"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将酒满满斟！"
        },
        {
          "character": "张飞",
          "type": "二黄原板",
          "text": "一斗酒儿满满筛， 翼德掩袍跪尘埃。 上跪天来下跪地， 跪父跪母不跪人。 今日跪在先生面， 只为大哥锦乾坤。 先生说话言有信， 俺老张带马接先生。"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "好一个粗中有细三将军， 他把山人看得真。 皇叔驾前有了你， 好似金殿柱一根。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "赵云",
          "type": "二黄原板",
          "text": "兄敬酒来弟饯行， 赵云带过马能行。 有请先生忙上马， 俺赵云送先生早到曹营。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "吓，不敢。将马带过。"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "山人在此有何能， 怎敢劳动四将军？ 上前来辞别了仁义主， 回头别过文武众三军。 辞别了主公上马行， 马上加鞭到曹营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "一见先生过山林，"
        },
        {
          "character": "关羽",
          "type": "二黄摇板",
          "text": "只见树木不见先生。"
        },
        {
          "character": "张飞",
          "type": "二黄摇板",
          "text": "叫人来——"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "二黄摇板",
          "text": "将树木一齐砍伐，"
        },
        {
          "character": "赵云",
          "type": "二黄摇板",
          "text": "又只见四下起黄沙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "二黄摇板",
          "text": "带住缰绳勒住马， 又只见四下起黄沙。 攀鞍离镫把马下，"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "先生为何去而复返？"
        },
        {
          "character": "徐庶",
          "type": "二黄摇板",
          "text": "非是山人去而复返， 主公因何把树砍伐？"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "弟兄们望不见先生驾， 故此树木一齐伐。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "徐庶",
          "type": "二黄摇板",
          "text": "人说桃园仁义深， 话不虚传果是真。 罢罢罢， 不免将两个谋士荐了罢，"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公吓！"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "手挽手儿站山岗， 山人言来记心旁： 离此不过二十里， 卧龙岗前有道家。 双姓诸葛单名亮， 道号孔明就是他。 袖内阴阳藏八卦， 知天识地不毫差。 看他年纪不多大， 如今还是娃娃家。 主公若得将他访， 兴刘灭曹要去请他！"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "听罢先生说的话， 水镜先生举荐他。 卧龙先生孤去访， 但不知凤雏是哪家？"
        },
        {
          "character": "徐庶",
          "type": "二黄原板",
          "text": "凤雏家住襄阳地， 姓庞名统字士元。 本当同主一齐访， 老母望儿泪巴巴。 辞别主公把马跨， 马上加鞭走天涯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "先生打马你去了， 不由孤王心内焦。 二弟、三弟一声叫， 子龙四弟听根苗： 诸葛先生同去访， 请得先生破奸曹。 挣下江山我不要， 兄弟同孤掌代劳。 军士们摆驾返营壕， 要学文王访贤曹。"
        },
        {
          "character": null,
          "type": "stage",
