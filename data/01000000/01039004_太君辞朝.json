{
  "script_id": "01039004",
  "title": "太君辞朝",
  "alias": [
    "黄花国造反"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "宋仁宗",
      "hangdang": "老生"
    },
    {
      "name": "杨排风",
      "hangdang": "占旦"
    },
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "岳士奎",
      "hangdang": "末"
    },
    {
      "name": "呼天保",
      "hangdang": "付"
    },
    {
      "name": "恩孟",
      "hangdang": "丑"
    }
  ],
  "plot": "《太君辞朝》为宋朝杨家将事实。按剧情所载，系出仁宗时代，黄花国造反。时杨家三代，俱已丧亡，只余\n太君、穆桂英、杨排风诸老妇，及曾孙杨藩一人而已。朝廷仍命杨家出征。佘太君既平定黄花回朝，自念全\n家三代，均为国亡身，人口凋零已极，设日后再有战征，命吾家出征，万一杨藩有伤，恐一脉宗嗣，从此断\n绝，因修下辞表，上朝告老。宋仁宗初时不准，续念其合家除小孙杨藩外，余俱年老，确系真情，遂许之。\n次日，即率同文武，至长亭饯送。",
  "notes": "此剧为老旦唱工戏。昔年龚云甫最拿手。坤伶苗鑫如，颇能得其真传。余亦曾屡见之。余最爱其辞朝场中之\n快三眼一段，声容并茂，真有气旺神流之致。今虽男伶中，亦不多觐。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "佘太君上。"
        },
        {
          "character": "佘太君",
          "type": "引子",
          "text": "杨家为国秉忠心，受皇爵禄报君恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君坐正场。"
        },
        {
          "character": "佘太君",
          "type": "念",
          "text": "天波府内将英雄，南征北战立奇功。可叹忠良今何在，到头只落一场空。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨排风暗上。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "老身佘氏太君，山东池州人氏。配夫金刀令公。我杨家自从投宋以来，四代忠 良。只因黄花国代兵作乱，今有圣上，有谕旨前来，命老身带兵前去，征战黄 花国。且喜大兵一到，一战成功，因此平定。我想吾杨家，死的么死了，亡的 么亡了，只有孙儿杨藩一脉。倘若是在阵有失，岂不是绝了我杨家后代的宗嗣。 今有昨日我合家商议，修下了辞王的表章，今日要上殿启奏一本，告职归林， 安然潇洒，不免上殿一走。 排风，"
        },
        {
          "character": "杨排风",
          "type": "白",
          "text": "太君。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "捧定了表章，随定老身，金殿走走。"
        },
        {
          "character": "杨排风",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨排风拿表章盘子。"
        },
        {
          "character": "佘太君",
          "type": "二黄慢板",
          "text": "吾主爷坐山河皇恩高厚， 下河东我杨家才把宋投。 那萧邦兴人马与主争斗， 潘仁美与杨家结下冤仇。 我儿夫命丧在两狼山口， 可叹他为国家南征北战，东挡西杀，不能到头。 黄花国带人马又来争斗， 他要夺我主爷江山锦绣。 且苦得我老身扫尽贼囚。 叫排风忙带路金殿来走， 上金殿辞王驾本奏龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君、杨排风同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "包拯、岳士奎、呼天保、恩孟同上。"
        },
        {
          "character": "包拯、岳士奎、呼天保、恩孟",
          "type": "同点绛唇",
          "text": "彤云升降，太极承恩，连玉觞，纷纷传。干戈扰攘，却龙鱼汗马强。国泰民安， 庆永祯祥。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老夫包文正。"
        },
        {
          "character": "岳士奎",
          "type": "白",
          "text": "下官岳士奎。"
        },
        {
          "character": "呼天保",
          "type": "白",
          "text": "下官呼天保。"
        },
        {
          "character": "恩孟",
          "type": "白",
          "text": "下官恩孟。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "今当万岁设立早朝，你我不免殿脚伺候。金钟三响，万岁临朝，你我分班伺候。"
        },
        {
          "character": "岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、岳士奎、呼天保、恩孟自两边分下。四小太监、二大太监引宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "引子",
          "text": "龙门闪放，文武臣，齐贺君王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、岳士奎、呼天保、恩孟自两边分上。"
        },
        {
          "character": "包拯、岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "臣等见驾。愿吾主万岁。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "包拯、岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、岳士奎、呼天保、恩孟分站立两边。"
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "黄花国内起风波，生灵涂炭受折磨。多亏众卿来相扶，扫平蛮贼整山河。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "寡人大宋天子仁宗在位。自孤王登基以来，风调雨顺，国泰民安。只因外邦黄 花国作乱，幸喜太君，带领人马，前去征战，黄花国的贼囚，一战成功，各处 平尽。今当设立早朝。 内侍！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "替孤传旨下去：满朝文武，有本早奏，无本退班。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。 万岁有旨：满朝文武，有本早奏，无本退班。"
        },
        {
          "character": "佘太君",
          "type": "内白",
          "text": "佘氏有本启奏。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "候旨。 启奏万岁：佘太君有本启奏。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "替孤传旨：太君上殿。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。 万岁有旨：太君上殿。"
        },
        {
          "character": "佘太君",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨排风引佘太君同上。"
        },
        {
          "character": "佘太君",
          "type": "念",
          "text": "修下辞王表，上殿奏当朝。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "臣妾佘氏见驾，愿吾主万岁。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君平身。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君上殿，有何本奏。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "启奏万岁：今有黄花国的反冠平尽，乃是吾主洪福齐天也。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平伏黄花国，乃是太君一门之功。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "我主洪福。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "手捧何物？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "臣妾修下本奏。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来，待孤一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "吓太君，想外邦已平，太君要告职，叫孤王是怎能舍得？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "咳，万岁吓！"
        },
        {
          "character": "佘太君",
          "type": "二黄慢板",
          "text": "佘氏女在金殿把本启奏， 尊一声万岁爷细听从头： 我夫君居住了池州山后， 太祖爷今下河东把宋来投。 宋天子待杨家恩比天厚， 赐臣做一个个官封王侯。 可恨那潘洪贼心怀绝后， 他与我杨家将来结冤仇。 萧天佐领番兵与主争斗， 潘仁美讨帅印暗用机谋。 大郎儿替宋主忠心尽了， 二郎儿短剑下命丧荒丘。 三郎儿马踏死如泥酱透， 四郎儿失番邦不见回头。 五郎儿看破了红尘之路， 他无奈五台山去把道修。 六郎儿英雄将下场无有， 七郎儿被潘洪乱箭命休。 万岁爷开龙恩告职回头，万岁爷吓！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君吓！"
        },
        {
          "character": "宋仁宗",
          "type": "二黄慢板",
          "text": "老太君在金殿把本奏启， 不由我两眼中珠泪湿衣。 老太君今日里告职归里， 叫寡人怎舍得架海金女。 望太后还需要三思主意， 你去后何人来保孤华夷。"
        },
        {
          "character": "佘太君",
          "type": "二黄快三眼",
          "text": "万岁爷不准我把本奏告， 细听我佘氏女再奏当朝： 我杨家英雄将俱皆伤了， 并无有一个的能将英豪。 穆桂英生的来年纪老了， 她怎比当年时女将英豪。 杨排风她今年七十多了， 她也是难保国立下功劳。 只有那小杨藩年纪幼小， 两军前他不能枪对钢刀。 臣妾的迈年人无有用了， 我好比那枯树恐怕风摇。 万岁爷今准了臣妾本表， 我合家老幼小来把香烧。 佘氏女在金殿忙忙跪了， 万岁吓！ 为国的忠良将无有下稍。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "哎呀！太君，快快请起。"
        },
        {
          "character": "宋仁宗",
          "type": "二黄摇板",
          "text": "老太君在金殿珠泪滚滚， 不由得孤王我两泪淋淋。 这两边文武臣俱把泪含， 思一思想一想是要伤心。 左千思右万想无计意论， 我再与文武臣细说分明。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "吓，众卿。"
        },
        {
          "character": "包拯、岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "今日太君，要辞朝归故。还是准吓，还是怎样呢？"
        },
        {
          "character": "包拯、岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "太君辞朝怎好不准。想当年，他杨家八虎闯幽州九虎下南唐。到今日，太平江 山，万岁问太君居住何地，倘若是日后外邦要动刀兵，也好使人前去，搬兵取 救。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "众卿言之有理。 吓，太君辞朝，不知居住何地？日后寡人，也好使人前去问安。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "启奏万岁：此番回去，安居在那苟西番。想那地虽然是反邦，还有正直清泉可 饮。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "那苟西番，乃是我国平伏之处，孤将那边钱粮，免解京地，付与太君掌管钱粮 作为养老之敬。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "多谢万岁。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君今日。叫孤怎生得舍？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "日后还有回朝。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "众卿。"
        },
        {
          "character": "包拯、岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "明日准备酒宴，与太君饯行。"
        },
        {
          "character": "包拯、岳士奎、呼天保、恩孟",
          "type": "同白",
          "text": "领旨。朝事已毕，请驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四小军、岳士奎同上。〖牌子〗。"
        },
        {
          "character": "岳士奎",
          "type": "白",
          "text": "下官岳士奎，奉了万岁之命，准备酒宴，在长亭与太君饯行。 来，"
        },
        {
          "character": "四小军",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "岳士奎",
          "type": "白",
          "text": "带马长亭去者。"
        },
        {
          "character": "岳士奎",
          "type": "西皮原板",
          "text": "号炮三声出了城， 大小儿郎齐分明。 阵前功劳成何用， 一世为官一世空。 今日太君辞王去， 不知何日才回程。 叫人来带路长亭进， 万岁驾到报分明。"
        },
        {
          "character": "宋仁宗",
          "type": "内西皮导板",
          "text": "龙车凤辇出皇城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四龙套、四太监、二小太监、四宫女、包拯、恩孟、呼天保引宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮慢板",
          "text": "为王的我亲自至在长亭。 太君隐住西番地， 去了擎天柱一根。 西番地钱粮俱免尽， 功劳买动帝王心。 内侍臣摆驾长亭来进， 太君到此报分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆桂英上。"
        },
        {
          "character": "穆桂英",
          "type": "唱",
          "text": "来在长亭下了轿， 辞别万岁要动身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆桂英下。"
        },
        {
          "character": "宋仁宗",
          "type": "唱",
          "text": "她今一去不当紧， 孤王江山靠何人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨藩上。"
        },
        {
          "character": "杨藩",
          "type": "唱",
          "text": "来在长亭下能行， 拜别万岁要回程。 辞别万岁跨金蹬， 从今不到午朝门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨藩下。"
        },
        {
          "character": "宋仁宗",
          "type": "唱",
          "text": "长亭去了小爱卿， 那边来了老太君。"
        },
        {
          "character": null,
