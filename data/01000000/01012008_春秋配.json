{
  "script_id": "01012008",
  "title": "春秋配",
  "alias": [
    "捡芦柴；一名：拷打捡柴"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "姜秋莲",
      "hangdang": "小旦"
    },
    {
      "name": "李春发",
      "hangdang": "小生"
    },
    {
      "name": "乳娘",
      "hangdang": "老旦"
    },
    {
      "name": "贾氏",
      "hangdang": "丑旦"
    }
  ],
  "plot": "姜秋莲，商人姜韶之女，姜韶原配早故。继娶贾氏，性悍刻，有小家气，以姜秋莲系前室所生，非己出，故\n待之虐。每逢姜韶远出经商，则待之甚酷。日者见姜秋莲深处闺中，又不悦，即呼之出，命往郊野捡柴。姜\n秋莲以非素习，辞不能。贾氏怒，遂詈且杖姜秋莲，乳娘见之不忍，愿代往，贾氏不许。姜秋莲无如何，只\n得勉强与乳娘同往郊外捡拾芦柴。偶忆亡母，不禁泪簌簌如梗糜，放哭声。时有书生李华者，走马郊野，适\n与姜秋莲主仆遇，见姜秋莲哭甚哀，且人品不类农家女，不应做此事，度必有委屈，因一再穷诘之。乳娘初\n之不理，且斥其无状，不避男女嫌。李华既去复返。意终不释，宁忍耐不与校，而必欲得其究竟。姜秋莲在\n后，见其人英伟不凡，知非伧荒鄙夫，始以直告，并再三诘问李华姓名身世，欲以终身委之，乃去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾氏上。"
        },
        {
          "character": "贾氏",
          "type": "数板",
          "text": "闲来时装模作样，怒恼了拿刀弄棒，女儿称我为晚娘，常与老身算帐，妇人家 良心尽丧，狂妄狂妄。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "老身贾氏。前夫亡故，改醮姜门，配夫姜韶，倒也老实和顺。只是前房所生一 女，名叫秋莲，每日在我跟前，装模作样，不听我教训，思想打她一顿，奈无 由头。哦有了，郊外广出芦柴，不免叫她前去捡柴，她若不去，我就好打她个 稀烂。 秋莲哪里，走来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲上。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "姜秋莲",
          "type": "念",
          "text": "窗下绣鸳鸯，听唤出闺房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘上。"
        },
        {
          "character": "乳娘",
          "type": "念",
          "text": "雨过芭蕉润，风送桂花香。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "还不快来！"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘，母亲发怒，怎好向前？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哪有不去之理，惟要小心则个。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "母亲万福。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "站过去。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "安人，老奴有礼。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "又不是过年，又不是过节，要你见什么礼，气死老娘哦！"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "母亲为何生气？"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "郊外广出芦柴，我家无人去捡，故而把老娘气煞了。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "吓，母亲何不雇人去捡？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是吓，安人何不雇人去捡？"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "我们这等人家，哪有许多银钱，雇人去捡？秋莲，想你在家身闲无事，可以前 去捡柴。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "母亲，孩儿乃深闺少女，出外捡柴，恐被旁人取笑。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是吓。安人，大姐乃深闺少女，郊外捡柴，当真有人取笑。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "多嘴！这是我家之事，要你多什么嘴！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是是是。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "秋莲，你去是不去？"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "孩儿只会刺绣，不会捡柴。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "你敢讲三声不去？"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "孩儿不敢多讲，只是不去不去真不去。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "啊哟哟，她就偏偏都讲出来了！"
        },
        {
          "character": "贾氏",
          "type": "西皮摇板",
          "text": "你本是穷家女全不思量， 为什么朝夕里不出闺房？ 娇养得全不像民女模样， 懒得去作生活气煞老娘。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "劝母亲且息怒容儿细讲， 二八女理应该不出闺房。 捡柴事男子汉气力精壮，"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "哎，母亲吓！"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "去捡柴你孩儿不敢承当。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "你不承当，难道就罢了不成？看家法过来！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是。 安人，家法在此。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "将衣服脱下来。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐将衣服脱下来。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "哎呀呀！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "安人，衣服在此。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "秋莲，待老娘打个样子你看看！"
        },
        {
          "character": "贾氏",
          "type": "西皮快板",
          "text": "小贱人怎大胆这般性强， 娘跟前岂容你作怪装腔。 全不听娘言语实难轻放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏打姜秋莲。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "安人请息怒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲哭。"
        },
        {
          "character": "贾氏",
          "type": "西皮快板",
          "text": "打死了懒贱人料也无妨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲哭。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮快板",
          "text": "纵打死儿不去桑间濮上， 诚恐怕过路人说短道长。 况孩儿弓鞋小如何来往？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲哭。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "望母亲息雷霆斟酌商量。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "贾氏",
          "type": "西皮摇板",
          "text": "娘有命你擅敢这等违抗， 皆因是少家法惯了性常。 怒冲冲举起了无情棍棒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏打姜秋莲。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "安人不要打罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲哭。"
        },
        {
          "character": "贾氏",
          "type": "西皮摇板",
          "text": "顷刻间管教你命见阎王。"
        },
        {
          "character": "乳娘",
          "type": "西皮快板",
          "text": "瘦弱体怎受得无情棍棒， 守清规哪见你这等猖狂。 这大姐全杖你安人痛养，"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哎呀安人吓！"
        },
        {
          "character": "乳娘",
          "type": "西皮摇板",
          "text": "捡柴事有老奴一力承当。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "有你承当？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "老奴承当。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "你去也离不了她，她去也离不了你。起来罢。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "谢过母亲。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "秋莲，你去是不去？"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "孩儿不去。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "不去照打！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐去呢。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "是，去、去、去的。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "安人，大姐愿去了。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "怎么说，她愿去？ 啊呀呀我的乖宝宝儿子，你早讲愿去了，为娘烂手也不打你了。过来，这里有 镰刀、绳索在此，前午去，过午回来，要这模样两捆芦柴。如若没有，我就打 死你这两个贱人！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "请安人上香。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "啊呀呀，只管在此教训女儿，忘了佛前烧香。正是："
        },
        {
          "character": "贾氏",
          "type": "念",
          "text": "坐卧千声佛，晨昏一柱香。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "阿弥陀佛！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "我把你这老……"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "“老”什么？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "老安人老太太。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "怕你不叫老安人老太太！若是我不吃三官斋，我就端碗凉水，吞了你这个贱人。 哎呀呀，阿弥陀佛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏下。"
        },
        {
          "character": "乳娘",
          "type": "念",
          "text": "切齿恨毒妇。"
        },
        {
          "character": "姜秋莲",
          "type": "念",
          "text": "滴泪想娘亲。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐不要啼哭，同老奴前去捡柴。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "咳，乳娘吓。这是我连累你了。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "唉，大姐吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲换装围腰裙。"
        },
        {
          "character": "乳娘",
          "type": "西皮摇板",
          "text": "深闺女一旦里遭逢磨障，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲哭。"
        },
        {
          "character": "乳娘",
          "type": "西皮摇板",
          "text": "说什么连累我白发梅香。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "叹苍天把我的亲娘早丧， 思想起不由人哭断肝肠。"
        },
        {
          "character": "乳娘",
          "type": "西皮摇板",
          "text": "背地里紧咬着牙关不放， 恨泼妇真个是狠毒心肠。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "劝乳娘休把我晚母讪谤， 这也是奴命中该遭祸殃。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐不要啼哭，随我走吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲、乳娘同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李春发上。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "马来。"
        },
        {
          "character": "李春发",
          "type": "西皮原板",
          "text": "真个是英雄汉比天还大， 一霎时变作了绿林豪侠。 旌旗飘干戈动扬鞭走马， 我若是胆小的活活唬杀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李春发下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "乳娘上。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐走吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲上。"
        },
        {
          "character": "姜秋莲",
          "type": "二黄原板",
          "text": "出门来羞答答将头低下， 忍不住珠泪儿点点如麻。"
        },
        {
          "character": "乳娘",
          "type": "二黄原板",
          "text": "你看那狂风起百草齐压， 劝大姐免悲伤且把泪擦。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘。"
        },
        {
          "character": "姜秋莲",
          "type": "二黄原板",
          "text": "奴好比花未开遭逢雨打， 忍住声吞住气暗自嗟呀。"
        },
        {
          "character": "乳娘",
          "type": "二黄原板",
          "text": "可怜你鞋弓小金莲不大， 怎能得在荒郊如何挣扎。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐请到那边坐坐，待老奴捡柴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李春发上。"
        },
        {
          "character": "李春发",
          "type": "西皮摇板",
          "text": "如画女坐荒郊此事有诈， 我看她年纪儿不过二八。 细观她花容貌难描难画， 为什么坐荒郊眼泪巴巴？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "且住，那边有位老妈妈，待我向前问来。 吓，老妈妈，小生这厢有礼。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "原来一位君子，莫非迷失了路途？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "非也。请问老妈妈，这位大姐是妈妈什么人，为了何事，在荒郊啼哭捡柴？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "君子敢是问她么？她是我家大姐，我是她的乳娘，主仆二人在此捡柴，何劳君 子下问，多嘴。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "是是是，小生多嘴了。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "呸！啐！真是多嘴，请赶路去。 咳，少年人好不知趣。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "李春发",
          "type": "西皮快板",
          "text": "她那里恶狠狠言语不答， 我亦非起邪心有意阅查。 再看她梳油髻尚未出嫁， 不像个寻常的败柳残花。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "我到底要问个明白。 吓，妈妈。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "吓，又作什么事？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "我看你们并非小户人家，因何要这幼女郊外捡柴，必有缘故，请教明白。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "方才对你说过，她是我家大姐，我是她的乳娘，主仆二人在此捡柴，何劳君子 常常动问，若再不走，必讨没趣。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "哦，回去罢。"
        },
        {
          "character": "李春发",
          "type": "西皮摇板",
          "text": "这事儿不由人无端牵挂， 引得我无定意心乱如麻。 挽综缰斜踏镫扬鞭跨马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲哭。"
        },
        {
          "character": "姜秋莲",
          "type": "哭",
          "text": "我的娘亲吓！"
        },
        {
          "character": "李春发",
          "type": "西皮摇板",
          "text": "急煎煎忙下马再问根芽。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "到底要问个明白。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哦，好不老成。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "且住，我若再去问那妈妈，必讨没趣。哦，待我去问那位大姐。 吓大姐，小生这厢有礼。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "不便还礼，君子休怪。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "我看你们并非小户人家，如何来到荒郊捡柴，请教明白。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "旷野荒郊，男女不便答话，请君子远站一步，容奴告禀。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "如此，小生带马小涧饮水，当洗耳领教。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘这里来。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐作什么？"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "那位君子，有话问我。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐，旷野荒郊，男女交言不便，难免嫌疑。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘吓。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "虽则是男女们不便答话，"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "请教明白。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "吓吓吓，你还不曾去么？"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "蒙君子细盘诘再三问咱。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "请问大姐家住哪里？"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "家住在罗郡地魁星楼下， 我门前有几株槐柳交加。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "令尊叫什么名字？"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "我爹爹名姜韶字表德化，"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "作何生理？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "开当铺。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "因家贫少金银贸易天涯。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "大姐不在闺阁，因何故来此捡柴？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是她晚母逼出来的。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "哦，原来如此。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "在家中受不住晚母拷打，"
        },
        {
          "character": "姜秋莲",
          "type": "哭",
          "text": "哎呀娘亲吓！"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "呀，可怜。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "因此上同乳娘来捡芦花。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "原来被晚母打出来的。吓大姐，小生这里有一锭银子，大姐拿去买些柴薪，免 在外面受苦。请收下。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "君子休要献富，我家大姐，乃是大户，非比等闲，快将银子拿回去，恐染嫌疑。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "老妈妈，小生乃是恻隐之心，若有邪意，天见地知。银子放在地上，妈妈请收 下。小生去也。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "啊呀呀，果然难得吓。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘，请那君子留步。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "走远了，也就罢了。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "我还有话问他。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是吓，君子请留步。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "走远了。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐有话问你。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "大姐有话问小生，就回来了。 吓，大姐有何话说，小生还有赶路吓。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘这里来。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "话要少讲才好，天色不早了吓。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘吓。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "问君子因何事荒郊走马？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "君子吓，大姐问你，因何事在荒郊走马？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "小生送朋友而回。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐吓，君子是送朋友而回。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "问君子住罗郡哪里家门？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "君子住居何所？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "居住永寿街。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐，那君子家住永寿街。君子，我们与你乃是乡邻吓。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "正是乡邻。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "还将他名和姓一一留下，"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哈哈，哪有许多话问，我不去。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘去呢。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "吓，大姐请问君子尊姓大名？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "小生姓李名华字春发。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "他姓李名华字春发。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "再问他可登科，可登甲？你要细细问他。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哪有许多的唠唠叨叨，我不去。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘去呢。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "真真唠叨吓，君子可曾登科登甲？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "尚未科甲，早年入学。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哦，这等说起，敢是一位秀才。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "吓大姐，他是一位秀才。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "好吓。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "再问他椿萱茂高堂潇洒？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "问了半日话，这一句倒是该问的。 吓，君子，令尊可全福否？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "父母早年不在了。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哦，令尊早年不在了，倒也可怜。 吓，大姐，他的父母不在了。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "哦，下世了。哎呀爹娘吓！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "这叫什么名堂，是他的父母，要你啼哭？"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "再问他贵昆仲排行几家？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "又有许多的唠叨，我不去。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘去呢。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "正正不去了。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "乳娘去呢，去呢。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "咳咳，真真得罪。"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "好说好说。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "君子昆仲几位？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "小生孤自一人。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "就是你一人，没有兄弟了。 大姐吓，那君子孤身一人。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "再问他贵年庚青春多少？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "吓，君子，大姐问你年纪多少？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "小生今年才得弱冠。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "这一冠，倒把老身冠住了。看他的面相，也不过十七八岁。 吓，大姐，君子青春二九。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮原板",
          "text": "再问他绣房中可有混家？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "正正不害羞脸，这样话儿，怎么问得出口？"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "哎呀，问来问去，问到混家来了。唔，恐惹嫌疑，如此小生乘马去者。正是："
        },
        {
          "character": "李春发",
          "type": "念",
          "text": "堪笑天台路匪赊，阮郎一心饮胡麻。落花有意随流水，流水无情恋落花。"
        },
        {
          "character": "李春发",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "李春发",
          "type": "白",
          "text": "岂有此理！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李春发下。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哎呀呀，那君子见我家大姐问出那话，满脸通红，他竟乘马一去如飞，真乃圣 贤圣贤。 吓，大姐天色晚了，收拾回去了。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "回去罢。"
        },
        {
          "character": "乳娘",
          "type": "西皮摇板",
          "text": "好一个真君子可敬可夸， 又疏财又仗义盖世豪家。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "他一片志诚心必真不假， 我和他并无有半点葛瓜。"
        },
        {
          "character": "乳娘",
          "type": "西皮摇板",
          "text": "你日后若有这才郎出嫁， 配一对锦鸳鸯却也不差。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "我和你甚心事莫说此话， 婚姻事全在我一双爹妈。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "回去罢。"
        },
        {
          "character": "姜秋莲",
          "type": "西皮摇板",
          "text": "归家去又恐怕继母拷打， 纵然怕免不得要去见她。"
        },
        {
          "character": "姜秋莲",
          "type": "白",
          "text": "哎，我那亲娘吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲哭。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "大姐天色晚了，不要啼哭，回去了罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜秋莲、乳娘同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}