{
  "script_id": "01012015",
  "title": "一捧雪",
  "alias": [
    "审头刺汤；一名：反复小人"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "陆炳",
      "hangdang": "末"
    },
    {
      "name": "雪艳",
      "hangdang": "旦"
    },
    {
      "name": "汤勤",
      "hangdang": "丑"
    },
    {
      "name": "戚继光",
      "hangdang": "外"
    },
    {
      "name": "衙役甲",
      "hangdang": "净"
    }
  ],
  "plot": "上半本为陆炳汤勤复审人头，勘验真假。下半本乃莫雪娘会意伪嫁汤裱褙，成亲之夕，怀刃刺汤裱褙仇。\n《审头刺汤》，按莫成既代主替死，被戮蓟州后，严嵩命戚继光将头解京，令汤裱褙验视。汤裱褙察得非莫怀\n古真头，即直告严嵩。严嵩大震怒，立交刑部陆炳，提集戚继光雪娘及当时行刑刀斧手等一干人证，严密复\n讯，并令汤裱褙亦到堂督察。然诸人供词皆同，绝无破绽。陆炳拟诘讯复严，汤裱褙坚执不允，谓诸人皆串\n供朦听。陆炳与力争辨，汤裱褙不可，甚至欲诬陆炳通同。正争执间，忽朝旨下，命陆炳出斩他盗犯，陆炳\n乃将诸人证悉他押，唯留雪娘一人在，命汤裱褙代行盘诘。盖故与汤裱褙可乘之间，而阴伺其行为，以觇汤\n裱褙本心。讵意汤裱褙见四下无人，果向雪娘陈述思慕之情，且挟此案为求婚地。雪娘芳心自计，知既有挟\n而来，苟不遂其私，则非徒己一身无幸，即戚继光一干人，恐亦皆不免，因伪诺之。迨陆炳事毕返，汤裱褙\n果即改词称人头非伪，无待再讯，惟要求案定后雪娘当给彼为妾。陆炳早烛其奸，惟欲图脱诸人冤，而使案\n速结，故许之。及临行，陆炳暗授雪娘意，雪娘会悟去。既而私愿既得遂，乃乐极。酩酊入洞房，遂为雪娘\n刺死。雪娘亦即自刎，以明其志。",
  "notes": "此出在《搜杯追捕·莫成代戮·蓟州堂》之后。其后本为《雪杯圆》，即莫怀古生还也。此剧相传为明季苏\n浙间故事，昆班中久已编演，近海虞有镇集名莫城者，或谓即莫成之故里也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陆炳上。"
        },
        {
          "character": "陆炳",
          "type": "引子",
          "text": "身受皇恩禄，千钟品为尊。"
        },
        {
          "character": "陆炳",
          "type": "念",
          "text": "自幼读书贯古今，紫袍钦赐享太平。圣上宠爱严阁老，不用吹详绣五刑。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "下官陆炳，在嘉靖驾前为臣，官居锦衣卫九堂前程。莫仁兄进京补官，酒醉冒 犯严公，斩首冀州，人头不明。今日发在本院台前审问，汤勤必要来拿我之成 错。来，伺候。"
        },
        {
          "character": "汤勤",
          "type": "内白",
          "text": "汤老爷到。"
        },
        {
          "character": "手下",
          "type": "白",
          "text": "汤老爷到。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "说来他就来了。本当下个“请”字，又恐他消受不起。且看严公分上，请。"
        },
        {
          "character": "手下",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤勤上。"
        },
        {
          "character": "汤勤",
          "type": "念",
          "text": "只为人头事，慌忙到此间。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "少礼。请坐。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "不敢坐。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "且看严公分上。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "提起严府二字，倒要坐坐。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "请问汤老爷，莫非前来拿我的错处么？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "为何去而太急？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "卑职到此，一言未发，怎说错处？"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "同审人头一事，还要先生指教。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "这个自然。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "传严府二校尉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "手下招二校尉同上。雪艳、戚继光同上。"
        },
        {
          "character": "雪艳、戚继光",
          "type": "同白",
          "text": "叩见大人。"
        },
        {
          "character": "手下",
          "type": "白",
          "text": "禀爷：人犯到齐。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "听点：犯官戚继光、犯妇雪艳下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳、戚继光同下。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "严府二校尉，莫爷在哪里拿获？"
        },
        {
          "character": "二校尉",
          "type": "同白",
          "text": "在西门外柳林下拿获。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "什么时候？"
        },
        {
          "character": "二校尉",
          "type": "同白",
          "text": "黄昏时候。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "怎么进城？"
        },
        {
          "character": "二校尉",
          "type": "同白",
          "text": "叫开城门，劈开关闸，击了戚大人堂鼓。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "黄昏时斩人不便。"
        },
        {
          "character": "二校尉",
          "type": "同白",
          "text": "戚大人说了：此事大了，写个担代。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "怎么担代？"
        },
        {
          "character": "二校尉",
          "type": "同白",
          "text": "头门之外，仪门之内，差一兵丁，将小房外面下锁，里边加闩。次日五鼓天明， 看着绑，看着斩，人头打入囚桶，回复严爷。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "下去。传戚继光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二校尉同下。戚继光上。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大人。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "汤大人，想戚继光也是个阃外八台前程，这人头无非连累，与他个坐位。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "但凭大人。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "戚继光，汤老爷赐你个坐位，日后要记得他。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "谢汤老爷。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "严府二校尉，追拿莫爷，在哪里拿获？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "在西门外，柳林之下拿获。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "什么时候？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "黄昏时候。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "怎么进城？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "叫开城门，劈开关闸，击了堂鼓。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "黄昏时候，斩人不便。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "要个担代。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "怎么担代？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "头门之外，仪门之内，差个兵丁，将小房外面上锁，里边加闩，锁上加封。次 日五鼓天明，看着绑，看着斩，人头打入囚桶，回复严爷。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光下。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "汤老爷，人头是真的。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "他四人口供，俱是一样。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "大人，此言差矣。想他四人，日间并马而，夜来同宿而眠，乃是串通口供，欺 瞒大人。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "如此又有一个审法。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "怎么审法？"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "前日监斩人头未曾发回，一概摆在丹墀，莫爷人头，也放在其内。雪艳若认得 人头，便是真的。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "大人高才。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "传雪艳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "手下招雪艳上。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "大人。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "你夫君人头，现在丹墀，抱来见我。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳抱头。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳下。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "人头是真的。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "丹墀无数人头，雪艳不抱。单单抱了他丈夫的人头痛哭，岂不是真的？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "大人，她好有一比。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "比什么？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "猫儿哭鼠——假慈悲。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "两边衙役为何掉下泪来？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "他们也好有一比。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "比什么？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "圣贤看兵书——替古人耽忧。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "先生为何不哭？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "又不是我亲，哭他怎的？"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "莫爷他待你如何？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "情爱不薄。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "既是待情不薄，何不说人头是真？"
        },
        {
          "character": "陆炳",
          "type": "二黄摇板",
          "text": "得恩不报非君子， 反把恩情当作仇。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "回复严爷。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "严爷问道？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "说陆大人糊里糊涂落了案。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "严爷是狼？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "不是狼。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "是虎？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "不是虎。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "既不是狼虎，难道吞噬我陆炳不成？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "不会吃人，他所下之官，也要惧怕三分。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "那么又有个审法。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "怎么审问？"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "传戚继光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光上。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "此区区之事，问得不明。来，看刑。"
        },
        {
          "character": "官员",
          "type": "内白",
          "text": "圣旨下。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "带下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光下。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "先生，还是接旨，还是审问？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "接旨为尊。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "请至书房。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤勤下。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "官员上。"
        },
        {
          "character": "官员",
          "type": "白",
          "text": "旨下：十三名犯官，命陆炳在乔田出决，旨毕谢恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "官员下。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "有请汤先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤勤上。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "圣旨到来何事？"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "十三名犯官，命老夫监斩。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "监斩的事大。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "将雪艳吊在西廊，你可背问。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "领命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤勤下。戚继光上。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "戚继光，你随我轿后，看老夫监斩。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "是，开道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆炳、戚继光同下。"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "陆大人去了，我且到西廊偷观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳上。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "那边来的可是汤先生？"
        },
        {
          "character": "汤勤",
          "type": "白",
          "text": "便是。"
        },
        {
