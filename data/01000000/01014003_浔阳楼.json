{
  "script_id": "01014003",
  "title": "浔阳楼",
  "alias": [
    "闹江州"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "宋江",
      "hangdang": "老生"
    },
    {
      "name": "戴宗",
      "hangdang": "副净"
    },
    {
      "name": "二差役",
      "hangdang": "丑"
    }
  ],
  "plot": "宋江发配在江州，结识戴宗、张顺、李逵等；虽为军犯，亦可以优游岁月。一日，寻访三友不遇，独自一人\n至浔阳楼，饮酒遣兴。醉后在粉壁间任意涂鸦，被无为军通判黄文炳瞧见，指为反诗，抄呈太守蔡得章。命\n戴宗提取宋江，治以叛逆之罪。戴宗至牢营，私将情节备细告知。宋江闻言，惶恐无措。明知罪若成立，关\n系实为匪细，不特自己身命难保，即父母妻子宗族友朋，必致牵累，再三央求援救。戴宗为之设一装疯之计，\n希图暂时掩饰。及庭讯时，宋江遂语无伦次。大都所问非所对。问官欲辨真伪，传差役抬粪水一桶安放堂\n上，试其口鼻有无知觉。宋江无可如何，只得不顾臭秽，饱尝一种“特别滋味”，因此暂且收禁，再行定夺。",
  "notes": "枥老编此剧考，不禁莞尔发噱，又喟然兴叹曰：能忍人所不能忍，那是宋江机械变诈之心出人头地处。所以，\n后为盗中之渠魁，横行河朔一带也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宋江上。"
        },
        {
          "character": "宋江",
          "type": "西皮原板",
          "text": "昨日里在江楼把酒饮， 只吃得醉醺醺转回牢城。 迈步儿且把小营房进， 等待了戴贤弟把话来云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戴宗上。"
        },
        {
          "character": "载宗",
          "type": "念",
          "text": "忙将衙中事，报与大哥知。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呀，贤弟来了。"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "大哥，大事不好了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "只因昨日，大哥在浔阳楼上饮酒，酒后在粉壁墙上，曾题反诗一首，被那黄文 炳看见，报与州官知道。适才将小弟唤进衙去，叫小弟将大哥拿到州衙，问出 口供，就要就地正法！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "就地正法！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江昏厥。"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "大哥醒来！"
        },
        {
          "character": "宋江",
          "type": "西皮导板",
          "text": "听一言不由人三魂渺渺，"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "贤弟呀！"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "吓得我魂灵儿飞上九霄。 走向前来忙跪倒， 望贤弟搭救我性命一条。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "贤弟，你要快快想一妙计，搭救愚兄性命才好！"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "事到如今，哪有妙计？大哥你快快打扮作一疯汉，混他一时，再作道理。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "事到如今，只好如此。正是："
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "闭门家中坐，祸从天上来。"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "大哥速速改扮，小弟要少陪了。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戴宗下。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "待我改扮起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二差役同上。"
        },
        {
          "character": "二差役",
          "type": "同念",
          "text": "奉了太爷命，捉拿造反人。"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "伙计，咱们太爷叫拿造反之人，叫什么葱姜？"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "宋江。"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "不错，宋江。这宋江，他到底在什么地方呀？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戴宗上。"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "你们敢是去拿宋江的么？"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "来来来，随我来！"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "好，正在为难的时候，偏偏遇见戴院长啦，不然我们一辈子也找不着他！"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "到了。宋江想必正在里面。我少陪了。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "请便请便。"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "待我喊叫一声。 我说宋江，你出来！"
        },
        {
          "character": "宋江",
          "type": "内西皮导板",
          "text": "乔装改扮安排定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江上。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "假装疯魔有病人。 悔不该在江楼来把酒饮， 无故地题诗句惹下祸根。"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "宋江，你出来！"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "我这里迈步来忙观定， 却原来是我的结发人。 叫一声贤妻你来得好， 你我到房中叙一叙恩情。"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "你是他的媳妇呀？"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "你才是他的媳妇哪！"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "我是他媳妇的爹！"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "扭回头来把话论， 却原来是岳父到我门。"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "你原来是他的丈人呀！"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "得啦！别玩笑。我说宋江，太爷传你哪，跟着我们走吧。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "叫岳父与贤妻把路引， 你我一同见圣君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江、二差役同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、州官同上。"
        },
        {
          "character": "州官",
          "type": "念",
          "text": "奉了太尊令，审问造反人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "差役甲上。"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "启太爷：宋江拿到。"
        },
        {
          "character": "青袍官甲",
          "type": "白",
          "text": "带上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "差役乙押宋江同上。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "我大摇大摆往前进， 上面厢坐的是对头人。 我撩袍端带上龙庭， 问我一言我答一声。"
        },
        {
          "character": "州官",
          "type": "白",
          "text": "胆大宋江，见了本州为何不跪？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你是何等样人，我岂能跪你！"
        },
        {
          "character": "州官",
          "type": "白",
          "text": "你在酒楼题了反诗，你要从实招来！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "想我宋江，乃是天神下界。吾奉玉帝敕旨，带领十万天兵天将，去至京城，扫 荡奸臣。我不久就是皇帝了。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "我奉上方玉帝令， 带领十万鬼神兵。 除却朝中众奸佞， 一统山河我坐朝廷。"
        },
        {
          "character": "州官",
          "type": "白",
          "text": "看宋江，满口疯话，但不知是真是假。呵哈有了：待我将些尿粪臭秽之物，叫 他去用，若是吃，便是真疯；他若不吃，便是装就。 来！"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "州官",
          "type": "白",
          "text": "将尿粪抬一桶上来。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "嗻！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二差役同下，抬桶同上。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "嘿，好臭好臭！ 粪抬到。"
        },
        {
          "character": "青袍官甲",
          "type": "白",
          "text": "宋江，你莫要欺哄本州。堂下有粪水一桶，你去用来。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呵哈，哈哈哈！我今到此，你还要费心设宴。好，待我用来。喝喝，我就叨扰 了。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "多谢兄台太多情， 来此还要设席珍。 众位何妨同来请，"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "这样的好东西，你请吧，我们没有这个造化。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "他一个一个就不应声。 看起来你等无福分， 他不识海味与山珍。 我这里抓一把就四面洒，"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "有道是“主不请，客不饮”，你请用啊！"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "我洒他个满堂乱纷纷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江向四周泼洒粪水。"
        },
        {
          "character": "州官",
          "type": "白",
          "text": "来！将宋江暂且收禁，待我禀报蔡大老爷，任他发落便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}