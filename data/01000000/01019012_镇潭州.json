{
  "script_id": "01019012",
  "title": "镇潭州",
  "alias": [
    "九龙山；一名：收杨再兴"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "岳飞",
      "hangdang": "老生"
    },
    {
      "name": "杨再兴",
      "hangdang": "武生"
    },
    {
      "name": "岳云",
      "hangdang": "小生"
    },
    {
      "name": "牛皋",
      "hangdang": "净"
    },
    {
      "name": "杨景",
      "hangdang": "外"
    },
    {
      "name": "徐仁",
      "hangdang": "外"
    },
    {
      "name": "施全",
      "hangdang": "末"
    }
  ],
  "plot": "杨再兴占据九龙山为盗，势甚猖獗。岳武穆率师征讨，牛皋为先锋，抵山讨战，为杨再兴所败。武穆爱其勇，\n欲收入帐下，以资臂助。亲身临阵，与杨再兴订明，两下自决胜负，不用帮手。武穆传令大小将士，远立\n观战，不准上前。二人大战至三百余合，因天晚歇息。次日又战，正在难解难分之际，公子岳云解粮到，不\n知有约在先，遂骤马助战。杨再兴讥武穆背约，又谓军令不严，无元帅之资格，匆匆收兵。武穆回营，立命\n斩岳云。幸牛皋与众将再三哀求，始得免死。重责四十军棍，送往山前，听杨再兴验看刑伤，作为负荆请罪。\n杨再兴亦心许武穆之公允。而武穆因杨再兴武艺惊人，异常焦急，竟至夜不成寐。朦胧间，梦杨再兴曾祖\n杨景，授以杀手锏。翌日击杨再兴落马，杨再兴乃心悦诚服，归降于武穆。",
  "notes": "剧本事实，出于《说岳全传》，无甚差别，唯谓杨再兴兵犯潭州，似有异点。传载岳武穆征洞庭湖水寇杨么，\n驻节潭州，当在收服杨再兴之前也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、牛皋、岳云、三将、岳飞同上。〖点绛唇〗。"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "文韬武略智超群，报国精忠一片心。统领雄兵扫贼寇，灭却金人答圣君。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅，姓岳名飞字鹏举，宋室驾前为臣，官拜四路招讨使。今有九龙山贼寇作 乱，是俺带领人马，前来征剿，看前面已是潭州地面。 牛皋听令。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "命你带领三千人马，攻打头阵，须要小心。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、牛皋同下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "岳云听令。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "命你解押粮草，军前听用。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "看香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "弟子岳飞，祝告山川社稷，旗纛尊神。此番奉命，带领人马，扫荡贼寇。但愿 此去，旗开得胜，马到成功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同绕场，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴上，拉起霸双虎头。"
        },
        {
          "character": "杨再兴",
          "type": "念",
          "text": "统领貔貅镇九龙，将军八面逞威风。腰悬三尺青锋剑，要夺宋室锦江山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手同暗上。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "俺，杨再兴，乃山后磁州郡人士。我祖上世代忠良，忠心报国。俺只为朝中奸 佞专权，馋臣当道，是俺不愿为官，就在这九龙山，自立为王。今特带领人马， 攻取潭州。 众儿郎，兴兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、牛皋同上，对阵。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "俺乃岳元帅麾下，前战先行，牛皋是也。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "敢么是汴梁小校场，枪挑小梁王的岳飞么？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "然也。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "你叫你家元帅前来会俺。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "住了。想你这小小毛贼，何用俺家元帅。休走，吃你牛爹爹一鞭。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "看枪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋败下，杨再兴随四龙套、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、三将、岳飞同上，徐仁上，出城迎接，众人同进城，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、三将、岳飞、徐仁同上。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "末将有何德能，敢劳恩师，迎接十里长亭之外。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "元帅领兵，到处闻风丧胆。今日潭州，危在旦夕，百姓生命，全赖元帅援救。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "惶恐吓，惶恐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞看。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "那牛皋，往哪里去了？"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "牛将军与贼兵交战，相必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、牛皋同上。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "谢元帅"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "贤弟出阵，胜负如何？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "是俺到了两军阵前，遇一年少的娃娃。被他这么一枪，就将我枪拨回来了。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "可曾问来将的姓名。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "这，倒不曾问得。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "呣，随愚兄出兵多年，办事还是这等粗鲁，两军阵前，与敌人交阵，不问来将 的名姓，倘若得胜回来，叫愚兄怎能上得功劳簿？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "那厮曾经言道：他在什么小校场，见过元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "敢么是杨再兴么？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "正是那个囚囊的。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "贤弟后帐歇息。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "谢元帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "待本帅会他一会。众将官，抬枪备马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐仁下，四龙套、四下手、杨再兴同上，会阵。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "来着敢是杨将军，别来无恙。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "俺与你素昧平生，何言别来无恙。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "你我在汴梁城小校场一别，直到如今，难道将军就忘怀了？"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "你敢么就是在汴梁城小校场，枪挑小梁王的岳飞么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "岳元帅，你看今日，当今懦弱，奸臣专权，残害忠良。以俺相劝，你我合兵一 处，反上临安，得了宋室天下，你我平分疆土。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞冷笑。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "你意如何？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "杨将军，此言差矣。想你杨家，历代忠良，世受国恩。将军为何违背祖训，落 草为寇。以本帅相劝，弃暗投明，归顺吾主，少不得封侯之位。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "既然如此，你我今日比试。倘若我胜不过你，情愿马前归顺，你呢？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "也罢，我若胜不过你，愿将潭州献上。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "丈夫一言。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "岂能反悔。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "如此请。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "且慢。今日你我比试，只许参将观战，不许助战，你意如何？"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "好，你我一同传令。"
        },
        {
          "character": "岳飞、杨再兴",
          "type": "同白",
          "text": "呔！众将听者，今日阵前交锋，只许掠阵，不许助战，违令者斩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞、杨再兴同起打，对夺枪，同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四旗车、岳云同上。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "俺，岳云。奉了父帅之命，押解粮草，军前听用。 众将官，趱行者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云、四旗车同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（牛皋、三将同上，同上桌观阵。岳飞、杨再兴夺枪同上，同开打，岳飞败下，杨再兴耍枪花，下。牛皋、"
        },
        {
          "character": null,
          "type": "text",
          "text": "三将自桌上同跳下。）"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "众位将军，你看元帅，往日出兵，百战百胜，今日为何败下阵去？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四旗车、岳云同上。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "参见众位叔父。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "岳云，你父与杨再兴交战，败下阵来，你还不上前，快快帮助。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云提锤，上马，下。"
        },
        {
          "character": "三将",
          "type": "同白",
          "text": "你叫公子出马，岂不违了元帅将令？倘若降罪下来，何人担待？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "不要紧，有我呐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、三将同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "岳飞上，杨再兴追上，同开打。岳云冲上，打杨再兴，杨再兴败下。岳飞气，追下，岳云下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴上，转场，岳飞上，拦。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "杨将军，你我再战三合。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "住了。想你身为天下都招讨，兵马大元帅，军令不严，何以服天下。岂不令天 下人耻笑！"
        },
        {
          "character": "杨再兴",
          "type": "笑",
          "text": "哈哈，吓哈。吓哈哈哈哈哈！"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "呀呀呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴下。岳飞气，牛皋、三将、岳云同上。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将岳云，与我绑了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞下，牛皋、三将、岳云同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、牛皋、三将同上，四上手绑岳云同上，岳飞上，枪刺岳云，牛皋、三将同挡。岳飞坐高台。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将岳云绑上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云跪。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "唗！胆大岳云，为父与杨再兴交战，传令在先，不许助战，违令者斩。众家叔 父，俱不敢犯为父将令。你这奴才，竟敢犯为父的将令么？ 来，推出斩了！"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "启禀爹爹：想孩儿离家之时，我祖母曾经言道，此番前到营中，要对爹爹言讲， 孩儿年幼，若有犯罪，该斩首者打上几下，应打者骂上几句。今日既然犯了 爹爹的将令，叫孩儿再见祖母一面，再斩孩儿，纵死九泉，也得瞑目吓！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将岳云托上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同抬岳云仰面。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "岳云，我儿，儿吓！你方才言道，还想你的祖母娘亲么？只怕今生，不能得够 了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞执令箭，牛皋、三将同求情。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "可知本帅令出山岳动，严法鬼神惊。斩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞掷令箭，牛皋接令箭。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "牛叔父，想孩儿解粮好好，都是你叫我助战，今日犯了我家爹爹得将令，要将 我斩首，岂不是你害了我了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "元帅，想你今日与那杨再兴交战，堪看败了……"
        },
        {
          "character": "三将",
          "type": "同白",
          "text": "胜了！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "他也配！若不是公子出马，你焉得活命？也罢，我牛皋也不活着了，待我自刎 了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三将同拦。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "岳云，为父本当将你斩首，念在你众家叔父讲情，死罪已免，活罪难逃。 牢子手，与我重责四十军棍！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同打岳云。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "一十！二十！三十！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋俯岳云身，四上手同打。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "四十！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同扶岳云跪。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "施全听令。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "命你将岳云，送在杨再兴营中。对他言讲：说岳云解粮在先，本帅发令在后， 因此违犯军规。本要将他斩首，念在满营众将讲情，重责四十军棍，送他前来 验伤。快去快回，不得有误。吩咐掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞下，牛皋、三将同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、杨再兴同上。"
        },
        {
          "character": "杨再兴",
          "type": "西皮摇板",
          "text": "适才间阵前打一仗， 岳云武艺果然强。 将身且坐宝帐上， 且听儿郎报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施全扶岳云同上。"
        },
        {
          "character": "岳云",
          "type": "西皮摇板",
          "text": "帐中奉了爹爹命，"
        },
        {
          "character": "施全",
          "type": "西皮摇板",
          "text": "来到营前把话明。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "岳元帅的差官要见。"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "候着。 启大王：岳元帅的差官要见。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "唤他进来。"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "唤你等进来。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "杨将军在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云怒视杨再兴。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "将军请坐，到此何事？"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "只因我家公子，奉令解粮在先，元帅传令在后，因此误犯军令。我家元帅，本 要将公子斩首，念在众将讲情，死罪已免，活罪难饶。将公子重责四十军棍， 特命俺将公子送来，请你验刑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴看。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "这才是做元帅的道理。将军请回，拜上你家元帅便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施全扶岳云同下。"
        },
        {
          "character": "杨再兴",
          "type": "西皮摇板",
          "text": "人言岳飞营规整， 话不虚传果是真。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴下，四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒、杨景同上。"
        },
        {
          "character": "杨景",
          "type": "念",
          "text": "生前为大将，死后做忠魂。"
        },
        {
          "character": "杨景",
          "type": "白",
          "text": "吾乃杨景阴魂是也。只因我家玄孙杨再兴，落草为寇。岳元帅有意收服于他， 奈他武艺高强。我不免前去宋营，与元帅托兆，将杨家撒手锏，传授与他便了。 众鬼卒，驾起阴风，宋营去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。杨景、四鬼卒同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "岳飞上。"
        },
        {
          "character": "岳飞",
          "type": "二黄原板",
          "text": "昨日里打一阵龙争虎斗， 战不过杨再兴满脸含羞。 夜来时巡营哨小心防守， 怕的是小胡儿来把营偷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒、杨景同上。"
        },
        {
          "character": "杨景",
          "type": "二黄摇板",
          "text": "恼恨那杨再兴甘为贼寇， 全不顾俺杨家爱国勋猷。 叫鬼卒驾阴风宋营后， 见了那岳帅细说根由。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "请问将军，尊姓大名？"
        },
        {
          "character": "杨景",
          "type": "白",
          "text": "俺乃杨景是也。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "原来是前辈老先生，失敬了。"
        },
        {
          "character": "杨景",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "老先生到此，必有所为。"
        },
        {
          "character": "杨景",
          "type": "白",
          "text": "只因我的玄孙杨再兴，落草为寇，辱没祖宗。望求元帅，收留他以做鞍前马后。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本要说他归降宋室，怎奈他武艺高强，难以取胜，不能折服。"
        },
        {
          "character": "杨景",
          "type": "白",
          "text": "这有何难。俺杨家的梅花枪，暗藏撒手锏，传授元帅，定能取胜。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "如此晚生领教了。"
        },
        {
          "character": "杨景",
          "type": "二黄摇板",
          "text": "俺杨家梅花枪暗藏撒手，"
        },
        {
          "character": "岳飞",
          "type": "二黄摇板",
          "text": "老将军世代臣万古名留。"
        },
        {
          "character": "杨景",
          "type": "二黄摇板",
          "text": "望元帅收服他鞍前马后，"
        },
        {
          "character": "岳飞",
          "type": "二黄摇板",
          "text": "他本是将门子一定封侯。"
        },
        {
          "character": "杨景",
          "type": "二黄摇板",
          "text": "脱绨袍亮出了玲珑甲胄， 这一锏你必须牢记心头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞睡。"
        },
        {
          "character": "杨景",
          "type": "二黄摇板",
          "text": "叫鬼卒忙带路宋营口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨景、四鬼卒同下。院子上，推门。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "元帅醒来。"
        },
        {
          "character": "岳飞",
          "type": "二黄摇板",
          "text": "醒来时鸡报晓红日当头。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官，带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、三将同上，四龙套、杨再兴同上。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "杨将军，昨日可曾验过小儿的责？"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "元帅可谓军令森严。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "今日，还要与将军比试数合。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞、杨再兴同起打，三转场，岳飞锏打杨再兴，杨再兴落马，岳飞下马，扶杨再兴。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅一时失手，请将军上马再战。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "末将情愿归顺帐下，望祈元帅收留。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将军弃暗投明，愿与将军，结为金兰之好。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "待末将去至山头，将人马调齐，同赴大营去者。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将军请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞、杨再兴同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}