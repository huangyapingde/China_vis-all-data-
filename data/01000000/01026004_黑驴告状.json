          "type": "白",
          "text": "老婆快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李妻上。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "什么事情，这样大惊小怪的呀？"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "买卖到了，要发财啦。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "什么买卖，要发财呀？"
