          "character": "包拯",
          "type": "白",
          "text": "打道回衙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四邻居、翟绅、白桂娥、范仲禹、地保同上，同转场。黑驴引王朝、马汉同上。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "你们这一伙人，在此做甚？"
        },
        {
          "character": "地保",
          "type": "白",
          "text": "原来是王、马二位老爷到了。启禀二位老爷：现有一桩奇案，甚是难明。此一 女子，分明是范相公的令正夫人，她倒反说她是山西的客人；这一位客人，他 反说是范相公的妻子。你看奇怪不奇怪。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "我等奉了包大人之命，特来查访。走，大家一同去见包大人便了。"
        },
        {
          "character": "地保",
          "type": "白",
          "text": "好了，大家去见包大人，再做道理。快走，快走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉引众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四青袍、张龙、赵虎引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "宋天子坐江山人称有道， 包文正断阴阳不差分毫。 法堂上虎头铡谁人不晓， 秉忠心保定了宋室皇朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同上。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "启大人：小人随同黑驴，到了东关以外，见一起奇案，特来禀告。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "可曾将人犯带到？"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "俱已带到。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "好，带上堂来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人、翟绅、白桂娥同上，同跑。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "那一汉子，姓甚名谁，一一道来。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "奴家白桂娥，嫁与范仲禹为妻。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "王朝、马汉，范仲禹可曾到案？"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "现在衙外。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "请范相公后堂待茶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉引范仲禹同上，范仲禹参拜包拯，下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你且讲来。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "只因我丈夫进京赶考，将奴留在家中。可恨葛登云老贼，将奴抢到他府内，立 逼成亲，是奴不允，因此悬梁自缢，将我尸首盛殓，停在菩提寺内。是奴还阳， 望求大人做主。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "那一女子，姓字名谁，快快讲来。"
        },
        {
          "character": "白桂娥",
          "type": "白",
          "text": "大人容禀："
        },
        {
          "character": "白桂娥",
          "type": "西皮摇板",
          "text": "大人在上容我禀， 家住山西名翟绅。 孤身骑驴把京进， 那日路过李保门。 借宿一宵把酒饮， 被他害了命残生。 是我还魂来到此， 叩求大人把冤伸。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "听一言来自沉吟， 到叫老夫费调停。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "王朝、马汉，将人犯暂且带下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉引翟绅、白桂娥同下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "转堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套暗同下。〖吹打〗。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且住，适才听他二人之言，阴阳颠倒。待老夫去到阴曹，查点一番，便知分晓。 来，看阴阳枕伺侯。"
        },
        {
          "character": "包拯",
          "type": "二黄原板",
          "text": "公堂上他二人一一禀告， 这件事看起来甚是蹊跷。 男变女，女变男，阴阳颠倒。 叫马汉再唤王朝，看过了阴阳枕找牙床卧倒，"
        },
        {
          "character": "包拯",
          "type": "二黄摇板",
          "text": "去到那阴曹府巡查一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯入帐子，睡。〖起三更鼓〗。"
        },
        {
          "character": "包拯",
          "type": "二黄导板",
          "text": "森罗殿我也曾详查细问，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯出帐，王朝、马汉同暗上。"
        },
        {
          "character": "包拯",
          "type": "二黄摇板",
          "text": "小李保图银财谋害翟绅。 白桂娥守贞节悬梁自尽， 大胆的老太师葛登云。 似这等大王法你全然不论， 明日里我定要启奏当今。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，升堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "升堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四青袍、王朝、马汉、张龙、赵虎引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "念",
          "text": "铁面无私神鬼寒，谁人不知包青天。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，将人犯带上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉引翟绅、白桂娥同上。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "翟绅、白桂娥，你二人乃是认错尸身，借尸还魂。 王朝、马汉，看老夫照妖镜伺侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝呈镜，包拯接镜，照。"
        },
        {
          "character": "包拯",
          "type": "二黄摇板",
          "text": "我这里用宝镜来照定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白桂娥魂、翟绅魂同上，白桂娥魂附白桂娥，翟绅魂附翟绅。"
        },
        {
          "character": "包拯",
          "type": "二黄摇板",
          "text": "一霎时管叫尔魂归己身。"
        },
        {
          "character": "翟绅",
          "type": "二黄导板",
          "text": "三魂渺渺归了壳，"
        },
        {
          "character": "翟绅",
          "type": "二黄摇板",
          "text": "心中好似水来浇。 恼恨贼徒小李保， 害我性命为哪条！"
        },
        {
          "character": "白桂娥",
          "type": "二黄导板",
          "text": "一时间只觉得昏迷不醒，"
        },
        {
          "character": "白桂娥",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "白桂娥",
          "type": "二黄摇板",
          "text": "三魂七魄附了身。 心中只把葛云登恨， 害得奴一命归了阴。 今日幸喜得活命， 叩请大人把冤伸。"
        },
        {
          "character": "包拯",
          "type": "二黄摇板",
          "text": "李保图财害翟绅， 逼死白氏是葛云登。 管叫他一命偿一命， 老夫王法不容情。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，将翟绅带下堂去。待等将李保夫妇传到，再行定罪。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟绅下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，将白氏带至后室，交付范相公，带回家去。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "白桂娥",
          "type": "白",
          "text": "多谢大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白桂娥下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老贼葛云登，乃是告老的太师。待老夫明日上朝，参奏一本，请旨定罪。 左右，掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}