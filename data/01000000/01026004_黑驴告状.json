        {
          "character": "翟绅",
          "type": "白",
          "text": "太费心了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李妻托酒菜上。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "酒里头下好了药啦扉有？"
