        {
          "character": "李妻",
          "type": "白",
          "text": "下好了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李保接酒菜，李妻下。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "酒也来了，菜也来了，你老人家请用吧。待我替你斟上一盅。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "你也喝一盅。"
