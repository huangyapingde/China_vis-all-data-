    },
    {
      "name": "李保",
      "hangdang": "丑"
    },
    {
      "name": "李妻",
      "hangdang": "彩旦"
    },
    {
      "name": "邻居甲",
      "hangdang": "外"
    },
    {
      "name": "邻居乙",
      "hangdang": "丑"
    },
    {
      "name": "邻居丙",
      "hangdang": "末"
    },
    {
      "name": "地保",
      "hangdang": "丑"
    },
    {
      "name": "白斌",
      "hangdang": "小生"
    }
  ],
  "plot": "范仲禹妻白氏，情急自尽。奸相葛登云，命家院寄柩在菩提寺内。山西客翟绅，往京城收账，半路换骑驴子。\n李保夫妇，谋财害命。翟绅、白氏，借尸还魂，阴差阳错，互投躯壳。包公下朝，黑驴冲道。包公卧游仙\n枕，至阴曹地府，勘察情由。用照妖镜，转换男女两魂。各归自身。葛登云、李保，均治以应得之罪。遂成\n定谳。",
  "notes": "本考第三册，载有《琼林宴》一出，至《打棍出箱》为止。编考者，已穷源溯委，详细阐述。然观剧诸君，\n未窥全豹，不免有所缺陷。今觅得北京名艺员编排之后本，以餍诸君之愿望。\n世传包公断过七十二件无头案，此事亦七十二中之一。坊间有《包公案》小说一书，翻阅之，其真相自然明\n了。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "白桂娥上。"
        },
        {
          "character": "白桂娥",
          "type": "二黄摇板",
          "text": "心中恼恨葛登云， 擅抢民妻为何情。 苦苦逼奴成婚配， 岂肯做此下贱人。"
        },
        {
          "character": "白桂娥",
          "type": "白",
          "text": "奴家，白桂娥。嫁与范仲禹为妻。丈夫上京赶考。奴家被葛登云老贼，抢进府 来。要与奴成婚配。是奴再三推却，假做染病在身。今日老贼又命人，苦苦逼 迫。倘若老贼到此，奴的名节何在？也罢。不免拜谢丈夫夫妇之情，寻一自尽 了罢。"
        },
        {
          "character": "白桂娥",
          "type": "二黄摇板",
          "text": "丈夫一去无音信， 奴家今日受苦情。 倒不如一死寻自尽， 免得失却贞节名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白桂娥吊死。院子上，看。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请太师爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "葛登云上。"
        },
        {
          "character": "葛登云",
          "type": "念",
          "text": "昔日在朝为首相，今朝归里称富豪。"
        },
        {
          "character": "葛登云",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "白氏妇人自缢了。"
        },
        {
          "character": "葛登云",
          "type": "白",
          "text": "可惜一个美貌的佳人。 家院，买上一口棺木，将她盛敛起来。送至菩提寺内便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "葛登云",
          "type": "白",
          "text": "咳，可惜一个美貌妇人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "葛登云下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "翟绅上。"
        },
        {
          "character": "翟绅",
          "type": "念",
          "text": "家住在太原，银钱堆如山。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "在下，翟绅。太原人氏，富有家财。父母双亡，只有我兄弟二人，贩卖绸缎， 甚是发财。东京也曾开了两座缎店，两年不曾算账。意想前去，观看观看。不 免将兄弟，唤将出来。将家中之事，交付他经理，我好起身。 兄弟快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟缙上。"
        },
        {
          "character": "翟缙",
          "type": "念",
          "text": "闻听兄长呼唤，急忙来到面前。"
        },
        {
          "character": "翟缙",
          "type": "白",
          "text": "兄长。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "兄弟，坐着，坐着。"
        },
        {
          "character": "翟缙",
          "type": "白",
          "text": "兄长唤我出来，有何话讲？"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "咱在东京，做的生意，两年不曾算账，我要前去看看。家中无人，我叫你出来， 交待交待，你要好生照应。多则三月，少则两月，我就回来。"
        },
        {
          "character": "翟缙",
          "type": "白",
          "text": "不知兄长何时启程？"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "我收拾收拾，即日启程。正是："
        },
        {
          "character": "翟绅",
          "type": "念",
          "text": "在家千日好，"
        },
        {
          "character": "翟缙",
          "type": "念",
          "text": "出外一时难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟绅、翟缙同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "僧人上。"
        },
        {
          "character": "僧人",
          "type": "念",
          "text": "晨昏三叩首，早晚一炉香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍抬棺木同上，院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "师傅请了。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "原来是葛府管家到了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "我家太师府中，死了一位姬妾。命人抬到此地，要在你寺中暂停。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "是是是，抬在后殿，廊房之下便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍抬棺木同下，院子、僧人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "翟绅骑驴上。"
        },
        {
          "character": "翟绅",
          "type": "西皮原板",
          "text": "一日离家一日深， 好一似孤雁宿寒林。 只为生意兴隆甚， 欲到东京走一程。 我这里加鞭往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驴失蹄，翟绅倒地，驴跑下，翟绅起。"
        },
        {
          "character": "翟绅",
          "type": "西皮原板",
          "text": "一跤跌得两腿疼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟绅拾包袱，追驴下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "驴上，跑下。翟绅提包袱上。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "我的驴子跑到哪里去了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑驴上，吃草。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "看里旁有一匹黑驴，待我来骑上，走他娘的便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟绅上黑驴。"
        },
        {
          "character": "翟绅",
          "type": "西皮原板",
          "text": "谁家的驴子我不问， 且自加鞭赶路程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟绅下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李保上。"
        },
        {
          "character": "李保",
          "type": "念",
          "text": "越热越出汗，越冷越打战。越穷越没有，越有越方便。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "在下，李保便是。不幸父母双亡，只留下我夫妻二人度日。虽有几亩田地是， 我终日好赌，把家业都输净了。只落得饥寒困苦，十分难过。不免把老婆唤出 来，商量一个主意，也好度日。 老婆哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李妻上。"
        },
        {
          "character": "李妻",
          "type": "念",
          "text": "家中无银钱，终日受饥寒。忽听丈夫唤，上前问根源。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "你叫我什么事情呀？"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "老婆坐下说。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "坐着，就坐着。什么事情呀？"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "我也没有别的事，只为咱们家道贫苦，无以度日。我叫你出来，商量一个好主 意，吃饭要紧呐。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "是什么一件事情呀。你想当初，咱们家里，也有几亩田地，要是好好安分守己， 也可以够吃了。谁想你，天天在外头赌钱、吃酒，把家私都折变啦。如今落 到这步田地，你既是无有法子想，难道叫我一个女人家去替你变钱不成？"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "你不要着急，咱们慢慢商量。总要想出一个法子来才好。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "法子我实在想不出来。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "你素来主意极多。今天我请你想主意，你反倒说没有主意了。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "我的主意有，只怕你办不了。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "什么主意？你说说，我听听看。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "事到如今，别的法子，也是不能行；非想没一个没本钱的生意才好。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "不错，是要没有本钱的生意，才好。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "你想世间上，无有本钱的生意，只有两条路：或者是你去做贼，去偷人家去； 或者我去当娼妓。除此两条路之外，别的再也没有了。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "不成。不成。你要叫我去做贼，偷人家里去。我一来不会飞檐走壁，二来又不 会拖窟窿。我如何能去做贼？"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "你不去做贼，只好我去当娼啦。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "不成，不成。想如今堂子里的人，具是年轻女子，都要金珠满头，还得要穿几 件绸缎的好衣服，才能接客；看你的岁数，也过了景了，又没有首饰衣服，怎 么有人看得上你？"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "要照你这样一说，我也当不了官人了。那么，可就无法可想了。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "我倒有一个主意在此。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "什么主意？"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "你我住的村庄，正临大道。待我在门前眺望，如有单身客人，从此经过，我就 把他让到家里来，用酒灌醉了他，把他害死。他的行李银钱。岂不就是咱们的 了？"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "听你这话。是要图财害命呀。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "不要吵，小心街坊邻舍听见了。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "这个法子，虽然是好，似乎有伤天理。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "事到如今，难道还等死不成？我们做一回，可就不做第二回了。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "好，就是这么办吧。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "老婆，家中还有吃食无有，我肚里饿得很。"
        },
        {
          "character": "李妻",
          "type": "白",
          "text": "后面房里，还有半碗稀饭，你去吃去吧。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "先吃了再说。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李保、李妻同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "翟绅骑黑驴上。"
        },
        {
          "character": "翟绅",
          "type": "西皮原板",
          "text": "晓行夜宿把路赶， 又只见红日落西山。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "看天已不早，又无有旅店，这便怎么好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟绅看。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "看道旁有一小小人家，不免我向前借宿一宵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "翟绅下黑驴，打门。李保上。"
        },
        {
          "character": "李保",
          "type": "念",
          "text": "忽听人叫门，向前看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李保开门。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "是哪一位？哦。原来是一位客官。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "大哥请了。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "请了。客官莫非是走错路途了么？"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "我是行路之人，看天色已晚，投不上客店，要想借宿一宵。不知大哥，可能方 便么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李保暗做喜。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "可以使得，只是舍间窄小，客官要屈尊些。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "岂敢，岂敢。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "待我将驴儿带进来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李保转场，拴黑驴。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "请坐。请问客官，贵姓高名，打从哪道而来呀？"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "在下姓翟，名绅，山西太原人氏，要到东京做生意。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "原来是翟大哥，你到东京做什么生意？"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "做些绸缎生意。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "绸缎乃是大生意。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "小本钱。"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "太谦了。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "请问大哥上姓？"
        },
        {
          "character": "李保",
          "type": "白",
          "text": "我名叫李保。"
        },
        {
          "character": "翟绅",
          "type": "白",
          "text": "原来是李大哥。"
        },
