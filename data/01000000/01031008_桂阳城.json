        {
          "character": "赵范",
          "type": "白",
          "text": "好，弟当备酒相待。告辞了。"
        },
        {
          "character": "赵范",
          "type": "西皮摇板",
          "text": "辞别仁兄出营门， 明日设宴候光临。"
