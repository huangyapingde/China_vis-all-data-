          "character": "樊氏",
          "type": "白",
          "text": "妾身还礼。待奴再敬三杯。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "小弟焉敢劳嫂嫂前来把盏，实实担当不起，嫂嫂请回后堂去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊氏转身，回顾，微笑，下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "贤弟，你我自家兄弟，何必烦劳嫂嫂前来举杯把盏。"
        },
        {
          "character": "赵范",
          "type": "白",
          "text": "兄长不知，此中有个缘故在内。"
