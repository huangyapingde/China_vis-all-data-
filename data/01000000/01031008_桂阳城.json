          "character": "马童甲",
          "type": "白",
          "text": "唤你二人进帐。"
        },
        {
          "character": "陈应、鲍龙",
          "type": "同白",
          "text": "参见将军。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "你二人前来作甚？"
        },
        {
          "character": "陈应",
          "type": "白",
          "text": "将军有所不知：那赵范定下胭粉美人之计，要杀害将军，被将军看破，将他暴 打一顿，怒气而回。是我二人见将军盛怒，必不与他干休，又恐怕牵连在内， 特来投降，望将军收留在鞍前马后。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "原来如此。你二人既肯投降，吾必有重用。"
        },
        {
          "character": "陈应、鲍龙",
          "type": "同白",
          "text": "多谢将军。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "来，带他二人到后帐饮酒用饭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引陈应、鲍龙同下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "你等用酒将他二人劝醉，给吾捆绑起来。"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童甲下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "看此二人贼头贼脑，定非真心来降，其中必有诡诈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童甲上。"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "已将二将绑讫。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "将他同来的兵卒传来见我。"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "兵卒走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "参见将军。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "陈、鲍二人前来诈降，吾已将二人绑讫，少时就要将他正法。此事不与尔等相 干，少时随吾前往城下叫门。待吾成功之后，定有重赏。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "将军开恩饶命。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "来，将二将斩首。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲允，下，提首级上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "众将官，随吾诈城去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手同转场。四下手同叫城。守城军上。"
        },
        {
          "character": "守城军",
          "type": "白",
          "text": "何人叫门？"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "陈、鲍二将军斩首赵云，回营交令。"
        },
        {
          "character": "守城军",
          "type": "白",
          "text": "果然是我们的人马，快快开城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手同入城，同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵范上。"
        },
        {
          "character": "赵范",
          "type": "念",
          "text": "眼跳心惊，坐卧不宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、四龙套、四下手同上，绑赵范。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "将赵范暂且押在营中，等候主公、军师到来，定有发落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云三笑，下。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}