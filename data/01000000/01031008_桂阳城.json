        {
          "character": "陈应",
          "type": "白",
          "text": "多带人马，恐他心疑，只带三百精兵足矣。"
        },
        {
          "character": "赵范",
          "type": "白",
          "text": "快去快去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵范下。四下手同上。"
