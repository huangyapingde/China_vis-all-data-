        {
          "character": "赵云",
          "type": "白",
          "text": "云今年三十有四。如此，吾到齿长了。 来，香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。赵云、赵范同拜。"
