{
  "script_id": "01022002",
  "title": "哭祖庙",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘谌",
      "hangdang": "老生"
    },
    {
      "name": "刘禅",
      "hangdang": "末"
    },
    {
      "name": "崔夫人",
      "hangdang": "正旦"
    },
    {
      "name": "黄皓",
      "hangdang": "丑"
    },
    {
      "name": "长子",
      "hangdang": "小生"
    },
    {
      "name": "次子",
      "hangdang": "小生"
    }
  ],
  "plot": "邓艾兵破绵竹，长驱大进，逼近成都。后主刘禅听谯周之言，肉袒出降。五子北地王刘谌，叩头哭谏，后主\n毫不介意，命近侍推出宫门。刘谌思先人创业艰难，万不容轻弃，事既无可挽回，只有一死以报先人于地下。\n带剑入宫，将情节告知其妻崔氏。崔氏以为死诚得所，且请先死，绝丈夫眷顾之心，里头触柱，顷刻间玉\n碎香消。刘谌自杀其三子，并割崔氏之头，提至昭烈庙中，伏地大哭，泪尽而继之以血，遂伏剑以殉国难焉。",
  "notes": "此剧为汪笑侬首先演唱，继之者，惟坤伶苗鑫如，汪固须生中之杰出，而苗亦堪与伯仲。剧本中反二黄一段，\n辞句甚长，异常吃力，若非上乘功夫，断难臻此。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四士卒引刘谌同上。门官跪。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "启禀王爷：今有邓艾围困成都，吾主明日出城纳降。特来禀知。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "回府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官下。刘谌中坐。"
        },
        {
          "character": "刘谌",
          "type": "念",
          "text": "凤子龙孙自不同，为子当孝臣当忠。腰悬三尺龙泉剑，夜作龙吟虎啸声。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "本爵，北地王刘谌。适才教场归府，门官报道：邓艾贼暗渡阴平，破了绵竹， 围困成都。吾父皇听了谯周、黄皓之言，明日就要开城纳降。国家存亡，就在 今日，时势危急，不免进宫谏劝父皇一番，再作道理。两厢退下。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "邓艾贼子渡阴平， 团团围困吾都城。 进宫劝谏去奏本， 背城一战退贼兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘禅上。"
        },
        {
          "character": "刘禅",
          "type": "西皮流水板",
          "text": "邓艾贼子渡阴平， 团团围困吾都城。 曾命黄皓将神师请， 如何未见进宫庭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄皓上。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "叩见万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "罢了。命你去请神师进宫，可曾请到？"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "已在宫门侯旨。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫上，上坐，起立跪。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "吾乃西川土神是也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅跪。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "参见上神。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "相请吾神到来有何见谕？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "只因邓艾贼子暗渡阴平，袭了绵竹，进围成都。那满朝文武，有的愿战，有的 愿降，纷纷不一。寡人毫无主见，不能定夺。因请上神驾临一卜，还是战的好， 还是降的好？"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "依吾神之见，你若投降邓艾，都管保你天下太平，晏安无事。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "谨遵仙命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫作神退惊醒状。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "哎呀！万岁爷圣驾在此，参见万岁爷！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "谢万岁爷。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "黄皓，命你赏她白银千两，送她出宫去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫出，刘谌上。刘谌视女巫作切齿状。女巫下。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "父皇一味妖巫信， 恐怕江山难保存。 撩袍端带宫门进， 见了父皇说分明。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "儿臣见驾，父皇万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "皇儿进宫，有何本奏？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "那邓艾贼子，围困成都城，父皇如何坐事不理？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "非是为父坐视不理。只因满朝文武百官，有愿战的，有愿降的，议论纷纷，并 无定见。孤想与其劳动干戈，胜败不测，不如投降邓艾，免得涂炭生灵。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "自古以来，哪有将大好的江山，白送人家的道理？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤也曾问过神师，那神师言道：投降邓艾，都管保孤天下太平，晏安无事。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "父皇休听那妖巫一派荒诞之辞！想邓艾孤军深入，利在速战，父皇不可开城， 只可坚守。儿臣不才，愿率领众将，君臣父子，背城一战，何愁邓艾不灭！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "唗！动不动就要开城战！胜了还则罢了，若是败了，岂不是要了你老子的命不 成？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "刘谌控背忙躬身， 尊声父皇龙耳听： 妖巫之言不可信， 儿愿领兵灭敌人！"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "皇儿不必苦争论， 神师之言敢不尊？"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "千言万语父不信， 在宫中难坏小刘谌。 走向前来忙跪定， 抱住父皇放悲声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌跪。"
        },
        {
          "character": "刘谌",
          "type": "西皮二六板",
          "text": "未曾开言泪难忍， 尊声父皇龙耳听： 贼邓艾孤军深入渡阴平， 团团围困锦绣的都城。 到不如父子君臣背城一战战必胜， 杀得他大小三军、马步儿郎，弃甲丢盔，败走无门。 孩儿的言语不肯信， 祖宗基业莫当轻！"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "为父龙心业以定， 午时三刻便开城。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "今日的堂堂天子尚称朕， 明朝就是那亡国君。 天下后世看公论， 骂父的词儿不忍云。 若谓孩儿言不逊， 开刀先杀吾小刘谌。"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "奴才说话言不逊， 胆敢当面骂天伦。 恨不得一足要儿的命， 不杀你还念父子情。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "不必多言，出宫去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌起立。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "刘谌奏本皇父不信， 一足踢吾出宫门。 国破家亡心何忍？ 先皇祖啊！ 吾先杀妻、后杀子，然后杀身！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌下。"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "黄皓与孤安排定， 投降之后享太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅、黄皓同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "董敏上。"
        },
        {
          "character": "董敏",
          "type": "二黄摇板",
          "text": "自幼净身入宫院， 算来到今数十年。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "咱家董敏，奉了夫人之命，去到御花园游玩，天气不早，不免回去者。"
        },
        {
          "character": "董敏",
          "type": "二黄摇板",
          "text": "手拉世子回府转， 但愿国家早治安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏下。崔夫人抱小儿上。"
        },
        {
          "character": "崔夫人",
          "type": "二黄正板",
          "text": "贼邓艾渡阴平十分危险， 眼见得围成都黎民不安。 吾丈夫每日里把兵操练， 为什么这时候不见回还？"
        },
        {
          "character": "刘谌",
          "type": "内二黄导板",
          "text": "怒哄哄出离皇宫院，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌上。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "不由本爵怒冲冠！ 未曾进宫先拔剑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人起立。"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "呀，王爷！"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "这才是儿女情长、英雄气短，吾的手足酸！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "呀，王爷！今日进宫，为何拔剑出鞘？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "你乃妇道人家，女流之辈，不问也罢！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "呀，王爷说哪里话来？有道是：朝中有事，君臣论；家中有事，夫妻商量。哪 有丈夫有事，妻子不问的道理？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "哎呀！夫人有所不知！今有邓艾贼子，围困成都，父皇听信谯周、黄皓之言， 明日就要开城投降，本爵意欲拔剑出鞘，殉国难一死！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "哎呀！如此说来，妾请先死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人将小儿放桌上。"
        },
        {
          "character": "崔夫人",
          "type": "二黄摇板",
          "text": "将娇儿放在青玉案， 心中好似滚油煎。 人生百岁终须死， 恩爱夫妻不团圆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人撞死，下。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "死的好！"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "一见夫人寻短见， 吾心中好似乱刀剜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌起立，割人头。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "忙将宝剑人头割，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌手指桌案上小儿。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "吾三岁的婴儿也要被刀餐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌杀小儿。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "手提人头出宫殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏引二皇子同上。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "一见二子眼睁圆。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "哎呀！王爷呀！一言不发为何要杀那二位殿下？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "想吾国破家亡，死了倒也干净！"
        },
        {
          "character": "二皇子",
          "type": "同白",
          "text": "父皇要杀孩儿却也不难，容孩儿进宫，见吾母亲一面，再杀不迟！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "儿要见你母亲么？来看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二皇子同惊跑圆场，刘谌杀皇子甲，皇子乙、董敏同跑。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "哎呀，王爷！杀了一个，留下一个，也好接续后代香烟。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "念你苦苦哀求，出宫去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏起立，挽皇子乙。刘谌赶杀皇子乙。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "看二位殿下已死，国破家亡，俺不免也碰死了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏撞死。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "好一个忠心董太监， 留下美名万古传。 忙将人头一齐割， 祖庙之中祭祖先。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌手提四人头下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘禅面缚舆榇作出城投降状，下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "邓艾引四士卒同上，邓艾三笑，邓艾、四士卒同进城，同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘谌左手提人头，右手持剑进祖庙。"
        },
        {
          "character": "刘谌",
          "type": "二黄导板",
          "text": "进祖庙不由人心中悲惨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌插剑，三次分献四人头，奠酒，拜跪，起立。"
        },
        {
          "character": "刘谌",
          "type": "叫头",
          "text": "先皇呀，昭烈帝，皇祖呵！"
        },
        {
          "character": "刘谌",
          "type": "回龙",
          "text": "将人头供神案祭奠祖先。"
        },
        {
          "character": "刘谌",
          "type": "反二黄慢板",
