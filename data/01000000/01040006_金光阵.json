{
  "script_id": "01040006",
  "title": "金光阵",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "樊梨花",
      "hangdang": "正旦"
    },
    {
      "name": "薛丁山",
      "hangdang": "老生"
    },
    {
      "name": "薛应龙",
      "hangdang": "小生"
    },
    {
      "name": "秦汉",
      "hangdang": "净"
    },
    {
      "name": "窦一虎",
      "hangdang": "净"
    }
  ],
  "plot": "薛丁山、樊梨花双挂元帅征西，义子薛应龙战死于金光阵。薛丁山从仙山回营，得知此事，心疑樊梨花之有\n意逼令薛应龙往破此阵。几有“汝虽不杀伯仁，伯仁实由汝而死”之恨，因此夫妻之间大相反目。后樊梨花\n对天明誓，薛丁山始信。夫妻大破金光阵，为子报仇。",
  "notes": "此剧下半本全演薛丁山与樊梨花，夫妇二人抢白争辩之情节，故彼此皆哭一声，唱一句，善演此剧之生、旦\n演此，且哭且说之情形，其做工亦颇有可观焉。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛应龙上。"
        },
        {
          "character": "薛应龙",
          "type": "念",
          "text": "万事皆由命，半点不由人。"
        },
        {
          "character": "薛应龙",
          "type": "白",
          "text": "俺，薛应龙。自进唐营并无半点之功。今日芦花河摆下无名大阵，不免单人独 马前去破阵，岂不是好！不如盗了老马，出营去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦汉、窦一虎同上。"
        },
        {
          "character": "秦汉",
          "type": "白",
          "text": "小本官往哪里去？"
        },
        {
          "character": "薛应龙",
          "type": "白",
          "text": "前去破阵！"
        },
        {
          "character": "窦一虎",
          "type": "白",
          "text": "元帅有令，叫你不要出兵。"
        },
        {
          "character": "薛应龙",
          "type": "白",
          "text": "此回出兵，破得此阵便罢！"
        },
        {
          "character": "秦汉",
          "type": "白",
          "text": "倘若不能？"
        },
        {
          "character": "薛应龙",
          "type": "白",
          "text": "死在外面，永不回营！"
        },
        {
          "character": "窦一虎",
          "type": "白",
          "text": "我弟兄二人助你一臂之力！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛应龙、秦汉、窦一虎进场。乌礼黑上，开打。"
        },
        {
          "character": "乌礼黑",
          "type": "白",
          "text": "打着了！"
        },
        {
          "character": "秦汉",
          "type": "白",
          "text": "老子上了天！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦汉下。"
        },
        {
          "character": "乌礼黑",
          "type": "白",
          "text": "又打着了！"
        },
        {
          "character": "窦一虎",
          "type": "白",
          "text": "老子又入地！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦一虎下。乌礼黑、薛应龙开打。"
        },
        {
          "character": "乌礼黑",
          "type": "白",
          "text": "你看这小将生得厉害！不免用铁板收他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乌礼黑、薛应龙开杀。薛应龙下，乌礼黑下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花上。"
        },
        {
          "character": "樊梨花",
          "type": "念",
          "text": "眼跳心惊，未知吉凶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦汉、窦一虎上。"
        },
        {
          "character": "秦汉",
          "type": "白",
          "text": "启元帅：大事不好了！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "有什么大事？"
        },
        {
          "character": "窦一虎",
          "type": "白",
          "text": "小本官芦花河阵中身亡！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "不好了！尸首可曾带回？"
        },
        {
          "character": "秦汉",
          "type": "白",
          "text": "带来了。"
        },
        {
          "character": "樊梨花",
          "type": "西皮快板",
          "text": "一见姣儿伤了命， 不由为娘痛在心。 千言万语说不尽， 哪个叫你去出兵？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛丁山上。"
        },
        {
          "character": "薛丁山",
          "type": "西皮原板",
          "text": "在深山领了师父命， 回到大营说分明。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "元帅，大事不好了！"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "什么大事不好？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "应龙丧命！"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛丁山看。"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "薛丁山",
          "type": "西皮原板",
          "text": "一见姣儿伤了命，"
        },
        {
          "character": "樊梨花",
          "type": "西皮原板",
          "text": "怎不叫为娘痛在心？"
        },
        {
          "character": "薛丁山",
          "type": "西皮原板",
          "text": "你在玉泉山何等不好？"
        },
        {
          "character": "樊梨花",
          "type": "西皮原板",
          "text": "哪个叫你去出兵！"
        },
        {
          "character": "薛丁山、樊梨花",
          "type": "同西皮原板",
          "text": "千言万语讲不尽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛丁山、樊梨花同哭。"
        },
        {
          "character": "薛丁山",
          "type": "西皮流水板",
          "text": "把话说与夫人听： 芦花河摆下了金光阵， 休叫应龙去出兵。 今日我儿伤了命， 难道你心疼不疼？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛丁山、樊梨花同哭。"
        },
        {
          "character": "樊梨花",
          "type": "哭",
          "text": "薛应龙！"
        },
        {
          "character": "薛丁山",
          "type": "哭",
          "text": "小姣生！"
        },
        {
          "character": "樊梨花",
          "type": "西皮流水板",
          "text": "元帅有所不知情， 妻子言来你是听： 我在营中传将令， 不知他私自去出兵。 如今姣儿伤了命， 难道我不痛在心！"
        },
        {
          "character": "薛丁山",
          "type": "哭",
          "text": "薛应龙！"
        },
        {
          "character": "樊梨花",
          "type": "哭",
          "text": "小姣生！"
        },
        {
          "character": "薛丁山",
          "type": "西皮流水板",
          "text": "大夫人也有麒麟子， 二夫人也有后代根。 唯有夫人没了后， 你把应龙当亲生。 今日夫人心不愿， 有意绝我后代根。"
        },
        {
          "character": "樊梨花",
          "type": "哭",
          "text": "薛应龙！"
        },
        {
          "character": "薛丁山",
          "type": "哭",
          "text": "小姣生！"
        },
        {
          "character": "樊梨花",
          "type": "西皮流水板",
          "text": "元帅有所不知情， 妻子言来听分明： 先禁自己后禁人， 怕的三军心不平。"
        },
        {
          "character": "薛丁山",
          "type": "哭",
          "text": "薛应龙！"
        },
        {
          "character": "樊梨花",
          "type": "哭",
          "text": "小姣生！"
        },
        {
          "character": "薛丁山",
          "type": "西皮流水板",
          "text": "自古道青竹蛇儿口， 自古道黄蜂尾上针。 自古道万事皆由命， 自古道最毒妇人心！"
        },
        {
          "character": "樊梨花",
          "type": "哭",
          "text": "薛应龙！"
        },
        {
          "character": "薛丁山",
          "type": "哭",
          "text": "小姣生！"
        },
        {
          "character": "樊梨花",
          "type": "西皮流水板",
          "text": "元帅疑我两样心， 对着苍天把誓明。 梨花待子有假意， 死在千军万马营！"
        },
        {
          "character": "薛丁山",
          "type": "哭",
          "text": "薛应龙！"
        },
        {
          "character": "樊梨花",
          "type": "哭",
          "text": "小姣生！"
        },
        {
          "character": "薛丁山",
          "type": "西皮流水板",
          "text": "一见夫人把誓明， 不由本帅放了心。 叫人来，"
        },
        {
          "character": "秦汉、窦一虎",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "薛丁山",
          "type": "西皮流水板",
          "text": "将应龙尸首抬往后营进， 父子们相逢万不能！"
        },
        {
          "character": "樊梨花",
          "type": "哭",
          "text": "薛应龙！"
        },
        {
          "character": "薛丁山",
          "type": "哭",
          "text": "小姣生！"
        },
        {
          "character": "薛丁山、樊梨花",
          "type": "同哭",
          "text": "俺的儿，儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}