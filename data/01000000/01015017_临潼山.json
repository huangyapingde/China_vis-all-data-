    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上，伙计上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "走过两京十三省， 杀得人来救得人。"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "秦二爷到了临潼关，关门紧闭。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "前去叫关。你说青天白日，为何关门紧闭？"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "哦。我且问你，青天白日，为何将关门紧闭？"
        },
        {
          "character": "龙套",
          "type": "内同白",
          "text": "只因小千岁，与李千岁歛战，被一穿黄之人，打了一锏。故此紧闭关门，捉拿 穿黄之人。"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "喝喝，这回打出祸来了。 秦二爷，他说小千岁与什么李千岁歛战，被那穿黄之人，打了一锏。故此这才 紧闭关门，捉拿穿黄之人。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "嗳呀，且住。我想在临潼山前救了他，我今又不能出关，也是枉然。我想是救 人救到底，撑船撑到岸，自有道理。 小伙计，"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你前去说山东济南府厉城县好汉一名秦琼，押解一十八名囚犯，天堂潞州挂号。 好好开关便罢，如若不然，打进关来，杀个鸡犬不留。"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "哦，二爷不要打出祸来。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "无妨。"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "哦，关内把关的将爷们听着！"
        },
        {
          "character": "龙套",
          "type": "内同白",
          "text": "哦。"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "有山东济南府历城县好汉一名秦琼，押解一十八名囚犯，天堂潞州挂号。好好 开关便罢。如若不然，杀进关来，鸡犬不留。"
        },
        {
          "character": "龙套",
          "type": "内同白",
          "text": "不开。"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "不开关。你们这些人，就不想活命？ 二爷，他们不肯开关。不开就打。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "打得的？"
        },
        {
          "character": "伙计",
          "type": "白",
          "text": "打得无妨。有俺怕什么。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "如此闪开了！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "豪杰生来真可夸， 手提双锏一百八。 一声怒气冲牛斗， 打出潼关不犯王法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、李母、窦氏同上。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "那员将生来好无理。俺这里舍生忘死，救了你一家性命。谢字也不答一声，跨 马扬鞭就走。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "请问恩人上姓？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "在下姓这个…… 且住。我想那山前山后，俱是那奸王的人马。倘若知道我，太爷的考成要紧。 也罢，锏上有“秦琼”二字，待我按住“秦”字，现出“琼”字。将军请看。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "敢是姓“琼”？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "再看。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "原来是琼五将军。记下了。"
