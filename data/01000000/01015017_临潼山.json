          "character": "家将",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "就此起行。呵呵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
