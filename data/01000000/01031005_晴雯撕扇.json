{
  "script_id": "01031005",
  "title": "晴雯撕扇",
  "alias": [
    "千金一笑"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "晴雯",
      "hangdang": "正旦"
    },
    {
      "name": "贾宝玉",
      "hangdang": "小生"
    }
  ],
  "plot": "贾宝玉用睛雯，一视同仁，高下尊卑，在所不计。贾府中之婢女，才貌双全者，不一而足，贾宝玉真与姊妹\n行同等看待。袭人与睛雯，最为亲昵。袭人性柔而和，睛雯性刚而傲，两美同室，不免有含酸意，而势成水\n炭矣。然袭人未尝形诸颜色，晴雯时或贻以口实，故晴雯敢于贾宝玉前放肆。贾宝玉于盛怒之下，被晴雯跌\n断扇子，示尝严加申饬，惟言语间略见偏重。而晴雯已将平素积忿，尽行发泻，贾宝玉虽欲回禀王夫人，将\n晴雯遣出，亦不过一时口头语，岂真必欲为此决绝之事耶。所以袭人等代为缓颊，贾宝玉遂因之而息怒。及\n至赴宴回来，仍与晴雯喁喁私语，反授以扇使之随意撕破，消其不平之气，且设一千金买笑之誓喻，无限欢\n欣。似乎贾宝玉多情，而晴雯寡情，然执是说也，犹未深知晴雯。晴雯如此举动，正其情之至于极处也。",
  "notes": "《金玉缘》一书，尽人知为言情小说也。是剧事实，出于《金玉缘》三十、三十一两回。剧本与说部，略有\n参差，所谓大同小异耳。观剧诸君，检阅《金玉缘》，便知详细，述考者不再啰嗦。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "晴雯淡装小锣上。"
        },
        {
          "character": "晴雯",
          "type": "引子",
          "text": "心比天高，争奈我，命似蓬蒿。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "奴家晴雯，贾府为婢。奴一向服侍宝二爷，多蒙他另眼相看。只的我心直口快， 姊妹们对我，都有些面和心不和，这也是我性情不好，无意中得罪她们，倒 也罢了。只有那袭人，性格阴柔，居心险诈，我总有些瞧不起，便是招人恐恨， 我也不能理会她的。"
        },
        {
          "character": "晴雯",
          "type": "西皮原板",
          "text": "看她们狐媚子又兼霸道， 好一似暮气怜昼把人骄。 天生我清净身苦把心傲， 我岂肯附和她自贬风标。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "哦呀，明日乃是端阳佳节，此时闲着无事，不免做起艾人蒲剑，点缀一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宝官、玉官同上。"
        },
        {
          "character": "宝官",
          "type": "西皮摇板",
          "text": "一年佳节近端阳，"
        },
        {
          "character": "玉官",
          "type": "西皮摇板",
          "text": "嬉游休负好时光。"
        },
        {
          "character": "宝官",
          "type": "白",
          "text": "咱们自到贾府，居住梨香院中天天学戏，十分拘管，喜得明日端阳，今日放假， 姊妹们同到园中走走。"
        },
        {
          "character": "玉官",
          "type": "白",
          "text": "姐姐，走了半日，我可走不动了。前面便是怡红院，咱们且进去闲话一回。"
        },
        {
          "character": "宝官",
          "type": "白",
          "text": "妹妹言之有理，一同前往便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "袭人上。"
        },
        {
          "character": "袭人",
          "type": "引子",
          "text": "一身专爱宠，姊妹尽低头。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "奴家袭人。上蒙太太抬举，下有宝玉爱怜，在这怡红院中，一向称尊，只有晴 雯她总是负气，不肯相下。好在她性情暴燥，口角尖酸，得罪的人不少，我且 让她一步，待她自己得了不是，那里便不能再与我呕气了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宝官、玉官同上。"
        },
        {
          "character": "宝官、玉官",
          "type": "同白",
          "text": "来此正是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宝官、玉官同叩门。"
        },
        {
          "character": "宝官、玉官",
          "type": "同白",
          "text": "姐姐开门。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "小丫头，小丫头们！ 都不知跑到哪里去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯手执蒲剑上。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你叫小丫头做什么？"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "外面有人叩门。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "呸！我道有什么大事，难道你出去开了门，便折了你的身份不成？你不去开， 待我去开便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯将艾人蒲剑放桌上，开门。"
        },
        {
          "character": "宝官、玉官",
          "type": "同白",
          "text": "有劳姐姐开门。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "原来是二位妹妹，请进来罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人出来迎接。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "原来是二位妹妹到了，里面请坐罢。想是今儿放假了？"
        },
        {
          "character": "宝官、玉官",
          "type": "同白",
          "text": "正是今儿放假，特来园中玩耍。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "请坐请坐。小丫头们倒茶上来。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "啧啧啧，你不用瞎张罗了，有你这会子张罗的，倒不如早些替她们开门，免得 她们白站着晒日头，不是好多着吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人笑。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "晴妹妹总是喜欢取笑，待我去倒茶来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人下。玉官见艾人蒲剑，拿起看，笑。"
        },
        {
          "character": "玉官",
          "type": "白",
          "text": "这是谁做的？"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "是我做的。"
        },
        {
          "character": "玉官",
          "type": "白",
          "text": "好姐姐，赏给我罢，怪好罗的。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你要你便拿去就是，但是我要求你二位唱个曲子给我们听。"
        },
        {
          "character": "宝官",
          "type": "白",
          "text": "我嗓子不好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯笑。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你好意思说不唱，我便膈肢你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯呵手作膈肢状，宝官笑避。"
        },
        {
          "character": "宝官",
          "type": "白",
          "text": "我唱我唱，只是唱什么好呢？"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你愿意唱什么，就是什么。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人端茶上。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "二位用茶。"
        },
        {
          "character": "宝官、玉官",
          "type": "同白",
          "text": "有劳姐姐。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你且坐下，听她唱曲子。"
        },
        {
          "character": "宝官",
          "type": "白",
          "text": "我就是请随便唱了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宝官唱昆曲一支。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "这就是请教玉官妹妹的曲子了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内作雷声。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "大雨来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉官掩耳。"
        },
        {
          "character": "玉官",
          "type": "白",
          "text": "姐姐我怕。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "怕什么，你还是唱你的，管它什么雷不雷、雨不雨的。你要再怕，我就膈肢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉官笑。"
        },
        {
          "character": "玉官",
          "type": "白",
          "text": "姐姐不好耍闹，我唱便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉官唱昆曲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉急上。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "好大的雨，浑身都着泾了。 开门，开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉官仍唱昆曲，贾宝玉在雨下急，叩门。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "开门！开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉官唱昆曲完，晴雯笑。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "真唱得好，我跟你学罢。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "你的嗓子最会让，你学一出《醉打山门》倒好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宝官、玉官同笑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉怒。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "为什么总不开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉踢。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "又是谁来叩门？"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你不会出去张张看吗，别叫人家淋着雨回去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人张，笑。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "你们快来瞧，二爷淋得像雨打鸡一样的回来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人开门，弯腰笑。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "谁知道二爷这会子就回来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉怒打，踢，袭人呼痛。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "什么下流东西！我平日担待你们得了意，今日拿着我取笑来了！还了得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人哭。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "呀！怎么开门的是袭人姐姐么？踢在哪里了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人忍泪。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "没有踢着，快换衣去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉向宝官、玉官。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "你们且坐坐，我换了衣就来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉偕袭人下。"
        },
        {
          "character": "宝官",
          "type": "白",
          "text": "雨住了，天也快黑了，我们回去罢。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "明儿再来罢。"
        },
        {
          "character": "宝官",
          "type": "白",
          "text": "那是自然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉官拿艾人薄剑。"
        },
        {
          "character": "玉官",
          "type": "白",
          "text": "谢谢你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉扶袭人同上。"
        },
        {
          "character": "袭人",
          "type": "西皮摇板",
          "text": "腰肋间这伤痛叫人难忍， 坐不安睡不稳捱到天明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人坐。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "袭人姐姐，我不知道开门的就是你。这一踢，真踢重了。你吃了药，觉得好些 么？"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "咳，二爷，今日乃是端阳佳节，你不到老太太、太太那边去，请安道贺，只管 服侍我做什么？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "我撇下你怎么能够放心前去。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "二爷，适才夫人看过，料不妨事。你只管在此，人家倒要说我轻狂。你还是到 老太太、太太那边去。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐既如此说，我去便了。"
        },
        {
          "character": "贾宝玉",
          "type": "西皮摇板",
          "text": "被催促没奈何出门前往， 行一步一回头掛肚牵肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。袭人立起。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "二爷上头去了，我不免去到后房，小憩一回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人作痛。"
        },
        {
          "character": "袭人",
          "type": "白",
          "text": "哎哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袭人下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "麝月、秋纹同上。"
        },
        {
          "character": "麝月",
          "type": "念",
          "text": "榴花照眼红如火。"
        },
        {
          "character": "秋纹",
          "type": "念",
          "text": "好是风和日丽天。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "我麝月。"
        },
        {
          "character": "秋纹",
          "type": "白",
          "text": "我秋纹。姐姐，今日端阳，姊妹们都到园中玩耍去了，你我也去凑个热闹儿。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "不是这么说，现在袭人姐姐有病，晴雯又是不管事的，我们再出了，这屋可叫 小丫头们给弄毁了。"
        },
        {
          "character": "秋纹",
          "type": "白",
          "text": "我要问你，袭人姐姐昨儿怎样挨了二爷的窝心脚。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "只因晴雯要听宝官、玉官唱戏，大雨的时候，二爷惴起来，进门就是一脚，可 就把袭人姐姐踢跌了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯暗上。"
        },
        {
          "character": "秋纹",
          "type": "白",
          "text": "如此说来，又是晴雯惹起来的？"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "不是她是谁！"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "唗，你二个蹄子背着人，又嚼念起来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月、秋纹惊看。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "你什么时候溜出来的，倒吓我一跳！"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你们说我不管事的时候，我就出来了。"
        },
        {
          "character": "麝月",
          "type": "白",
