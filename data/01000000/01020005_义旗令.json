  "plot": "《施公案》中，老英雄张七有女张桂兰，丰姿既美，武艺尤精。薛家窝恶霸薛金龙久属意，欲为其子聘妻。\n而张七则意在黄天霸，久慕其少年豪侠，且能自拔于绿林之中，拟与缔姻。然张桂兰颇自负，曾故盗施公金\n牌，以显其能，且亦即留作日后婚姻之媒介。施公尝令部下四出侦访，久不得实。至是始探得在包头镇张七\n家。惟时张七已死，其妻遂向施公部下说明，欲知金牌缘由，须问李五爷便知。李五爷者，老英雄李堃也。\n李堃本在施公处，遂告施公，谓张氏欲赘黄天霸为婿云云。施公乃欣然愿与作伐，遂率同一众英雄护黄天霸\n往张处入赘。而张桂兰负气，必欲与黄天霸一较武艺。相角之下，可称双绝，洵堪匹敌。张桂兰乃惬意，遂\n与成亲。事为薛金龙所闻，深妒黄天霸占此便宜，乃率其子阻黄天霸归路，思夺张桂兰。然黄天霸夫妇武艺\n远胜薛金龙，薛金龙遂卒为所擒服云。",
  "notes": "惟此剧中所演，与传载少有不同。从前尝推李春来与沈韵秋合演为最拿手，至使春来有“如沈死，誓不再演\n此剧”之语。诚以夺刀一场，舍沈外，洵无一人能应手故也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛金龙上。"
        },
        {
          "character": "薛金龙",
          "type": "引子",
          "text": "武艺超群，压绿林，白发如银。"
        },
        {
          "character": "薛金龙",
          "type": "念",
          "text": "自幼生来胆气豪，白发苍苍似银条。绿林之中谁不晓，薛家窝内逞英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、丑院子同暗上。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "吾，薛金龙。爱习拳棍，带领四个孩儿独霸薛家窝。今乃老夫寿诞之期。 众家丁，伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四弟兄同上。"
        },
        {
          "character": "四弟兄",
          "type": "同念",
          "text": "好汉生来秉性刚，爱习拳棒和刀枪。"
        },
        {
          "character": "四弟兄",
          "type": "同白",
          "text": "爹爹在上，孩儿等拜寿！"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "不消拜了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "八英雄",
          "type": "内同白",
          "text": "众位英雄到！"
        },
        {
          "character": "四弟兄",
          "type": "同白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八英雄同上。"
        },
        {
          "character": "八英雄",
          "type": "同白",
          "text": "吓！老英雄！"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "众位请！"
        },
        {
          "character": "八英雄",
          "type": "同白",
          "text": "老英雄请上，待吾等拜寿！"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "这就不敢当！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "杨、李二位老英雄前来拜寿。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "敢么是那杨香武、李玉么？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨香武、李玉同上。"
        },
        {
          "character": "杨香武、李玉",
          "type": "同白",
          "text": "薛老英雄！"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "二位老英雄请！"
        },
        {
          "character": "杨香武、李玉",
          "type": "同白",
          "text": "老英雄请上，待我二人与老英雄拜寿！"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "不敢当了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "未知二位老英雄驾到，小弟未曾远迎，当面恕罪！"
        },
        {
          "character": "杨香武、李玉",
          "type": "同白",
          "text": "岂敢！"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "酒宴摆下！"
        },
        {
          "character": "杨香武、李玉",
          "type": "同白",
          "text": "来此就要叨扰！"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二庄客同上。"
        },
        {
          "character": "二庄客",
          "type": "同白",
          "text": "启寨主：我等在庄外酒楼擒住两个奸细。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "竟有这等事？与我绑上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押关泰、谢永泰同上。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "大胆奸细，擅敢前来窥探，通上名来！"
        },
        {
          "character": "关泰",
          "type": "同白",
          "text": "你老爷总漕大人标下，漕标参将关泰。"
        },
        {
          "character": "谢永泰",
          "type": "同白",
          "text": "你老爷漕标守备谢永泰。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "原来是无名之辈。 将他二人吊在马棚之内，押下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押关泰、谢永泰同下。"
        },
        {
          "character": "杨香武、李玉",
          "type": "同白",
          "text": "老英雄，想关泰、谢永泰二人俱是漕标手下的官员，今将他等擒来，只恐与老 英雄有些不便。"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "想那天霸在施世纶手下，每每与吾绿林作对。今日他二人前来，未必非天霸的 主使，这也是他自投罗网。"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "倘若那天霸带领官兵前来，你是怎生得了？"
        },
        {
          "character": "薛金龙",
          "type": "白",
          "text": "纵有官兵到来，俺薛某何惧！想俺薛家五虎乎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹牌子。"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "好言相劝，执意不听，少时悔之晚矣！俺杨香武告辞了！"
        },
        {
          "character": "杨香武",
          "type": "西皮摇板",
          "text": "我把好言来劝你， 怎奈你心中太痴迷。 马到悬崖收缰晚， 船到江心补漏迟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨香武、李玉同下。"
        },
        {
          "character": "薛金龙",
          "type": "西皮摇板",
          "text": "他二人一怒出庄院， 大家到后堂痛饮一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "计全、何路通同上。"
        },
        {
          "character": "计全",
          "type": "西皮摇板",
          "text": "在衙中奉了大人命， 寻找令牌要小心。"
        },
        {
          "character": "计全、何路通",
          "type": "同白",
          "text": "俺——（计全）（何路通）。"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "你我奉了大人之命寻找金牌。看前面已是薛家窝，你我还是与那厮前去拜寿， 还是越庄而过？"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "你我去至他庄，再作道理。"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "计全",
          "type": "西皮摇板",
          "text": "二人催马往前拥， 又只见二位老英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨香武、李玉同上。"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "原来是杨、李二位老英雄。"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "原来是计全。此位是？"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "这就是何路通。 来，见过二位老英雄！"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "参见二位老英雄！"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "敢么就是人称“赛鱼鹰”？"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "令师可好？"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "已下世了。"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "咳！又去了一位老英雄！"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "但不知二位老英雄打从哪道而来？"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "打从薛家窝而来。"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "老英雄，为何与那厮来往？"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "我二人亦是为金牌之事而来。只因我二人在酒楼饮酒，见关泰、谢永泰被他们 擒去，故而以拜寿为名，前去探听。那薛金龙将关泰二人吊在马棚之内。 何路通听令！今晚三更十分，去到他庄马棚之内，搭救他二人，不得有误！回 去对天霸言讲，上你一件功劳。"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何路通下。"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "前面有一包头镇，就是凤凰张七住处，去到那里访问金牌下落，便知明白。"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "计全下。"
        },
        {
          "character": "杨香武",
          "type": "西皮摇板",
          "text": "到此时我这才把宽心来放，"
        },
        {
          "character": "李玉",
          "type": "西皮摇板",
          "text": "寻访金牌为忠良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨香武、李玉同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "何路通上，救关泰、谢永泰同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、八英雄、朱光祖、李堃、黄天霸、施世纶同上。"
        },
        {
          "character": "施世纶",
          "type": "西皮摇板",
          "text": "本院下马鸡鸣驿， 失却金牌甚跷蹊。 闷奄奄且坐二堂里， 且等众人报端的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王栋、王梁同上。"
        },
        {
          "character": "王栋、王梁",
          "type": "同白",
          "text": "叩见大人！"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "王栋、王梁回来了。金牌之事如何？"
        },
        {
          "character": "王栋",
          "type": "白",
          "text": "启禀大人：小人去到包头镇，见有一个人家，是八字小门墙。进去一问，果然 是张姓。只是凤凰张七现已去世，见了那老夫人。她曾言道："
        },
        {
          "character": "王栋",
          "type": "念",
          "text": "若问金牌事，李五爷便知情。"
        },
        {
          "character": "李堃",
          "type": "白",
          "text": "咳，不好了！"
        },
        {
          "character": "李堃",
          "type": "西皮摇板",
          "text": "听说是老英雄丧了命， 倒叫李堃恸在心。 大人若问金牌事， 只为他女一段婚姻。"
        },
        {
          "character": "李堃",
          "type": "白",
          "text": "启禀大人：那张七之女，名唤桂兰，久已许配黄爷，并未下聘。今日失去金牌， 定是为黄爷而起。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "既然如此，本院就同诸位同到她家，本院还要看看她的武艺。吩咐外厢开道！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "开道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允。〖吹牌子〗。众人同转场。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "里面有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "施大人要见你家老夫人。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请老夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张夫人上。"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "施大人到。"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "老夫人！"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "参见大人！"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "老夫人请坐！"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "金牌奉上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施世纶接。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "天霸，见过你的岳母！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "叩见岳母！"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "不消拜了。 来，请你家小姐！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请小姐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张桂兰上。"
        },
        {
          "character": "张桂兰",
          "type": "白",
          "text": "参见母亲！"
        },
        {
