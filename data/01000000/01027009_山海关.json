        {
          "character": "家将",
          "type": "stage",
          "text": "中国京剧戏考 《山海关》【头、二本】 6"
        },
        {
          "character": "赵率教",
          "type": "唱",
          "text": "后营酒宴安排定， 且与监军叙寒温。"
        },
