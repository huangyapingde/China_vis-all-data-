        {
          "character": "袁崇焕",
          "type": "白",
          "text": "俺就这一座孤城，看他如何破得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁崇焕引满桂、左辅、何可刚、朱海同下。祖大寿上。"
