        {
          "character": "袁崇焕",
          "type": "西皮摇板",
          "text": "人来带马回营往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁崇焕、赵率教同下城上马。"
        },
        {
          "character": "袁崇焕",
