    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众辽民同上，设城墙，筑城。辽婆手提饭篮碗筷上。"
        },
        {
          "character": "辽婆",
          "type": "数板",
          "text": "筑城高，筑城高，搬砖抱瓦把土挑。奴家生来十分俏，柳眉杏眼，口似樱桃， 金莲脚，杨柳腰，嫁个丈夫本姓焦。看我风骚不风骚。"
        },
        {
          "character": "辽婆",
          "type": "白",
          "text": "嗳，老伴儿，拿饭去吃呀。"
        },
        {
          "character": "众辽民",
          "type": "同白",
          "text": "喔唷，大嫂体面得很。俺说哪里来的一阵香风，原来大嫂脸上的粉花香。"
        },
        {
          "character": "辽婆",
          "type": "白",
          "text": "呸，嚼你的舌根。俺今天是淘米水洗脸，粘着些米土罢了，有甚么香味。"
        },
        {
          "character": "众辽民",
          "type": "同白",
          "text": "俺们不信，是要闻的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众辽民同围上，同打翻饭篮。老汉上。"
        },
        {
          "character": "老汉",
          "type": "白",
          "text": "众位朋友休得取闹，多是这贱人不是，她贯会惹祸招非。"
