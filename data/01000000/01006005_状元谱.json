{
  "script_id": "01006005",
  "title": "状元谱",
  "alias": [
    "打侄上坟"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "陈伯愚",
      "hangdang": "老生"
    },
    {
      "name": "陈大官",
      "hangdang": "小生"
    },
    {
      "name": "陈夫人",
      "hangdang": "老旦"
    },
    {
