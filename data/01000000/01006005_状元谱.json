          "text": "有有，跟我走，到了。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "你看看这也是一个大洞，那也是一条缝，拿把锹来。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "锹。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "拿去。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "你到外面去看，员外来了，报我知道，"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "是了，你快点罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱仓下。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "爹娘吓。"
        },
        {
          "character": "陈大官",
          "type": "西皮摇板",
          "text": "跪倒坟前珠泪滚， 恕却孩儿不孝人。 望来爹娘多保应， 保佑孩儿早成名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱仓上。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "员外来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈大官、朱仓同下。陈伯愚、陈夫人、院子同上。"
        },
        {
          "character": "陈伯愚",
          "type": "西皮原板",
          "text": "三月三日正清明，"
        },
        {
          "character": "陈夫人",
          "type": "西皮原扳",
          "text": "家家户户上坟茔。"
        },
        {
          "character": "陈伯愚",
          "type": "西皮原板",
          "text": "别人家有儿女何等侥幸，"
        },
        {
          "character": "陈夫人",
          "type": "西皮原板",
          "text": "我二老年半百缺少后根。"
        },
        {
          "character": "陈伯愚",
          "type": "西皮原板",
          "text": "将身儿我且把坟茔进，"
        },
        {
          "character": "陈夫人",
          "type": "西皮原板",
          "text": "见几个来往的上坟之人。"
        },
        {
          "character": "陈伯愚",
          "type": "西皮原板",
          "text": "望祖先在阴曹多多保应，"
        },
        {
          "character": "陈夫人",
          "type": "西皮原板",
          "text": "保佑得我二老四时康宁。"
        },
        {
          "character": "陈伯愚",
          "type": "西皮原板",
          "text": "叩罢了祖先爷站立不稳，"
        },
        {
          "character": "陈夫人",
          "type": "西皮原板",
          "text": "上前去搀扶起年迈之人。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "陈芝，祭礼赏与朱仓。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "祭礼赏与朱仓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱仓上。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "谢谢员外、安人。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "员外，你我到坟前游玩游玩。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "年年如此，有什么游玩？"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "怕的来年有你无我。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "有你无我。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "彼此。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "一样。安人你看青的是——"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "松。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "绿的是——"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "柏。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "松柏长青。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "牛马来往。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "好个牛马来往。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "员外，大哥、大嫂的坟墓，哪个上了去了？"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "吓，你我不来，还有何人前来？"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "纸钱灰未散，上坟人去之不远。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "唤朱仓。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "朱仓！"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "叩见员外、安人。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "大员外坟墓，哪个上了去了？"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "清明节上坟人多，谁家错上了坟了。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "唔，快快讲来。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "陈大官。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "吓，陈大官，也是你这奴才叫的么？"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "大官叔。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "叫他前来。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "大官叔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈大官内允，上。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "大相公，员外叫你。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "说我不在这里。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "员外，大相公说：说他不在这里。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "这是怎么了？ 大相公。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "你去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱仓推陈大官。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "怎么将他推倒在地。"
        },
        {
          "character": "朱仓",
          "type": "白",
          "text": "他要学武戏。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱仓下。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "奴才，敢是前来偷盗树木来了？"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "哎呀，叔父，今当清明佳节，侄儿在街坊讨了几文钱，买些纸钱，与爹娘上坟 来了！"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "哎呀，安人，倘若你我二人下世，这奴才他就不来了。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "哎呀，叔父吓，倘若你二老黄金入库，孩儿照样前来烧纸化钱。从今以后，遇 斧斧下死，遇涧水下亡，儿再也不来了。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "咳，儿吓！"
        },
        {
          "character": "陈伯愚",
          "type": "西皮摇板",
          "text": "小奴才说出这伤心话，"
        },
        {
          "character": "陈夫人",
          "type": "西皮摇板",
          "text": "倒叫我年迈人珠泪如麻。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "吓，员外，我有意将大官儿收留名下，不知意下如何？"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "但凭安人。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "大官儿，你叔父有意收留于你，你意如何？"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "如此爹娘请上，受儿一拜。"
        },
        {
          "character": "陈大官",
          "type": "西皮摇板",
          "text": "爹娘请上儿拜定， 从今以后当亲生。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "陈芝，回去取几件好衣帽来，接你大相公回去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子允，下。"
        },
        {
          "character": "陈伯愚",
          "type": "念",
          "text": "我儿改邪要归正，"
        },
        {
          "character": "陈夫人",
          "type": "念",
          "text": "莫学浪子花了心。"
        },
        {
          "character": "陈大官",
          "type": "念",
          "text": "立志休被旁人笑，"
        },
        {
          "character": "陈伯愚",
          "type": "念",
          "text": "从今要学人上人。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "大官儿为何不走？"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "怕叔父要打侄儿。"
        },
        {
          "character": "陈夫人",
          "type": "白",
          "text": "员外请转，大官儿怕你拷打，不回去。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "儿吓，从今以后，有口不来骂儿，有手不来打儿。这万贯家财，付儿掌管。成 人也在儿，不成人也在我儿。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "哦，从今以后，有口不来骂我，有手不来打我。这万贯家财，付儿掌管。成人 也在我，不成人也在我。这就是："
        },
        {
          "character": "陈大官",
          "type": "念",
          "text": "爹娘打骂终何用，成人还要哪、哪、自成人。"
        },
        {
          "character": "陈伯愚",
          "type": "白",
          "text": "好吓，好个“成人还要自成人”！大官儿，随为父的来吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈伯愚下。"
        },
        {
          "character": "陈大官",
          "type": "白",
          "text": "是是。嗳、嗳，发了烟瘾了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈大官、陈夫人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}