{
  "script_id": "01023009",
  "title": "双锁山",
  "alias": [
    "俊保招亲"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "高俊保",
      "hangdang": "小生"
    },
    {
      "name": "刘金定",
      "hangdang": "贴旦"
    },
    {
      "name": "刘能",
      "hangdang": "丑"
    }
  ],
  "plot": "高俊保奉父之命，出营探山。行至双锁山前，见树木之上，铸有七言诗四句，系女寇刘金定所铸。自述从仙\n山学武下来，欲与高俊保结为婚姻云云。高俊保见之大怒，即将诗句铲去。其意尽谓身系将门之子，岂肯与\n贼女定为夫妻。继而刘金定得报，下山面会，并言奉仙师之命，与君有姻缘之份。讵知高俊保执意不应，遂\n相交锋。刘金定不敌，卒用法术困高俊保于山腰。高俊保求死不得，只得允从。刘金定乃放之下，邀入山寨，\n款待成亲云。",
  "notes": "《双锁山》一剧，系出后周赵宋间之俗传小说中，其剧情大致与丁山招亲相仿佛。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、高俊保同上。"
        },
        {
          "character": "高俊保",
          "type": "西皮流水板",
          "text": "帐中领了父帅言， 命我出营去探山。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "俺，高俊保。帐中领了父帅的将令，命我前去探山，不免就此前往。 众三军！听你少爷一令。"
        },
        {
          "character": "高俊保",
          "type": "西皮导板",
          "text": "高俊保在马上把令传，"
        },
        {
          "character": "高俊保",
          "type": "西皮快板",
          "text": "叫声三军听我言： 今日领兵把山探， 鞍前马后莫偷闲。 人来与爷往前趱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手同转场，同下。"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "去到山前看根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高俊保下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "刘金定",
          "type": "内西皮导板",
          "text": "辞别了圣母下山岗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四女兵、四下手、刘金定同上。"
        },
        {
          "character": "刘金定",
          "type": "西皮摇板",
          "text": "师父教我的道法强。 跨马提枪精神爽， 双锁山前逞豪强。 下山会授三件宝， 叫奴领兵保宋王。 旁人岂是真天子， 真龙本是赵玄郎。 众喽兵催动人和马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四女兵、四下手同走圆场，同下。"
        },
        {
          "character": "刘金定",
          "type": "西皮摇板",
          "text": "下山去看是谁来摆战场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定蹚马，浪头，耍枪花，下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘能上。"
        },
        {
          "character": "刘能",
          "type": "唱",
          "text": "时才领了姑娘命， 叫我下山去巡风。 急急忙忙把山下， 去到山下看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘能下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、四女兵、刘金定同上。"
        },
        {
          "character": "刘金定",
          "type": "西皮流水板",
          "text": "勒住马头用目看， 双锁山上是威严。 层层叠叠松柏树， 重重密密是山巅。 就在山巅留诗句， 手持银枪把山剜。 奴家本是刘金定， 辞别师父下仙山。 倘若遇着高俊保， 奴与他定然结姻缘。 一首诗句写完了， 字字行行写的全。 拨转马头回山转， 松林之内暂停鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定耍枪花，下，四龙套、四女兵、四下手同随下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘能上。"
        },
        {
          "character": "刘能",
          "type": "数板",
          "text": "好，好，好，我来了，姑娘叫我来巡哨，只得下山瞧一瞧。我也不骑马，我也 不坐轿，转仗两条腿来跑。若有人打从山下过，定要留下财和宝。你若留下便 罢了，怒脑姑娘你名难保。姑娘武艺好，她的道法高。我刘能，不会半分毫。 一打仗，我就跑，跑到营中睡大觉，一觉睡到天明了。吃的跑睡得着，说着说 着，就来了，呵哈哦，我还是睡他娘的一大觉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高俊保上。"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "来在山前催坐战， 勒住马头仔细观： 山岩之上留诗句， 字字行行写的全： 奴家本是刘金定， 辞别师父下仙山。 倘若遇着高俊保， 奴与他定然结姻缘。 看罢诗句怒冲冠， 丫头胆敢出大言。 少爷本是将门后， 怎能与女寇结姻缘。 手提银枪把诗句铲， 又见一人睡山前。 向前且把小卒叫，"
        },
        {
          "character": "刘能",
          "type": "唱",
          "text": "抬头只见一少年。 你是何人来到此？"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "你高少爷前来要洗山。"
        },
        {
          "character": "刘能",
          "type": "唱",
          "text": "听一言来心害怕， 去对姑娘说跟芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘能下。"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "急忙催动坐下马， 等候丫头动杀法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高俊保下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、四女兵、刘金定同上。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "山前山后来闲玩，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘能上。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "又只见刘能到跟前。"
        },
        {
          "character": "刘能",
          "type": "念",
          "text": "报，报，报，报与姑娘你知道。山下来了一员将，威风凛凛甚年少。 白盔白甲白旗号，凶猛非常赛虎豹。跨下一骑白鬃马，手提银枪光耀耀。 他说他姓高，他要想把山寨洗平了。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "一同追上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、四女兵、刘能、刘金定同转场。四龙套、四上手引高俊保同上。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "喽兵一齐往前进， 要与来将动刀兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、高俊保同打过合，比式子。四龙套、四下手、四女兵、四龙套、四上手同哦那个钻烟筒下。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "问声小将通名姓，"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "高俊保就是你少爷的名。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "高俊保长得好。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "也罢了。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "叫小将进前来听奴相告，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、高俊保二过合架枪。"
        },
        {
          "character": "刘金定",
          "type": "西皮快板",
          "text": "细听奴家说根苗： 山岩诗句留的好， 你铲平字迹为哪条？ 你若与奴成婚配， 双锁山中结鸾交。 你我一同把山下， 情愿同你保皇朝。 你若不把亲事允， 管教你性命就难逃。"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "丫头休得来逞强， 细听少爷说端详： 我本堂堂有名将， 怎能与你配鸾凰？ 你若再要胡言讲， 管叫你枪下一命亡。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "听一言来怒气生， 不由奴家动无名。 手执银枪将尔刺，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、高俊保同起打，快枪。刘金定败下，高俊保拉下场花，下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘金定上。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "小将武艺时可夸， 杀得奴家两眼花。 急忙掐诀念咒语， 遣来了六丁合六甲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小鬼持风旗同上。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "山前来了高俊保， 命你前去将他拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小鬼同下。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "回头再把土地叫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "参见道姑。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "将小将吊在半山崖。 莫要伤了他性命， 他本是栋梁保皇家。 拨转马头追小将， 奴再与他动杀法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定下。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "道姑已去，待吾变来。 一变二变，樵夫出现。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地扮樵夫。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "这还无有柴担，待我用拐杖变来。 看柴担已有了，待我在此。等候他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地下。"
        },
        {
          "character": "土地",
          "type": "stage",
          "text": "【【第八场】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高俊保上。"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "催马来到山岗上， 待等丫头摆战场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定上，打过合。四小鬼同上，同托高俊保上桌子。刘金定下。樵夫上。"
        },
        {
          "character": "樵夫",
          "type": "念",
          "text": "老汉今年八十八，一生尚未成过家。娶了一个老伴九十二，我两个人足足一百 八。 每日上山把柴打，回家把米面糊涂揸。每人咂上一二碗，预备明年抱娃娃。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "这丫头也不知怎样，把我引到这山岩之上，我是怎生下去？看下面有一老汉， 带我唤他一声。 老伯伯请了！"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "何人唤我？"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "老伯请了。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "你这个娃娃，怎么跑到山岩上去玩耍？倘若跌将下来，那还了得！"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "老伯，你在那里作甚？"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "老汉在此砍。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "你若大的年纪，怎么还砍呐？"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "嗳。老汉在此砍樵。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "望求老伯，救我一救。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "要我救你，也倒不难。待我将柴担捆好了。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "老伯伯你来呀。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "我来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小鬼同上，用风旗遮高俊保，樵夫下。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "不、不好了！"
        },
        {
          "character": "高俊保",
          "type": "唱",
          "text": "中了丫头牢笼计， 将我吊在半山漥。 倘若失足跌下去， 定然一命染黄沙。 我哭一声父帅，叫一声老爹爹！嗳嗳，我的娘吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定上。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "叫声小将休逞能， 少时叫你一名倾。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "刘小姐，刘姑娘，你将我放下山来吧！"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "叫姑娘放你倒也不难，只是姻缘之事如何？"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "我从下就是。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "恐怕你还有三心二意，必须对天明誓。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "我若有三心二意，叫天厌之，天厌之！"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "众神速退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小鬼同下。高俊保自桌下。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "山寨摆宴与将军接风。歇兵三日，同下南唐。"
        },
        {
          "character": "高俊保",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹牌子。刘金定、高俊保同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}