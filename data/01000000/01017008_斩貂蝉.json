{
  "script_id": "01017008",
  "title": "斩貂蝉",
  "alias": [
    "月下斩貂"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "貂蝉",
      "hangdang": "小旦"
    }
  ],
  "plot": "吕布白门楼丧命，家属星散。吕布妾貂蝉，为张飞所得，送与关羽处。关羽光明磊落，安肯蹈非礼之行为，\n纳一失节少妇。虽貂蝉有殊色，亦不足以动其心。且念貂蝉系司徒王允义女，曾用连环计，离间董卓、吕布，\n使彼父子自相残害，而董卓遂因此殄退。牺牲一身，匡扶社稷，貂蝉诚有大功于汉朝也。然关羽恐女子水\n性杨花，乱离之际，难保不为人所污，惟有一死可以保全其名誉。关羽因于夜间唤貂蝉入帐中，拔剑斩之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、八卦旗、二马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "雄心赤胆汉英豪，撩袍勒马破奸曹。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "丹心耿耿社稷牢，万马营中逞英豪。力斩华雄谁不晓，桃园武艺美名标。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺乃汉室关公，自从桃园结义以来，宰白马以祭天，杀乌牛以祭地。一在三在， 一亡三亡。只因水淹下沛，擒了吕布。三弟擒了貂蝉，送与某家，铺床叠被， 这也不在话下。来，"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看今夜有月无月？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "启爷，今夜有月。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "把四面亮窗挂起。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "一轮明月照山川， 推去了云雾星斗全。 坐虎椅看几本春秋左传， 春秋内尽都是妖女婵娟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我想权臣篡位，即是董卓父子；妖女丧夫，即是貂蝉也！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "想起来此事儿令人可恼， 今夜里唤她来问个分晓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "来，唤貂蝉入帐。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "大王吩咐，唤貂蝉入帐。"
        },
        {
          "character": "貂蝉",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉上。"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "转移莲步兰房出， 想起温侯心惨伤。 儿夫吕布失了阵， 擒了奴家付关王。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子貂蝉。被张三将军擒拿，送与二大王铺床叠被。适才呼唤，不免将茶奉 上。"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "十指尖尖捧茶汤， 走向前来细端详。 我见他杀气如山样， 低头不语拜大王。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子貂蝉。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "为何不抬起头来？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "灯光下见貂蝉十分美貌， 杨柳腰裙不染尘。 怪不得温侯父子来争论， 好似嫦娥降下了凡尘。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你乃司徒之女，可知春秋历代褒贬之事么？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子不知。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "能知什么？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "能知三杰。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哪三杰？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "周三杰，汉三杰。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周三杰？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "周公、召公、太公。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "汉三杰？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "萧何、韩信、张良。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "自周朝到我朝，出了多少古今上将？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子才疏学浅，倘有一字差误，望大王恕罪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "恕你无罪，你且讲来。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "大王容禀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "讲。"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "前三皇后五帝年深月久， 有尧舜和禹汤四大明王。 周文王梦飞熊曾经入帐， 渭水河手指下定国安邦。 十八国论子胥明甫上将， 十二国钟娘娘女中豪强。 前七国有孙庞二人斗志， 后七国有乐毅来到齐邦。 我朝中自平帝出了王莽， 光武兴平汉世迁都洛阳。 小女子说不尽古今兴废， 一朝君一朝臣直到我邦。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "有关某听此言微微冷笑， 好一个貂蝉女伶俐佳人。 不问你前朝兴和废， 只问你虎牢关谁是英雄？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "貂蝉女听此言心惊胆怕， 口问心，心问口，自己思量： 论英雄我儿夫可算吕布，"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "呀，"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "这眼前还有那刘备、关、张。 我只得上前去曲膝来跪， 急忙忙上前去口称大王： 论英雄三将军天下无双，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你丈夫吕布呢？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "我儿夫三姓奴臭名难当。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "可曾见我三弟么？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "虎牢关鼓咚咚锣声响亮， 一霎时呼啦啦排开战场。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "头戴着？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "头戴着乌金盔光彩明亮，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "身穿着？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "身穿着乌油甲盖世无双。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "跨下的？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "跨下的乌骓马能行千里，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "手提着？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "手提着一杆丈八蛇枪。 在阵前吼一声如同雷响， 好一似黑煞神降下天堂。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "有关某听此言双眉倒竖， 骂一声貂蝉女无义不良！ 我这里将袍袖来卷上， 今夜里斩了她万古名扬。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂蝉，你可知俺家此剑否？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子不知。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此剑乃周文王所造，菩萨所赐。倘有不平不德之事，便响。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "但不知响过几次了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "响过三次了。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "这第一次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斩了颜良、文丑。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "这第二？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斩你丈夫吕布。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "第三？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你可知第三响么？今日帐前没有别人，就要应在你的身上！休走，看剑！"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "貂蝉女上前曲膝跪， 叫一声大王听我言： 往日里斩的是英雄汉， 今日斩奴为哪般？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂蝉，可知俺是真斩假斩？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "大王定是真斩。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "非也！你乃王司徒之女，能吹剑滚刀之法。待某家教你武艺，掌灯入帐。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "为何灯不明亮？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "上有灯花。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "去了灯花。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "是呀！"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "去了烛花心胆摇， 吉凶事儿全不晓。 乌鸦不住连声叫， 今宵有命也难逃。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂蝉，你看天上月正圆。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "照见水底月斜圆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽杀貂蝉。貂蝉下。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "满怀心腹事， 月下斩貂蝉。 大哥坐镇在西川， 三弟名扬虎牢关。 俺关某下沛擒吕布， 春秋月下斩貂蝉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}