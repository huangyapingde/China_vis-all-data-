{
  "script_id": "01009002",
  "title": "斩马谡",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "马谡",
      "hangdang": "净"
    },
    {
      "name": "王平",
      "hangdang": "老生"
    }
  ],
  "plot": "诸葛亮既冒险用空城计巧退司马懿之后，即弃斜谷西城县，及南安、天水、安定三郡，急返汉中。幸赖赵云\n断后，得不折一人一骑而还。诸葛亮方检点军马讫，忽报马谡、王平偕高翔、魏延同至。诸葛亮先唤王平入，\n责其失事。王平细述马谡愎谏不听，及己如何分兵图救等事而退。待马谡入帐，诸葛亮变色怒诘曰：汝非\n自谓饱读兵书，熟谙战法者耶？汝可知街亭乃吾根本之地，况吾临送时，如何累累叮咛告诫。汝若早听王平\n之劝，何至有此？马谡只有深自引咎，俯首甘受军法而已，惟以八旬老母为请。诸葛亮既令左右绑出，复唤\n回以好言慰之，大有依依不忍之状。盖诸葛亮既爱其才，又抱“伯仁由我而死”之隐憾。故虽正军法，而挥\n泪大哭幼常不已。至左右问之，诿称“追思先帝之明”因而痛哭，则又其用计处，而藉以自解之语也。读书\n观戏者幸勿为其瞒过。",
  "notes": "诸葛亮虽非害马谡，然明知其不可用而故用之，则虽谓马谡由诸葛亮而死，亦无不可。非大错苛责也。试观\n其遣王平为副，及事前种种周密之设备，可知诸葛亮实早知马谡之十九不可用也。\n此剧于诸葛亮挥泪斩谡时，颇难形容，需做得又恨又痛惜，于严厉中寓爱怜不忍，无法援救之状，始得将其\n心事曲曲得出也。谭叫天与贵俊卿，演时最注意于此，名下毕竟无虚。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "先帝创业三分鼎， 险些一但化灰尘。 将身且坐宝帐等， 马谡回来问斩刑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "王平、马谡回营请罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "吩咐击鼓升账！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "赵老将军回营。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上，诸葛亮敬酒，赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，传王平进帐！"
        },
        {
          "character": "手下",
          "type": "白",
          "text": "王平进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平上。"
        },
        {
          "character": "王平",
          "type": "西皮快板",
          "text": "忽听丞相传将令， 好叫王平胆战惊。 迈步且把宝帐进， 等候丞相把令行。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮导板",
          "text": "返来覆去难消恨，"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "抬头只见小王平。 先前怎样对你论， 靠山近水扎大营。 失落街亭不打紧， 反被司马笑山人。 他道我平日用兵多谨慎， 交锋对垒错用了人！"
        },
        {
          "character": "王平",
          "type": "西皮快板",
          "text": "丞相不必怒气生， 细听末将说分明： 虽然失却街亭地， 先有画图到来临。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "不是画图来得紧， 定与马谡同罪名，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来吓！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "将王平责打四十棍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套押王平下。"
        },
        {
          "character": "龙套",
          "type": "内白",
          "text": "一十、二十、三十、四十。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "再传马谡无用的人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套押马谡上。"
        },
        {
          "character": "马谡",
          "type": "西皮快板",
          "text": "只恨不听王平话， 失落街亭犯王法。 将身跪在宝帐下， 且候丞相把令发。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "一见马谡跪帐下， 不由山人咬钢牙。 先前吩咐你的话， 不该山顶把营扎！ 失落街亭倒也罢， 有何脸面对汉家？"
        },
        {
          "character": "马谡",
          "type": "西皮快板",
          "text": "丞相不必怒气发， 末将言来听根芽： 白虎当头凶难化， 因此街亭失落他。 丞相快把令传下， 斩了马谡正军法。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "想起先帝托孤话，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "先王吓！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "一时大意错用他。 吩咐两旁刀斧手， 快将马谡正军法！"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "丞相宝帐令传下， 要将马谡正军法。 我今一死倒也罢， 家中还有老白发。 将身跪在宝帐下， 还求丞相饶全家。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相，末将一时大意，今将街亭失落，丞相将我斩首，末将一死倒也罢了。家 中还有八旬老母，无人侍奉，我死之后，还求丞相另眼看待，谡纵死九泉也感 丞相大恩也，吓！"
        },
        {
          "character": "马谡",
          "type": "哭",
          "text": "哎哎，丞相吓！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮导板",
          "text": "见马谡只哭得泪如雨洒，"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "马谡，参谋吓！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "我心中好似快刀扎。"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "马谡！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "参谋！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "武侯！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "非是山人定要将你斩首，只因你未曾出兵，先立军状，今日失守街亭，若不你 斩首，焉能服得汉营中大小三军？"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "马谡！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "参谋！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "武侯！"
        },
        {
          "character": "诸葛亮、马谡",
          "type": "对哭",
          "text": "吓……吓……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，斩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "手下允。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "招回来！ 马谡，你方才言道：家有八旬老母，无人侍奉。你死之后，将你钱粮拔与你老 母名下，为养老之费。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "多谢丞相，"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "马谡！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "参谋！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "武侯！"
        },
        {
          "character": "诸葛亮、马谡",
          "type": "对哭",
          "text": "哎哎……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，斩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "手下允，押马谡下，开刀。龙套上，献首级。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "适才帐中来叙话， 一腔鲜血染黄沙。 我哭一声马参谋，叫一声马幼常，吓吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "丞相为何泪如麻？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "丞相，今日斩了马谡，为何流泪？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎呀，老将军，我想先帝白帝城托孤之时，言道：马谡言过其实，总无大用。 山人一时大意，错用了马谡，失守街亭。我哭得先主，何曾哭得马谡？待山人 拜本还京，自贬武乡侯，以安军心。掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗，诸葛亮、赵云同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}