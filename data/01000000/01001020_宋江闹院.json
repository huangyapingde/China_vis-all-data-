{
  "script_id": "01001020",
  "title": "宋江闹院",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "宋江",
      "hangdang": "老生"
    },
    {
      "name": "阎惜姣",
      "hangdang": "花旦"
    },
    {
      "name": "张文远",
      "hangdang": "丑"
    }
  ],
  "plot": "宋江为郓城县书吏，昵土娼阎惜姣，为营乌龙院以居其母女，给衣食。宋江有徒张文远，性佻健，喜冶游，\n常乘间入院，与阎惜姣言笑取乐。阎惜姣亦爱张文远年少风流，遂与之通。久之，乐张文远而厌宋江。人言\n啧啧，宋江有所闻，责阎惜姣忘恩负心。阎惜姣不服，反唇相讥，宋江大受奚落。宋江在郓城，常勾结梁山\n大盗晁盖等，私相往还。一日，晁盖遣刘唐至宋江处下书赠金，宋江藏书金于招文袋。夜宿乌龙院，黎明即\n匆匆出门。至中途，忽悟招文袋遗失在院，大惊，急回院搜索不得，意必为阎惜姣所匿。问之，阎惜姣直认\n不讳。宋江哀恳再三，许尽与其金，而求将书掷还。阎惜姣掉头不允，逼宋江亲立笔据，许与张文远来往，\n不准宋江再来院。宋江不得已允之。立据后，阎惜姣谓盗书当呈县令，论宋江当堂领取。宋江急甚，苦求不\n已，而阎惜姣置若罔闻。宋江怒不可遏，遂拔刀刺死阎惜姣，取书而去。阎婆见女为宋江所杀，即控宋江于\n县。县令稔知宋江为人诚实宽厚，欲偏袒之。无奈张文远伤其所欢横罹惨酷，欲为之伸雪，坚执宋江罪，并\n嘱阎婆上控，以胁县令。县令乃科宋江以误杀罪，流至江州。后张文远为阎惜姣活捉去，亦不得善终云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张文远上。"
        },
        {
          "character": "张文远",
          "type": "念",
          "text": "惜的的，爱的的，私通阎婆惜。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "在下张文远，今拜宋江门下为徒。我与那阎婆惜眉来眼去，两下苟合。今日闲 暇无事，不免到乌龙院走走。"
        },
        {
          "character": "张文远",
          "type": "二黄平板",
          "text": "摇摇摆摆摆摆摇， 摇摇摆摆过小桥。 一步儿来至在乌龙院， 叫声大姐快开门。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "大姐开门来！"
        },
        {
          "character": "阎惜姣",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣上。"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "忽听得双环响一声， 不知来的是何人。 用手儿开开了门两扇，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张文远进门。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "妙啊，妙啊！"
        },
        {
          "character": "张文远",
          "type": "二黄平板",
          "text": "有劳大姐礼相迎。"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "搬一把椅儿三郎坐，"
        },
        {
          "character": "张文远",
          "type": "二黄平板",
          "text": "大姐几日可安宁？"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "问三郎为何不到乌龙院？"
        },
        {
          "character": "张文远",
          "type": "二黄平板",
          "text": "衙前惧怕一个人。"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "问三郎怕的哪一个？"
        },
        {
          "character": "张文远",
          "type": "二黄平板",
          "text": "怕的师傅宋公明。"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "那宋江他是狼来他是虎？"
        },
        {
          "character": "张文远",
          "type": "二黄平板",
          "text": "非狼非虎，惧怕他三分。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "三郎你可好？"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "我好，大姐你可好?"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我也好。三郎这几日，为何不到乌龙院中走走？"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "衙前有事，少来拜望。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "这也难怪"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "啊，大姐，手中拿的是什么？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "红绣花鞋。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "是哪个穿的？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我妈穿的。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "妈儿娘老大年纪，怎么穿红绣花鞋？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "今天十四，明天十五，是我妈的生日。做双花鞋，与她老人家上寿的"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "不是大姐提起，我倒忘怀了。如此说来，我明日礼到人不到。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "是要你的人来。礼不来，不要紧的"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "如此说来，我礼到人又来。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "这不结了吗！"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "啊，大姐，你可晓得我的来意？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你要怎么样？"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "我要与你高兴高兴。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你猜我呢？"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "大姐越发的要高兴高兴。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我今天有点不高兴。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "三郎你回来。你上哪里去？"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "大姐今天不高兴，我等你高兴，我再来呀。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我跟你闹着顽的"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "你跟我闹着顽，唬了我一身的冷汗。正是："
        },
        {
          "character": "阎惜姣",
          "type": "念",
          "text": "东边日出西边雨，"
        },
        {
          "character": "张文远",
          "type": "念",
          "text": "大姐说我情来越有情。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "三郎随我来。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张文远、阎惜姣同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "众人",
          "type": "内同白",
          "text": "退堂呢！"
        },
        {
          "character": "宋江",
          "type": "内白",
          "text": "列位少陪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江上。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "大老爷打罢了退堂鼓， 衙前来了宋公明。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "卑人宋江，在这郓城县，当了一名刑房。今日闲暇无事，不免到乌龙院中走走。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "那一日打从在大街上， 偶遇好汉叫刘唐。 他把那实言对我讲， 请我梁山去为王。 一步儿来至在大街上，"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "啊，列位，你们来看前面走的张文远，后面跟的宋公明。师徒二人，同走一条 道，令人好笑，哈哈哈！"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "又听得那邻舍说短道长。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎呀，且住。听他们街坊邻舍言道：“前面走的张文远，后面跟随宋公明。师 徒二人，同走一条道路。”莫非张文远这小奴才，也到乌龙院中走走。嗳，是 非终朝有，不听自然无。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "自古道是非终朝有， 耳不听来自然无。 一步儿来至在乌龙院， 青天白日把门关。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊？青天白日为何将门紧闭？待我上前叫门。大姐开门来。呔！大姐开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣上。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊？宋大爷声音，难道听不出来了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哎，宋大爷来呢。你今天来得不凑巧。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怎么来得不凑巧？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "钥匙不在我身上。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "在哪一个身上？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "在我妈身上。你改日再来吧！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呀呸！快快到妈儿娘房中，将钥匙取来开门。快去！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "晓得了，你等一会儿。三郎快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张文远上。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "哎，大姐什么事？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "不好呢，你师父来了！"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "咳呀，这便怎么处？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "不要紧，你在我妈房里躲一会儿。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "快些打发他走啊！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "快些！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "为何这样慢腾腾的，待我打进去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣开门，宋江进门，东看西看。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哎哎哎，宋大爷，你进得院中，东照西望，难道我这院中，有什么歹人不成？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "不是啊。宋大爷往日进得院来，扫地挂画。今日进得院来，地也不扫，画也不 挂。来个朋友，像个什么样儿？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷，我啊不知道你今天要来。我知道你要来呀，地也扫了，画也挂了。我 没打算你来。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦，大姐不打算我来，我倒偏偏地来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣坐下。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎，大姐，这就是你的不是了。宋大爷进得院来，你就该搬个椅儿过来，让你 宋大爷坐下，才是你的道理。怎么你自己倒先坐下了。轻慢你宋大爷，怠慢你 宋大爷，真是岂有此理！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷，这边有的是凳子，那边有的是椅子，自己不会坐下，难道叫我搂住你， 抱住你？来来来吃点奶奶吧？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎呀呀，这倒不消了。哎呀，是啊。这边有的是凳子，那边有的是椅子，我自 己不会坐下，难道叫她搂住我，抱住我，自讨无趣？待我自己坐下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江、阎惜姣同坐椅子。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷你这怎么呢？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "花钱的老爷们儿就欢喜这个调调儿。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你猜我呢？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐么，你也喜欢？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我就恼得这个调调儿。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐不欢喜这个调调儿，我就免了这个调调儿。大姐你可好？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我没有病，怎么不好？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我也好。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "谁问你呢？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我问过大姐，大姐必要问我。我替大姐说了，省得大姐你劳神。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哪里这么些淡话？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐手里拿的什么？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你的帽子。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "分明是鞋子，怎么是帽子？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你知道么你问？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哪一个穿的？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我妈穿的。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "妈儿娘偌大年纪，穿什么红绣花鞋？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "今天十四，明天十五，我妈生日，做双花鞋与我妈上寿的。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦，不是大姐提起，我倒忘怀了。明日我礼到人不到。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "是要礼到，人不来不要紧。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "如此，我礼到人不来。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你来不来不要紧。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐，闻得你一双巧手，今日要见识见识。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "一双花鞋有什么好看？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "看看也不要紧。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你要看拿去。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "拿来。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "好脏的手！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦，我的手脏了。时才在衙内，抄写墨卷，未曾洗手，待我洗洗干净。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "拿去！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎，大姐这就是你的不是了。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你又挑眼了？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你方才嫌我的手脏，如今你把它丢在地下，难道他就不脏了么？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷你不要生气。常言道的好：洗手净指甲，作鞋泥里踏。终久它是要坏的。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "是啊，“洗手净指甲，作鞋泥里踏。”终久它是要坏的。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你往哪里指？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我说这个鞋子。待我来看看。果然做的不错呀，好，拿去罢！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你还知道好歹吗？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "为人在世，哪有不知道好歹的道理？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "它是怎么好？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "花儿也好，样儿也好，做的也好，这叫做好好好！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "一点不好没有么？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "就有一样。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哪一样？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "颜色不对。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "颜色不对，你就不该来。你拿过来罢！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "宋大爷往日进得院来，你欢天喜地。今日进得院来，面带忧愁，莫非有什么心 事不成？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "没有心事。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "一定有心事。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "慢说没有心事，纵有心事，你也猜不着。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "慢说大姐心事，就是我父母太爷的心事，不猜便罢……"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "要猜呢？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "猜他个八九不离十。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你不要猜。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "一定要猜。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你就猜。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐听了："
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "宋公明打坐在乌龙院， 猜一猜大姐肺腑情。 莫不是茶饭不随你的口？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷，你这头一猜……"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "猜着了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "猜错了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怎么猜错呢？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "想我们平等人家，吃的是鸡鸭鱼肉，还要吃什么龙肝凤目不成？不是的。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦，猜错了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "猜错了。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "莫不是衣裳不遂你的身？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷，你这第二猜……"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "猜着了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你又猜错了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怎么又猜错呢？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "想我们平等人家，穿的是绫罗绸缎。难道呀穿什么描龙绣凤不成？不是的。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦？不是的。再猜。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "莫不是街坊邻居得罪了你？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "想那街坊是好街坊，邻居是好邻居。慢说我得罪不着他们，就是得罪他们，还 要看宋大爷三分金面。不是的。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦，又不是的。我再来猜。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "莫不是妈儿娘打骂你的身？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷，你越猜越不对了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怎么越不对了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "想那妈儿娘，她是我的妈，打也打得，骂也骂得。不是的。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "又不是的啊。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "这不是那不是是何意见，"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊，大姐的心事，往日一猜就猜着了，今日怎么猜不着了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你猜不着，不要猜了。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我一定要猜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江、阎惜姣同做身段。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐，你过来。我这一猜，一定猜着了！"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "莫不是思想我宋公明？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "真有你的！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦，猜着了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "可不是猜着呢！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你是想我？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "可不是想你么！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎呀，我说大姐的心事，果然被我猜着了。请坐请坐。大姐你几时想我？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我前天就想你。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "衙前有事。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "昨天想你。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "朋友吃酒。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "今天又想你。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "今天想我，我倒偏偏地来了！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "今天想得厉害。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怎么样的厉害？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "清早起来，头也不梳，脚也不裹。前厅跑到后院，后院跑到厨房。左手拿一盆 凉水，右手拿住蒜瓣。喝口凉水，咬口蒜瓣……"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "这叫怎么想法？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "这叫做淡想。淡想想断了肝肠！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊，大姐，只怕不是想我！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我不想你谁想你？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐你想我？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你妹子想你！你姐姐想你！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "怪不得大姐人谈论， 道你的言语不中听。 话到舌尖留半句， 说出口来你难为人！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "什么难为人？想我们妇道人家，一要走得正，二要走得端，三条大路走中间！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我问你这一？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我一不作贼！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我问你这二？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "不偷人家的！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我问你这三？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "三啊？还有他妈的四呢！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎！你就坏在这个三上了！"
        },
        {
          "character": "宋江",
          "type": "二黄摇板",
          "text": "都道你私通了张……"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "张什么？张什么？张什么！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "说不出口来，难为情。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "不要紧，我替你难为情。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "宋江",
          "type": "二黄摇板",
          "text": "那张文远！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "张文远！张文远！你的心事，我会猜不着！提起那张文远，你看他这个样儿， 叫我们花钱的老爷们，好不寒心哪！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "被他猜破肺腑情。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哎呀，他怎么会晓得了？这怎么好？有呢，待我去灌灌米汤。哎呀，我说这个 宋大爷……"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呀呸！哪个不叫我宋大爷，要你来叫我宋大爷？宋大爷呀，还宋二爷呢！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷不好，宋先生……"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呀呸！哪个不叫我宋先生，要你来叫我宋先生？真真岂有此理！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哎呀，宋先生……不好，还是宋大爷……，我说宋大爷，我不会吃酒，清早起 来，吃了几杯早酒，酒言酒语，得罪你了。我跟你闹着玩的。谁晓得你不经玩， 一玩就炸呢！哎呀，我说宋大爷啊！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦？你是与我做耍的？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "可不是闹着玩的！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎呀，唬了我一头的冷汗呢！请坐。大姐，从今以后，酒要少饮。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我戒酒了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "少吃些就是了。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我一点也不吃了。宋大爷，你方才说张……张什么？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "张文远。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "张文远是你什么人？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "是我的小徒。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "是你的小徒。白日在街内做什么？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "抄写墨卷。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "到晚来？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "抵足而眠。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷你这话漏了。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "漏了我房东。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "什么“我房东”？你的话头漏了。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "漏了什么？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我看别人没有私通张文远，我看你私通张文远了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "世间之上，自有男子私通女子，哪有男子私通男子的道理？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你没有私通张文远，你猜我呢？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "大姐么，也不能够！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "那么谁公通张文远？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "是啊，哪一个私通张文远？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "眼前有一人，私通张文远，你不敢惹她！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哪一个我宋江不敢惹她？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你的姐姐私通张文远！你的妹妹私通张文远！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "宋江",
          "type": "西皮导板",
          "text": "一言怒恼宋公明！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江、阎惜姣碰椅子。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "阎大姐！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "阎惜姣！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋公明！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "阎婆惜！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋江！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哈哈哈！我宋江的名字，你倒叫起来了。我把你这个狗淫妇！狗淫妇！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哎呀，我把你这死乌龟！你们看他像不像！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呵呵！我宋江花了许多银钱，落了个忘八二字！咳！"
        },
        {
          "character": "宋江",
          "type": "西皮原板",
          "text": "骂一声阎惜姣无耻的贱人！ 曾记得在家遭荒旱， 你一家逃难来到了郓城。 遭不幸你的父丧了命， 无银钱买棺木葬尔的天伦。 尔的母没奈何将你卖， 卖了那身价葬尔的先人。 清早起卖到午时后， 午时卖到夜黄昏。 大街小巷俱卖尽， 并无有一人问一声。 大老爷打罢了退堂鼓，"
        },
        {
          "character": "宋江",
          "type": "西皮快板",
          "text": "衙前来了宋公明。 三十两银子将你卖， 买回家来度光阴。 我为你造下了乌龙院， 我为你花下了许多银。 我为你父母堂上难行孝，"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你就该天打雷劈！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "宋江",
          "type": "西皮快板",
          "text": "我为你失散了夫妻情。 怒气不息将你打！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你要打谁？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我要打你！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我告诉你，太太好吃好穿没见过，好打见过的！我打个样儿与你看看！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "定要打你！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江、阎惜姣碰膀子。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "呀吓！踹了我的脚了！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怎么样了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你走开去吧！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "宋江",
          "type": "西皮快板",
          "text": "越思越想越伤心。 一怒赶出乌龙院！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我就走！"
        },
        {
          "character": "阎惜姣",
          "type": "西皮快板",
          "text": "阎婆惜到处有宾朋。"
        },
        {
          "character": "宋江",
          "type": "西皮快板",
          "text": "任你跑到天边远， 难逃宋江掌握中！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "谅不就！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "谅的就？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "宋江",
          "type": "西皮快板",
          "text": "从今后我不进乌龙院！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "再来呢？"
        },
        {
          "character": "宋江",
          "type": "西皮快板",
          "text": "情愿对天把誓盟！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我不信！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我就对……"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我就跪……"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎，大姐我是与你做耍的。你怎么跪下了？来个朋友，看见像什么样儿？你起 来吧！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我也不是三岁两岁小孩，让你打哭呢，哄乐呢！你与我跪下罢！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "双膝跪在尘埃地， 过往神灵听分明： 从今后再进乌龙院，"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "药酒毒死我宋公明！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你走出去！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "嗳，我与她恩爱夫妻，争吵几句，说什么不来？待我转去……啊？这贱人已经 将门紧闭。哎！大丈夫做事，提得起，放得下。这烟花之地，来不来，有什么 要紧？说不来我就不来了。嗳？说什么不来？想这乌龙院，乃是我银钱所造， 阎惜姣是我银钱所买，我宋江不来，是哪个敢来？从今以后，无有风吹草动便 罢，若有风吹草动，我就是这一刀结束尔的狗命！正是："
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "当初不听朋友劝，失足上了无底船。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "受了许多的腌臜的气。哎！花了许多昧心钱。列位老爷们，你们哪个要来只管 来走走，我宋江是不来了，我一定不来了。嗳！我是再也不来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江下。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷！宋江！哎呀，真走了！待我开开门，看看走呢！三郎快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张文远上。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "我师父可曾走了？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你师父走了。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "我也要去了。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你回来！"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你还愿意作长久夫妻，还是愿意作短头夫妻？"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "长头夫妻怎说？短头夫妻怎讲？"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "短头夫妻，你今个去了，不要来了。"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "我舍不得大姐。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你舍不得我，我也舍不得你。闻听人说宋江私通梁山，你在外头访，我在家里 访。访出此事，将他送入当官，你我就是长久夫妻了！"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "好，我告辞了。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "回来。我看看有人没人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣看。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "没有人。正是："
        },
        {
          "character": "阎惜姣",
          "type": "念",
          "text": "二人定计二人知，"
        },
        {
          "character": "张文远",
          "type": "念",
          "text": "休要走漏这消息。"
        },
        {
          "character": "阎惜姣",
          "type": "念",
          "text": "但愿害得宋江死，"
        },
        {
          "character": "张文远",
          "type": "念",
          "text": "你我夫妻顷刻离。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "哎呀，永不离！"
        },
        {
          "character": "张文远",
          "type": "白",
          "text": "不错，永不离。请吓，请吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张文远下。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "正是：宋江啊，宋江，管叫你："
        },
        {
          "character": "阎惜姣",
          "type": "念",
          "text": "明枪容易躲，暗箭最难防！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
