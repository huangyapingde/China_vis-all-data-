  "plot": "薛平贵既回窑，夫妇满意甚。会值王宝钏父王允寿诞，夫妇商略届时往贺寿，即与魏虎算粮，借端寻隙，以\n图报复。计定，届日王宝钏先往，仍伪作孤苦状，不提薛平贵归来事。既而席间，王允遣二女及婿，劝王宝\n钏改蘸。王宝钏遂与争论，继以耻笑，唯于苏龙前，略吐己意，盖苏龙本当年救薛平贵，而有德于王宝钏者\n也。既而王宝钏愤愤出，引薛平贵至。遂与魏算粮争闹。",
  "notes": "后本即《大登殿》。此剧虽名为《算粮登殿》，仅算粮而未尝登殿也。剧中最重角色，为王宝钏。盖其出言\n吐语，或争执，或讥讽。处处皆有有恃无恐之意。故必描摹到丝丝入扣，方为得当。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王允上。"
        },
        {
          "character": "王允",
          "type": "念",
          "text": "我本是一朝忠宰，倒做了位列三台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启相爷：文武前来拜寿。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "明日朝房面谢。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "明日朝房面谢。"
        },
        {
          "character": "丫鬟",
          "type": "内白",
          "text": "三姑娘到。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘到。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "吩咐丫鬟有请三姑娘。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "吩咐丫鬟有请三姑娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "哎哎，来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "王宝钏离了寒窑院， 想起了平郎夫嘱托之言。 昨日里我夫妻曾相见， 他命我到相府去把粮搬。 这几载未到过王相府， 油漆彩画不一般。 王宝钏行抵进相府，"
        },
        {
          "character": "丫鬟",
          "type": "西皮原板",
          "text": "小丫鬟迎接三姑娘。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "问一声我的娘安好可安好？ 我的父上朝可曾回还？"
        },
        {
          "character": "丫鬟",
          "type": "西皮原板",
          "text": "老夫人为你眼哭坏， 老相爷上朝也曾回来。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "我的娘想我常思念， 嫌贫爱富老椿萱。 我不见爹爹回去了罢， 平郎问我无话言。 走上前来双膝跪， 儿本是不孝的王氏宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "宝钏与爹爹叩头。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "下跪儿可是宝钏？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "三小姐？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "罢了儿吓。"
        },
        {
          "character": "王允",
          "type": "西皮慢板",
          "text": "十八载见了王宝钏， 泪珠滚滚洒胸前。 我儿不在寒窑院， 来在相府为那般？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "我儿坐下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "儿谢坐。爹爹身体可好？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "为父安康。儿吓，不在寒窑来在相府为何？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "前来与爹爹拜寿来了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿还记得为父寿诞之日么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "生儿一场，哪有忘却之理？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "好。上房见过你母亲去吧。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哦哦哦，儿遵命。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "可恼爹爹心太偏， 一样女儿两样看。 想父不与奴讲话， 后堂去把老娘参。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下，丫鬟下。家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "二位姑老爷到。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "吩咐有请。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。苏龙、魏虎同上。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "岳父大人一向可好？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "老夫常常如此。二位贤婿今天过府，莫非为老夫寿诞而来？"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "特为大人千秋而来。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "今年拜寿比不得往年。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "却是为何？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "我那三女她也来了。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "苏亲，想必三姑娘守节不住，来到相府，是与不是？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "哎。大约借贷而来。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "二位贤婿，少时酒席筵前，相劝三女，另行改嫁，老夫有一言不到，还要二位 贤婿帮言。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "尽在我二人身上。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "家院。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院允。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "吩咐丫鬟，有请老夫人与三位姑娘出堂。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请老夫人与三位姑娘出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王母、王金钏、王银钏、王宝钏、丫鬟同上。"
        },
        {
          "character": "王母",
          "type": "念",
          "text": "厅前亮而高，"
        },
        {
          "character": "王金钏",
          "type": "念",
          "text": "鲜花用水浇。"
        },
        {
          "character": "王银钏",
          "type": "念",
          "text": "人前夸富贵，"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "贫穷苦难熬。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "贤婿把盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。安席。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "上筵。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "二位贤婿请。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "岳父请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "宝钏，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "今日酒筵前，为父有一言，不知当讲不当讲？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹有何金言，当面请讲何妨。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "想那平贵命丧西凉，为父有心与我儿在这五府六部之中，选赘一婿，我儿心意 如何？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹，纵然我那平郎一死，儿要与他守节立志。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿吓，"
        },
        {
          "character": "王允",
          "type": "念",
          "text": "守节要到头，立志要长久。守节不到头，"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿吓，"
        },
        {
          "character": "王允",
          "type": "念",
          "text": "反被人笑丑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹，儿"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "守节要到头，立志要长久。纵然不到头，何劳父担忧？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "从今以后，再不用爹爹相劝。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "臭丫头！"
        },
        {
          "character": "王允",
          "type": "西皮慢板",
          "text": "我一声吓不住王宝钏， 为父的言语全不听。"
        },
        {
          "character": "王母",
          "type": "西皮原板",
          "text": "老相讲话太绝情， 你说三女我心疼。"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "看儿吃来看儿用， 在寒窑只落得这般光景。"
        },
        {
          "character": "王母",
          "type": "西皮原板",
          "text": "你说她穷是她命， 王相府未借米半升。"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "老乞婆说话纵她性， 三女儿俱是你惯成。"
        },
        {
          "character": "王母",
          "type": "西皮原板",
          "text": "守节立志心拿定， 你父之言莫要听。"
        },
        {
          "character": "王宝钏",
          "type": "西皮导板",
          "text": "酒席前施一礼劝奉高堂，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹娘在上，孩儿有一言告禀："
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "儿命薄怎配那状元的才郎？ 闻人说平郎夫西凉命丧， 爹娘吓， 依儿看他还在阳世上。 有此话你就该背地言讲， 同我娘咱三人再作商量。 酒席前现有我二位姐丈，"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "三姑娘，咱们是内亲。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "贼吓！"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "虽然是内亲姓不了王。 王宝钏低头自思想， 想必是穿父的好衣裳。 我把这宝衣宝裳一件一件俱脱下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "咏锣。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "我至死不沾你相府的光。"
        },
        {
          "character": "王允",
          "type": "西皮导板",
          "text": "好一个烈性的王宝钏，"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "宝衣摔在父面前。 回头我把贤婿唤， 老夫不能你向前。"
        },
        {
          "character": "苏龙",
          "type": "西皮原板",
          "text": "酒席筵前告了便，"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "苏亲，你上哪里去？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "相劝三姑娘去。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "好话多讲。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "知道。"
        },
        {
          "character": "苏龙",
          "type": "西皮慢板",
          "text": "上前去相劝王氏宝钏。 三妹妹请来把礼见， 为兄言来听根源： 旁人说平贵把命丧， 是不是还在两可间。 岳父大人命你另改嫁， 从不从尽在你的心间。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "王宝钏走上前忙施一礼， 尊一声大姐丈你听仔细： 在征西路上救命多亏你， 那魏虎他本是谋害的。 昨夜晚回来了一个薛……"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "“薛”什么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "薛平郎相见在寒窑里。 倘若是爹娘问到你， 你一摇二摆三不知。"
        },
        {
          "character": "苏龙",
          "type": "西皮原板",
          "text": "好一个烈性王宝钏， 说出话来人可观。 出言我把魏亲唤， 下官不能你上前。"
        },
        {
          "character": "魏虎",
          "type": "西皮原板",
          "text": "苏亲说话你有差， 男子汉说不过妇道人家。 上前去不用着两三句话， 管教她另行改嫁在目下。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "魏虎",
          "type": "西皮快板",
          "text": "有魏虎，笑嘻嘻， 出言叫声咱三姨。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "三姑娘，老大人在酒席筵前，劝你另行改嫁，为着你来，你要再思再想。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "在我面前摇来摆去，你是什么人？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "吓，连你魏姐丈的声音，都听不出来了？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "听你之言，敢则是魏虎？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "吓，魏姐丈。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你莫非劝你三姑娘改嫁不成？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "一个挑儿摆不开。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "此话……"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "然乎？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "魏虎你敢是放屁！"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "魏虎贼好大胆， 三姑娘面前发癫狂。 有日犯在我的手， 剐你一刀问一声。"
        },
        {
          "character": "魏虎",
          "type": "西皮原板",
          "text": "三姑娘不要把脸翻， 非是俺魏虎卖狠言。 慢说犯不了你的手， 犯在你手也枉然。 狗屁蛋来狗屁蛋， 狗屁蛋来狗屁蛋。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "咱们走着看。"
        },
        {
          "character": "王银钏",
          "type": "西皮导板",
          "text": "酒席筵前告了便，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王银钏走浪。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你扭扭捏捏哪里去吓？"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "相劝三妹妹改嫁。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你不要去，为丈夫带了红胡子回来。你去不要带了鬼脸子。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "我们有姐妹的情肠。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你叫她千万不要嫁了别人。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "嫁哪个？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你我她，咱三人糊里糊涂过两天。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "你吓，咱怎能够吓？"
        },
        {
          "character": "王银钏",
          "type": "西皮慢板",
          "text": "上前来劝王宝钏。 三妹妹请来把礼见， 为姐言来听根源： 人人说平贵把命丧， 你苦苦守节为那般？ 老爹爹命你来改嫁， 轰轰烈烈过一场。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "狗贱人假意将我劝， 王宝钏心中不耐烦。 我看你花枝招展头上戴， 红红绿绿身上穿。 来来来随我到檐下看， 你看一看魏虎贼那个容颜。 秤砣鼻子呕呕眼， 亚赛过古庙中一个判官。 未曾走动大肚皮来挺， 要赛那东海岸一个老乌龟。 我要嫁嫁一个真皇帝， 我是不嫁那魏虎狗官。"
        },
        {
          "character": "王银钏",
          "type": "西皮原板",
          "text": "三妹妹休要出此言， 为姐有话听根源： 你说他不好看， 我看他容貌赛潘安。 你爱平贵哪一件， 不过挨门乞讨郎。 爹爹奶奶千声叫， 好容易赚来一文钱。 在相府不看爹娘面， 我一脚踢你个面朝天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王银钏、王金钏同下。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "三妹妹，自古良言讲的好：死了男儿莫怨天。十字路有万千，去了穿红的，你 看还有我们穿绿的男。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "好贼吓！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "魏虎贼，好大胆， 三姑娘前出狠言。 讲此话你敢打我的手？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "来哉。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "打了我手欺了天。"
        },
        {
          "character": "王允、王母",
          "type": "同西皮原板",
          "text": "走上前来忙遮定， 你二人吵闹为何因？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "就该清算孩儿一十八载的粮饷。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "住了吧，人在粮在，人死粮散。哪有粮饷于你？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "倘若平郎在世？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "加倍奉还。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "好贼，不要改口。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "岂能改口。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "二爹娘与儿作一硬证。魏虎，我把你这贼吓！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "魏虎不要出此言， 三姑娘把话对你明。 如若平郎他在世， 十八载粮饷你要还。"
        },
        {
          "character": "魏虎",
          "type": "西皮快板",
          "text": "假如平贵他在世， 短你一斗还石三。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "魏虎不要说狂言， 爹娘与儿作证见。 低头出了王相府， 寒窑去把平郎搬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "观看宝钏大模大样，莫非平贵他还在世？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "想必平贵还在。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "住了吧，是我亲眼得见，在征西路上，被代战公主挑下马来，腰斩三截。我气 他不过，是这样踏、踏、踏他三脚！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "踏他为何？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "踏他个死不超生。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "死了好。"
        },
        {
          "character": "王母、苏龙",
          "type": "同白",
          "text": "在着好。"
        },
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "有为王打扮的小军模样，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏同上。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "平郎去到相府，见我娘去。你把帽儿戴的端端的，衣服穿的整整的，齐齐的。 看你身上的土，脸上的尘，就不像个拜府的样子。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你要老成些。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "平郎，自古常言讲的好："
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "官凭印信虎凭山，婆娘凭的男儿汉。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你一十八载不在家中，为妻也不敢在人前讲话；如今你回得家来，为妻敢说敢 应的了。我如今也是有了人的了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "太厌气了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你看这是老天爷叫我厌气，我不得不厌气。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你我走吓。"
        },
        {
          "character": "薛平贵",
          "type": "西皮慢板",
          "text": "为三姐叫孤王离了西凉。 此一去到相府莫要乱嚷， 算粮事有丈夫一面承当。 行几步来在了相府以上，"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "死了好！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "魏虎贼在一旁意气昂扬。 见岳母施一礼，可恼丞相， 薛平贵怒轰轰立在一旁。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "平郎为何不坐？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "相府内哪有你我的坐位？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我看有他们的坐位，就有你我夫妻的坐位。你闪开了，待为妻与你端一个坐位 来。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "犹恐坐出祸来。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不妨事，坐出祸来，你来看有我老三呢。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有三姑娘么？我薛平贵就大胆坐下了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "宝钏！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哼。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "厅前坐下一人，志气昂扬，身施一礼，他是何人？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹你问的是他？他就是征西路上，千方百计害不死的薛平贵。他偏偏的又回 来了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "待老夫看过。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "慢着，待小婿看过。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "有劳贤婿。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你上哪里去？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "廊下看先行平贵去。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "我说你这个人真倒霉，分明死去的人了，你要看，鬼门关去看活鬼吧！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "来者敢是薛亲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "原来是苏亲。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "几时回来？少得奉迎，面前恕罪。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好说，征西路上多谢大人救末将不死，当面谢过。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "岂敢，到此为何？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "清算一十八载的粮饷，还请大人作一见证。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "那个自然。请来入席。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "慢着，仇人在此，不便入席，请。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "明白了。 启岳父大人：果然是薛亲回来了。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "住了吧，我看你是不能活了，看见鬼了！明明见他死去，他的鬼魂回来了？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "请自看过。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "那是自然。明明已死，焉能回来？ 吓，不是他是谁。想我在征西路上，百般苦苦害他，今日有何面目相见？有了， 常言说的好，一笑遮百丑，待我上前施一礼，岂不丢开。 吓，那是薛亲，哈哈，几时回来？少得奉迎，望乞恕罪。 吓，听不见，我再来。 吓，那是薛亲，几时回来？少得迎接，这二次有礼。 唗！某连施二礼，你扬扬不采，看我的拳头打下来了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "慢着。魏虎，你在征西路上，未曾将他害死，今天还想把他打。有三姑娘在此， 奸贼你不能！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王银钏暗上。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "三妹妹，这一拳就打死人了么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不是你的汉子，你不心疼。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "我看你太厌气了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你厌气。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "你厌气。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你坐了吧。"
        },
        {
          "character": "魏虎",
          "type": "西皮原板",
          "text": "平贵做事礼不该， 你把我妻搂抱怀。 回头再对大人讲， 果是薛亲转回来。"
        },
        {
          "character": "王允",
          "type": "西皮导板",
          "text": "听说来了薛平贵，"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "小婿告便。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你上哪里去？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "府下有事。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "哪里是有事，分明见我两家事情大了，你想逃脱，是与不是？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "哪有此事。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "也罢，你只管走，有什么大事，都有我老魏。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "他两家事情大了，待我躲在一旁。看他们怎样下场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙下。"
        },
        {
          "character": "王允",
          "type": "西皮慢板",
          "text": "待老夫上前看端的。 看他不像昔年体， 胸前打着三扭须。 为三女上前施一礼，"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "贤婿，老夫有礼了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允低头。"
        },
        {
          "character": "王允",
          "type": "西皮慢板",
          "text": "扬扬不采藐视谁！ 老夫人，快接喜， 薛平贵果然转回归。"
        },
        {
          "character": "王母",
          "type": "西皮原板",
          "text": "贤婿做事欠主裁， 西凉一去不回来。 老身为你眼哭坏， 三女为你受苦埃。 从今向后莫出外， 免得母女挂心怀。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多谢岳母。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "王母",
          "type": "西皮原板",
          "text": "看罢一番笑开怀， 果是贤婿转回来。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "当年脾气还未改， 坐在一旁痴呆呆。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "平郎，你还坐着不成？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "干何事吓？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "上前算粮。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有理不在先后，山高遮不住太阳。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "说什么有理不在先后，山高遮不住太阳？算粮算得明明白白，临行背上一斗大 麦。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "要它何用？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "为妻我好来糊口。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你常来打搅。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你不晓得一十八载，你不在家中，把为妻饿得黄黄的。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如今为丈夫回来，有你吃的有你喝的。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "怎么，有吃的有喝的？哎呀，老天爷，我再也不发愁的了。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "平郎算粮之事要明白， 千万间莫走脱魏虎狗官。"
        },
        {
          "character": "王银钏",
          "type": "西皮原板",
          "text": "大事总有男儿汉， 你我姐妹何相干？"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "头上青丝如墨染， 不是姐妹是仇冤。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "谁是仇冤？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你是仇冤。"
        },
        {
          "character": "王母",
          "type": "西皮原板",
          "text": "你不要巧嘴波浪舌， 你的心肠如蟹尖。 来来来，宝钏儿随娘走， 去到后堂饮杯巡。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "娘吓，走走。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "来吓。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "娘吓，我也要去。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "如今有了你三妹妹，不要你了。从今后若进娘房，打折你的箍拐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王母、王宝钏同下。"
        },
        {
          "character": "王银钏",
          "type": "白",
          "text": "你看有了三妹妹，就不要我了。我偏要去，母亲等着，儿赶来了。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "出言叫声魏元帅， 克扣军饷为哪般？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "魏虎，将你老爷一十八载的粮饷算来。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "住了，潦乱之年，临阵迷走；太平之年，回朝算粮。哪有粮饷于你！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你敢与我面君？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "面君何妨？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "上前抓住袍和带， 万岁面前把理排。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哈哈，好奸贼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、魏虎同下。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "看平贵与魏虎抓袍夺带，上殿面君。待老夫上殿，保他一本便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
