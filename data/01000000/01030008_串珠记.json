          "text": "贤婿请。"
        },
        {
          "character": "蔡鸣凤",
          "type": "白",
          "text": "岳父请。"
        },
        {
          "character": "祝有德",
          "type": "白",
          "text": "贤婿，此番出外，但不知生意如何？"
        },
        {
          "character": "蔡鸣凤",
          "type": "白",
