{
  "script_id": "01003014",
  "title": "富春楼",
  "alias": [
    "缝搭膊"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "周翠屏",
      "hangdang": "旦"
    },
    {
      "name": "陈魁",
      "hangdang": "小生"
    }
  ],
  "plot": "郓城妓女陈三两，本宦家女，真名周翠屏。自小父母双亡，为人鬻入烟花，颇驰美名。客有名陈魁者，年少\n诚笃，与陈三两有齿臂盟。陈三两本有心人，非甘堕落者，平日故多积攒。一日，陈魁为人所辱，诉之陈三\n两，陈三两乘机劝其勿恋烟花，早出经商自立。陈魁患无钱，陈三两遂出所积金，贷以三百两，相约获利后，\n重来为女脱籍，并与缝一搭膊，俾得束诸腰间而去。",
  "notes": "此剧情致缠绵，须做得柔情绰约，不即不离，而无淫荡之态，方合陈三两身价。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小锣。周翠屏上。"
        },
        {
          "character": "周翠屏",
          "type": "引子",
          "text": "清晨起来倚梳妆，蝴蝶儿乱扑纱窗。"
        },
        {
          "character": "周翠屏",
          "type": "念",
          "text": "红颜薄命女娇娘，不幸父母丧无常。命苦身落烟花巷，何日跳出是非墙？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "奴家，周翠屏。爹爹在世，官居五马太守。不幸父母双亡，多蒙姑母，恩养成 人。是她改变心肠，将奴卖在烟巷花柳之中。多蒙世家公子抬爱，赠名陈三两。 是我结拜一个兄弟，名叫陈魁，年长一十六岁，倒是个志气君子。昨日妈儿 娘寿诞之日，命他前去拜寿。这般时候，不见到来。正是："
        },
        {
          "character": "周翠屏",
          "type": "念",
          "text": "满怀心腹事，尽在不言中。"
        },
        {
          "character": "陈魁",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈魁上。"
        },
        {
          "character": "陈魁",
          "type": "念",
          "text": "可恼老淫妇，叫人气断肠。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "姐姐开门来。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "外面什么人叫门？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "为弟到了。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "兄弟到了，待姐姐与你开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周翠屏开门。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "兄弟请进。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "姐姐请。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "有座。可恼吓，可恼吓！"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "兄弟这般嗔怒，与哪个淘气？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "与你妈儿娘淘气。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "与她淘的何气？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "昨日妈儿娘寿诞之日，为弟前去拜寿。满满斟上一杯酒，跪在她的面前，叫她 允承我一件大事。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "什么大事？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "不叫姐姐迎宾接客。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "她可曾允承？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "她竟然不允。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "她不允就罢。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "她罢我不罢。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "你不罢，心想怎样？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "我心想告她。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "你告她下何句语？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "我告她买良为娼，私买人口。大老爷闻听此言，将她一顿板子打死，方消为弟 心头之恨。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "兄弟这两句话，还是你心中就有，还是旁人教道于你？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "姐姐说哪里话来，为弟长成一十六岁，这两句话，不会讲它，怎样为人？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "姐姐告便。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周翠屏背供。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "观看陈魁，虽则年幼，说两句话，倒是个志气男子。我不免借他几百两银子， 叫他大小做个买卖，日后若有发达，好将奴家救出娼门。就是这个主意。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周翠屏坐。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "兄弟你与她呈讼到官，岂不被旁人耻笑？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "依姐姐之见？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "大小做个买卖才好。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "请问姐姐：为弟要做什么买卖才好？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "兄弟愿意做脸朝里的买卖，还是脸朝外的买卖？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "脸朝里的怎讲，脸朝外的买卖怎说？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "脸朝里的买卖：身背货箱，东家门进，西家门出。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "脸朝外的买卖呢？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "脸朝外的买卖：在这郓城县下，开一座绒线铺面，这就是脸朝外的买卖。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "脸朝外的买卖好做，也得三头五百两银子，为弟哪有许多银子？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "你就该在大户人家去借。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "姐姐你又来了。为弟来在这郓城县，靠亲无亲，靠故无故，哪里去寻，哪里去 借？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "也罢。你若肯满满斟上一杯酒，跪在我的面前，叫我三声“亲亲姐姐”，我就 借与你五百两银子。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "姐姐真心？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "真心。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "实意？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "实意。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "陈魁",
          "type": "西皮紧板",
          "text": "满满斟上一杯酒， 双膝跪在地留平。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "亲亲姐姐，请来用酒，请来用酒。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "兄弟，你这算何意？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "弟贺的是五百两银子。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "咳，怎么你就贺的那五百两银子么？我说兄弟吓，兄弟，想姐姐那五百两银子， 非从容易而来的吓！"
        },
        {
          "character": "周翠屏",
          "type": "西皮慢板",
          "text": "一句话儿错出唇， 见兄弟跪在地埃尘。 用手儿搀起结拜弟，"
        },
        {
          "character": "周翠屏",
          "type": "西皮摇板",
          "text": "姐姐言来听原因： 五百银子是小事， 哪知姐姐费尽心。 前门接了有钱客， 后门送出无钱人。 命苦身落烟花巷， 难得积攒这五百银。 但愿得买卖多茂盛， 姐姐才的放下心。"
        },
        {
          "character": "陈魁",
          "type": "西皮原板",
          "text": "姐姐不要两泪淋， 为弟也非无义人。 但愿买卖多茂盛， 我情愿将姐姐救出娼门。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "周翠屏",
          "type": "西皮原板",
          "text": "救不救，全在你， 此话在心莫出唇。"
        },
        {
          "character": "陈魁",
          "type": "西皮原板",
          "text": "自古路遥知马壮， 日久才见人的心。"
        },
        {
          "character": "周翠屏",
          "type": "西皮原板",
          "text": "好一个路遥知马壮， 日久才见人的心。 来来来随姐姐开箱柜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周翠屏开箱。"
        },
        {
          "character": "周翠屏",
          "type": "西皮原板",
          "text": "亲手儿递你五百银。"
        },
        {
          "character": "陈魁",
          "type": "西皮原板",
          "text": "一见银两放桌案， 再叫姐姐你听原因。"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "姐姐，想为弟带了许多银两，若被你妈儿娘看见，她说为弟盗你的家财不成？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "也罢，待姐姐去到楼上，缝上一条搭膊，将银两带出院去，瞒过妈儿娘，岂不 是好？"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "但凭姐姐。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "随姐姐上楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周翠屏、陈魁同上楼。小梆子。周翠屏捻线。"
        },
        {
          "character": "陈魁",
          "type": "西皮摇板",
          "text": "上楼来我这里打开针织， 观兄弟容貌儿可算第一。 缝搭膊表一表姐姐的情意， 他哪知陈三两一片心机。 观兄弟春心动放下作计，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "周翠屏",
          "type": "花梆子原板",
          "text": "叫兄弟你醒来细听仔细。"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "且住，兄弟苏醒，兄弟醒来。睡死你了！"
        },
        {
          "character": "陈魁",
          "type": "白",
          "text": "姐姐搭膊可曾缝完？"
        },
        {
          "character": "周翠屏",
          "type": "白",
          "text": "还有几针，未曾缝完。你我伙缝了罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行上弦。周翠屏咬线。"
        },
        {
          "character": "周翠屏",
          "type": "西皮二六板",
          "text": "我将搭膊缝完毕， 再叫兄弟听仔细： 来来来你把肩儿背，"
        },
        {
          "character": "周翠屏",
          "type": "断板腔",
          "text": "大谅来妈儿不晓得。"
        },
        {
          "character": "陈魁",
          "type": "西皮二六板",
          "text": "姐姐打开皇历看一看， 看看黄道好吉日。"
        },
        {
          "character": "周翠屏",
          "type": "西皮二六板",
          "text": "初四、十五、廿七， 俱都是开市好吉日。"
        },
        {
          "character": "陈魁",
          "type": "西皮二六板",
          "text": "辞别姐姐下楼去，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下锣。"
        },
        {
          "character": "陈魁",
          "type": "西皮二六板",
          "text": "回家去禀告爹娘知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈魁下。"
        },
        {
          "character": "周翠屏",
          "type": "西皮原板",
          "text": "一见兄弟下楼门， 背转身来自想情。 但愿买卖多茂盛， 他将我陈三两救出火坑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周翠屏下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}