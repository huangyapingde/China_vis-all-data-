{
  "script_id": "01006019",
  "title": "三疑计",
  "alias": [
    "拾绣鞋"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "李月英",
      "hangdang": "旦"
    },
    {
      "name": "唐寅",
      "hangdang": "老生"
    },
    {
      "name": "唐子其",
      "hangdang": "小生"
    },
    {
      "name": "书童",
      "hangdang": "丑"
    }
  ],
  "plot": "明季闯贼初起时，有总兵唐寅，所生一子，爱如掌珍，特请王某在家教读。时值八月中秋，王先生因患虐，\n向学生借被蒙汗，学生即向母卧床，取大被一袭，往蒙师身，不意误卷母之绣鞋一只在内，致堕先生榻前。\n唐寅公毕回家，知师有病，特擎灯亲入书斋探问，忽于王先生榻前拾得此鞋，见系妻物，怒不可遏，即回房\n出鞋示妻，并置刀索，逼令妻死。妻以事属无端污蔑，羞忿不白，真欲一死自明，唐寅又疑信参半，遂逼妻\n至王先生处，以试真伪。妻无奈从之去，既至书斋外，妻不知作何语，唐寅教以呼王先生启门，讵知王先生\n因闻系女子声音，且在深夜，拒而不纳。唐寅又逼妻，以卓文君奔司马相如等故事相诱，不意王先生闻言，\n更怒其夤夜淫奔，不守礼法，竟大加斥骂，且言明日当告诉东家辞馆，看汝有何颜面云云。唐寅至是始知其\n冤，乃自责荒唐，亟向妻李氏，陪礼请罪而罢。",
  "notes": "此剧昔年曾见崔灵芝唱演数次，说白清亮，歌响遏云，如闻哀猿啼峡，秋雁唳空，人称之为青衫中之叫天，\n洵不诬也。至于毛韵珂丰腴妩媚，天然佳丽之质，似与此剧不称，孰意每演至此，剧中苦绪幽情，竟能曲曲\n传出，较之崔伶，亦何多让。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "唐寅上，中军上。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "众将官，散操回衙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "唐寅",
          "type": "念",
          "text": "李贼反过江，本镇下校场。操演人和马，与主定家邦。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "本镇唐寅，三六九日操演弓马已毕。 中军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军允。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "吩咐众将散操，改日领赏。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将官，元帅有令散操，改日领赏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同允。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "转堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。中军下。家院、丫鬟同上。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "家院，府下有事无事？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "府下无事。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有事。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "有何事？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "先生染病在床。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "家院不晓，你何为知晓？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "只因少爷在夫人面前，讨去红绫大被，与先生蒙头发汗。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "翠花对夫人去说，茶水伺候。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "家院掌灯。"
        },
        {
          "character": "唐寅",
          "type": "梆子慢板",
          "text": "吾主爷有道坐北京， 湖南地反了李士成。 闯贼领兵多骁勇， 挡住了运粮河路道不通。 叫家院掌银灯头前引路， 到书馆看一看王先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐寅下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王标上。"
        },
        {
          "character": "王标",
          "type": "梆子原板",
          "text": "八月十五月儿圆， 夜夜日日不安然。 将身躺在牙床上， 等徒弟他到来细问根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐子其上。"
        },
        {
          "character": "唐子其",
          "type": "梆子原板",
          "text": "母亲面前讨红绫， 我与先生把汗蒙。 迈步我把书房进， 请问先生可安宁？"
        },
        {
          "character": "王标",
          "type": "白",
          "text": "罢了，子其到此为何？"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "在母亲面前，讨来红绫大被，与先生蒙头发汗。"
        },
        {
          "character": "王标",
          "type": "白",
          "text": "放在桌上，读书去罢。"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "唐子其",
          "type": "梆子原板",
          "text": "施一礼来出书馆， 一到上房读书篇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐子其下。唐寅上。"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "王先生在大街曾把文卖， 我看他文才好带进府来。 进府来我将他好好看待， 为的是唐子其功名文才。 行一步来至在书馆门外， 叫家院掌灯笼前面走来。 进书馆见先生躬身下拜， 尊先生你苏醒本镇到来。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "吓，书童哪里去了？桌案上亦无灯亮，炉子里火也没有，待我掌灯取火。 哎，桌案下面红的不知什么，待我看来。 原来一只绣鞋，怪不得有病，也不知哪家丫鬟，与先生勾引，被俺来的慌忙， 将他二人冲散，这鞋失掉书馆，不免回到府中，见了夫人，说个笑话，待我看 明。吓，这、这、这绣鞋，好象我妻李月英的，怎么在此？李月英吓李月英， 若没此事便罢，倘有此事，俺唐寅岂肯与你干休！"
        },
        {
          "character": "唐寅",
          "type": "梆子乱导板",
          "text": "一见绣鞋怒气冲，"
        },
        {
          "character": "唐寅",
          "type": "唱",
          "text": "无名之火往上升。 意欲上前将他打，"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "唐寅",
          "type": "唱",
          "text": "错打了先生礼不通。 我在此处莫久站， 到馆驿去杀李月英。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐寅下。"
        },
        {
          "character": "王标",
          "type": "梆子原板",
          "text": "一见子其他去了， 不见书童哪里行？"
        },
        {
          "character": "王标",
          "type": "白",
          "text": "这奴才哪里去了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王标下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "李月英",
          "type": "内白",
          "text": "嗳嗳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李月英上。"
        },
        {
          "character": "李月英",
          "type": "梆子慢板",
          "text": "昔日里洪武爷在南京地面， 全凭着文共武保护江山。 文凭着刘伯温阴阳有准， 武凭着老徐达扶保乾坤。 胡大海、常遇春能征惯战， 李文忠他本是皇家外甥。 将身儿坐至在二堂以上， 等翠花她到来细问端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "梆子原板",
          "text": "府下领了老爷命， 禀报奶奶得知情。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "老爷回府。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "茶水伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐寅上。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "唐寅",
          "type": "梆子乱导板",
          "text": "有唐寅回府来怒气生， 开言大骂李月英。 转身且把二堂进， 一见贱人执剑行。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "吓，老爷回得府来，一言不发，掌剑就杀，却是为何？"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "李月英吓，狗贱人你做的此事，你还不知，反来问我，反来问我。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "吓，老爷，为妻将什么事做错，说一明白，何用老爷来杀，为妻我自刎头首下 来。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "李月英吓，狗贱人。"
        },
        {
          "character": "唐寅",
          "type": "梆子慢板",
          "text": "有唐寅在二堂怒气生， 开言再骂李月英： 本镇不在唐府内， 狗贱人做下了什么事情。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "老爷不必怒气生， 听为妻把话说分明： 回府来提刀来杀我， 为妻的做错了什么事情？"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "王先生书馆身得病， 你在府中可知情？"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "王先生书馆身有病， 子其儿禀报我知情。"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "贱人接言知此事， 你就该书馆探望先生。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "老爷讲话你错了， 哪一个妇道人探望先生？"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "去不去在于你， 莫哄我唐寅昏迷虫。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "老爷说话有其情， 莫非说妻私通了王先生？"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "三六九日操演兵， 狗贱人私通了王先生。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "言说私通王先生， 有何物件作证凭？"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "贱人与我要凭证， 取出了绣鞋你看分明。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "与你看看，与你看看！"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "不、不、不好了。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "见绣鞋唬得我三魂不在， 七魄悠悠转回来。 出言便把老爷问， 绣鞋怎到书房中？"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "绣鞋实在书房内， 我亲在书馆看得明。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "言说既在书馆中， 你就该前去问先生。"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "先生岂肯说真话？"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "想杀为妻万不能。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "好贱人！"
        },
        {
          "character": "唐寅",
          "type": "梆子原板",
          "text": "贱人还敢巧言辩， 气得我鲜血上下翻。 三尺宝剑出了鞘，"
        },
        {
          "character": "丫鬟",
          "type": "梆子原板",
          "text": "拦住老爷且慢行。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "老爷息怒，你我去到书馆，问过先生，再杀奶奶，也还不迟。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "翠花言之有理，掌灯伺候。"
        },
        {
          "character": "唐寅",
          "type": "梆子乱导板",
          "text": "老爷正在沙滩困， 一句话提醒了懵懂人。 翠花掌灯头引路， 到书馆去杀王先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐寅下，丫鬟下。"
        },
        {
          "character": "李月英",
          "type": "梆子乱导板",
          "text": "唐老爷回府来怒气冲冲，"
        },
        {
          "character": "李月英",
          "type": "梆子慢板",
          "text": "倒叫我李月英大吃一惊。 这绣鞋本是我亲手刺做， 插双翅飞到了书馆里边。 我有心在二堂悬梁自尽， 纵死在阴曹府真假难分。 将身儿坐至在二堂以上， 等我儿他到来细问一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐子其上。"
        },
        {
          "character": "唐子其",
          "type": "梆子原板",
          "text": "唐子其门外侧耳听， 忽听母亲放悲声。 迈步且把二堂进， 问母亲痛哭为何情。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "儿吓，"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "你的父回家来来杀我，"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "他杀母亲为何？"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "儿吓。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "他言我与先生有……"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "有了什么？"
        },
        {
          "character": "李月英",
          "type": "唱",
          "text": "哎哎哎……"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "有了什么？"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "有了私情。"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "母亲你做起这个事情，叫孩儿怎样为人？"
        },
        {
          "character": "李月英",
          "type": "梆子快原板",
          "text": "一见奴才讲出口， 羞得为娘脸通红。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "你这小奴才，与你父一口同音，从今往后，不要你到娘的上房，再进娘房，将 你膝骨打直，还不上学去罢。"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "唐子其",
          "type": "梆子原板",
          "text": "施一礼来下二堂， 活活羞杀我学生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐子其下。"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "一见我儿他去了， 怎不叫人恼在心。 将身回至上房内， 等翠花回来问分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李月英下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "唐寅上，丫鬟上。"
        },
        {
          "character": "唐寅",
          "type": "梆子乱导板",
          "text": "翠花掌灯前引路，"
        },
        {
          "character": "唐寅",
          "type": "唱",
          "text": "一到书馆看分明。 我在此处莫久站， 再叫翠花扣门庭。"
        },
        {
          "character": "丫鬟",
          "type": "白",
