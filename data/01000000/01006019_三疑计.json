          "character": "唐寅",
          "type": "白",
          "text": "你与母亲说话，不要跪下。"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "我偏跪下。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "你不要哭。"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "我偏哭。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "与我哭哭哭。"
        },
        {
          "character": "唐子其",
          "type": "梆子哭板",
          "text": "哭一声母亲，母亲吓， 你今日寻短见， 丢下孩儿倚靠何人？"
        },
        {
          "character": "李月英",
          "type": "哭",
          "text": "儿吓！"
        },
        {
          "character": "李月英",
          "type": "梆子原板",
          "text": "一见我儿跪留平， 好似刚刀刺在心。 知道还言他不是， 不知还说我不贤。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "儿起来，老爷我的错了。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "我也有错，不该回府，就杀夫人。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "为妻不错，绣鞋怎到书馆？"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "人非圣贤，谁能无过。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "好一个谁能无过。 翠花今夜辛苦，有赏。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "赏我什么？"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "赏你永远伺候你奶奶。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "一夜未睡觉，伺候人还是伺候人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童上。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "与老爷叩头。"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "呔，那边。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "这边是周仓，与老爷叩头，先生有贴。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "“上写王标顿首拜，辞馆不教。” 前行一步，随后就到。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哦，前行一步，随后就到，去是不去，待我问问。 这前行一步，随后就到，还是去不去？"
        },
        {
          "character": "唐子其",
          "type": "白",
          "text": "去。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "去就去，就完了，还这么一脚。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "嗳哟，踹了我的脚了。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "谁说话这么好听？ 咦，原来是翠花，你在哪里睡？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我在小东房间里。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "我在小西房间里，咱二人越睡越远。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童下。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "唐寅",
          "type": "念",
          "text": "居家吵闹人人笑，"
        },
        {
          "character": "李月英",
          "type": "念",
          "text": "吵的乌鸦乱分巢。"
        },
        {
          "character": "唐寅",
          "type": "白",
          "text": "夫人请在后边。"
        },
        {
          "character": "李月英",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}