{
  "script_id": "01023008",
  "title": "乔醋",
  "alias": [
    "对双雀"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "潘安仁",
      "hangdang": "小生"
    },
    {
      "name": "井文鸾",
      "hangdang": "旦"
    },
    {
      "name": "瑶琴",
      "hangdang": "丑"
    },
    {
      "name": "彩鹤",
      "hangdang": "丑旦"
    }
  ],
  "plot": "潘安仁未第时，与一乐妓巫彩凤，两情相洽，以山涛之怂恿，遂订白头之盟。旋经丧乱，彼此分离。潘安仁\n有金雀一对，以一支赠巫彩凤，以为表记。既而潘安仁出宰河阳，巫彩凤以一纸书寄潘安仁，备述别后情状，\n并言暂度为尼，以自明其不渝初志云云。讵意书为潘安仁妻拾得，遂多方盘诘，欲一观其金雀。潘安仁初\n尚掩饰，继被再三逼问，卒至辞穷，只得直陈，且长跪请命焉。潘夫人佯作含酸，不遽许可，实则潘夫人未\n抵河阳署时，早已廉得其详情，且极贤淑，非惟毫无醋意，并亦欲玉成之。此不过乔装以绐潘安仁耳，故剧\n名《乔醋》云。",
  "notes": "《乔醋》本昆剧《金雀记》中之一出，系演晋时潘安仁惧内故事，乃小生、正旦之重头，向为昆班中最著名\n之戏。此本仍用昆腔，尚系旧面目，惟近时京班中能演者已如广陵散矣。考晋代人物，多风流韵事，此剧虽\n无所本，然亦非全然凿空者，按《金雀记》剧本，系据《世说新语》等小说杂记中散见杂出之语，熔铸成篇。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁上，"
        },
        {
          "character": "潘安仁",
          "type": "引子",
          "text": "承恩命，除授新任河阳令，种花满园，曷胜荣幸。"
        },
        {
          "character": "潘安仁",
          "type": "念",
          "text": "赋罢气凌霄汉，文成口吐珠玑。夜扶老叟青藜，杖上红光焰气。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "下官自到任以来，且喜黎民从约，士子循文，坐致物阜民安，一见太平景象。 又得山公，近与嵇阮诸君子，会集于此，多觅奇花异种，时时相聚，共谈诗酒。 也曾命家童瑶琴，遍访名花奇卉异种，为何还不见回来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "瑶琴上。"
        },
        {
          "character": "瑶琴",
          "type": "念",
          "text": "正欲清谈逢客至，偶思小饮报花开。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "老爷在上，瑶琴叩头。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "瑶琴你回来了。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "所觅名花，今得几种？"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "名花甚多，花样不一，带得一种金雀花回来，老爷请看。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "这花生得果然古怪。"
        },
        {
          "character": "瑶琴",
          "type": "念",
          "text": "古怪古怪真古怪，说来一场好惊骇。老爷请看这封书，管教泪湿宝罗带。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "有怎么书，取来我看，你把这花，供在书房，你且退下。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "晓得哉。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "待我拆书看来："
        },
        {
          "character": "潘安仁",
          "type": "念",
          "text": "遭兵守志入空门，幸遇瑶琴达远音。不识河中金雀女，可能再会月中人。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "潘安仁",
          "type": "太师引",
          "text": "顿心惊， 蓦地如悬罄， 止不住盈盈泪零。 记当日长亭分袂， 问归期细嘱叮咛。 却缘何身罹陷阱， 幸喜得保全躯命。 劈鸳鸯，是猖狂寇兵， 最堪怜，蓬纵浪迹，似浮萍。"
        },
        {
          "character": "彩鹤",
          "type": "内白",
          "text": "请夫人下轿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾上，彩鹤随上。"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "远涉兼程，到河阳，锦绣城。"
        },
        {
          "character": "彩鹤",
          "type": "唱",
          "text": "此是官衙近，"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "彩鹤忙行通报便相迎。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "老爷，彩鹤叩头。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "彩鹤，夫人到了么？"
        },
        {
          "character": "彩鹤",
          "type": "白",
          "text": "到了。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "吩咐开正门。"
        },
        {
          "character": "潘安仁",
          "type": "唱",
          "text": "出公庭，"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人在哪里？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人请。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公请。"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "喜今官爵威仪盛， 不弃糟糠感至诚。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人说哪里话来，请上，下官有一拜。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "妾也有一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁、井文鸾同拜。"
        },
        {
          "character": "潘安仁",
          "type": "唱",
          "text": "真侥幸，偶因代赋承新命，有惭为令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "瑶琴上。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "启爷：外面有紧急公文，请老爷升堂发遣。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "看官服过来。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人，且请少坐，下官去去就来。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁失书，下。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "呀，看相公袖中，遗下怎么东西，待我拾起来看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾拾书看。"
        },
        {
          "character": "井文鸾",
          "type": "念",
          "text": "遭兵守志入空门，幸遇瑶琴达远音。不识河中金雀女，可能再会月中人。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "吓，原来是巫妹所寄之书，可见相公时刻在心，我且藏在袖中，用言语打动他 便了。"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "剪雪裁冰， 袖失遗书似薄情。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "巫妹吓！"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "似杨花性， 沾泥飞絮类书生。"
        },
        {
          "character": "潘安仁",
          "type": "内白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁上。"
        },
        {
          "character": "潘安仁",
          "type": "唱",
          "text": "见卿卿，"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人吓！"
        },
        {
          "character": "潘安仁",
          "type": "唱",
          "text": "今朝喜得交鸾颈，"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "不负当年金雀盟。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "是吓，我与夫人所分金雀，想必带来也。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "当年惜别，金雀轻分。今日重逢，依然成对。相公你可取来，待我仍以绣线同 心，系在一处。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "多谢夫人的美意，待下官去取来。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "快去取来。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "好个绣线同心，待下官取来。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "我看他往哪里去取。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "吓，且住。夫人初到，未可轻言巫姬一事，她倒提起了金雀，叫我拿怎么与她 对合呢？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公，"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "来了。 吓，有了，待我就将巫彩凤所寄之书，与她看了，或者她见巫姬为我守志投崖， 接来完聚，也未可知。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "就来了。 呀，为何不见了，哪里去了？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公快来。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "金雀呢？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "有吓。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "取来呀。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人请坐，不是吓。只因下官，一时寻不见书箱上锁匙，所以不曾取来，待寻 着了锁匙，就有金雀与夫人了。"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "真薄幸！"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "怎见下官薄幸？"
        },
        {
          "character": "井文鸾",
          "type": "唱",
          "text": "缘何陇蜀相兼并，这般渴病，"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "呀，夫人太多心了，那金雀好好藏在书箱，就是明日取来，也不为迟。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "果在书箱内么？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "在书箱内。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "咳，那金雀乃是至灵之物，先已飞到我袖中来了。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "在夫人袖中？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "在我袖中。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "岂有此理，我却不信。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "你不信，待我取出来，这不是么？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "这是夫人的。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "不差，是我的，我还有。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "还有，一发去取出来看。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "这不是一对？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "呀，这竟奇了！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "咳，相公吓！"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "休得要乔装行径， 我跟前不耐听，"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "那金雀有个原故吓！"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "金雀当年婚订姻，得谐双姓， 挽红丝，牵定盟。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人取来，待下官再看看。"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "我与你鸳侣交颈，连枝同并。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人，今日合当欢喜。"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "只合契求相应，共享安宁， 你傍枝为何觅小星？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人太多心了，下官哪有此事。"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "你言清浊行，"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "并无浊行。"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "亏心短行。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "有甚短行？"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "你还要语惺惺， 这题诗绝句，是谁寄？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "阿呀，好奇怪，怎么书，也在夫人处？"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "雀解双飞却怎生？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾掷书。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人呀，非是我亏心短行，你从来贤惠称。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "我一向原是贤惠的，今日权且不贤惠一遭罢。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "呀，这也是儿女之态吓。"
        },
        {
          "character": "潘安仁",
          "type": "江头金桂",
          "text": "一自与卿卿分手，良朋胥庆， 喜巫……"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "“巫”什么？"
        },
        {
          "character": "潘安仁",
          "type": "江头金桂",
          "text": "喜巫姬，守志坚贞。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "我不晓得怎么无鸡有鸡。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人不是有无之无，那巫姬者，名唤彩凤，乃青楼守志之女子也。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "青楼女子，还守怎么志来？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "守志呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁拉井文鸾。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "不知羞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾推潘安仁。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "待我说与夫人听：我同山公，名山酌酒，见她执爵彷徨，举止羞耻，山公细问 其情，顿生怜悯，下官实无意于她，当不过山公再三撺掇。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "那山公作得主？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "山公作得主，下官也是没奈何。"
        },
        {
          "character": "潘安仁",
          "type": "江头金桂",
          "text": "因此上未闻尊命，偶遇私成，"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "可又来，你既有意于她，何不先着人报我知道，然后成事，而乃率意竟行，这 等大胆可恶。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人，下官这件事，原有些欠通，那里本要差人来报，怎奈一时情牵，只得不 告而娶。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "哼，好个不告而娶！"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "若是夫人见她守志投崖，未免也要见怜，"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "我倒不晓得怎么见怜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾坐。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "我偏要见怜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁推井文鸾，井文鸾坐。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "掷果之生，你好不知耻也！"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "耻呀，夫人，那巫姬原无一端可取。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "住了，既无一端可取，缘何两下相投？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "不是这等说哪！"
        },
        {
          "character": "潘安仁",
          "type": "江头金桂",
          "text": "闻说寇兵入境， 她投崖捐躯， 感神灵救之为尼僧，"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "可又来，她既做了尼僧，也是六根清净之人，你又去缠她怎的？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人既知道了，我就差人去叫她来，服侍夫人便了，"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "官衙内，岂少丫鬟服侍，要这尼僧伏侍，不劳！"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "岂有此理，即刻差人去吓。哪个在？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "呀，官衙中，岂容尼僧出入，使不得。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人不要作难哟！"
        },
        {
          "character": "潘安仁",
          "type": "江头金桂",
          "text": "望海涵仁宥，毕吾狂兴，"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "你本是狂生，如今的兴，就太狂了些！"
        },
        {
          "character": "潘安仁",
          "type": "江头金桂",
          "text": "夫人你若是肯相容， 是免得意盈盈。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "不许！"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "若夫人执意不许，我就要……"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "要怎样？"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "我就跪。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "堂堂县令，做此丑态，被家人们看见，可不羞耻！"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "家人们看见，我跪的是夫人，何妨？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人见允，方敢起来。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "起来再说。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "如此多谢夫人见允。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "此事断然成不得，你休做此想。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "就不成，也罢，不要气坏了身子，只是异哉，金雀缘何皆在夫人处？"
        },
        {
          "character": "潘安仁",
          "type": "唱",
          "text": "正是，鹿麋郑相难分辨， 唔，难道蝶梦庄周不易明，"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "请教夫人，说个明白。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "路上辛苦，我要去安歇了，有话明日再说罢。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "夫人莫辞劳倦，下官还要与夫人接风。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾推潘安仁跌，井文鸾下。瑶琴下。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "好跌哉，此一跌是，美哉，非凡之跌，乃天下第一跌也！"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "狗才，老爷下阶错步了。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "弗是错步，只怕是夫人吃……"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "吃怎么？"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "拉里吃醋。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "狗才！"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "老爷。夫人将门关闭了，弗肯开哉，老爷去到书房里，去修修旧罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁踢瑶琴。"
        },
        {
          "character": "潘安仁",
          "type": "白",
          "text": "这狗才，真真可恶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘安仁下。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "弗要踢哉，踢坏了无得用哉，再弗晓得，怕家婆个风气，直头野怪拉吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "瑶琴下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}