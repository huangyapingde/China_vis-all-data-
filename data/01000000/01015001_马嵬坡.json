{
  "script_id": "01015001",
  "title": "马嵬坡",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "唐明皇",
      "hangdang": "老生"
    },
    {
      "name": "陈元礼",
      "hangdang": "末"
    }
  ],
  "plot": "唐明皇为安禄山所逼，驾幸西蜀，出咸阳道，次马嵬驿，六军徘徊，持戟不进，伏明皇驾前，请诛杨国忠以\n谢天下，未降旨而杨国忠已死于道周。左右之意犹未快，陈元礼复请诛贵妃以释众怨。明皇不得已，命高力\n士引贵妃于佛堂缢杀之，葬于马嵬坡下，始整顿部伍而行。杨氏兄妹之怙宠藉势，乱天下，祸苍生，尽人饮\n恨，独明皇不悟耳。然自贵妃死后，明皇朝夕思念，未曾有一日忘怀，甚至梦寐之间，时时索绕。后郭子仪、\n李光弼等，恢复两京，迎驾还都，再经马嵬，触景伤怀，命于贵妃坟茔前，陈设祭品，降尊拜奠，掩面悲\n泣，不胜凄怆。经高力士再三劝解，方肯回銮。",
  "notes": "按此剧系沪上名艺员汪笑侬所编排，自香山《长恨歌》中有句云：“蜀江水碧蜀山青，圣主朝朝暮暮情。行\n宫见月伤心色，夜雨闻铃肠断声。天旋地转回龙驭，到此踌躇不能去。马嵬坡下泥土中，不见玉颜空死处。”\n大约胎息于此。尤妙在剧本中辞句，缠绵悱恻，旖旎风华，脱却俚言俗语之习气，是为众剧本之上乘。笑\n侬诚不愧剧界杰出之人。当年鼎鼎大名，轰传南北，亦实至名归之确证耳。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、陈元礼同上。"
        },
        {
          "character": "陈元礼",
          "type": "念",
          "text": "渔阳击鼓起仓猝，护驾巡行到西蜀。且喜逆贼已就戮，五色旌旗返帝都。"
        },
        {
          "character": "陈元礼",
          "type": "白",
          "text": "俺，右护龙卫将军陈元礼是也。只因安禄山造反，圣驾西行。今幸反贼平靖， 正好保驾还朝。 御林军，人马可齐？"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "陈元礼",
          "type": "白",
          "text": "侯驾起行者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈元礼、四龙套、四大铠同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、高力士、唐明皇同上。"
        },
        {
          "character": "唐明皇",
          "type": "引子",
          "text": "万里巡行路途穷，看云山，乱愁交迸。长空孤雁添悲哽，无边落木响秋声。叹 凄凉，万种离情。"
        },
        {
          "character": "唐明皇",
          "type": "念",
          "text": "江山只为美人愁，万里山河半壁休。自愧三郎空好色，风流天子惯无忧。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "孤，大唐天子，天宝在位。只因安禄山造反，谋取神京，将孤逼幸西蜀。行至 中途，六军不发，众小军声声言道：“不杀杨家兄妹，誓不保驾。”陈元礼那 时奏道：“社稷为重。”孤万般无奈，行在马嵬坡下，只得传旨赐玉环一死。 今幸反贼平复，每忆玉环，不禁伤感。陈元礼又催驾还朝。 内侍，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "车驾可齐？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "齐备多时。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "起驾还朝。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "御林军走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、陈元礼同上。"
        },
        {
          "character": "唐明皇",
          "type": "二黄原板",
          "text": "恨禄山贼造反逼我神京， 李猪儿刺逆贼才得太平。 这个是蜀道难道途泥泞， 峨眉山下少人行。 风飘飘一阵阵愁云滚滚，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "雨来啦！请万岁爷剑阁避雨！"
        },
        {
          "character": "唐明皇",
          "type": "二黄原板",
          "text": "下金鞍离玉辔剑阁来登。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇上山。"
        },
        {
          "character": "唐明皇",
          "type": "二黄原板",
          "text": "观一派白茫茫云遮日影， 雨苦风酸扑面迎。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士，看看是什么声响？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高力士看。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "启万岁：外面乃是雨打树林之声，风吹栈间铁马之声。"
        },
        {
          "character": "唐明皇",
          "type": "念",
          "text": "断肠最是雨淋淋，与愁人泪血相交并。"
        },
        {
          "character": "唐明皇",
          "type": "二黄原板",
          "text": "想孤魂此际太凄清， 白杨萧萧夜雨淋。 鬼火青磷寒霄静， 听一片风声、雨声、铃声、锣声、人声、马声、秋声、金声并作了断肠声！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "雨住了，请万岁爷下剑阁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇下山。"
        },
        {
          "character": "唐明皇",
          "type": "二黄摇板",
          "text": "雨霁风消寒夜冷， 人马浩荡转帝京。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "前面人马为何不进？"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "来此已是马嵬坡了。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士，来此什么所在？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "来此已是马嵬坡。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "唐明皇",
          "type": "二黄导板",
          "text": "听说来到马嵬坡，"
        },
        {
          "character": "唐明皇",
          "type": "二黄摇板",
          "text": "点点珠泪似滂沱。 陈元礼将人马且扎山脚， 满腹酸辛可奈何。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "内侍，吩咐外面预备清香白酒，到贵妃娘娘坟前一祭，卿表寸心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，高力士上。设祭堂。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有请万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇上。"
        },
        {
          "character": "唐明皇",
          "type": "二黄摇板",
          "text": "定情钿盒今犹在， 长生密誓记心怀。 冤怨缘三字孤不解， 这才是伯劳飞燕两分开。 看天台犹是人不在， 我前度刘郎今又来。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "启万岁：杨娘娘坟茔，已经打扫洁净了。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "待孤拈香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖哭皇天〗。"
        },
        {
          "character": "唐明皇",
          "type": "叫头",
          "text": "贵妃！梓童！咳，卿家吓！"
        },
        {
          "character": "唐明皇",
          "type": "二黄导板",
          "text": "见坟台不由人泪如雨下，"
        },
        {
          "character": "唐明皇",
          "type": "叫头",
          "text": "贵妃！梓童！爱卿吓！"
        },
        {
          "character": "唐明皇",
          "type": "顶板回龙",
          "text": "尊一声杨贵妃，杨玉环，孤的爱卿，在夜台下，九泉间，一件件，一桩桩，细 听根芽："
        },
        {
          "character": "唐明皇",
          "type": "反二黄慢板",
          "text": "想当初孤坐的风流天下， 重国色慕倾城运走桃花。 为娇容孤也曾求遍风雅， 压六宫冠粉黛绝世才华。 七月七长生殿花前月下， 连理枝比翼鸟并带莲花。 早不幸安禄山渔阳杀驾， 破潼关扫河北直抵京华。 无奈何且迁都起了銮驾， 幸西蜀为的是有情冤家。 离都门路不远马嵬坡下， 最可恨这六军按兵不发。 孤忙问尔六军因何驻马？ 扬言道杀兄妹六军才发。 叹贵妃死在这尺组之下， 卿家吓！ 红颜女变作了白骨黄沙。 可怜你霓裳舞独擅风雅， 酒醉后闭月羞花； 可怜你洗儿钱空空挣下， 可怜你今日里玉损桃花。 谢秋波止不转百媚无价， 倒叫孤空辜负恩宠独加。 唐天宝空坐了一朝天下， 身不能庇一女辜负名花。 卿一死且莫要将孤咒骂， 夜台下谁怜你少妇无家。 朕负卿并非是卿负陛下， 国乱时权在臣不在官家。 李三郎只哭得泪如雨下，泪如雨下， 卿家吓！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "万岁不可过伤，务宜保重圣体要紧。"
        },
        {
          "character": "唐明皇",
          "type": "二黄摇板",
          "text": "高力士捧金爵酒祭香插。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "遵命。祭奠已毕，请万岁上马回銮。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士，带马。"
        },
        {
          "character": "唐明皇",
          "type": "二黄摇板",
          "text": "陈元礼奏一本催孤起驾， 浩荡荡领人马直奔金华。 御林军忙转过马嵬坡下， 要相逢除非是梦里天涯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}