        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "招打。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "且慢，现在翠云山白云洞。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你且退下。"
