      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四童子、八神将引李靖同上。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "吾乃托塔天王李靖。今有大圣有难，必来求救。 来，打开南天门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上。"
        },
        {
          "character": "孙悟空",
