          "text": "禀大王：众位大仙前来拜寿。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "小妖",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八大仙同上。"
        },
        {
          "character": "八大仙",
          "type": "同白",
          "text": "大王在上，我等拜寿。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "生受了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "众位大仙请坐。不知众位大仙驾到，未曾远迎，当面有罪。"
        },
        {
          "character": "八大仙",
          "type": "同白",
          "text": "岂敢。我等少来问候，大王恕罪。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "岂敢。 小妖们，酒宴摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "众位大仙请。"
        },
        {
          "character": "八大仙",
          "type": "同白",
          "text": "大王请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。小妖上。"
        },
        {
          "character": "小妖",
          "type": "白",
          "text": "禀大王：悟空要见。"
