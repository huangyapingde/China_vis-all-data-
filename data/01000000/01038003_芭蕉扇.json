        {
          "character": null,
          "type": "stage",
          "text": "土地下。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "且住，牛马王现在翠云山白云洞，在我前去借扇便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四下手、四小妖引牛马王、玉面仙姑同上。〖点绛唇〗。"
        },
        {
