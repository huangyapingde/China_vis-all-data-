          "text": "大王有所不知，日前悟空到这里来了。"
        },
        {
          "character": "假牛马王",
          "type": "白",
          "text": "悟空到这里做什么？"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "前来借扇子来了。"
        },
        {
          "character": "假牛马王",
          "type": "白",
          "text": "你可借与他人无有？"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "我借给他了。"
        },
        {
          "character": "假牛马王",
          "type": "白",
          "text": "女人家办不了大事，镇洞之宝，好借与人的？"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "我借给他是假的。"
        },
        {
          "character": "假牛马王",
          "type": "白",
          "text": "真的呢？"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "真的我在洞内收着那。"
        },
        {
          "character": "假牛马王",
          "type": "白",
          "text": "快快拿来我看，别叫悟空盗了去。"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "大王请看。"
        },
        {
          "character": "假牛马王",
          "type": "白",
          "text": "仙姑，这把扇子是真的？"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "是真的。"
        },
        {
          "character": "假牛马王",
          "type": "白",
          "text": "是真的，我是假的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "假牛马王夺扇下。"
        },
        {
          "character": "大女妖甲",
          "type": "白",
          "text": "禀仙姑：悟空将扇盗去。"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "众小妖，追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四下手、四小妖引牛马王同上。"
        },
        {
          "character": "牛马王",
          "type": "唱",
          "text": "众小妖带路回洞转， 见了仙姑问根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "娥叉女、众女妖同上。"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "大王大事不好了。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "怎么样了？"
        },
        {
          "character": "娥叉女",
          "type": "白",
          "text": "今有悟空，变作大王模样，将宝扇盗去。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "你且退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "娥叉女、众女妖同下。"
        },
        {
          "character": "牛马王",
          "type": "白",
          "text": "且住，猴头将宝扇盗去，待我变作八戒模样，将宝扇盗回便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛马王、众人同下。假猪八戒上。"
        },
        {
          "character": "假猪八戒",
          "type": "白",
          "text": "俺猪八老爷，牛马王变的。自因悟空将我宝扇盗去，在此等候与他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "原来是八戒，在此做什么？"
        },
        {
          "character": "假猪八戒",
          "type": "白",
          "text": "我这里等你呢，你手里拿的何物？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "盗来的宝扇。"
        },
        {
          "character": "假猪八戒",
          "type": "白",
          "text": "拿来我看。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "不要你看。"
        },
        {
          "character": "假猪八戒",
          "type": "白",
          "text": "我不要你的，我来问你，这回是真的？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "是真的。"
        },
        {
          "character": "假猪八戒",
          "type": "白",
          "text": "是真的，我是假的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "假猪八戒下。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "哪里走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空追下。"
        }
      ]
    },
    {
