        {
          "character": "报子",
          "type": "白",
          "text": "黄忠讨战。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "叫人来带过赤兔骑， 要与黄忠比高低。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唗，昨日阵前饶你不死，今日还来送死？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "昨日阵前未曾提防，今日实要与你决一死战。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "休得多言，放马过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、关羽同开打，同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩玄上。"
        },
        {
          "character": "韩玄",
          "type": "西皮快板",
          "text": "黄忠阵前去打仗， 不由本帅挂胸膛。 三军带马敌楼上， 看看谁胜比谁强？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩玄上城。黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "百步穿杨射得好， 箭射盔缨将他饶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "搭上弓弦忙射到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠射箭，下。关羽接箭。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "用手接过箭一条。 黄忠武艺真真好， 暗放冷箭不为高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "催马来在战场道， 关公追赶怎肯饶。 二次开弓箭放了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠射箭，下。关羽上，接箭。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "接过雕翎第二条。 明知深山有虎豹， 偏要追赶入笼牢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "且住，你看关公不解其情，打马紧紧追赶，也罢，待俺射他的盔缨便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "着箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下，关羽接箭，下。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "且住，黄忠百步穿杨，百发百中。今日连放三箭，不伤他的性命，只射盔缨， 必有心降顺桃园之意。 人来收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩玄下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽、龙套同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住，黄忠老儿，百步穿杨，百发百中。今日箭射盔缨，不伤某的性命，必有 归顺之意。 军校将长沙团团围住。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、龙套同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "腰挂三尺剑，定斩海底蛟。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "俺魏延。奉了元帅将令，四路催粮，粮草已齐，回营交令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩玄、龙套同上。"
        },
        {
          "character": "韩玄",
          "type": "西皮快板",
          "text": "乌鸦不住叫喳喳， 本帅心中乱如麻。 三军带路莲花下， 黄忠回来问根芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "来在营门下战马，"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "可恼吓可恼。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "元帅为何怒气发？"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "就为你来。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "为末将何来？"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "我且问你，你的百步穿杨，百发百中，今日连放三箭，因何不伤他的性命？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "回禀元帅，昨日阵前，末将中了关公拖刀之计，他不忍伤害于我，我今日若将 他人射死，旁人道俺黄忠不仁不义。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "哼，你只顾你的仁义，不顾本帅的长沙么？"
        },
        {
          "character": "韩玄",
          "type": "西皮快板",
          "text": "听一言来心头呕， 起意归顺关、张、刘。 吩咐两旁刀斧手， 推出营门斩人头。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "元帅做事无来由， 动不动要斩项上头。 黄忠一死何足呕， 落得美名万古流。 迈步来在营门口， 不知何人把情求。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "来在营门下走兽， 因何捆绑说从头。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "都只为龙争并虎斗， 两军阵前结下仇。 百步穿杨报仁厚， 他道我归顺关、张、刘。 进帐不容某开口， 推出营门要斩头。"
        },
        {
          "character": "魏延",
          "type": "西皮快板",
          "text": "老将军不必心头呕， 魏延进帐把情求。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "韩玄与你有仇恨， 何必为我把命丢。"
        },
        {
          "character": "魏延",
          "type": "西皮快板",
          "text": "老将军不必面带忧， 纵有大事我担承。 回头叫声刀斧手， 你把老将留一留； 倘若误斩老将首， 准备钢刀割儿头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套押黄忠同下。"
        },
        {
          "character": "魏延",
          "type": "西皮快板",
          "text": "迈步如梭宝帐口， 魏延解粮转回头。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "末将交令。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "魏将军的头功，后帐歇息。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "元帅，黄老将军身犯何罪，为何推出营门斩首？"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "犯了本帅军令。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "斩了黄忠不大要紧，倘若桃园兴兵前来，何人抵挡？"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "还有魏将军。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "俺不管，你若赦了黄忠，末将出马。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "定斩不赦。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "你若不赦，某家就要，"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "要怎样？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "就要反反反。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "哼。"
        },
        {
          "character": "韩玄",
          "type": "西皮摇板",
          "text": "魏延说话礼太差， 敢在帐前嘴喳喳。 吩咐两旁来拿下， 推出营门把头杀。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "哽。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "听一言来怒气发， 你把魏延当娃娃。 两旁儿郎一齐杀，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延杀龙套、韩玄。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "问你赦他不赦他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": "黄忠",
          "type": "内西皮导板",
          "text": "可恨元帅太无情，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套押黄忠同上。"
        },
        {
          "character": "黄忠",
          "type": "西皮原板",
          "text": "一言未发问斩刑。 舍不得长沙好美景， 舍不得长沙众黎民。 含悲忍泪法场进， 魏延到来问详情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "开刀先杀刽子手，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延杀龙套。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "老将军醒来说从头。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "老将军醒来。"
        },
        {
          "character": "黄忠",
          "type": "西皮导板",
          "text": "法场上绑得我昏迷不醒，"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "但不知元帅可准情？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "老将军，某家进帐讲情，是他不准，俺恨他不过，将他杀了。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "我却不信。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "首级在此。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "一见人头鲜血淋， 不由黄忠痛在心。 为国忠良身丧命，韩元帅吓，"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "不许你哭。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "不哭。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "但愿你阴魂赴天庭。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "魏将军将元帅杀死，须要保守他的家眷才是。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "俱被俺杀了。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "如此走。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "去到魏王驾前请罪。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "黄老将军，我把你好有一比，"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "咸干鱼放生——"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "你连死活都不知。依某之计，归顺桃园，岂不是好？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "你去我不去。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "你去是不去？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "我不去。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "你不去我就要……"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "吓，去去去。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "走。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "走走走吓。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "恼恨元帅太不良，"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "一家大小丧无常。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "投降事儿全不想，"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "总有大事我承当。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}