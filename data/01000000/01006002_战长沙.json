        {
          "character": "韩玄",
          "type": "西皮摇板",
          "text": "黄忠、魏延出宝帐， 一来对敌二为粮。 三军暂退莲花帐， 再等探马报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩玄、四红龙套同下。"
        }
      ]
