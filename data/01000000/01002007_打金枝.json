{
  "script_id": "01002007",
  "title": "打金枝",
  "alias": [
    "绑子上殿；一名：男绑子"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "唐王",
      "hangdang": "老生"
    },
    {
      "name": "郭子仪",
      "hangdang": "外"
    },
    {
      "name": "郭暧",
      "hangdang": "小生"
    },
    {
      "name": "公主",
      "hangdang": "旦"
    },
    {
      "name": "皇后",
      "hangdang": "旦"
    }
  ],
  "plot": "唐郭子仪既平安史之乱，功高望重。唐肃宗以女妻其子郭暧。会郭子仪夫妇八十双寿，家人相率拜贺，独公\n主不出拜寿，郭暧大恚，乘醉殴公主，公主痛哭回宫诉皇后。郭子仪闻之大惊，立缚其子。负荆上殿请罪。\n唐王笑曰：“不痴不聋，不作阿家翁。儿女琐屑事，何必问？”郭子仪乃安。父子再拜谢恩而退。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "唐王",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，唐王上。"
        },
        {
          "character": "唐王",
          "type": "西皮慢板",
          "text": "金乌东升玉兔坠， 景阳钟三响把皇催。 忆昔当年遭颠沛， 国乱只为杨贵妃。 安禄山在河东曾起反意， 兵困长安夺社稷。 杨玉环被困在马嵬驿， 可惜她一命受凌逼。 先皇逃在西蜀地， 多亏了皇兄郭子仪。 血战三载狼烟息， 才把逆贼剑下劈。 到如今乐享太平世， 河清海宴凤来仪。 内侍臣摆驾九龙椅， 孤王有道福寿齐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "皇后上。"
        },
        {
          "character": "皇后",
          "type": "西皮摇板",
          "text": "内侍摆驾金殿里， 见了万岁辩是非。"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "妾妃见驾，吾皇万岁。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "御妻平身。"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "御妻上殿，有何本奏？"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "郭暧怒打金枝，万岁做主！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "孤王不信。"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "万岁宣皇儿上殿一看便知明白。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "内侍，宣公主上殿。"
        },
        {
          "character": "公主",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、公主同上。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "呵吓！"
        },
        {
          "character": "公主",
          "type": "西皮摇板",
          "text": "忽听见皇传旨意， 急忙上殿奏端的。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "唐王",
          "type": "西皮快板",
          "text": "一见皇儿泪悲啼， 打碎珠冠拆破衣。 你与驸马因何起？ 一一从头奏皇知。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "容禀，"
        },
        {
          "character": "公主",
          "type": "西皮导板",
          "text": "尊父皇容儿本奏起，"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "皇儿平身，赐坐。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "公主",
          "type": "西皮慢板",
          "text": "细听儿臣奏端的： 当朝的驸马太无礼， 酒醉回宫把儿欺。 他言道父皇的江山从何起？ 尽多是他们父子功劳争来的。 孩儿未曾回半句， 他那里拳打足又踢。 不是婆婆进宫里， 孩儿险些命归西。 有一句话儿不好启： 脱去了旧衣换新衣。 父王快快传旨意， 不斩驸马儿不依。"
        },
        {
          "character": "皇后",
          "type": "西皮慢板",
          "text": "君比天来臣比地， 天翻地覆世间稀。 郭暧打了吾皇女， 打皇儿犹如把万岁欺。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "御妻休要把本奏起，"
        },
        {
          "character": "公主",
          "type": "哭",
          "text": "啊吓！"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "皇儿也莫泪悲啼。 郭暧不是皇降罪，"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "谢父王！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "且慢，"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "联恐其中儿有非。 你母女暂且回宫去，"
        },
        {
          "character": "皇后",
          "type": "西皮摇板",
          "text": "我这里带皇儿转回宫里。"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "公主",
          "type": "哭",
          "text": "啊吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "皇后、公主同下。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "内侍与孤传旨意， 快宣汾阳郭子仪。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "郭子仪上殿！"
        },
        {
          "character": "郭子仪",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": "郭子仪",
          "type": "内西皮导板",
          "text": "汾阳王绑蠢子珠泪撇地，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭暧上，郭子仪上。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "奴才！"
        },
        {
          "character": "郭子仪",
          "type": "西皮快板",
          "text": "大骂奴才听端的： 安禄山在河东曾起反意， 将我主驾逼在琴西。 那时为父不得地， 多亏了太白先生把本提。 他将为父荐朝里， 挂帅才把逆贼劈。 儿酒后打了皇王女， 连累我白发苍苍受凌逼。"
        },
        {
          "character": "郭暧",
          "type": "西皮快板",
          "text": "爹爹休要怒不息， 孩儿言来听端的： 他既皇王玉叶体， 不该与臣配夫妻； 既与臣子来婚配， 为论什么高来论什么低？ 儿今打了皇王女， 论皇法不过是剥儿的皮！"
        },
        {
          "character": "郭子仪",
          "type": "西皮快板",
          "text": "小奴才说话大有理， 问得老夫无话提。 父子们同到金銮殿，"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "跪下！"
        },
        {
          "character": "郭子仪",
          "type": "西皮快板",
          "text": "儿要端端正正跪， 且待为父把本提。"
        },
        {
          "character": "唐王",
          "type": "西皮二六板",
          "text": "九龙口内红光起， 来了皇兄郭子仪。 昨日皇兄寿诞日， 孤未曾去拜寿，未曾赐给你的酒席。 孤坐江山全仗你， 从今后见孤免屈膝。 内侍臣与孤忙搀起， 君臣们对坐把话提。"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "绑坏了！"
        },
        {
          "character": "唐王",
          "type": "西皮二六板",
          "text": "殿角下绑的何臣子？ 一一从头奏皇知。"
        },
        {
          "character": "郭子仪",
          "type": "西皮摇板",
          "text": "绑的郭暧不成器， 酒后无端把君欺。 请皇传旨将他斩，"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "且慢，"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "老皇兄做事太心急。 况且驸马幼年纪， 公主又是少年妻， 自古道清官难断家务事， 他夫妻们吵闹是常有的。 孤皇传旨不降罪，"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "松绑。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "驸马到后宫换朝衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭暧下。"
        },
        {
          "character": "郭子仪",
          "type": "西皮摇板",
          "text": "万岁不降郭暧罪， 背地喜煞郭子仪。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "郭子仪见驾，吾皇万岁！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "平身，赐坐。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "皇兄，驸马与公主吵闹，皇兄怎么知晓？"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "老臣正在银安标本，忽听内侍来报，才得知晓。万岁宣小奴才上殿，一问便知 明白。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "内侍，宣驸马冠带上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "驸马冠带上殿！"
        },
        {
          "character": "郭暧",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭暧上。"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "适才如遇阴曹地，鬼门关前七魄归。 臣郭暧见驾，吾皇万岁！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "驸马平身。"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "驸马为了何事，与公主吵闹？当殿奏来。"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "容奏：臣逢尧舜之主，蒙恩将公主匹配。自盘古以来，只有妻拜夫，那有反礼 而行？"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "唔，听奴才之言，把我君臣大礼，一旦抛废！"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "皇兄，此乃是公主故作威福。从今以后，将红灯撇去，也不用三四诏，驸马有 何本章当殿奏来。"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "容奏：昨日臣父母八旬双寿，满朝文武，众家各嫂，一个个成双作对，拜寿堂 前。公主不去拜寿，到也罢了。连问安二字，全然无有。大非儿媳之道。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "哈！想公主乃金枝玉叶，岂向我臣门拜寿？"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "想东宫太子，他是守缺之龙，怎么过府拜寿?"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "想小千岁，他乃奉了万岁的旨意。"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "公主不去拜寿，也是奉了他父的旨意么？"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "皇兄，听驸马所奏，孤皇心下明白了：昨日你二老八旬双寿，满朝文武，众家 各嫂，一个个成双作对，拜寿堂前。驸马有妻，不能孝敬父母。自觉孝道有亏， 是与不是？"
        },
        {
          "character": "郭暧",
          "type": "白",
          "text": "诚如圣谕。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "吓，皇兄，古人有言，道是“不痴不聋，不作家翁”。从今以后，他夫妻闺房 之事，你要少管。听孤旨下："
        },
        {
          "character": "唐王",
          "type": "西皮二六板",
          "text": "驸马奏本孤的龙心爽， 深知三纲并五常。 臣心若得君欢畅， 福寿齐眉永安康。 老皇兄暂且回府上， 孤与驸马有商量。"
        },
        {
          "character": "郭子仪",
          "type": "西皮摇板",
          "text": "辞别万岁下殿往， 背转身来自揣详。 皇恩浩荡真浩荡， 天降明主掌大唐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪下。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "驸马近前听旨降："
        },
        {
          "character": "唐王",
          "type": "西皮流水板",
          "text": "忠臣孝子永留芳。 曾记得安贼来反上， 你父子领兵去到边疆。 孤皇赐你大红蟒， 忠孝碑匾挂高堂。 再赐一口上方剑， 巡查内外与宫墙。 倘若是公主近心强， 你只管把本一本一本奏孤皇。 驸马暂且回府往， 公主赔罪到汾阳。"
        },
        {
          "character": "郭暧",
          "type": "西皮摇板",
          "text": "辞别万岁下殿往， 公主赔罪到汾阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭暧下。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "驸马犯罪难发放， 难道说为皇儿斩杀忠良？ 死罪不降反而加赏， 买动他父子们忠心好助孤皇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}