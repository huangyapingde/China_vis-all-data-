{
  "script_id": "01007005",
  "title": "凤鸣关",
  "alias": [
    "力斩五将"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "赵云",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "孔明既祭马超以激励军心，得悉魏遣驸马夏侯楙来拒，知非劲敌，即令赵云进兵。时夏侯楙调得西凉大将韩\n德，并四子韩瑛、韩瑶、韩琼、韩琪等为前锋，父子五人，皆弓马过人，力敌万人之勇将，不意一阵交绥，\n韩德及四子俱被赵云斩杀净尽，魏军大败而逃，真快事也。",
  "notes": "孔明每遇难题目，衡览大势，不能有十分把握时，及每次初出军，欲速其成功时，往往用激将之法，以鼓士\n气。此剧又为孔明激将故智，即用定军山智激黄忠之法，以激赵云。实则孔明因其时关、张、黄、马、诸大\n将，均已凋丧，锐气不张，军声远不如前。环顾帐前，足资臂助者实寥寥，所鼎鼎大名者，惟一身是胆之子\n龙而已，然亦已须鬓如银，苍苍老矣。故虽拜表出师，大书特书曰：“平北大都督丞相武乡侯诸葛亮率领魏\n延等三十三员将佐出师伐魏”，而心中实惴惴时惧不胜，盖即所谓不能有十分把握之时也。故不得不复用激\n将惯技，以速赵云之成功。观其师次沔阳，不用魏延褒斜之计，而必取陇右平坦大道者，亦以小心虚怯，不\n能有十分把握，故不敢走险道也，是以处处以恐伤锐气为言。赌博者之言曰：腰粗者胆壮，孔明此时，即腰\n不粗故胆不壮之明徵也。此剧为前出师表后第一见仗，子龙第一立功，即《三国志》“力斩五将”故事。在\n《取三郡》之前。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、邓芝同上，诸葛亮上。〖点绛唇〗。魏延、马岱、关兴、张苞同上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "天为阳来地为阴，九宫八卦腹内存。我今奉了幼主命，一战成功取凤鸣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人诸葛亮。奉了幼主之命，夺取凤鸣。 邓芝听令。"
        },
        {
          "character": "诸葛亮",
          "type": "邓芝允",
          "text": "。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传令下去：命王平、廖化、严颜、马忠与为四路总先锋。余下之将，随营调遣， 大队人马，兵发凤鸣。"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "且慢。"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "何人阻令？"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "赵云。"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "随令进帐。"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "桓公三略安天下，吕望六韬定邦家。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "报：赵云告进，恭见相爷。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军少礼。请坐。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军无令进帐则甚？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "相爷今日登台点将，满营将官，俱有差遣，把俺赵云一字不提，是何理也？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想老将军年迈，又是先帝托孤的老臣，倘若阵前有失，山人吃罪不起。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "相爷，末将老只老头上发项下须，胸中韬略，却也不老。有道是：虎老雄心在， 年迈力刚强。"
        },
        {
          "character": "赵云",
          "type": "西皮二六板",
          "text": "相爷说话藐视人， 细听俺赵云表一表功勋： 忆昔磐河与主相认， 杀败了袁绍救过了公孙。 长坂坡曾救幼主的性命， 七进七出显过了奇能。 只杀得张郃无处投奔， 卸甲丢盔奔回了曹营。 大功劳一时说不尽， 小功劳一时我记也记不清。 相爷若还不恁信， 你在功劳簿上查分明。 快快与我一枝令。 要学那黄忠取定军。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "老将军不必表功勋， 山人心中明如灯。 你今年迈七十整， 怕你难学黄汉升。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "相爷不与我先锋印， 兵发中原去不成。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "山人奉了幼主命， 哪个大胆阻令行。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "相爷说话我好恨， 不如碰死在辕门。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "一句话儿错出唇， 险些逼坏老将军。 邓芝看过先锋印， 双手付与老将军。 三千人马你带定， 鞍前马后要小心。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "用手接过先锋印，"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "背转身来自思忖： 怕的此去不得胜， 笑坏南阳诸葛孔明。 机谋二字心拿稳，"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套同上，带马，同下。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "凤鸣关前见计行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "邓芝近前听一令： 暗地保护老将军。"
        },
        {
          "character": "邓芝",
          "type": "西皮摇板",
          "text": "帐中领了相爷令， 保护老将把功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓芝下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "满营将官俱遣定， 一战成功取凤鸣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官，兵发凤鸣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，车夫上，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "赵云",
          "type": "内西皮导板",
          "text": "三国纷纷刀兵动，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引赵云同上。"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "我朝中出了汉奸雄。 曹操中原把权弄， 孙权霸占在江东。 我主爷，怒气冲， 一心要灭汉奸雄。 相爷道我老无用， 不由老夫怒气冲。 三军与爷往前涌， 此去一仗定成功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、四龙套、邓芝、魏延、马岱、关兴、张苞同上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏延听令：命你打听魏邦，何人挂帅。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "启禀丞相：来此绵远地界，乃是我兄长坟墓，末将讨下一祭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人也有一祭。 来，看祭礼伺候。 将军呀！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "见坟台不见马将军， 怎不叫人痛在心。 为国忠良丧了命，将军呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "见了丞相说分明。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "启禀丞相：打听魏邦，夏侯楙挂帅，韩德父子，与为前站先行。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军此去必然成功，众将官起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、韩德、韩瑛、韩瑶、韩琼、韩琪同上。"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "某，韩德。赵云老儿兴兵前来，岂肯容他猖狂。众孩儿上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓芝上。"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "来将通名受死。"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "听者：俺乃赵老将军麾下，前部先锋邓芝是也。"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "无名小辈。看刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩德追邓芝同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、赵云同上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "老夫兴兵谁不怕， 赫赫威名扬天涯。 我命邓芝去出马， 等他回来问根芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓芝上。"
        },
        {
          "character": "邓芝",
          "type": "西皮摇板",
          "text": "来在营门下战马， 见了老将把话答。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "命你魏营去把仗打， 一一从头说根芽。"
        },
        {
          "character": "邓芝",
          "type": "西皮摇板",
          "text": "韩德父子威名大， 要与老将动厮杀。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "听罢言来怒气发， 不由老夫咬钢牙。 人来带过刀和马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、邓芝、龙套同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩瑛上，赵云上，杀韩瑛，韩瑛下。邓芝上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "邓芝看我老不老？"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "将军不老。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "军师爷台前报功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、邓芝同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩瑶上，赵云上，杀韩瑶，韩瑶下。邓芝上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "杀了一个又一个， 越杀越勇越快活。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、邓芝同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩琼上。"
        },
        {
          "character": "韩琼",
          "type": "西皮摇板",
          "text": "二位兄长把命丧， 不由豪杰怒满膛。 开弓就把雕翎放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩琼下。赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "老夫接箭也不慌也不忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。韩琼上。"
        },
        {
          "character": "韩琼",
          "type": "西皮摇板",
          "text": "二次来在战场上， 赵云老儿果然强。 二次开弓雕翎放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩琼下。赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "接过雕翎第二条。 儿说儿的武艺好， 放箭哪有接箭高。 认扣搭弦箭放了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩琼上，中箭，下。韩琪上，开打，赵云追韩琪同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩琼、韩琪同上，赵云上，杀韩琼、韩琪，韩琼、韩琪同下。邓芝上，杀头。"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "宝刀一举狗命丧， 无知匹夫丧疆场。 眼前若有诸葛亮， 管叫他含羞带愧脸无光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩德上、四龙套同上。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "四小将落马。"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。赵云、龙套同上，开打。"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "二马连环战疆场， 韩德老儿听端详： 四子俱在刀下丧， 顷刻叫尔一命亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、韩德开打，韩德追赵云同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "且住，韩德老儿杀法厉害。倘若追来，拖刀计伤他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩德上，赵云拖刀斩韩德，韩德下。"
        },
        {
          "character": "赵云",
          "type": "三笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}