{
  "script_id": "01007006",
  "title": "罗成叫关",
  "alias": [
    "淤泥河；一名：周西陂"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "罗成",
      "hangdang": "小生"
    },
    {
      "name": "罗春",
      "hangdang": "小生"
    }
  ],
  "plot": "唐初高丽入寇，李渊命三子元吉帅师往征，以罗成为先行前锋。罗成兵次铭关，出军颇利，屡败苏定方。奈\n元吉以罗成为世民得力骁将，非已之爪牙，方甚忌嫉，故遂有意陷害，逼处死地，谓若不斩得苏烈首级，即\n系通寇，令左右琐闭关门，不许放罗成进。罗成义子罗春暗上城楼探视，适罗成单骑力战归，不得进，抵城\n叫关。罗春遂诉述元吉命令，罗成知元吉有意倾陷，情愿以一死殉国，即命罗春将纱灯坠下，破指裂袍，席\n地草成一血疏，嘱罗春驰归奏闻朝廷，已遂重复上马，拼死入番营索战，乃中苏烈计，被乱箭射死淤河中，\n殊堪浩叹。",
  "notes": "此剧本属于昆剧中之《淤泥河》，全本系《番衅》、《败虏》、《屈辱》、《计陷》、《血疏》、《乱箭》、\n《哭夫》、《显灵》等八折。此《叫关》，即《血疏》也。德珺如、朱素云二人，于此剧堪称一时瑜亮。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗春提灯上。〖水底鱼〗。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "俺，罗春，继父罗成。只因河北反了刘黑塔，李天寿挂帅夺取铭关，二奸王谋 了帅印，命我继父以为前战先行，将那四门紧闭，不放继父进城；如若放进， 全家诛杀，看那日已西沉，不免手提红灯，且上城楼，探听继父下落便了。"
        },
        {
          "character": "罗春",
          "type": "二黄慢板",
          "text": "昔日英雄霸王强， 楚汉相争动刀枪。 霸王自刎乌江丧， 韩信命丧女陈仓。 自古多少英雄将， 好似南柯梦一场。 将身来至敌楼上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗春上城。"
        },
        {
          "character": "罗春",
          "type": "二黄摇板",
          "text": "不知继父在哪厢？"
        },
        {
          "character": "罗成",
          "type": "内锁呐二黄导板",
          "text": "黑夜里闷坏了罗士信，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "回龙腔慢板",
          "text": "胡风儿吹得我透甲如冰。"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "耳边厢又听得金声震，"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "想必是——"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "想必是那苏烈鸣锣收军。 那反贼他倒有爱将之意， 三千岁全无有痛臣之心。 那江边渔翁收了钓， 砍柴樵子下山林。 庵观寺院钟鼓响， 那放牛牧童转芳村，"
        },
        {
          "character": "罗成",
          "type": "二黄摇板",
          "text": "加鞭催动白龙马， 只见城楼掌红灯。 掌灯之人是哪个？"
        },
        {
          "character": "罗春",
          "type": "二黄摇板",
          "text": "儿是继子小罗春。"
        },
        {
          "character": "罗成",
          "type": "二黄摇板",
          "text": "听说来了罗春子， 不孝奴才骂几声： 明知奸王将父害， 还不开关救严亲！"
        },
        {
          "character": "罗春",
          "type": "二黄摇板",
          "text": "爹爹有所不知情， 只因奸王使计行： 如若放进继父身， 全家诛杀罪非轻。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "哦吓！"
        },
        {
          "character": "罗成",
          "type": "二黄摇板",
          "text": "这是我错把姣儿怨， 埋怨罗春也枉然。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "城楼上还有何人？"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "只有孩儿一人。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "好。儿将红灯坠下城来，待为父修下血书，儿去搬兵救父。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗春放灯。"
        },
        {
          "character": "罗成",
          "type": "二黄导板",
          "text": "下了雕鞍城边站，"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "虎头枪插立在马前。 临阵上哪里有笔和砚？ 拔宝剑割战袍修书一封。 钢牙一咬中指破，"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呼呼呼！"
        },
        {
          "character": "罗成",
          "type": "西皮慢板",
          "text": "十指连心痛煞人！ 上写着为臣顿首拜， 启奏秦王有道明君： 都只为秦琼封王位， 程咬金解粮未回程； 尉迟敬德身染病， 我朝缺少挂帅人。 三王元吉挂帅印， 俺罗成做了马前先行。 头一阵枪挑李天寿， 有功不赏反加刑。 责打为臣四十棍， 身带棒伤还要出兵。 从早晨杀到了午时候， 午时杀到夜黄昏。 连杀四门不得进， 城楼遇见小罗春。 望求千岁速救应， 千岁爷吓！ 快到长安搬救兵。"
        },
        {
          "character": "罗春",
          "type": "西皮摇板",
          "text": "罗春接书泪涟涟， 哀告爹爹听儿言： 倒不如铭关造了反， 点动人马反朝廷。"
        },
        {
          "character": "罗成",
          "type": "西皮摇板",
          "text": "罗家本是忠臣将， 岂能做那反叛人！ 儿今若提造反字， 金枪之下命不存！"
        },
        {
          "character": "罗春",
          "type": "西皮摇板",
          "text": "爹爹不听儿相劝， 事到临头悔后难。 父子铭关来分别，"
        },
        {
          "character": "罗成、罗春",
          "type": "同三叫头",
          "text": "（罗春）（爹爹）！（我儿）（吾父）！（我的儿）（爹爹）吓！"
        },
        {
          "character": "罗春",
          "type": "西皮摇板",
          "text": "一封血表到长安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗春下。"
        },
        {
          "character": "罗成",
          "type": "西皮摇板",
          "text": "城楼去了罗春子， 再要相逢万不能。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "罗成",
          "type": "西皮摇板",
          "text": "耳旁听得金声震， 想必苏烈发来兵。 抖抖精神跨金镫， 要想与贼把命拼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}