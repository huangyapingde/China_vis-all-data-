{
  "script_id": "01014016",
  "title": "董家山",
  "alias": [
    "闯山"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "董金莲",
      "hangdang": "旦"
    },
    {
      "name": "尉迟宝林",
      "hangdang": "小生"
    },
    {
      "name": "周鼎",
      "hangdang": "丑"
    }
  ],
  "plot": "剧本中情节出于唐代，大致谓董明在朝为官，被奸臣所谗构，祸及全家。董明女董金莲，逃出此险，孑然一\n身，匿居董家山上。盖女荣华绝世，艺勇惊人者，无可泄愤，因招集亡命，专以抢夺为事。女恃其智力，笼\n络侪辈，为山中之主，亦闺阁中之杰出者也。一日巡哨，适有一少年经过、思劫其行囊，少年人奋力与斗，\n为女擒获。女见其纠纠气象，实生爱羡之心，愿以终身许之，自己却羞人答答，未便明言，遣心腹周鼎，为\n之说合。讵知少年再三推脱，不愿就此良缘。女恼羞成怒，即欲斩之，忽而拔剑上前，忽而释剑回步，脉脉\n含情，直使英雄气短。后少年说出姓名，系尉迟恭之子尉迟宝林。与女家确有世谊者。即释其缚，备酒筵以\n款之。",
  "notes": "此剧演时，观看周鼎插科打诨一段，令人发嘘；而女之风流旖旎，亦颇赏心悦目，谓为佳剧本也可。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、董金莲同上。〖点绛唇〗。"
        },
        {
          "character": "董金莲",
          "type": "念",
          "text": "家住董家山，吃粮不种田。打我山前过，留下买路钱。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "奴家，董金莲。我父董明，唐朝驾前为臣，被奸臣所害，全家遭难。是我来在 此山落草。今当三、六、九日，下山之日。 来。宣周鼎。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "周鼎进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎上。"
        },
        {
          "character": "周鼎",
          "type": "念",
          "text": "忽听姑娘唤，慌忙到跟前。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "报，周鼎进。姑娘在上，周鼎打蹶。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "我说老周呀，人家都说是打茶，你怎么打蹶呀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘呀，我前头一躬，后头岂不是一蹶嘛。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "还是打茶。我说咱们多少日子靡有下山啦？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "有七八十来年啦吧。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "只怕是七八天啦吧。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "正是七八天啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "来，带马下山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林上，对阵。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "何方毛贼，敢抢你少爷去路？"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "好好留下买路金银，放尔过去。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "好好放你咱爷过去便罢，如若不然，定将你山寨，踏为齑粉。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘呀，他骂起咱们来啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "他骂咱们娘们什么来着？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "他说放他过去便罢，如若不然定将山寨打成鸡粪。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "他开口就骂人，咱们揍了他吧。 （董金莲、尉迟宝林同打过合，董金莲下，尉迟宝林追下。周鼎上，引四下手埋伏，董金莲上，尉迟宝林杀， 董金莲退，尉迟宝林落马被擒，众人同下。）"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、周鼎、董金莲、尉迟宝林同上。周鼎挥，四下手同下。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "回避了。 姑娘，周鼎叨赏。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "老周啊，往日你姑娘下山，得些金银财宝，可以赏你们。今个姑娘，什么靡有 得着，可怎么赏你呀。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘，你今个虽靡有得着金银财宝，可是你得了活宝呐。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "呸，还不退下。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎下。"
        },
        {
          "character": "董金莲",
          "type": "西皮原板",
          "text": "看小将是一个英雄好汉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎上。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "报。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "老周，你报什么呀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "可了不得了，山下发啦水啦，冲了一个大萝葡来。我叫老喽啰们打捞上来，刀 斩斧劈，全弄不动它。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "那是怎么啦？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "他们说是腊月的萝葡，动了心啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "唗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎下。"
        },
        {
          "character": "董金莲",
          "type": "西皮原板",
          "text": "奴只想与此人结下良缘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎上。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "报。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "又报什么呀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "山下来了个卖肉的，同一个叫卖鸡蛋的，打起来啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "他是为什么打架？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "他是肉卖一吊钱一斤，鸡蛋一个大钱十个。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "咦，怎么这么贱呀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "这样贱旦还靡人要吶。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "啐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎下。"
        },
        {
          "character": "董金莲",
          "type": "西皮原板",
          "text": "奴有心向前去细问一遍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎上。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "报。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "你又报什么呀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "咱们山上房子塌啦，希哩花拉，塌了半间。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "这算什么，叫喽啰修修就完啦。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "他们说啦，姑娘还不羞，他们就羞啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "唗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎下。"
        },
        {
          "character": "董金莲",
          "type": "西皮原板",
          "text": "怎奈我一时间面带羞惭。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "我说老周啦，老周，老周，我的爹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周鼎上。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "喴。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "你怎么答应爹呀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "喴。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "好，又找补一个。老周喂，你去问问那一小将。他还是愿意吃这一招哇，还是 要吃这一刀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "这我会说。 那一孙子。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "咴。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "那一君子，我们始娘，问你是愿意吃一招呀，还是要吃这一刀？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "“招”、“刀”二字，俺不明白？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "你不明白，我也糊涂。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "前去问来。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘喂，他说“招”、“刀”二字，俺不明白。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "这一刀，就是把他杀了。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "那一君子，这一刀，就是把你杀了。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "这一招呢？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "我也不明白。 姑娘，他问这一招呐。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "这一刀，是把他杀啦。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "他问的是一招。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "老周喴，你明白。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "我不明白，我糊涂。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "老周，你知道。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "我不知道。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "这一招，也是把他杀啦。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "君子，这一招吓，你明白，你知道，咳，也是把你杀啦。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "传话不清，叫你姑娘前来答话。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "兜耍当面，对说对讲，要我们拉皮条的作什么呀？ 姑娘，他说我传话不清，叫姑娘近前答话。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "起过了。"
        },
        {
          "character": "董金莲",
          "type": "西皮摇板",
          "text": "听一言来喜吟吟， 叫声小将听分明： 你若山前来归顺， 情愿与你结婚姻。"
        },
        {
          "character": "尉迟宝林",
          "type": "西皮摇板",
          "text": "丫头说话理不通， 细听某家说详情： 你若要想成婚配， 除非红日自西升。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘，他骂起咱们来了，他说是若要成婚配，除非娘舅配外甥。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "这东西，真可恨，杀了罢。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "杀了罢。"
        },
        {
          "character": "董金莲",
          "type": "西皮摇板",
          "text": "三尺青锋忙抽定， 管叫小将丧残生。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "我说老周呀，姑娘往日杀人不展眼，今个怎么杀不下去啦？"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "这可也就怪啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "老周，你替我想一个计策才好。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "我屁股上有个猴子。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "姑娘倒有一计。老周呀，我要用用你。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "好。真是靡有不开张的油盐店。姑娘，你等等，我先去洗澡去。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "我不是那么用你，我想了一个拉杀之计。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "何为拉杀之计？"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "我假杀，你真拉。一吓唬他就得啦。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "好。姑娘你杀罢。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "杀了罢！"
        },
        {
          "character": "董金莲",
          "type": "西皮摇板",
          "text": "手持宝剑将头割下。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "拉杀之计，她假杀，我真拉。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "老周呀，你误啦。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "我靡开戏就来啦。我会误啦？"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "你倒是快点拉呀。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": "董金莲",
          "type": "西皮摇板",
          "text": "手持宝剑。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "别杀，别杀看我。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "你又太快啦。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "快又快啦，慢又慢啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "你看着刀离脖子，有个二三寸。你一拉就好。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "知道啦。"
        },
        {
          "character": "董金莲",
          "type": "西皮摇板",
          "text": "宝剑一举人头下，"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "二三寸，这还差多着啦。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "老周，你倒是拉呀。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘，你倒是杀呀。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "你不拉，叫我们怎么杀呀？"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘，你不杀，叫我们怎么拉呀？"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "你是成心。我先杀了你罢。"
        },
        {
          "character": "周鼎",
          "type": "白",
          "text": "姑娘，他不怕杀，他就怕么二三小鞭子。"
        },
        {
          "character": "董金莲",
          "type": "白",
          "text": "好，快办来。"
        },
        {
          "character": null,
