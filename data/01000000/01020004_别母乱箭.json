    }
  ],
  "plot": "事实系出明季《铁冠图》小说，乃演定西伯周遇吉力战身死故事。即二十七回“宁武关玉贞尽节，岱州城遇\n吉冲围”及二十八回中“全忠烈周家督战”等一段情节。惟剧本与小说不同。按小说中，周遇吉镇守宁武关，\n名震西北，久为李闯所惧。其妻白氏，亦具通身武艺，善使双刀，胜如一员骁将。夫妻共守此关，闯兵万\n难攻取。无如监军杜勋，已暗与闯贼私通。遂用调虎离山之计，引诱周遇吉追贼远出，以分其夫妇之势，一\n面即开城门迎闯兵入关。白氏闻讯出战，虽斩杀贼兵无算，然究众寡不敌，卒被围困，至力竭而死。时周遇\n吉之母赵氏及其余家口，住居岱州城内。周遇吉乃奔岱州见母。赵太夫人见宁武已失，知岱州更难守，然恐\n周遇吉以己为念，俟周遇吉出府后，即令放火自焚，合家殉节。周遇吉得报，一恸几绝，遂益奋勇出战，然\n亦蹈白氏覆辙，众寡不敌，卒被乱箭射死。洵是一门忠烈。惟此剧本中，则谓其母妻全家均住宁武关，而周\n遇吉则反从岱州失陷，奔回别母。且并无白氏先行战殒等情节。先后自经殉难耳，此即其不同处。总之全家\n忠烈则一也。",
  "notes": "是剧为谭叫天中年在京师著名之戏。此剧纯系吹腔，与昆班脚本尽同。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周母上。"
        },
        {
          "character": "周母",
          "type": "引子",
          "text": "暮景喜安康，两鬓星霜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白氏上。"
        },
        {
          "character": "白氏",
          "type": "引子",
          "text": "晨昏甘旨勤供养，侍奉姑嫜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子上。"
        },
        {
          "character": "周子",
          "type": "引子",
          "text": "萤窗日夜苦钻研，黄卷青箱。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "婆婆，"
        },
        {
          "character": "周子",
          "type": "白",
          "text": "婆婆，母亲。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "罢了。老身乃周遇吉之母。我儿职居岱州总兵，家眷侨居在宁武关。老身年过 耄耋，喜得媳妇贤孝，孙儿攻读书史，娱我暮年。只是吾儿，两月未回，使我 时刻思念。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "启婆婆：闻得流贼，围困岱州，你儿日夜在城守卫，怎得回来？"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "你一向为何再不提起？"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "唯恐惊了婆婆，所以不曾言及。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "就该着人前去打听才是。"
        },
        {
          "character": "周子",
          "type": "白",
          "text": "孙儿昨日已差人打探，早晚必有回音了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、随从同上。"
        },
        {
          "character": "周遇吉",
          "type": "引子",
          "text": "败北非因畏敌狂，虑萱堂，倚门凝望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随从接枪、马，下。家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "老爷回来了。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "我且问你，太夫人在哪里？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "在堂上与夫人、公子讲话。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "你快去准备酒宴伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院允，下。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "参见母亲！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "我儿回来了。为娘正在此想你。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲请上，待孩儿拜见！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "孩儿久离膝下，定省有亏，恕孩儿不孝之罪。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "儿吓，你勤劳王事，我岂罪汝？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "夫人，"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "相公。"
        },
        {
          "character": "周子",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "闻听贼兵，围困岱州，怎得回来？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "我正为贼兵猖獗，特地回来作个……"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "作个什么？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "咳！你问他怎么！"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "好奇怪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启爷：酒筵完备了。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "看酒来！ 母亲，孩儿特治一樽酒，与母亲介寿。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "生受你。"
        },
        {
          "character": "周遇吉",
          "type": "小桃红",
          "text": "擎杯含泪奉高堂，"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "我儿面貌声音，为何有悲惨之状？"
        },
        {
          "character": "周遇吉",
          "type": "小桃红",
          "text": "揾不住，万斛琼珠漾。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "劝萱堂，"
        },
        {
          "character": "周遇吉",
          "type": "小桃红",
          "text": "强笑加餐，好把暮年怡养， 切莫要念儿行！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "我儿光景，似有可疑。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "我好恨！"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "相公恨什么？"
        },
        {
          "character": "周遇吉",
          "type": "小桃红",
          "text": "恨我幼时，怎不去效渔樵？ 习耕牧，守田园，事农桑。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "倒得个，"
        },
        {
          "character": "周遇吉",
          "type": "小桃红",
          "text": "全终养，尽子职无妨， 习什么剑和枪，登什么朝和廊？ 到如今，叫我进退意彷徨！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "周母",
          "type": "下山虎",
          "text": "凭般凄惨，这等悲伤， 有甚衷肠事，何妨细讲？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "孩儿只为远在任所，不能常依膝下，故而如此。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "就是远在任所，也不过一、二日程途耳。"
        },
        {
          "character": "周母",
          "type": "下山虎",
          "text": "何必愁容切切，悲声怏怏， 必有万恨愁，故断肠，何须深掩藏？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "孩儿无有甚事，母亲开怀畅饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉看白氏。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "媳妇奉敬婆婆一杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白氏跪。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "生受你，我手捧。"
        },
        {
          "character": "周母",
          "type": "下山虎",
          "text": "这霞觞，心内细参详。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "我晓得了。孩儿，"
        },
        {
          "character": "周母",
          "type": "下山虎",
          "text": "你不须悒怏， 我有个守节全身善后方。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲知道什么来？"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "你因贼兵围困岱州，恐战死沙场，无人侍奉老身，可是么？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "孩儿心事，既被母亲猜着，怎敢隐瞒。可恨流贼兵众，岱州兵少粮尽，孩儿连 打数阵，不能退敌。岱州已破，孩儿只得退守在宁武关。怎奈此关，前无接应， 后无退步，旦夕必破。特地回来，见母一面，纵然战死沙场，分所当然！只 是不能保护母亲，是以寸心如割。孩儿欲命家将，保护母亲，逃往外府躲避， 免受惊恐。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "我儿此言差矣。我闻昔日王陵之母，尚然能成自之名。"
        },
        {
          "character": "周母",
          "type": "五般宜",
          "text": "难道我未亡人，畏着剑锋？ 难道我年暮人，恋着夕阳寸光？ 不能个成子效忠良？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲还是远避好。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "你叫我避到哪里去？"
        },
        {
          "character": "周母",
          "type": "五般宜",
          "text": "我平生志向，只愿你裕后流芳。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "自古妇人三从为首：在家从父，出嫁从夫，夫死从子。你父不幸早亡，喜汝名 登武库，今逢国难尽忠，为娘的呵！"
        },
        {
          "character": "周母",
          "type": "五般宜",
          "text": "也是理所正当， 何必商量！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "周遇吉，儿吓！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": "周母",
          "type": "五般宜",
          "text": "你若是为国捐躯， 不负我谆谆训义方。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启爷：贼兵围困关前了！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉两边望。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "哎呀母亲！贼兵围困关前，这便怎么处？也罢！待我自刎了罢！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "唗！你若战死沙场，名垂青史；你若死在家中，人必道你：眷恋妻拏，岂不遗 臭万年？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲说得是。天吓，天！我周遇吉不幸至此！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "儿吓！我说个古人你听：东晋时有个苏峻，跋扈提兵犯阙。有个大夫卞昆，仗 剑与苏峻战于阙下而死。他有一子，亦随父而亡。家中妻子亦伏剑而亡。其母 年过九十，拍案大笑曰：吾门幸哉！父死为忠，子死为孝，妻死为节，母死为 义。忠孝节义，出于一门，至今永垂不朽。我们今日，何不效他一效？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲说得是。天吓！我周遇吉不幸至此！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "家将过来。我家遭此大难，合门尽节，你们各自逃生去吧！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "小人蒙太夫人豢养，恩同骨肉，怎能抛撇而去？情愿死一处！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "好，难得，难得。我家有此义仆，胜似卞家一等也！家将与我赶他出去。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "老爷请出去吧。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲，孩儿是去了！"
        },
        {
          "character": "周遇吉",
          "type": "小蔴楷",
          "text": "遵严训，难违抗， 只得含悲忍恸，拜倒在阶旁。 呵呀，堪伤痛， 衰年暮景罹此灾殃！"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "过来！"
        },
        {
          "character": "周母",
          "type": "小蔴楷",
          "text": "从今后绝伊留恋， 断伊索紧，免伊凝望。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "母亲，孩儿是去了。"
        },
        {
          "character": "周遇吉",
          "type": "小蔴楷",
          "text": "谨遵堂上慈亲命，"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "夫人，"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "相公。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "我儿，"
        },
        {
          "character": "周子",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "周遇吉",
          "type": "小蔴楷",
          "text": "捐尽余生答圣明！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉下。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "看相公已去，妾当早为自尽便了。"
        },
        {
          "character": "白氏",
          "type": "五供养",
          "text": "我是裙钗妇，守糟糠， 闺箴从幼慕共姜。 贞操自会凛冰霜， 呵，婆婆呀！ 只为龆龄幼子，衰老姑嫜。 因此上偷生忍死相偎傍，"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "白氏",
          "type": "五供养",
          "text": "倒不如先淬青锋，免使伊牵心挂场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白氏自刎，下。"
        },
        {
          "character": "周子",
          "type": "哭",
          "text": "哎呀，亲娘呀！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "太夫人，少夫人自刎了。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "好，真乃烈妇也！"
        },
        {
          "character": "周子",
          "type": "白",
          "text": "呵呀，婆婆呀！"
        },
        {
          "character": "周子",
          "type": "江头送别",
          "text": "孩儿不能遵祖训光耀门墙， 不能够承父志继绍书香。 穷途流落谁倚仗？"
        },
        {
          "character": "周子",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "周子",
          "type": "江头送别",
          "text": "倒不如先游黄壤！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子撞死，下。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "太夫人，小官人砸阶而死了。"
        },
        {
          "character": "周母",
          "type": "白",
          "text": "好，我家有如此贤孙，难得，难得！来，与我把前后门封起来，四面放火。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院持火把烧场，周母跳火，下。家院自刎，下。仙童、土地同上，迎周母、白氏、周子、家院同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、随从同上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "呀，娘吓！"
        },
        {
          "character": "周遇吉",
          "type": "蛮牌令",
          "text": "看风助火威光， 火趁猛风飏。 满天飞烈焰， 遍地闪金光。 呵，亲娘吓！ 不能够殷勤奉养， 倒使你骨朽形伤。 千倍恨，泪万行， 这的是终天抱恨，万劫难忘！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "来，带马！"
        },
        {
          "character": "随从",
          "type": "白",
          "text": "咋！"
        },
        {
          "character": "周遇吉",
          "type": "尾声",
          "text": "腾腾怒气飞千丈， 绝却家庭内顾伤。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "周遇吉",
          "type": "尾声",
          "text": "俺待放胆扬眉， 和他战一场！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、左金龙同上，对阵。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "贼将通名上来！"
        },
        {
          "character": "左金龙",
          "type": "白",
          "text": "我乃左金龙是也！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "赏你一枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左金龙死，下。四上手、射蹋天同上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "贼将留名！"
        },
        {
          "character": "射蹋天",
          "type": "白",
          "text": "俺乃射蹋天是也！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "赏你一鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "射蹋天下。一支虎上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "贼将何名？"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "俺乃御弟一支虎是也！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起打，一支虎下，周遇吉追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、众闯将、一支虎引李自成同上。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "孤，李自成。你看那周总兵，连伤孤数员上将，他越杀越勇，料难得胜。不如 折兵退回，攻打别处。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "启王兄：周遇吉虽然英烈，有道是：寡不敌众。兄王带领弓箭手，埋伏山谷之 中，待小弟诈败，引他到来。一齐放箭，哪怕他飞上天去。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "此计甚好，待孤前去埋伏，你引他到来便了。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、一支虎同下。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "众将官，随吾山谷去者。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "李自成",
          "type": "念",
          "text": "用箭需用长，挽弓需挽强。射人先射马，擒贼先擒王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "射蹋天上，周遇吉追上，射蹋天下。"
        },
        {
          "character": "周遇吉",
          "type": "采芙蓉",
          "text": "战场黯黯阵云黄， 浮云寒露惨苍茫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎上。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "嘚！周遇吉，敢与俺战几十回合么？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "呔！毛贼吓！"
        },
        {
          "character": "周遇吉",
          "type": "采芙蓉",
          "text": "只俺这枪尖动处， 便披靡奔逸忙忙！"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎下，周遇吉追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李自成、众闯将同上，同上高处。一支虎上，周遇吉追上。转场，一支虎藏。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "众将放箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉带箭下。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "周遇吉已中乱箭，我等赶上前去！"
        },
        {
          "character": "李自成",
          "type": "采芙蓉",
          "text": "似乌号遍张， 飞蝗骤雨难遮障！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉上，持鞭拄地。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "杀败了呀，杀败了！不想我误入罗网，身被重伤，只怕性命难保了！"
        },
        {
          "character": "周遇吉",
          "type": "尾声",
          "text": "悲怏身未死忠魂先漾， 心已碎丹心雄壮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎上。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "周遇吉，敢与我再战数合么？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "放马过来！ 看鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉鞭打一支虎左臂，一支虎下。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "圣上吓，圣上！臣力已尽，不能保全社稷了！"
        },
        {
          "character": "周遇吉",
          "type": "尾声",
          "text": "出师未捷身先丧， 赢得英雄泪两行。"
        },
        {
          "character": "众闯将",
          "type": "内同白",
          "text": "周遇吉，还不投降么！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "尔等谁敢来！"
        },
        {
          "character": "周遇吉",
          "type": "尾声",
          "text": "休无状！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉跪拜。"
        },
        {
          "character": "周遇吉",
          "type": "尾声",
          "text": "望龙城稽颡，"
        },
        {
          "character": "周遇吉",
          "type": "夹白",
          "text": "也罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉拔剑。"
        },
        {
          "character": "周遇吉",
          "type": "尾声",
          "text": "好从容结缨，正是谈笑饮干将！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉自刎，站立。李自成、众闯将同上。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "周遇吉自刎了，可惜可惜，真乃忠良雄将。明朝将官，若能个个如此，孤家焉 能到此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、一支虎同上。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "御弟为何这等模样？"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "适才与周遇吉交战，被他打了一鞭，好不疼煞我也！"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "请到后帐，命御医调治。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "谢兄王。这是何人尸首？"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "这就是周遇吉。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "待我将他碎尸万段！"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "且慢，他也是各为其主，御弟请回大营。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "谢兄王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎下。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "众将官，周遇吉尸身，不可损坏。好好用棺木盛敛，埋葬高阜。"
        },
        {
          "character": "众闯将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "歇兵三日，整顿人马，直捣燕京便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
