    },
    {
      "name": "毛子贞",
      "hangdang": "丑"
    },
    {
      "name": "胡卢大王",
      "hangdang": "净"
    },
    {
      "name": "红烂漫",
      "hangdang": "净"
    },
    {
      "name": "猩猩胆",
      "hangdang": "丑"
    },
    {
      "name": "亚李驮金",
      "hangdang": "末"
    },
    {
      "name": "亚李驮银",
      "hangdang": "副净"
    }
  ],
  "plot": "薛仁贵跨海征东，兵经九连、凤凰等处（即今东三省之九连城、凤凰城是），一路得手，惟抵摩天岭险隘，\n为番将猩猩胆等所阻，屡攻不下。薛仁贵乃拜阅圣母天书，乔装小兵，亲往探山，因天书中现示“卖弓能取\n摩天岭，反得擎天柱二根”之语也。行抵山麓，适遇弓箭匠毛子贞，解送雕弓四十把上山，薛仁贵乃向毛子\n贞探得山上兵力厚薄，及上山情形，遂杀毛子贞，并取其衣帽，伪作弓匠上山。既混入，得与番营守寨总兵\n周文、周武相结纳，并拜为弟兄，随乘机说降二周，盖二周本中华人之流转于东者，故久有剿灭倭夷，振兴\n祖国之志。三人计既定，薛仁贵乃下山返营，旋即进攻，一战而克，枭其巨帅，二周内应之功，不可没也。",
  "notes": "唐代说部《征东传》中，剿平摩天岭一役，实即正史中，薛仁贵三箭定天山之故事。惟说部惯穿凿附会，每\n多荒诞不经，不近情理之处。如薛仁贵之无字天书，及红烂漫、猩猩胆等之奇奇怪怪是也，是剧即三箭定天\n山之戏，而本于《征东说》传中者。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四唐将同上。"
        },
        {
          "character": "唐将甲",
          "type": "念",
          "text": "大将威风凛，"
        },
        {
          "character": "唐将乙",
          "type": "念",
          "text": "腾腾杀气高。"
        },
        {
          "character": "唐将丙",
          "type": "念",
          "text": "玲珑护心镜，"
        },
        {
          "character": "唐将丁",
          "type": "念",
          "text": "日照紫罗袍。"
        },
        {
          "character": "四唐将",
          "type": "同白",
          "text": "请了。元帅升帐两厢伺候，请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四唐将自两边分下。四文堂、中军、薛仁贵同上。〖点绛唇〗。"
        },
        {
          "character": "薛仁贵",
          "type": "念",
          "text": "白盔白甲白旌旗，旗旙招展雪花飞。跨下一骑白龙马，手中使的画杆戟。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "本帅薛仁贵。蒙圣恩挂我为帅，奉旨征讨摩天岭。日前与那贼交过一战，谁知 那贼，用滚木擂石打下，不是本帅回马甚急，险遭不测。 中军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军允。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "传众将进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将进帐。"
        },
        {
          "character": "四唐将",
          "type": "内同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四唐将同上。"
        },
        {
          "character": "四唐将",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "四唐将",
          "type": "同白",
          "text": "谢元帅。传末将等进帐，有何军情？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "蒙圣恩拜我为帅，征讨摩天岭，不能得破。为此请众位将军，一同商议。"
        },
        {
          "character": "四唐将",
          "type": "同白",
          "text": "元帅何不将圣母所赐天书，焚香观看，恐有妙计，亦未可知。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同摆香案。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮导板",
          "text": "为主江山心暗惊，"
        },
        {
          "character": "薛仁贵",
          "type": "西皮摇板",
          "text": "弟兄双双拜神明。 奉旨攻打摩天岭， 可叹众将都耽心。 天书现出踪迹影， 字字行行写得清： 卖弓能取摩天岭， 又得擎天柱二根。"
        },
        {
          "character": "四唐将",
          "type": "同白",
          "text": "元帅，天书上面可有应验？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "天书上面，现出一十四字。"
        },
        {
          "character": "四唐将",
          "type": "同白",
          "text": "哪一十四字？"
        },
        {
          "character": "薛仁贵",
          "type": "念",
          "text": "“卖弓能取摩天岭，又得擎天柱二根”。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "本帅今欲扮作卖弓之人，前去探视。"
        },
        {
          "character": "四唐将",
          "type": "同白",
          "text": "元帅，那贼滚木擂石厉害，须要小心。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "圣母之言，岂有虚妄。 来，看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。薛仁贵更衣。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "众位将军，小心把守大营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四唐将同允。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "毛子贞上。"
        },
        {
          "character": "毛子贞",
          "type": "西皮摇板",
          "text": "我今奉了总爷命， 叫我推弓上山林。"
        },
        {
          "character": "毛子贞",
          "type": "白",
          "text": "老汉毛子贞。奉了总爷之命，叫我造弓四十把，昨日成功，今日齐备，推上山 去，就此趱行。"
        },
        {
          "character": "毛子贞",
          "type": "西皮摇板",
          "text": "年迈无子绝后裔， 每日推弓费心机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛子贞下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵上。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮摇板",
          "text": "圣母之言必有应， 叫我扮作卖弓人。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "俺薛仁贵。只因摩天岭难攻，拜看天书，圣母娘娘叫我扮作卖弓之人，混上贼 的山寨。天色尚早，不免洒开大步，就此走啊。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮摇板",
          "text": "日前带兵探山境， 滚木擂石打三军。 可叹姜兄丧了命， 为国亡家丧了身。 因此本帅心怀恨， 独自前来探贼兵。 洒开大步往前行，"
        },
        {
          "character": "毛子贞",
          "type": "内白",
          "text": "咳！"
        },
        {
          "character": "薛仁贵",
          "type": "西皮摇板",
          "text": "那壁厢来了贼的人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛子贞上。"
        },
        {
          "character": "毛子贞",
          "type": "西皮慢板",
          "text": "行过一程又一程， 歇息歇息养精神。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "呔，拿奸细！"
        },
        {
          "character": "毛子贞",
          "type": "白",
          "text": "我不是奸细。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "你不是奸细，为何推此宝雕弓？家住哪里，姓甚名谁，一一讲来。"
        },
        {
          "character": "毛子贞",
          "type": "白",
          "text": "老汉毛子贞，生长在这摩天岭上，做生意度日。奉了总爷将令，叫我监造宝雕 弓四十把。昨日成功，今日齐备，我是送弓上山的，并不是奸细。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "老人家你生长在这山上，做生意度日。他山上兵有多少，将有几员，你总是知 道的。"
        },
        {
          "character": "毛子贞",
          "type": "白",
          "text": "小人一概知道。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "好，你且讲来。"
        },
        {
          "character": "毛子贞",
          "type": "白",
          "text": "这半山头有二位总爷，一名周文，一名周武，乃是弟兄二人。再上去二十五里， 乃是大寨，内有五员大将：一个叫作胡卢大王；一个叫做红烂漫，乃是高建 王的女婿，手使一口大刀，如同板门一般，有万夫不当之勇；还有一员大将名 叫猩猩胆，使的斗大的铜锤，飞在空中，能取上将之首级；还有二位大将，一 个叫做亚李驮金，一个叫做亚李驮银。爷爷，这都是小人的句句真情。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "少待。 且住。圣母之言，莫非应在此人身上？哦哦，我自有道理。 老人家推此重车上山，肚内岂不饥饿么？"
        },
        {
          "character": "毛子贞",
          "type": "白",
          "text": "到了山上，有人送酒饭与我吃。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "那厢来了一人，敢则是送酒饭与你吃的？你回头看来。"
        },
        {
          "character": "毛子贞",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵杀毛子贞死，毛子贞下。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "且喜这一老人被俺杀死了。他有衣帽在此，待俺装扮起来。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮摇板",
          "text": "为国忠良忠心耿， 食君俸禄报君恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二下手同上。"
        },
        {
          "character": "二下手",
          "type": "同念",
          "text": "领了总爷命，把守栅子门。"
        },
        {
          "character": "下手甲",
          "type": "白",
          "text": "伙计，你我奉了总爷之命，把守栅子门，小心伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵上。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮摇板",
          "text": "一步来在山林境， 见了总爷说分明。"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "拿奸细。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "啊，我不是奸细，我是毛子贞送弓上山。"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "哎！毛子贞嘴上有胡须，你嘴上没胡须，岂不是奸细？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "二位，我是毛子贞的儿子，送弓上山的。你们不信，车上可是我父亲的名讳？"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "果然是他父亲的名讳。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "请你总爷出来。"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "有请总爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引周文、周武同上。"
        },
        {
          "character": "周文",
          "type": "念",
          "text": "坐立貔貅帐，"
        },
        {
          "character": "周武",
          "type": "念",
          "text": "宝剑似秋霜。"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "启总爷：毛子贞送弓上山来了。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "传。"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "呔，毛子贞，总爷传！"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "啊。 参见二位总爷。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "抬起头来。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "小人不敢抬头。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "恕你无罪。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "谢二位总爷。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "啊？毛子贞乃是年大之人，你是他什么人？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "毛子贞乃是小人的父亲，小人叫做毛礼。父亲有病在床，所以命小人送弓上山。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "可知弓的数目？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "四十把。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "来。"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "查来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二下手同允。"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "一十、二十、三十、四十一把弓。 启总爷：多了一把弓。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "毛礼，为何多了一把弓？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "启禀二位总爷：小人自幼在外投师习武，这把硬弓，乃是小人用的。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "你可开得开？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "开得开。"
        },
        {
          "character": "周文",
          "type": "白",
          "text": "当面演来。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "领命。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮快板",
          "text": "随机应变把话答， 铁胎宝弓手内拿。 满满搭上珠丝扣。"
        },
        {
          "character": "周文、周武",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "薛仁贵",
          "type": "西皮快板",
          "text": "惹得总爷取笑咱。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "好的！毛礼还会什么？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "青铜大刀。"
        },
        {
          "character": "周文、周武",
          "type": "同白",
          "text": "演来本镇一观。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "领命。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮快板",
          "text": "手拿一把青铜刀， 不由担惊心内焦。 若是他人猜破了， 我的性命也难逃。 尊声总爷观定了，"
        },
        {
