    }
  ],
  "plot": "《施公案》载：淮安招贤镇剧盗费德恭，系飞天豹之门徒，武艺高强，恃有宝剑一口，削铁如泥；药箭二十\n四枝，百发百中，中无不死，并善使连环棍，附近绿林，无不拜服。因此霸占水龙窝，终日以抢家劫舍为事，\n尤最贪色。时逢八蜡庙庙会之期，费德恭与米龙、豆虎同往游玩，见某氏女名兰英者，姿首绝佳，遂强抢\n回寨，迫其服从。兰英不允，即用乱棒打死。先是，费德恭已因强欲于武举梁大刚女议婚未成，遂将其全家\n二十四口，杀死泄恨，故已犯有大刚一案。施公早令黄天霸等在外侦探。至此，适为黄天霸等所目睹，遂向\n庙祝老道士处，探得大略，知梁大刚一案亦即此人所犯。黄天霸等乃急归报知施公，于是有褚彪定策，令黄\n妻张桂兰扮作民女，也往八蜡庙进香，故予抢去，以便届时内应。张桂兰既至彼，先设计将其宝剑、药箭二\n物藏去，乃与贺人杰一同下手杀出，而褚彪、黄天霸等亦早埋伏在外，至是里应外合，方克将费德恭擒获正\n法云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "费德恭上。"
        },
        {
          "character": "费德恭",
          "type": "点绛唇",
          "text": "武艺高强，英雄胆壮，习拳棒，爱惜刀枪，绿林俺为上。"
        },
        {
          "character": "费德恭",
          "type": "念",
          "text": "两膀膂力压泰山，全凭袖箭镇淮安。压服绿林英雄汉，坐地分赃乐安然。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "吾，姓费，名德恭，人称追魂太岁。只因此地有一武举梁大刚，他有一妹子， 长得十分美貌，是我命家院前去提亲，亲事不准，倒也罢了，他反将我家院， 暴打一顿。是我怀恨在心，夜入他家，杀了他满门二十四口，这且不言。今有 八蜡庙开光大会，我不免前去走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启禀大爷：二位寨主到。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "米龙、豆虎同上。〖吹打〗。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "二位贤弟驾到，未曾远迎，面前恕罪。"
        },
        {
          "character": "米龙、豆虎",
          "type": "同白",
          "text": "我等来得卤莽，大哥恕罪。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "岂敢。二位到此，必有所为。"
        },
        {
          "character": "米龙、豆虎",
          "type": "同白",
          "text": "今有八蜡庙大会，开发一月，特请大哥前去逛会。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "好，就此前往。 来，带马。"
        },
        {
          "character": "费德恭",
          "type": "西皮导板",
          "text": "正在家中心焦躁，"
        },
        {
          "character": "费德恭",
          "type": "西皮快板",
          "text": "二位贤弟来相邀。 八蜡庙，好热闹， 家家户户把香烧。 也有老，也有少， 也有美貌女多姣。 小子们带路前引道， 太岁爷上庙神鬼嚎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张氏、丫鬟同上。"
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "老爷亡故早，母女受煎熬。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "老身张氏，不幸老爷早年亡故，所生一女，名唤兰英。今有八蜡庙大会，不免 将女儿唤出，一同前去还愿。 丫鬟，请小姐出堂。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张兰英上。"
        },
        {
          "character": "张兰英",
          "type": "念",
          "text": "忽听母亲唤，迈步到跟前。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "参见母亲。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "今有八蜡庙开光大会，唤我儿出来，一同前去烧香了愿。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张家院暗上。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "家院，车辆走上。"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "车辆走上。"
        },
        {
          "character": "张氏",
          "type": "西皮原板",
          "text": "都只为老爷亡故早， 母子们终日受煎熬。 家院与我前引道， 八蜡庙内去把香烧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "老道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老道上。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "太夫人到了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏烧香，吃茶，老道托缘簿。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "赏银二两。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "多谢太夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老道下。四下手、米龙、豆虎、费德恭同上。"
        },
        {
          "character": "费德恭",
          "type": "西皮摇板",
          "text": "来在庙内用目洒， 庙内坐定一枝花。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "家院，前去提亲。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "嗻。 我说那老头儿，过来。"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "庙里头坐的那是谁？"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "那是我家太夫人和小姐。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "你家小姐，有了人家靡有？"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "有人家无人家，你问他作甚？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "你看这是我们大爷，你们小姐若能与我们大爷作妾，是享不尽的荣华，受不尽 的富贵。"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "你满口胡言，真是岂有此理。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "大爷，他不允这门亲事。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "来，抢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人抢张兰英同下。张氏拉费德恭，费德恭推张氏。"
        },
        {
          "character": "费德恭",
          "type": "白",
          "text": "好不识抬举。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二差役、黄天霸同上，比粗，费德恭下。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "二位，你看此人，杀死丫鬟、抢去幼女。梁大刚一案，定是此人无疑了，待俺 赶上。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "我说黄爷，咱们先进庙去，打听打听，再作道理，也还不迟。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "好，请。 老道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老道上，黄天霸拜，吃茶。老道上缘簿。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "啊，老道，方才那伙强人，杀死丫鬟、打走家院、抢去幼女，他是何人？"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "我说三位，你们喝碗水，歇歇腿，你走你的路，别管闲事。如今晚的时候，管 闲事，落不是。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "我们是远方来的，且讲无妨。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "你们是远方来的，如此我就对你们说，方才那个红脸大汉，他姓费，名德恭， 人称追魂太岁。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "这位有什么毛病么？"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "他是害热病，靡出汗，汗闭的。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "往下讲。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "他在前面招贤镇居住，此人武艺高强。他有宝剑一口，削铁如泥，还有二十四 枝毒药袖箭，百发百中，可惜是一个酒色之徒。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "只因此地有一武举，名叫梁大刚，他有一妹子，长得十分俊俏。他命人前去提 亲，亲事不准，倒罢，反把他家人打了一顿。那费德恭一闻此言，他怀恨在心， 夜入他家，就杀了他满门二十四口。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "难道就无人叩告于他么？"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "此处府县官员，均与他来往，谁敢告他哪。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "现有纹银五两，将那女子尸首盛殓起来。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "难道不经官相验吗？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "三日后自然明白，告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二差役、黄天霸同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金大力上，张家院上，碰。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "老头儿，你怎么走道，不看人吗？"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "我有心事在怀呀。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "你有什么心事告诉我，我与你分忧解愁。"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "今有我家老夫人，带同小姐，在八蜡庙烧香了愿，不想来了一伙强人，杀死丫 鬟、抢去小姐、将老奴暴打一顿哪啊。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "今有施大人，在此下马，你为何不去告他去？"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "老奴无人引进，只怕告不上去。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "你要去告，你跟着我走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张家院、金大力同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、褚彪、关泰、王殿臣、贺仁杰、朱光祖、施世纶同上。"
        },
        {
          "character": "施世纶",
          "type": "西皮摇板",
          "text": "本院奉命出朝纲， 为民除暴并安良。 一路上接些冤枉状， 捉拿恶霸与强梁。 昨日闻得有梁大刚， 他一家二十四口被人伤。 也曾命天霸四处访， 至今未见转还乡。 人来开道察院上， 等候天霸问端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金大力、张家院同上。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "老头儿，大人在上，你往上告吧。 启禀大人：这来了喊冤的啦。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "带上来。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "老头儿，大人叫你哪。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "有何冤枉，一一诉来。"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "大人容禀：老奴随同我家太夫人、小姐去八蜡庙内还愿。不知哪里来了一伙强 人，杀死丫鬟、抢去小姐、将老奴打了一顿，望大人做主。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "三日后听审，下去。"
        },
        {
          "character": "张家院",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张家院下。黄天霸上。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "参见大人，列位英雄。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "黄爷请坐。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "你打探强人一事如何？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "今在八蜡庙内，见一伙强人，杀死丫鬟、抢去幼女、打走家院。梁大刚一案， 定是此贼无疑了。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "这件事情大人早已知道啦。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "金爷头功。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "还是黄爷的功劳。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "转堂。 列位英雄，"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "大人。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "但不知这恶霸姓甚名谁？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "此人姓费名德恭，人称追魂太岁。"
        },
        {
          "character": "褚彪",
          "type": "白",
          "text": "提起费德恭，老朽颇知一二。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "老英雄请讲。"
        },
        {
          "character": "褚彪",
          "type": "白",
          "text": "那费德恭，乃是飞天豹的门徒。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "敢是那五七达子飞天豹吗？"
        },
        {
          "character": "褚彪",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "老英雄请讲请讲。"
        },
        {
          "character": "褚彪",
          "type": "白",
          "text": "此贼炼就宝剑一口，削铁如泥，又有二十四枝毒药袖箭，百发百中，可惜他是 个酒色之徒。若拿此贼，非请黄副将的令正不可。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "既然如此，请到黄副将家中，定计捉拿此贼，便了。"
