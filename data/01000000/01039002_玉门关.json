        {
          "character": "呼韩豹",
          "type": "白",
          "text": "此处必有奸细，搜杀去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 18,
      "name": "第十八场",
      "utterances": [
