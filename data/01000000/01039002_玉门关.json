          "character": "班超",
          "type": "白",
          "text": "却道是不入虎穴，焉得虎子？我想今晚夜间，三更时分，暗暗混进敌营，一在 后面放火，一在前面喊杀。倘若胜了番兵，国家必有重赏；若是不胜，就为国 一死，也不失英雄的体面。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "将军之言有理，就请传令。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "王忠、朱武听令！"
        },
        {
          "character": "王忠、朱武",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "命你二人扮作番兵模样，混进敌营。等到三更时分，一齐放火，不可有误。"
        },
        {
          "character": "王忠、朱武",
          "type": "同白",
          "text": "遵令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武同下。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "邓远听令！"
        },
        {
          "character": "邓远",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "命你埋伏高岗之上，等到敌营火起，擂鼓助战，当作疑兵，不可有误。"
        },
        {
          "character": "邓远",
          "type": "白",
          "text": "遵令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓远下。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "刘鹏、马严、郭昭听令！"
        },
        {
          "character": "刘鹏、马严、郭昭",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "徐大哥！"
        },
        {
          "character": "徐干",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "我们今晚就可一同前往。"
        },
        {
          "character": "徐干",
          "type": "白",
          "text": "好。"
        },
        {
          "character": "班超",
          "type": "念",
          "text": "单身伏猛虎，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "赤手缚长蛇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武同上，同走圆场。"
        },
        {
          "character": "王忠",
          "type": "白",
          "text": "俺王忠。"
        },
        {
          "character": "朱武",
          "type": "白",
          "text": "俺朱武。 奉了将军将领，今夜晚间，命我二人扮作番将模样，暗暗混入敌营，就此走走。"
        },
        {
          "character": "王忠、朱武",
          "type": "同新水令",
          "text": "松阴宿鸟夜飞腾， 月沉沉更深人静。 潜踪行没影， 紧急似流星。 放胆前行， 哪怕他兵强将猛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二更夫同上。"
        },
        {
          "character": "更夫甲",
          "type": "念",
          "text": "为人别打更，"
        },
        {
          "character": "更夫乙",
          "type": "念",
          "text": "打更睡不宁。"
        },
        {
          "character": "更夫",
          "type": "白",
          "text": "伙计！"
        },
        {
          "character": "更夫乙",
          "type": "白",
          "text": "今夜该我们执更巡夜，就此走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武暗同上，同执二更夫。"
        },
        {
          "character": "更夫乙",
          "type": "stage",
          "text": "中国京剧戏考 《玉门关》【前本】 9"
        },
        {
          "character": "王忠、朱武",
          "type": "同白",
          "text": "你们是甚人？"
        },
        {
          "character": "二更夫",
          "type": "同白",
          "text": "我们是打更的。"
        },
        {
          "character": "王忠、朱武",
          "type": "同白",
          "text": "你们可晓得营中的粮草，现在何处？"
        },
        {
          "character": "二更夫",
          "type": "同白",
          "text": "在大营后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武同杀二更夫，同换衣。"
        },
        {
          "character": "王忠",
          "type": "白",
          "text": "眼看敌营不远，不免闯进者呀。东南风起，此天助我也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武同下。"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武同上。"
        },
        {
          "character": "王忠",
          "type": "白",
          "text": "贤弟。"
        },
        {
          "character": "朱武",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "王忠",
          "type": "白",
          "text": "你我混进了敌营，幸喜无人知觉。天到什么时候？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "打三更鼓。"
        },
        {
          "character": "朱武",
          "type": "白",
          "text": "三更三点。"
        },
        {
          "character": "王忠",
          "type": "白",
          "text": "放火烧营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火焰。王忠、朱武同下。"
        }
      ]
    },
    {
      "scene_id": 17,
      "name": "第十七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "呼韩豹、四番卒同上。"
        },
