      ]
    },
    {
      "scene_id": 20,
      "name": "第二十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王忠、朱武同上，呼韩豹、四番卒同追上，班迎上。"
        },
        {
          "character": "呼韩豹",
          "type": "白",
          "text": "你是何人？挡住某的去路！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "俺大汉司马班超是也。你是何人，还不通名受死！"
        },
        {
          "character": "呼韩豹",
          "type": "白",
          "text": "俺匈奴大将呼韩豹。 中国京剧戏考 《玉门关》【前本】 10"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "这样狗虏，敢来为敌？ 众将，杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同开打，同下。"
        }
      ]
    },
    {
      "scene_id": 21,
      "name": "第二十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "邓远执旗上。众马军同上。内鼓声。"
        },
        {
          "character": "邓远",
          "type": "白",
          "text": "前面火起，我不免登高擂鼓助战者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓远登山。内鼓声。"
        },
        {
          "character": "邓远",
          "type": "白",
          "text": "呀，好一场厮杀也！"
        },
        {
          "character": "邓远",
          "type": "石榴花",
          "text": "只见那番兵番将似海潮， 观不尽人头滚荒郊。 又只见将士纷纷一阵乱剿， 烈焰中马嘶人哭叫。 助他阵战鼓冬冬， 助他阵战鼓冬冬。 我天朝将帅把那刀枪绕， 高高下下飞腾，也应烟冒。 见一派旌旗烧， 见一派旌旗烧。 胡尘也应尽扫。 俺这里一战灭儿曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "班超、王忠、刘鹏、马严、徐干、郭昭同上。呼韩豹、四番卒同上，同开打，呼韩豹败下，众人同追下。"
        },
        {
          "character": "邓远",
          "type": "白",
          "text": "马军！"
        },
        {
          "character": "众马军",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "邓远",
          "type": "白",
          "text": "你看番兵败下，带马前去截杀者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓远下山，带众马军同下。"
        }
      ]
    },
    {
      "scene_id": 22,
      "name": "第二十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "呼韩豹、四番卒同上。班超、王忠、朱武、徐干、刘鹏、马严、郭昭、邓远同上。班超坐。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "众将！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "把番将绑上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼韩豹站立，不跪。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "你这狗虏，私通鄯善，要谋害俺的性命。 来！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "绑下去杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "军卒绑呼韩豹同下。内鼓声。军卒捧人头上，跪。"
        },
        {
          "character": "军卒",
          "type": "白",
          "text": "将军请看。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "悬在辕门。 众将！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "传鄯善国王进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。鄯善王上，惊。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "嗳吓！吓、吓死我也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄯善王进见，跪。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "将军将我传来，有何吩咐？"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "你这老奴才，违背大汉，私通匈奴，要害某的性命。 来！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "嗄。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "绑下去杀！ 中国京剧戏考 《玉门关》【前本】 11"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄯善王叩头。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "将军且请息怒，在下不敢害将军。情愿归降大汉，望求饶恕。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "看你老迈，暂且饶过。限你三天，将军马点齐，待本官查验，不得违误。下去。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄯善王起。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "嗳吓，险哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄯善王下。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "请在后帐，与诸将贺功。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
