          "character": null,
          "type": "stage",
          "text": "王忠、朱武同上。"
        },
        {
          "character": "王忠",
          "type": "白",
          "text": "后面追兵前来，不免截杀一阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番卒、呼韩豹同上。"
        },
        {
          "character": "呼韩豹",
          "type": "白",
          "text": "尔等何人，敢来放火？"
        },
        {
          "character": "王忠",
          "type": "白",
          "text": "俺汉朝大将王忠，"
        },
        {
          "character": "朱武",
          "type": "白",
          "text": "朱武。"
        },
        {
          "character": "呼韩豹",
          "type": "白",
          "text": "无名小卒。巴图鲁与我拿下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同开打，王忠、朱武同败下。呼韩豹、众人同下。"
