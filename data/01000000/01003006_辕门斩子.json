{
  "script_id": "01003006",
  "title": "辕门斩子",
  "alias": [
    "白虎堂"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "焦赞",
      "hangdang": "净"
    },
    {
      "name": "孟良",
      "hangdang": "净"
    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "赵德芳",
      "hangdang": "老生"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "穆桂英",
      "hangdang": "武旦"
    },
    {
      "name": "穆瓜",
      "hangdang": "旦"
    }
  ],
  "plot": "宋杨延昭征剿山东穆柯寨，先被穆桂英所败，夜命儿子杨宗保，出营巡哨，为穆桂英擒逼成亲。既而杨宗保\n回营，杨延昭怒其临阵招亲，违犯军法，定欲处斩。焦赞、孟良苦求不下，驰报佘太君出救，杨延昭不听。\n适八贤王赵德芳至，又代杨宗保说情，杨延昭亦不允，甚至反颜怒争，斥赵德芳冲闹白虎法堂，即命部下，\n将赵德芳乘马刖去了足，以示其罪，赵德芳无知之何。正危险间，忽穆桂英至，呈献降龙木，见夫婿绑示辕\n门，即带怒入，硬请赦免。杨延昭始亦不允，既而畏其强，不得已乃允之。",
  "notes": "此戏去杨延昭之须生，最为吃重，颇费力量，须唱做兼工者，演时方有精彩。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、焦赞、孟良引杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "山东把阵败，怒气满胸怀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭坐帐。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "元帅今日升帐，与往日大不相同，大家小心了！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将，"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "宗保到此，叫他报门而进！"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "哦！ 小本官哪里去了？你我外面找寻。"
        },
        {
          "character": "杨宗保",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "离了穆柯寨，来此是宋营。"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "小本官来了！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "二位叔父！"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "你爹爹今日升帐，与往日大不相同，你要小心了！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "待我转去。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "大丈夫只有向前，哪有后退之理？ 二哥与他报门。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "报：小本官告进！"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "小本官当面！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "下跪儿是宗保？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将，将他掌起面来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞、孟良同允。"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "怒恼杨延昭， 蠢子听根苗： 命儿去巡哨， 私自把亲招。 枪挑穆天王， 桂英下山巢。 将父擒下马， 这笑！笑坏帐下众英豪。 焦孟二将一声叫， 绑至辕门定斩不饶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良、焦赞同绑杨宗保，杨宗保坐。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "贤弟。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "小本官犯罪，乃是你我弟兄二人的引诱，你我进帐，讲个人情。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我想这个人情，讲不下来。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "都有我！"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "焦、孟二将与元帅叩头！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将，进帐何事？"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "小本官犯罪，看在我兄弟二人，鞍前马后，讲他饶恕了罢！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你二人，敢是与他讲情？"
        },
        {
          "character": "焦赞、孟良",
          "type": "白",
          "text": "元帅开恩！"
        },
        {
          "character": "杨延昭",
          "type": "笑",
          "text": "哼哼……"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "我说不要紧的！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哽！唗！宗保犯罪，皆是你二人的引诱！先斩宗保，然后再去你二人的首级！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我说讲不下来，你说有你！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你说有你！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "你说有你！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥不必如此，你看好了小本官，待我去搬太娘。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "快去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞下，佘太君、焦赞同上。"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "听说是斩宗保把我唬坏， 行一步险些儿跌倒尘埃。 见娇儿绑至在营门以外， 因甚事绑辕门要把刀开？"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
          "text": "辕门外绑得我三魂不在， 猛抬头又只见祖母前来。 都只为招亲事将令犯坏， 因此上绑辕门要把刀开。"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "小孙儿休的要悲声哭坏， 待祖母进帐去把情讲来。 叫焦赞与孟良通禀元帅， 不由人怒冲冲气满胸怀。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "太君驾到！"
        },
        {
          "character": "杨延昭",
          "type": "西皮导板",
          "text": "听说是老娘亲来到帐外，"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "杨延昭离虎堂迎接娘来。 见老娘施一礼躬身下拜，"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "问老娘进虎堂所为何来？"
        },
        {
          "character": "佘太君",
          "type": "西皮原板",
          "text": "娘进帐难道你还不自解？ 谁要你假殷勤问娘何来！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "老娘亲怒不息愁锁眉黛， 莫不是为宗保不肖奴才？"
        },
        {
          "character": "佘太君",
          "type": "西皮原板",
          "text": "小孙儿并不会为非作歹， 因甚事绑辕门要把刀开？"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "儿命他领将令巡查营外， 又谁知穆柯寨私配裙钗！ 临阵上招了亲王法犯坏， 问老娘儿斩他该是不该？"
        },
        {
          "character": "佘太君",
          "type": "西皮原板",
          "text": "小孙儿违了命理当斩坏，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "谢母亲！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "还看他年纪轻无志无才。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "娘道他年纪小孩童气概，"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "有几个年幼人娘且听来： 秦甘罗十二岁称为太宰， 石敬塘十三岁拜帅登台。 三国中周公谨名扬四海， 七岁上学道法人称将才； 十三岁与东吴挂印为帅， 烧曹兵八十万无处葬埋。 那都是父母生非神非鬼， 难道说小奴才禽兽投胎？"
        },
        {
          "character": "佘太君",
          "type": "西皮快板",
          "text": "听儿言豺狼辈安心毒坏， 不由人闷恹恹珠泪满怀。 你父亲丧李陵尸留北塞， 一家人死得惨好不伤怀！ 到如今只剩得宗保血块， 到后来还要他祭扫坟台。 倘若是小冤家有个好歹， 那时节管教儿悔不转来！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "昨日里斩八将头挂帐外， 老娘亲何不将慈悲放开。 今日里斩宗保娘把儿怪， 哭啼啼坐虎堂所为何来？ 老娘亲休讲清请出帐外， 儿今日定斩这不肖奴才！ 叫焦赞将宝剑悬挂帐外，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞拿剑下。"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "老娘亲再讲情儿自刎头来。"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "杨延昭生得来性情高傲， 他把我母子情一旦撇抛。 眼睁睁小孙儿难以救了， 孙儿吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君下。焦赞引赵德芳同上。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "赵德芳催白龙来在法标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳下马。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "御外郎把什么军令犯了， 你为何绑辕门项上加刀？"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
          "text": "都只为招亲事将令犯了， 因此上绑辕门项上加刀。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "御外男休得要心中烦恼， 有为王进帐去将情讨饶。 叫焦赞与孟良向前通报， 杨延昭不下位藐视当朝。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "贤爷到！"
        },
        {
          "character": "杨延昭",
          "type": "西皮导板",
          "text": "听说是八贤爷御驾来到，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "贤爷到！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "元帅知道了！"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "驾离了南清宫所为哪条？ 走上前施一礼扬尘舞蹈，"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "免！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "免！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "恕微臣接驾迟将臣饶恕。"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "丢愁眉换笑颜抛却烦恼， 尊一声御妹夫细听根苗： 御外男把什么军令犯了， 你将他绑辕门要把头招？"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "臣命他领将令巡营瞭哨， 又谁知穆柯寨私把亲招。 临阵上招了亲王法犯了， 因此上绑辕门项上加刀。"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "御外男犯将令理当斩了，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "念本御讲人情将他饶恕。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "君有命臣当领怎敢违拗， 我主爷降下罪哪个承招？"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "休虑我叔王爷降旨来到， 五阎君要性命本御承招。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "八千岁休得要把事看小，"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "为什么在帐中絮絮叨叨？ 斩不斩本是我杨家令号， 并不曾犯千岁哪些律条！"
        },
        {
          "character": "赵德芳",
          "type": "西皮快板",
          "text": "杨元帅休得要把脸变了， 听本御把前事细说根苗： 曾记得你七弟打死潘豹， 潘仁美上金殿哭奏当朝。 我叔王龙颜怒降旨一道， 将你的一满门绑赴法标。 有本御上金殿把你来保， 才得你一满门无罪逍遥。 到如今做高官前情忘了， 看起来你是个无义的尔曹！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "曾记得天庆王打来战表， 他要夺我主爷锦绣龙朝。 我大哥替宋王长枪丧了， 我二哥短剑下命赴阴曹； 我三哥被马踹尸如泥草， 我四哥失番邦无有下梢； 我五哥弃红尘削发修道， 我七弟被仁美射死芭蕉； 我八弟被贼擒生死不晓， 一家人好一似燕被鹰叼。 哪一阵我杨家死的不少， 论功劳才挣下这玉带紫袍！"
        },
        {
          "character": "赵德芳",
          "type": "西皮快板",
          "text": "你有功孤有赏替天行道， 并没有埋没你半点功劳。"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "你把你南清宫太看大了！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "本来的不小！"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "你把我杨延昭哪放心稍？ 闯辕门我就该将你斩了，"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哪个敢斩？"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "斩不得！"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "看在了宋王爷将你饶恕。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "八千岁。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "杨元帅。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "赵德芳！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "杨延昭！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "此地什么所在？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "小小白虎聚堂！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "既知白虎聚堂，为何在此摆来摆去？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "慢说小小白虎聚堂，就是我叔王金銮宝典，也要摆这几摆！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "上闯白虎堂，理当取斩！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哪个敢斩！"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "斩不得！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将，八千岁轿来马来？"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "白龙马来。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "将马刖去四足！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞、孟良剁马足。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "白龙马去四足心中害怕， 杨延昭他那里藐视皇家。 眼睁睁御外男难以救下， 御外男吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳下。穆桂英、穆瓜同上。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "穆柯寨来了我女将娇娃，"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "耳边厢又听得锣鸣鼓响， 辕门外排刀锤剑戟如麻。 叫穆瓜上前去看个真假， 或斩兵或斩将细问根芽。"
        },
        {
          "character": "穆瓜",
          "type": "西皮摇板",
          "text": "我姑娘她那里把令传下， 穆柯寨来了我大将穆瓜。 我这里走上前用目来斜，"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "咦！"
        },
        {
          "character": "穆瓜",
          "type": "西皮摇板",
          "text": "辕门外绑的是我的姑爷，你的他！"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "听一言不由我翻鞍下马， 向前来叫一声恩爱冤家： 因犯了何条罪辕门绑下？ 对妻子一一地细说根芽。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "将军、将军吓！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "我这里问他言不把话答，"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "想必是穆柯寨招亲事发。 劝将军你那里宽心放下， 有妻子进帐去哀告爹家。 我这里整乌云忙理铠甲， 回头来唤一声吩咐穆瓜。"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "三千担干粮草？"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "三千担干粮草辕门堆下，"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "五百名家丁？"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "五百名勇家丁四路安扎；"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "还有降龙木？"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "降龙木交与我你且退下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆瓜下。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "我这里跪宝帐不把话答。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "适才间与贤爷帐中叙话， 只气得杨延昭咬碎银牙。 睁开了杀人眼观看帐下，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "女将跪帐！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "元帅知道了。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "宋营中跪定了女将娇娃。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦赞，"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "叫焦赞你与我向前问话， 谁家女哪家眷在何处有家？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "咋！ 那一女子，家住哪里，姓甚名谁，一一讲来。"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "家住在山东地穆柯寨下， 俺乃是穆桂英宗保的浑家。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "吓！她就是山东穆桂英——杀人的祖宗！元帅你要小心了！ 二哥你也小心了！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "听说是穆桂英我的心中害怕，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，元帅听见穆桂英，他的嗓子眼倒吓小了。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "宋营中来了个杀人的夜叉。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦赞，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞允。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "问小姐不在那山东潇洒， 来到我宋营中有何话答？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "咋！ 穆小姐，你不在山东潇洒，来到我宋营，干什么来的？"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "容禀。"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "三千担干粮草辕门堆下，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "还有什么？"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "五百名勇家丁四下安扎；"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "还有什么？"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "降龙木它本是此宝无价， 特地里赴宋营献于皇家。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "元帅，她进降龙木来了。"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "听罢言来笑开怀，"
        },
        {
          "character": "杨延昭",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "焦赞",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "叫焦赞将宝呈上来。 我为你务日愁眉带， 我为你终日挂在怀； 我为你山东把阵败， 我为你才斩小奴才。 叫焦赞将宝后帐摆， 等候了五哥下山来。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "三千担粮草？"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "三千担干粮草堆在营外，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "五百名家丁？"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "五百名众家丁自有安排。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "穆小姐？"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "穆小姐且归那穆柯山寨， 奏明了宋天子接进营来。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "穆小姐，你暂且回去，奏明了天子，接你进营。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "奴还有话讲。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你等着。 启禀元帅：她还有话讲。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "是她说的。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "小将军因何故辕门绑下？ 因犯了何条罪要把头杀？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "她为小本官而来。"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "斩宗保为的是违令犯法， 穆小姐这件事休要管他。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你不要管他。"
        },
        {
          "character": "穆桂英",
          "type": "西皮快板",
          "text": "小将军犯将令理当斩杀， 看在那进宝功饶恕与他。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "着，念她进宝有功！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "好一个穆桂英果真胆大， 敢在我宋营中卖舌张牙。 若不念投帐前进宝功大， 定将你与宗保一齐斩杀！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "吓！穆小姐，你要动这个家伙才行呢！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "老元帅如不把人情准下，"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "宋营中杀他个血染黄沙！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "吓！元帅，吃饭的家伙要紧吓！"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "叫焦赞和孟良急忙招架，"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "叫一声穆小姐细听根芽： 赦却了罢杨宗保倒还也罢， 怕的是天门阵无人去杀。"
        },
        {
          "character": "穆桂英",
          "type": "西皮快板",
          "text": "老元帅你若把人情准下， 天门阵自有我一人去杀。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "天门阵，有她去杀。"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "天门阵摆下了一百单八， 难道说阵阵你都能杀？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "穆小姐，天门阵摆下一百单八，难道说，阵阵你都能杀？"
        },
        {
          "character": "穆桂英",
          "type": "西皮快板",
          "text": "一千阵一万阵何在跨下， 何况那天门阵一百单八。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "一千阵，一万阵，她都能！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "吓，一千阵，一万阵，她都能。焦赞你可能？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "我不能，元帅你可能？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "穆桂英在帐中夸口甚大， 我这里翻天书仔细盘查："
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "九女星奉玉旨鹅怀投化， 脱化了穆桂英半点不差。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "这里跪着一个穆桂英，这书上有个穆桂英，在两军阵前，把元帅这么一挟，就 是她！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "杨延昭",
          "type": "哭头",
          "text": "穆桂英，我那智勇双全的儿吓……"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "我的儿吓……"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "你不该将为父擒在马下， 满营中大小将活活笑杀。 我这里将人情暂且准下， 看小姐饶恕了不肖的冤家。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "叩罢头谢公公恩比天大，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，你与他松绑。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "拔宝剑唬退了红黑二煞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保、穆桂英同下。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，元帅有四字不周全。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哪四字？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "不忠，不孝，不仁，不义。你我不要管它闲事，吃酒去。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦赞哪里去？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "吓，元帅。"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "有焦赞和孟良一旁叙话， 杨延昭倒做了无有话答。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将，本帅赦了杨宗保，收了穆桂英，有保状者，呈上来。"
        },
        {
          "character": "焦赞、孟良",
          "type": "同白",
          "text": "元帅赦了杨宗保，收了穆桂英，有保状者，呈上来。"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "贤爷保状，太君保状，满营将士保状。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "贤爷的保状。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "太君的保状。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "满营将官的保状。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "我弟兄二人，还有个小小的帖。"
        },
        {
          "character": "杨延昭",
          "type": "笑",
          "text": "哈哈……"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "叫焦赞将保状后堂高挂， 唤上了小奴才训教于他。"
        },
        {
          "character": null,
