{
  "script_id": "01003003",
  "title": "桑园会",
  "alias": [
    "秋胡戏妻；一名：马蹄金；一名：辞楚归鲁"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "秋胡",
      "hangdang": "老生"
    },
    {
      "name": "罗氏",
      "hangdang": "正旦"
    },
    {
      "name": "秋母",
      "hangdang": "老旦"
    }
  ],
  "plot": "考此剧即《列女传·秋胡妇》故事。传载鲁秋胡子，纳妻五日而宦于陈，后归，未至家，见路旁一美妇采桑，\n悦之，下车谓曰：力田不如逢年，采桑不如见郎，吾有金一蹄，愿馈夫人。妇不受而去。秋胡归，母呼其\n妇出，乃即采桑妇也。秋胡子惭，妇数秋胡之罪，而自投于河。按剧本与传载稍有出入，其相异之点有三：\n如一为宦陈，一则宦楚；一为秋胡但知悦路旁美妇人，一则疑为已妇，而故试探之；一为投河竞死，一则自\n缢获救。案陈，即今河南陈州，其地当时或已属楚，亦未可知，是二而一也。不知为妻与疑其为妻，相去本\n在毫发之间，而调戏则一也。是虽异而实同。惟考时传记载，均称秋胡女因此致死，而秋胡子，即以妇死之\n故，而为后世引为轻薄之戒。然则所讹者，惟女不死之问题耳。噫，晚近世风不古，一般庸夫俗妇之心理，\n皆以一死为凶，安知非编剧者，有鉴于此，而故予以不死，以劝励薄俗耶。",
  "notes": "此剧多流水快板，须生、青衫均重在唱工，而须生尤须唱得流转如意。飘飘然有逸致，方佳。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引秋胡上。"
        },
        {
          "character": "秋胡",
          "type": "引子",
          "text": "归心似箭，辞王驾，转回家园。"
        },
        {
          "character": "秋胡",
          "type": "念",
          "text": "秋胡离家二十春，千里迢迢无信音。世上若得全忠孝，臣报君恩子奉亲。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "下官姓秋名胡，字高强，乃鲁国人氏。在楚国为官，官居光禄寺大夫。只因离 家日久，不知老母妻室，怎生度日？为此辞王别驾，回家祭祖。 来，看衣衾换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋胡换衣。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍下。"
        },
        {
          "character": "秋胡",
          "type": "西皮快三眼",
          "text": "一日离家一日生， 好似孤雁宿寒林。 尽得忠来难尽孝， 靴尖不离午朝门。 虽然楚国为官好， 还有思家一片心。 无心观看路旁景， 披星戴月转家门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋胡下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗氏上。"
        },
        {
          "character": "罗氏",
          "type": "引子",
          "text": "愁锁眉梢，每日里，奉养年高。"
        },
        {
          "character": "罗氏",
          "type": "念",
          "text": "儿夫一去未归家，婆媳双双度日华。望穿两眼空流泪，斜依门前盼天涯。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "奴家罗氏女，配夫秋胡，去往楚国求官，一去二十余载，并无音信回来。婆媳 二人，采桑度日。今乃桑园桑枝茂盛，不免前去采桑便了。待我奉告婆婆知道。 呀，婆婆，"
        },
        {
          "character": "秋母",
          "type": "内白",
          "text": "作什么？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "媳妇去往桑园采桑，婆婆好生看守门户。"
        },
        {
          "character": "秋母",
          "type": "内白",
          "text": "媳妇儿，早去早回。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "媳妇知道。 呀，出得门来，好天气也！"
        },
        {
          "character": "罗氏",
          "type": "西皮慢板",
          "text": "三月里天气正艳阳， 手提勾篮去采桑。 老婆婆两鬓如霜降， 织麻纺线度日光。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "来此已是桑园，不免采桑便了。"
        },
        {
          "character": "罗氏",
          "type": "西皮二六板",
          "text": "自古道男耕女织纺， 莫把黄金用斗量。 在头上整整青丝发， 身上抖抖旧衣衫。 腰中紧紧丝罗带， 足下蹬蹬破鞋袜。 轻轻奴把桑枝上， 惊动了蝴蝶乱飞扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋胡上。"
        },
        {
          "character": "秋胡",
          "type": "西皮流水板",
          "text": "秋胡打马奔家乡， 行人路上马蹄忙。 坐在刁鞍用目望， 见一位大嫂手攀桑。 前影好似罗氏女， 后影好似我妻房。 本当下马将妻认，"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "秋胡",
          "type": "西皮流水板",
          "text": "错认民妻错非常。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "且住，看那旁好像我妻子模样，本当向前相认，又恐错认民妻，这便怎么处？ 待我下马问来。 大嫂请了，"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "呀，"
        },
        {
          "character": "罗氏",
          "type": "西皮流水板",
          "text": "耳边厢听得人喧嚷， 举目抬头看端详： 阳关大道人来往， 见一客官在路旁。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "客官，敢是迷失路途？"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "阳关大道，哪有迷失路途？乃是找名问姓的。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "请问大嫂，此处有一秋胡，住在何处？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "呀，客官，此人就在前面。问他则甚？"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "我与他有八拜之交，带来万金家书，故而动问。"
        },
        {
          "character": "罗氏",
          "type": "西皮流水板",
          "text": "听一言来喜洋洋， 口内不住谢上苍。 二十年前分别往， 今日才得信回乡。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "呀，客官，秋胡离我家不远，将书信留下，我与他带回就是。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "秋兄言道：书信要面交本人，"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "若不是本人呢？"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "原书带回。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "呀，客官，你与秋胡有八拜之交。可将他家中之事，说得一字不错，奴家放桑 不采，送你前去。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "大嫂听了："
        },
        {
          "character": "秋胡",
          "type": "西皮快板",
          "text": "站立在桑田把话讲， 尊一声大嫂听端详： 秋兄家住鲁国古田桑， 姓秋名胡字高强。 他父名叫秋祖旺， 二十年前早已亡。 他母柯氏六旬上， 白发孀居在高堂。 他妻名唤罗氏女， 留下裙钗守空房。 临行送回阳关上， 叮嘱言语记心旁： 此去若登龙虎榜， 急忙修书转回乡。 这是秋兄对我讲， 并无风言哄娘行。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "呀，"
        },
        {
          "character": "罗氏",
          "type": "西皮快板",
          "text": "听他言来无虚谎， 果是儿夫结义行。 罗氏女忙把桑田下， 整整青丝抖衣衫。 回首便把客官叫， 你拿书来我回乡。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "大嫂，你要书信。你是秋兄什么人？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "客官呀，"
        },
        {
          "character": "罗氏",
          "type": "西皮快板",
          "text": "客官不必问其详， 奴与秋胡配鸳鸯。 二十年前分别往， 奴家每日奉高堂。 婆婆白发如雪降， 只为家贫来采桑。"
        },
        {
          "character": "秋胡",
          "type": "西皮快板",
          "text": "听她言来心欢畅， 果然我妻来采桑。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "唉呀，且住：想我秋胡，离家二十余载，不知她贞节如何？看这桑田，四下无 人，我不免调戏她一番，就是这个主意。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "客官，本当请到舍下待茶，奈房屋窄小不是待客之所。有日丈夫回来，登门叩 谢。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "谢倒不用谢，卑人有几句言语，你且听了："
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "客官请讲。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "大嫂呀，"
        },
        {
          "character": "秋胡",
          "type": "西皮导板",
          "text": "秋胡他把良心丧，"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "住了！他丧良心不丧良心，与你什么相干？"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "大嫂呀！"
        },
        {
          "character": "秋胡",
          "type": "西皮原板",
          "text": "他在那楚国配鸳鸯。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "你要放老实些！"
        },
        {
          "character": "秋胡",
          "type": "西皮原板",
          "text": "劝他回家他不往，"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "不回来就罢。"
        },
        {
          "character": "秋胡",
          "type": "西皮原板",
          "text": "撇下了大嫂守空房。 你好比明月空放亮，"
        },
        {
          "character": "秋胡",
          "type": "西皮二六板",
          "text": "你好比明珠土内藏。 你好比鲜花空开放， 卑人好比采花郎。 大嫂若是从勾挡， 我和你织女配牛郎。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "罗氏",
          "type": "西皮摇板",
          "text": "客官说话欠思量， 胡言乱语罪非常。 既与儿夫结金兰， 不该起下此心肠。 有书快把书呈上， 无书快快出田桑。 你若在此胡言讲， 恶言恶语骂一场！"
        },
        {
          "character": "秋胡",
          "type": "西皮快板",
          "text": "大嫂不是这样讲， 卑人言来听端详： 男儿无妻家无主， 女子无夫房无梁。 阳关大道无人往， 学一个仙女会襄王。"
        },
        {
          "character": "罗氏",
          "type": "西皮快板",
          "text": "客官早早出田桑， 奴本是大户人家女娘行。 你在胡言多乱讲， 管教你披枷带锁无有下场！"
        },
        {
          "character": "秋胡",
          "type": "西皮摇板",
          "text": "好个贞节女娘行， 果然守节世无双。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "哎呀，且住：调戏了她半日，并无半点春心，这便怎么？有了，不免取出马蹄 金一锭，倒要试试她的贞节！ 呀，大嫂，这里有马蹄金一锭，拿回家去，你婆媳度日。卑人图一时之欢乐， 你意如何？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "罗氏",
          "type": "西皮摇板",
          "text": "任你说得风流样， 奴本是铜打铁心肠。 低下头来暗思想，"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "有了。 客官，那旁有人来了。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "来在哪里？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "在那里！"
        },
        {
          "character": "罗氏",
          "type": "西皮摇板",
          "text": "将身跳出是非场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗氏下。"
        },
        {
          "character": "秋胡",
          "type": "西皮摇板",
          "text": "好个贞节女娘行， 论理可挂贞节坊。 黄金不要抽身往， 急忙回家奉高堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋胡下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秋母上。"
        },
        {
          "character": "秋母",
          "type": "西皮流水板",
          "text": "乌鸦不住叫呱呱。 叫得老身心内麻。 眼看红日落西下， 不见媳妇转回家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗氏上。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "呀，"
        },
        {
          "character": "罗氏",
          "type": "西皮摇板",
          "text": "将身来在草堂下， 见了婆婆说根芽。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "哎呀，婆婆。"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "媳妇为何这等模样？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "婆婆呀，媳妇去往桑田采桑。来了一狂徒，调戏媳妇，故来迟了。娘呀！那贼 徒，"
        },
        {
          "character": "罗氏",
          "type": "西皮摇板",
          "text": "一马来在桑田下， 胡言乱语把话答。"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "他讲些什么？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "他言道，与你儿子下书的。"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "你就该问他要书才是。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "媳妇问他要书，谁想那贼徒，"
        },
        {
          "character": "罗氏",
          "type": "西皮摇板",
          "text": "三番两次来戏耍，"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "媳妇，你可允他没有？"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "哎呀，婆婆呀！媳妇若是应允他，也不回来禀告婆婆知道。吓……"
        },
        {
          "character": "罗氏",
          "type": "西皮摇板",
          "text": "守节立志岂从他！"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "媳妇不要啼哭，后面收拾茶饭去罢。"
        },
        {
          "character": "罗氏",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗氏下。"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "好狂徒呀！"
        },
        {
          "character": "秋母",
          "type": "西皮快板",
          "text": "手指狂徒高声骂， 气得老身咬刚牙。 若是我儿在家下， 定把狂徒送官衙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋胡上。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "秋胡",
          "type": "西皮快板",
          "text": "扬鞭催动能行马， 杨柳深处是我家。 去时杨柳不多大， 回来不觉两交加。 扳鞍离蹬下了马，"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "好狂徒呀！"
        },
        {
          "character": "秋胡",
          "type": "西皮快板",
          "text": "高堂上坐定老白发。 走上前来忙跪下， 儿是秋胡转回家。"
        },
        {
          "character": "秋母",
          "type": "西皮快板",
          "text": "客官免礼请坐下， 休要错认年迈妈。 我的儿本是书生样， 为何项上长了须发？"
        },
        {
          "character": "秋胡",
          "type": "西皮快板",
          "text": "打罢春来又转夏， 春夏秋冬日月华。 少年子弟江湖老， 老母青丝转白发。"
