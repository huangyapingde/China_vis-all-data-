        {
          "character": "秋母",
          "type": "白",
          "text": "去往楚国求官，官居何职？"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "儿居光禄大夫之职。"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "哦呵呀，我儿做了光禄大夫。待为娘谢天谢地！"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "当谢天地！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋胡看。"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "我儿看些什么？"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "孩儿回来，为何不见你那贤德媳妇，往哪里去了？"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "我倒忘怀了，我唤她出来，你夫妻相会。"
        },
        {
          "character": "秋胡",
          "type": "白",
          "text": "母亲不要唤她。"
        },
        {
          "character": "秋母",
          "type": "白",
          "text": "呀，媳妇儿快来呀！"
        },
        {
          "character": "罗氏",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗氏上。"
