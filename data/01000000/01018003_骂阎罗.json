{
  "script_id": "01018003",
  "title": "骂阎罗",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "郭胡迪",
      "hangdang": "老生"
    },
    {
      "name": "阎王",
      "hangdang": "净"
    },
    {
      "name": "老道",
      "hangdang": "丑"
    },
    {
      "name": "郭胡仪",
      "hangdang": "末"
    },
    {
      "name": "郭妻",
      "hangdang": "旦"
    },
    {
      "name": "李七",
      "hangdang": "净"
    }
  ],
  "plot": "宋岳武穆归神于风波亭，天下士民，无不为之叹息痛恨。而高宗之昏聩，秦桧之奸恶，当时尽人皆知，无待\n后世为之论定。有书生胡迪者，素性耿直，因武穆之冤抑，愤恨达于极点。每谓天地鬼神，皆有偏向，以致\n是非颠倒如此。一日酒醉，忽然牵动心事，痛骂阎罗王，不施报应。阎王命鬼卒摄其魂，欲治以狂妄侮辱之\n罪，胡迪侃侃诘辩，阎王信其刚正，反温论慰藉之，使遍观各种地狱，以证明报应之不爽，忠贞魂魄，早作\n天界之神；奸恶夫妻，已定阴司之律，彰善殚恶，自有权衡。乃召请岳公，阎王与之分庭抗礼，而锁提秦桧，\n鬼役为之怒目横眉。胡迪一一得以目见，方始悦服，阎王亦始终敬礼，增寿算一纪，送之还阳。",
  "notes": "剧本情节出于《说部岳传》，惟中间穿插处，与《岳传》所载，大不相同，盖编排者之心理，但使观剧者有\n趣味可寻，即为善本，不必沾沾于事实也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪上。"
        },
        {
          "character": "郭胡迪",
          "type": "引子",
          "text": "十载寒窗，勤学业，苦读文章。"
        },
        {
          "character": "郭胡迪",
          "type": "念",
          "text": "如今朝事太不平，奸贼专权乱朝廷。可叹岳家三父子，风波亭上受苦情。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "学生，姓郭名胡迪，字梦蝶，乃湖广汉阳人氏。今逢大比之年，进京来赴试， 寓在这天齐庙内。只因那岳少保，在朱仙阵上，杀退金兵百万，堪看就要成功， 不料朝廷下了十二道金牌，将岳少保调回。前者又将他父子拿问进京，交大 理寺三法司审问，不知为了何事？我也曾命家院，前去打探，未见回来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "念",
          "text": "打听忠良事，报与相公知。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "参见相公。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "罢了，你回来了？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相公大事不好了！"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "那岳家三父子被秦桧所害，在风波亭上，三绞丧命。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "三绞丧命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪气死。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相公醒来！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮导板",
          "text": "一霎时不由人心头火起，"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "为国忠良丧了躯。 咬牙切齿骂秦桧， 屈害忠良化灰泥。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "反了啊，反了！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "越思越想心越气， 无人替岳少保辩冤屈。 我这里急忙金殿去，"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相公你往哪里去呀？"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "我道朝中把本题。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相公，你乃是一秀才，上不得金殿，奏不得本章！"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "听一言来心头火起， 我秀才不能把本题。 霎时间只觉得肝胆碎， 活活气坏了我郭胡迪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪死。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相公！哎呀，相公气绝了。待我将老道唤出来。 老道，老道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈贵上。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "什么事情啊？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "我家相公气绝了，你在此好好看守，待我去请一医生前来，与他调治。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "你去吧，我在这里伺候着他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "相公醒来！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮导板",
          "text": "三魂渺渺离了体，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪看。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "只间一人把话提。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "啊，你是何人呐？"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "我是老道陈贵呀。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "好贼啊！"
        },
        {
          "character": "郭胡迪",
          "type": "扑灯蛾",
          "text": "闻言怒冲冠， 奸贼听根源： 岳家被你害， 少时你命难全！"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "这是怎么啦？"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "我把你这贼子啊！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "大骂秦桧狗贼子， 你屈害岳家理不宜。 恨不得将你来打死， 我抽你的筋来剥你的皮。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "你别打我！我不是秦桧，我是老道陈贵！"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "你不是秦桧，是老道陈贵？"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "不错！我是老道陈贵。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "秦桧？陈贵？这是音同字不同？"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "我不相信。我要摸摸。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "你摸什么呀？"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "我一摸便知真假。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "如此相公你就请摸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪摸陈贵。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "不错，你是老道。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "你怎么知道是老道啊？"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "你有一双耳朵！"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "人嘛！焉能没有耳朵啊？"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "叫老道带路大殿去， 这上面塑的是哪一位神诋？"
        },
        {
          "character": "陈贵",
          "type": "西皮快板",
          "text": "相公你要问来历， 细听老道说端的： 若问神灵是哪一位， 这就是大帝东岳天齐。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮快板",
          "text": "听说这是东岳大帝， 倒叫我心中怒不息。 善恶报应你全不理， 我就向前打倒你。 再把油灯扯在地，"
        },
        {
          "character": "陈贵",
          "type": "西皮快板",
          "text": "打碎了玻璃又油了我的衣。 油了衣服我无有换替，"
        },
        {
          "character": "郭胡迪",
          "type": "西皮快板",
          "text": "我与你再做衣件新衣。"
        },
        {
          "character": "陈贵",
          "type": "西皮快板",
          "text": "倘若是庙主来问起？"
        },
        {
          "character": "郭胡迪",
          "type": "西皮快板",
          "text": "我就与你多上布施。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "好！多上布施就好啦！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "叫老道引路前殿去，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小鬼上，做泥塑，郭胡迪打倒。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "我打死你这老贼气方息！"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "相公，这是泥塑小鬼，不是秦桧，你又打错啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪看。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "我与你将他来扶起，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小鬼伛偻。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "相公，你看他原来不是这个样子，他怎么弯着个腰啊？"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "不妨事，待我将他揍直了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪打小鬼。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "相公，你可是把他打直了，可就是有一点歪。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "不妨事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪打小鬼。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "我向前就与你作上一个揖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小鬼下。四青袍捧香盘同上，转场，同下。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "又听得庙前人喧语， 不知他们是做什么的？"
        },
        {
          "character": "陈贵",
          "type": "西皮快板",
          "text": "今日三月二十七， 他们是上庙烧香的。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮快板",
          "text": "善恶报应神全不理， 何必烧香祷神诋？ 站立在墙头用目觑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪上椅子，看，下椅子。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮快板",
          "text": "他们来时我定不依！"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "相公，你后面歇歇好不好？"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪、陈贵同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二女施主同上，烧香拜神，陈贵捧簿上，二女施主写布施。"
        },
        {
          "character": "二女施主",
          "type": "同白",
          "text": "庙中可有歇息所在？"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "庙外就是茶棚。"
        },
        {
          "character": "二女施主",
          "type": "同白",
          "text": "我等前去一游。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二女施主同下。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "烧香的全走了，待我把他请出来，听他说些什么？ 相公，请出来凉爽凉爽吧！"
        },
        {
          "character": "郭胡迪",
          "type": "内西皮导板",
          "text": "我心中抱定了这不平事，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪上。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "心神不定眼昏迷。 抓住了奸贼我就用力打，"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "你怎么又打起来啦？"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "我把你这秦桧奸贼！"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "我是陈贵，我不是秦桧。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "你是哪个？"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "我是老道陈贵。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "你是老道？我不信，我还要摸上一摸。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "你又要摸？你就摸吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪摸陈贵，提耳朵。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "不错，你是老道陈贵！你有两只耳朵哟！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "叫声老道听端的： 与吾引路后殿去，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭胡迪、陈贵同转场。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "这上面坐的是哪一位神诋？"
        },
        {
          "character": "陈贵",
          "type": "西皮快板",
          "text": "老道开言告诉你， 相公你要听端的： 若问上面是哪一位， 他就是五殿阎君秦广辉。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "呀呀呸！"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "听说五殿秦广辉， 倒叫胡迪纵双眉。 秦桧作恶罪应死， 反享荣华福寿齐。 老道看过了一支笔！"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈贵托笔、墨、砚。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "这不必说，一定是要上布施。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮摇板",
          "text": "我在这粉壁墙上要把诗题。"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "原来是要在墙上题诗。"
        },
        {
          "character": "郭胡迪",
          "type": "西皮原板",
          "text": "上写着：湛湛青天真可欺！"
        },
        {
          "character": "陈贵",
          "type": "白",
          "text": "错了，错了！常言道：“湛湛青天不可欺”。"
        },
        {
          "character": "郭胡迪",
          "type": "白",
          "text": "想那岳少保，为国忠心，被奸臣秦桧所害，他父子三人，俱在风波亭遭害。那 天道无知，真可欺！"
        },
        {
          "character": "陈贵",
