{
  "script_id": "01014022",
  "title": "四杰村",
  "alias": [
    "余千救主"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "鲍士安",
      "hangdang": "净"
    },
    {
      "name": "余千",
      "hangdang": "武生"
    },
    {
      "name": "廖锡龙",
      "hangdang": "净"
    },
    {
      "name": "鲍金花",
      "hangdang": "武旦"
    },
    {
      "name": "濮天鹏",
      "hangdang": "净"
    },
    {
      "name": "萧计",
      "hangdang": "净"
    }
  ],
  "plot": "此剧出于《绿牡丹》小说中。朱氏兄弟龙、虎、熊、豹四人，在扬州独霸，所住之处，名曰四杰村。当初平\n山堂摆设擂台，卖弄武艺，被鲍士安、骆宏勋等所打败。朱豹又被鲍金花脚尖踢瞎两眼，结下仇恨，适骆宏\n勋因贺世赖诬为盗，囚解到京。朱氏偶知此事，动入村中。骆宏勋有义仆余千急欲往救，途遇头陀箫计，观\n其张皇之状，盘问事由，余千备细告之。盖萧计与骆宏勋素有交情，即锐身自任，而水陆两路好汉，鲍士安、\n花振芳、濮天鹏、鲍金花诸人亦不期而遇。及至庄门前，早将护庄河吊桥抽去，无计可进，萧计即用神光\n普照牌匾，渡过众好汉。始得将朱氏消灭，救出骆宏勋。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、朱龙、朱虎、朱熊、朱豹同上。"
        },
        {
          "character": "朱龙、朱虎、朱熊、朱豹",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "朱龙",
          "type": "白",
          "text": "朱龙。"
        },
        {
          "character": "朱虎",
          "type": "白",
          "text": "朱虎。"
        },
        {
          "character": "朱熊",
          "type": "白",
          "text": "朱熊。"
        },
        {
          "character": "朱豹",
          "type": "白",
          "text": "朱豹。"
        },
        {
          "character": "朱龙",
          "type": "白",
          "text": "众位贤弟请了。"
        },
        {
          "character": "朱虎、朱熊、朱豹",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "朱龙",
          "type": "白",
          "text": "今有骆宏勋，打入囚车，解往京都，打此经过。你我弟兄在前面等候，等他到 来，将他掠进村中，好与四弟报仇。"
        },
        {
          "character": "朱虎、朱熊、朱豹",
          "type": "同白",
          "text": "好。就此前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四上手押囚车同上，四下手、朱龙、朱虎、朱熊、朱豹同上，同抢车。余千上，上桌看。众人自两边分下。"
        },
        {
          "character": null,
          "type": "text",
          "text": "余千下桌。）"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "不知何人，将我家主人掠去。呵喝是了！此地离四杰村不远，想是被朱氏弟兄 将我主抢去。待我赶上前去便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "余千下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "萧计上。"
        },
        {
          "character": "萧计",
          "type": "引子",
          "text": "带发修行，习拳棒，结交绿林。"
        },
        {
          "character": "萧计",
          "type": "念",
          "text": "自幼出家入空门，终日禅堂念经文。闷来山前看虎斗，闲来山后听鸟鸣。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "洒家，萧计。在这普陀寺内出家。爱习拳棒，结交绿林英雄好汉。今日天气炎 热，不免将茶桌摆起。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人押骆宏勋同上，过场，同下。萧计看。余千上，推倒桌。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "那一汉子休走，将俺茶桌撞倒，是何道理？"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "将你茶桌撞倒，你便如何？"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "似你这等言语，你可知俺的厉害？"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "你何狂言，着打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧计打，余千倒地，起。"
        },
        {
          "character": "余千",
          "type": "念",
          "text": "强中自有强中手，休在人前夸自强。"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "请问师傅上下。俺这里赔礼了。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "洒家萧计。"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "请问师傅，那萧安、萧月是师傅什么人？"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "一个师兄，一个是俺师弟。"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "原来是萧师傅，俺余千有礼了。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "看你慌慌张张，不知为了何事？"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "只因俺家公子，骆宏勋，被人诬告，打入囚车解往京都。不知哪里来了一伙强 人，将我家公子掠去，依小人看来，定是四杰村朱氏弟兄所为。师傅闪开，待 俺前去搭救。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "那朱氏弟兄十分凶勇，你一人前去，画虎不成，反类其犬。"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "倘若迟延，只怕公子性命难保。休要拦阻，待我赶上。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "慢来，这有护身佛一尊，你且拿去，倘有暗器伤你，可保无虑。"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "多谢师傅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "余千下。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "看他此去，定难成功。待俺庙内等候便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧计下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "濮天鹏、鲍金花、鲍士安同上。"
        },
        {
          "character": "濮天鹏、鲍金花、鲍士安",
          "type": "同西皮摇板",
          "text": "出离了龙潭镇阳关路上， 大英雄受招安四海名扬。"
        },
        {
          "character": "濮天鹏",
          "type": "西皮摇板",
          "text": "自幼儿闯江湖豪气千丈，"
        },
        {
          "character": "鲍金花",
          "type": "西皮摇板",
          "text": "巾帼中女英雄谏世无双。"
        },
        {
          "character": "濮天鹏、鲍金花、鲍士安",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "鲍士安。"
        },
        {
          "character": "濮天鹏",
          "type": "白",
          "text": "濮天鹏。"
        },
        {
          "character": "鲍金花",
          "type": "白",
          "text": "鲍金花。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "此番骆公子有书前来，邀请我等，倘若到得京城，得了一官半职，也是我绿林 中的体面。"
        },
        {
          "character": "濮天鹏",
          "type": "白",
          "text": "据我看来，这作官还不如作强盗的好。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "哽，想那骆公子仗义疏财，你夫妻若不是他搭救，你夫妻焉有今日。"
        },
        {
          "character": "鲍金花",
          "type": "白",
          "text": "我说爹呀！"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "嘁！"
        },
        {
          "character": "鲍金花",
          "type": "白",
          "text": "您能同他可生什么气呐，他简直的是一个饭桶。他哪里有一点良心。"
        },
        {
          "character": "濮天鹏",
          "type": "白",
          "text": "你才没有良心呐！"
        },
        {
          "character": "鲍金花",
          "type": "白",
          "text": "我说今年是大比之年，开科取士。可惜我鲍金花是个女子，我要是个男子，今 科的武状元，一定是我的啦。"
        },
        {
          "character": "濮天鹏",
          "type": "白",
          "text": "哪里有你这个母状元。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "不必争论。大家趱路要紧。"
        },
        {
          "character": "鲍士安",
          "type": "西皮摇板",
          "text": "加鞭催马往前闯， 又只见小冯洪急走慌忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯洪上。"
        },
        {
          "character": "冯洪",
          "type": "白",
          "text": "启禀鲍老丈：大事不好啦！"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "冯洪",
          "type": "白",
          "text": "只因骆公子不知身犯何罪，装入囚车解往京都，行至前面，被一伙强人劫入村 庄去了。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "那余千呢？"
        },
        {
          "character": "冯洪",
          "type": "白",
          "text": "那余千不顾生死，搭救他家主人去了。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "大家一同赶上前去，搭救于他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "萧计上。"
        },
        {
          "character": "萧计",
          "type": "念",
          "text": "余千救主命，未见转回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲍士安、濮天鹏、鲍金花、冯洪同上。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "原来是萧师傅。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "鲍老丈，请到庙中一叙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同进庙，同坐。余千上。"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "参见鲍寨主。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "你搭救你家公子之事如何？"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "是俺去到村前，那厮寨门之内，俱有弩弓冷箭，不是萧师父赐我护身佛，险遭 不测。"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "如何！"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "但不知怎样方能入庄？"
        },
        {
          "character": "萧计",
          "type": "白",
          "text": "那四杰村四面寨门俱有埋伏，他村中出入皆要安放吊桥。今晚众位英雄随同洒 家前去，洒家安下神光普照牌匾，送你等过了吊桥，方可进去。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "命你等三人今晚一同前去。须要小心。"
        },
        {
          "character": "鲍金花",
          "type": "白",
          "text": "爹呀，我也要去。"
        },
        {
          "character": "鲍士安",
          "type": "白",
          "text": "你乃女流之辈，不去也罢。"
        },
        {
          "character": "鲍金花",
          "type": "白",
          "text": "想骆公子待我们恩厚，我要不去，叫我碧莲姐姐知道，她看我鲍金花，可就不 够朋友啦。"
        },
        {
          "character": "鲍赐安",
          "type": "白",
          "text": "好，大家用了斋饭，一同前去便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四英雄、廖锡龙同上。"
        },
        {
          "character": "廖锡龙",
          "type": "西皮流水板",
          "text": "胸中韬略般般优， 某的威名冠九州。 要那骆宏勋心已久， 万剐凌迟刀割头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱龙、朱虎、朱熊同上。"
        },
        {
          "character": "朱龙、朱虎、朱熊",
          "type": "同白",
          "text": "启师爷：骆宏勋今已拿到。"
        },
        {
          "character": "廖锡龙",
          "type": "白",
          "text": "押上来！"
        },
        {
          "character": "朱龙、朱虎、朱熊",
          "type": "同白",
          "text": "押上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押骆宏勋同上。"
        },
        {
          "character": "廖锡龙",
          "type": "唱",
          "text": "一见宏勋怒冲冠， 今日才得报仇冤。"
        },
        {
          "character": "廖锡龙",
          "type": "白",
          "text": "有请四爷！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有请四爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱豹上。"
        },
        {
          "character": "朱豹",
          "type": "念",
          "text": "眼前不辨黑和白，足下哪晓路高低。"
        },
        {
          "character": "朱豹",
          "type": "白",
          "text": "师爷。"
        },
        {
          "character": "廖锡龙",
          "type": "白",
          "text": "今将骆宏勋拿到了。"
        },
        {
          "character": "朱豹",
          "type": "白",
          "text": "好。看刀来。"
        },
        {
          "character": "廖锡龙",
          "type": "白",
          "text": "且慢。想他犯罪，押往京者，今被我等掠进庄来，必须少待一二日，倘若官兵 不来追赶，那时再杀不迟。"
        },
        {
          "character": "朱豹",
          "type": "白",
          "text": "师爷，想你们有眼的在天堂，我这无眼的在地狱。好不闷煞人也！"
        },
        {
          "character": "廖锡龙",
          "type": "白",
          "text": "你息一时之怒，今将他打入山洞之内，哪怕他飞上天去！日后定要将他剖肠挖 心，与你报仇。后面有酒，大家痛饮。正是："
        },
        {
          "character": "廖锡龙",
          "type": "念",
          "text": "宏勋打入山洞中，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "哪怕他插翅又腾空！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。四下手押骆宏勋同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "众人",
          "type": "内同白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯洪、余千、濮天鹏、鲍金花同上，走边。"
        },
        {
          "character": "众人",
          "type": "同斗鹌鹑",
          "text": "英雄侠义志高强， 闯江湖天下名扬。 恨强徒当是猖狂， 逞凶必暗害贤良。 改扮巧装， 管叫他全家命丧！"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "此番诸位若将我家主人搭救出来，俺余千感恩非浅！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "闲言少讲，搭救公子要紧。"
        },
        {
          "character": "众人",
          "type": "同斗鹌鹑",
          "text": "路绕羊肠， 急忙忙来到村上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
