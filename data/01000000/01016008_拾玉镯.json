{
  "script_id": "01016008",
  "title": "拾玉镯",
  "alias": [
    "买雄鸡；一名：孙家庄"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "孙玉姣",
      "hangdang": "旦"
    },
    {
      "name": "傅朋",
      "hangdang": "小生"
    },
    {
      "name": "刘媒婆",
      "hangdang": "彩旦"
    }
  ],
  "plot": "陕西郿邬县城外，孙家庄孙寡妇，生女曰玉姣，豆蔻年华，风姿曼妙。其母因家计困穷，业养鸡为生活，孙\n玉姣则日事女红，藉佐炊舋。有世袭指挥使傅朋者，至郊外踏青，乡村间柳绿桃红，已极游目骋怀之乐。忽\n于竹篱茅舍中，见一绝色女子，手托香腮，停针不语，若有所思。傅朋目逆而送之，曰美而艳，遂不顾唐突，\n上前询问姓氏。孙玉姣见傅朋风流潇洒，亦不愧为翩翩浊世之佳公子，脉脉含情，备告以母女历史。傅朋\n赠以玉镯，孙玉姣故作羞怯，却而不受。傅朋委镯于地。孙玉姣俟其去远，始拾藏于袖。不意二人缱绻深情，\n早为邻居刘媒婆所窥破，突至孙家，诘问玉镯之所由来。孙玉姣红晕于颊，言语支吾。刘媒婆直道其隐，\n孙玉姣无可掩饰，恳刘媒婆不传于外，以免旁人之飞短流长。刘媒婆遂甘言以诱之，且肯为成全其好姻缘，\n索取表记，回赠傅公子。孙玉姣乃与以绣鞋一只。",
  "notes": "后刘媒婆子刘彪，见鞋图奸，竟演出种种惨剧，傅朋性命，几乎不保。幸有未婚妻宋巧姣，直至太后前鸣冤，\n由刘瑾为之彻底根究，始得昭雪。《法门寺》一出，即此剧后本，详情均载在内。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣上。"
        },
        {
          "character": "孙玉姣",
          "type": "引子",
          "text": "愁锁在眉头，习针黹，挑罗刺绣。"
        },
        {
          "character": "孙玉姣",
          "type": "念",
          "text": "泪湿罗巾袖，新愁加旧愁。春光容易过，薄命女含羞。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "奴家，孙玉姣。不幸爹爹早年亡故，留下母女二人度日。今日母亲，去到前村 听经去了，留我一人在家。清早起来，烦闷无事，不免捻针刺绣便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣拈针纫线。"
        },
        {
          "character": "孙玉姣",
          "type": "梆子慢板",
          "text": "二八女在房中心中自叹， 思想起儿的父好不惨然。 都只为遭不幸把命染， 留下了母女们受尽熬煎。 我的母到前村听讲经卷， 只剩下奴一人看守家园。 终日里在家中挑针纫线， 但不知何日里才得安然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋上。"
        },
        {
          "character": "傅朋",
          "type": "西皮流水板",
          "text": "有傅朋清晨起闲游玩， 出城来在郊外散闷消闲。 看桃红和柳绿春光无限， 不觉得来至在孙家庄前。 迈步儿门前观看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘媒婆上，孙玉姣开门，刘媒婆下。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "妙吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣闭门。"
        },
        {
          "character": "傅朋",
          "type": "西皮摇板",
          "text": "见一位二八女亚赛天仙。 我这里迈步儿抽身回转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋下，孙玉姣开门，傅朋上，孙玉姣闭门。"
        },
        {
          "character": "傅朋",
          "type": "西皮摇板",
          "text": "我二人怎能够结下姻缘。 我这里将玉镯脱离手腕， 走向前放至在柴门外边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋下。"
        },
        {
          "character": "孙玉姣",
          "type": "西皮摇板",
          "text": "适才间开了门来观看， 见一少年赛潘安。 站在门前将奴看， 倒叫我二八女面带羞惭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣开门看，脚踏镯，拾镯看。傅朋上。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "呵欬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣放镯，赶鸡。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "呕哧，呕哧，呕哧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋拾镯。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "那位小娘子，请来见礼。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "有礼相还。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "这里可是孙妈妈家中？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "正是家母寒舍。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "既称家母，想必就是孙姑娘。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "不敢。请问少年，尊姓大名？"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "在下姓傅名朋字友生，就在郿邬县城居住。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "来到寒舍，必有所为。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "你家可有雄鸡？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "雄鸡倒有，只是昨日已卖完了。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "既是卖完了，待我再到别家去买。现有玉镯一只，奉送大姐。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "奴家不要。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "送与大姐，收了罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣摇头，下。"
        },
        {
          "character": "傅朋",
          "type": "西皮摇板",
          "text": "我这里将玉镯且放下， 但看那佳人怎样拿？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋下，孙玉姣上，下场看，拾镯，试。傅朋上，孙玉姣递镯。"
        },
        {
          "character": "傅朋",
          "type": "西皮摇板",
          "text": "我看她拾玉镯是心中已允， 我二人一定要结成婚姻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋下，孙玉姣看。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "妙吓。"
        },
        {
          "character": "孙玉姣",
          "type": "西皮摇板",
          "text": "见少年丢玉镯扬扬去了， 好叫我小奴家挂在心梢。 但愿他遣媒人早早来到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣闭门。"
        },
        {
          "character": "孙玉姣",
          "type": "西皮摇板",
          "text": "我二人成姻缘凤友鸾交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘媒婆上。"
        },
        {
          "character": "刘媒婆",
          "type": "西皮快板",
          "text": "他二人苟且事被我看见， 倒叫老身笑连连。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘媒婆笑。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "我，刘杨氏。今早打从孙寡妇门前经过，看见小傅朋与孙玉姣二人，眉来眼去， 好不叫人可笑也。"
        },
        {
          "character": "刘媒婆",
          "type": "西皮慢板",
          "text": "这件事把我的牙关笑破， 孙玉姣小猴儿露了手脚。 此一番到她家细细问过， 看丫头对我说些什么。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘媒婆下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣上。"
        },
        {
          "character": "孙玉姣",
          "type": "西皮摇板",
          "text": "母亲一去不回转， 倒叫奴家挂心间。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘媒婆上。"
        },
        {
          "character": "刘媒婆",
          "type": "西皮摇板",
          "text": "今晨起在家中并未用饭， 贪看了他二人目送眉传。 迈步儿转过了孙家庄院， 到门首我急忙手扣门环。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "开门来。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "是哪一个？"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "连你刘妈妈的声音，都听不出来了么？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "原来是刘妈妈到，待我开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣藏镯，戴镯，开门。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "快点儿。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "刘妈妈来了，请到家中。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "你母亲呐？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "我母亲到前村听经去了。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "那么家里头，就剩了你一个人啦？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "你妈可到真放心。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "妈妈请坐。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "坐着。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "妈妈你可用茶，待我与你泡去。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "我不吃茶。我说你妈去听经去啦，把你一个人留在家中，她倒也真舍得。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "这有什么舍得舍不得。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "我说你妈不在家，你这脚是谁给你裹的？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "是我自己裹的。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "这头是谁给你梳的？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "这头也是我自己梳的。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "看见了，看见了。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "妈妈看见什么呀？"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "你胳膊上白花花明亮亮，是什么东西呀？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "这么，乃是一只玉镯。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "玉镯？你拿来，待我瞧瞧。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "妈妈请看。你要小心了。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "我知道，我比你还要经心呐。这只镯子真不错。想你贫寒人家，哪里来的这个 东西呀？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "这是我清晨起来，在门外捡得来的。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "捡来的？你可是真走红运哪。大清早起，一开门就捡一只玉镯。你妈妈天天东 庄跑到西庄，城里走到城外，连一个小铜钱都捡不着。我看这镯子不是捡的吧， 只怕是有情人送与你的吧。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "呸。好一个刘妈妈，你到此处，我将你让到家中，我母亲不在家，你口出恶言， 是何道理？你快与我滚出去吧。我把你个老臭毴。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "哈哈，她倒翻啦。你当我全不知道吓？你且听了！"
        },
        {
          "character": "刘媒婆",
          "type": "西皮原板",
          "text": "小傅朋今晨起闲来游玩， 他无故来到了孙家庄前。 你二人见了面传眉送眼， 他故意将玉镯丢在门前。 那时节你开门伸手去捡，"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "我学你那个样儿：你一开门，东一望，西一张，脚底踏着镯子啦。拿到手里一 看，那傅朋可就回来啦。你赶紧把镯子放在地下，你假装赶鸡子的样式，就这 么呕哧，呕哧。等他同你说了话之后，把镯子就送与你。你不肯要他，把镯子 仍旧放在地下，这才拾起来戴上，你说对不对？"
        },
        {
          "character": "刘媒婆",
          "type": "西皮摇板",
          "text": "这件事你休要把老娘来瞒。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "你可真是气死我啦，我把你个小骚毴。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "刘妈妈。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "刘妈妈？庄里庄外，谁不知道我刘妈妈，要你叫我刘妈妈。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "刘大娘。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "刘大娘？刘二娘哪。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "刘妈妈呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣哭跪。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "我方才说的是不是，摇头不算点头算。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣点头。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "我学的一点儿也不错吧。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "你起来吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣起。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣跪。"
        },
        {
          "character": "刘媒婆",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "起来吧，妈妈同你闹着玩哪。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "妈妈既然看见，还要求妈妈与我做主。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "这个不难。他既是送了你玉镯，你也要拿一样东西送他才行。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "想我这贫寒人家，哪有什么送他？"
        },
        {
          "character": "刘媒婆",
