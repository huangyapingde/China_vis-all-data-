{
  "script_id": "01035002",
  "title": "徐母骂曹",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "徐母",
      "hangdang": "老旦"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "程昱",
      "hangdang": "老生"
    }
  ],
  "plot": "曹操欲得徐庶，知其改名单福，在刘备处佐理军务。知非干旌所可召，因用程昱计：遣一家将，先密赚徐母\n至，令其作书招徐庶，则徐庶奉母素孝，断无不来之理。谁知徐母深明大义，初时虽被赚，既至曹操处，窥\n破奸情，坚不允招，且反将曹操指鼻痛骂，飞砚相击。曹操大怒，欲杀之。徐母大笑，毫不畏惧，盖徐母意\n本欲觅死，以坚徐庶佐刘备之心耳。讵又为程昱所劝阻，自后遂殷勤相待，卒被程昱用计套去笔迹也。",
  "notes": "《徐母骂曹》一剧，为老旦角色唱、做、说白三者俱不易之戏，为京伶龚云甫从前拿手杰作。坤伶苗鑫如于\n此剧亦深得龚派三昧。陈善甫自改唱老旦以来，此剧亦颇擅长。大错编撰戏考将十年，久欲购求此脚本而不\n得。本考中虽亦会于他剧脚本内附见之，然终非专剧，故不敢谬自引重。兹从龚之琴师处假得真本，真连城\n璧不啻也。剧中事实，全出《三国演义》。\n此剧先二黄，后转高腔，唱工既重，而骂曹时之说白做工，必须手口相应，尤为不易。往岁见云甫唱此，听\n其道白，说至“世之牧夫、樵子”一长句，及骂曹至“三尺童子无不思食汝之肉”\n等数句，又煞尾“你真名教中之罪人”\n二句，一字紧一字，咬字既准，口齿又清，全神贯注，真所谓慷慨激昂也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四曹将、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "执掌威权，收天下，文武英贤。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "汉室江山气运终，群雄四力各争锋。老夫坐镇许昌地，搜罗天下众英雄。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫，曹操，汉室为臣。只因曹仁、李典失守樊城，闻得刘备军中有一单福策 划。不免请仲德进帐，问明来历。 来，请程谋士进帐。"
        },
        {
          "character": "四曹将",
          "type": "同白",
          "text": "请程谋士进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱上。"
        },
        {
          "character": "程昱",
          "type": "念",
          "text": "胸藏五典三略理，袖吞提兵调将才。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生少礼请坐。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "谢坐。唤卑人进帐，有何军情？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "闻得刘备军中有一单福划策，先生可知单福何人也？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相听禀！"
        },
        {
          "character": "程昱",
          "type": "二黄原板",
          "text": "单福家住在颖州， 其中必有细根由。 字表元直徐门后， 单名徐庶有名头。 如今落在刘备手。 丞相兴兵要神留。"
        },
        {
          "character": "曹操",
          "type": "二黄原板",
          "text": "程昱比他差八九， 丞相我怜才早设计谋。 既与玄徳为好友， 要想收他我也无计求。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此人既与刘备相投，恐无外人能下手，真乃可惜了！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相有心要用此人，却也不难。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "卑人素闻徐庶极孝。只消丞相差人，将徐母赚至许昌，令其修书元直，谅无不 来之理。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此计甚好。后堂摆宴，与先生同饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "引子",
          "text": "闷坐草堂，自凄凉，怎不惨伤！"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "大儿四海访良朋，次子一命赴幽冥。可叹老身无伺奉，凄凉孤苦在家中。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身徐庶之母。所生二个孩儿：长子徐庶，在外访友；次子徐广，不幸身亡。 撇下老身，独守家中，好不伤感人也！"
        },
        {
          "character": "徐母",
          "type": "二黄正板",
          "text": "老身生来命不强， 不幸中年居了孀。 不盼我儿归家往， 但盼我儿把名扬。 生养二字全不讲， 怕人说我教子无义方。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "丞相差我颍州往， 迎接徐母进许昌。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "俺，曹府家将是也。奉丞相之命，迎接徐庶之母进京。就此马上加鞭。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "催马加鞭朝前闯， 抬头只见一村庄。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "借问一声：此地可有个徐老太太？"
        },
        {
          "character": "路人",
          "type": "内白",
          "text": "哪个徐老太太？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "徐庶、徐广之母，徐老太太。"
        },
        {
          "character": "路人",
          "type": "内白",
          "text": "前面黒漆门楼就是。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "多谢多谢。 来此已是。 徐老太太开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "门外有人把话讲， 莫非徐庶转回乡？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母开门。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你是哪里来的？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "京都来的。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "到此作甚？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "奉了我家主人，迎接徐老太太进京。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你可认识？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "不相认。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身正是。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "原来是徐太太，小人扣头！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "不消。你奉何人所差？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "小人奉程大老爷与徐大老爷所差。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程大老爷他是何人？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "我家老爷姓程名昱，与徐大老爷同殿为官，结拜弟兄。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "他二人官居何职？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "俱是议郎。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "因何接我进京。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "二位老爷，闻听徐二老爷亡故，恐老太太无人伺奉，特差小人接老太太进京， 同享荣华。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "可有书信？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "无有。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "为何无有书信？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "官差荣耀，修书不及。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "如此备车轮伺候。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "我儿官居为议郎， 迎接老身进许昌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "门前备下车一轮， 有请太太上京城。"
        },
        {
          "character": "徐母",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "家将引路将车上， 想起徐广两泪汪。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "哎呀儿吓！你哥哥接为娘进京，同享荣华，你是怎的不来？徐广苦命儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、家将同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "曹操",
          "type": "内西皮导板",
          "text": "汉室衰微天地荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四曹将、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "各路烟尘起四方。 老夫时刻将士访， 但愿徐母到许昌。 将身且坐二堂上， 这就是水旺求土日夜忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "相府门前住车轮， 见了丞相说分明。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "丞相在上，小人叩头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "徐母可曾接到？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "现在府外。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命众将前去迎接。"
        },
        {
          "character": "四曹将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四曹将同下。"
        },
        {
          "character": "徐母",
          "type": "内西皮导板",
          "text": "来在门前下车轮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、四曹将同上，四曹将同扯四门。"
        },
        {
          "character": "徐母",
          "type": "西皮原板",
          "text": "我与丞相无来往， 迎接老身为哪桩？"
        },
        {
          "character": "四曹将",
          "type": "同白",
          "text": "丞相有大事相商。"
        },
        {
          "character": "徐母",
          "type": "西皮原板",
          "text": "众将带路朝前往，"
        },
        {
          "character": "四曹将",
          "type": "同白",
          "text": "太夫人到！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "迈步且把二堂上， 见了丞相说端详。"
        },
        {
          "character": "四曹将",
          "type": "同白",
          "text": "徐母到！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "四曹将",
          "type": "同白",
          "text": "有请！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "丞相在上，老身万福。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人少礼。请坐。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人一路之上，多受风霜。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "承问。请问丞相，我儿徐庶往哪里去了？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "现在新野，太夫人修书将他招回。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我儿在新野依佐何人？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "在新野扶助刘备，如玉陷于泥花之中。太夫人将他召回，奏知天子必有封赠也。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "太夫人修书将他召， 官封列位在群僚。 人来奉过文房宝，"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "这事其中有蹊跷。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我闻家将言道：我儿在朝，官居议郎之职。如今又命我修书召他，其中是何道 理？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恐太夫人不允前来，故言在京为官，以安太夫人之心。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "原来你等用的鬼计。丞相，你可知道刘备是何等人物？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "他乃涿县小辈，妄称皇叔。所谓外君子内小人也！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "老夫暗把美言讲， 莫把恩人当鬼殃。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "听他言来怒满腔， 才知就你鬼计殃。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹丞相此言差矣！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身久闻刘备乃中山靖王之后，屈身下士，恭己待人。义气传于四方，仁声闻 于天下。世之牧夫、樵子、黄童、白叟无不称他为仁人君子，真乃当世英雄。 我儿辅之，如鱼龙得水，际遇风云，事得其主矣。汝托汉天子洪福，名为汉相， 实为汉贼。内怀谋朝篡位之心，外逞欺主专权之意。汉都迁驾，流离百姓。 许田打围，众官无不痛恨。辱祢衡为鼓吏，逼死贵妃，甄氏霸为儿媳，种种忤 逆，三尺童子，无不思食尔之肉、割尔之心、碎尔之骨。你反以玄德为逆臣， 欲使我儿，弃明投暗，不知自耻。曹操吓曹操！你真名教中之罪人，衣冠中之 禽兽也！"
        },
        {
          "character": "徐母",
          "type": "西皮二六板",
          "text": "刘备本是英雄將， 义气仁声起四方。 尔是曹嵩亲抱养， 夏侯族中抛去娘。 明明在朝为首相， 内怀篡位乱朝纲。 许田打围欺主上， 无故逼都迁许昌。 你比当年贼王莽， 你比董卓更猖狂。 欲使我儿归你掌， 除非日出在西方。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "相府如同刑口样， 霎时教你一命亡！"
        },
        {
          "character": "徐母",
          "type": "西皮快板",
          "text": "听他言来怒洋洋， 骂声奸贼听端详。 老身既来不思往， 你拿虎口吓老娘！ 文房四宝案桌放，"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "击死奸贼赴无常！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "反了吓！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "人来与我上了绑， 推出斩首在云阳。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大胆恶妇，敢掌打老夫！武士推出斩去了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母背下。程昱上。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "将身且把二堂上， 见了丞相说端详。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相因何将徐母斩首？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恶妇百般叫骂，故而她他斩首。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "斩了徐母，恐大事不利。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相若将她斩首，她子徐庶在彼，闻听此事，必然尽心相助刘备。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "将她放回，派人侍奉，每日伺候。套她笔迹修书，差人送至新野。徐庶乃是大 孝之人，必定随书前来。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此计甚好。 来，将徐母放回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "欲借曹操帐中刀， 全我半世美名标。 忽听前堂赦言到， 倒叫老身心内焦。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹操要杀，就该开刀。为何又将老身放回？真真岂有此理！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "非是老夫不斩与你，程先生言到他与你子有八拜之交。斩了你，如斩他母一般， 故而放回。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程先生为何多事？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母吓！"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "我与元直曾交好， 岂肯伯母吃一刀。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "先生只管将我保， 我儿新野住不牢。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生将徐母小心伺候。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "久闻曹操多奸诈，今日一见果不差。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母随小侄来吓！"
        },
        {
          "character": "程昱",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、程昱同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
