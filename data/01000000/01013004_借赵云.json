{
  "script_id": "01013004",
  "title": "借赵云",
  "alias": [
    "一将难求"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "公孙瓒",
      "hangdang": "末"
    },
    {
      "name": "典韦",
      "hangdang": "净"
    }
  ],
  "plot": "据戏中情节，为曹操攻夺徐州，徐州陶谦乞援于刘备，刘备既欲往救，然又自知寡不敌众，因向公孙瓒处借\n兵，并求借赵云一用。盖刘备于磐河之役，一见子龙，久已倾倒赏识，故此次竟指名往借。公孙瓒乃允令同\n往，并拨与马步三千。刘备既归，张飞见之不服，屡屡出言轻慢，幸刘备一再道歉，劝赵云勿介介于心。适\n曹操令典韦索战，张飞大败，赵云不忍坐视，乃出与典韦对阵，一战即将典韦杀败，张飞始自知不及，自后\n遂佩服赵云不置云。",
  "notes": "《借赵云》系出《三国演义》第十一回，“刘皇叔北海救孔融”一役之中。然考演义中，则不过略一提及借\n赵之事，并无张飞不服，及战败典韦等事实，此盖编剧者因拾得好题目，然本题实无文章可做，故借用他处\n文章，以为题目点缀耳，不能谓其拉杂抄袭也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "千军容易得，一将最难求。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "俺，刘备。只因曹操，带领十万雄兵，攻打徐州，要与他父曹嵩报仇，那陶谦 向吾求救，怎奈我兵微将寡，恐难取胜。是我去至北邳，公孙瓒那里借将。看 前面不远，就此马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。刘备下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军、公孙瓒同上。"
        },
        {
          "character": "公孙瓒",
          "type": "念",
          "text": "辕门战鼓响，儿郎报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报，刘使君到。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。刘备上。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "未知贤弟驾到，有失远迎，面前恕罪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备来的鲁莽，仁兄海涵。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "贤弟驾到，必有所为。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "今有曹操，因张闿杀死他父曹嵩，他就赖在陶谦的身上，因此带领十万人马， 攻打徐州，要与他父报仇。陶谦向弟借兵相助，怎奈备兵微将少，皆非典韦对 手。是以到此，与仁兄借兵三千，借将一员。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "原来如此。 来，"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "命赵云带领三千人马，随同刘使君，同往徐州解围。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。 下面听者，元帅有令：命赵云带领三千人马，随刘使君同往徐州。"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "得令。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "备得有酒，与贤弟痛饮。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "徐州危在旦夕，备不敢久停，告辞了。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "多蒙仁兄恩量宽， 借兵三千将一员。 辞别仁兄跨走战， 哪怕典韦小儿男。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "公孙瓒",
          "type": "西皮摇板",
          "text": "人来与爷把门掩， 怕的是刘玄德借将不还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、赵云、刘备分上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "久闻大名，如雷贯耳，今日一见，果然名不虚传。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云有何德能，敢劳使君称赞。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "但不知将军，几时起兵？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "即刻起程。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好，将军可命人马前行，你我马上，缓缓而行，以慰平时渴慕。不知赵将军， 意下如何？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "好。 众将官，人马先行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套、上手分下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赵将军，你看当今之时，天下大乱，汉室衰微，众诸侯各据一方，争雄赌胜， 日后不知何人成王立帝，重整汉室基业？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "想俺赵云，生性蠢笨，乃是草野愚夫，日后成王立帝，是哪一家，使君必有高 见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赵将军，备倒想起一人来了：想公孙瓒，乃是汉室功臣，足智有谋，又有赵将 军辅助，日后成王霸业，莫非就是此人了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "吓，使君，想我主公孙瓒，性情高傲，不纳忠言，日后断难成其大事，他只怕 不能。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "他不能。呵，备又想起一家来了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "是哪一家？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "想那袁术，占据寿春，兵多将勇，又有纪灵、桥藐，勇冠三军，日后或者是此 人了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "想那袁术，优柔寡断，生性矫情，虽有桥藐、纪灵等，皆是一勇之夫，焉能成 其大事？袁术他不能。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "他不能。备又想起一人来了：想河北袁绍，四世三公，谋士有田丰、沮受、逢 纪、郭图等，武有颜良、文丑之辈，日后汉室基业，定属此人了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "想那袁绍，昏庸老悖，犹豫多疑，帐下谋士，互相猜忌，自行残害，袁绍他也 不能。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "袁绍也不能。备又想起一人来了：想那荆襄王刘表，坐镇荆州，据有长江之险， 统属一十三郡，兵精粮足，日后定能称王霸业的了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "那刘表，虽是汉胄，坐镇荆襄，怎奈他无勇无谋，焉能有此大志？刘表他不能。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "如此看来，天下竟无人了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "眼前倒有一人，日后定能成王立帝。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备倒明白了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "明白何来？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "想赵将军，英雄盖世，智勇双全，日后天下，定是赵将军的了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云有何德能，敢设此妄想？刘使君乃是中山靖王之后，汉室宗亲，盖世英雄， 又有关、张辅助，日后天下，定是使君的了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备乃是困水蛟龙，陷阱猛虎，圣人云：“有美玉于斯，韫匵而藏诸？求善贾而 沽诸？沽之哉！我待贾者也。”正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "天上无云难下雨。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "掌中无剑怎杀人。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "低头不语恨苍穹，"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "刘备身旁少英雄。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "你好比红日撑空亮，"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "你好比皓月在当空。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、赵云同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "大哥去借兵，未见转回程。"
        },
        {
          "character": "中军",
          "type": "内白",
          "text": "刘使君到。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。刘备上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥回来了，你辛苦了，请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。四龙套、四上手同上，同下。赵云上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "吓，三将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞背面。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "咳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且住，我道大哥，此番借兵，定必是天神的一般，不料是一个黄毛孺子！嘿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、刘备、赵云、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥此番前去，但不知兵借了多少，这将有几员？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "此番借得兵马三千，大将一员。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "这将在哪里？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "就是赵将军。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥，想那典韦，是何等英雄。似这等黄毛孺子，慢说是交锋打仗，就是吓也 将他吓死了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "休得胡言，后帐去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，赵将军，想吾那三弟张翼德，乃是鲁莽之夫，言语傲慢，备这厢赔罪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云怒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备，这厢有礼了，请至后面痛饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、刘备同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四下手、典韦同上。"
        },
        {
          "character": "典韦",
          "type": "念",
          "text": "奉了丞相令，攻打徐州城。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "众将官，杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备、张飞、赵云同上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "辕门旌旗起，儿郎报端的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "典韦讨战。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待俺老张会他一阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下，刘备下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "且住，看刘备之弟张飞，藐视于我，不免人马转回北邳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赵将军，我三弟万分粗鲁，言语冒犯，休得见怪，备这里有礼了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、赵云同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "典韦、张飞同上。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "张飞，昨日饶尔不死，今日又来作甚？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吃你三老子一鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "典韦、张飞开打。张飞上桌子。赵云上，开打，典韦下，赵云追下。典韦上。"
        },
        {
          "character": "典韦",
          "type": "白",
          "text": "赵云杀法厉害，收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。张飞下桌子。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "赵云是个好的，好的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备、赵云同上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "后堂排宴，与将军庆功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}