{
  "script_id": "01023004",
  "title": "三击掌",
  "alias": [
    "宝钏出府"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "王允",
      "hangdang": "外"
    }
  ],
  "plot": "王允之女王宝钏，自抛彩球择定丐薛平贵为夫之后，其父大以为辱，不允嫁薛平贵，而王宝钏偏立志欲从之。\n王允遂逐薛平贵出。王宝钏愤极，宁拔去钗饰，出从薛平贵居寒窑，其父更怒极，竟不齿王宝钏。王宝钏\n临行，与其父三击掌为誓，谓不富贵不再入父门。其母夫人虽再三从中解释，而王宝钏志甚决，竟一去不顾，\n其母亦无如之何。",
  "notes": "此后本即《探寒窑》，均为《彩楼记》中戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王允上。"
        },
        {
          "character": "王允",
          "type": "引子",
          "text": "调和鼎鼐，位列三台。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "老夫，王允。唐室驾前为臣，官拜当朝首相，夫人陈氏，膝下无儿，所生三女： 长女金钏，匹配苏龙；次女银钏，匹配魏虎；只有三女宝钏，尚未婚配。本 月二日，曾在十字街前，高搭彩楼，抛球招赘。吾只道打着哪家王孙公子，不 料打着了花郎薛平贵。想吾儿乃是千金之体，怎能与那花郎匹配，不免将女儿 唤出。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "将这门亲事打退，另配王孙公子，免得耽误吾儿终身。 家院，后堂传话：请三姑娘出堂。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "后堂传话：请三姑娘出堂。"
        },
        {
          "character": "丫鬟",
          "type": "内白",
          "text": "请三姑娘。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、丫鬟同上。"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "十字街前搭彩楼，为招夫婿抛彩球。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹万福。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "吾儿少礼，一旁坐下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "谢坐。爹爹唤女儿出来，有何训教？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "吾儿在十字街前，抛球招赘，可知打的哪家王孙公子？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "孩儿不知。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "就是那花郎平贵。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "也是儿命该如此。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "依为父之见，莫若将此门亲事打退，另配王孙公子。不知吾儿，意下如何？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹说哪里话来，想孩儿既然抛球招赘，就是凭天所定。今日慢说是打着花郎 平贵，就是打着一块顽石，孩儿也要抱……"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "抱什么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "抱他三年五载，以表恩爱之情。 丫鬟，打坐向前！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "为父与你讲话，敢是同为父赌气？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "孩儿焉敢与爹爹赌气。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "既然不是与为父赌气，就该退去此门亲事。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "慢说是爹爹之命，就是皇王旨意，也难更改。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿就该掌嘴！"
        },
        {
          "character": "王允",
          "type": "西皮慢板",
          "text": "小奴才说此话全然不想， 不由得年迈人怒满胸膛。 你大姐配苏龙户部执掌， 你二姐配魏虎兵部侍郎。 惟有你小冤家性情倔强， 千金女配花郎怎度时光？"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "老爹爹说此话全不思想， 细听着孩儿说端详： 秦甘罗一十二身为宰相， 姜子牙八十二才遇文王。 你莫道薛平贵他花郎模样， 贫穷人发迹比富还强。"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "薛平贵生来命运低， 每日里在长街去讨食。 半截褴衫罩不住身体， 遮住东来露着西。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "昔日里有一个孟姜女， 他与那范郎送寒衣。 哭倒了长城十数里， 至今留名万古题。"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "前朝事儿——"
        },
        {
          "character": "王允",
          "type": "西皮流水板",
          "text": "休提起， 千金怎为花郎妻？"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "昔日韩信曾受困， 登台拜帅落美名。"
        },
        {
          "character": "王允",
          "type": "西皮流水板",
          "text": "既知前朝韩元帅， 未央宫死的是什么人？"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "未央宫死的是韩信， 可知那张良与苏秦？"
        },
        {
          "character": "王允",
          "type": "西皮流水板",
          "text": "沈宏也会把亲退， 另配姻缘为何情？"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "沈宏虽然把亲退， 他乃是不义不肖人。"
        },
        {
          "character": "王允",
          "type": "西皮流水板",
          "text": "要退要退偏要退，"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "你不能不能万不能。"
        },
        {
          "character": "王允",
          "type": "西皮流水板",
          "text": "两件宝衣来脱下，"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "再与爹爹把话明。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "请问爹爹，这两件宝衣，是哪里来的？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "乃是圣上所赐。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "圣上所赐，但不知为着何来？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "不过是念在君臣之意。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "好吓！圣上倒有君臣之意，难道爹爹，就无有父女之情了么？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "吾儿将这门亲事打退，慢说这两件宝衣，就是府内的金银，也任儿搬取。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "孩儿不要了。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "老爹爹不念父女意， 孩儿焉有儿女情？ 忙把宝衣齐脱下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏脱宫装，捧衣看，掷与王允。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "递于嫌贫爱富人。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿吓，为父嫌贫爱富，爱的是哪一个？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "孩儿不知。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "为的就是你这个奴才呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "爹爹不必把儿为， 孩儿不做那无义人。 三从四德是本分， 怎敢爱富来嫌贫。 要与爹爹三击掌， 从今后不登相府门。"
        },
        {
          "character": "王允",
          "type": "西皮摇板",
          "text": "宝钏说话太无情， 到叫老夫怒生嗔。 今日与吾三击掌， 从今后就断了父女情。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "非是孩儿心太狠， 只为不贤留骂名。 悲切切我这里三击掌，"
        },
        {
          "character": "王允",
          "type": "西皮摇板",
          "text": "活活气坏了年迈人。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "叫丫鬟带路后堂进，"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "你往哪里去？"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "到后堂拜别老娘亲。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "丫鬟好好把守庭堂，若有人去往后堂，定要打断尔的狗腿！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "孩儿不去了。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "老爹爹不许吾把老娘见， 倒叫宝钏痛在心。 含悲忍泪出府门，"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "三姑娘要往哪里去？"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "去到寒窑中把身存。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我们实实舍不得三姑娘。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你们舍不得三姑娘，你三姑娘是怎么舍得了你们？"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "这丫鬟们她倒有主仆义， 恋恋不舍两泪淋。 咬定牙关出相府，"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "送三姑娘。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "到破瓦寒窑中暂度光阴。"
        },
        {
          "character": "王宝钏",
          "type": "三叫头",
          "text": "老娘，母亲，娘吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "三姑娘出府去了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "奴才呀！"
        },
        {
          "character": "王允",
          "type": "西皮摇板",
          "text": "为人养子如养花， 生儿莫养女娇娃。 当面孝顺背地里骂， 女生外相向人家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}