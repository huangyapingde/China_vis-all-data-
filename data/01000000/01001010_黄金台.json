        {
          "character": "田单",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "田单",
          "type": "二黄摇板",
          "text": "背地里只把那伊立埋怨， 平白地害幼主所为哪般？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "今有伊公公带领许多校尉，前来搜府。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "再去打听！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院允，下。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哎呀，千岁，今有伊立带领许多校尉，前来搜寻殿下。这便如何是好？"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "哎呀，卿家，你要救我一救！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哎呀，千岁，事到如今，并无别计：千岁扮做小妹模样，等那奸贼到来，混过 一时，再作道理。"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "小王乃金枝玉叶，岂扮那妇人模样！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哎呀，千岁，事到如今，讲什么“金枝玉叶”？龙驾要紧！乳娘，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘允。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "与千岁改扮起来！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田法章、乳娘同下。"
        },
        {
          "character": "田单",
          "type": "二黄导板",
          "text": "水不清皆因是鱼儿搅混，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同上，过场。伊立上。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "呔，马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伊立过场，下。四校尉同下。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "田单",
          "type": "二黄摇板",
          "text": "我朝中又出了卖国的奸臣！ 施一礼我把千岁爷的驾请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田法章、乳娘同上。"
        },
        {
          "character": "田法章",
          "type": "二黄摇板",
          "text": "金枝玉叶扮妇人。"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "卿家，看小王扮得可像？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "千岁扮得倒像，可晓得妇人家行走？"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "这倒不晓得妇人家行走。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "乳娘教导千岁。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是。啊，千岁，妇人行走，必须要这样走。"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "哦，妇人行走，必须要这样走。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哦，啊，照照照！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "伊公公驾到！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田法章、乳娘同下。四校尉、伊立同上。"
        },
        {
          "character": "伊立",
          "type": "二黄摇板",
          "text": "御史衙前下了马，"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "公公请进！"
        },
        {
          "character": "伊立",
          "type": "二黄摇板",
          "text": "有劳大人相迎咱。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "公公请坐。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "请。田大人这作什么？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "与公公挡坐。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "这就不敢！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "当得的！"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "这就不敢，吓！"
        },
        {
          "character": "田单、伊立",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "公公这作什么？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "与田大人挡坐。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "这就不敢！"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "当得的！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "这就不敢，吓！"
        },
        {
          "character": "田单、伊立",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "不知公公驾到，未曾远迎，当面恕罪！"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "岂敢，岂敢。咱家来的鲁莽，望田大人恕过罪罢！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "岂敢那岂敢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同喊。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "啊，公公，这夜静更深，带领许多校尉，来到敝衙，有何公干？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "怎么着，这桩事情，你还不知道么？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "倒也不知。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "既然不知，待咱家慢慢的告诉于你。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "公公请讲。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "今有东宫世子田法章，人伦大变，子淫父妃。大王大怒，赐咱家宝剑一口，三 更时分，斩杀回奏。也不知何人走漏了消息，将世子放走。咱家二次启奏大王， 大王赐咱家校尉四十名，各府搜寻。各府俱已搜到没有。我想那世子他定藏 在你府！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "啊，公公，既是千岁犯罪，你我为大臣者，就该上殿保奏才是。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "咱家连保数本，大王不准，那也是枉然。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哦，公公保过本了。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "保过许多的呢！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "也罢，待下官明日亲自私访。有了千岁的下落献于公公，这桩事也就完了！"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "田大人，你这话不是这么说。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "要怎么的讲？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "我想那世子定在你府，你将他献将出来，保你无事，那也就完了！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哈哈哈，多蒙公公美意。我想世子他……"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "怎么着？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "不在敝府。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "当真不在你府？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "当真不在。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "果然不在？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "果然不在。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "田大人你这儿来。你说世子不在你府，咱家就要……"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "你要怎么？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "我就要搜！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "公公你当真要搜？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "当真要搜。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "果然要搜？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "果然要搜。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "请搜！"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "校尉的与我搜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同允。四校尉两边搜。田法章、乳娘同上。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有两个妇人。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "起过了。田大人，你说世子不在你府，任我亲自一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伊立亮架子。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "那两个妇人她是谁？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哈哈哈，我道是谁，原来是小妹同乳娘，乳娘同小妹。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "怎么着，田姑娘么？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "不敢，小妹。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "请过来，咱家见过礼吧！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "小妹礼貌不周，冲撞公公，那还了得，不见也罢。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "见见何妨？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "不见也罢。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "我一定要见！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "当真要见？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "当真要见！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "就见！"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "这不结了么！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "乳娘搀扶小妹，见过伊公公。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "待我看她行走如何。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "是，姑娘有礼。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "咱家还礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田法章、乳娘同下。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "且住，我想那世子上了天？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "天高只怕上不去。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "他入了地？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "地原无门，只怕下不去。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "他往哪里去了呢？"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "照吓，他往哪里去了？"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "哦呵，有了。不免回去多讨校尉，再来搜寻。田大人，咱家清晨起来，吃了几 杯早酒，言语得罪大人。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "冒犯大人。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "越发的不敢。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "告辞了。"
        },
        {
          "character": "伊立",
          "type": "二黄摇板",
          "text": "辞别大人把马跨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同带马，同下。"
        },
        {
          "character": "伊立",
          "type": "二黄摇板",
          "text": "多讨校尉再搜查。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "送公公。"
        },
        {
          "character": "伊立",
          "type": "三笑",
          "text": "哈哈，哈哈，哈哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伊立下。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "田单",
          "type": "二黄摇板",
          "text": "狗奸贼发了怒令人害怕， 倘若是漏机关就把头杀。 二次里走上前急忙接驾，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田法章、乳娘同上。"
        },
        {
          "character": "田法章",
          "type": "二黄摇板",
          "text": "再与卿家把话答。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哎呀千岁，那贼临行言道：还要多讨校尉，前来搜寻殿下。这便如何是好？"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "卿家你还要救我一救！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "哎呀，千岁，你我君臣扮作烧香还愿之人，诈出皇城，再作道理。"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "此计甚好！"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "改扮起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田单、田法章同换行头。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "乳娘，这有官宝一锭，逃回原郡去吧！"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "卿家带马。"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田单带马。"
        },
        {
          "character": "田法章",
          "type": "白",
          "text": "卿……"
        },
        {
          "character": "田单",
          "type": "白",
          "text": "静声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田单、田法章同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}