{
  "script_id": "01013006",
  "title": "奇冤报",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘世昌",
      "hangdang": "老生"
    },
    {
      "name": "赵大",
      "hangdang": "丑"
    },
    {
      "name": "赵妻",
      "hangdang": "彩旦"
    },
    {
      "name": "刘升",
      "hangdang": "丑"
    },
    {
      "name": "判官",
      "hangdang": "净"
    }
  ],
  "plot": "考四川华阳县缎商刘世昌，贩缎出门三年，方作归计，主仆行至定远县境，因遇雨，投宿于赵大瓦窑中。赵\n大见其行李甚重，带有巨款，遂即起意谋害，下毒于食中。刘世昌主仆，于是均遭非命。至次日，夫妻二人\n将二尸捣成肉浆，和入泥中，烧成瓦盆，以灭形迹，可称神鬼不知。直待数年后，张别古见其家顿富，往索\n前欠，其案方明云。",
  "notes": "近来所演《乌盆计》，多仅演《瓦盆诉冤》一段，从张别古出场向赵大索债做起，未见有演全本者。良以此\n剧唱工本以盆鬼说话告状之一幕为重，故时流往往节演。然前本刘世昌主仆，为赵大毒害时，其做工亦颇吃\n重，即唱工亦不甚轻，此曲本即其前本也。从前叫天演此，每演全本，贵俊卿亦仿谭派全演，其毒发时，从\n桌上滚下之惨状，颇足动人。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "念",
          "text": "越热越出汗，越冷越打颤。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我，赵大的便是，在这定远县东大洼居住。不幸父母双亡，是我夫妻二人，烧 窑度日。这些日子，买卖不好，不免将老婆唤出，做些个盆子罐子，烧烧，好 到集镇上去卖。 老婆哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻上。"
        },
        {
          "character": "赵妻",
          "type": "念",
          "text": "自幼儿在东庄居住，嫁了个汉子是窑户。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "我说当家的，叫我干什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我说这些日子，无有什么生意，叫你出来，咱们做点活儿，我好到集镇上去， 卖钱使用。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "言之有理，你我到后面去做活便了。"
        },
        {
          "character": "赵大",
          "type": "西皮摇板",
          "text": "夫妻二人把后窑进， 取点柴火烧瓦盆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、赵妻同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌上，刘升随上。"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "一日离家一日深， 好似孤雁宿寒林。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "卑人，刘世昌，乃四川华阳人氏。前奉母命，进京贩卖绸缎，是我主仆二人， 讨清帐目，转回家园。刘升，带路。"
        },
        {
          "character": "刘世昌",
          "type": "西皮原板",
          "text": "自从那年离乡井， 思会双亲常挂在心。 主仆贸易三年整， 讨清帐目转回家门。 走过了多少州县郡， 晓行夜宿马不留停。 一霎时乌云起天盖定，"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "倾盆大雨洒淋淋。 叫刘升与爷把路引， 寻找旅店把身存。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌、刘升同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众鬼同上，判官上，堆鬼，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌、刘升同上。"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "急急忙忙往前奔， 不觉来到一窑门。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "来此窑门，刘升上前言道，你我在此借宿一宵，明日早行。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "这我会。 我说有人么，走出一个来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "是谁呀？"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "我们要到你们这来睡觉啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你这小子，满嘴胡说八道！"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "什么小子？你才是小子呐！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "吓，大哥请了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "请啦，你们是干什么的？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "我乃行路之人，天降大雨，无有旅店，欲想在大哥处，借宿一宵，明日早行。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这才是会说话的呐。这个不要紧，请到窑里坐吧。我与你牵着马。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "这就不敢，请。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你看你们的衣裳，都淋湿啦，快脱下来，我与你晾晾吧。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有劳了。请问大哥尊姓大名？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "在下，姓赵，哥儿一个，人都叫我赵老大。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "原来是赵大哥。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "请问客人尊姓吓？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "卑人刘世昌，乃四川华阳县人氏。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "但不知作何买卖？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "贩卖绸缎为生。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "原来是大买卖。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "小本钱。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "好说好说。我说你们还没有吃饭吧？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "这……前途用过了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "得啦，得啦，哪用过？咱们都不是外人，我也没有什么好吃的，也不过粗菜粗 饭而已，等我与你烫酒去。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "慢着，我看这位客人，他行李里头，沉甸甸的，八成银子不少。我想我烧窑一 辈子，也发不了财，不免将他害死，这银子都是我的啦。就是这个主意，老婆 这来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻上。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "来了来了。当家的什么事？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "老婆，咱们要发财！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "发什么财？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "刚才来了二位客人，是一主一仆，乃是卖绸缎的大客商，他行李里头，全是银 子，我想把他害了，这银子都是咱们的啦！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "害人我可不会呀！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "别嚷，别嚷！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "你说害人，怎么个害法吓？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "他们没有吃饭呐，你与他安排点酒饭，我把酒里头，与他下上点耗子药，他们 吃了，不到一个时辰，管保他就跷缏子。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "这个，我倒能办得了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻下。赵妻托盘子上，下毒药，赵妻下。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "酒钣到啦，二位请用吧。来来来，我与你们斟上！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "刘世昌",
          "type": "西皮原板",
          "text": "好一个赵大哥多慷慨， 一霎时酒饭摆上来。 初次相逢承恩爱， 借宿一霄理不该。 明日里定要多谢拜， 昏昏沉沉倒卧在土台。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "看他二人已经醉啦，待我将门倒锁上，咱们明个见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大下。"
        },
        {
          "character": "刘世昌",
          "type": "西皮导板",
          "text": "时才朦胧将睡倒，"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "一霎时心中似火烧。 是是是来明白了， 中了赵大计笼牢。 回头便把刘升叫， 奴才一命赴阴曹。 眼望着华阳县高声叫， 爹娘吓！ 一命定然赴阴曹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌死。"
        },
        {
          "character": "刘升",
          "type": "西皮导板",
          "text": "时才间醉酒将合眼，"
        },
        {
          "character": "刘升",
          "type": "西皮摇板",
          "text": "我心中好似刀来穿。 是是是来我知道了， 中了他娘的巧机关！ 眼望着华阳县高声喊， 我的妈妈呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘升死。赵大、赵妻同上。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "天亮了，咱们去看看。没有什么动静，光景是死啦。待我开开门， 喝，两人死了一对。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "这两个死尸怎么办呐，抬出去埋了吧。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "不好，不好，倘若被人看见，那不是白做了活儿啦吗？有啦，有啦，咱们把他 二人尸首，剁成肉酱，和在泥里，烧成了盆子，就是神仙也不能找寻着！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "好，等我拿刀去。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "来，咱们动手吧！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "当家的，你看画上那个判官，他拿两个眼睛瞪我。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "他瞪你，待我把他的眼睛与他剜了去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大剜判官眼。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "得啦，咱们这可发财啦，赶紧叫泥瓦匠，先盖起房子来再说！正是："
        },
        {
          "character": "赵大",
          "type": "念",
          "text": "禹门三激浪，平地一声雷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、赵妻同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "判官上。"
        },
        {
          "character": "判官",
          "type": "念",
          "text": "天理昭彰不可欺，未从起意神先知，善恶到头终有报，只看来早与来迟。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "吾，判官是也，可恨赵大夫妇，图财害死刘世昌，又将吾神双目剜去，得我上 奏阎君，便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "判官下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}