{
  "script_id": "01001017",
  "title": "清官册",
  "alias": [
    "升官图；一名：提寇阴审"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "寇准",
      "hangdang": "老生"
    },
    {
      "name": "潘洪",
      "hangdang": "净"
    },
    {
      "name": "赵德芳",
      "hangdang": "小生"
    },
    {
      "name": "马牌子",
      "hangdang": "丑"
    },
    {
      "name": "夫人",
      "hangdang": "正旦"
    }
  ],
  "plot": "杨继业碰碑后，杨延昭进京告御状。金牌宣召寇准刻日进京，审问潘、杨二家之事。寇准本一县令，抵京后，\n潘妃贿以金帛。寇准直告八贤王，八贤王嘱以暂领贿金，留作证据。审问时潘洪欺寇准官卑职小，傲不为\n礼。寇准请过圣旨，潘洪始下跪。然口供一昧狡赖。",
  "notes": "此剧于寇准进京时，夜宿店中，左思右想，坐至天明，所唱一段二黄，调颇动听，入后则全系白口取神耳。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上，寇准上。"
        },
        {
          "character": "寇准",
          "type": "引子",
          "text": "做清官民之父母，积阴功留与儿孙。"
        },
        {
          "character": "寇准",
          "type": "念",
          "text": "读诗书智广才高，中状元青史名表。三杯御酒加封号，被谗臣一本参掉。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "下官寇准，蒙圣恩得中一甲一名，又被权相参掉。是我在吏部效力三载，除授 霞榖县正堂。到任以来，黎民倒也好训。今当三、六、九日，放告之期。左右 将放告牌抬出。"
        },
        {
          "character": "金牌官",
          "type": "内白",
          "text": "圣旨下。"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "圣旨下。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金牌官上。"
        },
        {
          "character": "金牌官",
          "type": "白",
          "text": "金牌下，寇准听者：圣上有旨调寇准连夜进京，不得有误。"
        },
        {
          "character": "金牌官",
          "type": "念",
          "text": "金牌如虎啸，"
        },
        {
          "character": "寇准",
          "type": "念",
          "text": "即刻便登程！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金牌官下。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同下，家院上。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夫人上。"
        },
        {
          "character": "夫人",
          "type": "念",
          "text": "夫受皇家禄，妻沾雨露恩。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "吓，老爷，"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "吓，夫人请坐。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "适才金牌到此，不知为了何事？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "金牌调我连夜进京，不知所为何事。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "想是老爷为官清正，加官受爵，也未可知。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "但愿如此。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "不知老爷几时起程？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "即刻起程。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "妾身备得有酒与老爷饯行。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "有劳夫人。看衣衾更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准换衣。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "马牌子走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌子上。"
        },
        {
          "character": "马牌子",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "老爷进京，命你备马二匹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌子允，下。"
        },
        {
          "character": "夫人",
          "type": "白",
          "text": "丫鬟看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟允。"
        },
        {
          "character": "夫人",
          "type": "二黄原板",
          "text": "叫丫鬟看过了酒一樽， 我与老爷来饯行。 但愿老爷早到京， 但愿得老爷步步高升。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "接过了夫人酒一樽， 背转身来谢神灵。 叫家院请右堂来护印， 你就说你老爷即刻登程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "夫人请上受一礼， 礼下还有所托情： 老母老母你孝顺， 早晚侍奉要殷勤。 辞别夫人跨金镫， 披星戴月奔帝京。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌子带马上，马牌下。寇准跨马，下。"
        },
        {
          "character": "夫人",
          "type": "二黄摇板",
          "text": "一见老爷足踏镫， 但愿老爷早回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夫人下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马牌子、家院、寇准同上，同走圆场。"
        },
        {
          "character": "寇准",
          "type": "二黄摇板",
          "text": "马蹄踏遍路旁草， 日落西山小桃红。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准下马。"
        },
        {
          "character": "马牌子",
          "type": "白",
          "text": "咳，这里有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驿丞官上。"
        },
        {
          "character": "驿丞官",
          "type": "白",
          "text": "什么人吵？"
        },
        {
          "character": "马牌子",
          "type": "白",
          "text": "我们跟寇老爷来的，安排什么地方？"
        },
        {
          "character": "驿丞官",
          "type": "白",
          "text": "你这么海外，你是什么人？"
        },
        {
          "character": "马牌子",
          "type": "白",
          "text": "我里里外外、上上下下一个马牌子！"
        },
        {
          "character": "驿丞官",
          "type": "白",
          "text": "哦，马牌子，认识我么？"
        },
        {
          "character": "马牌子",
          "type": "白",
          "text": "不认识。"
        },
        {
          "character": "驿丞官",
          "type": "白",
          "text": "我是驿丞官，单管你们马牌子！"
        },
        {
          "character": "马牌子",
          "type": "白",
          "text": "哎吓，上司老爷来了！带马遛了吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌子下。"
        },
        {
          "character": "驿丞官",
          "type": "白",
          "text": "滚下去吧！ 参见大老爷。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准、家院同进门。"
        },
        {
          "character": "驿丞官",
          "type": "白",
          "text": "老爷可用些什么？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "前途俱已用过，取明灯一盏。"
        },
        {
          "character": "驿丞官",
          "type": "白",
          "text": "老爷，明灯到。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "退下了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驿丞官允，下。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "家院，四更时官带伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院允，下。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "想我寇准，职授霞榖县令，上不亏君，下不亏民。金牌调我连夜进京，也不知 所为何事。今夜独宿馆驿，好不愁闷人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄慢板",
          "text": "一更一点月东升， 闷坐馆驿自思忖。 臣伴君好一似羊伴虎， 尽得忠来难把孝行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "二更二点月正明， 睡不安来坐不宁。 在霞榖并不曾亏负百姓， 金牌调我所为何情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "三更三点月照阶， 想起了霞榖县管万民。 早堂接状早堂审， 午堂接状审得清。 到晚来接下了无头状， 一盏红灯审到天明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院捧茶上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "请老爷更衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。寇准换衣。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "四更时分衣冠正， 叫一声家院听分明： 回家去与老爷送上一信， 一路之上莫要留停。 若是夫人来问你， 你就说你老爷平安到京。 倘若是太夫人来问你， 你就说你老爷已进京城，见万岁，一步一步，步步高升，请太夫人放心！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。寇准出驿。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "朝臣待漏五更尽， 铁甲将军夜渡津。 东华门乃是文官走， 西华门本是武将行。 有寇准也打从东华门进， 又听得两班内文武笑声。 是是是来明白了， 他笑我七品县令当今。 有志何在官大小， 无才枉受爵禄恩。 撩袍端带御街进， 品级台前口称臣。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "臣寇准见驾，吾皇万岁！"
        },
        {
          "character": "宋王",
          "type": "内白",
          "text": "卿家进京来了？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "臣进京来了。调臣进京所为何事？"
        },
        {
          "character": "宋王",
          "type": "内白",
          "text": "调卿进京非为别事，只为潘、杨二家官事命卿审问。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "一家太师之职，一家郡马之职，臣官卑职小，难以审问。"
        },
        {
          "character": "宋王",
          "type": "内白",
          "text": "外廉御史，加升西台御史；外赐圣旨一道。审明回奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳上，坐。太监捧圣旨上。"
        },
        {
          "character": "太监",
          "type": "念",
          "text": "金殿赐圣旨，"
        },
        {
          "character": "寇准",
          "type": "念",
          "text": "捧旨下龙庭。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "贤爷在此！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "参见八千岁。臣寇准见驾，念臣有圣旨在身，不能全礼，贤爷千岁！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "寇卿回京来了？我叔皇调卿进京所为何事？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "调臣进京，审问潘、杨二家官事。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "卿可知前任御史之事？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "臣却不知。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "只因他审问潘、杨二家官事，不明不白，被小王金锏打死！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "内侍回复御旨。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "且慢！卿家只管问。倘有不明之处，到我南清宫领教。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "臣领钧旨。"
        },
        {
          "character": "寇准",
          "type": "二黄摇板",
          "text": "八千岁做了主大胆审问， 哪怕潘洪是皇亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准下。"
        },
        {
          "character": "赵德芳",
          "type": "二黄摇板",
          "text": "好一个忠心小寇准， 七品县令审皇亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、马牌子、寇准同上。"
        },
        {
          "character": "寇准",
          "type": "二黄摇板",
          "text": "金殿之上奉圣命， 升迁西台审皇亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "衙役",
          "type": "内白",
          "text": "公公到！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "念",
          "text": "一封丹草诏，飞下九重霄。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "请旨！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "有请！公公驾到，未曾远迎，恕罪！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "恭喜寇老先生，贺喜寇老先生！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "七品县令升为西台御史，可喜可贺！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "公公提拔。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "潘、家二家官事，在贵衙审问么？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "在敝衙审问。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "后宫潘娘娘有份礼单，拿去看来！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "好一份厚礼！吓，公公此礼为何？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "后宫潘娘娘有句话嘱咐你：只要太师在，不要太师坏。你要动了他一根毫毛， 哥哥你这顶乌纱戴不牢了！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "王法森严，必须要照律而断！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "礼单收下！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "无功不受禄！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "受禄必有功！收下了好！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "不敢收！"
        },
        {
          "character": "太监",
          "type": "念",
          "text": "暂离西台地，"
        },
        {
