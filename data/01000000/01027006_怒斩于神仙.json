          "character": null,
          "type": "stage",
          "text": "于吉下。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "来，将柴草堆积台下。倘若无雨，将这妖道烧死。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同积柴堆。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "看天到什么时候了。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "午时了。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "天到午时。空中略有浓云，看这妖道，还敢欺人惑众。 来，将于吉搭在柴薪之上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同抬于吉坐柴上。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "天到什么时候了？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "午时三刻了。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "午时三刻已到，并不见有甘霖。来，将柴薪点起来，与我烧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火彩。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "好大雨呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四病人、老妇、少妇同跪拜于吉。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "你等如此被妖人所惑，想这晴雨乃天地之定数，妖人偶乘其便，以此搧惑愚民。 来，与我斩了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刽子手甲杀于吉，于吉下。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "将尸首号令市曹，以正妖妄之罪。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙母上。"
        },
        {
          "character": "孙母",
          "type": "唱",
          "text": "只因吾儿身染病， 倒叫老身挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "破曹之计心已定， 只为得病难出征。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "自从斩了于吉，不料这妖道，阴魂不散，夜夜缠绕于我。数月以来，身子十分 困倦。老母为此常常忧虑，我不免假装强壮，去见母亲便了。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "斩却于吉除妖妄， 他屡屡缠绕为哪桩？ 我抖擞精神做强壮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "于吉上。孙策退。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "免得老母挂心旁。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "参见母亲。"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "我儿，自从斩了于神仙，即得重病，但不知这几日病势如何？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "孩儿这几日病体痊愈，倒比从前强壮了。"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "我儿屈杀神仙，故招此祸。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "孩儿昔年随同吾父东荡西除，南征北战，也不知杀了多少人，并不曾有祸。今 日杀了妖人，正绝其祸，他怎能反来祸我？"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "儿不闻圣人云：鬼神之为德，其盛矣乎。这鬼神之事，不可不信。此郡之北， 有一玉清观，灵验非常，我儿去到那里，祷告神祗，自必转祸为福。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "嗳！母亲不须多言，孩儿夙来不信鬼神。"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "儿不听母言，殊非孝道。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "我儿快快前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙母下。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "我这里急忙出宫院，"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "又只见于吉在眼前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策把剑砍，于吉退下，孙策追下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、黄盖、张昭、朱治、程普同上。"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "今日主公，奉了太后之命玉清观拈香，我等在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "创业开基锦江山， 赫赫威名震东南。 人来同往玉清观，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "于吉上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "妖道竟敢把我缠！ 拔出龙泉将尔砍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "于吉抱刽子手甲，孙策杀刽子手甲。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "一阵昏迷为哪桩？"
        },
        {
          "character": "黄盖、张昭、朱治、程普",
          "type": "同白",
          "text": "杀错了！"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "杀错了？杀得是哪一个？"
        },
        {
          "character": "黄盖、张昭、朱治、程普",
          "type": "同白",
          "text": "杀得是前日杀于吉的刽子手。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "人来带马往前趱， 焚香顶礼告苍天。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "老道哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "道士上。"
        },
        {
          "character": "道士",
          "type": "白",
          "text": "叩见将军。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "香烛伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策拈香。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "香烟缭绕空中映，"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "又见妖道现身形。 怒气不息出观门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "于吉挡孙策。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "三番两次搅乱人。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "你等可曾看见妖道于吉么？"
        },
        {
          "character": "黄盖、张昭、朱治、程普",
          "type": "同白",
          "text": "我等不曾看见。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "想是这妖道阴魂在此观中藏躲。 来，将庙宇拆毁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同拆庙。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "人来带马回府门， 妖道怎能乱胡行？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大乔、孙母同上。"
        },
        {
          "character": "孙母",
          "type": "唱",
          "text": "我儿焚香未回转， 但愿疾病早安痊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "将身且上后堂道， 见了母亲说根苗。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "参见母亲！"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "哎呀儿啊！你这几日的形容越发憔悴了。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "怎么？孩儿形容憔悴了？"
        },
        {
          "character": "大乔",
          "type": "白",
          "text": "将军，你的形容不像人样了。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "俱道我形容憔悴了， 倒叫豪杰心内焦。 看过了菱花镜来瞧，"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "形容消瘦为哪条？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "我这形容为何落得到这般光景？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策举镜照。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "镜中又现出于妖道， 吾料今生命难逃！"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "吾料自今生性命难保矣！ 来，快请众将进帐。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "众将进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张昭、黄盖、程普、朱治、孙权同上。"
        },
        {
          "character": "张昭、黄盖、程普、朱治、孙权",
          "type": "同白",
          "text": "主公玉体如何？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "方今天下大乱，以我有吴越之众，三江之险，大有可为。吾今将死，望子布等 扶保吾弟。须要各尽其力，以保江山。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "现有印绶在此，吾弟应念父兄创业艰难，要保全基业。"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "恐你兄弟年幼，不能成其大事。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "吾弟之才胜孩儿十倍，母亲但放宽心。倘内事不决，可问张昭；外事不决，可 问周瑜。 乔夫人过来。吾死之后，你必须要善侍老母。我纵死九泉也是感恩不尽的了！ 恨周瑜不在此地，不能与他共议大事也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策死。众人同哭。"
        },
        {
          "character": "孙母",
          "type": "白",
          "text": "吾儿孙权，速备棺槨，成殓你兄长，整理葬事便了！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}