{
  "script_id": "01031009",
  "title": "雍凉关",
  "alias": [
    "流言计"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "司马懿",
      "hangdang": "净"
    },
    {
      "name": "马谡",
      "hangdang": "净"
    },
    {
      "name": "曹睿",
      "hangdang": "小生"
    },
    {
      "name": "司马师",
      "hangdang": "净"
    },
    {
      "name": "司马昭",
      "hangdang": "小生"
    },
    {
      "name": "贾诩",
      "hangdang": "末"
    }
  ],
  "plot": "蜀汉诸葛武侯，自平蛮之后，养精蓄锐，预备伐魏，以兴复汉室为己任。探知魏主曹睿，用司马懿执掌兵权，\n镇守雍、凉等处。武侯以魏邦诸人，俱无足虑，惟司马懿极有智略，殊费踌躇。参军马谡，请用反间计，\n使其君臣猜忌。武侯深然之，遣人暗至魏郡，散布流言，云司马懿拥众据险，判反朝廷。且假造司马懿檄文，\n榜示通衢。近臣揭奏，果然启魏主之疑。贾诩为之设谋，驾幸安邑，以观动静。司马懿茫然不知，大陈兵\n权，迎接魏主。魏主明告以故，司马懿惊慌无措，急为申辩，魏主疑终不释。贾诩等请杀之，魏主以顾命之\n重，臣保其首领，将司马懿兵权削夺，废而不用。武侯因计之得行，业已无所虑忌，欣慰殊甚。于是表奏蜀\n帝，名正言顺，出师讨贼矣。噫！天之不欲复兴汉室也。此时曹睿若杀司马懿，何至使武侯六出祁山，功业\n不就，鞠躬尽瘁，死而复已哉！",
  "notes": "是剧前见名伶孙菊仙，在上海屡次唱渍，颇为社会所欢迎。近今北京富连成班，谭鑫培之孙谭富英，亦属拿\n手。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、王平、马岱、廖化、张嶷引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮慢板",
          "text": "叹先皇白帝城龙归天上， 托孤与诸葛亮扶保朝纲。 怎奈我受先帝皇恩浩荡， 保幼主登大宝国泰民康。 都只为南蛮贼强悍狂妄， 奉圣命统大兵渡过泸江。 我也曾与蛮兵连打数仗， 深入那不毛地累动刀枪。 用巧计战孟获七擒七放， 火烧尽藤甲兵转回朝堂。 南方平须把那中原扫荡， 灭却了小曹贼答报先皇。 闷恹恹坐至在中军大帐，"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "待等那探马报便知端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "念",
          "text": "探听中原事，报与丞相知。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将军少礼。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "谢丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你打听中原之事如何？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "启禀丞相：曹丕已死，曹睿继位，加封文武官员。封司马懿为骠骑大将军，统 领兵马，督阵雍凉等处，特来报与丞相知道。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "啊，哈哈呀！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "曹丕已死，孺子曹睿继位，皆不足虑。惟有司马懿，此人深有谋略，颇能用兵。 今日提督雍凉兵马，倘若训练已成，必为我汉中之大患。必须起兵征剿，以 灭此人。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "启丞相：今当平定南蛮而回，军马疲惫，只可存恤，不可远征。末将倒有一计 献上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将军有何妙计？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "司马懿虽是魏国大臣，怎奈曹睿年少，素怀疑忌。丞相何不遣人，散布流言， 道此人欲反；遍贴告示，晓喻百姓。那曹睿闻之，必杀此人也。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此计甚妙。就命将军去至洛阳、邺郡等处，散布流言，遍贴榜文，告示天下， 不得有误。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "看马谡此去，行此反间之计，管叫司马性命难保！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "恼恨曹睿狗奸党， 他命司马镇雍凉。 榜文遍贴在城门上， 管叫那司马懿无有下场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "司马懿上。"
        },
        {
          "character": "司马懿",
          "type": "引子",
          "text": "虎跃龙骧，统貔貅，督镇雍凉。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "长须如雪鬓如霜，战策兵机腹内藏。愿学孙武与吕望，扶保魏国锦家邦。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "老夫，司马懿。魏王驾前为臣，官拜骠骑大将军，提督全国兵马，坐镇雍凉。 每日带领两个孩儿，操练军士。待等兵马练熟，定要扫灭西蜀，生擒诸葛亮， 以报国恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马师、司马昭同上。"
        },
        {
          "character": "司马师",
          "type": "念",
          "text": "黄公三略安天下，"
        },
        {
          "character": "司马昭",
          "type": "念",
          "text": "吕望六韬定太平。"
        },
        {
          "character": "司马师、司马昭",
          "type": "同白",
          "text": "参见父帅。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吾儿少礼。"
        },
        {
          "character": "司马师、司马昭",
          "type": "同白",
          "text": "谢父帅。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "命你等整顿兵马，可曾点齐？"
        },
        {
          "character": "司马师",
          "type": "白",
          "text": "人马将士，均在校场伺候，请父帅前去阅操。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "好，一同前往。正是："
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "校场训练兵和将，要与诸葛定雌雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、司马师、司马昭同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "帐中奉了丞相令， 去到洛阳贴榜文。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "俺，马谡。奉了丞相将令，去到洛阳临郡等处，遍贴榜文，散布流言，就此前 往。"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "加鞭催马往前进， 散布流言走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "诸葛亮",
          "type": "内二黄导板",
          "text": "谯楼上打罢了三更鼓响，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、二童儿提灯引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢板",
          "text": "秉忠心重整顿汉室家邦。 高皇帝创基业起义沛上， 全凭着驾下臣韩信、张良。 到后来出了个奸贼王莽， 用药酒毒平帝篡夺家邦。 光武兴仗云台二十八将， 灭莽贼承汉统迁都洛阳。 十常侍乱宫闱黄巾结党， 恨奸曹逞凶心霸占朝堂。 欺天子挟诸侯欺君藐上， 有曹丕受禅台篡夺家邦。 到如今有曹睿加官封赏， 命司马统大兵督镇雍凉。 叫人来掌红灯观星台上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上桌子。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢板",
          "text": "又只见南北斗齐发光芒。 看北方旺气盛明星甚亮， 只有那司马星暗淡少光。 想必是他一时命不该丧， 还需要设妙计另作主张。 我这里下星台且归大帐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下桌子。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "且待那马谡回便知端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、二童儿、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾诩上。"
        },
        {
          "character": "贾诩",
          "type": "西皮摇板",
          "text": "适才探马报一声， 大胆司马起反心。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "下官，贾诩。适才探马报道，洛阳、邺郡等处，遍贴司马懿的榜文，他要造反， 告示天下。不免将榜文呈进我主，速灭此人，以安天下便了。"
        },
        {
          "character": "贾诩",
          "type": "西皮摇板",
          "text": "司马榜文袖藏定， 去至金殿奏主君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾诩下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、内侍、曹睿同上。"
        },
        {
          "character": "曹睿",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "曹睿",
          "type": "念",
          "text": "金殿当头紫阁重，仙人掌上玉芙蓉。太平天子朝元日，五色云车驾六龙。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "寡人，大魏天子，曹睿在位。自登基以来，风调雨顺，国泰民安。今当早朝。 内侍，传旨：文武百官，有本早奏，无本退班。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "领旨。 万岁有旨：文武百官，有本早奏，无本退班呐！"
        },
        {
          "character": "贾诩",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾诩上。"
        },
        {
          "character": "贾诩",
          "type": "念",
          "text": "忙将机密事，启奏万岁知。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "臣贾诩见驾，吾皇万岁！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "启万岁：大事不好了！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "今有司马懿，意欲造反，在各州郡遍贴榜文，布告天下，不久就要起兵反上。 臣今将他的榜文，抄录呈上，请我主御览。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "竟有这等之事！将榜文呈上来，待寡人观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾诩呈文，曹睿接看。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "“骠骑大将军总领雍凉兵马军司马懿，谨以信义布告天下：昔太祖武皇帝，创 立基业，本欲立陈思王子建，为社稷之主；不幸奸谗交集，岁久潜龙。皇孙曹 睿，素无德行，妄自居尊，深负太祖之遗意。今吾应天顺人，克日兴师，以慰 万民之望。告示到日，各宜归命新君。如不顺者，当灭九族！先此告闻。” 唔咳咳呀！竟有这等之事！卿家何计安哉？"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "想那司马懿上表，乞守雍凉，正为此耳。当年太祖武皇帝，尝谓臣曰等：司马 懿鹰眼狼顾，不可付以兵权；久必为国家大祸。今日反情已萌，可速诛之。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "如此，待寡人点动倾国人马，御驾亲征，以杀此人。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "万岁，若要御驾亲征，是逼之速反也。万岁可仿汉高祖，伪游云梦之计。御驾 至安邑阅兵，司马懿必然来迎；观其动静，就车前擒之可也。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "此计甚好。就命卿家传旨：寡人带领御林军十万，驾幸安邑，就此响炮离京。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "御林军走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、黄伞同上。〖泣颜回〗。众人同大转场，同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "司马懿上。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "辕门旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马师上。"
        },
        {
          "character": "司马师",
          "type": "念",
          "text": "忙将朝中事，启禀父帅知。"
        },
        {
          "character": "司马师",
          "type": "白",
          "text": "参见父帅。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吾儿少礼。进帐何事？"
        },
        {
          "character": "司马师",
          "type": "白",
          "text": "适才探马报到：万岁驾幸安邑，不久即到。特来禀告父帅。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "如此，吾儿传令下去，命全部人马，大小将官，全身披挂，刀枪要齐整，盔甲 要鲜明。排列队伍，出城迎接圣驾，不得有误。"
        },
        {
          "character": "司马师",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马师下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "整顿全部人和马，欲令天子识威严。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿下。"
        }
      ]
