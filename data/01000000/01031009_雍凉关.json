    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": "曹睿",
          "type": "内西皮导板",
          "text": "龙驹凤辇出帝京，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、二内侍、四将、贾诩引曹睿同上。"
        },
        {
          "character": "曹睿",
          "type": "西皮慢板",
          "text": "刀枪剑戟排列如林。 带领着十万御林军， 文武百官随驾行。 恼恨那司马贼奸佞， 他本是我朝中两代老臣。 身受那先皇帝恩意重， 因何故一旦间起下反心。 今日里才把那雍凉来镇， 竟敢在各州郡遍贴榜文。 有寡人此一番安邑西幸， 司马懿他必然带兵来迎。 朕看他到那时是何动静， 就车前一定要把他来擒。 叫人来催人马齐往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、二内侍、四将、贾诩同下。"
        },
        {
          "character": "曹睿",
          "type": "西皮摇板",
          "text": "但愿得此一去灭却反臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹睿下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、四上手、四将、司马师、司马昭、司马懿自下场门同上，同出城迎接。四龙套、四大铠、四将、"
        },
        {
          "character": null,
          "type": "text",
          "text": "二内侍引曹睿同上。司马懿跑接。〖吹打〗。）"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "胆大司马懿！你身受先皇帝厚意，不知报效，擅敢造反。本当将你斩首问罪， 姑念你是先朝老臣，加恩撤去兵权，削职为民。去罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、四上手、四大铠、八将、二内侍、曹睿同同下。司马懿看司马师、司马昭。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、司马师、司马昭同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "司马督兵守雍凉， 老夫刻刻挂心旁。 将身且坐宝帐上， 待等马谡报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "司马削职还乡井， 见了丞相说分明。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "罢了。命你散布流言，不知那曹睿是怎样行事？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "末将奉命，在洛阳、邺郡等处，散布流言，遍贴榜文。那曹睿即刻带了御林军 十万，兵出洛阳，驾幸安邑。那司马懿不知此中之事，带那数十万相迎。曹睿 心疑，当时就撤去兵权，削他父子为民，兵权交付曹休执掌。曹睿已回洛阳去 了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫久有伐魏之心，奈因司马懿兵镇雍凉，吾甚可虑。今既中计，司马懿遭贬， 罢职还乡，吾又何虑！明日修本，启奏幼主，点动人马，兵发中原便了。吩 咐掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、马谡、四龙套同下。〖牌子〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
