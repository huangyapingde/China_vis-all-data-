{
  "script_id": "01020012",
  "title": "拷红",
  "alias": [
    "拷打红娘"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "红娘",
      "hangdang": "贴旦"
    },
    {
      "name": "崔母",
      "hangdang": "老旦"
    },
    {
      "name": "张珙",
      "hangdang": "小生"
    },
    {
      "name": "崔莺莺",
      "hangdang": "旦"
    }
  ],
  "plot": "老夫人得悉崔莺莺每夜往园中烧夜香，近日又神思困懒，知必有异，因即拷问红娘。红娘始而狡猾，继则渐\n渐供出真情。老夫人闻言，则始而怒，继而不得不从红娘之言，将张生、莺莺一齐唤至，当面许婚，以了结\n此段公案，如是云云而已。",
  "notes": "《拷红》一剧，本为《西厢记》中一大关键，亦一大结束。盖君瑞与双文，既经拆此烂污，而老夫人方面，\n碍于相国门阀，既未便出乖露丑，告官指奸，又不能任其苟且，不加谴责，然又用何种言语，何种脸面，可\n以去谴责他们。故必得此《拷红》一出，以为玲珑剔透面面俱到之过渡。故此剧中红娘之一言一动，嬉笑怒\n骂，皆有分量。观此剧者，当注意红娘之白口。惟白中袭用“大车无輗，小车无軏，其何以行之哉”等成句，\n竟是背书，可笑之至，我愿此后当酌改。此为贴旦角色上最难演之戏，其表情处之不易，当与唱《红楼梦》\n戏，有同一至高之程度。此戏虽极简单，然实可称为全本《西厢记》之告终处。盖《拷红》以后，皆余波\n而已。吾愿近之旦角，当细细将此戏之做工白口，倍加研究，冀成为一出有价值之戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崔母上。"
        },
        {
          "character": "崔母",
          "type": "引子",
          "text": "凄凉萧寺，空迤逦，故园不堪回首。"
        },
        {
          "character": "崔母",
          "type": "念",
          "text": "雕笼不解藏鹦鹉，绣幕何须护海棠。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "这几日，窃见莺莺神思恍惚，不知为着何事。待我叫红娘出来，拷问一番，便 知明白。 红娘哪里，红娘哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘上。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "吓，来了。"
        },
        {
          "character": "红娘",
          "type": "引子",
          "text": "若不是红娘引逗，怎能够两下来成就。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "红娘快来。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "哎呀且住，今日老夫人为何怒气冲冲，在那里叫我，莫非此事发觉了。这便怎 么处？啐，自古道丑媳妇，少不得要见公婆面的，就去何妨。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "吓红娘。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "叫你半日，为何不来。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "老夫人叫红娘是就来的吓。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "与我跪下。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "好端端的为何跪起来？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "还不跪。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "要跪就跪。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "我且问你，每日同小姐，到后花园中干什么？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "叫我道着什么？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "唔。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "吓，是烧香的。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "烧什么香？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐说，若要萱堂增寿考，全凭早晚一炉香，可以保佑老夫人的。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "可有什么别事？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "没有吓。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "唔，你还瞒我。打死你这小贱人，小贱人吓！"
        },
        {
          "character": "崔母",
          "type": "桂枝香",
          "text": "着你行监坐守， 谁许你胡行乱走。 一任你握雨携云， 常使我提心在手。 你花言巧语，你花言巧语， 将没做有，使我出乖露丑。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "相府家，有什么出乖露丑？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "还要胡说，打死你这小贱人。"
        },
        {
          "character": "崔母",
          "type": "桂枝香",
          "text": "吓哈打打你这贱丫头， 不说出始末根由事，叫我如何索罢休。"
        },
        {
          "character": "红娘",
          "type": "桂枝香",
          "text": "那日间，停刺绣， 把此情穷究。 道张——"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "“张”什么？"
        },
        {
          "character": "红娘",
          "type": "桂枝香",
          "text": "张生病染沉疴。 小姐说，要同我到书斋问候。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "张生有病，与你们什么相干？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "不但小姐不该去，连红娘也是不该去的。阿呀张生，你那天杀的。"
        },
        {
          "character": "红娘",
          "type": "桂枝香",
          "text": "使红娘暂回，使红娘暂回。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "小姐呢？"
        },
        {
          "character": "红娘",
          "type": "桂枝香",
          "text": "小姐权——"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "“权”什么。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "待我说呢。"
        },
        {
          "character": "红娘",
          "type": "桂枝香",
          "text": "小姐权时落后。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "女孩儿家岂可落得后的？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "落后就落后，只管问。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "你不说，我就要打。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "老夫人不要打，待我说。女孩儿家落后有什么好处吓。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "完了。"
        },
        {
          "character": "红娘",
          "type": "桂枝香",
          "text": "想做了鸾交凤友。 慢追求始末根由事， 如何索罢休。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "我想此事，非怪张生、小姐、红娘之过，都是老夫人不是。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "怎么到是我不是？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "老夫人请坐，待红娘告禀。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "你说。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "我想信乃人之根本，人而无信，不知其可也。大车无輗，小车无軏，其何以行 之哉。当初兵围普救寺的时节，老夫人有言：“如有退得贼兵者，愿将小女妻 之”。可是有的？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "是有的。此乃退兵之计。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "张生非慕小姐颜色，岂肯建此退兵之计？如今兵退身安，老夫人悔言失信。既 不成其亲事，只合酬以金帛，令张生舍此而去，不合留于书院，相近咫尺，使 怨女旷夫，早晚各相窥视，因而有此一端。老夫人若不早息此事，一来玷辱相 国家声，二来张生名望有亏，既施恩于人，反受其辱。那官府推详此事，老夫 人先有治家不严之罪，忘恩负义之愆。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "今据红娘看来，一些也不难。莫若赦其小过，成其大事，只滌其旧染之污，而 自新，岂不为长便乎？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "你这小贱人，倒说得干净。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "不干净，也不说了。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "退后。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "且住。我想家门不幸，养这不肖之女，我今若到官去，一来玷辱相国家声，二 来张生名望有亏。咳，罢，不如依了这小贱人。 过来，唤那禽兽过来。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "哪个什么禽兽吓？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "张生。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "我不去。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "为何不去？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "又道是红娘递书信去了。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "哪个在，取家法过来。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "走走走，张生快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙上。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "来了，红娘姐。为何如此？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "好吓。你们快活，累我打得这般光景。如今叫你去做亲。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "怎生去见老夫人？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "你装做假道学，摇摇摆摆，过去就是了。"
        },
        {
          "character": "张珙",
          "type": "引子",
          "text": "自古沉舟可补，如今覆水难收。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "老夫人拜揖。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "张生，我何等样待你，如今干出这样事来。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "小生只此一遭。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "两遭，连外孙都有了。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "胡说。唤那不肖的出来。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔莺莺上。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "红娘怎么说？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "此事老夫人知道了，被我说长道短，讲了一番。如今叫你去做亲。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "羞答答怎样前去？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "就照前日，见张生时的样儿就好。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "母亲。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "张生，今日我就将莺莺许配与你。只是我家三代姻亲无白身者，我今赠你盘费， 明日就起行赴京，求取功名。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "也要过了满月再去。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "什么满月？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "不过满月也要过了三朝。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "明日定要动身。倘能到京，得个一官半职，那时回来，也对得过我母女。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "多谢厚意。正是："
        },
        {
          "character": "张珙",
          "type": "念",
          "text": "今日果然成凤侣，明朝又复唱丽歌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙下，崔莺莺下。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "吓老夫人，此事若不是我红娘调处，断难结此良缘。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "若无你这小贱人，还坏不了大事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔母下。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "总是我的不是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}