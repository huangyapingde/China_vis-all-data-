        {
          "character": "陈炳顺",
          "type": "白",
          "text": "娘子吓！"
        },
        {
          "character": "陈炳顺",
          "type": "西皮二六板",
          "text": "娘子休要问根源， 下官言来听心间： 老母当年将你赶， 姑母家中把身安。 为丈夫上京去赴选， 千里迢迢去求官。 我只道今生夫妻难相见， 又谁知天理循环，珠还合浦，破镜又重圆。 我母得病甚危险， 又蒙你焚香祝告，割股作羹汤，尽孝在堂前。 今日老母心回意已转， 特地接你回家园。"
        },
        {
          "character": "大媳妇",
          "type": "西皮摇板",
          "text": "既然婆母将奴唤， 妾身怎敢不回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈炳顺扶大媳妇上轿。鸣锣。众人同下。"
        }
      ]
