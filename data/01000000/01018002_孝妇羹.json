        {
          "character": null,
          "type": "stage",
          "text": "陈炳义、二媳妇同跪。"
        },
        {
          "character": "陈炳顺",
          "type": "白",
          "text": "想兄弟并无过错，老母开恩。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "看在我儿面上，留下你们两个畜牲！"
        },
        {
          "character": "陈炳义、二媳妇",
          "type": "同白",
          "text": "谢老娘！"
