        {
          "character": "大媳妇",
          "type": "白",
          "text": "原来如此。谢天谢地！"
        },
        {
          "character": "陈炳顺",
          "type": "白",
          "text": "娘子，你抱的是谁家孩儿？"
        },
        {
          "character": "大媳妇",
          "type": "白",
          "text": "自从官人去后，妾身产生一男。官人请看。"
        },
        {
          "character": "陈炳顺",
          "type": "白",
          "text": "我陈门有子，又是一辈人了。我今奉母亲之命，前来接你回去。"
        },
        {
          "character": "大媳妇",
          "type": "白",
          "text": "我婆母怎样叫你来接妾身呐？"
