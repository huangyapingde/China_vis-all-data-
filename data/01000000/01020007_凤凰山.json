  "plot": "薛仁贵自三次投军，投入张士贵部下以来，屡立大功，惟久被张士贵所冒，屈居火头军，既而唐太宗被困凤\n凰山，丧去大将数十员，又赖薛仁贵出救，鞭打盖苏文，方得解围。唐太宗望见白袍小将，料是应梦贤臣，\n定欲查出。尉迟元帅乃以犒军为名，暗向张士贵先锋营中物色，讵知为酒所误，仍被张士贵瞒过，将薛仁贵\n等九人，藏在离营三里山神庙中。尉迟恭元帅酒既醒，自知误事，乃微服夜行，向各营头暗中探听，方被侦\n悉，遂径向山神庙中寻访，甫至山神庙外，正值薛仁贵在月下对天叹怨，历历追诉，自述其功。尉迟恭元帅\n见应梦贤臣已遇，喜出望外，不禁冒昧掩上，骤将薛仁贵拦腰抱住，讵意薛仁贵久为张士贵所愚，谓尉迟恭\n元帅久奉密旨，欲拿捉应梦之人薛仁贵云云，至是回头一望，见果是黑脸元帅将己抱住，不觉狂惊，遂拼命\n力挣将尉迟恭推倒在地，慌慌张张脱身而去。迨尉迟恭爬起，四处找寻，薛仁贵已避逸他处矣。直至独木关\n枪挑安殿宝方再出现。",
  "notes": "此剧出《征东传》，在《独木关》之前。《叹月》一段，本在《独木关》剧中，惟与此亦可带演。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、徐勣、尉迟恭、程咬金、李世民同上。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "孤王领兵出朝门， 跨海征东把贼平。 军师徐勣阴阳准， 神机妙算鬼神惊。 尉迟元帅威风凛， 前部先锋程咬金。 将身且把宝帐进， 听候探马报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "盖苏文讨战。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "忽听探马报一声， 胆大番将敢逞能。 人来带马两军阵， 孤王亲自会贼人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙旗、四番兵、盖苏文同上。李世民、四龙套同上。"
        },
        {
          "character": "盖苏文",
          "type": "白",
          "text": "来将通名受死。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤乃大唐贞观天子。"
        },
        {
          "character": "盖苏文",
          "type": "西皮摇板",
          "text": "闻听来了小唐王， 倒叫某家怒胸膛。 劝你快把降表上， 少若迟延刀下亡。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "听罢言来怒气生， 闻言大骂盖苏文。 快快马前来归顺， 少时叫你命难存。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、盖苏文同起打，李世民败下，盖苏文追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "薛仁贵",
          "type": "内西皮导板",
          "text": "豪杰出世逞刚强，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵上。"
        },
        {
          "character": "薛仁贵",
          "type": "西皮快板",
          "text": "抢关夺寨把名扬。 方天画戟无人挡， 匹马单身保大唐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内擂鼓声、喊声。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "吓，哪里有人呐喊之声，待俺登高一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵上桌，李世民上，盖苏文追上，李世民败下。"
        },
        {
          "character": "盖苏文",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "盖苏文下。薛仁贵下桌。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "前面败的乃是吾主，后面番兵追杀，此时不救，等待何时。 呔，番贼休要猖狂，你薛爷来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵下，李世民上，盖苏文追上，李世民落马，薛仁贵上。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "来将通名受死。"
        },
        {
          "character": "盖苏文",
          "type": "白",
          "text": "你老爷辽东大将，盖苏文也。来将通名！"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "你老爷薛礼，看戟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵、盖苏文同起打，李世民上桌看，盖苏文败下，薛仁贵追下。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "孤王被贼挑下马， 忽然闪出年少娃。 此人不在功劳簿下， 应梦贤臣定是他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "盖苏文上。"
        },
        {
          "character": "盖苏文",
          "type": "白",
          "text": "且住，薛礼杀法厉害，飞刀擒他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵上，打盖苏文，盖苏文祭飞刀，薛仁贵挑刀落，杀盖苏文下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小将休走！"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤王贞观在此！"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵跑下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小将休走，孤家来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、李世民、徐勣、程咬金、尉迟恭同上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤王与盖苏文交战，被他将孤挑下马来，忽然闪出一员小将，身穿白袍，将那 贼杀败，莫非此人就是梦中贤臣么？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "哎呀且住，薛礼此番救驾，吾主若与他相见，定有牢狱之灾，不免朦胧启奏。 吓，万岁要见那白袍小将，必须差人，前去寻访。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤发饷银十万犒赏三军，暗中寻访应梦之人，只是无人前去。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老臣不才，愿放饷银，寻访白袍小将。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不行不行，尉迟恭，你是向来有毛病的，一见酒就没有命了。漫说见不着白袍 小将，就是见着白袍小将，你吃得大醉，也认不出来呀。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吾今戒酒就是。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "只怕你是狗改不了吃屎。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "你若是访着应梦贤臣，吾愿将军师大印付你执掌！你呢？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吾若访不着白袍小将，愿赌项上的人头！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "口说无凭，敢与山人击掌么？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "击掌！请呐！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "二位皇兄不必争论，孤赐你戒酒金牌一面，待等放饷归来，方许饮酒。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张士贵同上。"
        },
        {
          "character": "张士贵",
          "type": "念",
          "text": "撒出鹰鹞去，捉拿燕雀回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志龙、何宗宪同上。"
        },
        {
          "character": "张志龙",
          "type": "白",
          "text": "启爹爹：今有尉迟老元帅，奉了万岁旨意，发饷银十万，犒赏三军，要访查那 白袍薛礼，倘若被他访出，如何是好？"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "我自有道理。来，薛礼进帐。"
        },
        {
          "character": "张志龙",
          "type": "白",
          "text": "薛礼进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵上。"
        },
        {
          "character": "薛仁贵",
          "type": "念",
          "text": "英雄运不至，何日见青天！"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "参见总爷。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "唤小人进帐，有何军情议论？"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "薛礼，你的祸事到了！"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "吓，小人在营中，肃守营规，并不曾做过犯法之事，但不知这祸从何而起？"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "今有尉迟老元帅，要拿你问罪，岂不是祸事到了？"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "总爷呀，想小人自进营来，无非自将身许国，报效皇家，今日既然得罪了尉迟 老元帅，还望总爷周全小人。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "他乃奉命而来，叫老夫也是无法。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "哎呀总爷吓，想小人随同总爷出兵以来，也曾抢关夺寨，立下功劳，杀死番兵 番将无数，今日小人遇祸，望求总爷，开天地厚之恩，搭救小人性命，小人纵 死九泉，也是感恩非浅！"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "既然如此，这营盘之后，有一山神庙，你在那里躲避几日，再做道理。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "谢总爷。正是："
        },
        {
          "character": "薛仁贵",
          "type": "念",
          "text": "晴天闻霹雳，平地起风波。"
        },
        {
          "character": "薛仁贵",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛仁贵下。"
        },
        {
          "character": "四龙套",
          "type": "内同白",
          "text": "尉迟元帅到！"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四龙套、尉迟宝林、尉迟宝庆、尉迟恭同上。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "元帅驾到，未曾远迎，元帅恕罪！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老夫奉令前来放饷，明日五鼓，老夫在营门点名，叫众将军士，皆从东辕门而 入，从西辕门而出，按名点放，如有违犯者，照军令施行！你等要记下了！"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、尉迟宝林、尉迟宝庆、尉迟恭同下。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "方才元帅言道：明日要按名点放饷银，倘若见了薛礼名字，大为不便。"
        },
        {
          "character": "张志龙",
          "type": "白",
          "text": "想那尉迟元帅，生性最好饮酒，爹爹明日预备上等好酒，将他劝醉，他糊里糊 涂，可也就不点了。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "今有万岁，赏他戒酒金牌一面，他挂在胸前，如何还敢饮酒?"
        },
        {
          "character": "张志龙",
          "type": "白",
          "text": "明日等他点名，到那口渴之时，我将酒坛打开，叫他闻着这酒的香味，他必然 要问，爹爹你就将酒送上，不说是酒，就说这是五味香茶，他听说不是酒，是 一定要饮的，他喝顺了口，自然还要，就此一盏一杯，他自然就醉了。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "呵哈哈哈哈，吾儿此计甚好，照计办来。掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、尉迟宝林、尉迟宝庆、尉迟恭同上。"
        },
        {
          "character": "尉迟恭",
          "type": "西皮摇板",
          "text": "老夫奉命放饷银， 来到营中访贤臣， 将身且把大堂进， 定要仔细点花名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士贵引张志龙、何宗宪同上。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "名册可曾造齐？"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "名册造齐。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吾儿押同张士贵，将名册取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林押张士贵同下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "少时点名，吾儿须要仔细查验。"
        },
        {
          "character": "尉迟宝庆",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林、张士贵同上。"
        },
        {
          "character": "尉迟宝林、张士贵",
          "type": "同白",
          "text": "名册呈上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吾儿听令！"
