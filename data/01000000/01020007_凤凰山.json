          "text": "有！"
        },
        {
          "character": "尉迟宝庆",
          "type": "白",
          "text": "后营？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志龙、何宗宪同举杯吹气。"
