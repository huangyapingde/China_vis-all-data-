        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "命你在营门之外监视军士，须从东辕门鱼贯而入，由西辕门而出，如有乱行不 遵者，鞭下做鬼！"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "得令！"
