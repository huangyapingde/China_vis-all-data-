        {
          "character": "陈杏元",
          "type": "西皮正板",
          "text": "卢杞贼在朝中良心丧尽，"
        },
        {
          "character": "邹王氏",
          "type": "白",
          "text": "卢杞乃是朝中大大的奸臣，谁人不知！他便怎么样吓？"
