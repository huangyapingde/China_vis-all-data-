        {
          "character": "邹王氏",
          "type": "白",
          "text": "圣上可曾信他问罪？"
        },
        {
          "character": "陈杏元",
          "type": "西皮正板",
          "text": "万岁爷宠爱贼谁人不敬？"
        },
        {
          "character": "邹王氏",
          "type": "白",
          "text": "后来便怎么样呢？"
