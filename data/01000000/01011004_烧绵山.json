          "type": "同白",
          "text": "香烟渺渺，圣上临朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引晋文公上。"
        },
        {
          "character": "晋文公",
          "type": "引子",
          "text": "重整山河，万民安乐。"
