      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引晋文公同上。"
        },
        {
          "character": "晋文公",
          "type": "西皮摇板",
          "text": "一十九载闲漂荡， 今日重振旧家邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监引解张同上。"
        },
        {
          "character": "大太监",
          "type": "西皮摇板",
          "text": "用手带定老解张， 品级台前奏君王。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "站定了，奴婢启奏千岁：有一庶民，名叫解张，知道介子推的下落。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "宣解张上殿。"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "草民见驾。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "解张可知介子推母子下落？"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "他母子逃走了。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "逃往哪里去了？"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "逃往绵山去了。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "吓，卿家吓！"
        },
        {
          "character": "晋文公",
          "type": "西皮摇板",
          "text": "听说此言泪汪汪， 割股忠良一旦亡。 心思切切意彷徨， 亲到绵山走一场。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "解张封为下大夫，朝房官带。"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "解张下。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "内侍传孤旨意，颠颉、魏犨打扫校场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引晋文公同下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "千岁有旨：命颠颉、魏犨打扫校场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨内同允。大太监下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推搀介母同上。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "搀扶老母到山洼， 不贪富贵共荣华。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "老母，来此绵山。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "儿吓，这高山怎样崎岖，为娘怎生行走？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "老母，"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "这座绵山高接天， 峡崴四壁锦物佳。 云横峻岭甚潇洒， 清泉涧下照眼花。 猿猴献果枝头耍， 乌鸦林中叫喳喳。 攀藤扶草上山洼， 古木松林可为家。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "老母，此地可以安身。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "此地到好，不知母子终日何以为食？"
        },
        {
          "character": "介子推",
          "type": "西皮导板",
          "text": "老母不必自嗟呀，"
        },
        {
          "character": "介子推",
          "type": "西皮慢板",
          "text": "草衣木食可为佳。 无是无非真潇洒， 胜似蓬莱第一家。"
        },
        {
          "character": "介母",
          "type": "西皮摇板",
          "text": "我儿说的哪里话， 为娘岂有此嗟呀？ 母子且把松林下，"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "儿把这功名二字付黄沙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨同上，四龙套、四下手同上。"
        },
        {
          "character": "颠颉",
          "type": "念",
          "text": "十万狼牙箭，"
        },
        {
          "character": "魏犨",
          "type": "念",
          "text": "血染马蹄红。"
        },
        {
          "character": "颠颉",
          "type": "白",
          "text": "俺，颠颉。"
        },
        {
          "character": "魏犨",
          "type": "白",
          "text": "俺，魏犨。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "颠颉",
          "type": "白",
          "text": "千岁绵山访贤，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引晋文公同上。"
        },
        {
          "character": "晋文公",
          "type": "念",
          "text": "孤王到校场，绵山访忠良。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "参见千岁。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "人马可齐。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "摆驾绵山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "介子推",
          "type": "内西皮导板",
          "text": "春竹青青隐翠围，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推上。"
        },
        {
          "character": "介子推",
          "type": "西皮慢板",
          "text": "母子叮咛结草依。 我好比箕子绝宗义， 我好比鸿雁隐山溪。 不愿在朝争名利， 终朝每日马不停。 耳边听得人马喊， 此言叫我难猜疑。 站在高山用目视，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推上山。晋文公、颠颉、魏犨、四龙套、四下手同上，过场，同下。"
        },
        {
          "character": "介子推",
          "type": "西皮慢板",
          "text": "彩旗不住空中飞。 五色旌旗当空立，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋文公、颠颉、魏犨、四龙套、四下手同上，过场，同下。"
        },
        {
          "character": "介子推",
          "type": "西皮快板",
          "text": "刀枪剑戟排得齐： 见几个怀抱双黄锏， 见几个手拿打将锤； 见几个手执画杆戟， 见几个手拿银战杆。 莫不是哪国烟尘起？ 莫不是千岁把兵提？ 莫不是要把山头洗？ 莫不是访我介子推？ 我也曾对天把誓立： 永不在朝挂紫衣。 观罢一场心上气， 一腔恶气往上提。 任你搜来任你洗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推下山。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "死在绵山总不回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "晋文公、四下手同上。"
        },
        {
          "character": "晋文公",
          "type": "西皮摇板",
          "text": "野草闲花遍地黄， 亲到绵山访忠良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨同上。"
        },
        {
          "character": "颠颉",
          "type": "西皮摇板",
          "text": "水底捞月无踪影，"
        },
        {
          "character": "魏犨",
          "type": "西皮摇板",
          "text": "沙窝捞金莫处寻。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "可有踪迹？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "并无踪迹。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "卿家吓！"
        },
        {
          "character": "晋文公",
          "type": "西皮摇板",
          "text": "听一言来好惨伤， 找不着忠良在哪厢。 二卿一齐把马上， 东山西岭访忠良。"
        },
        {
          "character": "颠颉",
          "type": "西皮摇板",
          "text": "辞别千岁把马上，"
        },
        {
          "character": "魏犨",
          "type": "西皮摇板",
          "text": "东山西岭访忠良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推上。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "四下不住喊声近， 叫人难解其中情。 回头便把老娘请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介母上。"
        },
        {
          "character": "介母",
          "type": "西皮摇板",
          "text": "我儿请娘为何因？"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "老娘有所不知情， 重耳带兵将儿寻。"
        },
        {
          "character": "介母",
          "type": "西皮摇板",
          "text": "既是重耳将儿寻， 就该前去见圣君。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "老母说话欠思论， 孩儿立意不回心。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "母子哪里安身？"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "搀扶老母东山进， 东山以内避躲君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "颠颉上。"
        },
        {
          "character": "颠颉",
          "type": "西皮摇板",
          "text": "吾主本是有道君， 君访贤臣臣隐林。 将人马齐把东山进， 东山以内寻贤良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推搀介母同上。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "扶定老母西山进， 西山内面去安身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "魏犨上。"
        },
        {
          "character": "魏犨",
          "type": "西皮摇板",
          "text": "吾主有道坐龙庭， 忘却忠臣割股情。 人马齐把西山进， 西山以内去搜寻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏犨下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推搀介母同上。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "母子们同把中山上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同上山，同下山。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "中山内面去安身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "晋文公上。"
        },
        {
          "character": "晋文公",
          "type": "西皮摇板",
          "text": "百鸟不住叫山岗， 何处深林将卿藏？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨、四龙套、四下手同上。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "启奏千岁：满山寻尽，并无踪迹。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "这便怎么处？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "千岁传下旨意，火焚绵山。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "岂不将他母子烧死内面？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "吓，千岁，想那介子推，乃是大孝之人，见火一起，他必定背他老母，前来见 驾。"
        },
        {
          "character": "晋文公",
          "type": "白",
          "text": "好，吩咐火焚绵山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨同允，同放火。众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推上。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "耳旁听得炮连声，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推跌。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "重耳放火烧山林。 东山不进西山隐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推跌。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "西山烈火密层层。 回头便把老母请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介母上。"
        },
        {
          "character": "介母",
          "type": "西皮摇板",
          "text": "我儿慌张为何因？"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "老母不解其中情， 重耳放火烧山林。"
        },
        {
          "character": "介母",
          "type": "西皮摇板",
          "text": "既是重耳烧山林， 我儿速速去见君。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "老母不必将儿劝， 孩儿立意不回还。"
        },
        {
          "character": "介母",
          "type": "西皮摇板",
          "text": "在哪里安身？"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "扶定老母东山进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火。介子推跌。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "东山烈火如烟腾。 搀扶老母西山隐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推跌。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "西山烈火密层层。 一言未尽火扑面，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推跌，散连子。放火。介子推两边望。"
        },
        {
          "character": "介子推",
          "type": "西皮摇板",
          "text": "母子一命赴幽冥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推死，介母死。晋文公、颠颉、魏犨、四龙套、四下手同上。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "启千岁：介子推母子已死。"
