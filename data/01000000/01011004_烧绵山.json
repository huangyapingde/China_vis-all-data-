          "character": "解张",
          "type": "白",
          "text": "请，老汉有礼。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "还礼，请坐。"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "谢坐。"
