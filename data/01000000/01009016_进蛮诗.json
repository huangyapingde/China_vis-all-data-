        {
          "character": "杨国忠",
          "type": "白",
          "text": "你是甚等样人，叫老夫与你磨墨？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "杨国忠与学士公磨墨！"
