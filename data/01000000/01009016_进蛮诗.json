        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "臣。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "与学士公侍立左右。"
        },
        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "他乃甚等样人，臣能与他站班？"
