{
  "script_id": "01002020",
  "title": "白状元祭塔",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "白素贞",
      "hangdang": "旦"
    },
    {
      "name": "许仕林",
      "hangdang": "小生"
    }
  ],
  "plot": "许仙之妻白氏，系白蛇妖化身。金山主持法海，与有嫌隙，用合钵镇压之，而建塔其上。后白氏所生之子许\n仕林，以第一人及第，衣锦还乡，就塔前祭之。白氏出见大哭，历诉往事。痛恨许仙薄幸，法海狠毒不已。\n许仕林虽为乌哺情深，莫能救也，叹惜愤恨而归。",
  "notes": "此剧事实荒诞，听者付之一笑可也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上，许仕林上。"
        },
        {
          "character": "许仕林",
          "type": "引子",
          "text": "一色杏花红十里，状元归去马如飞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许仕林坐。"
        },
        {
          "character": "许仕林",
          "type": "念",
          "text": "中状元名扬天下，琼林宴帽插宫花。喜则喜三宫摘宴，稳坐在三元上下。"
        },
        {
          "character": "许仕林",
          "type": "白",
          "text": "下官许仕林，蒙圣恩得中头名状矣。想我母亲雷峰塔受苦，是我上殿启奏一本， 今日奉旨回家祭祖。 左右，吩咐外厢开道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、许仕林同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "塔神上。"
        },
        {
          "character": "塔神",
          "type": "念",
          "text": "力大无穷顶砚台，玉帝符旨把某差。"
        },
        {
          "character": "塔神",
          "type": "白",
          "text": "我乃塔神是也，奉了玉帝符旨，在此看守雷峰塔。不免在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上，同挖门，许仕林上，拈香。"
        },
        {
          "character": "许仕林",
          "type": "三叫头",
          "text": "母亲！老娘！娘亲！"
        },
        {
          "character": "许仕林",
          "type": "二黄导板",
          "text": "见此塔不由人双泪落定，"
        },
        {
          "character": "许仕林",
          "type": "二黄摇板",
          "text": "怎不叫儿痛在心。"
        },
        {
          "character": "许仕林",
          "type": "哭板",
          "text": "哭一声老娘亲不能相见， 儿的娘吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许仕林躺下，四青袍同下。"
        },
        {
          "character": "塔神",
          "type": "白",
          "text": "白氏仙姑，你儿前来祭奠于你，快些走动。"
        },
        {
          "character": "白素贞",
          "type": "内二黄导板",
          "text": "在塔中思娇儿珠泪滚滚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白素贞上。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "苦哇……"
        },
        {
          "character": "白素贞",
          "type": "二黄摇板",
          "text": "又听得揭谛神呼唤一声。 我这里向前去开言便问， 问尊神呼唤我所为何情？"
        },
        {
          "character": "塔神",
          "type": "白",
          "text": "你儿许仕林，前来祭奠于你。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "可容我母子相见？"
        },
        {
          "character": "塔神",
          "type": "白",
          "text": "容你母子相见。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "塔神下。"
        },
        {
          "character": "白素贞",
          "type": "二黄摇板",
          "text": "听说是小孩儿前来祭奠， 不由我一阵阵泪洒胸前。 我这里向前来用目观看， 又只见小娇儿倒在塔前。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "我儿醒来……"
        },
        {
          "character": "许仕林",
          "type": "二黄导板",
          "text": "耳边厢又听得有人唤声，"
        },
        {
          "character": "许仕林",
          "type": "二黄摇板",
          "text": "急忙上前开言问： 今日下官来到此， 你是何人叫仕林？"
        },
        {
          "character": "白素贞",
          "type": "二黄摇板",
          "text": "我的儿你不必将娘来问， 我就是在塔中受苦的娘亲。"
        },
        {
          "character": "许仕林",
          "type": "二黄摇板",
          "text": "听说母亲到来临， 怎不叫儿痛在心！ 走上前来忙跪定， 一一从头说儿听。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "我儿免礼平身。"
        },
        {
          "character": "许仕林",
          "type": "白",
          "text": "谢母亲。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "那旁有块顽石，我儿坐下。 儿吓！哪里来的一身荣耀？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许仕林坐。"
        },
        {
          "character": "许仕林",
          "type": "白",
          "text": "孩儿得中头名状元，故而这身荣耀。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "儿就该奏明圣上，搭救为娘，才是道理。"
        },
        {
          "character": "许仕林",
          "type": "白",
          "text": "孩儿上殿连奏数本，圣上不准也是枉然。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "这也是为娘命该如此。"
        },
        {
          "character": "许仕林",
          "type": "白",
          "text": "嗳，母亲，将当年受苦之事，说与孩儿知道。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "我儿坐在一旁，听为娘将受苦之事，说与我儿知道。"
        },
        {
          "character": "白素贞",
          "type": "反二黄慢板",
          "text": "未开言不由人珠泪双流， 叫一声仕林儿细听从头： 黑风仙他本是为娘道友， 劝为娘勤修炼自有出头。 峨眉山同修道千年已久， 悔不该贪红尘始下山头。 在西湖遇儿父初瞻山斗， 借雨伞结丝罗我把他赘。 都只为端午日同饮药酒， 是为娘显法身惹下忧愁。 在床前将儿父灵魂嚇走， 为娘的盗灵芝用尽心谋。 儿的父上金山烧香行走， 又谁知那秃驴洩漏计谋。 那法海他那里早已算就， 现神通用法术欲把娘收。 实指望遇儿父天长地久， 实指望遇儿父到老白头。 又谁知儿的父谗言听就， 听信了那法海一片奸谋。 为娘的我也曾水内职斗， 为娘的悔不该水漫山头。 到后来与儿父断桥又会， 为娘的与儿父再转杭州。 为娘的产我儿只得满月， 狠心父将为娘就塔内押收！ 但愿得儿夫妻天长地久，天长地久， 我的儿吓…… 但愿得儿夫妻到老百头。 切莫学儿的父心如禽兽， 切莫学儿的父无义无情！"
        },
        {
          "character": "塔神",
          "type": "内白",
          "text": "白氏仙姑回避了！"
        },
        {
          "character": "白素贞",
          "type": "反二黄慢板",
          "text": "母子们才相逢就要分手， 揭谛神呼唤我哪得容留。"
        },
        {
          "character": "白素贞",
          "type": "叫头",
          "text": "我儿！"
        },
        {
          "character": "许仕林",
          "type": "叫头",
          "text": "母亲！"
        },
        {
          "character": "白素贞",
          "type": "叫头",
          "text": "仕林！"
        },
        {
          "character": "许仕林",
          "type": "叫头",
          "text": "亲娘！"
        },
        {
          "character": "白素贞",
          "type": "叫头",
          "text": "我的儿吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白素贞下。"
        },
        {
          "character": "许仕林",
          "type": "叫头",
          "text": "老娘亲吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许仕林带马，下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}