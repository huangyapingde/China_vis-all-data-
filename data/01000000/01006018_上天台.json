{
  "script_id": "01006018",
  "title": "上天台",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘秀",
      "hangdang": "老生"
    },
    {
      "name": "姚期",
      "hangdang": "净"
    },
    {
      "name": "郭妃",
      "hangdang": "正旦"
    }
  ],
  "plot": "姚期自草桥关召回，君臣甚相得，忽其子姚刚在外击死郭后之父，（一作阴丽华之父）郭后诉诸帝，帝盛怒\n之下，欲将其子治罪，令姚期带姚刚上殿。继念姚期系中兴功臣，且三子已战死其二，逐回意释免。适湖北\n有战事，逐令姚刚前去平寇，立功自赎。",
  "notes": "按《草桥关》之后本，即此事实，惟参阅此剧本，其加罪及赦免二层，均彼此不同，并无马武逼书赦诏等情。\n此剧不常见，是一是二，还以质诸演剧家与老戏曲家。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "刘秀",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引刘秀同上。"
        },
        {
          "character": "刘秀",
          "type": "二黄慢板",
          "text": "金钟响玉鞭应王登龙廷， 喜的是太平年五谷丰登。 君有道民安乐天下同庆， 普天下众黎民共享太平。 文凭着邓先生阴阳有准， 武凭着姚皇兄保定乾坤。 内侍臣摆御驾九龙口进， 又听得后宫院大放悲声。"
        },
        {
          "character": "郭妃",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭妃上。"
        },
        {
          "character": "郭妃",
          "type": "二黄摇板",
          "text": "内侍摆驾上龙廷， 万岁台前奏分明。"
        },
        {
          "character": "郭妃",
          "type": "白",
          "text": "哎吓，万岁吓！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "梓童为何这等模样？"
        },
        {
          "character": "郭妃",
          "type": "白",
          "text": "今有姚刚，将我父剑劈府门。万岁作主！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "既有此事，梓童暂且回宫，寡人自有道理。"
        },
        {
          "character": "郭妃",
          "type": "白",
          "text": "谢万岁！哎吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭妃下。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "内侍！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲允。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "宣伴驾王带子上殿。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "伴驾王带子上殿。"
        },
        {
          "character": "姚期",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": "姚期",
          "type": "内二黄导板",
          "text": "安定府绑姚刚怒气皆发，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期、姚刚同上。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "奴才！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "只气得年迈人二眼昏花。 郭太师在朝中势力皆大， 满朝中文武臣谁不怕他？ 似这等犯王法儿全然不怕， 少刻间见万岁定把儿的头杀！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "姚刚",
          "type": "二黄摇板",
          "text": "爹爹不必怒气发， 孩儿言来听根芽。 在府门与郭荣百般叫骂， 怒恼了你孩儿将他来杀！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "小奴才说此话胆比天大， 打死人还说是不犯王法！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "儿是好汉？"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "儿是好汉！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "是好汉随老父参王见驾， 少刻间见万岁，谁是谁非，儿要启奏皇家。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "臣，姚期见驾，吾皇万岁！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "姚皇兄你可知罪？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "臣知罪，不知罪犯何条？"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "今有你三子姚刚，骑马游街，将郭老太师打死。你还言无罪？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "郭老太师也有一行大罪。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "罪犯何条？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "在府门以外私立三尺禁地，文官下轿，武官离鞍。万岁可曾降旨？"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "这个……孤王有言在先，未曾降旨。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "万岁无旨，斩者无亏。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "好一个“斩者无亏”！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "绑坏了！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "吓，殿角下绑的何人？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "三子姚刚。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "内侍，快快松绑，不要绑坏孤的少爱卿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲松绑。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "谢万岁不之恩！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "非是孤王不斩与你，是孤先前许下“姚不反汉，汉不斩姚”。赐你三千人马， 去到湖北枉子城，保定金固牛庄。你父子午门一别，下殿去吧！"
        },
        {
          "character": "姚期、姚刚",
          "type": "同白",
          "text": "谢万岁！"
        },
        {
          "character": "姚刚",
          "type": "三笑",
          "text": "哈哈，哈哈，哈哈哈……"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "奴才！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "万岁爷赦了姚霸林， 好似枯木又逢春。 手拉姣儿下龙廷， 开言叫声姚霸林： 此番湖北儿要改性情， 儿不要提刀乱杀人！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "儿来看。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "看什么？"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "为父的年迈苍苍白如银， 姚刚，我的儿吓！ 好一似瓦上霜、风前灯，能过几春？"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "姚刚",
          "type": "二黄摇板",
          "text": "爹爹落泪儿悲伤， 点点珠泪洒胸膛。 在朝为官有什么好？ 一点不到有损伤！ 倒不如写上辞王表， 告职回乡乐安康。 在午门辞别生身父， 回府去拜上老萱堂。"
        },
        {
          "character": "姚刚",
          "type": "叫头",
          "text": "爹爹，我父，爹爹吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚刚下。"
        },
        {
          "character": "姚期",
          "type": "三叫头",
          "text": "姚刚，霸林，哎吓我的儿吓！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "金殿去了姚霸林， 父子们相逢万不能。 转过金阶梧桐树， 告职回乡乐安宁。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "臣启见万岁！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "吓，姚皇兄为何去而复返？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "臣启万岁：臣要告职归林。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "皇兄告职，寡人怎样舍得？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "要臣在朝伴驾，依臣一件。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "万岁戒酒百日，老臣方能在朝伴驾。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "只要皇兄在朝，慢说戒酒百日，就是周年半岁，又待何妨？内侍，将姚皇兄扶 起！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲扶姚期。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "刘秀",
          "type": "二黄原板",
          "text": "姚皇兄休得要告职还乡， 龙书案听寡人细说端详： 你本是坐朝中开国良将， 叫寡人怎舍得架海金梁？"
        },
        {
          "character": "姚期",
          "type": "二黄原板",
          "text": "非是臣在金殿告职还乡， 老姚期有一本启奏吾王： 小姚刚打死了太师命丧， 怕的是郭娘娘陷害忠良。"
        },
        {
          "character": "刘秀",
          "type": "二黄原板",
          "text": "孤离了龙书案把话来讲， 君臣们站金阙细谈衷肠： 昔日里老王爷龙归海葬， 那时节孤年幼不能承当。 那王莽将玉殿自行执掌， 将孤王赶出都流落他乡。 甲子年那王莽曾开科场， 众举子内其中也有孤王。 孤一心放冷箭射死王莽， 又谁知那一箭不曾带伤。 那王莽中了那岑彭貌相， 科场内怒走了马武子章。 城墙上提反诗险把命丧， 孤与那邓先生到卿的宝庄。 鬼神庄兴皇乡住了一乡， 老皇兄曾言道上有高堂。 老伯母窗台外偷听话讲， 行至在厨房下自尽悬梁。 老皇兄要守孝三年制丧， 天下人俱挂孝方称心肠。 六月天霎时间曾把雪降， 老皇兄，三年孝改三月，三月孝改三日，三日孝改三时，三年、三月、三日、 三时，三刻不满，扶保孤王。 孤念你开国臣曾把江闯， 孤念你秉忠心扶保家邦。 孤念你一杆枪东征西讨， 孤念你每年间，东挡西除，马不停蹄，血战疆场，到如今你还是扶保孤王！ 孤念你三个子把两子来丧， 孤念你只剩下一子姚刚。 孤念你两鬓苍苍如同霜降， 孤念你风前灯瓦上之霜。 后宫院孤赐你玉宴琼浆， 王戒酒你陪酒又待何妨？ 君臣们站金阙细说相让， 叫一声姚皇兄，姚子匡，伴驾王，孤的爱卿，你那里放宽心，大着胆，一步一 步随定了孤王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引刘秀同下。"
        },
        {
          "character": "姚期",
          "type": "二黄原板",
          "text": "万岁爷待老臣恩似山海， 老姚期粉身碎骨理所应该。 自盘古哪有臣把君酒来戒， 这也是老姚期，幼年间，东荡西杀、南征北战、昼夜杀砍、马不停蹄，买动了 皇王的心怀，吾还怕着谁来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}