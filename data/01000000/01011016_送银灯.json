{
  "script_id": "01011016",
  "title": "送银灯",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "张子显",
      "hangdang": "小生"
    },
    {
      "name": "桂娟",
      "hangdang": "花旦"
    },
    {
      "name": "老妇",
      "hangdang": "老旦"
    }
  ],
  "plot": "有张子显者，自称为秀士，为宦家子，不详其为何等人。风流蕴藉，大概如张绪当年。因当大比年，晋京应\n试。途经一镇集，忽被一打虎少年劫之去，闭置书馆中。旋有一老妇出，与之议婚事，欲赘为婿。至晚，忽\n有美人送灯至。张子显见之，心摇摇不能自主，遂与扳谈。言语间一味挑逗，且挽之求欢。女名桂娟。其送\n灯至此，本出老妇计，盖故予以暧昧可乘之机。使男女见之，两相爱悦，而苟且作合也。桂娟见张子显如潘\n安、宋玉，心已雅爱之。惟女孩儿家人前尚腼腆，故假不允。张子显至此，忍俊不禁，急色儿已轻薄不复能\n耐。方屈膝依依跪桂娟裙胯间，而老妇忽至，始则故装门面，作假正经语以窘张子显。迨张子显求之再三，\n乃卒为之配合。",
  "notes": "此种调情戏，与《月华缘》、《打樱桃》等，同是一丘之貉耳。从前本西皮调，近则多唱梆子矣。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张子显上。"
        },
        {
          "character": "张子显",
          "type": "引子",
          "text": "十载寒窗苦，但愿早成名。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "在下张子显。我父在朝，官居武陵侯之职。今乃大比之年，上京赶考。打此经 过，又被一打虎壮士，劫进他府。适才有一位年老妈妈，在我面前提起亲事。 是那妈妈临行言道，少时有人送灯前来。这件事，倒叫我难猜难解也。"
        },
        {
          "character": "张子显",
          "type": "西皮慢板",
          "text": "老妈妈作此事太以短见， 她言道有一女要配夫选。 又言道少时间有人来到， 这件事倒叫我难以解开。 将身儿坐至在书馆以内， 看一看是何人送灯前来？"
        },
        {
          "character": "桂娟",
          "type": "内西皮导板",
          "text": "有桂娟持银灯怎敢怠慢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "桂娟上，老妇上。"
        },
        {
          "character": "桂娟",
          "type": "西皮慢板",
          "text": "绣阁里来了我女儿桂娟。 明亮亮银灯儿照粉面， 一阵阵迎风过丹墀。"
        },
        {
          "character": "桂娟",
          "type": "西皮二六板",
          "text": "急急地走来掉金钗，"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "且住。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "儿为何不走？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "妈妈，儿头上金钗掉了。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "妈妈与儿拾起，与儿插上。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "是。走吓。"
        },
        {
          "character": "桂娟",
          "type": "西皮二六板",
          "text": "罗裙下失掉了红绣花鞋。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "儿吓，为何又不走了？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "妈妈，儿的花鞋掉了。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "为娘与你拔上。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "走吓。"
        },
        {
          "character": "桂娟",
          "type": "西皮二六板",
          "text": "行走来在书馆外， 羞答答怎见那秀才？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "桂娟站住。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "走吓。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "儿不走了。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "儿为何不走？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "儿怕。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "怕什么？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "儿怕害羞。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "儿附耳上来，去也在你，不去也在你。为娘要回上房去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老妇下。"
        },
        {
          "character": "桂娟",
          "type": "叫头",
          "text": "妈妈，娘吓！"
        },
        {
          "character": "桂娟",
          "type": "西皮慢板",
          "text": "有桂娟只生得命运低， 未出绣阁愁满怀。 来在了书馆用目观看，"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "桂娟",
          "type": "西皮慢板",
          "text": "桌案上睡下了一少年。 我将这银灯放桌面， 他问我一声答一言。"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "书馆里闷坏我张子显，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "桂娟咳嗽。"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "倒叫子显着了忙。 若不然上前去拿礼见，"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "书馆内来了女天仙。 搬椅儿，把桌案， 打扫尘土好几番。 小娘子请到书馆里面坐， 有劳你送灯到此间。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "请问小娘子，适才有一位打虎的壮士，是你的什么人吓？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "是我的舍弟。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "令弟。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "舍弟。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "令弟。吓，哈哈哈！请问适才有一年老的妈妈，是你的什么人？"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "那是家母。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "令堂。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "家母。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "令堂。吓，哈哈哈！请问小娘子，你的尊字贵表？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "我叫桂娟。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "哦。你叫桂娟。你这“桂”，乃是“月中丹桂”之“桂”；但不知你那“娟” 呢？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "就是那“月内婵娟”之“娟”。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "哦。那“月内婵娟”之“娟”。非是学生说，你倒占了一个好美的名儿。"
        },
        {
          "character": "张子显",
          "type": "笑",
          "text": "吓，哈哈哈！"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "请问相公尊姓大名？因何到此？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "学生张子显。我父在朝官拜武陵侯，我是个公子，诺诺，还是个秀才。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "哦，哎呀，原来是公子秀才到了，奴家不知，多多有罪。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "你看！"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "看些什么？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "看你那个下作的样儿。"
        },
        {
          "character": "桂娟",
          "type": "西皮慢板",
          "text": "好一个风流张子显， 我爱他青春在少年。 站立在书馆用目看，"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "哎呀且住，方才小娘子言道，她叫作什么娟？什么桂？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "我叫桂娟呢。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "口说是桂娟桂娟，非是学生说你，你倒占了一个好美的名儿。"
        },
        {
          "character": "张子显",
          "type": "笑",
          "text": "吓，哈哈！"
        },
        {
          "character": "桂娟",
          "type": "西皮原板",
          "text": "他将奴名问一番。 有桂娟，言语乱， 黑暗里撒下钓鱼竿。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "哦？"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "桂娟容颜生得好， 倒叫子显喜心间。 书馆内引坏我张子显，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "桂娟咳嗽。"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "若不然上前拉衣裳。"
        },
        {
          "character": "桂娟",
          "type": "西皮摇板",
          "text": "公子礼乐行不正， 我母知道送当官。 打你板子问你罪， 事前容易后悔难！"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "她不从，也枉然， 倒叫子显着了忙。 若不然上前去屈膝跪？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "吓，我是公子，又是一个秀才，我岂肯与她下跪？跪不得跪不得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "桂娟咳嗽。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "若不然上前去双膝跪，跪跪跪， 小娘子念在生可怜！"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "桂娟",
          "type": "西皮摇板",
          "text": "君子做事礼不端， 枉戴头巾穿蓝衫。 始读诸书知礼义， 堂堂的男子无有脸面。"
        },
        {
          "character": "张子显",
          "type": "西皮摇板",
          "text": "自古道色胆大如天， 不怕王法哪怕官。 小娘子请过来拜天地， 拜定天地了姻缘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老妇上。"
        },
        {
          "character": "老妇",
          "type": "西皮摇板",
          "text": "将身来在书馆外， 他二人已成了一对姻缘。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "呀，唗唗！你可是桂娟？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "儿是桂娟。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "哪个叫你前来？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "娘叫儿来。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "还不与我跪下？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "跪下就跪下。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "还不与我起来？"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "起来就起来。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "你可是公子？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "是公子。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "可是秀才？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "是秀才。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "好公子！好秀才！哼哼！"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "哎呀且住，闹到这般时候，这年老妈妈是哪里来的？她那里有气，我不免与她 赔上一礼，也就完了。 吓妈妈，休要动怒，学生这厢有礼。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "你有礼，老身无礼。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "张嘴吃了老身不成？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "我这里与她赔礼，她的气越发大了。小娘子在那里指天画地，莫非叫我与她母 亲下上一跪么？吓，我是公子！我是秀才！岂肯与她下跪？哎跪不得，跪不得。 哎吓，事到如今，说的什么公子、秀才，我就是他娘的举人、进士，我也要 下她一跪，也就完了。 吓妈妈，休要动怒，学生这里跪下了。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "你住了罢！方才你说是公子，又是秀才，你与我娘下跪，岂不是想折死我母亲 么？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "哎吓，一个人在为难之处，你在一旁打搅。你再要打搅……"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "我这一条腿也就跪下了。"
        },
        {
          "character": "桂娟",
          "type": "白",
          "text": "我这里奉陪。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "你们来看，他们油盐酱醋，合了味了。"
        },
        {
          "character": "老妇",
          "type": "西皮摇板",
          "text": "他二人见了面双膝下跪， 倒叫我大张口无有话言。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "先前提亲为何不允？"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "山遥路远，拿礼不便。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "不用财礼，对着老身一拜。"
        },
        {
          "character": "张子显",
          "type": "白",
          "text": "多谢妈妈！"
        },
        {
          "character": "张子显",
          "type": "西皮快板",
          "text": "多谢妈妈许姻缘， 子显才把心放宽。 小娘子请过来拜天地， 拜完了天地了姻缘。"
        },
        {
          "character": "老妇",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张子显、桂娟、老妇同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}