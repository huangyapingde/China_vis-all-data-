{
  "script_id": "01016009",
  "title": "大锯缸",
  "alias": [
    "大补缸；一名：王家庄；一名：百草山"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "王大娘",
      "hangdang": "武旦"
    },
    {
      "name": "土地",
      "hangdang": "丑"
    },
    {
      "name": "大鹏",
      "hangdang": "净"
    },
    {
      "name": "青狮",
      "hangdang": "净"
    },
    {
      "name": "白象",
      "hangdang": "净"
    }
  ],
  "plot": "有王家庄王大娘者，当是旱魃之化身，神通极广，藏有黄磁缸一只，能大能小，能隐能显，用以抵挡雷劫，\n称为宝贝。即取死人之噎食管，磨炼而成，已为巨灵神撞破。白衣观世音菩萨，欲援生灵于涂炭，以达大慈\n大悲救苦救难之目的，遣土地神变作补锅匠，为之修理，故意失手，击成粉碎。而菩萨遂施展佛法，召集天\n神天将以除之。",
  "notes": "人死不腐，谓之僵尸，亦能走动，顾有魄无魂，性灵汨没，无知识之可言，每于深夜赶逐行人。所以村落之\n间，出现一僵尸，人皆视为畏途。然僵尸伹循直径，不知曲折，若陡然相遇，尽可转弯抹角以趋避之，其为\n害犹小。惟感受日月之精华，久而久之，僵尸即成旱魃。有此恶怪，天从此大旱不雨。年岁荒歉，荼毒一方\n人民。并且变化莫测，或幻形为女子以吸人精髓，其为害甚大。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四云童、观音同上。〖点绛唇〗。"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "吾乃，白衣观世音是也。只因此地，有旱魃为虐，扰害黎民，不免遣土地前去， 收服此怪。 天灵灵，地灵灵，当方土地何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "念",
          "text": "我本一小仙，保佑地方安。忽听菩萨唤，急忙到跟前。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "菩萨见召，有何法谕？"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "今有王家庄，妖魔作乱，伤害黎民。命你前去，将他的宝贝打破，不得有误。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "领法谕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "观音、四云童、土地同下。土地上。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "奉了菩萨之谕，前去降妖。待我变一固炉儿前去。一变，二变，固炉出现。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地换衣。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "无有担子，如何是好？不免将拐杖变来。急令勅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火彩。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "担子已有，就此前往。"
        },
        {
          "character": "土地",
          "type": "唢呐小调",
          "text": "有固炉儿出庙堂， 挑起担子走四方。 今日不上别处去， 一心要上王家庄。 王家庄有一个王员外， 他家有三个好姑娘。 大姑娘生来是个秃子， 二姑娘头上溜油光。 就算三姑娘头发好， 当中无毛四面光。 正走之间来得快， 不觉到了王家庄。 担子放在十字路口， 㕭货声锯盘子锯碗，锯大缸。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "固炉锅哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王大娘上。"
        },
        {
          "character": "王大娘",
          "type": "唢呐小调",
          "text": "王大娘正在房中坐， 忽听门外闹攘攘。 用手开开门来看， 只见固炉在街旁。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "固炉锅哟！"
        },
        {
          "character": "王大娘",
          "type": "唢呐小调",
          "text": "迈步出门开言道， 叫声固炉儿听端详： 昨日我打了个黄磁罐， 今日又摔了一个腌菜缸。 你若与我锯得好， 快把价钱来商量。"
        },
        {
          "character": "土地",
          "type": "唢呐小调",
          "text": "固炉一听心欢喜， 才出门来就要开张。 不要你多来不要你少， 铜钱只要你五百双。"
        },
        {
          "character": "王大娘",
          "type": "唢呐小调",
          "text": "不给你多来不给你少， 给你大钱一百双。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "你给一百双，是二百钱。好，就开开张。拿出来罢。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "拿什么呀？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "拿你的缸来呀。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "待我拿去。 你看看罢。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "嗳唷，是一个破的呀！"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你好混蛋呐！要是个整的，还叫你锯什么呀？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "这可是费锯子不少。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你看这个地方，锯上一道锯子。这块，再包上一个叶子。这儿，再钉上你妈那 巴子。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "一道锯子，一个叶子，还钉上你妈那巴子。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你妈那巴子。你把担子挑进来，就在门里头做罢。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "好，我就这么办罢。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "我说你看什么呀？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "我常听人说，王家庄有一个王大娘，不知道在哪里住呀？"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你问王大娘吓，不才就是我。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "怎么就是你能吗？"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "人家都说王大娘，长得又丢丢，又勾勾。今个我这么一看，好比王胖子的裤腰 带——稀松又平常。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你别见笑，今天是我起来太晚啦，头也靡有梳，脚也靡有裹，脸也靡有洗，衣 裳也靡有换。你且在这里做你的活，我到后面梳洗梳洗，打扮打扮，叫你也开 开左鼻子右眼睛。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "好好，你去罢。我今天倒真要开开眼界。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "咱们回来见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王大娘下。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "哈哈，看她去打扮去啦，我不免做起活来。"
        },
        {
          "character": "土地",
          "type": "唢呐小调",
          "text": "固炉急忙把活做， 想起当年事一桩。 自幼生来命儿苦， 不幸父母早双亡。 留下我弟兄有三个， 三人贸易俱经商。 大哥开了个剃头铺， 二哥修脚带开澡堂。 惟有我的生意苦， 每日挑担子在街坊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王大娘换衣暗上，坐。"
        },
        {
          "character": "土地",
          "type": "唢呐小调",
          "text": "固炉正在把活做， 又听得高低响叮当。 急忙回头来观看， 大娘梳洗出绣房。 走路好似风摆柳， 扭扭捏捏赛过海棠。 苏州香粉擦满面， 朱红胭脂点在唇上。 头上青丝挽螺髻， 挑腮杏脸好风光。 身穿一件绣花袄， 八幅罗裙绣着鸳鸯。 腰间紧系绫罗带， 金莲只有三寸长。 固炉越看越爱看， 手里锤子着了忙。 不觉一时失了手， 走了锤子离了缸。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你怎么不锯啦？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "破啦。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "呵，破啦。我也知道是破啦。你这个手艺是同你师妈学得吗？你给我说好听的 罢！"
        },
        {
          "character": "土地",
          "type": "唢呐小调",
          "text": "固炉这里开言道， 尊声大娘听端详： 大娘且慢别生气， 我打破旧缸赔新缸。"
        },
        {
          "character": "王大娘",
          "type": "唢呐小调",
          "text": "新缸靡有我旧缸好， 哪有我旧缸腌菜香。"
        },
        {
          "character": "土地",
          "type": "唢呐小调",
          "text": "固炉一见事不好， 今天一定要闹饥荒。 左思右想无主意， 我挑起担子走他娘。"
        },
        {
          "character": "王大娘",
          "type": "唢呐小调",
          "text": "叫声小子往哪里走， 看你怎么对付老娘？ 我今与你拼了罢， 担子翻在了大街旁。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "好啦，你这可赔我罢。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "我赔你什么呀？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "你看看，白花花，洒了一地金刚钻。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "一地是多少呀？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "一升零一把。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你滚毬开罢！你要有他妈得那么些金刚钻，你也不当小炉匠啦！"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "闲话少说，你看怎么办罢？"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "怎么办？今个你就走不了了。要叫你试试我的厉害。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "你有什么厉害呀？"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你是不知道呀？你打听打听，东庄到西庄，南庄到北庄，谁不知道，我是著名 的一个雌老虎。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "你也不好打听打听大太爷，我是谁？"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "你是个什么奏得？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "我是有名的公老虎。巧啦，我今天单玩你这雌老虎。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "小子你等着老娘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王大娘脱衣持棍。"
        },
        {
          "character": "王大娘",
          "type": "白",
          "text": "我今个非毁你不可！"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "好，她拿出兵器来啦。有了，我就拿我这根扁担。 你来罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王大娘、土地对打。土地戳王大娘裆，王大娘倒。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "看看你这个雌老虎，禁不住戳，一戳就完啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王大娘起，入帐子。现出妖形，打。土地下。妖形追下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四云童、观音同上。土地上。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "启菩萨：妖魔宝贝，已被小仙打碎，但是她十分厉害，小仙道法不高，难以收 服。"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "归位去罢。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "谢菩萨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地下。观音转场。"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "天灵灵，地灵灵，三弟子速现。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四风旗、四天将、大鹏、青狮、白象同上。〖点绛唇〗。"
        },
        {
          "character": "大鹏",
          "type": "白",
          "text": "吾乃大鹏金翅大仙是也。"
        },
        {
          "character": "青狮",
          "type": "白",
          "text": "青狮大仙是也。"
        },
        {
          "character": "白象",
          "type": "白",
          "text": "白象大仙是也。"
        },
        {
          "character": "大鹏",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "青狮、白象",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "大鹏",
          "type": "白",
          "text": "菩萨见召，一同驾云前往。"
        },
        {
          "character": "青狮、白象",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。四风旗、四天将、大鹏、青狮、白象同大转场。"
        },
        {
          "character": "大鹏、青狮、白象",
          "type": "同白",
          "text": "菩萨在上，弟子稽首。"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "今有旱魃扰害黎民，速速降妖者。"
        },
        {
          "character": "大鹏、青狮、白象",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "观音、四云童同下。四风旗、八怪、王大娘同上。对阵，起打，十二股荡，四连环。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王大娘打出手。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "锞子，攒摆阵。王大娘被擒，众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}