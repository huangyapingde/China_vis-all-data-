        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "常山赵云。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "收兵，收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、司马懿、司马师、司马昭同下。四上手、赵云同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、司马懿、司马师、司马昭同上。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "呸呸！我说是实城，你们说是空城。那赵云从天上掉下来的不成？"
        },
        {
          "character": "司马昭",
          "type": "白",
