        },
        {
          "character": "关羽",
          "type": "白",
          "text": "外面何人讲话？"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "小人胡班。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "进前答话。"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "咋。 叩见将军。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "小人名叫胡班。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "敢么是许都城外，胡华之子么？"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "现有你父亲书信在此，拿去看来。"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "嗳呀，倘若我一时莽撞，险些误杀忠良。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此话从何而起？"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "启将军：今有太守王植，叫俺用柴薪，围住驿馆，欲将将军，烧死在内。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "如此待某速速脱逃。"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "待我前去叫关，将军你要快快前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡班下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马童走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "保定车辆，速速出城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡班上。"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "开关！ （关羽引甘夫人、糜夫人、马童同上，同出关，同下。四龙套、四上手、王植同追上，同下。关羽上，王植 追上。）"
        },
        {
          "character": "王植",
          "type": "白",
          "text": "将军为何不辞而别？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽杀王植，王植下，关羽下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、秦琪同上。"
        },
        {
          "character": "秦琪",
          "type": "白",
          "text": "俺，秦琪。奉了夏侯将军之令，把守黄河渡口。 众将官，黄河去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马童、甘夫人、糜夫人、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "挂印封金辞丞相， 保定皇嫂出许昌。 东岭关孔秀将某挡， 在某剑下一命亡。 韩福、孟坦两员将， 被某刀劈在疆场。 卞喜贼，起不良， 镇国寺中暗埋藏。 多亏了普净禅师对我讲， 剑劈卞喜离祸殃。 可恨王植狗贼党， 他要焚烧我关云长。 胡班送信出罗网， 杀却王植出荣阳。 人来与爷往前闯， 看是何人到战场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、秦琪同上。"
        },
        {
          "character": "秦琪",
          "type": "白",
          "text": "来者敢是关公？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "秦琪",
          "type": "白",
          "text": "你意将何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "河北寻兄，要请将军，备我船只。"
        },
        {
          "character": "秦琪",
          "type": "白",
          "text": "船只到有，必须一件。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "秦琪",
          "type": "白",
          "text": "丞相路引。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺不受丞相节制，焉有路引？"
        },
        {
          "character": "秦琪",
          "type": "白",
          "text": "无有路引，定要将你拿下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你可知一路之上，我过关之事么？"
        },
        {
          "character": "秦琪",
          "type": "白",
          "text": "他等皆是无用之辈。今遇你秦爷，休想活命。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽杀死秦琪。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "秦琪出言太狂妄， 怒恼豪杰关云长。 过五关斩却了六员上将， 关某名儿万古扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
