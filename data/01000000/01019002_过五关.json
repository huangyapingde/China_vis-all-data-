        {
          "character": null,
          "type": "stage",
          "text": "胡班上。"
        },
        {
          "character": "胡班",
          "type": "念",
          "text": "闻听太守唤，急忙到跟前。"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "参见太守。"
        },
        {
          "character": "王植",
          "type": "白",
          "text": "罢了。今有关公，来到荣阳，我将他接进关来，请他在驿馆安歇。命你准备干 柴苇草，将驿馆围定，三更时分，放起火来，将他活活烧死，不得违误。"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡班下。"
        },
        {
          "character": "王植",
          "type": "白",
          "text": "来，出关去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童、甘夫人、糜夫人、关羽同上。"
        },
        {
          "character": "王植",
          "type": "白",
          "text": "关将军到此，请至驿馆一叙。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "到此就要讨扰。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同转场，同下。"
        }
      ]
    },
    {
