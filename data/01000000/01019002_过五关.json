    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军、王植同上。"
        },
        {
          "character": "王植",
          "type": "念",
          "text": "辕门战鼓响，儿郎报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启爷：今有关公，连闯三关，斩了四将，已到荣阳来了。"
        },
        {
          "character": "王植",
          "type": "白",
          "text": "再探。 胆大关公，擅敢闯过三关，连斩四将，这便如何是好，我自有道理。 来！"
