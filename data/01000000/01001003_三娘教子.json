{
  "script_id": "01001003",
  "title": "三娘教子",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "王春娥",
      "hangdang": "旦"
    },
    {
      "name": "薛保",
      "hangdang": "外"
    },
    {
      "name": "薛倚哥",
      "hangdang": "小生"
    }
  ],
  "plot": "明代，儒生薛广，往镇江营业。家中有妻张氏，妾刘氏、王氏。刘氏生一子，乳名倚哥。又有老仆薛保。薛\n广在镇江，适遇同乡人，以白金五百两，托带回家。不料其人吞没白金，购一空棺，停厝荒郊，以为薛广灵\n柩，回乡报知张氏等，举室嚎啕，使薛保运回灵柩安葬。后家渐衰落，张、刘不能耐贫，先后改嫁。三娘王\n氏深鄙之，誓与薛保茹苦含辛，抚养倚哥，送之入学，己则织布以易升斗之栗。倚哥在学堂被同学讥为无母\n之儿，气愤回家，遂不认三娘为母，语语挺撞，三娘怒不可遏，将刀立断机布，以示决绝。幸薛保竭诚劝导，\n母子始和好如初。",
  "notes": "前在丹桂听孙菊仙小子和小黎青合唱此剧，唱做俱妙，无懈可击，生平最为惬意。孙菊仙去薛保，白口至\n“三娘”二字，声若洪钟，有石破天惊之概。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王春娥上。"
        },
        {
          "character": "王春娥",
          "type": "引子",
          "text": "守冰霜贞节为本，效寡居教子成名。"
        },
        {
          "character": "王春娥",
          "type": "念",
          "text": "可叹儿夫丧镇江，每日织机度日光。但愿我儿龙虎榜，留下美名万古扬。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "奴家，王氏春娥。配夫薛广，去往镇江贸易，不想命丧镇江，多亏薛保搬尸回 来，可恨张、刘二氏，见儿夫一死，一个个另行改嫁。是我对天洪誓大愿，永 不改嫁，抚养前房之子，取名倚哥，南学攻书去了。我不免机房织绢便了。正 是："
        },
        {
          "character": "王春娥",
          "type": "念",
          "text": "云雾不知天早晚，雪深哪知路高低。"
        },
        {
          "character": "王春娥",
          "type": "二黄慢板",
          "text": "王春娥坐草堂自思自叹， 思想起我儿夫好不惨然。 遭不幸薛郎夫镇江命染， 多亏了老薛保搬尸回还。 奴好比南来雁失群无伴， 奴好比破梨花不能团圆。 薛倚儿好一似无弓之箭， 老薛保好一似浪里舟船。 将身儿来至在机房织绢， 等候了我的儿转回家园。"
        },
        {
          "character": "薛倚哥",
          "type": "内白",
          "text": "走吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛倚哥上。"
        },
        {
          "character": "薛倚哥",
          "type": "二黄原板",
          "text": "有薛倚在学中来把书念， 怀抱着圣贤书转回家园。 众学友一个个说长道短， 他道我无娘亲好不惨然。 因此上回家去——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛保上。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "这般时候，还不见东人回来，待老奴外面看来。"
        },
        {
          "character": "薛倚哥",
          "type": "二黄原板",
          "text": "与母争辩， 又只见老薛保站立门前。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "参见薛保。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "东人回来了。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "回来呢。我妈呢？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "你母亲在机房织绢。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "带我去见。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "且慢，随老奴后面用饭。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "见过我妈，再吃饭。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "你就要来吓。"
        },
        {
          "character": "薛保",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "就来的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛保下。"
        },
        {
          "character": "薛倚哥",
          "type": "二黄原板",
          "text": "听说是我母亲机房织绢， 走上前施一礼儿见母安。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "参见母亲。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "罢了。儿吓，回来了？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "回来呢。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "为何今日下学甚早？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "先生不在学中，故而回来甚早。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "那书来背。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "妈吓，吃完了饭在背书。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "背了书再去用饭。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "要背就得背。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "将脸朝外。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "背吓。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "妈吓，我忘了书尾。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "自有忘了书头，哪有忘了书尾的道理？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "不错，忘了书头了。妈吓，你提我一句。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "“曾子曰：‘吾日三省吾身。’”"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "“曾子曰：‘吾日三省吾身。’”"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "“为……”"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "妈吓，咱们家里为什么？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "“为人谋面不忠乎？”"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "哦，“为人谋面不忠乎？”唬唬唬，香炉瓦灯唤唤呵唬。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "往下背。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "往下背。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "叫你往下背。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "叫你往下背。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "咀。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "咀。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "指望儿在学中攻读，谁想儿在外面贪顽，贪顽不知紧要，岂不误了儿的青春年 少。还不与我跪了。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "要跪就得跪。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "畜生吓！"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "畜生吓！"
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
          "text": "小奴才不读书把娘气坏， 有几个年幼人儿且听来。 秦甘罗十二岁身为太宰， 石敬塘十三岁拜帅登台。 三国中周公瑾名扬四海， 七岁上学道法人称将才。 十三岁在东吴挂印为帅， 烧曹兵八十三无处葬埋。 那都是父母养非神下降， 难道说小奴才禽兽投胎？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "也罢。"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "手执家法将儿来打，"
        },
        {
          "character": "薛倚哥",
          "type": "二黄摇板",
          "text": "你打别人孩儿好不害羞。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "妈吓，你要打，生一个打，养一个打。你打别人的孩儿，好不害羞，好不害臊。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "儿吓，这两句话，哪个教道与你？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "饭也会吃，书也会念，这两句话，还不会说么？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "话倒是两句好话，可惜儿太讲迟了。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "你今天不打我，我还不说呢。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "哎，天吓！"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "哎，地吓！白相去哉。"
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
          "text": "小奴才一言问住了我， 闭口无言王氏春娥。 叫一声薛郎夫阴曹等我， 等候了你的妻同见阎罗， 我那薛郎夫吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛保上。"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "小东人下学来机房闯祸， 好一似火上又把油泼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王春娥哭。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "三主母在机房啼哭闷坐， 转面来问一声东人一个。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "东人。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "干什么？"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "你的母教训你非为之过， 为什么将好言当作了恶说， 东人哪……"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "你少管我们家里闲事。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "嗳……"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "这才是养子不教父之过， 教不严来师之惰。 老薛保进机房双膝跪落，双膝跪落，"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘吓……"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "问三娘发雷霆却是为何？"
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
          "text": "老薛保你不必苦苦哀告， 三娘言来细听根苗： 自古道养娇儿终身有靠， 又谁知小奴才平日无故，半路途中，跌了奴一跤。"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "劝三娘休得要珠泪双掉， 老奴言来细听根苗： 千看万看，看东人年纪小， 望三娘念东人下世早， 只留下这一根苗，必须要轻打轻责，饶恕他一遭，下次不饶。"
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
          "text": "你道他年纪小，心不小， 说出话来雅赛铜刀。 自古道，人无有千日好， 花开哪有百日姣？ 织什么机来把什么子教，"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "也罢，"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘忍耐了吧！"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "割断了机头两开交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王春娥哭。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "见三娘怒冲冲把机头割断， 吓得我老薛保胆战心寒。 走上前来好言相劝， 尊一声三主母细听根源： 都只为老东人镇江命染， 是老奴千山万水，万水千山，搬尸回还。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "老奴好恨！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "恨着何来？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘，"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "恨只恨张、刘二氏，他把心肠改变， 一个个反穿罗裙另嫁夫郎。"
        },
        {
          "character": "王春娥",
          "type": "哭",
          "text": "哎呀……"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "老奴好喜！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘，"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "喜只喜三主母发下洪誓大愿， 你言道永不改嫁教训儿郎。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "哎呀……"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘不言，老奴明白了。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "明白何来？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘，"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "莫不是见那张、刘二氏心肠改变， 你也要反穿罗裙另嫁夫郎？"
        },
        {
          "character": "王春娥",
          "type": "哭",
          "text": "哎呀……"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘你要走只管走，你要嫁只管嫁。"
        },
        {
          "character": "王春娥",
          "type": "哭",
          "text": "哎呀……"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "留下了老的老，小的小，在沿门讨饭， 我也要扶养他薛门中后代香烟， 哦，哦，哦，好不明白的三娘吓……"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "我哭，哭一声老薛保， 叫，叫一声老掌家。 都只为小奴才下学甚早， 我叫他拿书来背，他一字也不晓。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘就该打。"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "手执家法未曾打下， 他，"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "他讲些什么？"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "他，他，他，他言道我不是他的亲娘。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘忍耐了吧！"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "啊啊啊……老掌家……"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "听罢言来才知情， 回头埋怨小东人。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "东人这里来。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "干什么？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "这就是你的不是了。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "你们两个人唱的半天，怎么我的不是？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "你下学回来，一言冒犯你母亲，就该上前，领责才是。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "什么叫“领责”？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "就是挨打。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "挨打疼不疼？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "焉有不疼之理？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "你晓得疼，你替我去挨罢。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "哎呀，东人哪，去与不去，但凭与你。将老奴推倒在地，倘有不测，看你母子 怎生得了？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "哦吓，你的唱功不好，做功倒不错。你不要哭，我去就是了。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "待老奴教道于你。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "你教于我。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "现有家法在此，顶在头上，跪在你母亲面前，你就言道：“母亲吓母亲，孩儿 下学回来，一言冒犯母亲，现有家法在此，望母亲高高举起，轻轻落下；打儿 一下，如同十下；打儿十下，如同百下；打在儿身，痛在娘心。”你母亲有爱 子之意，她就不打你了。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "这两句话我会呢。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "东人回来。你母亲问你，就说你自己讲的，不要说老奴教道于你。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "我晓得了。 孩儿下学回来，一言冒犯母亲，现有家法在此，望母亲高高举起，轻轻落下； 打儿一下，如同十下；打儿十下，如同百下；打在儿身，痛在娘心。娘吓，你 饶了我吧！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "儿吓，你早有这两句话，免得为娘一场恶气。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "娘吓，这话不是我会说的，是老薛保教与我的。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘，老奴跪下了。"
        },
        {
          "character": "王春娥",
          "type": "二黄快三眼",
          "text": "老薛保你莫跪一旁立站，"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "多谢三娘。"
        },
        {
          "character": "王春娥",
          "type": "二黄快三眼",
          "text": "骂一声小奴才细听娘言："
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
          "text": "遭不幸儿的父镇江命染， 多亏了老薛保搬尸回还。 有为娘不改嫁为的哪个？ 都只为儿年小，他年老，儿小他老，他老儿小，无依无靠，娘心不安。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘教训了罢。"
        },
        {
          "character": "王春娥",
          "type": "二黄慢板",
          "text": "手执家法将儿来管，"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "老薛保向前忙遮拦。 你要打将老奴责打几下， 你，你，你，你要打我的小东人，老奴心酸。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "老薛保只哭得我心好惨， 他主仆的恩情重如山。 走上前来用手搀，"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "儿吓，"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "从今后读书不要贪玩。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "着吓！"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "我的儿好好的把书来念，"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "要做高官有何难？"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "但愿得我的儿鳌头来占，"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘，"
        },
        {
          "character": "薛保",
          "type": "二黄摇板",
          "text": "三娘教子万古传。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "薛保，我儿，来吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王春娥、薛保、薛倚哥同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}