        {
          "character": "邓伯道",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "母亲。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "哥哥！罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道、邓方同下。风旗引金氏同上。"
        },
        {
          "character": "金氏",
          "type": "二黄导板",
          "text": "遇贼兵吓得我灵魂不在，"
        },
        {
          "character": "金氏",
          "type": "三叫头",
          "text": "大伯！邓元！邓方，我的儿吓！"
