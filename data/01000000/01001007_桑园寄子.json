        {
          "character": "金氏",
          "type": "白",
          "text": "说过不用拜了。"
        },
        {
          "character": "邓元",
          "type": "二黄摇板",
          "text": "儿谨遵婶母命怎敢达坳， 双膝里跪尘埃珠泪两行。 从今后儿就是婶母亲养， 久以后儿成名不忘我娘。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "儿吓，"
        },
        {
          "character": "金氏",
          "type": "二黄摇板",
          "text": "我的儿后话休要讲， 快快地逃走免遭祸殃。 金命土命走为上， 再遇贼兵命必亡。 奔到潼关把心放， 见了你母舅再作商量。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "邓元。"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "母亲。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "我儿快走。"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "快走快走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金氏、邓元同下。"
        },
        {
          "character": null,
