        {
          "character": "金氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "金氏",
          "type": "二黄摇板",
          "text": "见血书果然真悲伤， 衣衾上写的是血气红光。 字行行大伯的笔迹在上， 舍亲生救侄儿万古流芳。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "吓，儿吓，为婶母，将你收在身旁，以为己子，逃往你母舅那里安身，不知你 意下如何？"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "母亲请上，受儿一拜。"
