{
  "script_id": "01001007",
  "title": "桑园寄子",
  "alias": [
    "黑水国"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "邓伯道",
      "hangdang": "老生"
    },
    {
      "name": "金氏",
      "hangdang": "旦"
    }
  ],
  "plot": "晋，黑水国石勒造反，扰乱中原。邓伯道携弟妇及一子一侄，出奔避难，投至戚潼关守将金水成。不料中途\n弟妇被乱兵冲散，只余子侄相随。邓伯道年老，子侄又弱，不能行路，求邓伯道背负。邓伯道负子则侄号泣；\n负侄则子啼哭，左右为难，既而慨然曰：弟死妇亡，并此孤侄而不保，何以对死者。乃决计弃子携侄。路\n过桑园，唤子采桑椹，遂以带缚之于树，咬指血书置其怀，始含泪负侄而去。适其弟妇过桑园，见侄紧于树，\n急解之下，携至潼关，一家仍得团聚。",
  "notes": "然正史所载，邓伯道之子竟失去，故曰：天道无知，使伯道无儿。此剧情节离奇，神情悲惨，能使观者悲喜\n交加，感激涕零，油然起骨肉之感，诚有功世道人心之剧也。\n孙菊仙、小连生合演是剧，可谓四美具二难并矣。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道上。"
        },
        {
          "character": "邓伯道",
          "type": "引子",
          "text": "兄弟丧了命，倒叫我，好不伤心。"
        },
        {
          "character": "邓伯道",
          "type": "念",
          "text": "人生在世几度秋，好似杨花水上浮。有朝一日狂风起，大限来时一笔勾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家院自两边分上。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "老汉邓伯道。兄弟伯俭，中年丧命，撇下邓方孩儿，无人教训。今当周年之期， 备定祭礼，带领两个孩儿，去到坟前一祭，以表手足之情。 来，"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "有请二位少爷。"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "有请二位少爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓元、邓方同上。"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "邓元",
          "type": "念",
          "text": "学中习孔孟，"
        },
        {
          "character": "邓方",
          "type": "念",
          "text": "何日得成名。"
        },
        {
          "character": "邓元、邓方",
          "type": "同白",
          "text": "参见（爹爹）（伯父）。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "邓元、邓方",
          "type": "同白",
          "text": "唤儿出来，有何训教？"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "今当你爹爹，周年之期，备定祭礼，带领你弟兄二人，去到坟前一祭。"
        },
        {
          "character": "邓元、邓方",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "来，"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "吩咐祭礼抬上。"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "祭礼拾上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍抬祭礼自两边分上。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "嗳，兄弟吓！"
        },
        {
          "character": "邓伯道",
          "type": "二黄慢板",
          "text": "叹兄弟遭不幸中年丧命， 撇下了年幼儿好不伤情。 眼望着孤坟台心痛难忍， 见坎台不见弟刀刺我心。"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "来此坟台。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "祭礼摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家院同摆祭礼，同下，四青袍同下。"
        },
        {
          "character": "邓伯道",
          "type": "叫头",
          "text": "兄弟吓，伯俭！"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "今当你周年之期，备定祭礼，带领两个孩儿，前来祭奠与你，以表你我手足之 情。"
        },
        {
          "character": "邓伯道",
          "type": "三叫头",
          "text": "兄弟！伯俭！兄弟吓！"
        },
        {
          "character": "邓伯道",
          "type": "二黄导板",
          "text": "见坟台不由人珠泪滚滚，"
        },
        {
          "character": "邓伯道",
          "type": "三叫头",
          "text": "兄弟，伯俭，兄弟吓！"
        },
        {
          "character": "邓伯道",
          "type": "回龙",
          "text": "到叫我年迈兄好不伤情！"
        },
        {
          "character": "邓伯道",
          "type": "二黄原板",
          "text": "你在世弟兄们一家欢庆， 共商量做计较家业同兴。 好端端得疾病一旦丧命，一旦丧命，兄弟吓！ 似黄土埋却了无价的宝珍。"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "叔父！"
        },
        {
          "character": "邓元",
          "type": "二黄原板",
          "text": "见爹爹只哭得昏迷不醒， 叫一声我叔父细听分明： 你死在九泉下好不安静， 撇下了我兄弟依靠何人？"
        },
        {
          "character": "邓方",
          "type": "三叫头",
          "text": "爹爹，我父，爹爹吓！"
        },
        {
          "character": "邓方",
          "type": "二黄导板",
          "text": "在坟前不由我珠泪难忍，"
        },
        {
          "character": "邓方",
          "type": "三叫头",
          "text": "爹爹，我父，爹爹吓！"
        },
        {
          "character": "邓方",
          "type": "二黄原板",
          "text": "见坟台不见儿疼儿爹尊。 你死在九泉下好不安静， 撇下了我母子依靠何人？"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "咳，爹爹，我要我的叔父。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哦，儿要儿的叔父么？"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "那里面就是儿的叔父，你去叫吓！"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "叔父吓，叔父，侄儿在此叫你！你是怎的不言，怎的不语？"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "嗳，伯父，我要我的爹爹。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哦，儿要儿的爹爹么？"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "那里面就是儿的爹爹，你去叫他出来吓！"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "爹爹吓，爹爹，孩儿在此叫你！你是怎的不言，怎的不语？"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "兄弟吓，伯俭，这两个孩儿，在此叫你，你是怎的不言，怎的不语？莫非你聋 了，你哑了，你你你睡死了？"
        },
        {
          "character": "邓伯道",
          "type": "二黄摇板",
          "text": "这一个要叔父心痛难忍， 那一个要爹爹刀刺我心。 望贤弟在阴曹慢慢相等， 等候了你的兄一路同行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二家院同上。"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "启禀员外：大事不好了！"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "今有黑水国造反，逢州夺州，遇县抢县，看看杀到我庄来了！"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哎呀，这才是福不双降，祸不单行！ 儿吓，犹恐你母亲在家悬望，我们快快回去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金氏上。"
        },
        {
          "character": "金氏",
          "type": "二黄摇板",
          "text": "遭不幸我官人一旦丧命， 撇下奴每日里独守孤灯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二家院、邓元、邓方、邓伯道同上。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "大伯伯回来了。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "弟妇，大事不好了！"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "今有黑水国造反，逢州夺州，遇县抢县，看看杀到我庄来了！"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "金氏",
          "type": "二黄摇板",
          "text": "听说是黑水国兴兵犯境， 眼见得一家人四下离分。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "大伯伯，何不收拾收拾，逃往潼关我兄弟那里，安身才是。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "好，后面收拾收拾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金氏、邓元、邓方同下。"
        },
        {
          "character": "邓伯道",
          "type": "叫头",
          "text": "众家丁！"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "今有黑水国造反，看看杀到我庄。我带领二东人，前去逃命。将这万贯家财， 付与你等掌管。倘若贼兵不到此地，我回来将这家财，与你等平分一半；倘若 贼兵到此，你们各自逃命去罢。"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "哦呵，员外，将这万贯家财，交与我等执掌，料然无事。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "好，真乃忠义之士。改扮起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道换衣衾。金氏、邓元、邓方同上。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "众家丁，你等请上，受我全家一拜！"
        },
        {
          "character": "邓伯道",
          "type": "二黄摇板",
          "text": "一家人跪草堂珠泪滚滚， 尊一声众家丁细听分明： 都只为黑水国兴兵犯境， 我带着二东人前去逃生。 但愿得他贼兵不到此境， 我回来将家财与尔等平分。 急忙忙说不尽衷肠话论，"
        },
        {
          "character": "邓伯道",
          "type": "三叫头",
          "text": "家丁！义仆！哎吓！"
        },
        {
          "character": "众家丁",
          "type": "同白",
          "text": "员外吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道、金氏、邓元、邓方同下。"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "嗳，列位，员外东人他们俱已去了，倘若贼兵到此，你我如何是好？"
        },
        {
          "character": "众家丁",
          "type": "同白",
          "text": "你我吃的饱饱的，关上了门，尽等窍辫子。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引番王同上。"
        },
        {
          "character": "番王",
          "type": "白",
          "text": "某，石勒。某家一路而来，斩关夺寨。前面已是文水县。 巴都鲁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "番王",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "邓元、邓方",
          "type": "内同白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道、金氏、邓元、邓方同上。"
        },
        {
          "character": "邓伯道",
          "type": "二黄摇板",
          "text": "走青山望白云，"
        },
        {
          "character": "邓方",
          "type": "二黄摇板",
          "text": "家乡何在？"
        },
        {
          "character": "金氏",
          "type": "二黄摇板",
          "text": "一家人逃性命哪顾家财。"
        },
        {
          "character": "邓伯道",
          "type": "二黄快三眼",
          "text": "山又高水又深无计何奈，"
        },
        {
          "character": "金氏",
          "type": "二黄慢板",
          "text": "道有草石有苔寸步难挨。"
        },
        {
          "character": "邓伯道",
          "type": "二黄原板",
          "text": "带姣儿手攀藤忙登出界，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道、金氏、邓元、邓方同上山。"
        },
        {
          "character": "金氏",
          "type": "二黄原板",
          "text": "走得我两腿痛珠泪满腮。"
        },
        {
          "character": "邓伯道",
          "type": "二黄原板",
          "text": "眼望见白茫茫何方地界？"
        },
        {
          "character": "金氏",
          "type": "二黄原板",
          "text": "何日里到潼关才放心怀。"
        },
        {
          "character": "邓伯道",
          "type": "二黄摇板",
          "text": "眼望见旌旗飘把人唬坏，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同上，逃离，番兵同追上，过场，众人同下。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哎呀，"
        },
        {
          "character": "邓伯道",
          "type": "二黄摇板",
          "text": "又只见众百姓逃离前来。 叫姣儿随定我切莫痴呆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "番兵自两边抄下。风旗引金氏同下，邓伯道、邓元、邓方同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道挽邓元、邓方同上。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "唬杀我也，唬杀我也！儿吓，你婶娘哪里去了？"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "不知去向。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "儿吓，你母亲哪里去了？"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "被贼兵抢了去了！"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "你待怎样？"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "抢了去了！"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哎吓，"
        },
        {
          "character": "邓伯道",
          "type": "二黄导板",
          "text": "听说是贼兵抢三魂不在，"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "邓元、邓方",
          "type": "同白",
          "text": "醒来！"
        },
        {
          "character": "邓伯道",
          "type": "二黄摇板",
          "text": "眼见得一家人四下分开。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "儿吓，谅那贼兵走之不远，我们快快赶上前去！"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "我哥哥不走了。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "儿吓，你为何不走？"
        },
        {
          "character": "邓元",
          "type": "白",
          "text": "孩儿两足疼痛，难以行走。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哦，你两足疼痛，难以行走？"
