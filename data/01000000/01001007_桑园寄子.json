        },
        {
          "character": "邓元",
          "type": "三叫头",
          "text": "我父！"
        },
        {
          "character": "邓伯道",
          "type": "三叫头",
          "text": "儿吓！"
        },
        {
          "character": "邓元",
          "type": "三叫头",
          "text": "爹爹吓……"
        },
        {
          "character": "邓伯道",
          "type": "二黄摇板",
          "text": "好一似刀割肉箭穿胸怀。 在腰中扯下了衣衾一块， 咬指尖心内痛珠泪满腮。 家住在太原省文水县界， 我的名邓伯道逃难前来。 舍亲生留侄儿传留后代， 也免得人道我老而无才。 将时辰和八字血书上代， 仁君子若救去胜似如来。 血书上写不尽阴德山海， 罢罢罢，叫侄儿急忙走开。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "儿吓，起来走。"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "我要我的哥哥了！"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哎呀，这小冤家要他哥哥，这便如何是好？ 儿吓，你母亲来了！"
        },
        {
          "character": "邓方",
          "type": "白",
          "text": "在哪里？"
