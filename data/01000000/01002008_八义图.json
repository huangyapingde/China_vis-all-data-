        {
          "character": "程婴",
          "type": "白",
          "text": "公孙兄，赵公子，你二人死在阴曹，休来怨我！"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "我躬身施礼忙拜定， 眼望孤儿两泪淋。 法场上看的人人恨， 个个叫骂我程婴。 我是个负义之人，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "锣鼓。"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "多道我享荣华富贵断送忠良后代根。 可怜我好心成歹意， 我这满腹含冤向谁明。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄原板",
          "text": "我见他说话不留神， 泄漏了机关事不成。 去掉了好言换恶语， 开言大骂小程婴： 你不过贪图受富贵， 断送忠良后代根！ 我今一死不要紧， 一桩桩一件件记在心！"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "公孙兄说话句句真， 口口指教我程婴。 我为孤儿丧了子， 你为孤儿伤残生。 我这里烧两把酒斟，"
        },
        {
          "character": "程婴",
          "type": "哭",
          "text": "公孙兄，我的亲……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴两边看。"
        },
        {
          "character": "程婴",
          "type": "哭",
          "text": "亲生的儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴敬酒三杯，烧纸钱。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "但愿灵魂早讨生。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "有请大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾上，四龙套同上。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "可曾祭过？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "已经祭过。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的。将孤儿与老狗，一齐开刀！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "好贼子呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼、四龙套同下。起鼓，四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "斩首已毕。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "起过了。 程婴，程婴！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "呀，你为何落下泪来？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人与他八拜之交，见他一死故而流泪。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "喔，是了。 来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "与程婴看赏。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "且慢，小人不愿领赏。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "为何愿不领赏？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人家中，现有一子，与孤儿同庚，怨怕旁人暗害我父子。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "将你儿子，保在老夫面前，料来无事。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "辞别大人回家门， 奸贼中了我的巧计生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "老夫的仇人俱杀尽， 这才是剪草又除根！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴抱孩儿上。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "但愿此子成大人， 赵家有了报仇人。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "眉清目秀天平满， 两儿垂肩是贵男。 老夫膝下无有后，"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "你就是我养老送死的男。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "程婴，你在老夫府中，吃碗安乐茶饭，并无人欺压于你。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "多谢大人！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的，打道回府。"
        },
        {
          "character": null,
          "type": "stage",
