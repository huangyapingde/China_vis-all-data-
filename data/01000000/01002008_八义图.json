      "utterances": [
        {
          "character": "公孙杵臼",
          "type": "内二黄导板",
          "text": "一片好心反成恨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼上。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄原板",
          "text": "年迈苍苍血染身。 将孤儿来在法场进， 咬定牙关等时辰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "手捧祭礼法场进， 只见孤儿与公孙。"
