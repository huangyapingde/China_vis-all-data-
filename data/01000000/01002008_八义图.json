{
  "script_id": "01002008",
  "title": "八义图",
  "alias": [
    "搜孤救孤；一名：程婴舍子"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "程婴",
      "hangdang": "老生"
    },
    {
      "name": "屠岸贾",
      "hangdang": "净"
    },
    {
      "name": "公孙杵臼",
      "hangdang": "外"
    },
    {
      "name": "程妻",
      "hangdang": "旦"
    }
  ],
  "plot": "春秋时，晋国有佞臣屠岸贾，景公宠之。屠岸贾与赵氏不睦，诬赵盾以弑君之罪，将赵氏抄斩。赵朔之妻，\n公之庶妹也，怀孕走入宫中，得免。后生赵武，托门客程婴、公孙杵臼，设法保护。屠岸贾为斩草除根计，\n严索孤儿。程婴适生子，公孙杵臼请将婴儿伪作孤儿，应屠岸贾索。程婴许之。公孙杵臼乃抱程婴子藏于首\n阳山边，嘱程婴出首。屠岸贾带校尉搜山，果得公孙杵臼及孤儿，立将孤儿掷死，又命程婴举鞭击公孙杵臼，\n以试虚实，以程婴与公孙杵臼，同为赵氏家客也。程婴忍泪痛击公孙杵臼，屠岸贾乃信，杀公孙杵臼。后\n景公崩，成公立，赵武为上卿，将屠岸贾剐戮。以报昔日之仇。赵武既成立，程婴乃自杀以报公孙杵臼。赵\n武感二客义侠，立位宗庙，配享祖先，所以报也。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼上。"
        },
        {
          "character": "公孙杵臼",
          "type": "引子",
          "text": "赵屠结怨恨，恨奸贼，何日罢休。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "老汉公孙杵臼，曾在赵家为门客。可恨屠贼，误杀赵家三百余口。只剩庄姬一 人，逃进宫去。闻得屠贼进宫搜孤，天呐天呐，看看忠良无救了。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "可恨屠贼太欺心， 误杀赵家一满门。 看看忠良无救应， 大事还要问程婴。"
        },
        {
          "character": "程婴",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "适才屠贼传一令， 要害晋国众儿孙。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "来此已是。 公孙兄在家么？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "哪一个？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小弟来了。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "请进。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "晋国之中，又出了一种奇事。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "什么奇事？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "屠贼进宫搜孤，未曾搜出孤儿，出下赏格在外：十日之内，有人献出孤儿，赏 赐千金；十日之内，若无孤儿下落，要将这晋国之中，与孤儿同庚者，斩尽杀 绝。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "愚兄早已知道，你的来意如何？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小弟来意，与公孙兄商议。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "愚兄慌忙无计。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "弟倒有计在此。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "你有何妙计？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "只要有人舍得一命，舍得一子，方能搭救孤儿。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "愚兄若大年纪，死亦何惧，情愿舍命，但不知何人舍子？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小弟家中，现有一子，与孤儿同庚，将我儿藏在你家，将孤儿掉换，倘若屠贼 前来搜寻，尤恐连累与你。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "弟妇可曾应允？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "你那弟妇那是贤德的。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "快快回去商议。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "告辞了。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "公孙兄且把心放定， 救孤之事我担承。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "但愿救得忠良后， 满斗焚香谢神灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程妻上。"
        },
        {
          "character": "程妻",
          "type": "引子",
          "text": "仗义救孤身，妻随夫志行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "大事安排定，劝妻舍亲生。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "官人回来了，请坐。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "有座。唉！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "官人，我想相国，忠心为国，爱民如子，反遭灭门大祸，眼见上天没有报应了！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "卑人也是这等讲，只是那贼又出了狠毒的心了！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "又出了什么狠毒的心？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "搜孤不出，有赏格在外：十日之内，有人献出孤儿便罢；若无人献出孤儿，要 将晋国中与孤儿同庚者，尽行斩绝。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "想屠贼如此的行事，只怕孤儿难保也！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "卑人有一两全之计，可以救得孤儿。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "有何两全之计？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "只要有人舍得一命，舍得一子，可以救得孤儿。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "何人能得舍命？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "就是公孙老爷，情愿舍命。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "还有何人舍子？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "乃是卑人许他……"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "许他什么？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "娘子，你我夫妻，受过赵相大恩，眼见孤儿无救。你我夫妻，所生一子，舍了 也罢，替换孤儿，也好接代赵氏门中后裔。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "官人此言差矣！你我所生一子，岂肯搭救他人，那是万万不能！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "娘子吓！"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "娘子不必太烈性， 卑人言来听分明： 赵屠二家结仇恨， 三百余口命归阴。 你今救得忠良后， 赵家代代感你的恩！"
        },
        {
          "character": "程妻",
          "type": "二黄原板",
          "text": "官人说话理虽顺， 妾身言来听分明： 你今有了五十整， 妾身也有四十春。 夫妻只生一个子， 怎肯舍子救他人？"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "卑人五十不算老， 娘子年纪倒还轻。 你今舍了亲生子， 来年必定降麒麟。"
        },
        {
          "character": "程妻",
          "type": "二黄原板",
          "text": "赵家犯罪赵家受， 为什么连累小姣生？"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "再三相劝她不应， 不舍子来孤难存。 没奈何只得忙跪定， 哀劝娘子舍亲生！"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "你要跪来你就跪， 叫我舍子万不能"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "常言道妇人心肠狠， 最毒不过妇人心！"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "又道是虎狼不食子， 你比虎狼狠十分！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "倒不如程婴死了罢！"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "或生或死一路行！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "手拿钢刀取你命，"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "用手带上小房门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程妻下。公孙杵臼上。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "又与程婴把计定， 不知他心与我心。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "来此已是，待我进去。 贤弟在家么？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "公孙兄来了，请坐。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "有座。弟妇可曾应允？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "这贱人执意不肯！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "请出弟妇，愚兄相劝。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "是。 娘子哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程妻上。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "来了，官人何事？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "公孙兄来了，上前见过。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "是。 公孙老爷万福！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "弟夫人来了，请坐。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "有座。公孙老爷，到此何事？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "弟夫人听你丈夫之言，舍了亲生之子，救得忠良之后。你今日舍了亲生子，来 年必定降祥麟。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄原板",
          "text": "人有善念天有神， 莫大阴功此时行。 弟妇舍了亲生子， 来年必定降祥麟。"
        },
        {
          "character": "程妻",
          "type": "二黄原板",
          "text": "公孙兄说话理难顺， 我夫妻吵的乱纷纷。 爱子搭救他人命， 要我舍子万不能！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "老汉的薄面情要准，"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "谁能舍子救他人？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "看起来你就是无义人"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "你要尽忠奴不行。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "手拿钢刀来自刎，"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "贤弟息怒慢稍停。 走上前来言相劝， 死了丈夫靠何人？"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "多口！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "啊吓！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "没奈何只得忙跪定， 哀求弟妇舍亲生！"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "他二人哭得珠泪滚， 铁石人儿也泪淋。 公孙老爷你请起， 奴家情愿舍亲生。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "多谢弟妇开了恩， 上得史书表得名！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "多谢娘子舍亲生， 你母子快快两离分。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "啊吓！"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "一句话儿错出唇， 把姣儿送在枉死城。 怀抱姣儿泪难忍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴抢子，程婴、程妻、公孙杵臼同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，屠岸贾上。"
        },
        {
          "character": "屠岸贾",
          "type": "念",
          "text": "斩草不除根，萌芽依旧生。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "老夫屠岸贾，前番进宫搜孤，未曾搜出孤儿。出下赏格在外：十日之内，有人 献出孤儿，赏赐千金。今当十日已满，不见孤儿下落。 校尉的伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上，击鼓。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有人击鼓。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "带进来。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "击鼓人上堂。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "来了。 参见大人。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "唗！为何擅击老夫堂鼓？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人有密言告禀。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "有何密言，当面讲来。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "这个……耳目甚众。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "两旁俱是老夫心腹之人，但讲何妨。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "前番大人进宫搜孤可曾搜出孤儿？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "未曾搜出。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "孤儿现在……"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "现在哪里？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "现在首阳山公孙杵臼家中。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的，去到首阳山将公孙杵臼拿来见我！"
        },
        {
          "character": "二龙套",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二龙套同下。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你怎么知道？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人与他曾在赵家以为门客，再三相劝，他执意不肯。恐怕牵连在内，前来出 首与你。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "可是实言？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "句句实言。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人叫程婴。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "站过一旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二龙套同上，公孙杵臼上。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "参见大人。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "唗！胆大老狗，隐藏孤儿，为何不报？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "小人隐藏孤儿，谁人得见？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "抬头观看。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "呵吓大人呐！他叫程婴。他与小人旧有仇恨，乃是诬告小人！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你在怎讲？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "诬告小人！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "听罢言来怒气升， 大骂老狗不是人！ 隐藏孤儿你不报， 论皇法就该问斩刑！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "白虎堂上禀一声， 尊声大人听分明： 只是程婴诬告我， 拿什么孤儿与大人？"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "白虎堂上开言问， 不动大刑不招认。 人来与我乱棍打，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同打公孙杵臼。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "打死小人不招承！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "回头便把程婴叫， 公堂赐你鞭一根。 一边打来一边问， 看他招承不招承！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "程婴",
          "type": "二黄导板",
          "text": "白虎门领了大人命，"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你与老夫重重的打！"
        },
        {
          "character": "程婴",
          "type": "二黄叠板",
          "text": "可怜他为孤儿到如今连累了他白发苍苍受苦情，倒叫我好不伤心！"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "背转身自思忖， 好似钢刀刺在心。 哪知道二人把计定， 连累白发丧残生。 使一个眼色把他问， 公孙老爷你且听： 你若说至死不招承， 大人的王法不任情。 手执皮鞭将你打， 打你，打你，你不要胡言乱语诬攀好人。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "好贼子吓！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "手指程婴骂高声， 你本忘恩负义人！ 我今一死不要紧，"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "贼吓，贼吓！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "阴曹地府等你魂！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "公孙老爷不招承， 首阳山前去搜寻！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "何不到他家中去寻找？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "打道首阳山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同滑门。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "来此首阳山。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "两厢搜来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同搜，抱孤儿上。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "唗！胆大的老狗！隔壁墙内，婴孩哪里来的？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "好贼子吓！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "贼子做事太欺心， 苦害忠良后代根。 舍死忘生把孤儿抢，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾踢公孙杵臼。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "一足踢你地埃尘！ 人来与我忙上捆，"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "这是你飞蛾投火自烧生。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的，将孤儿与老狗绑赴法场。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "好贼子吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二龙套、公孙杵臼同下。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人讨祭。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "为何讨祭？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人与他八拜之交，如不祭奠，岂不被天下人叫骂？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "容你一祭。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "多谢大人！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "准备祭礼黄粱饭， 一表当年故旧情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的，打道法场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾、二龙套同下。"
        }
      ]
    },
    {
      "scene_id": 4,
