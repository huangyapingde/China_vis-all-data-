{
  "script_id": "01034004",
  "title": "池水驿",
  "alias": [
    "奴主相会"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "殷碧莲",
      "hangdang": "花旦"
    },
    {
      "name": "倪厚",
      "hangdang": "小生"
    },
    {
      "name": "殷照磨",
      "hangdang": "老生"
    },
    {
      "name": "张润和",
      "hangdang": "丑"
    },
    {
      "name": "殷夫人",
      "hangdang": "老旦"
    }
  ],
  "plot": "自殷碧莲与其父殷照磨（官名）欲出潼关避婚，在少华山遇盗后，殷碧莲被抢，秋香失散，老主仆二人，求\n死不能，只得狼狈回家。其婿张润和已来上门抢过，见殷父女均不在，遂向殷夫人餂得确实，知已避赴潼关\n外。渠亦假惺惺，谓潼关道上多山寇，不能放心，即命张福立往探问云。惟殷照磨主仆则既归，而秋香失散\n以后，独身伶丁，颇尝辛苦，幸至池水驿，得遇店主人收留为女，暂作栖身，缓缓访问。一日，忽有少男女\n一对，前来池水驿下寓，秋香一见岂知即是殷碧莲，然不知彼同来之少年是谁。既而二人难分难离，少年则\n急急欲行，殷碧莲则恋恋不舍，再四唤回。盖此少年系搭救殷碧莲之人，故殷碧莲已属意于彼，而彼少年却\n义气干云，绝无些微暧昧心也。此末一段始为《池水驿》正文，即是班中所常演者。",
  "notes": "《池水驿》一戏，近来班中，往往单演殷碧莲、秋香主婢在池水驿相会一段。此本系全出，与上出《少华山\n》紧接。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "殷照磨、院子、车夫、四青袍同上。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "哎呀，且住！是我父女在家逃出潼关，路过少华山，又被此山大王，将我女儿 碧莲，抢上山去。也不知我女儿生死如何？又不知她贞节可保？想我将女儿失 落，回得家去，怎样见我那夫人之面？也罢！想我这大年纪，活在世上，也无 颜为人。倒不如待我碰死了罢！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓家爷，不必如此。先回到府去，再作道理。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "家院，如若回得府去，那张润和再到府下，我拿何言答对？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓家爷，如若那张润和再到府中，就说小姐一人逃出府去，不知去向，也就完 了。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "讲得有理。我来问你，你们大家，可看见秋香逃在哪里去了？"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "我等不知去向。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "可同小姐上山？"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "无有。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "嗳！这奴才一人逃走，真真可气。你我大家回得的府去，再作道理。正是："
        },
        {
          "character": "殷照磨",
          "type": "念",
          "text": "闷在家中坐，祸从天上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张润和上。"
        },
        {
          "character": "张润和",
          "type": "数板",
          "text": "自幼生来浪荡，懒读诗书文章，喜的是游山走马，爱的是烟花柳卷，观的是美 色佳人，恨不的差人去抢，我进了娼门院下，就当我家祠堂。"
        },
        {
          "character": "张润和",
          "type": "念",
          "text": "自幼生来懵懂，诗书文章不通。见了家谱牌位，当作奇画春宫。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "我张润和，我父张景春，现在大明为臣，官居右都御史。是我自幼懒读诗书， 专好行围走马，爱喜烟花，这且不言。是我与殷家，早已定下亲事，定于中秋 完婚。是他女儿，见我生的丑陋，他父就想打退亲事。是我不愿，前日带领家 丁，去到他家逼办完婚。他家与我言定，今日过门完婚。我想今日乃是大喜之 日，不免带领花轿，前去抬亲便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子上。"
        },
        {
          "character": "丑院子",
          "type": "念",
          "text": "打听殷家事，禀报公子知。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "参见公子。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "罢了。张福，今天是我喜日，你们都上哪里去了？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "吓公子，今天是什么喜日？"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "你们心里，都惦记着玩，那把大爷的事，全都忘了！今天要到殷家抬亲去。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "公子，我劝你这个亲事，不必办了。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "怎么不必办了？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "公子有所不知：时才我在大街上，有人说殷照磨，同他女儿碧莲，连夜逃出潼 关去了。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "此话当真？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "当真的。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "张福，快叫家丁们走上。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "家丁们走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家丁同上。"
        },
        {
          "character": "四家丁",
          "type": "同白",
          "text": "参见公子。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "四家丁",
          "type": "同白",
          "text": "公子将我等唤来，有何吩咐？"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "今日随大爷去到殷家抬亲。若有殷小姐，这还罢了；如若无殷小姐，大爷叫你 们打，你们就打，叫你们抢，你们就抢。看大爷的眼色行事。 张福带路，殷家走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秋香上。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "哎呀且慢！是我跟随我家小姐，逃出门来。行在山口，下来许多山贼，将我们 冲散。也不知老太爷同小姐，逃往哪里去？想我秋香一人，投奔哪里？有了， 前面有一村庄，到在那里，打听我家小姐下落便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张润和、四家丁、丑院子同上。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "公子，来到殷家门首。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "上前叫门。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "呔，有人么？走出一个来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老院子上。"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "什么人叫门？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "你开开罢！"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "嗳，你们又来了。前来作什么？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "我们公子呀，抬亲来了！"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "我们家爷不在。对你公子去说：不必进来，叫他回去罢。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "你胡说！ 公子，他们说道：家爷不在家，叫公子回去。他们说这话，可气不可气？"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "怎么说，不叫新姑老爷进去？真真给脸不要脸！ 家丁们打进去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家丁、张润和、丑院子同进门。"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "吓公子，我们家爷不在。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "我晓得，你们家里还有人么？"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "老夫人现在后边。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "请你夫人出来。"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "是是。 有请老夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷夫人上。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "张公子来了。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "吓，公子，请来上坐。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "有坐有坐。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "吓，公子，今日到此何事？"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "我前来抬亲来了。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "吓公子，日前对你说过，将这门亲事打退。你我两家合好在前，请公子另娶一 房罢。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "什么另娶一房？不像话！当初这亲事，乃是你夫妻二人许配我的，是不是？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "不错的。此事么，乃是我女儿不情愿的，我夫妻也是无法了。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "我来问你：老太爷同小姐，哪里去了？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "不在家中。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "哪里去游？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "到他舅父家中去了，"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "不对，明明在家，你说不在家."
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "当真不在.。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "不在我要搜。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "请搜。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "家丁们，两厢搜来。"
        },
        {
          "character": "四家丁",
          "type": "同白",
          "text": "无有小姐。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "老夫人，小姐不在，想是他父女逃走了罢？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "哎呀公子呀！事到如今，我实对你说了罢：是我二老无法可想，他父女连夜逃 出潼关去了。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "逃出潼关去了。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "哎呀老夫人！我想那潼关以外，有许多山贼，若将小姐失落，那还了得？ 张福过来，命你带领家丁，去到潼关之外，打听小姐下落，速报我知。这有拾 两银子，好作路费，快快前去！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子、四家丁同下。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "吓老夫人，我这亲事，候她回来完婚。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "就依公子。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "我要回去了。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "不送了。 家院，将门上好。"
        },
        {
          "character": "张润和",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "张润和",
          "type": "念",
          "text": "一心做新郎，不想又还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张润和下。殷夫人、老院子同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "殷照磨、院子、车夫、四青袍同上。"
        },
        {
          "character": "殷照磨",
          "type": "念",
          "text": "出了虎口地，来到自家门。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "殷忠开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老院子上。"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "又是哪个叫门？待我看来。 吓，家爷回来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷照磨、院子、车夫、四青袍、老院子同进门。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "你们大家后面歇息歇息，用饭去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、车夫、四青袍同下。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "殷忠！"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "有请老夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷夫人上。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "老院子",
          "type": "白",
          "text": "家爷回来了。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "待我去看。 吓老爷回来了！"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "吓夫人，请坐。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "老爷请坐。吓老爷，一路之上，多受辛苦。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "我辛苦什么？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "吓，老爷，为何不见我女儿，哪里去了？"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "哎呀夫人，那是我带领女儿，出了潼关，行至少华山口，又被那山上大王，将 我女儿抢上山寨去了！"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "抢上山寨去了！"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "殷夫人",
          "type": "西皮导板",
          "text": "听说我儿被人抢，"
        },
        {
          "character": "殷夫人",
          "type": "三叫头",
          "text": "我儿！碧莲！嗳，儿吓！"
        },
        {
          "character": "殷夫人",
          "type": "唱",
          "text": "好似刚刀刺胸膛。 骂声山中众贼党， 害我女儿为哪桩？ 千思万想无下场， 不如碰死在厅上。"
        },
        {
          "character": "殷照磨",
          "type": "唱",
          "text": "夫人不必两泪汪， 我有言来听端详： 我有妙计将儿救， 夫妻有话好商量。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "吓夫人，事到如今，你也不要难过。此事全怪为丈夫，一时大意，将女儿失落， 被山贼抢的去。待我修下书信一封，下到京中侄儿殷志那里，叫他差人将我 儿领回，你看如何？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "就依老爷。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "待我修书。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹牌子。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "来，下书人走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "差人上。"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "见家爷。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "罢了。这有书信一封，下到京城侄少爷那里，不得有误。"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "差人下。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "吓夫人，自我走去，那张郎可到我家来过？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "再不要提起，自老爷去后，那张郎带领许多家丁，来到就要抬亲。是我与他说 实话，言道女儿与你，连夜逃出潼关去了。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "吓夫人，想那张郎知晓，焉能与你干休？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "那张郎听说此言，不来抬亲，反倒差人保护女儿去了。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "你乃是妇道之家，晓得什么？哪里是保护，分明追赶与我回来。吓夫人，那张 郎走后，言讲何来？"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "那张郎言道：等我女儿回来完婚。"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "好一不要脸的东西！"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "老爷就当差人，去到山前山后，打探女儿下落如何？"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "吓夫人，我想此事，怪你女儿不好。当初将她许配张郎，是她不愿，如今遭此 大难，乃是她命当如此。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "听你之言，罢了不成？"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "候等京城回信，再作道理。"
        },
        {
          "character": "殷夫人",
          "type": "白",
          "text": "嗳，这也是养女儿的好处！"
        },
        {
          "character": "殷照磨",
          "type": "白",
          "text": "夫人请到后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷照磨、殷夫人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "数板",
          "text": "一关一缩不成店，一开一掀不见面，他在头里走，我在后面赶，二人见了面， 腰中就不便，改日再见，改日再见。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "小老儿，王三利。在这本街开了一座小店，名叫池水驿。我这店里，就是我一 个人，我老婆已就早下世去了。我也无有儿女，心想找一个伙计。我这店里， 也无有什么客人，开销不出，只好一人挣来一人吃。看今日天气晴和，不免收 拾收拾，到外面看看，将招牌挂起来。 呀，呔，有住店的，这里来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香上。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "哎呀且住！是我来到此地，投奔哪里？看那边有一老头，待我上前问来。 请问老伯伯，这里叫作什么地方？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我们这里，叫池水驿。这位小姑娘，你是找什么人的？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "我找我们小姐。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我们这里，是个小地方，无有大户人家。哪里有小姐？你们小姐，是哪一家的？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "我们是殷照磨老爷那里的小姐，可看见过去无有？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我来问你，来到这里做什么事情？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "老伯有所不知：是我跟随小姐，出得门来，路过那边山口。山上下来许多山贼， 将我们冲散，不知小姐哪里去了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "小姑娘说的话，我明白了。我对你说：你先在我这里住个十天半月，我到外边， 打听你小姐下落。若有了下落，你再走，你看好不好？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "老伯有好意收留与我，后来我与小姐相会，永不忘大恩！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "不必多说了。来，随我到房里去。我来对你说：人家问我，你是我的什么人吓？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "若不然，我拜在老伯门下罢！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "使不的！"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "使得。如此爹爹请上，受儿一拜！"
        },
        {
          "character": "秋香",
          "type": "西皮摇板",
          "text": "爹爹请上受儿拜， 从今以后孝当先。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我来问你，叫什么名字？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "儿叫秋香。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "好名字，你多大年岁？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "儿一十九岁了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "这就是儿呀，我们这里，本是开的小店房。从今以后，你是我的女儿了。店内 之事，还要你来照看。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "那是自然。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "好女儿。天时不早，随为父后边用饭来罢！"
        },
        {
          "character": "店家",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家、秋香同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丑院子、四家丁同上。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "我张福。奉了我家公子之命，带领家丁，打听殷小姐的下落。我想这一路之上， 无有住户，哪里去问？有了，看前面有一座高山，到在那里访问访问。 家丁们往山口儿去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子、四家丁同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "唱",
          "text": "人得喜事精神爽， 月到中秋分外光。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我王三利。自从那日收了一个义女，倒也孝顺。这也是我前世修来的德行，这 且不言。我有意去到外边，访问殷小姐的下落，不免将女儿叫出，商议商议。 秋香女儿走来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香上。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "来了！ 参见爹爹。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "将儿唤来，有何训教？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我有意去到外边，访问你家小姐的下落，你意如何？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "爹爹有这好意，儿也感恩不尽，就凭爹爹。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "好，店内之事好好照看，我要去也！"
        },
        {
          "character": "店家",
          "type": "西皮摇板",
          "text": "父女分别出店房， 访问小姐走一场。"
        },
        {
          "character": "秋香",
          "type": "西皮摇板",
          "text": "但愿小姐早回转， 奴主相会谢老天！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家、秋香同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "倪厚上。"
        },
        {
          "character": "倪厚",
          "type": "念",
          "text": "出了虎口地，再等豺狼围。"
        },
        {
          "character": "殷碧莲",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷碧莲上。"
        },
        {
          "character": "殷碧莲",
          "type": "念",
          "text": "眼看红日落，叫奴好伤心。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓解元爷，你我下得山来，投奔哪里？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "哎呀小娘子！你我下得山来，你东我西，各自分别了罢！"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗳，解元爷呀！"
        },
        {
          "character": "殷碧莲",
          "type": "西皮快板",
          "text": "解元爷下山来亲自行走， 留下了女子家哪个收留？ 今日里将奴家一人行走， 倒叫我女子们无处去投。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷碧莲笑。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗳，解元爷呀！"
        },
        {
          "character": "倪厚",
          "type": "白",
