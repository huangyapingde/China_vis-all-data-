        {
          "character": "倪厚",
          "type": "白",
          "text": "嗳，又是一个女子。 贤妹上前。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "待我看来。 店主人在哪里？店主人在哪里？ 哎呀且住，我看她好像我家侍女秋香，她为何来到此地？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "我看她好像我家小姐，为何来到此地？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "你可是秋香么？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "你可是我家小姐？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "吓小姐，因何来到此地？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓秋香，一言难尽！"
        },
        {
          "character": "殷碧莲",
          "type": "西皮快板",
          "text": "少华山打一战老爷逃走， 许多人将姑娘抢上山头。 在山上多蒙那君子搭救， 险些儿用刚刀把我命留。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "吓小姐，身后那是什么人？"
