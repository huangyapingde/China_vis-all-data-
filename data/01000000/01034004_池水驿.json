        {
          "character": "倪厚",
          "type": "白",
          "text": "罢罢罢，这就好了！"
        },
        {
          "character": "倪厚",
          "type": "西皮快板",
          "text": "这才是苍天爷有了保佑， 倒叫我倪顺天喜在心头。 叫贤妹你暂在店房忍守， 我与你留银两好度春秋。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "吓贤妹，这是富贵图一幅，与你留下，作为纪念。还有银子二百两，与你留下 一半，以作日用。将话说完，为兄的要进京去求取功名。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "仁兄且慢！我想你进京求名，将我留在店内，依靠何人？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "吓贤妹！我想那秋香，是你家侍女。你在此安身，又待何妨？兄此去进京求名， 你在此等候为兄。若是得中，必定差人前来接你。好好在此居住，为兄的要 走了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香上，在门外听话。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗳，你说的此话，可是真心实意？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "贤妹，为兄与你说的，乃是实言。兄若有二意，叫我进京不能得中！"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "言重了！不知仁兄何日起程？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "为兄今日就要起程。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "罢了，夫——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香进门送酒。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "小姐酒到。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "可说是秋香取酒来！"
        },
        {
          "character": "殷碧莲",
          "type": "西皮慢板",
          "text": "与仁兄对坐来饮酒，"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "仁兄请酒！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "吓贤妹请！"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗳仁兄吓！"
        },
        {
          "character": "殷碧莲",
          "type": "西皮慢板",
          "text": "你听我把此话细说根由： 奴问你家娶妻可是真有？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "我有来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷碧莲哭。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗳，仁兄吓！"
        },
        {
          "character": "殷碧莲",
          "type": "西皮慢板",
          "text": "你若有奴情愿入庵去修。"
        },
        {
          "character": "倪厚",
          "type": "西皮原板",
          "text": "尊贤妹你不必泪珠双流， 我总有铁打心也把你收。 我劝你在店房暂且忍守， 候为兄得中回同登凤楼。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "吓贤妹，天不早了，为兄要去了。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄，你就要去了，罢了，夫吓！"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "哽吓，秋香在！"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓秋香，你还在此做什么？"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "侍奉小姐。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓秋香，下边取茶来我用。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "无有开水。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "下边去做。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "我不去。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "秋香进前来。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "有话对你讲。嗳，你出去罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香下。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "贤妹，你不要三心二意，为兄要去了。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄就要去了？嗳仁兄，吓吓吓吓！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "贤妹不必哭了，兄要去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚出门，下。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄，嗳，当真去了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷碧莲出门。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄，你回来，仁兄你回来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚上。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "唤我回来了。吓贤妹，将愚兄唤同来，将说什么？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄，想进京求名，一路之上，必要早落店晚登程才是。一路之上，多加小 心，保重为要。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "为兄的晓得了，贤妹请回去罢。兄要去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚下。殷碧莲哭。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "又走了。吓，仁兄回来，仁兄回来，仁兄回来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚上。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "为兄回来了。吓贤妹，又将为兄唤来，又说什么？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄，你若到了京城，如若得中，千万差人接我才是。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "贤妹，那是自然。快把话说完，兄要去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚下。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄，又走了。仁兄回来，仁兄回来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚上。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "嗄！为兄又回来了。有话快快的讲，真真烦死人了！"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓仁兄！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "还有什么说的？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "这个。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗄，你去罢！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "哎呀天哪天哪，这一回我可走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚下。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗄，仁兄吓，又走了。仁兄你回来罢！"
        },
        {
          "character": "殷碧莲",
          "type": "哭板",
          "text": "见仁兄出店房不回转， 倒叫我二八女挂心间。 将身儿进了店房以内， 但不知仁兄何日回还？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香上。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "吓小姐，方才走去，他是什么人？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "不必多言，搀我来。"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓秋香，罢了。夫——"
        },
        {
          "character": "秋香",
          "type": "白",
          "text": "吓小姐，看错了，是我。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "嗄，可说是秋香，你、你、你、你、你、你搀我来罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷碧莲、秋香同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}