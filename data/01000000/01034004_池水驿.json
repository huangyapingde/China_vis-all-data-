        {
          "character": "殷碧莲",
          "type": "白",
          "text": "仁兄上前搭店。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "等我前去看来。 来此已是池水驿，池水驿店主人有么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秋香上。"
