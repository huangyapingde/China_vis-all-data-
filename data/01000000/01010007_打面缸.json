        {
          "character": "张才",
          "type": "白",
          "text": "大老爷差我山东去催粮，我哪里有这个心事？我打点酒，回去吃酒。 开门！"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "我张才。"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "不好呢，大老爷，张才回来了。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "这怎么好？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "老爷藏起来罢。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "藏在哪里？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "藏在床底下。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你们两人，可要老实点。"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我们两个人规矩的很，老爷藏起来罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大老爷躲。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周腊梅开门。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "怎么这慢腾腾的，烫酒去。"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我不会烫酒，自会做裤子。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "我晓得你们这些人，好吃懒做，待我自己来烫。灶窝里忙塞一把火——"
        },
        {
          "character": "张才",
          "type": "吹腔",
          "text": "灶腹堂忙点一把火，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王书吏上。"
        },
        {
          "character": "王书吏",
          "type": "吹腔",
          "text": "灶锅里烧出我， 烟薰火爆实难过。"
        },
        {
          "character": "张才",
          "type": "吹腔",
          "text": "手使大棍朝下打，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四老爷上。"
        },
        {
          "character": "四老爷",
          "type": "吹腔",
          "text": "面缸里打出我， 搬把椅儿四老爷坐。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "四老爷，我们家里乱唧吧嘈。请四老爷与我们断一断。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "你听好了："
        },
        {
          "character": "四老爷",
          "type": "数板",
          "text": "叫张才，你过来，听你四老爷把话说明白：大老爷差你山东公干去，为什么私 自转回来？放住冷酒你不喝，一心要往灶锅里塞。灶锅里烧出了王书吏，面缸 里打出我四老爷来。清官难断家务事，床底下请，"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "请谁？"
        },
        {
          "character": "四老爷",
          "type": "数板",
          "text": "请出大老爷来。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "大老爷也来了？ 有请大老爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大老爷出。"
        },
        {
          "character": "大老爷",
          "type": "吹腔",
          "text": "床底下，闷坏了张知县， 低下头往外攒。 一见张才我浑身战，"
        },
        {
          "character": "王书吏",
          "type": "吹腔",
          "text": "灶锅里，烧来我黑黑黑。"
        },
        {
          "character": "四老爷",
          "type": "吹腔",
          "text": "面缸里，打出我一身白，"
        },
        {
          "character": "大老爷",
          "type": "吹腔",
          "text": "床底下，闷的我气儿出不来。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "王先生，你到我们这里，做什么来的？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "贺喜来的。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "拿喜封来。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "多少？"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "五十两银子。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "明天衙门里拿。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "不成功，今天要。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "今天要？我来找个保人。 四老爷。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "王先生什么事？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "我来贺喜来的，他问我要五十两银子喜封。请四老爷保一保。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "你明天到衙门里还我。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "明天一定还上。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "好呢，我来作保，让他去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王书吏下。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "四老爷该你呢。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "我多少？"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "你也五十两，连他共是一百两。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "你明天到衙门里去拿。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "不成功，今天就要。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "不要闹，我也与你找个保人。 大老爷。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "四老爷你来做什么？"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "我贺喜来的，他们问我要喜封。我没有带银子，请大老爷替我保一保。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你多少银子？"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "我自己五十两，与王先生保了五十两，共总一百两。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你明天要还我的。"
        },
        {
          "character": "四老爷",
          "type": "白",
          "text": "送到衙门就是。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "好呢，让他去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四老爷下。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "大老爷该你呢。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "我多少？"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "你自己一百两，他们两个人的一百两，共凑二百两。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "明天到衙门去拿。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "今天就要。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "今天没有。"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "没有，我要剥你的衣裳。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你敢剥老爷我么？"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "我说剥就剥。"
        },
        {
          "character": "张才",
          "type": "吹腔",
          "text": "脱元领，摘纱帽，"
        },
        {
          "character": "周腊梅",
          "type": "吹腔",
          "text": "客出去，门关了。"
        },
        {
          "character": "大老爷",
          "type": "吹腔",
          "text": "握住屁股往衙门里跑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大老爷下。"
        },
        {
          "character": "张才",
          "type": "吹腔",
          "text": "白得银子二百两。"
        },
        {
          "character": "周腊梅",
          "type": "吹腔",
          "text": "这丑名，奴担了，"
        },
        {
          "character": "张才、周腊梅",
          "type": "同吹腔",
          "text": "夫妻拍手哈哈笑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张才、周腊梅同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}