    },
    {
      "name": "宇文成都",
      "hangdang": "净"
    },
    {
      "name": "伍夫人",
      "hangdang": "旦"
    },
    {
      "name": "朱粲",
      "hangdang": "净"
    },
    {
      "name": "伍保",
      "hangdang": "净"
    },
    {
      "name": "尚师徒",
      "hangdang": "净"
    },
    {
      "name": "麻叔谋",
      "hangdang": "净"
    }
  ],
  "plot": "按炀帝既杀伍建章及全家三百余口，以伍建章之子伍云昭远镇南阳、勇冠三军，留之必为后患，遂命韩擒虎\n率兵前往征讨。伍云昭闻讯，愤极而叛。两军相遇，隋兵大挫，折丧大将十余员。韩擒虎亲自会阵，亦不敌。\n惟韩擒虎与伍建章有故旧之谊，故暗嘱伍云昭暂行退兵，以避后路宇文成都之师。盖韩擒虎知伍云昭现虽\n获胜，然终非宇文成都之敌，后必败衄也。伍云昭不听，既而宇文成都至，伍云昭果大败，几被擒。幸赖朱\n粲伪饰周仓，用计哄退隋兵，方得弃城他往，保全性命也。惟《说唐》中朱粲系吓退尚师徒，剧中作为吓退\n宇文成都，是有小异。盖编剧者之剪裁借用也。",
  "notes": "隋炀帝弑父杀兄，既得篡位自立。以伍建章耿直负时望、有重名，欲令伍建章草诏发丧。伍建章不奉命，且\n痛骂杨广（即炀帝）灭伦绝理、神人不容，因被害。《骂杨广》一剧即演此事，而此《南阳关》，则在《骂\n杨广》之后。《说唐》中第十五回“伍云昭报仇起兵”、十七回“韩擒虎二路调兵，伍云昭被困南阳”、十\n九回“伍云昭弃城败走，勇朱灿杀退师徒”等节，即本剧事实。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尚师徒、麻叔谋同上。"
        },
        {
          "character": "尚师徒",
          "type": "念",
          "text": "大将生来秉性刚，"
        },
        {
          "character": "麻叔谋",
          "type": "念",
          "text": "扶保社稷把名扬。"
        },
        {
          "character": "尚师徒",
          "type": "白",
          "text": "某，尚师徒。"
        },
        {
          "character": "麻叔谋",
          "type": "白",
          "text": "麻叔谋。"
        },
        {
          "character": "尚师徒",
          "type": "白",
          "text": "请了。元帅升帐，在此伺候。"
        },
        {
          "character": "尚师徒、麻叔谋",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引韩擒虎同上。"
        },
        {
          "character": "韩擒虎",
          "type": "点绛唇",
          "text": "奉王钦命，统领雄兵，扫南阳，将勇兵精，要把干戈定太平。"
        },
        {
          "character": "韩擒虎",
          "type": "念",
          "text": "今奉圣命出京闱，铁甲纷纷映日辉。三声大炮镇天地，雀鸟不敢向空飞。"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "本帅韩擒虎。新主登基，命我为帅去往南阳关，捉拿伍云昭进京问罪。 二先行，人马可齐？"
        },
        {
          "character": "尚师徒、麻叔谋",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "兵发南阳关。"
        },
        {
          "character": "尚师徒、麻叔谋",
          "type": "同白",
          "text": "众将官，兵发南阳关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍保上。"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "俺，伍保。可恨杨广无道，将太老爷斩首，不免去到南阳关，报与老爷知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍保下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍云昭、四下手同上。"
        },
        {
          "character": "伍云昭",
          "type": "引子",
          "text": "威镇南阳，秉忠心，扶保朝堂。"
        },
        {
          "character": "伍云昭",
          "type": "念",
          "text": "领人马东西浩荡，每日里操演校场。受君禄何能安享，与先祖朝堂争光。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "本帅伍云昭。我父伍建章，在隋帝驾前为臣，官拜当朝太宰。本帅镇守南阳， 只因夫人所生一子，命伍保进京，一来与圣上问安，二来与父母报喜。一去数 日，不见音信回关。本帅这两日眼跳心惊、魂梦颠倒，不知主何吉凶。 军士们！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同允。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同喝。伍保上。"
        },
        {
          "character": "伍保",
          "type": "念",
          "text": "忙将京中事，报与老爷知。"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "老爷，大事不好了。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "伍保为何这等模样？"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "杨广无道，将老相爷午门正法，满门尽行斩首。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "你才怎讲？"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "老相爷金殿正法，满门尽行斩首。"
        },
        {
          "character": "伍云昭",
          "type": "叫头",
          "text": "爹爹！母亲！哎呀爹娘呀！"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "老爷醒来。"
        },
        {
          "character": "伍云昭",
          "type": "西皮导板",
          "text": "听罢伍保一声报，"
        },
        {
          "character": "伍云昭",
          "type": "叫头",
          "text": "爹爹！母亲！哎呀呀！"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "唬得我三魂七魄飘。 忍泪含悲叫伍保， 你把犯罪情由细说根苗。"
        },
        {
          "character": "伍保",
          "type": "西皮摇板",
          "text": "杨素、化吉行奸巧， 私通杨广篡九朝。 相爷金殿去守孝， 昏王割舌把牙敲。 太宰夫人俱斩了， 可怜四将尽开刀。 韩擒虎统领人马到， 要拿老爷转回朝。"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "听一言来心头恼， 二目圆睁似火烧。 扭项回头把三军叫， 老爷言来听根苗： 本帅与父把仇报， 尔等可愿反皇朝？"
        },
        {
          "character": "下手",
          "type": "同白",
          "text": "我等情愿。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "好。"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "擂鼓摇旗放号炮， 生死存亡走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "韩擒虎",
          "type": "内西皮导板",
          "text": "人马纷纷往前闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩擒虎、尚师徒、麻叔谋、四龙套同上。"
        },
        {
          "character": "韩擒虎",
          "type": "西皮原板",
          "text": "对对旌旗空中飘。 左先行骑的是呼雷豹， 右先行手执丈八矛。 大小三军齐开道， 耀武扬威立功劳。 新主降下旨一道， 命我灭却伍云昭。 此事把我心悔恼， 为国的忠良无下梢。"
        },
        {
          "character": "尚师徒",
          "type": "西皮摇板",
          "text": "元帅说话多奥妙， 文帝难以掌九朝。 新主既发旨一道， 何必常常挂心劳？"
        },
        {
          "character": "麻叔谋",
          "type": "西皮摇板",
          "text": "在王驾前说王好， 吃皇水土报君劳。 打蛇不死反仇报， 要绝草除根不留苗。"
        },
        {
          "character": "韩擒虎",
          "type": "西皮摇板",
          "text": "二先行说话志量高， 耀武扬威逞英豪。 南阳关前齐围绕， 要拿云昭转回朝。"
        },
        {
          "character": "伍云昭",
          "type": "内西皮导板",
          "text": "越思越想心头恼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍云昭上城。"
        },
        {
          "character": "伍云昭",
          "type": "哭",
          "text": "哎呀，爹娘呀！"
        },
        {
          "character": "伍云昭",
          "type": "西皮慢板",
          "text": "叹双亲不由人珠泪双抛。 手扶着垛口往下瞧， 层层人马围住城壕。 尚师徒跨下呼雷豹， 麻叔谋手执丈八矛。 忍泪含悲把伯父叫，"
        },
        {
          "character": "伍云昭",
          "type": "西皮二六板",
          "text": "侄儿有言禀年高： 自古道为臣尽忠子尽孝， 当在人间逞英豪。 叹先王文帝驾晏了， 无人执掌锦绣龙朝。 大千岁即位礼正道， 恨杨广作恶霸占当朝。 我父忠心把国保， 敲牙割舌为哪条？ 可怜我四将俱斩首， 年迈老娘受一刀。"
        },
        {
          "character": "伍云昭",
          "type": "西皮快板",
          "text": "合家满门忠难表， 兵困南阳为哪条？ 亲年迈，遭强暴， 老伯父论情理也该恕饶。"
        },
        {
          "character": "韩擒虎",
          "type": "西皮快板",
          "text": "贤侄休把事看小， 你父金殿骂当朝。 合朝公卿把他保， 毁谤文帝众群僚。"
        },
        {
          "character": "伍云昭",
          "type": "西皮快板",
          "text": "伯父如今领兵到， 侄儿含泪禀年高： 老伯父放我一条路， 我与你晚点灯早把香烧。"
        },
        {
          "character": "韩擒虎",
          "type": "西皮快板",
          "text": "贤侄说话好蹊跷， 休怪老夫不肯饶。 今日把你放走了， 违了圣旨怎回朝？"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "既不将我来恕饶， 哪有闲言叙唠叨。 三军忙把城开了， 舍生忘死战一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍云昭下城，出城，开打。韩擒虎败下，伍云昭追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩擒虎、四龙套同上。"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "伍云昭杀法厉害，老夫难以对敌。 众将收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引宇文成都同上。"
        },
        {
          "character": "宇文成都",
          "type": "念",
          "text": "奉了新主命，去助老将军。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "俺，宇文成都。奉了新主之命，去往南阳，助韩老将军一膀之力。 来，兵发南阳关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩擒虎、四龙套同上。"
        },
        {
          "character": "韩擒虎",
          "type": "念",
          "text": "眼望救兵，坐卧不宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报：无敌将军到。"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宇文成都、四下手同上。"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "不知将军驾到，未曾远迎，多有得罪。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "岂敢。不知老将军可曾见过阵来？"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "老夫年迈，难以对敌。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "待某会他一阵。"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "须要小心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩擒虎下。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "三军起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍云昭、伍夫人同上。"
        },
        {
          "character": "伍云昭",
          "type": "念",
          "text": "满腹冤仇事，"
        },
        {
          "character": "伍夫人",
          "type": "念",
          "text": "时刻挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍保上。"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "启老爷：宇文成都发兵到了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍保下。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "听说成都领兵到， 贼子武艺比人高。 父母冤仇难以报，"
        },
        {
          "character": "伍云昭",
          "type": "哭头",
          "text": "爹爹，亲娘吓！"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "请老爷上马。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "也罢。"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "舍生忘死走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍云昭下。"
        },
        {
          "character": "伍夫人",
          "type": "西皮摇板",
          "text": "一见老爷出大营， 倒叫奴家挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍夫人下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宇文成都、四下手同上，伍云昭、四下手同上。"
        },
        {
          "character": "宇文成都",
          "type": "西皮摇板",
          "text": "一见云昭心烦恼， 骂声无知小儿曹。 既知某家领兵到， 就该一同转回朝。"
        },
        {
          "character": "伍云昭",
          "type": "白",
          "text": "呀呀呸！"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "你父万恶罪难表，"
        },
        {
          "character": "宇文成都",
          "type": "西皮摇板",
          "text": "你父不该骂当朝。"
        },
        {
          "character": "伍云昭",
          "type": "西皮摇板",
          "text": "除非你是天神到，"
        },
        {
          "character": "宇文成都",
          "type": "西皮摇板",
