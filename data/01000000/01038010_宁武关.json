{
  "script_id": "01038010",
  "title": "宁武关",
  "alias": [
    "对刀步战；一名：闪电光"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "周遇吉",
      "hangdang": "老生"
    },
    {
      "name": "李洪基",
      "hangdang": "武生"
    },
    {
      "name": "李自成",
      "hangdang": "净"
    },
    {
      "name": "一支虎",
      "hangdang": "净"
    }
  ],
  "plot": "明末周遇吉，镇守岱州宁武关，李闯屡攻不下。诸将遇遇吉，皆披靡败北。惟子李洪基，足与周遇吉旗鼓相\n当。论兵势则全军势方盛，周遇吉究孤立无援，理宜早为李自成所胜。无如李洪基因乃叔一支虎之忌，极爱\n重周遇吉之才，拟收为心腹。每稍让一步，而周遇吉则拼命而上，故反占胜。前已交绥，此次李洪基又奉命\n往攻岱，与周遇吉相遇。李洪基反复苦劝，周遇吉终不听，乃厮杀。却乃是棋逢敌手，莫决雌雄。战至兴起，\n李洪基乃约周遇吉舍枪而用刀，周遇吉即允用刀。乃不分上下。李洪基又约周遇吉下马而比步，周遇吉即\n允步战。然周遇吉方患李洪基之得藉宝马之力而占优势（马名闪电光），今弃马用步，则正中下怀矣。因此\n李洪基卒被擒。故此剧名为《对刀步战》。",
  "notes": "《宁武关》之剧名，前已见诸本考中，然实非重复叠载。前之《宁武关》，为《别母乱箭》。此剧乃李洪基\n（即李闯之子）与周遇吉对刀步战也。系在《别母乱箭》之前。从前谭叫天演《宁武关》，闻每代演对刀步\n战，尽此非有靠把之真本领者不办。此戏源出昆乱，故多用斗鹌鹑、风入松等牌子吹腔。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四黑龙套、二旗牌引李自成同上。"
        },
        {
          "character": "李自成",
          "type": "西皮摇板",
          "text": "自从起手立帝号， 遇吉累次动枪刀。 孤王坐在金殿道。 但愿把贼一起剿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左金龙、一支虎同上。"
        },
        {
          "character": "左金龙、一支虎",
          "type": "同白",
          "text": "参见兄王。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "御弟请坐。上殿有何本奏？"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "启兄王：今有周遇吉，带领人马前来讨战，众将难以抵挡。兄王可派能人前去 对战。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "就命洪基儿对战，你看如何？"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "可以胜得过那周遇吉。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "旗牌过来，去到教坊，命李洪基带领数十万精兵，前去岱州，不得违误。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌甲下。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "你我点动人马便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小军、四上手引周遇吉同上。"
        },
        {
          "character": "周遇吉",
          "type": "点绛唇",
          "text": "手握兵符，镇守岱州，献威武，虎视耽耽，谁敢关前遇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉坐高台。"
        },
        {
          "character": "周遇吉",
          "type": "念",
          "text": "渺渺戈纹贯落星，长幡早已动高旌。丈夫鹊印摇边月，大将龙韬旧有声。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "本帅周遇吉。奉命镇守代州等处。可恨闯贼统领大兵，直压城下，他有一义子， 名叫李洪基，我又与他连战数阵。看他有败怯之心，眼见得生擒在我，怎奈 他马骤如飞，不能擒获。探马报到，他又兴兵前来。今日与他交战。必定成功。 呔，众将官！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "与俺迎敌者。"
        },
        {
          "character": "周遇吉",
          "type": "金钱花",
          "text": "旌旗云绕，迷漫迷漫， 摆开阵势，城南城南。 只一战，凯歌旋， 擒虎儿寸心丹，擒虎儿寸心丹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李洪基上，起霸。"
        },
        {
          "character": "李洪基",
          "type": "引子",
          "text": "将遇良才，棋逢对手，越令人豪气频添，把精神抖擞。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "俺李洪基。俺奉了父王的将令，攻打岱州。那总兵周遇吉，他将人马扎在城外， 排成犄角之势，吾军不能近前，此乃以主代客。前者与他交战，他的枪法， 神出鬼入，不下与俺，难以招架。俺只得诈败而走，等他前来追赶与吾，暗放 飞刀前去斩他。又被他接去，反来斩俺。幸亏吾的坐骑千里驹，名曰闪电光。 那时若是迟了一步，定被他伤了俺的性命。自从父王与俺改名洪基，名字应了 年号。只是俺叔父一支虎，有些妒忌与俺。若是招降此人，作为心腹，吾的天 下稳稳。我今与他随机应变，同一事也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "千岁，大王命你带领了精兵数十万，大战周遇吉，不可迟误。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "父王又有令前来，命俺前去大战周遇吉。 呔，众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵卒、四下手自两边分上。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "起兵迎敌者。"
        },
        {
          "character": "李洪基",
          "type": "滴溜子",
          "text": "催铁骑，催铁骑，如云骤， 挽金戈，挽金戈，如霜，光溜溜。 捣雄关烽堠，把熊罴两翅排，旌门紧守， 各显威，神惊鬼愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李洪基带马。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四小军、四上手引周遇吉同上，同站门。四兵卒、四下手、李洪基同上。会阵。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "呔！马前来的，可是周将军！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "贼子！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "周遇吉！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "李洪基！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "可惜你这般的大英雄威武，也算天下间一筹好汉。只是你生于末世，未逢明主。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "李洪基吓，李洪基吓！俺周遇吉呵！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "俺堂堂帝统御中州， 鸿图四海全收。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "只是你主弱臣勇，将见败亡耳！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "俺的圣上呵！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "比尨尧舜功德茂， 少什么稷契夔名胄。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "谅你一旅之师，际得什么事，为人也要见机而行，才称得起英雄好汉。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "俺周遇吉呵！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "忠和孝，平身自守， 身和命笑浮沤。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "周将军。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "你昂昂气宇恁风流， 更艺勇可称琼玖。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "你若倾心归顺，俺和你结为昆弟。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "真果是，云龙风虎金兰友， 保毕世恩荣化胄。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "休得多言，看枪！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "你若如此行之。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "刀头丧身家尽休， 英雄骨弃荒丘。"
        },
        {
          "character": "周遇吉",
          "type": "急三枪",
          "text": "俺心如铁，意如石，胆如斗， 任你随何口，说不转寸心头。"
        },
        {
          "character": "李洪基",
          "type": "急三枪",
          "text": "莫待钟鸣漏尽，到山水穷头， 灾星透，便欲悔悔无由。 （四小军、四兵卒自两边分下。周遇吉、李洪基同对抢，同亮架子，同开打，同下。四上手、四下手同开打， 同下。李洪基上，周遇吉杀上，李洪基败下。四小军同上。）"
        },
        {
          "character": "四小军",
          "type": "同白",
          "text": "李洪基走了！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、四小军同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵卒、四下手、李洪基同上。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "罢了吓，罢了吓！他的枪法十分厉害，这便怎么处？有了，等他到来，俺与他 对刀可以取胜。 众将官，杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军、四上手、周遇吉同上。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "周将军，为将者十八般武艺，件件皆能。你的枪法，不足为奇。你与俺对刀。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "刀乃军家要事，怎么不知！就与你对刀。"
        },
        {
          "character": "周遇吉",
          "type": "急三枪",
          "text": "披风泼雪猛如彪， 万丈寒光飞骤。 似银蟒旋抖擞， 耳边风声频吼。 冷飕飕，闪烁光侔， 干羽振舞阶溜。"
        },
        {
          "character": "周遇吉、李洪基",
          "type": "同白",
          "text": "众将官，看刀伺候。 （周遇吉、李洪基同换刀。四小军、四兵卒自两边分下。周遇吉、李洪基同开打，同对刀，同下。四上手、 四下手同开打，同下。李洪基上，周遇吉杀上，李洪基败下。四小军同上。）"
        },
        {
          "character": "四小军",
          "type": "同白",
          "text": "李洪基又败走了！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、四小军同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵卒、四下手、李洪基同上。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "罢了吓，罢了吓！俺的刀法，数年以来，并无人对手。他的刀法，也不输俺。 有了，等他到来，俺与他马下步战。 众将官，杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军、四上手、周遇吉同上。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "周将军，你我马上武艺，彼此皆知。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "你要怎样战法？"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "当初张飞与马超步战，杨再兴与庚丙文步战。俺如今与你比拳步战，若胜你不 得，情愿收兵回去，永不犯你的边界。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "和你较拳纵飞演，比进步， 这秘法可周知。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "且往。俺与他交战，怎奈他的马骤如飞。如今反要与俺步战，此乃是天赐我成 功也！ 呔，李洪基！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "你待要撼天山穿云斗海蛟， 俺如今要对付你这小猕猴。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "周将军，今日英雄遇英雄，好汉遇好汉，只可阵上赌输赢，不可暗箭伤人，方 为好汉。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "俺平生，正直待人。 众将官，不可暗使冷箭者。"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "狻猊摆尾下山头， 彩凤穿花滴溜。 撩衣托塔君知否， 举鼎势，伍子胥传授， 双展翅，鹰拿燕雀，龙探爪戏珠球。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、李洪基同下马，同起打。众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。〖牌子〗。"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "列位请了。元帅对李洪基交战，你我前去帮忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李洪基上，周遇吉上，李洪基、周遇吉同开打，周遇吉擒住李洪基。"
        },
        {
          "character": "周遇吉",
          "type": "三笑",
          "text": "呵呵，呵呵呵，哈哈哈！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "众将，将他的营盘闪电光抢过来。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "启元帅：闪电光抢过来了。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "好，记功领赏。摆队进关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军、四上手自两边分上。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "恭喜元帅，天神威武，擒此巨寇，威震华夷，小将等不胜忻贺。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "小丑虽擒，大逆尚存，何喜何贺？"
        },
        {
          "character": "四上手",
          "type": "同白",
