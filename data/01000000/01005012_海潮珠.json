        },
        {
          "character": "齐王",
          "type": "白",
          "text": "着吓，无故回朝，理当问斩。"
        },
        {
          "character": "大夫",
          "type": "白",
          "text": "有病回朝。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "假意得病。"
        },
        {
