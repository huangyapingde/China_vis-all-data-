          "type": "stage",
          "text": "大夫上。"
        },
        {
          "character": "大夫",
          "type": "唱",
          "text": "将身且把龙庭进， 见了大王奏分明。"
        },
        {
          "character": "大夫",
          "type": "白",
          "text": "为臣见驾，大王千岁！"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "卿家平身。"
