          "character": "棠姜",
          "type": "白",
          "text": "老爷身有病症，不能迎接大王。为妻倒也迎得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "你是妇道人家，如何迎得？"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "为妻受过三次诰封，可以迎得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "迎不得"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "迎得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "迎不得。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "迎得迎得，迎得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "如此你与我迎、迎、迎。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "好吓。"
        },
        {
          "character": "棠姜",
          "type": "唱",
          "text": "一见崔子说一声， 怎不叫人喜心中。 我这里出府用目看， 只见大王到门庭。 我上前双膝跪倒地， 叫声大王把我封。"
        },
        {
          "character": "齐王",
          "type": "西皮摇板",
          "text": "叫声梓童莫高声，"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "梓童！"
        },
        {
          "character": "齐王",
          "type": "西皮摇板",
          "text": "墙里讲话墙外听。 但愿崔子丧了命， 孤王封你昭阳宫。"
