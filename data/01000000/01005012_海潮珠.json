        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "怕他弟报兄仇。"
        },
        {
          "character": "大夫",
          "type": "白",
          "text": "有老夫担当。"
        },
        {
          "character": "崔杼",
          "type": "白",
