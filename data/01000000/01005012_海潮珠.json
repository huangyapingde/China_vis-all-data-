        {
          "character": "齐王",
          "type": "西皮原板",
          "text": "手挽手儿进府去， 再对卿家说分明： 卿家得的什么病， 快对孤王说从头。"
        },
        {
          "character": "崔杼",
          "type": "双西皮导板",
          "text": "有崔子身有病不能迎驾，"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "夫人，与大王打坐"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "晓得了，哎哎。"
