        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崔杼、棠姜同上。"
        },
        {
          "character": "崔杼",
          "type": "西皮摇板",
          "text": "假意儿跌倒在流平地上，"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "夫人你搀我来。"
        },
        {
