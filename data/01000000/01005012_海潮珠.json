        {
          "character": "崔杼",
          "type": "西皮慢板",
          "text": "他二人果然有此心肠。 叫夫人搀扶我下床去， 本帅见驾说分明。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "夫人搀我下床，迎接大王。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "床下有风。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "我不怕风了。"
        },
        {
          "character": "崔杼",
          "type": "西皮摇板",
          "text": "有崔子下床来假意栽倒， 叫大王近前来细听根苗： 倘若是为臣亡故了， 撇下了我的妻无有下梢。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "呔。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "卿家若是你死了，你妻有孤照应。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "着吓，撇下为妻，有大王照应。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "不要你多言。"
        },
        {
          "character": "崔杼",
          "type": "西皮摇板",
          "text": "叩罢头来抽身起， 他二人要想活转世投胎。"
        },
        {
          "character": "齐王",
          "type": "西皮摇板",
          "text": "卿家但把心放定， 孤王与你请名医。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "卿家但放宽心，孤王回得朝去，请那太医院，与你疗病就是。孤王要回宫去了。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "为臣身得重病，不能送驾大王。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "不用你送，不用你送。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "老爷身得重病，不能送驾，为妻倒也送得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "你妇道人家，如何送得？"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "方才迎得就送得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "送不得。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "送得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "送不得。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "送得送得。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "如此你与我送、送、送。"
        },
        {
          "character": "棠姜",
          "type": "西皮快板",
          "text": "一见崔子来应允， 怎不叫人喜在心。 手搀手儿出府去， 咱二人到花园前去调情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "棠姜拉齐王同下。"
        },
        {
          "character": "崔杼",
          "type": "西皮摇板",
          "text": "站立二堂用目望， 他二人到花园前去调情。 迈步且把花墙上， 他二人来到看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "棠姜、齐王同上。"
        },
        {
          "character": "齐王",
          "type": "唱",
          "text": "今日与你来调情， 明日接你进宫庭。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "我说你这个人吓，唗唗唗！崔子回朝，就该将他斩首。为什么还请太医院，与 他疗病？"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "我说你这个人吓，嗳嗳嗳！哪里是与他疗病，分明是下付毒药，将他害死，你 我不是长久夫妻么。"
        },
        {
          "character": "棠姜",
          "type": "白",
          "text": "这就好了。"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "好贱人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崔杼追齐王同上。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "卿家这是为何？"
        },
        {
          "character": "崔杼",
          "type": "白",
          "text": "好昏王！"
        },
        {
          "character": null,
          "type": "stage",
