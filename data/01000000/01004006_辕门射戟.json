        {
          "character": "刘备",
          "type": "白",
          "text": "上前投帖。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "投帖乃是小事，待小弟上前。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你不会讲话。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我连话都不会讲呢？呔，有人么，滚出一个来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吕布狗子，可曾升帐？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "他升帐不升帐与你什么相干？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你就说大伯伯、二伯伯、三老子来了！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "这是什么话？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你不通报，呸，照打！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，你不会讲话。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "他不与我通报。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你站远些。烦劳通禀，桃园弟兄求见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "少站一时。 启禀温侯：桃园弟兄求见。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "温侯，"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "使君。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "温侯，"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "君候"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞进。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "刘备、关羽",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "吓，贤弟……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，俺大哥乃中山靖王之后，孝景皇帝阁下玄孙，你敢叫他贤弟！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，温侯，温侯。吓，三弟，温侯叫我贤弟，与你什么相干？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我不许他叫。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你不要讲话。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我就不讲话。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你与我坐下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我就坐下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，温侯，"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "不知使君驾到，未得远迎，当面恕罪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "少来问候，都督海涵。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "岂敢，二君候可好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "温侯驾安。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟，与温侯见礼。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺老张不会见礼。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，桃园呢？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咳，俺老张不与吕布狗子见礼，俺大哥在一旁“桃园”“桃园”呢！俺老张一 生一世，就吃这“桃园”亏了。吕布狗子，请了！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "哪个是狗子？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你是狗子！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "你是狗子！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，温侯！ 吓，你怎么叫他狗子？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "他本来就是狗子！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我不许你讲话！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我就不讲话！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你与我坐下！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我就坐下！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "温侯，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎，咦咦咦……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，温侯，"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "黑脸的可好？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺老张无病，怎么不好？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "身为大将，事要正办，酒要少饮。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，俺老张不过一时酒醉，你不该夺我徐州！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哪个？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，温侯！ 吓，事到如今，提起徐州则甚？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "这样之人我要顶他两句！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你不要讲话！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我就不讲话！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你与我坐下！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我就坐下！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，温侯，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我坐下，你请安！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "温侯相邀我等有何见论？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "请使君到此，与你二家解围。"
