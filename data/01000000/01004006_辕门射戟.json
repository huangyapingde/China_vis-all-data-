        {
          "character": "刘备",
          "type": "白",
          "text": "不知怎样的解法？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "等纪灵到此，自有定夺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "纪将军到。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "不妨，有某担任。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵、四龙套同上。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "温侯！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "将军。"
        },
        {
          "character": "纪灵、吕布",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "且慢，为何去心太急？"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "营中有事。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "吓，营中有事，你就不该来，坐下了！"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "有坐，温侯敢是欺某？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "非也，俺无霸王之勇，不过与你二家解围，不必多疑，请坐。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "但不知怎样的解法？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "宴罢之后，再为定夺。刘使君见过纪将军。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，纪将军，"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "哪个与你见礼！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "宴罢之后，自有道理。来，将宴摆下。"
        },
        {
          "character": "吕布",
          "type": "西皮导板",
          "text": "中军帐内饮琼浆，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哇呀！"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "是哪里响雷？"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "张将军虎威。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "吓了我一跳！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "原来是草包！"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "只为和好免争强。 怒气不息纪灵将， 那一旁闷坏了刘、关、张。 回言便对将军讲： 看某且免动刀枪。"
        },
        {
          "character": "纪灵",
          "type": "西皮摇板",
          "text": "多蒙温侯赐琼浆， 某家言来听端详： 不看温侯脸面上， 霎时席前摆战场。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "走上前来忙告退， 今日此宴难奉陪。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "帐下听真：有人不服者，要杀抬枪，要战何惧！"
