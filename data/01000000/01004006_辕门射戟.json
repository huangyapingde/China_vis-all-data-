        {
          "character": "张飞",
          "type": "白",
          "text": "呔，纪灵！想你带领不过十万之众，可记得大破黄巾雄兵百万，被俺枪挑鞭打！"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "你敢上来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你敢下来？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "且慢，与你两家解围，谁叫你等争斗起来！"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "不知怎样的解法？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "辕门之外立一方天画戟，本侯一箭箭射中心，你两家收兵回转……"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "倘若不中？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "但凭你二家所为。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "告便。且住，温候言道，辕门之外，立一方天画戟，箭射红心，我两家收兵回 转。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "但愿得射得着。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "但凭温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "有佔了！"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "画戟抬在辕门外， 两家人马站两旁。 人来看过弓和箭，"
        },
        {
          "character": "刘备",
          "type": "西皮快板",
          "text": "汉刘备上前来祝告神威： 但愿得老天爷扶保刘备，"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "使君休要心发愁。 双手搭上珠红扣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布照箭，射。"
        },
        {
          "character": "吕布",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "这一箭射去了兵有数千！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "还有什么话讲？"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "想我怎样回复我主？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "待我修下书信，回复你主。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "但凭温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "浓墨伺候。"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "上写拜上多拜上， 拜上袁王看端详： 刘备看在我面上， 免得两下动刀枪。 一封书信忙修上， 烦劳将军奏你王。"
        },
        {
          "character": "纪灵",
          "type": "西皮快板",
          "text": "纪灵接书面带愧， 背转身来把胸槌。 上前施个分别礼， 奉命夺沛空走一回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵、四龙套同下。"
        },
        {
          "character": "吕布",
          "type": "西皮快板",
          "text": "这一箭射却了百万雄队，"
        },
        {
          "character": "刘备",
          "type": "西皮快板",
          "text": "吕温侯可算得将中之魁！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "使君，后来若有得地之日，切不可忘却了辕门射戟的情由！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "温侯，后来忘了辕门射戟情由，这天……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥天色不早了，你我弟兄回去了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "纪灵讨战。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同白",
          "text": "待俺弟兄出马！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "且慢，请在后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、张飞同下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "众将官抬枪带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵上，会阵。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "纪将军为何去而复转？"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "奉了我主之命，灭尔的徐州！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "一派胡言！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵、吕布会阵，同开打。纪灵败下。"
        },
        {
          "character": "吕布",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
