      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贺天保上。"
        },
        {
          "character": "贺天保",
          "type": "二黄摇板",
          "text": "在生时谁不知江南四霸， 到如今作忠魂答报皇家。"
