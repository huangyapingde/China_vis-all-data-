    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（贺天保上，众人同上，同围贺天保，大绕场，余六以飞抓打贺天保，贺天保下。管宁上，开打，众人同下。"
        },
        {
          "character": null,
          "type": "text",
          "text": "卢志义魂引秦盛上。）"
        },
        {
          "character": "秦盛",
          "type": "白",
          "text": "俺正在公馆打睡，梦见卢志义前来言道：他一人私自探山，被余六将他杀死， 叫我与他报仇。是俺昏昏沉沉来在此地。好一高大山头，想必就是浮山了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "秦盛",
          "type": "白",
          "text": "听山内有喊杀之声，待俺赶上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦盛入山，下。"
        }
      ]
