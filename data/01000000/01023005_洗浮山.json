        {
          "character": "黄天霸",
          "type": "白",
          "text": "众位英雄，昨晚三更，偶得一兆，见贺天保兄长浑身是血，言道他一人私自探 山，倍余六飞抓打死了。吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸哭。"
        },
        {
          "character": "李堃",
          "type": "白",
          "text": "黄爷，休得悲泪，待等着人，打探明白，再作道理。"
