    },
    {
      "name": "吕洞宾",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    },
    {
      "name": "关平",
      "hangdang": "武生"
    },
    {
      "name": "周从纶",
      "hangdang": "小生"
    },
    {
      "name": "书童",
      "hangdang": "丑"
    }
  ],
  "plot": "此种神怪杂剧，大都十九子虚，无从考索，即或偶有所本，而纯乎述信之谭，且属在孔子四不语之例。则亦\n何庸搜神志怪，以重世人疑心生暗鬼之愚。至其大概，即从昆剧《请师斩妖》出翻成，略谓青石山有风魔洞，\n洞中有千年之九尾妖狐，化身为美妇人，在周家作法施妖，蛊媚其少年主人名德龙者，致此主人终日捉空\n喃喃，似病疯癇一般。其家习闻道十能捉妖怪，遂延请王法师到家蘸禳，讵如绝无效验，反致愈益猖獗。卒\n赖吕纯阳至，为之召请天将，召得关公及周仓等（昆剧中系二郎神杨戬），方用神兵降伏擒斩而毕，盖仍以\n迷信收场也。",
  "notes": "寻常仅演《请师斩妖》一段。此曲本则系全木，世人苟善能观戏者，则于此剧当可得二大领悟。一则对于外\n遇之美妇人，苟淫媚而惑己者，皆当视等九尾狐一例；一则凡迎神求仙禳灾祈福之举，可知皆王法师类也，\n非徒无效，反足召祸。人均能作如是观，则是剧虽神怪不经，而既得大错之说破，则当亦不为无益矣乎。此\n大错之所以不欲考而终不得不略言其大概也。杨小楼于《青石山》，颇有名，试参观本考第七册之真影可。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "狐形上，跳下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "火彩，四小妖、四女妖引九尾仙姬同上。〖点绛唇〗。九尾仙姬上高台。"
        },
        {
          "character": "九尾仙姬",
          "type": "念",
          "text": "天上雾层层，地下雨纷纷。任他风波起，各自显神灵。 奴乃九尾仙姬是也，在青石山下，风魔洞中，修炼千年。昨日朝罢圣母而归， 这机仙言道，奴与周从纶有姻缘之份。想我乃是仙体，他乃凡人，怎与他配得 佳偶？哦有了，今日乃是清明佳节，那周官人必定前去上坟插柳。我不免去到 他家坟前，变一凡妇模样，等他到来，用巧言打动于他。若能成就良缘，岂不 两全其美。 众小妖！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小妖、四女妖同允。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "随俺到周家坆冢去者。"
        },
        {
          "character": "四小妖、四女妖",
          "type": "同白",
          "text": "领仙旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周从纶上。"
        },
        {
          "character": "周从纶",
          "type": "引子",
          "text": "苦读寒窗，何日里，才把名扬？"
        },
        {
          "character": "周从纶",
          "type": "念",
          "text": "少小须勤学，文章可立身。满朝朱紫贵，尽是读书人。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "小生周从纶，乃洛阳人氏。父亲周继昌，不幸早逝，撇下母子二人，是我苦读 诗书，闭门不出，今当清明佳节，不免去至爹爹坆茔，祭扫一番。 吓，家院哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子同上。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "来了！"
        },
        {
          "character": "二院子",
          "type": "同念",
          "text": "堂上一呼，堦下百诺。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "公子。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "唤老奴出来，有何吩咐？"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "命你等准备祭礼，坟茔祭奠。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "祭礼一概齐备。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "吩咐小使抬上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子同允。"
        },
        {
          "character": "二院子",
          "type": "白",
          "text": "祭礼抬上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍抬祭物同上。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "带马伺候。"
        },
        {
          "character": "周从纶",
          "type": "西皮原板",
          "text": "白幼儿习孔孟心血用尽， 又谁知天不佑不第回程。 叫家院忙带路缓步前进， 但不知何日里浪级禹门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小妖、四女妖引九尾仙姬同上。"
        },
        {
          "character": "四小妖、四女妖",
          "type": "同白",
          "text": "来此周家坟茔。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "众小妖回避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小妖、四女妖同下。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "待我变一凡妇模样。在此等候周官人到来便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "九尾仙姬当场换妆。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "哦，远远望见周家官人来也。"
        },
        {
          "character": "周从纶",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍抬祭物同上，二院子引周从纶同上。"
        },
        {
          "character": "周从纶",
          "type": "西皮摇板",
          "text": "一路上观不尽野花美景， 霎时间已到了周氏祖茔。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "来，将祭礼摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二院子同允。小过门。周从纶拜。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "哎呀，爹爹吓！"
        },
        {
          "character": "周从纶",
          "type": "西皮导板",
          "text": "见坆台不由儿珠泪滚滚，"
        },
        {
          "character": "周从纶",
          "type": "西皮摇板",
          "text": "儿好似刀割胆箭穿我心。 望爹爹在阴曹多多保验， 愿孩儿登分榜及早成名。 哭罢了老爹爹家院来叫， 将祭礼收过了转回家门。 命小使将草料喂好马匹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子、四青袍同允，同下。"
        },
        {
          "character": "周从纶",
          "type": "西皮摇板",
          "text": "且迈步坟前后查看一番。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "哎呀，苦吓！"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "吓，那旁有位小娘子，为何来到吾家坟前啼哭。哦哦，其中必有缘故，待我向 前问来。 吓，小娘子，小生有礼了。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "奴家还礼。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "请问小娘子家住哪里，姓甚名谁，因何来到吾家坆前啼哭。请道其详。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "相公容禀。"
        },
        {
          "character": "九尾仙姬",
          "type": "西皮摇板",
          "text": "未曾开言泪先淋， 尊声相公听详情： 家往本城洛阳郡， 鼓楼大街有家门。 奴夫张姓名文成， 奴名叫做花秀英。 吾夫贸易未回转， 一去数载杳无音。 家有婆婆心肠狠， 逼勒奴家改嫁人。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "哦，你既有夫之妇，为何要逼你改嫁呢？"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "相公有所不知，因我丈夫，出外贸易，杳无音信。婆婆无有衣食，故尔逼奴改 嫁的呢。相公你岂不知，古语云“好马不配双鞍子，烈女岂嫁二夫君”！"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "是吓！"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "小妇人至此，意欲寻个自尽，不知是相公祖茔，望乞恕罪。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "岂敢，既然如此，待我着人送你回去就是。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "唉呀相公，承你美意，送我回去，岂不是火上加油了么。唉呀，我情愿死在此 地，也是不回去的呢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "九尾仙姬哭。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "小娘子不要啼哭，依你主见，便怎样呢？"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "既承相公施恩，何不带着小妇人，到相公府上暂住几日，待我婆婆回心转意， 那时再回家中，但不知相公尊意如何？"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "唔唔唔，想小娘子乃是有夫之妇，怎叫我带你同行，只恐旁观不雅，断然使不 得的。"
        },
        {
          "character": "九尾仙姬",
          "type": "哭",
          "text": "哎呀……"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "这便怎么处？哦有了。 小娘子，且止啼哭，待我回去禀知家母，方可接小娘子回去。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "如此相公请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子、四青袍同上。"
        },
        {
          "character": "二院子、四青袍",
          "type": "同白",
          "text": "相公，天色巳晚，回去罢。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "如此带马。"
        },
        {
          "character": "周从纶",
          "type": "西皮摇板",
          "text": "若非俺上坟来将她救下， 险些儿遭不幸命染黄沙。 怕的是有外人观之不雅， 我若是起歹意天地鉴察。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子、四青袍、周从纶同下。"
        },
        {
          "character": "九尾仙姬",
          "type": "西皮摇板",
          "text": "这也是前世里姻缘结下， 奴岂肯误良宵舍此俊雅。 施法力管叫他将我牵挂， 待三更到书房倍伴与他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "九尾仙姬下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "吕洞宾",
          "type": "内西皮导板",
          "text": "适才间离却了蓬莱仙境，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八云童引吕洞宾同上。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮原板",
          "text": "奉师命显道法点石为金。 在洞府观看那松柏茂盛， 花开放和结子迅速光阴。"
        },
        {
          "character": "吕洞宾",
          "type": "白",
          "text": "贫道吕岩，道号洞宾，方才与果老仙翁，在那蓬莱顶上奕棋散闷。忽有仙童来 报，奉金母之命，相邀吾等，去赴金花盛会。 众云童驾云前往。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮原板",
          "text": "我也曾岳阳楼三醉比胜， 我也曾邯郸县渡过卢生。 俺这里驾祥云速往前进， 去赴那金花会恭贺相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕洞宾、八云童同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。周从纶上。"
        },
        {
          "character": "周从纶",
          "type": "西皮原板",
          "text": "在坟前见佳人心神不定， 老娘亲她道我起下歹心。 曾命我至书房观看占今， 但愿得开科场皇榜题名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。九尾仙姬上。"
        },
        {
          "character": "九尾仙姬",
          "type": "西皮摇板",
          "text": "奴这里施法力府门来进， 到书房见相公细诉其情。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "相公开门来。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "是奴在此。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "吓来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周从纶开门，看，关门。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "哎，方才分明有人叫门，好像坟前那位小娘子的声音。吓，为何不见呢？哦是 了，想是我的母亲，恐我在书房贪玩，故尔至此窥视与我，也未可知。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "相公，快些开门来。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "吓，又在那里扣门了。 你可是坟前那位小娘子么？"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周从纶开门。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "你怎么进得吾府？"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "奴见府门打开，无人阻拦。我就进来了。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "可有人看见于你？"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "并无一人知觉。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "想我书房，乃是用功之所，焉能隐藏小娘子么。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "奴到有个主意在此。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "有何高见？"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "我有心与相公成其美事，但不知你意下如何？"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "吓，小娘子，我想姻缘之事，必须要奉父母之命，央媒说合，岂能私配之理。 哎呀呀，此事断然使不得的。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "相公你若不允，我就喊叫四邻，到了当官，我就说你相公，诱奸有夫之女，你 该当何罪？"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "哎呀小娘子，不必如此，这是那里说起。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "相公，你若疑心未决，我就与你对天一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "九尾仙姬拉周从纶拜。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "哎呀呀使不得的。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "来吓。"
        },
        {
          "character": "九尾仙姬",
          "type": "西皮摇板",
          "text": "今日如比七月七， 牛郎织女会佳期。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。周从纶、九尾仙姬同进帐。〖起四更鼓〗。书童上。"
        },
        {
          "character": "书童",
          "type": "念",
          "text": "奉了安人命，烹茶到书房。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "我周安便是，奉了安人之命，送茶书房，叫我家相公起来用功。吓，怎么书房 门开在这里？待我进去叫来。 吓，相公起来，相公起来。"
        },
        {
          "character": "周从纶",
          "type": "西皮导板",
          "text": "耳旁听得人声嚷，"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "周从纶",
          "type": "西皮摇板",
          "text": "大胆小使太猖狂！"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "呔，大胆奴才，我娘子在此，你、你、你竟敢进我书房。唔，还不出去！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哎呀，这是什么意思吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周从纶拉书童。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "哎呀，娘子吓！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哎吓，相公，我旱道可不通的。"
        },
        {
          "character": "周从纶",
          "type": "西皮摇板",
          "text": "你若是与相公作了勾当， 我与你做夫妻地久天长。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "来吓。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哎呀，相公我不行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周从纶神气。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "这差使我可当不了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童下。"
        },
        {
          "character": "九尾仙姬",
          "type": "白",
          "text": "相公还是来罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "九尾仙姬浪抅周从纶。"
        },
        {
          "character": "周从纶",
          "type": "白",
          "text": "哎呀，娘子吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "九尾仙姬、周从纶同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "书童上。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哎，想必我相公，得了疯病了。不免去到上房，报与安人知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "念",
          "text": "奉了安人命，忙步不留停。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "昨日我家相公，在坟茔之上遇见那个年轻妇人，谅必定是妖魔，前来作耗。故 尔相公得此疯病。我家安人命我前去请王半仙前来降妖捉怪。正是“天有不测 风云，人有旦夕祸福”。来此已是。 吓，王法师在家么？"
        },
        {
          "character": "王法师",
          "type": "内白",
          "text": "不在家。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓，分明在家，怎说不在家？"
        },
        {
          "character": "王法师",
          "type": "内白",
          "text": "人不在家，单丢了一张嘴在家。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哎，还是在家出来罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王法师上。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "王法师",
          "type": "念",
          "text": "忽听人声唣，必是妖怪前来到。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王法师开门。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哦，我道是谁，原来是你老人家。请。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "家里老太太好？大嫂子大侄姑娘多好？猫儿狗鸡鹅鸭都好？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哎，畜生问他怎么？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "不问畜类，畜生怪我。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么话。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "呀，你是谁？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "问了半天，你还不认识我么？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "面熟，不敢瞎招呼。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "我就是周小官人的家人周安。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哦，你我说丁半天，你就是周府的周大爷吓。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "好杂种。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么话。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我眼睛欠光一时看不清，连大爷多会不认识了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "大爷，你是野猫进宅……"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓什么野猫，夜猫。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "不错，夜猫进宅，无事不来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "非为别事而来，只因我家相公，昨日上坟插柳。在坟前见一妇人啼啼哭哭，我 家相公解劝了一番回来。晚上偶得疯病。想这妇人，必是妖魔。前来作耗，故 尔相公得了疯病。我奉安人之命，来请师父前去降妖。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "但是今年不比往年。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "为何呢？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "弃了行业了！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "弃了什么行业了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "如今不降妖了，在大街之上卖符度日。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "师父看我员外在日之面，去这一遭。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哦，看你员外份上，去这一趟。呀，去不成。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我徒子法孙不在家，没人与我背包袱。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "拿来，我与你背上。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我告个罪。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "那么你权当我的徒子法孙。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "不要讨便宜，走吧。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "慢着，待我锁上门，不要叫羊吃了我的被子。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "怎么你的被会叫羊吃了？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "你不晓得，我的被窝，是稻草打成的。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哈哈，笑话了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "大爷了不得了，没有叫你喝茶。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "在家里不叫我喝茶，如今出了门户，还叫喝茶则甚。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我是灯草赶羊假意邀。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "走罢，到了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "不用倒，留着喂狗。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "到了家了，请罢。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哎呀，好大妖气。待我见见老太太。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "师父请到。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "老太太，王法师有礼了。 可了不得了！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我正与老太太施礼，只见那妖打我面前一绕，把我的眼睛，多绕花了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "不是的，乃是你手中的云帚，绕了一下。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我到不信，我再来试试看。吓，老太太，王法师有礼了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是妖怪不是？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "可不是，我的云带绕了一下子。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "师父看看到底什么妖怪。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哦。待我看来。哎吓，不是别的，乃是个棒槌精。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "何为棒槌精？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "这是老娘儿们洗衣服用的棒槌扎破了手，流出血来，沾在上面多年，受了日精 月华。故而成了棒槌精。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "用什么降他。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "嘴说不行，要开单子，拿笔砚来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "笔砚有了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "猪头—个，要八百二十斤重。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哪有这么大的猪头。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "这是西洋来的猪。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "减省的呢？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "只须三个钱的猪头肉也是使得个。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓，太小气了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "雄鸡一只，重要七百斤。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "那有那么大的鸡。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "也是外国来的。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "可能减省些？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "五个钱买个鸡蛋。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "太省了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "鲤鱼一尾，就省点罢，四百斤。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "就是海里也捉不起，这么大的鲤鱼来。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "那么就是喂猫的猫鱼，拣一个大的罢。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "过省了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "黄表五百刀。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "太多罢。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "就买三张。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "又太少。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "红烛一对，重一千斤。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "现浇也来不及。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "那么两个钱买一对磕头腊。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "太不像样了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "香一颗，快办去。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是了，照单办来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家人内允。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "包袱打开，拿出我的怒发沖……"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么叫“沖”？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "冠。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哦，道冠。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "再拿我的渔翁撒……"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么叫“渔翁撒”？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我们的法衣，叫渔翁撒网。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哎，你的名儿真多。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "还拿我遮脸笏。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "又是什么？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "象牙朝板。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "象牙朝板，就给了，什么遮脸笏。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哎呀，还拿不成。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "怎么拿不成？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "没人打家伙。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "我家有班顽友，请他们打起来。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "好。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓，众位请你们打打家伙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家人内允，乱打。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "得了得了，乱打二十四起，和尚有和尚典，道士有道士典，要打出个名堂来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "只要你交待他们。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "叫他们看我脑袋一幌，就是一噹；屁股一厥，就是一吱。要打个噹噹吱，记下 了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家人内允。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "叫他们打起来，噹噹吱吱噹噹。哎呀哎呀啊啊哇。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "叫你拿妖，你怎么肚子疼起来了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "你弄错了，这和尚有和尚腔，尼姑有尼姑腔。你妈妈偷道士有道士的。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "不要闹。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "奉请南方火刀、火石、火龙、火马、火德星君，速降门庭！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哎，叫你拿妖，怎么打起醮来了。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "你叫我来打火醮么。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "拿妖。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我倒忘了，再来，哎哟哟，奉请五湖四海九江八河东海龙君速降来临！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "得了，我又不求雨，你怎么请龙王。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "下了雨，妖怪上屋里来，我好拿他。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哦，妖怪怕雨？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "可不是的。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "那么再来。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "再来，哎呀哎呀赵、钱、孙、李老君，周、吴、郑、王天君，冯、陈、褚、卫 四国老，蒋、沈、韩、杨四将军。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "你怎么念起《百家姓》来了？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我且问你，妖怪姓什么？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "我不知道。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "却又来了，我念到他的姓他就来了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "那么你念。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "你跟我跑五方。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "怎样跑？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "你取瓶净水来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "净水到。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "拿我的宝剑来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "在此。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "把锣敲起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王法师、院子同跑五方。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "吾奉太上老君急急如令，恭喜恭喜。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "妖怪拿住了么？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "被我赶出去了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "赶到哪里？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "云南边地。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "她今晚来不来？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "来不了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "明日呢？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "谅她不敢来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "你要除根才好。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哦，除根，待我歇歇，你把鸡子烫烫饭来，我吃饱了，与你除根。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子允，下。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "我哪里会降妖，不过混饭饭吃。闹了半天，待我唱个小曲开开心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王法师唱小曲。"
        },
        {
          "character": "王法师",
          "type": "唱",
          "text": "姐在房中正描花， 忽然想起了俏冤家。 临走嘱咐我的话，再三叮咛， 哟哟呵哟呵哎哎哟，不要忘了他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "王法师。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "哎吓，我的妈，饶命吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王法师躲桌子下。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是我，你攒出来罢。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "得了，我认是妖怪，还是鸡子汤。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "鸡汤在此。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "好鸡子汤，真鲜。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "你唬昏了，开水泡饭，还吃不出？"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "呀，你来蒙我，叫我蒙谁？我不干了，鸡汤也不吃了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王法师收家伙。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "师父不要走。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "你不要急，我去请我师父前来，与你降妖。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "将家伙放下，我才放心。"
        },
        {
          "character": "王法师",
          "type": "白",
          "text": "好。交待与你。我去请来便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王法师下。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓闹了半天，屁也没拿着一个，还想鸡汤吃，真真好笑，哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        }
      ]
    },
    {
      "scene_id": 9,
