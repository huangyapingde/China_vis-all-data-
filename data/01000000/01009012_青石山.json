        {
          "character": "功曹",
          "type": "白",
          "text": "有何法谕？"
        },
        {
          "character": "吕洞宾",
          "type": "白",
          "text": "现有表文一道，命你南天门投递。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "功曹允，下。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮摇板",
          "text": "将身兄来至在云霄以外， 收伏了小妖么礼应合法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕洞宾下。"
        }
