      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众天将云幔遮同上高台。"
        },
        {
          "character": "关羽",
          "type": "内二黄导板",
          "text": "想当年辅汉室忠心扶保，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火彩，开幔。雨马童神上，关羽上。"
        },
        {
          "character": "关羽",
          "type": "锁呐二黄慢板",
          "text": "恼恨那小妖魔搅乱吾朝。 今有那吕法官牒文来到， 因此上带神将收伏此妖。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "蚕眉赤脸美髯飘，红光日照偃月刀。跨下赤兔胭脂马，一片忠心保天曹。"
        },
        {
