        },
        {
          "character": "吕洞宾",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕洞宾下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "众神将，撒下天罗天网！"
