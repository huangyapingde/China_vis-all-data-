{
  "script_id": "01032006",
  "title": "芙蓉诔",
  "alias": [
    "晴雯归天"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "晴雯",
      "hangdang": "旦"
    },
    {
      "name": "贾宝玉",
      "hangdang": "小生"
    },
    {
      "name": "焙茗",
      "hangdang": "丑"
    },
    {
      "name": "丫鬟",
      "hangdang": "贴旦"
    },
    {
      "name": "仙女",
      "hangdang": "贴旦"
    },
    {
      "name": "晴雯嫂嫂",
      "hangdang": "丑"
    },
    {
      "name": "五儿",
      "hangdang": "旦"
    }
  ],
  "plot": "王夫人因傻大姐误拾绣春囊，王善保家的妒恨睛雯，乘势进谗，王夫人抄检大观园，逐出晴雯，睛雯带病负\n气抵家，病益重。贾宝玉偷往探望，睛雯与之诀别。贾宝玉于其死后，闻其封为芙蓉花神，乃写《芙蓉诔》\n祭之，以泄郁闷。",
  "notes": "定名分而复分主奴，分主奴而后有贵贱，古今一辙，不易之常理也。故理可以制情，情不合乎理，所谓反常，\n终归于无情而已。贾宝玉，钟情者也，姐妹行间，日与厮混，爱之重之，情之作用固如此，而侍婢辈，亦\n何莫不然，竟以同等看待，无所谓主奴，无所谓贵贱也。晴雯亦侍婢之一，颇得贾宝玉之欢心，志高气傲，\n本属天赋，贾宝玉常纵容之，恃宠而骄，忘其为侍婢之身分矣。本考上册，载有《晴雯撕扇》一剧，平日之\n撒娇撒痴，毫无忌惮，枕可想见，得罪之由，实兆端于此。且晴雯被攒出府，蕴酿已非一日。贾宝玉既非常\n怜爱，妒忌者必多；自高位置，与同辈周旋，不肯稍假辞色，怨恨者必多；环伺其隙，继久自然勃发，正如\n水银泻地，无孔不入，于是晴雯万不能一刻容留矣。乃病忽加重，竟至不起，一激而齐恨九泉，良可悲痛，\n人谓主人之情而不情，以致如此，我则谓晴雯自取其祸，不能归咎于贾宝玉，更不能归咎于贾母。观剧者欲\n知详细，请参阅《金玉缘》一堂。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "晴雯",
          "type": "内白",
          "text": "苦啊！"
        },
        {
          "character": "晴雯",
          "type": "内二黄导板",
          "text": "无情天，他他他，他他他，偏把俺，生作女儿身，三江水洗不去这妖狐名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯披发上，跌倒。丫鬟上，扶晴雯起。"
        },
        {
          "character": "晴雯",
          "type": "二黄慢板",
          "text": "悔当初万不该烂漫天真。 悔当初万不该嫉恶太甚， 悔当初万不该以礼节，清到而今， 害得我冤屈莫伸，纵死在九泉下目也不瞑。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "啊，晴雯姑娘，病中被逐，到底为了何事？何不见过老太太，赔罪认过央告几 句。她老夫人家发个慈悲，天大的事，也就完了，在此悲伤何益。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "妹妹，你说哪里话来。想俺晴雯，在大观园中，独往独来，从不仰人鼻息，我 本无过，央告什么？我本无罪，何用慈悲？我们不幸生作女儿，又作侍婢，真 是不幸中之不幸，只要问心无愧，正当抖擞精神，为我女儿家，留点身分，莫 玷污了“女儿”这两个字。正是："
        },
        {
          "character": "晴雯",
          "type": "念",
          "text": "一点贞心照千古，不向东风浪折腰。"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "说什么堂前苦哀告， 说什么赔罪折纤腰。 我只自问无愧怍， 留取气节作女豪。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "啊，晴雯姑娘，既不肯去见老太太，何不见过宝二爷，说说离情，也是你二人， 相处了一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯惊。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "噢，那宝玉么，哎，我是不见他的了。啊，我是不能见他的了，啊，啊，啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯、丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉上。"
        },
        {
          "character": "贾宝玉",
          "type": "引子",
          "text": "愿作护花主，平生一片心。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "俺，贾宝玉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焙茗抢上。"
        },
        {
          "character": "焙茗",
          "type": "白",
          "text": "报报报，二爷大事不好了！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "啊，焙茗，何事如此惊慌？"
        },
        {
          "character": "焙茗",
          "type": "白",
          "text": "晴雯姑娘，不知为了何事，被太太立时逐出园去。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "焙茗",
          "type": "白",
          "text": "晴雯姑娘，逐出园去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉拭泪，搓手。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "有这等事么？呀吓不好了！"
        },
        {
          "character": "贾宝玉",
          "type": "二黄摇板",
          "text": "听说逐出小晴雯， 好似钢刀刺我心。 恼恨情天何太狠，"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "晴雯姐姐！"
        },
        {
          "character": "贾宝玉",
          "type": "二黄摇板",
          "text": "无限心领痛冤沉。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "呀，焙茗，不知晴雯被逐，究竟为了何事，现在何处，你可知道？"
        },
        {
          "character": "焙茗",
          "type": "白",
          "text": "哎呀，二爷，晴雯姑娘，乃是园中最矫激，有气节的女儿，此番被逐，定是被 那姐妹们，谗诉所中，一个逐令一下，刻不容留，就回家去了。啊，啊，啊。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "如此说来，你与我悄悄备马，由便门出园，速去速去！"
        },
        {
          "character": "焙茗",
          "type": "白",
          "text": "是，晓得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焙茗下。"
        },
        {
          "character": "贾宝玉",
          "type": "哭",
          "text": "啊，晴雯姐姐呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "晴雯嫂嫂扶晴雯病装同上。"
        },
        {
          "character": "晴雯",
          "type": "反二黄原板",
          "text": "一日别离一日心， 病魂犹绕大观园。 多情公子难相见， “妖狐”二字痛冤沉。 再不能怡红闻夜宴， 再不能扯扇掷千金， 再不能病补孔雀裘， 再不能悄听潇湘琴。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "宝玉呵，"
        },
        {
          "character": "晴雯",
          "type": "反二黄原板",
          "text": "枉费了你一段护花心， 要想见除非是这梦里贞魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯嫂嫂推晴雯伏病床，晴雯气郁。"
        },
        {
          "character": "晴雯嫂嫂",
          "type": "白",
          "text": "哼，哼，不得了，姑娘，你不要装斯文了。你自己想想，当日在大观中，何等 尊贵，哪一个高攀得上？你多少年儿，从不到娘门上。瞧一瞧你心上的人，又 是什么姑娘哩，少爷哩，全不把我们放在眼里，我们常说，贵人是不蹈贱地的 了，不料想今日，你还认得家。常言说得好，出了娘家门，还有姨家门，凭姑 娘有这个模样儿，宅门上买姨娘娘的，怕买不到手啦，哭什么，瞧好的啵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯气心痛。"
        },
        {
          "character": "晴雯嫂嫂",
          "type": "白",
          "text": "别撒娇了，我不喜欢那个样儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯怒。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你你嫂嫂不羞，敢在我面前来，胡言乱语，还不与我快走出去。"
        },
        {
          "character": "晴雯嫂嫂",
          "type": "白",
          "text": "走可别叫我，我看谁来服侍你，咱斗牌去，阿弥陀佛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯嫂嫂下。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "啊呀，天哪天那，想俺晴雯，落得这样地步，不如死了罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯昏去。贾宝玉、焙茗同上。"
        },
        {
          "character": "贾宝玉",
          "type": "二黄摇板",
          "text": "马上伤情魂欲断， 可怜一步一啼痕。"
        },
        {
          "character": "焙茗",
          "type": "白",
          "text": "来此已是。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "上前扣门。"
        },
        {
          "character": "焙茗",
          "type": "白",
          "text": "二爷，门正开着，快快进去罢，免得外人瞧见，传进府去，小子耽待不起。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焙茗下，贾宝玉入门，拥晴雯。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐醒来。姐姐醒来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯见贾宝玉，诧异，双手搓眼细看，欲起不能。贾宝玉扶晴雯起。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你怎么来了？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "我因闻知你被逐，故而急急赶来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯惊异。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "我敢是做梦呀？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "明明是我，何言做梦？ （晴雯指案上茶壶，贾宝玉斟茶，看，作恶劣。晴雯招手，贾宝玉送茶就晴雯，晴雯举碗抚贾宝玉肩，饮茶。 贾宝玉作暗暗下泪。）"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "奴只道俺与你此生两参商， 忽相见又寸断肝肠。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "叫奴好喜。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "喜只喜多情公子重相见，"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "叫奴好恨！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "恨从何来？"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "恨只恨数年来，朝朝暮暮时时刻刻，都只为，爱惜声名，辜负鸳鸯帐。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "也罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯咬折手指甲纳贾宝玉荷包内。"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "奴只把这全腔心血交付你， 再相见惟有是梦里高唐。 你与奴把衣裳互换，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯换衣。"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "生同室死同穴只有这件旧衣裳。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "啊，姐姐，被逐出园，因何而起？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯气急。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "噢，你问我这出园吗？咳，你乃好糊涂，贾二爷，呦，呦，呦，呦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仙女暗上，晴雯嫂嫂、焙茗同上，作掩。贾宝玉作惊慌闪躲。晴雯气绝，仙女暗下。"
        },
        {
          "character": "晴雯嫂嫂",
          "type": "白",
          "text": "哎呀，小宝贝人一市，诳狗咬利空，怪不得我……死去活来，今天大好运气， 不料想这阵，到我怀里来了，我看宝贝，你往哪里跑。⑴"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯嫂嫂与贾宝玉扭扯，五儿上。"
        },
        {
          "character": "五儿",
          "type": "白",
          "text": "晴雯姑娘，可好些了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯嫂嫂惊，出迎。贾宝玉逃脱，下。"
        },
        {
          "character": "晴雯嫂嫂",
          "type": "白",
          "text": "我们姑娘好些了，你要他，随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "晴雯宫装手执姑子上。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "俺乃晴雯灵魂是也。警幻仙姑怜俺玉洁冰霜，无罪被逐。封俺为芙蓉花神，今 有神瑛使者，情缘未了，撰成芙蓉诔文，在大观园中，池边相招。你看今宵， 月白风清，不免消遣则个前去。正是："
        },
        {
          "character": "晴雯",
          "type": "念",
          "text": "情丝不断死犹生，赚煞天离离恨人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "晴雯",
          "type": "stage",
          "text": "—————————— ⑴原文残缺。"
        }
      ]
    }
  ]
}