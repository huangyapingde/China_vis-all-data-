{
  "script_id": "01018004",
  "title": "望儿楼",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "窦太真",
      "hangdang": "老旦"
    },
    {
      "name": "李渊",
      "hangdang": "老生"
    }
  ],
  "plot": "剧本情节为唐高祖后窦氏，因次子李世民带兵在外，东剿西征，不获常依膝下，母子隔别，荏苒数年。后终\n日悬想，欲其回来团聚。至深夜独上高楼，推窗遥望以图一面。自悲自叹，涕泪沾襟，尽入于思子之情魔焉。\n呜呼！慈母爱子之心，无所不用其极。锦衣玉食之家，犹且如此，而况茅檐蔀屋中者乎。凡为人子者当体\n会亲心，不使有倚门倚闾之叹，庶几常得天伦之乐事也。观于此剧，而游子悽惶之泪，不禁夺眶而出焉，有\n益于世道人心，实非浅鲜。",
  "notes": "此系老旦单身重头之剧，纯以唱工为主。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引窦太真同上。"
        },
        {
          "character": "窦太真",
          "type": "引子",
          "text": "闷坐宫闱，想娇儿，好不伤悲。"
        },
        {
          "character": "窦太真",
          "type": "念",
          "text": "恼恨单于似豺狼，兴兵扰乱锦家邦。吾儿领兵把贼挡，不知何日转回乡。 哀家窦后。杨广无道，败坏纲常，天怒人怨，群雄蜂起。只为单于兴兵犯境， 建成、元吉两个奴才，上殿奏本，言道吾儿世民武艺高强，定能平灭贼寇。就 命吾儿带领三千人马前去平贼，至今三载有余，竟无音信，也不知生死存亡， 倒叫哀家时时挂念。思想起来，好不悲伤人也。"
        },
        {
          "character": "窦太真",
          "type": "二黄慢板",
          "text": "窦太真坐昭阳自思自忿， 想起了我的儿好不伤情。 恨杨广无道君不修德政， 每日里贪酒色残害黎民。 后花园奸胞妹羞愤自尽， 弟弑兄霸孀嫂败坏人伦。 气死了他的母一旦丧命， 戏父妃丧天良日夜荒淫。 天降下五花棒昏君丧命， 这江山归一统才得太平。 恨建成和元吉上殿奏本， 我的儿领人马去把贼平。 到如今已三载不见音信， 叫哀家终日里常挂在心。 想娇儿把我的心血用尽， 想娇儿止不住双泪淋淋。 将身儿且把那望儿楼进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真上楼。"
        },
        {
          "character": "窦太真",
          "type": "二黄摇板",
          "text": "但不知我的儿何日回京？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监提灯引李渊同上。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "适才间在朝中来标本， 各路兵马乱纷纷。 人来掌灯后宫进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊转场。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "又闻楼上有人声。 站立楼下把身隐， 看是何人把话云。"
        },
        {
          "character": "窦太真",
          "type": "二黄摇板",
          "text": "手扶定楼栏杆用目观定， 开言叫声李世民： 吾儿带兵去临阵， 为何不见信回音？ 眼睁睁我的儿不能相见，"
        },
        {
          "character": "窦太真",
          "type": "哭头",
          "text": "我的儿吓！"
        },
        {
          "character": "窦太真",
          "type": "二黄摇板",
          "text": "不知何日转回京。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "站立楼前仔细听， 却原来是窦后想念世民。 明日殿前将旨降， 即调我儿转回程。 叫人来带路后宫进， 又听谯楼起了更。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊下。〖起初更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "二黄原板",
          "text": "听谯楼打罢了初更时分， 又只见一轮月映照楼门。 有哀家在楼前用目观定， 深宫院静悄悄无有人声。 半空中烟雾沉山川罩定， 也不知我的儿何处存身？ 看不见我的儿何处临阵？ 也不知我的儿何处交兵？ 此时间观不见半点踪影， 好一似万把刀刺在我心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "二黄原板",
          "text": "又听得谯楼上二更鼓震， 一字儿长空雁不住哀鸣。 你可能与哀家寄上一信， 带至在边关外交付儿身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "二黄原板",
          "text": "听谯楼又打罢三更尽， 眼望着边关地大放悲声。 吾的儿领人马番贼会阵， 每日里与番兵对垒相争。 但愿得此一去旗开得胜， 但愿得此一去马到功成。 我的儿若将那贼寇灭尽， 那时节奏凯回庆贺功勋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "二黄原板",
          "text": "又听得谯楼上四更鼓震， 忍不住泪珠儿湿透衣巾。 有哀家望娇儿无人来问， 他怎知我母子难舍难分。 我的儿他为人十分孝顺， 事父母尽孝道定省晨昏。 但愿得众朝臣启奏一本， 唤吾儿早日里转回朝门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "二黄摇板",
          "text": "五鼓打罢天将明， 月暗星稀冷露侵。 盼望娇儿不能见， 好叫哀家恸在心。 悲切切无奈何出楼门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真下楼。"
        },
        {
          "character": "窦太真",
          "type": "二黄摇板",
          "text": "但不知何日里重叙天伦。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "儿吓，儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}