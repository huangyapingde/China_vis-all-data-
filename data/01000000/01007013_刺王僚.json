{
  "script_id": "01007013",
  "title": "刺王僚",
  "alias": [
    "鱼藏剑"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "姬僚",
      "hangdang": "净"
    },
    {
      "name": "姬光",
      "hangdang": "老生"
    },
    {
      "name": "专诸",
      "hangdang": "净"
    }
  ],
  "plot": "吴公子姬光既得伍员，甚相得。商议除姬僚之策。伍员遂转荐专诸可用。姬光即以千金为聘，专诸许以身报。\n后既炼成药剑名匕首，遂设宴款请姬僚，将匕首藏在鱼腹中，令专诸献馔。姬僚素知姬光有不臣心，故虽\n赴宴，防护甚周。内穿膛鳞甲以御凶器，并率禁军数百名，先行搜查一过，然后入宴。进馔之人复须赤身搜\n检。设备至此，亦云密矣。孰意杀人者不在兵、不在两厢、不在献馔人身畔，而竟在鱼腹。卒刺死姬僚，而\n专诸亦以身殉。噫天下事亦险矣，其胜防哉！",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四将、四校尉同上，姬僚上。"
        },
        {
          "character": "姬僚",
          "type": "引子",
          "text": "大地山河，图霸业，一统吴国。"
        },
        {
          "character": "姬僚",
          "type": "念",
          "text": "诸侯一概举心计，霸占江土地无余。开疆占土立大业，列国群雄谁敢欺？"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "孤，姬僚。老王晏驾，无人接位，是孤霸占山河。御弟心怀不臣，在秦小府设 下鱼肠大会，请孤前去赴宴。是孤内穿长猊宝铠，外罩锦袍，以防不测。众位 将军，人马可齐？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "摆驾秦小府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，姬光上。"
        },
        {
          "character": "姬光",
          "type": "念",
          "text": "计就月中擒玉兔，安排香饵钓海鳖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "大殿下到！"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖吹打〗。姬僚、四龙套、四将、四校尉同上。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "御弟！"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "兄王！不知兄王驾到，未曾远迎，恕罪！"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "御弟相邀，有何见谕？"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "兄王有所不知，只因太湖有人进得鲜鱼一尾，烹炙好了，其味无穷。故而请兄 过府同饮。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "到此就要讨扰！"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "内侍看宴！"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "摆下就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "众将！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同允。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "两厢搜来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同搜。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "没有！"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "兄王过府饮宴，为何这等见疑？"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "想想列国之中，兄不得不如此——"
        },
        {
          "character": "姬僚",
          "type": "西皮导板",
          "text": "列国相争干戈厚，"
        },
        {
          "character": "姬僚",
          "type": "西皮原板",
          "text": "弑君不如宰鸡牛。 虽然是御弟的恩情厚， 各自机来各自谋。 孤昨晚一梦真少有， 有孤王坐至在打鱼一个小舟。 见一个那鱼儿在那水上走， 它口吐寒光就照孤的双眸。 它的冷气搜身孤难消受， 高叫声那打鱼的人儿，你就快把那个船来收。 有孤王我正在那高声喊叫无人救， 扭回头我又不见那个打鱼那个小舟。 孤醒来正在那三更后， 止不住我浑身上下一阵一阵，阵阵冷汗流。 吉凶二字孤解也解不透， 御弟与孤你就解根由。"
        },
        {
          "character": "姬光",
          "type": "西皮快板",
          "text": "兄王说话没来由， 梦寐之事何须挂心头！ 人来看过葡萄酿， 小弟保兄坐龙楼。"
        },
        {
          "character": "姬僚",
          "type": "西皮快板",
          "text": "御弟说话孤心受， 你保孤王押诸侯。 天下的举子孤为首， 押定了一十一国，各国不敢统貔貅。 人来推杯你就换大斗，"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "姬僚",
          "type": "西皮摇板",
          "text": "御弟为何面带愁？"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "吓，御弟为何这等模样？"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "小弟不料足尖疼痛难忍。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "快快前去太医院调治！"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "兄长一人在此，弟放心不下。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "御弟你来看，孤内穿长猊宝铠，外罩锦袍三层。两旁战将千员，料无妨碍。快 快调治去罢！"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": "姬光",
          "type": "西皮摇板",
          "text": "谢过兄王龙恩厚， 小弟即来献酒酬。 袖内机关怎猜透， 管叫鱼儿上了钩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬光下。"
        },
        {
          "character": "姬僚",
          "type": "白",
          "text": "来，传进肴人走上！"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "传进肴人走上！"
        },
        {
          "character": "专诸",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸上。"
        },
        {
          "character": "专诸",
          "type": "西皮快板",
          "text": "三皇五帝夏商周， 盖世英雄不到头。 命中有来终须有， 命里无来莫强求。 鱼中暗藏剑一口， 要把王僚一笔勾。 手捧鲜鱼朝上走，"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "呔！作什么的？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "进肴的。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "可有夹带？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "无有。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "我等要搜！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "站立了！"
        },
        {
          "character": "专诸",
          "type": "西皮快板",
          "text": "这才是官差不自由。 解带脱衣你们请搜透，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同搜。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "无有。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "无有？闪开了！"
        },
        {
          "character": "专诸",
          "type": "西皮快板",
          "text": "老天爷助我把名留！ 手捧鲜鱼朝上走， 见君不敢强抬头。"
        },
        {
          "character": "姬僚",
          "type": "西皮摇板",
          "text": "霎时一阵寒风透， 这见鱼儿在当头。 快快拿来孤消受，"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "管叫王僚一笔勾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸刺姬僚，四将同打杀专诸。专诸下。柳展熊上，开打。四将同下。"
        },
        {
          "character": "柳展熊",
          "type": "三笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}