    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四手下、四童儿、四兵丁、辛甲、辛免、太颠、武吉、雷震子、哪吒、韦陀、护法、杨神、龙须虎、杨戬"
        },
        {
          "character": null,
          "type": "text",
          "text": "拿旗引姜尚同上。）"
        },
        {
          "character": "姜尚",
          "type": "点绛唇",
          "text": "天澹云孤，怨云愁雾，施英武，威震征夫，取胜如神助。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜尚上高台。"
        },
        {
          "character": "姜尚",
          "type": "念",
          "text": "事观当场事何欢，世事似同一局棋。空中伸去拿云手，推醒醉卧梦里痴。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "老夫，姓姜名尚字子牙。今日我奉女娲娘娘之旨，用法取斩妲己，以定民心。 再将妖妇首级割下，献与纣王，叫他伐罪。 呔，刀斧手！"
        },
        {
          "character": "四刀斧手",
          "type": "内同白",
          "text": "有！"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "将妲己绑上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手押妲己同上。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "好苦杀人也！好苦杀人也！"
        },
        {
          "character": "妲己",
          "type": "端正好",
          "text": "冷飕飕愁云敝， 心儿内鸭舒舒。 意乱了怀迷， 苏获女自进皇宫内院，何罪是非？ 姜吕望叟，无辜将人寻祸起， 这的也是那城门失火，城门失火！"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "呔，姜尚吓！你冒天封爵，难道君臣之大礼你就无有了么？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "哼哼，想吾主母姜后被你这妖妇害死，今日将你擒住，也是报仇之期，何屈与 你也？"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "想姜后弑叛，若不是多亏我清理宫院，焉能才得太平安享？你怎么不念君臣之 心，动了干戈？致弑我君妃，倾颓擢发难数也！"
        },
        {
          "character": "妲己",
          "type": "滚绣球",
          "text": "你藐君王欢， 论理拉中戈， 把诸侯群聚。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "哼哼哼！还是这样无礼！ 刀斧手！"
        },
        {
          "character": "四刀斧手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "将她推上法台！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手推妲己同上桌。"
        },
        {
          "character": "妲己",
          "type": "滚绣球",
          "text": "俺只见那蟒豺狼列云对， 胆战了心不定。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "武吉！"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "将她用刑！"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "呀！只见是受天去那夫无移，倒落得鲜血淋淋。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "你看刀！"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "哎呀将军吓！"
        },
        {
          "character": "妲己",
          "type": "滚绣球",
          "text": "将军只看俺怯怯惨绳索捆无门避， 望求你宽宏大量停了息嘘唏。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "呔！胆大武吉，军令森严，岂容你邪心不归来！ 将武吉打入后营罪伐。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武吉下。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "杨戬听令！"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "将她用刑！"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "领法旨！"
        },
        {
          "character": "杨戬",
          "type": "快活三",
          "text": "听军令将军使， 听军令将军使， 仗青锋无步撩袍双睛批， 俺自有玄功八九真奇异， 肯饶伊上云梯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨戬斩。妲己无头，去头。辛甲、辛免、太颠、雷震子、哪吒、韦陀、护法、杨神、龙须虎同怕。"
