        {
          "character": "姜尚",
          "type": "念",
          "text": "万将如云尽归周，纣王今日困楚囚。天尊付下封神榜，不让名利似汗流。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "一同前去奏与主公知道。"
