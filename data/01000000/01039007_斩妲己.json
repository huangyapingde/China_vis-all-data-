{
  "script_id": "01039007",
  "title": "斩妲己",
  "alias": [
    "鹿台赐宴"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "姜尚",
      "hangdang": "净"
    },
    {
      "name": "妲己",
      "hangdang": "花旦"
    },
    {
      "name": "纣王",
      "hangdang": "净"
    },
    {
      "name": "玉妹",
      "hangdang": "占旦"
    },
    {
      "name": "喜妹",
      "hangdang": "副旦"
    },
    {
      "name": "周武王",
      "hangdang": "小生"
    }
  ],
  "plot": "剧本从纣王在鹿台与妲己、玉妹、喜妹三妃，彻夜欢宴做起，至周师大会孟津，反入朝歌，被姜尚杀去三妖\n妃为止。开场演鹿台大宴，纣王听妲己之言，立命武士，将渡河涉水之一老一少，尽行斩断其腿骨，以验妲\n己有髓无髓。其残忍无道，不顾民命，亦可谓至于极点矣（此事并非戏剧与小说中之形容虚语，却的是实在，\n即《尚书》中所谓观“涉踖者，而断其胫是也）。于残杀之后，即紧接周师入攻，盈廷无人，愿出抵敌之\n一段。此用意颇严正，既而妲己亲自挂帅出战，自仗妖法，以为无敌，却不道三战三北，三妖妇均被姜尚擒\n住，尽行杀却。",
  "notes": "苏护进妲己，事出《封神榜演义》，亦为近年来本戏中之一种。此《斩妲己》一剧，与《进妲己》同源异流，\n一直紧接，盖即《进妲己》之后本也。\n演至要杀妲己之时，其妖淫惑人之情状，颇足唤醒一般色荒之人。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、二大太监、四宫娥同上。玉妹、喜妹、妲己、纣王同上。"
        },
        {
          "character": "纣王",
          "type": "引子",
          "text": "瑞霭盈庭，妆品粉台砌，玉人成对相迎。"
        },
        {
          "character": "妲己",
          "type": "引子",
          "text": "兆应三冬，万里如云，一片冰心。"
        },
        {
          "character": "玉妹、喜妹",
          "type": "同引子",
          "text": "煨炉煖阁，陪伴圣君，还借着云环肉阵。"
        },
        {
          "character": "玉妹、喜妹、妲己",
          "type": "同白",
          "text": "参见万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "御妻等平身。"
        },
        {
          "character": "玉妹、喜妹、妲己",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "玉妹、喜妹、妲己",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "孤，商君纣王。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "吾乃妲己。"
        },
        {
          "character": "玉妹",
          "type": "白",
          "text": "吾乃玉妹。"
        },
        {
          "character": "喜妹",
          "type": "白",
          "text": "吾乃喜妹。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "吓，美人，你看这长空雪砌玉银栏，可胜那冰月的佳境也！"
        },
        {
          "character": "纣王",
          "type": "西皮散板",
          "text": "一般的清气香冰霜玉骨， 可惜它不是枝生不长久。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "呵，万岁，我想这人生在世，百年的光阴，能有几时的快乐？不必说它。待妾 妃等与万岁观看跳舞，与万岁宽饮，待赏雪观梅花，不知圣意如何？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "好好好，正合孤王之心，生受美人了。 内侍！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "看宴伺候。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。安席。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "美人请！"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "万岁请！"
        },
        {
          "character": "纣王、妲己",
          "type": "同玉芙蓉",
          "text": "鹅毛把剪裁， 柳絮它就随着风来。 排粉成万里， 开展阁庭楼台。 非是六如银界， 撒遍了琼瑶玉砌阶。 真堪爱，凭飘空来瑞彩， 一时间鸟禽，认作了那白鹤来。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "呵美人，你来看这御河边，有二人他们渡河而过，一个个赤足。观见那一个年 老的，他就不惧，不怕这水寒冷；看那一个年少的，他倒反有惧怕之色容。那 一个年老的，他倒反渡了那个年少过去此河。是何原故？"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "启万岁：想那一个年老的人，他乃是早年间父母成胎，是先天气足，精力康健； 想那一个年少的人，他的父母，乃是晚年间才成一胎，精力衰败，先天不足， 所以畏寒，他就怕冷。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "想孤王生长在这皇宫内院，孤王倒也不知道，什么叫作先天后天之事。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "吓万岁，若是不深信，可将那二人拿来，将他二人的筋骨离开，试看试看。万 岁那时间可就便知明白了。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "就依美人之言。 内侍过来！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "宣众武士手，上鹿台听旨。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。 台下听旨！"
        },
        {
          "character": "四武士",
          "type": "内同白",
          "text": "有。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "万岁有旨：宣众武士上鹿台。"
        },
        {
          "character": "四武士",
          "type": "内同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同上。"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "参见万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "万万岁！宣吾等有何圣谕？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "命你等去到河边，快快将那渡河的二人，将他二人的筋骨离开，看看明白，谁 的满谁的虚，速速报与孤王知道。等候回旨，快去！"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "四武士",
          "type": "同念",
          "text": "我主心中太昏迷，平常无过害生民。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同下。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "吓美人！"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "孤想美人，你生长皇宫内院，闺阁不出，怎么知道这先天后天之事？"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "万岁要问，万岁听了！"
        },
        {
          "character": "妲己",
          "type": "玉芙蓉",
          "text": "我也曾归了教来， 必来受阴付载。 那老年吓，是先天气足，不差分解， 那少年吓，他本是父母血精皆衰败。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "那年老的人而将颓退，得受胎不久矣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同上。"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "启奏万岁：吾等奉旨去到那河边，今将那渡河的二人，筋骨离开，观其骨髓， 令人真可衰败。那年老的精足，那年少的精虚，特地回旨，万岁请看。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "打开，待孤观看。"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同打开箱。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "吓美人，你是真真看得不差。"
        },
        {
          "character": "纣王",
          "type": "玉芙蓉",
          "text": "真奇怪，真奇怪， 验筋骨，不差分毫，应先天不差分毫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑太监上。"
        },
        {
          "character": "丑太监",
          "type": "白",
          "text": "不好了，不好了！"
        },
        {
          "character": "丑太监",
          "type": "念",
          "text": "有事不得不报，无事不可乱言。"
        },
        {
          "character": "丑太监",
          "type": "白",
          "text": "启奏万岁爷：大事不好了！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "呵，你所报何事？"
        },
        {
          "character": "丑太监",
          "type": "白",
          "text": "万岁爷吓！"
        },
        {
          "character": "丑太监",
          "type": "剔银灯",
          "text": "事不关天非不解， 满城中的杀气又连天。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "但不知是何人兴兵前来？"
        },
        {
          "character": "丑太监",
          "type": "念",
          "text": "领兵调将姜元帅，顷刻就要到边关。看看杀到我边界，万岁快快把旨传。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "我看各路边关，俱都有兵将把手。他的大兵，怎能够就到我界？各路兵士如何？"
        },
        {
          "character": "丑太监",
          "type": "白",
          "text": "今有那东伯侯姜右大将军，从东路进伐，人马已将那陈塘关打破；还有那南伯 侯阿英大将军，从南路进兵，已破界牌关；那北伯侯破游界关，那西伯侯拜了 那姜尚为帅，领了大兵。他今会合了各路的诸侯，潼关连破，斩了大将，破了 阵，破了关，又破了诛仙阵，斩了一员大将，张奎夫妇二人阵亡了。哎呀我的 万岁爷吓！看看不久，他可就杀进皇宫来了！"
        },
        {
          "character": "丑太监",
          "type": "剔银灯",
          "text": "军威严整大，斩我将如草芥， 急早急早，整歌备凯。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "哦哦哦，既有这等的事。 内侍！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "旨意一道，快命文武诸将，各自全身披挂，铠甲齐整，速速御敌。不得有误。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监甲下。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "罢了吓，罢了吓！"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "吓万岁，不必烦恼着急。我想各国的兵马，重围铁桶。他等大兵，怎能就到了 吾界？这分明是狂奴妄奏龙颜，他是恐惧圣心。万岁传旨，快快将他斩首。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "哎哎，美人说哪里话来。我想此乃祸到燃眉，还说的什么妄奏。想孤当日，不 听忠言，杀害良臣。今日大兵临了城下，谁为计较？若是杀进了皇城，岂不悔 之晚矣！"
        },
        {
          "character": "纣王",
          "type": "剔银灯",
          "text": "恃权威，乘杀戮， 想良臣黎民，个个受了灾殃。 城门火一起，鱼无瀨， 折断了，九回肠在。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "哪个？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监甲上。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "启奏万岁爷知道：朝房之内，那些文武大小官宦僚臣等，他们听说大兵临了城 下，他们大家，一个个默然无言，内中也有那高兴的，跻跻跄跄出城，拜倒在 地。那些众百姓，一个个声噪。今日特见龙颜，跳出黑狱牢笼。可怜那忠义烈 胆，侍力生斧生抛。哎呀，万岁爷吓！"
        },
        {
          "character": "大太监甲",
          "type": "剔银灯",
          "text": "他们寸首脑身，赶到了泉台， 留万载，万古留名无改。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "站过一旁。 哎呀，美人吓！孤想如今的祸殃，就在了眼前。倒不如你我弃了宫院，逃往那 乡，另图复辟，你看好是不好？"
        },
        {
          "character": "玉妹、喜妹",
          "type": "同白",
          "text": "且慢。想万岁乃九五之尊，怎么能够弃了宫院而走，岂不被他人耻笑？万岁如 其不然，我姐妹三个人，练习兵符六甲。今夜晚间三更的时分，暗进周营，将 那周武王连姜尚一齐杀了，岂不是以除后患，何足忧思也！"
        },
        {
          "character": "玉妹、喜妹",
          "type": "同二黄原板",
          "text": "紧披着狻猊铠双刀如电， 须出不用劲敌良。 悄声胜雾拥云降，"
        },
        {
          "character": "纣王",
          "type": "二黄原板",
          "text": "两军阵前要提防。"
        },
        {
          "character": "妲己",
          "type": "二黄原板",
          "text": "万岁但把宽心放， 休惊怪么小裙妆。 管突重围无路礙，"
        },
        {
          "character": "纣王",
          "type": "二黄原板",
          "text": "快去后宫改换妆。 姬昌小子太不良，"
        },
        {
          "character": "妲己",
          "type": "二黄原板",
          "text": "姜尚邪道逞凶强。 万岁眼观旌旗展，"
        },
        {
          "character": "玉妹、喜妹",
          "type": "同二黄原板",
          "text": "凯歌升平转回还。"
        },
        {
          "character": "妲己、玉妹、喜妹",
          "type": "同二黄原板",
          "text": "辞王别驾后宫往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "妲己、玉妹、喜妹同下。"
        },
        {
          "character": "纣王",
          "type": "二黄原板",
          "text": "听得指日凯歌还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四兵丁引辛甲、辛免、太颠、武吉、雷震子、哪吒、韦陀、护法、杨神、龙须虎、杨戬同跳上。"
        },
        {
          "character": "辛甲、辛免、太颠、武吉、雷震子、哪吒、韦陀、护法、杨神、龙须虎、杨戬",
          "type": "同念",
          "text": "齐整武艺并法术，要把纣基换周朝。"
        },
        {
          "character": "辛甲、辛免、太颠、武吉、雷震子、哪吒、韦陀、护法、杨神、龙须虎、杨戬",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "辛甲",
          "type": "白",
          "text": "辛甲是也。"
        },
        {
          "character": "辛免",
          "type": "白",
          "text": "辛免是也。"
        },
        {
          "character": "韦陀",
          "type": "白",
          "text": "韦陀是也。"
        },
        {
          "character": "护法",
          "type": "白",
          "text": "护法是也。"
        },
        {
