{
  "script_id": "01003013",
  "title": "滑油山",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘青提",
      "hangdang": "老旦"
    }
  ],
  "plot": "目莲母刘氏，既遍历刀山、剑树、油锅、血池之苦，及煎熬剥刳等刑，游至第六殿，冥王又令鬼卒押往滑油\n山受罪。刘氏一路哀求，挨打受骂，备极惨苦。",
  "notes": "《滑油山》，即全本《目莲救母》中之一出。在《游殿》之末、《母子相会》之前。与本考第二册《救母》\n出剧本内容不同。此出即形容冥途押解及迫令上山之状，系老旦之唱工戏，中间原板甚多，而时以导板及摇\n板相间，则每至沉郁不舒之际，辄变为悲苍激越之声，故调颇铿锵可听。\n昔时大头最工此剧，近时实无继起者，惟吕月樵差强人意耳。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大鬼上，众鬼卒同上。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "我乃六殿阎君麾下大鬼是也。今有刘氏青提，作恶多端，将她打在滑油山前受 罪。 众鬼卒，将刘氏青提押上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同允。"
        },
        {
          "character": "刘青提",
          "type": "内二黄导板",
          "text": "黑暗暗雾沉沉一阵昏暗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘青提上。"
        },
        {
          "character": "刘青提",
          "type": "回龙",
          "text": "一步来到鬼门关。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "鬼哥，唤我何事？"
        },
        {
          "character": "小鬼",
          "type": "白",
          "text": "长官唤你。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "哦，长官唤我。老身今年——"
        },
        {
          "character": "刘青提",
          "type": "二黄原板",
          "text": "五十整， 悔不该吃斋我又开五荤。 转面来我便把长官一问， 你唤我难人所为何情？"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "长官唤我何事？"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "只因你在阳世之间作恶多端，阎君大怒，将你打在滑油山前受罪！"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "鬼哥若是将我放回，从此改过就是。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "改过改过，难免你的心头之火。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "长官，此路难行，行个方便罢。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "难行也要行。 诸鬼卒拉着走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同允。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "苦呀！"
        },
        {
          "character": "刘青提",
          "type": "二黄导板",
          "text": "刘青提未起身珠泪伤惨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同喝。"
        },
        {
          "character": "刘青提",
          "type": "二黄快三眼",
          "text": "想起了当年事好不心烦。 自幼儿吃长斋一心向善， 十八岁进夫门配结良缘。 遭不幸老员外黄泉命染， 生一子无踪影绝了香烟。 因此上心愤恨天地埋怨， 在中年饮酒开荤、打僧骂道、改变心田。"
        },
        {
          "character": "众鬼卒",
          "type": "同白",
          "text": "走呀！"
        },
        {
          "character": "刘青提",
          "type": "二黄原板",
          "text": "何立他用言语苦苦相劝， 到如今铁树开花方有见天。 悔不该在佛堂发下誓愿， 从此后破了杀戒、开了五荤、不信神佛、咒骂青天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同喝。"
        },
        {
          "character": "刘青提",
          "type": "二黄原板",
          "text": "阎罗王差五鬼白昼活现， 才将我三魂七魄拉在阴间。 看起来这时节后悔已晚， 叹人生如泡如影，如幻如梦，果然有报应循环。"
        },
        {
          "character": "众鬼卒",
          "type": "同白",
          "text": "走呀！"
        },
        {
          "character": "刘青提",
          "type": "二黄原板",
          "text": "在阴间见了些无情鬼判， 在阴间见了些剑树刀山； 在阴间见了些剥皮把草嵌， 在阴间见了些堆捣磨研。 行善的到阴间依旧行善， 只见在走金桥，过银桥，左金童，右玉女，黄幡宝盖金罗伞，他好不威严！ 可怜我做恶的有谁怜念， 到如今项带长枷、身背铁链，一步一打、一打一扑，获罪于天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同喝。"
        },
        {
          "character": "刘青提",
          "type": "二黄原板",
          "text": "今日里解丰都游过五殿， 眼前边黄沙滚黑雾漫漫。 大鬼恶狠狠执定铁链， 哪管他路难行扑打向前。 走得我遍体痛魂飞魄散，"
        },
        {
          "character": "刘青提",
          "type": "二黄摇板",
          "text": "又只见黑暗暗一座高山。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "长官，前面什么所在？"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "前面叫做滑油山。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "你我可从此经过？"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "正要打此经过。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "此山高大，有些难过。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "难过也要过。 众鬼卒，拉住走！"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "苦呀！"
        },
        {
          "character": "刘青提",
          "type": "二黄摇板",
          "text": "听说要过滑油山，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘青提上桌子。"
        },
        {
          "character": "刘青提",
          "type": "二黄摇板",
          "text": "不由刘氏心胆寒。 未曾迈步身先颤，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘青提跌下桌子。"
        },
        {
          "character": "刘青提",
          "type": "二黄摇板",
          "text": "一跤跌在地平川。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "哎，长官，我浑身疼痛，行个方便罢。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "你这泼妇，不打不行！ 众鬼卒，与我拉住走！"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "咳！苦吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}