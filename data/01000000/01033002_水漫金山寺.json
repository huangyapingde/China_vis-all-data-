        {
          "character": null,
          "type": "stage",
          "text": "虾形、蟹形、龟形、蚌形同上。"
        },
        {
          "character": "虾形、蟹形、龟形、蚌形",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "小青",
          "type": "白",
          "text": "与我把水势大作，漫过金山，只救俺官人便了！"
