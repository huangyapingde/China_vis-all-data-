        {
          "character": "法海",
          "type": "白",
          "text": "不妨。将我这袈裟，兜在这半山之中！"
        },
        {
          "character": "监寺",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "监寺下。"
