{
  "script_id": "01006006",
  "title": "叹皇陵",
  "alias": [
    "探皇陵"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "徐延昭",
      "hangdang": "净"
    },
    {
      "name": "杨波",
      "hangdang": "老生"
    },
    {
      "name": "赵飞",
      "hangdang": "丑"
    }
  ],
  "plot": "徐延昭、杨波为李良篡位、李后昏惑不悟，在殿与彼等争执之后，退回朝房，无计可展。徐延昭至深夜，乃\n独至先帝灵前，哭祷乞灵，思以孤忠一片，诉之冥冥，以冀仗先帝式凭之灵，佑令李后回悟。虽稍涉迷信，\n然大臣忧国之深，实为不可及。徐延昭正伏地痛诉时，忽闻有人马声自远而至，不觉大惊。盖恐李良已知之，\n而乘间来劫己也。及近，见系杨波，惊始稍定。及询情由，始知杨波亦为保护皇灵之故，率同子侄众将等\n偕来。徐延昭乃大喜，遂向诸将抚慰奖励，以忠贞相勉。诸人闻言，无不感激涕下。",
  "notes": "此一场在《大保国》之后、《二进宫》之前，仍以生、净对唱见工，然净尤较生为重。净角之唱工，当别具\n一种悲苍凄婉之声调，方为相称。不能仍以叱咤风云、喑哑山岳为能事也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "掌灯！"
        },
        {
          "character": "徐延昭",
          "type": "内二黄导板",
          "text": "听谯楼打罢了初更时候，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大铠同上，徐延昭上。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "开山府又来了定国王侯。 先王爷晏了驾太子年幼， 龙国太无主张推让龙楼。 满朝中文武臣旁观袖手， 眼见得这江山付与水流。 叫家将掌红灯龙楼阁走， 见皇陵不见君两泪交流。 徐延昭三叩首把本启奏， 尊一声臣的主细听从头： 先王爷晏了驾太子年幼， 恨李良起反心谋篡龙楼。 有徐、杨在金殿把本启奏， 龙国太她言道：大明朝有事无事，不用徐、杨二大奸党，赶出龙楼。 先王爷在阴曹多多保佑， 保佑那杨家将急早回头。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "耳边厢又听得人声马吼， 想必是李良将来夺龙楼。 叫家将掩红灯藏至在屏风以后， 今夜晚丧贼手万古名流。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大铠同下。四将、赵飞同上，杨波上。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "众家儿郎忙随定， 见了千岁礼相迎。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "参见千岁！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "哽！胆大杨波，带领众家孩儿，敢是夺取皇陵？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "学生怎敢！带领众家孩儿，前来扶保皇陵。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "众家孩儿今在何处？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "现在外面。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "叫他们悄悄而进。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "众家随我前来，见过千岁。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "是。 参见千岁！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "一文一武站朝廊，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "叙一叙大明朝锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "杨大人好一比汉高皇上，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "千岁爷好一比西楚霸王。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "进宫去摔死了年幼太子， 我保大人做一朝帝王。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "欺君话儿休要讲， 谋朝篡位奸贼李良，天理昭彰！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "我和你不过是闲谈言讲， 杨大人你哪有篡位的心肠？我要观观儿郎。 杨大郎生来好貌相， 好一似当年汉刘王。 身旁缺少诸葛亮， 阴阳八卦腹内藏，你亚赛刘王！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "好将！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "赤面长髯小马芳， 亚赛三国关二王。 过五关曾斩六员将， 擂鼓三通斩蔡阳，你亚赛二王！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "好将！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "豹头环眼杨三郎， 亚赛当年翼德张。 虎牢关前打一仗， 枪挑吕布紫金冠，你亚赛翼德张！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "好将！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "四公子生来面貌勇， 亚赛三国赵子龙。 长板坡前救幼主， 七进七出显威风，你亚赛子龙！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "好将！"
        },
        {
          "character": "赵飞",
          "type": "白",
          "text": "千岁，还有我呢？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人，这是何人？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "这就是七日七夜颁兵的小赵飞。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "哦，就是七日七夜颁兵的小赵飞，朝上跪。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "七日颁兵小赵飞， 这等功劳算第一。 等后幼主登龙位， 老夫把本往上提。 别的官儿不封你， 九门提督在朝里。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人，"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "服你服你真服你，"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "服我何来？"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "若大年纪用兵机。 叫一声众儿郎你们忙回避，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将、赵飞同下。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "后宫院看一看那李氏艳妃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐延昭、杨波同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}