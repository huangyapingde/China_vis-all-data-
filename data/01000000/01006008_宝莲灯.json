        {
          "character": "刘彦昌、王桂英",
          "type": "同白",
          "text": "儿吓。秦府官保，何人打死？"
        },
        {
          "character": "沉香、秋儿",
          "type": "同白",
          "text": "是孩儿打死。"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "哽，纵然是儿打死，就该推在他……"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "哽，纵然是儿打死，就该推在他……"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "哎，夫人这作什么？"
