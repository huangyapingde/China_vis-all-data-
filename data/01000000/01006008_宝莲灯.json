          "character": "刘彦昌",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "待妾身前去问沉香，你看好是不好？"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "怎么夫人你前去问沉香？请。"
        },
        {
          "character": "刘彦昌、王桂英",
          "type": "同白",
          "text": "儿吓，秦府官保何人打死？"
        },
        {
          "character": "沉香、秋儿",
          "type": "同白",
          "text": "孩儿打死。"
        },
        {
          "character": "刘彦昌、王桂英",
          "type": "同白",
          "text": "打死人可要偿命。"
        },
        {
          "character": "沉香、秋儿",
          "type": "同白",
          "text": "情愿抵偿。"
