{
  "script_id": "01006008",
  "title": "宝莲灯",
  "alias": [
    "二堂舍子；一名：打子放逃"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘彦昌",
      "hangdang": "老生"
    },
    {
      "name": "王桂英",
      "hangdang": "正旦"
    },
    {
      "name": "沉香",
      "hangdang": "小生"
    },
    {
      "name": "秋儿",
      "hangdang": "小生"
