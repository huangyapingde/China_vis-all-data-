        {
          "character": "刘彦昌",
          "type": "白",
          "text": "怎么不对？"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "妾身问过沉香，沉香言道，秦府官保，乃是沉香打死；他兄弟站在一旁，连手 都未曾动。"
        },
        {
          "character": "刘彦昌、王桂英",
          "type": "同白",
          "text": "还是不得明白。"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "哎，老爷。"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "夫人何事？"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "妾身倒有个主见。"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "有何高才？"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "老爷前去问沉香，妾身前去问秋儿，两下一对便知明白。"
