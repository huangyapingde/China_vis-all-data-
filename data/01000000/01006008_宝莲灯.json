        {
          "character": "王桂英",
          "type": "白",
          "text": "老爷我打了。"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "你打了打迟了。"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "王桂英",
          "type": "二黄摇板",
          "text": "打在儿身痛在心。"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "夫人可曾问过明白？"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "妾身问过沉香，沉香言道，秦府官保乃是沉香打死。就该带他前去偿命。"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "夫人可曾问过秋儿？"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "那秋儿么……哎，这个奴才，也将人打死。"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "哼哼，好一个“也将人打死”！夫人你问不明白，下官把你好有一比。"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "刘彦昌",
          "type": "白",
          "text": "好比一盆浆糊。"
