{
  "script_id": "01005009",
  "title": "孝感天",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "武姜",
      "hangdang": "老旦"
    },
    {
      "name": "共叔段",
      "hangdang": "小生"
    },
    {
      "name": "魏氏",
      "hangdang": "正旦"
    }
  ],
  "plot": "武姜自幽居城颍，终日悲啼，哀怜少子甚切。共叔段夫妻死后，以己之怙恶不悛，及母之溺爱，皆寤生阴谋\n故纵所致。故冤魂不散，于夜半托梦武姜，聊一相见，以慰老母舔犊之情，并恺切劝解，谓不久当与寤生有\n重聚之望。",
  "notes": "此剧即演春秋时郑庄公杀弟共叔段，并迁其母武姜于城颍之后，立誓不及黄泉母子不见之故事。\n全剧俱系反二黄，演时一种幽怨愁惨之声，颇令人酸鼻不忍闻。近时善此剧者颇少。\n剧名《孝感天》，殊不可解。或谓剧中共叔段鬼魂，为相沿之误，实则系演郑庄公掘地见母一节，而稍变动\n其情节者。故托于魂梦相见云，此说似稍近似。\n寤生，郑庄公名也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同上，共叔段、魏氏同上。"
        },
        {
          "character": "共叔段",
          "type": "念",
          "text": "丹心天地惨，黄泉路途远。"
        },
        {
          "character": "魏氏",
          "type": "念",
          "text": "溺爱反遭害，恩情一线牵。"
        },
        {
          "character": "共叔段、魏氏",
          "type": "同白",
          "text": "我乃（共叔段）（魏氏）鬼魂是也。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "只为母后姜夫人，爱子爱媳；不想你我夫妻，反遭毒害。可叹母后在颍燕城中， 思儿心切，啼哭悲声。你我夫妻，不免去至梦中，劝解一番。如此夫人请。"
        },
        {
          "character": "魏氏",
          "type": "白",
          "text": "夫君请。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "共叔段",
          "type": "念",
          "text": "说破啼惨三月雨，"
        },
        {
          "character": "魏氏",
          "type": "念",
          "text": "梦魂惊断五更风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、共叔段、魏氏同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "武姜上，二宫女同上。"
        },
        {
          "character": "武姜",
          "type": "引子",
          "text": "离别宫闱，空使我，老眼含泪。"
        },
        {
          "character": "武姜",
          "type": "念",
          "text": "生离最是苦，死别何伤乎！试看姜国母，有子不如无。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "老身姜氏。只因溺爱次子共叔段，反致他夫妇身亡。可恨寤生不孝，将老身迁 居颍地居住。思想起来，好不凄凉人也。"
        },
        {
          "character": "武姜",
          "type": "二黄原板",
          "text": "凄风苦雨多悲惨， 冷落离居泪不干。 有子如无发长叹， 老死此地几时还？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。武姜进帐子，脱帔。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "你们退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": "武姜",
          "type": "二黄原板",
          "text": "居异乡恨寂寞红日易晚， 思娇儿不觉得月上栏杆。 对银灯眼昏花自悲自惨， 有何人定晨昏心腹细谈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段、魏氏同上。"
        },
        {
          "character": "共叔段",
          "type": "二黄慢板",
          "text": "风飘飘冷飕飕黄昏惨淡， 曾记得在生前荣带正冠。"
        },
        {
          "character": "魏氏",
          "type": "二黄慢板",
          "text": "此时间也难说分诉情由， 进寝门见国母心内痛酸。"
        },
        {
          "character": "共叔段、魏氏",
          "type": "同白",
          "text": "母后醒来！"
        },
        {
          "character": "武姜",
          "type": "二黄导板",
          "text": "梦儿里只听得有人呼唤，"
        },
        {
          "character": "共叔段、魏氏",
          "type": "同白",
          "text": "母后醒来！"
        },
        {
          "character": "武姜",
          "type": "二黄摇板",
          "text": "又只见灯光下双影闪连。 看不明擦一擦昏花老眼， 你是我次子段儿媳元环。 曾记得寿筵前金杯酒满， 母子们共聚首一处同欢。 忆自你封京邑便不回转，"
        },
        {
          "character": "共叔段、魏氏",
          "type": "同回龙",
          "text": "虽是儿丧黄泉难以心甘。"
        },
        {
          "character": "共叔段",
          "type": "反二黄慢板",
          "text": "悲切切尊国母飞魂魄散， 悔不该妒兄位自惹神灾。 连累了我母后无依无伴， 儿死在九泉下心中难甘。"
        },
        {
          "character": "魏氏",
          "type": "反二黄慢板",
          "text": "这也是天命定数有修短， 劝国母切莫要终日泪涟。 为报恩来世里重亲慈范， 千古人有哪个百岁同餐。"
        },
        {
          "character": "武姜",
          "type": "反二黄慢板",
          "text": "听儿言不觉得珠泪悲惨， 纵然是鬼与魂娘也心甘。 怎能够同聚首襟怀坦坦， 随为娘在此地同把身安。"
        },
        {
          "character": "共叔段",
          "type": "反二黄摇板",
          "text": "儿在阴母在阳两厢隔断， 母子们要相逢今生实难。"
        },
        {
          "character": "魏氏",
          "type": "反二黄摇板",
          "text": "天将明儿要归不尽感叹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段下。"
        },
        {
          "character": "魏氏",
          "type": "stage",
          "text": "魏氏　　　　　　　　　　　郑君侯指日里迎接凤鸾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏氏下。二宫女同上。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "国母醒来！"
        },
        {
          "character": "武姜",
          "type": "二黄导板",
          "text": "贤儿媳一同去抛娘不管，"
        },
        {
          "character": "武姜",
          "type": "三叫头",
          "text": "叔段！元环！哎，儿吓……"
        },
        {
          "character": "武姜",
          "type": "二黄摇板",
          "text": "梦儿里重相见好不心酸， 嘱咐的言和语令人悲惨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": "武姜",
          "type": "二黄摇板",
          "text": "但不知何日里再见一番。"
        },
        {
          "character": "武姜",
          "type": "哭",
          "text": "哎，儿吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武姜下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}