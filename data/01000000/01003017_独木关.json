{
  "script_id": "01003017",
  "title": "独木关",
  "alias": [
    "枪挑安殿宝"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "薛礼",
      "hangdang": "武生"
    },
    {
      "name": "安殿宝",
      "hangdang": "净"
    },
    {
      "name": "二老军",
      "hangdang": "丑"
    },
    {
      "name": "张志龙",
      "hangdang": "丑"
    },
    {
      "name": "何宗宪",
      "hangdang": "丑"
    }
  ],
  "plot": "唐薛仁贵投效从军，隶张士贵部下，常被屈抑。虽叠斩寇将，屡建奇功，均为张士贵所冒，仍充火头军。张\n士贵兵次独木关，为敌将安殿宝所困，张士贵子张志龙、婿何宗宪均被擒，张士贵遣差官传令，命薛仁贵出\n战。薛仁贵部下周青等怒打差官，并将令箭折断，张士贵无奈，亲往薛帐拜求。时薛仁贵适抱病，但令周青\n等出敌，不能胜。薛仁贵在帐中闻鼓声甚急，恐不敌，因是带病上马，驰至阵前，即刺死安殿宝，众人方乘\n胜入关，救出张志龙、何宗宪。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，张士贵上。"
        },
        {
          "character": "张士贵",
          "type": "念",
          "text": "千军列队伍，万马扎团营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "打坏了，打坏了。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "为何这等模样？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "伙头军不听将令，将令箭拗断，暴打我一顿。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "想是你不会讲话，得罪他们。来，将他捆绑起来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "为何将我捆绑？"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "本帅自有用兵之策。 来，打道月字营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。众伙头军同暗上。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "前去通报：说张总爷来了。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "张总爷来了。"
        },
        {
          "character": "众伙头军",
          "type": "同白",
          "text": "不晓得什么张总爷。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "吓，众位英雄对薛礼言讲，就说本帅过营探病。"
        },
        {
          "character": "周青",
          "type": "白",
          "text": "站下些。 有请大哥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军搀薛礼同上。"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "在月下惊碎了英雄虎胆， 思家乡回故土千难万难。 我与那尉元帅无仇无怨， 平白地要拿我所为哪般？"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "周青，何事？"
        },
        {
          "character": "周青",
          "type": "白",
          "text": "张总爷过营探病。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "快快地有请。"
        },
        {
          "character": "周青",
          "type": "白",
          "text": "吓，张士贵，叫你进来。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "周青",
          "type": "白",
          "text": "随我进来。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "吓，薛礼，本帅来了。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "哎吓，总爷吓！小人有何德能，敢劳总爷过营探病。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "你屡次抢关夺寨，理当如此。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "多谢总爷。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "吓，薛礼，你此病因何而起？"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "哎吓，总爷吓，那日小人山神庙外，仰天看月，不料尉迟老元戎从后而来，将 小人搂抱在怀，是小人将他推倒在地，奔命而逃。小人这病，乃是从惊唬而来。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "怪不得尉迟老元戎问我要你，是我花言巧语，将他瞒哄过去，从今而后，再若 撞着于他，只恐你的性命难保。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "吓总爷，这几日可曾抢关夺寨？"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "再也不要提起。大兵来到独木关，偶遇安殿宝一马挡住。你染病在床，我命二 位少爷出马，又被他们擒去。我命中军拿了令箭，调众位英雄前去搭救，中军 不会讲话，他们将令箭拗断，将中军暴打一顿，是我亲自过营，带了中军与他 们陪礼。 中军跪下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军跪。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "哎……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛礼昏倒。"
        },
        {
          "character": "众伙头军",
          "type": "同白",
          "text": "你将我大哥气死了。跪下叫吓！"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "叫什么？"
        },
        {
          "character": "周青",
          "type": "白",
          "text": "叫伙头军爷爷。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "伙头军爷爷。"
        },
        {
          "character": "众伙头军",
          "type": "同白",
          "text": "大哥醒来。"
        },
        {
          "character": "薛礼",
          "type": "二黄导板",
          "text": "打中军劫令箭如同造反，"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "快快来救我。"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "似这等犯王法罪可欺天。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "总爷，你这算何意？"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "我与你讲话，你一时昏迷过去，他们将我捆绑起来。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "这还了得，快快地松绑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众伙头军同与张士贵松绑。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "哎吓，总爷吓，你看小人这班兄弟，俱是不法之徒，恐小人下世，他们必要谋 反朝庭，趁小人在世，将他们斩首，以正军规。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "看在你的份上，亦要将他们饶恕。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "还不过来谢过总爷。"
        },
        {
          "character": "众伙头军",
          "type": "同白",
          "text": "多谢总爷。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "少打几下，也就是了。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "周青过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周青允。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "带领众位贤弟，搭救二位少爷回来，将功折罪。"
        },
        {
          "character": "众伙头军",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众伙头军同下。"
        },
        {
          "character": "张士贵",
          "type": "白",
          "text": "你好好养息，我要回营去了。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "不能奉送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士贵、四龙套、中军同下。"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "张总爷过营来将我来探， 到来生变犬马结草衔环。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛礼下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，蓝天弼、周青同上，开打，同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二老军搀薛礼同上。"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "一路上枪挑了无数的上将， 每日里战疆场血染辽邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "啊？哪里这样擂鼓呐喊？"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "教场操演。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "吓，教场操演。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。"
        },
        {
          "character": "薛礼",
          "type": "同白",
          "text": "啊？这不像操演之声，为何这般喊杀连天？"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "这个……那个……"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "呔！你二人要言不言，要语不语，是何道理？"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "哎呀，薛爷吓，今有周青带领众家英雄，搭救二位少爷。那辽邦又出了个大将 安殿宝，众家英雄不能取胜，因尔如此。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "哎，俺薛礼得下这样冤孽病症，那辽邦又出了什么大将安殿宝。也罢，待我前 去会他有多大本领。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "吓，薛爷你出马，岂是那安殿宝的对手。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "薛礼",
          "type": "二黄导板",
          "text": "听一言气得我三魂飘荡，"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "叫老军抬枪马爷到战场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛礼下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，安殿宝上。"
        },
        {
          "character": "安殿宝",
          "type": "念",
          "text": "威风凛凛貌堂堂，虎背熊腰谁敢当。今日领动人和马，好似猛虎赶群羊。"
        },
        {
          "character": "安殿宝",
          "type": "白",
          "text": "大将安殿宝。奉主之命，镇守独木关。昨日拿住两个死囚，未曾发落。 来，将那两上死囚押上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押张志龙、何宗宪同上。"
        },
        {
          "character": "张志龙",
          "type": "西皮摇板",
          "text": "龙入沙滩爪方下，"
        },
        {
          "character": "何宗宪",
          "type": "西皮摇板",
          "text": "虎落平阳被犬拿。"
        },
        {
          "character": "张志龙",
          "type": "白",
          "text": "将军，此番进帐，还是叫骂的是，还是哀求的是？"
        },
        {
          "character": "何宗宪",
          "type": "白",
          "text": "自然叫骂的是。"
        },
        {
          "character": "张志龙",
          "type": "白",
          "text": "哀求的是。"
        },
        {
          "character": "何宗宪",
          "type": "白",
          "text": "大舅子！"
        },
        {
          "character": "何宗宪",
          "type": "西皮快板",
          "text": "大舅子休说懦弱话， 非是姐丈把你压。 进得帐高声骂， 拼得一死染黄沙。 迈步且把宝帐踏， 看你把爷怎开发。"
        },
        {
          "character": "安殿宝",
          "type": "白",
          "text": "两个死囚，通名受死。"
        },
        {
          "character": "张志龙",
          "type": "白",
          "text": "俺乃张士贵之子，名叫张志龙是也。"
        },
        {
          "character": "安殿宝",
          "type": "白",
          "text": "那一个呢？"
        },
        {
          "character": "何宗宪",
          "type": "白",
          "text": "俺乃白袍薛礼。"
        },
        {
          "character": "安殿宝",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "安殿宝",
          "type": "白",
          "text": "我道薛仁贵天上少有，地下难寻，今日一见，原来是个黄毛小子。 来，推去斩了。"
        },
        {
          "character": "何宗宪",
          "type": "白",
          "text": "不要忙，我是假充字号，我叫何宗宪。"
        },
        {
          "character": "安殿宝",
          "type": "白",
          "text": "来，将他二人绑在后面，拿住薛礼一齐开刀。押下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志龙、何宗宪同下。"
        },
        {
          "character": "安殿宝",
          "type": "白",
          "text": "众将官，杀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安殿宝、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周青、众伙头军同上，安殿宝、四龙套同上，会阵，同开打，同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "薛礼",
          "type": "内二黄导板",
          "text": "大英雄得下了冤孽病症，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛礼上，二老军手抬枪同上。"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "一霎时眼昏花双目不明。"
        },
        {
          "character": "薛礼",
          "type": "白",
          "text": "薛礼吓薛礼，想你这样英雄，得下这冤孽之病——"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "似猛虎丧了命威风还在， 大将军八面威何足道哉。 抖威风上战马把贼来战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛礼上马。"
        },
        {
          "character": "薛礼",
          "type": "二黄摇板",
          "text": "我不杀安殿宝誓不回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛礼下。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "薛爷去不得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安殿宝、周青同上，安殿宝打周青，周青下。"
        },
        {
          "character": "安殿宝",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛礼上，扎枪，开打。安殿宝、薛礼同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周青、众伙头军同上。"
        },
        {
          "character": "周青",
          "type": "白",
          "text": "众位兄弟，大哥大战安殿宝，你我在高坡一望。"
        },
        {
          "character": "众伙头军",
          "type": "同白",
