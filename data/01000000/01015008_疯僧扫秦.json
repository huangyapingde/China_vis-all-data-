{
  "script_id": "01015008",
  "title": "疯僧扫秦",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "疯僧",
      "hangdang": "丑"
    },
    {
      "name": "秦桧",
      "hangdang": "净"
    },
    {
      "name": "住持",
      "hangdang": "外"
    }
  ],
  "plot": "宋奸相秦桧，害死岳武穆之后，在万花楼上，被忠魂缠绕。因许愿，至灵隐寺，虔修斋醺，为忏悔之地。秦\n桧与妻王氏亲身拈香，见寺壁上提诗一首，第一句即夫妻于东窗下，定诬武穆之计，写在炉灰内者，非常秘\n密，忽然泄露与此，甚为诧异。追问住持，云系疯僧所写。唤至面前，则一蓬头垢面，浑身污秽之和尚，左\n手执一扫帚，右手执一吹火筒。问答间，语语含有针锋，刺入奸相夫妇之心肺，不禁毛骨悚然。秦桧命从人\n催下庭介，用乱棒以制起死命。王氏空为旁观者讥评，劝秦桧暂时释放。回府后，再命家将何立来寺锁拿，\n而疯僧放内只留柬贴一个，人已不知去向矣，盖疯僧者，地藏菩萨之化身也。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "住持上。"
        },
        {
          "character": "住持",
          "type": "念",
          "text": "扫地恐伤蝼蚁命，爱惜飞蛾纱罩灯。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "贫僧，乃灵隐寺住持便是。今有秦丞相到此拈香，只得在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引秦桧同上。"
        },
        {
          "character": "秦桧",
          "type": "出队子",
          "text": "三公之位，自小登科占大魁， 只因前日梦惊疑， 使我心中如醉痴， 灵隐寺修斋，虔诚忏悔。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "贫僧迎接相爷。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "罢了。经典可曾诵完？"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "诵完了。请相爷大殿拈香。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "引道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同走圆场。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "第一炷香：愿风调雨顺，国泰民安；第二炷香：愿秦桧夫妇，百年偕老；这第 三炷香：愿……"
        },
        {
          "character": "青袍",
          "type": "同白",
          "text": "喝！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "哎呀佛爷啊！愿岳家父子早登仙界！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖朝天子〗。秦桧下跪，站起。曲牌收。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "请相爷各处随喜随喜。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "引道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦桧、住持同走圆场。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这是什么所在？"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "香积厨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "倒也洁净。壁上有诗，待我看来："
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "缚虎容易纵虎难，无言终日倚栏杆。男儿两眼凄惶泪，流入襟怀透胆寒。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好奇怪！这诗是我与夫人在东窗下做的，何人写在此？ 和尚，这诗何人写的？"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "是个远方和尚写的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "如今可在？"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唤他前来。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "是。启相爷：此僧有些疯癫，恐冒犯相爷。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "不计较他。快快唤来。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "谁唤我？"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "秦丞相唤你！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺忙哩！"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "忙什么？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "烧火忙。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "搬下烟子快来！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺又忙哩。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "又是忙什么？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "忙念佛。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "念的什么佛？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "我念的佛，普天下世人多不省的。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "你念来我听。"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "南无阿弥陀佛。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "三岁孩童，多会念的。你快来！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧上。"
        },
        {
          "character": "疯僧",
          "type": "引子",
          "text": "偈波罗蜜，波罗蜜，一口砂糖一口蜜。 河里洗澡睡在寺里，黄牛儿可不羞煞你！ 你好痴，趱金银；打首饰，与汝妻， 自己死后，四块板儿一领席，这便是落得的！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "南无大慈大悲广大灵感观世音菩萨。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "看你垢面疯痴，怎么了？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！师父！"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "休笑俺垢面疯痴， 恁可也参不透我的本来主意。 我笑那世人痴， 不解我的禅机。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "看你鬓发蓬松！"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "休笑俺发蓬松，"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "挂这织袋何用？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "挂着这破织袋。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "袋内什么东西？"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "这里面倒包，包藏着天地。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "手中拿的是什么？"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "我拿着这吹火筒， 却离了这香积橱。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他哪知我是地藏王化身哩！"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "今日个泄天机， 故来临凡世。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "你经忏也不看些。"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "我不会看经忏， 在恁那法堂中， 我只理会打打的勤劳， 在恁那山寺里。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "你看你今日涂，明日涂，涂出事来了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "涂出什么事来？"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "秦丞相唤你。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "可是那奸臣秦桧？"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "唔！秦丞相！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我正要去见他。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "疯僧唤到。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唤过来。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "住持下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "呸！我道怎么样一个疯僧，原来是个腌臜和尚。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我道怎样一个丞相，原来是个奸臣秦桧。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！你怎么道我的名？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你的名，我不道，谁道？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你认得我是谁？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你么，"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "恁是个上瞒天子下欺臣，我单道着你，你！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好个腌臜和尚。"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "休笑俺污秽，我这肚皮中倒干净似你，你！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我来问你的原由？"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "恁来问我的原由，我对伊家说破， 看他怎生的将俺来支对？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我且问你，这壁上的诗，可是你写的？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是你做的，是我写的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何“胆”字能小？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我的胆小，出了家；你的胆大，就弄出事来哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！你可知我的来意？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我怎么不知！"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "恁主意我先知，则恁那梦境恶。 故来到，故来到俺这山寺里。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我拜当阳求忏悔！"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "恁来这里拜俺的当阳，求忏悔， 恁则待要灭罪消释。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "南无观世音菩萨。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "哪里是念彼观音力，"
        },
        {
          "character": "疯僧",
          "type": "石榴花",
          "text": "太师着俺说个因依， 俺与恁须仔细话个真实。 恁可也悔当初错听了恁能大贤妻， 她也曾屡屡的便诱你，恁却也依随，恁在那东窗下不解我的西来意。 只见他葫芦提无语，将俺支对， 恁那谗言谮语，恁便将心昧，恁可以立起一统儿价正直碑。"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "恁待要结媾金邦哩， 也只是肥家，"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "哪里肯为国？ 恁如今事要前思，吓哈！ 免劳免劳得这后悔。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "悔什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "秦桧！你下阶来！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "看上面是什么？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是天。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "却又来！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "却不道湛湛青天不可欺， 如今人都理会的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊哈哈哈！左右与我拿下！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "恁在这里吓鬼瞒神哩， 恁做的事事，做的来藏头嗳尾。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你手中拿的什么东西？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是扫帚。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "要它何用？"
        },
        {
          "character": "疯僧",
          "type": "念",
          "text": "昔日边上扫烟尘，今日殿上扫奸臣。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！那个呢？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是火筒。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "又要它何用？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "要它私通外国。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "何不放下来？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "放不得。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "放下来它就要弄权哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我是君子人。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "红绣鞋",
          "text": "君子人只怕当权倚势， 俺待说着呵害得他一家儿，恰便似烟灭灰飞。 恁待要节外生枝， 可便落什么便宜。 俺为甚不在那厨房中放？ 放常则在我这手中持。 哎呀！火筒儿啊！这其间引狼烟， 倾了他的社稷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "住持上。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚你平日可有功？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有功的多被你杀了！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "功课！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "在这袋里。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "取来。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "取去。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "功课有了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "住持呈上。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何能皱？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "在蜡丸内取出，怎么不皱？"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "“久闻丞相理乾坤，占断朝纲第一人。都领群臣朝北阙，堂中埋没老元勋。 闭门杀害忠良将，塞上欺君枉万民。贤相一心归正道，路上行人口”……"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！怎么诗不全？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "若遇施全，你就该死了！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "左右！若遇施全，与我拿下。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "还有！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "横着看去。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "诗怎么横着看？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你的事，怎么横行呢！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔。"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "“久占都堂，闭塞贤路”。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唗！你敢悔弄我朝中的宰相么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "嘚！秦桧！"
        },
        {
          "character": "疯僧",
          "type": "十二月",
          "text": "卖弄恁那朝中得宰相职， 恁可也懊恼我这阇黎。 俺这里明明得这取出， 他那里暗暗得这观窥。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "十二月",
          "text": "休笑俺疯魔和尚，会嘴！ 恁可也干净似你养堂食。"
        },
        {
          "character": "疯僧",
          "type": "尧民歌",
          "text": "呀！这的是坐而不觉， 立而得这饥。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "讲了半日，想是他肚中饥了，和尚！赏他一份斋。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "住持端馒头。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "相爷赏你一份斋。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我不吃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧倒馒头。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "倾坏了！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "再赏他一份斋。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "住持端馒头。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "又赏你一份。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我不吃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧倒馒头。"
        },
        {
          "character": "住持",
          "type": "白",
          "text": "又倾了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你不吃罢了，为何连坏我两个？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "呔！秦桧！我坏了两个，你就发恼；亏你害了他三个哩！"
        },
        {
          "character": "疯僧",
          "type": "尧民歌",
          "text": "两头白面做来的， 坏了恁那两个有谁得这知？ 恁便屈杀了他三人，待推着谁？ 痴也么痴，其间造化机。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这是馒首。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这不是馒首。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "敢是馋馅？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "也不是。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "呐！"
        },
        {
          "character": "疯僧",
          "type": "尧民歌",
          "text": "这的是岳家肚皮中腌臜气！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这里不好讲话，随我到冷泉亭上来讲。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "冷泉亭不好，倒是风波亭上好……行事哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，我看你伶牙利齿，有甚本事？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我会呼风唤雨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "风雨在天上，如何唤得来？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "唤得来，还要退得去。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "如此我要一阵大风。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有，有，有！如来佛助弟子一阵大风！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大风。收了收了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "收收收。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我要一阵大雨。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有！有！有！东海龙君，助奸臣秦桧一阵大雨！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大雨。收了收了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "收收收。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我想这风雨在天上，如何来得能骤？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "连发十二道金牌召来的，怎么不骤？"
        },
        {
          "character": "秦桧",
          "type": "笑",
          "text": "吓哈哈哈哈！"
        },
        {
          "character": "疯僧",
          "type": "快活三",
          "text": "风来时雨便起，云过处电光辉， 把他拿住风来握住雨不淋漓。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大风啊！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这不是风。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是朱仙镇上，那些黎民的怨气！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大雨啊！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这不是雨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "呐！"
        },
        {
          "character": "疯僧",
          "type": "快活三",
          "text": "这的是屈杀了岳家父子天垂泪！"
        },
        {
          "character": "疯僧",
          "type": "朝天子",
          "text": "太师爷俺与恁便说知， 说着恁那就里。 俺只索要忍辱波罗蜜， 恁可也悔当初屈杀了他三人，可也无着无对。 到如今悔后迟， 他在阴司下便等你，在阎王殿前去告你。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "告我什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他告你私造下十座牢房。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "哪十座？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "“雷霆施号令，星斗焕文章”。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "他在哪一号？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他在“章”字号等你哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "哎呀！佛爷佛爷！"
        },
        {
          "character": "疯僧",
          "type": "朝天子",
          "text": "这的是恁自早下落得这道旁州例。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，如今要免六道轮回之苦，可免的过去么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你随我出了家，削了发，就可免了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我要出家，怕没有高僧剃度；况灵隐寺小，怎藏得我下？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "灵隐寺虽小，佛力最大哩。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "方才这八句诗如何讲？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "方才这八句诗，"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "做一个哑谜儿与恁猜。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "横头上八个字？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "横头上八个字，"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "做一张闷弓儿在恁那心上射。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有一日东窗事犯，"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "才知我的西来意。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "那时节捶着胸，跌着脚，嗨！秦桧！"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "恁可也慢慢的悔！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "俺去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "哎呀！被这疯僧一番言语，说的毛骨悚然，回去与夫人商议便了。 来，打道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上，同引道。"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "疯僧一席话，使我魂魄飞！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦桧、四青袍同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}