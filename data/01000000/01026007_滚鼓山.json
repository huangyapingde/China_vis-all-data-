{
  "script_id": "01026007",
  "title": "滚鼓山",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘封",
      "hangdang": "丑"
    },
    {
      "name": "廖化",
      "hangdang": "老生"
    }
  ],
  "plot": "蜀汉张飞，镇守阆中。忽见廖化匆遽前来，报告荆州失陷，至上鄘告急，刘封不肯发兵，关公已为吕蒙所害。\n张飞恨刘封甚，欲往杀之，乃移兵上鄘，诳取刘封手中剑、印，甘言蜜语，愿助以弑父袭位。复为划策，\n将一大铜鼓装载，混进成都。刘封受其愚弄，张飞隧掷大铜鼓于山下，刘封因此毙命焉。",
  "notes": "是剧事实，全属无稽之谈，亦不近情理，究系何人编排，无从探悉。枥老笔墨余闲，至各舞台消遣睡魔，恒\n见此种戏剧，排在开场之前三出内，可知时下推重之名艺员，均不屑串演，一试好身手。然荟萃之区，莫如\n北京、上海，既有此名称，且不时排出，本考当然有采取主人，不欲以糟粕视之也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、旗牌、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "点绛唇",
          "text": "执掌兵权，威风八面，雄兵万，扶保江山，指日扫中原。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "忆昔结义在桃园，扶保大哥锦江山。二哥镇守荆州地，吾镇阆中把名传。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吾姓张名飞字翼德。自从桃园结义以来，大破黄巾，扫灭吕布，三顾茅庐，聘 请诸葛先生。战无不胜，攻无不取。可恨孙、曹，屡屡与我弟兄作对。但愿早 灭孙、曹，江山归成一统，方称俺老张之意。 三军们，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启禀三千岁，廖将军到。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖化到此，必有所为。有请。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。廖化上。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖将军，请坐。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将军不在荆州，来到阆中做甚？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁，大事不好了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二千岁中了东吴吕蒙之计，败走麦城，被吴、魏两国围困，受害归天去了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞拉廖化。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "归天去了！"
        },
        {
          "character": "张飞",
          "type": "三叫头",
          "text": "二哥！兄长！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞昏。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁醒来！"
        },
        {
          "character": "张飞",
          "type": "西皮导板",
          "text": "听一言不由人三魂不在，"
        },
        {
          "character": "张飞",
          "type": "三叫头",
          "text": "二哥！兄长！二哥吓！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "点点珠泪洒下来。 二哥为何归天界， 再与廖化说开怀。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖将军，我家二哥，素与东吴交好。那孙权为何下此毒手？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁有所不知：只因孙权，曾命诸葛瑾，来到荆州求亲。二千岁不允，曾经 言道：“虎女焉能匹配犬子”，将诸葛瑾赶出帐去。不想那诸葛瑾回到东吴， 搬动是非，故而孙权，设此毒计。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "原来如此。想俺二哥，既然败至麦城，为何不到上鄘，借兵相助？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "哎吓三千岁吓！二千岁也曾命廖化，去到上鄘，搬兵求救。怎奈刘封，坐观成 败，不肯发兵，并将末将赶出帐外。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "就是他！"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "小奴才吓！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "听一言来怒气生， 大骂刘封小畜牲！ 俺二哥麦城被兵困， 你竟胆敢不发兵。 你手抚胸膛想一想， 他是尔的什么人。 越思越想心头恨， 我不杀你气怎平！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "刘封这小奴才，如此丧心昧良，俺老张岂肯与你甘休。 来，起兵前往！"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖将军为何阻拦？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "想那刘封，有我主赐他尚方斩杀宝剑，又有九头狮子鱼耳印。三千岁此番前去， 只怕画虎不成，反类犬也。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将军但放宽心，俺老张自有道理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化暗下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众将官，兵发上鄘武印山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同允。〖泣颜回〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、刘封同上。"
        },
        {
          "character": "刘封",
          "type": "念",
          "text": "营门战鼓响，军士赛虎狼。"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "三千岁到！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、旗牌引张飞同上。〖吹打〗。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "参见三叔父。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "三叔父多日不见，身体可好？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "为叔的倒好，你可好？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "侄儿尚好。但不知叔父，打从何处而来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱老子打从成都而来。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "既从成都而来，我父王身体可好？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你父甚是安泰。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "我那二叔父，现在荆州不知身体安泰否？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞做沉吟。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "这个奴才，他倒同我装起傻来了。 刘封，你还不知么？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "小侄不知吓。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你二叔父，兵败麦城，已在玉泉山前，归天去了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封做惊骇。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "吓！我二叔父，怎么归天了？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "只因孙权，遣诸葛瑾前来提亲，你二叔父不允，将他赶出了营外。不想他在孙 权面前，搬动是非，联合曹操，故而全军覆没。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "既然如此，待侄儿发兵，前去与我二叔父报仇。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "三叔父为何阻拦？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我且问你，你这上鄘城，有多少人马？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "现有十万雄兵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "既有十万雄兵，却也不少。今日为叔的，要帮助与你。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "三叔帮助，必定成功。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "但是一件。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "必须将尚方斩杀宝剑、九头狮子鱼耳印，交付俺老张，方可前去。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "倘若杀退孙、曹两路兵将，三叔还要交付侄儿才好。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "那是自然。看印拜过！ （刘封抱剑举印。〖牌子〗。张飞拜，刘封拔剑欲杀张飞，退。张飞起，接印、剑，刘封拜，张飞欲杀刘封， 退。）"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "印、剑也交付三叔，望三叔传令起兵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "慢来，慢来。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "为叔的还有一言，要同我儿言讲。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "叔父有何金言，当面请讲。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱老张打从成都而来，见你父年迈，只恐不久人世。倘若晏驾，这汉室江山， 不知何人承袭？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "倘若我父王晏驾，这江山定是阿斗的了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "不能，不能！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "为何不能？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "想那阿斗，年轻幼小，怎能坐得江山？他是不能得够。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "阿斗年幼，不能执掌江山，只怕就要让与关兴坐了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "关兴正在服孝之中，不能登基继位。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "关兴不能，还有三叔父的儿子张苞，也坐得。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺乃异姓之人，也不能坐。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "如此说来，这江山竟无人可坐了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞哭。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "只怕这江山，就、就是我儿你的了！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "小侄若坐，只恐满朝文武不服。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "说什么满朝文武不服。你今既有十万雄兵，待老夫帮助与你，倘有不服者，即 按军法从事。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "倘能叔父替侄儿保驾，侄儿登了大宝，定封叔父为一字并肩王之位。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好！好！好！据俺老张看来，事不宜迟，倒不如点动人马，先到成都，将你父 王刺死，我儿就可身登大宝，你看如何？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "此事可以做得么？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "做得的。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "如此就起兵前往。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且慢。为叔的有一计在此。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "为叔的有一铜鼓，将你装在鼓内，就说是外国进来之宝，你父那时定要观看， 待为叔在一旁，一鞭将鼓打开，你就势一刀，可就将你父刺死了。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "此计甚好！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众将官，起兵蝎子山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。〖水龙吟〗。众人同走圆场。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来，将铜鼓抬上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手抬鼓同上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我儿藏在鼓内。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封脱衣去盔，四上手推刘封入鼓内。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将鼓与我掷于山下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同抛鼓。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "刘封尸骨碎如齑粉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞三笑。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "刘封已死，方解俺老张心头之恨！ 众将官，去往成都，待俺报与大哥知道便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗，〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}