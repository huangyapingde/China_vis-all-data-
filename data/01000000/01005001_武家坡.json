{
  "script_id": "01005001",
  "title": "武家坡",
  "alias": [
    "平贵回窑；一名：跑坡"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "老生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    }
  ],
  "plot": "俗传薛平贵既投身戎行，辗转西征，屡立奇功，番民慑服。西凉国王既封以王爵，复赐尚某公主为妻，以固\n其心。继念干戈已靖，身膺殊荣。薛平贵虽至人臣极地，然遥忆结发糟糠，或仍守破窑，曾为得一享天伦之\n乐。回望家山，不觉归心似箭。遂辞别公主，衣锦还乡。但在外十余年，更经风霜，已是须发苍苍，非复当\n年张绪矣。既抵武家坡，与王宝钏会面，复伪称薛平贵之友，故意调戏，以试王宝钏节操。王宝钏词气严正，\n见彼语涉亵狎，顿时怒形于色，戟指痛骂，愤愤而回。此段情节，与《桑园会》仿佛相同。谁知王宝钏方\n欲掩门，薛平贵已随入窑中，乃详告真名，备述别后十八年之状况。王宝钏又细审言语状态，知确系薛平贵，\n心乃大慰，始纳之。",
  "notes": "其后本即《算粮登殿》也。此剧须生、青衫，均须唱做兼功，方能功力悉敌。此次王凤卿、梅兰芳合演是剧，\n一则雍容华贵，一则幽丽贞静，无论唱功之出人头地，矫矫不群，即其举止神情，已足令观者倾倒矣。古\n人云“二难并”，吾于斯二人亦云。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "披星戴月奔长安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "不分昼夜回家园。 在三关辞别了公主代战，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "一马儿来至在武家坡前。 绿阴树下拴了红鬃马， 尊一声众大嫂借问一言。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "列位大嫂请了。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "请了。军爷敢是失迷路途？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "并非失迷路途，乃是找名问姓的。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "不知问的是哪一家呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "王丞相之女，薛平贵之妻，王氏宝钏。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "军爷问她则甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我与她丈夫同营吃粮，托我带来万金家书，故而动问。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "王三姐。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "做什么？"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "有人与你带来万金家书，叫你前去接收。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "有劳了。"
        },
        {
          "character": "王宝钏",
          "type": "内西皮导板",
          "text": "有劳大嫂一呼唤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "寒窑内来了王氏宝钏。 站立在坡前抬头观看， 武家坡站定了一位军官： 前形好像薛平贵， 后影好似儿夫男。 我这里假意把菜剜， 他问一声答一言。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "这大嫂传话太迟慢，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "武家坡站得我两腿酸。 薛平贵抬头用目望， 见几位大嫂把菜剜。 薛平贵不解其中意， 内有个大嫂泪不干： 前形好似王三姐， 后影好似妻宝钏。 我本当向前把妻唤，"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呵，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "错认民妻理不端。 我只得上前去施一礼， 尊一声大嫂借问一言。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂请了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷敢是失迷路途？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "阳关大道，哪有失迷路途之理。我是找名问姓的。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "提起此人，大大有名。就是王丞相之女，薛平贵之妻，王氏宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷敢是与她有亲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "非亲。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有故？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "非故。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "非亲非故，问她则甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂有所不知，我与她丈夫同营吃粮，托有带有万金家书，故而动问。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "王宝钏，在下边上前不远，军爷将书交付与我，我与她带去就是。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我那薛大哥言道：“书信要交本人”。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "倘若不见本人呢。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "将原书带回。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "少待。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "本当上前接书，怎奈衣衫褴褛；欲待不去接书，夫妻分别一十八载，今日纸上 不能相逢，这便如何是好？吓，有了。 吓，军爷你可晓得哑迷。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "略知一二。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "远？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "远在天边，不能相见。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这近？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "近，莫非你是薛大嫂？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不敢，就是平贵之妻。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "重见一礼。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "先前见过礼了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有道是：礼多人不怪。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "好一个“礼多人不怪”，拿书来吓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "且慢，少待。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀，且住。想我平贵离家一十八载，不知她节操如何，不免调戏她一番。她 若贞节，与她相会，她若失节，将她一刀两断，回转西凉，也好见我那代战公 主也。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "洞宾曾把牡丹戏， 庄子先生三戏妻。 秋胡曾戏罗氏女， 薛平贵调戏自己妻。 弓囊袋内取书信，"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊呀，失落书信真出奇。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "书信呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "失落了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "放在何处？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "弓囊袋内。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "敢是不要紧所在？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "倒是要紧的所在在。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "为何失落了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我在前面抽弓打雁。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "打雁则甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "打雁充饥。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "想是那雁吃了你的心肝不成！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "吓，大嫂，一封书信，能值几何，为何开口伤人？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你岂不知，曾子曰：吾日三省吾身，与朋友交而不信乎。你失落人家书信，呕 呀，岂不叫人心痛？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "吓，大嫂不必啼哭，那书信上面言语，我还记得几句。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "吓，是了，想是我那丈夫带来书信，一路之上，你将银子花费，故而你还记得 几句。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂，非是这样讲。因那日薛大哥修书，我在一旁打点行李，是我偷看了几句。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此说来你倒是个有心人了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我有心，还不失了你的书信。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你要讲吓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你且听了。"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "八月十五月正明，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了。军营中连灯亮也无有？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "军营中哪里来的灯亮，全凭皓月当空。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "薛大哥在月下修书文。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "我问他好？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "他倒好，"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "再问他安宁？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "他倒安宁。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "三餐茶饭？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "小军造，"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "衣服破了？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "自己缝。 薛大哥几年运不通， 西凉路上受苦刑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "吓，受了刑，想是挨了打？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是挨了打。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不知打了多少。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一捆四十。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "喂呀，我那苦命的夫呀！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "吓，大嫂不必啼哭，有苦还在后呢！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "军营中失落一匹马，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "还是官马，还是私马？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "自然官马。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "官马岂不要赔？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哪怕他不赔？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "他哪里来的银钱赔马？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "自然有呢。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "因赔马借了我十两纹银。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了，我来问你，你在营中，吃的几份钱粮？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一份。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我那丈夫呢。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "也是一份。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你二人俱是一份。你哪里来的银子放账？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂有所不知，我那薛大哥，乃是风流浪子，将银子俱都花费了。我乃贫寒出 身，故而积的下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这就不对了。我那丈夫也是贫寒出身，不会花费银钱。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "薛大哥，薛大哥，我今才知你也是贫寒出身吓！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "被他取笑了。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "本利算来二十两， 并无有还我半毫分。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你就该问他要。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "他无有也是枉然。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你就该打骂问他要。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "岂不伤了兄弟的和气？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷身带何物？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "防身宝剑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你就该杀了他问他要。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "清平世界，浩荡乾坤，杀了人岂不要偿命。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "难道你就舍了不成？"
        },
        {
