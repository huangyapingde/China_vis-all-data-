{
  "script_id": "01013003",
  "title": "赠别挑袍",
  "alias": [
    "挂印封金"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "甘夫人",
      "hangdang": "正旦"
    },
    {
      "name": "糜夫人",
      "hangdang": "正旦"
    }
  ],
  "plot": "考《三国演义》载称，关公自寄居曹营，曹操虽赠袍赐马，待之敬礼有加，然关公悬悬不忘刘皇叔。后得陈\n震赍来刘书，知寄居河北袁绍处。关公修书复答后，立即往见曹操告辞。孰意曹操已知其欲去，连次悬牌回\n避不见，往见张辽，张辽亦托疾不出。关公于是不待面辞，作书与曹操告别，并将累次所受金银，一一封置\n库中，悬汉寿亭侯之印于堂上。诸事部署既毕，乃请二嫂上车，自乘曹操所赐赤兔马，手提偃月刀，率领旧\n日跟随，约二十余人，护送径出。关吏欲挡之，关公怒喝一声，皆避退不遑。关公乃得断后出关，望官道进\n发。曹操得报，知其不可留。程昱、蔡阳等劝其追杀，曹操皆不听，先令张辽往邀于途，令其少待，己乃引\n数十骑往送。既相见，数语之下，先出千金为赆，关公不受，继赠征袍一袭，关公至此，念既非财贿，似未\n便再却，然疑其有变，终不敢造次，因以刀尖挑之，遂长揖而去。曹操见之，惟有回顾左右，长叹一声而已。",
  "notes": "是即演义第二十回中，“关云长挂印封金”之一段故事，故亦名挂印封金。是剧王洪寿最为拿手，此外则未\n见一人云。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小军、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "身在曹营心在汉，思念桃园泪涟涟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉寿亭侯。昨闻大哥现在河北袁绍军中，是我封金挂印，去往曹营走辞。 可恨奸曹，将免见牌高挂辕门，不容某相见。某特修书一封，不免遣人送至曹 营，就此保定二位皇嫂，闯出许昌便了。 来！"
        },
        {
          "character": "小军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这有书信一封，送至曹丞相营中，不得有误。"
        },
        {
          "character": "小军",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小军下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小校。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "车仗可曾齐备？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "齐备多时。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有请二位皇嫂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同上。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同念",
          "text": "思想皇叔泪嚎啕，终日如同坐监牢。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二叔唤我何事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小弟两次去见曹操，无奈他高挂免见牌，不容我相见，是弟封金挂印，修书一 封，送往曹营，意欲不辞而别。特请二位皇嫂登车。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "倘若途中有人拦阻，如何是好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二位皇嫂，但放宽心，只是小弟这青龙刀，管叫他难逃公道。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "全凭二叔。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "众小校，趱行者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二门官同上。"
        },
        {
          "character": "二门官",
          "type": "同念",
          "text": "奉了丞相令，把守许昌门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。关羽、二皇嫂、四马童同上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "开关！"
        },
        {
          "character": "二门官",
          "type": "同白",
          "text": "何人叫关？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "关将军保定二位皇嫂过关。"
        },
        {
          "character": "二门官",
          "type": "同白",
          "text": "可有丞相将令？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "无有。"
        },
        {
          "character": "二门官",
          "type": "同白",
          "text": "可有丞相公文？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "也无有。"
        },
        {
          "character": "二门官",
          "type": "同白",
          "text": "一无丞相将令，二无公文，要想出关，是万万不能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽怒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "尔等敢挡某家的去路么？"
        },
        {
          "character": "二门官",
          "type": "同白",
          "text": "小人不敢。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谅尔也不敢。小校，催车！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "伙计，你看他吹胡子瞪眼，实在可怕，我们快快报于丞相知道，便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二门官同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四将、郭嘉、程昱同上。大吹场。曹操上。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "爕理阴阳，统雄兵，坐镇许昌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小军上。"
        },
        {
          "character": "小军",
          "type": "白",
          "text": "今有关将军书信一封，丞相请看。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。曹操看信。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哦哈哈呀，关公封金挂印，竟是去心一定，真乃是义人也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二门官同上。"
        },
        {
          "character": "二门官",
          "type": "同白",
          "text": "启丞相：今有关公，保定二位皇嫂，怒气不息，闯出城去。小人等拦挡不住， 特来禀报丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "与你等无干，再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二门官同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "咳，不料此人，竟自去了。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "看关公志高气扬，情性狂妄，不辞丞相，竟敢修书前来，真乃胆大妄为。丞相 何不将他赶回杀之？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此人英雄出众，仗义轻财，不忘故主，吾甚敬之爱之。张辽听令，命你速速赶 去，见了关公，叫他少待一时，老夫还要亲自送他一程，以表旧日之情，快去 快去。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众位将军，随同老夫前去。 来，与爷带马。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "适才间众军校报连番， 许昌城走了关美髯。 人来与爷带走战， 见了关公说根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "关羽",
          "type": "内西皮导板",
          "text": "写柬辞曹出许昌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、甘夫人、糜夫人、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "挂印信封黄金来去清白，冠冕堂皇。 曹孟德他待我恩深谊广， 暗用那牢笼计打动我关云长。 他爱我是一个英雄能将， 我看他到如今枉费心肠。 此一番到河北去寻兄长， 青龙刀、赤兔马保定皇娘。 叫人来你与爷催车仗，"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "见一人骑战马急走慌忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关将军请了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "原来是文远贤弟，你此番前来，莫非丞相，叫关某回转么？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "非也。丞相言道：请将军少待片时，丞相要亲自送将军一程。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "纵然丞相，就是带来铁甲雄兵，关某也要决一死战。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "张辽把话对我讲， 到叫关某无主张。 叫人来忙把长桥上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同下，关羽、马童同上桥。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "等候曹军作商量。"
        },
        {
          "character": "曹操",
          "type": "内西皮导板",
          "text": "人马纷纷出城壕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、三将、郭嘉、程昱引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "不料关公竟脱逃。 我念他英雄盖世武艺好， 义气凌云盖九霄。 在许昌我与他相交好， 赠他的上马金、下马银，美女战马和锦袍。 都只为刘备投了贼袁绍， 他不忘桃园故旧交。 不远千里把兄找， 可算得世间一英豪。 人来与爷前引道， 见一人立马在长桥。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "关将军你为何去心太急？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相容禀：某本解良一武夫，自幼投侍刘皇叔，桃园结义，誓同生死，皇天厚 土，共鉴此衷。前在下邳，曾请三事，均蒙丞相恩准。昨日闻得故主刘玄德， 现在河北袁绍军中，是某一闻此言，寸心如割，追念前盟，恨不得插翅飞去。 有道是：大丈夫义不负心，忠不顾死，新恩虽厚，旧义难忘，倘有未尽之恩， 容俟异日图报。昨日挂金封印，缴还丞相，还望丞相无忘昔日之言，为幸也。"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "勒马提刀把话讲， 尊一声丞相听端详： 自从下邳来归降， 蒙丞相带我见君王。 官封我汉寿亭侯皇恩浩荡， 蒙丞相赐我锦袍、战马、美女、琼浆。 白马坡前无能将， 某也曾诛文丑，斩却颜良。 非是我关某太狂妄， 桃园恩情时时挂在心肠。 望丞相开恩将某放， 知恩报德不敢忘。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "听罢言来心欢畅， 忠义英雄世无双。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫欲与将军朝夕相随，共扶汉室，不料将军去心已定，老夫也不敢强留，现 备黄金千两，与将军作路途之费。 来！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将黄金献上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "久承丞相厚恩，感激不尽。某尚有川资，就将黄金分赏丞相之将士可也。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军真妙人也，既不收此黄金，现有锦袍一袭，聊以作别，望将军收纳乎。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "人言将军义气高， 仗义轻财大英豪。 千两黄金他不要， 只得献上锦战袍。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "丞相待我恩谊好， 临别又赠我锦战袍。 扳鞍下马把话表，"
        },
        {
          "character": "关羽",
          "type": "西皮紧板",
          "text": "曹营中将士杀气高。 李典、乐进把驾保， 又有那许褚和张辽。 曹孟德行事多奸巧， 恐怕中了计笼牢。 手执着青龙刀把袍挑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽挑袍，下桥。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "催马加鞭下长桥。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "曹丞相，赠我战袍，足见多情。今日一别，后会有期。异日相逢，定当厚报， 关某去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "一见关公他去了， 好叫老夫心内焦。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "关公已去，老夫少却一员战将，真真可惜！ 来，带马回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}