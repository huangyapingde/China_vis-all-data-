{
  "script_id": "01006014",
  "title": "金水桥",
  "alias": [
    "秦英钓鱼；一名：乾坤带"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "李世民",
      "hangdang": "老生"
    },
    {
      "name": "银屏公主",
      "hangdang": "旦"
    },
    {
      "name": "长孙皇后",
      "hangdang": "老旦"
    },
    {
      "name": "詹妃",
      "hangdang": "旦"
    },
    {
      "name": "秦英",
      "hangdang": "净"
    },
    {
      "name": "徐勣",
      "hangdang": "外"
    }
  ],
  "plot": "唐秦琼之子秦怀玉，尚太宗公主，生秦英，有臂力，不畏强御。日者秦英在金水桥畔钓鱼。适詹国丈经过，\n鸣锣呵殿，招摇过桥。秦英方恨被其锣声惊散游鱼，詹国丈复斥其当道不让。秦英遂大怒，摔詹国丈于地，\n击其毙。詹妃得信，诉诸太宗，请斩秦英。帝大怒，即传旨命公主带子上殿。始欲斩秦英以谢詹，旋经长孙\n皇后出，为极力乞免。以秦英为功臣之后，且其父方在征西，万不可杀。一面詹妃又再三泣求伸冤。上竟左\n右为难，卒以许詹妃为国丈建立寺庙，春秋祭享，并令公主向詹妃下跪谢罪，詹妃意始转。适逢徐勣拜本，\n因秦怀玉被困，奏请求兵。遂派秦英去救父立功，以赎其罪。",
  "notes": "此剧大致与姚期子击死国丈仿佛，惟赦免一段，则情节大异。前见刘鸿声、吴彩霞、陈文启等，常合演此剧，\n其唱工尚好。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "内监上，李世民上。"
        },
        {
          "character": "李世民",
          "type": "二黄慢板",
          "text": "先王爷坐江山风调雨顺， 全凭着文武臣保定乾坤。 文凭着徐先生阴阳有准， 武凭着秦恩公东荡西征。 恨只恨摩沙国欺孤太甚， 一心心要夺孤锦绣龙廷。 孤曾命秦驸马挂了帅印， 这几日并未见探马到京。 但愿得此一去旗开得胜， 但愿得此一去马到成功。 但愿得此一去把狼烟扫尽， 免得孤朝朝暮暮，时时刻刻，常挂在心。 内侍臣摆御驾九龙口进，"
        },
        {
          "character": "詹妃",
          "type": "内白",
          "text": "苦吓！"
        },
        {
          "character": "李世民",
          "type": "二黄慢板",
          "text": "又听得西宫院大放悲声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "詹妃上。"
        },
        {
          "character": "詹妃",
          "type": "白",
          "text": "走吓。"
        },
        {
          "character": "詹妃",
          "type": "二黄摇板",
          "text": "悲悲切切金殿进， 万岁台前把本伸。"
        },
        {
          "character": "詹妃",
          "type": "白",
          "text": "万岁吓！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "梓童为何这等模样？"
        },
        {
          "character": "詹妃",
          "type": "白",
          "text": "启奏万岁：只因秦英将我爹爹打死，望万岁作主！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "梓童平身。寡人自有议论。"
        },
        {
          "character": "詹妃",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "内臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内监允。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "命公主带子上殿。"
        },
        {
          "character": "内监",
          "type": "白",
          "text": "万岁有旨：命公主带子上殿。"
        },
        {
          "character": "银屏公主",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": "银屏公主",
          "type": "内西皮导板",
          "text": "挂铜府绑秦英珠泪嚎啕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "银屏公主、秦英同上。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "奴才吓！"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "骂一声小奴才不孝儿曹： 在书房读诗书何等不好， 为什么在金水桥自把祸招？ 万岁爷传圣旨将儿宣诏， 准了本午门外项上加刀。"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "母亲吓！"
        },
        {
          "character": "秦英",
          "type": "西皮摇板",
          "text": "尊母亲且息怒容儿禀告， 你孩儿有一言细听根苗： 那老贼在朝中横行霸道， 满朝中文武臣个个不饶。 你孩儿在金水桥西边垂钓， 鸣锣响惊走了鱼怒气难消。 一霎时你孩儿心头火冒，"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "母亲吓！"
        },
        {
          "character": "秦英",
          "type": "西皮摇板",
          "text": "打死那老贼子不犯律条。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "咀。"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "小奴才说此话胆量不小， 打死人还说是不犯律条。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "儿是好汉？"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "是好汉。"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "是好汉随为娘同上御道，"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "走。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "跪下了。"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "哇呀。"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "我的儿跪殿角休得声高。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "儿臣见驾，父王万岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "皇儿你可知罪？"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "儿臣知罪。秦英现在殿角之下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "将秦英押上殿来。"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "参见万岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "唗！胆大秦英，前番将程脑打死，孤不降罪于你。今番又将詹老太师打死，二 罪合一。 来，金刀武士，将秦英推出午门斩首。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "刀下留人。"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "哎，母亲吓，孩儿是斩不得的。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "住了，要遵圣命。"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "事到如今，还遵什么圣命吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦英下。"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "武士手将公爷押在法标， 伺候那圣旨到方可开刀。 内侍臣你与我把国母报道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内监允。"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "这时候不出宫所为哪条？"
        },
        {
          "character": "内监",
          "type": "白",
          "text": "有请国母。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "长孙皇后上。"
        },
        {
          "character": "长孙皇后",
          "type": "西皮导板",
          "text": "内侍臣进宫廷适才报道，"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "哎，母后吓！"
        },
        {
          "character": "长孙皇后",
          "type": "西皮快板",
          "text": "我的儿你不必珠泪滔滔。 母子们手挽手同上御道， 行一个君臣礼奉见当朝。"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "妾妃见驾，吾主万岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "梓童平身。"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "梓童上殿有何本奏？"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "金殿之上，斩斩杀杀，但不知斩的哪部大臣？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小将秦英。"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "身犯何罪？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "打死太爷。"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "他父子在朝有十大汗马功劳，只可以赦，不可以斩。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "詹妃",
          "type": "哭",
          "text": "哎，爹爹……"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "定斩不赦。"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "哎，万岁吓！"
        },
        {
          "character": "长孙皇后",
          "type": "西皮原板",
          "text": "长孙后在金殿把本奏上， 尊一声我主爷细听端详： 论秦英犯王法理应当斩， 还看他秦门中一脉儿郎。 望万岁你把那赦旨来降， 秦驸马回朝来再做商量。"
        },
        {
          "character": "李世民",
          "type": "西皮原板",
          "text": "劝梓童休得要把本奏上， 待寡人有一言细说端详： 慢说是打死了皇亲国丈， 就是那庶民人也要抵偿。 劝梓童你不必把本奏上， 孤斩他正国法免乱朝纲。"
        },
        {
          "character": "银屏公主",
          "type": "西皮慢板",
          "text": "金枝女跪金殿把本来上， 尊一声我父王细听端详： 论吾儿犯王法理应当斩， 求父王念附马未转朝邦。"
        },
        {
          "character": "詹妃",
          "type": "西皮摇板",
          "text": "詹翠屏在金殿把本奏上，"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "唔，你是何人，敢在金殿顶本！"
        },
        {
          "character": "詹妃",
          "type": "白",
          "text": "我父被人打死，难道就连话也说不得了？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "是吓。他父死得甚苦，难道连话也说不得一句？ 梓童有什么本章当殿奏来，寡人与你做主。"
        },
        {
          "character": "银屏公主",
          "type": "白",
          "text": "哎，母后吓！"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "皇儿有什么本章当殿奏来，为母后与你做主。"
        },
        {
          "character": "詹妃",
          "type": "白",
          "text": "万岁吓！"
        },
        {
          "character": "詹妃",
          "type": "西皮快板",
          "text": "尊一声万岁爷细听端详： 我父王在朝中并无轻狂， 为什么金水桥一命身亡？ 万岁爷若不斩秦英小将， 我情愿去了发身入庙堂。"
        },
        {
          "character": "李世民",
          "type": "西皮导板",
          "text": "这件事叫孤王难以发放，"
        },
        {
          "character": "詹妃",
          "type": "哭",
          "text": "老爹爹！"
        },
        {
          "character": "银屏公主",
          "type": "哭",
          "text": "哎，秦英儿！"
        },
        {
          "character": "长孙皇后",
          "type": "哭",
          "text": "吓，御外男！吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同哭。"
        },
        {
          "character": "李世民",
          "type": "西皮原板",
          "text": "母哭子，女哭父，好不惨伤。 孤本当斩却了秦英小将，"
        },
        {
          "character": "银屏公主",
          "type": "哭",
          "text": "秦英儿吓！"
        },
        {
          "character": "长孙皇后",
          "type": "白",
          "text": "哎，御外男吓！"
        },
        {
          "character": "詹妃",
          "type": "哭",
          "text": "老爹爹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同哭。"
        },
        {
          "character": "李世民",
          "type": "西皮原板",
          "text": "孤皇儿在一旁哭断肝肠。 孤本当赦却了秦英小将，"
        },
        {
          "character": "詹妃",
          "type": "哭",
          "text": "老爹爹吓！"
        },
        {
          "character": "李世民",
          "type": "西皮原板",
          "text": "殿角下哭坏了詹妃娘娘。 为王的在金殿左思右想， 左也难右也难难坏为王。 没奈何离龙位把好言劝讲，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。"
        },
        {
          "character": "李世民",
          "type": "西皮二六板",
          "text": "尊一声贤梓童细听端详： 你的父在朝中身无过犯， 今日里被秦英失手身亡。 孤本当斩却了秦英小将， 可怜那秦附马未转朝房。 劝梓童放开了宽宏大量， 劝梓童莫把那打父事放在心旁。 劝梓童与孤王同欢同畅， 午门外建造下忠臣庙堂。 庙堂内修造了太师的神像， 每年间春秋季，众大臣与孤王亲自降香。 这一旁劝梓童无有话讲， 回头来对皇儿细说端详： 慢说是打死了皇亲国丈， 就是那庶民人也要抵偿。 为王的赐皇儿玉宴琼浆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "殿角下哀告那詹氏娘娘。"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "我父王在金殿把旨传降， 这是我生下了不肖儿郎。 我只得对母后把话来讲， 金枝体玉叶女岂跪娘娘。"
        },
        {
          "character": "长孙皇后",
          "type": "西皮摇板",
          "text": "虽然是昭阳院为娘执掌， 她也在西宫院陪伴君王。 父有旨母有命怎能违抗， 为姣儿屈一膝这也何妨？"
        },
        {
          "character": "银屏公主",
          "type": "西皮摇板",
          "text": "父母命不可违回言再降， 为姣儿屈一膝这也不妨。 内侍臣看过了玉宴琼浆， 母后吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。"
        },
        {
          "character": "银屏公主",
          "type": "西皮二六板",
          "text": "尊一声詹娘娘细听端详： 论畜生打死了皇亲国丈， 理应该将奴才一命抵偿。 望姨母放开了宽宏大量， 还看他年纪小无知儿郎。 一来是小秦英情性倔强， 二来是老太师命该归天堂。 望姨母发慈悲情开恩施放， 望姨母千千岁万寿无疆。"
        },
        {
          "character": "詹妃",
          "type": "西皮摇板",
          "text": "詹氏女在金殿自思自想， 贤公主为姣儿跪在一旁。 用手儿接过了御酒琼浆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小长锤。"
        },
        {
          "character": "詹妃",
          "type": "西皮快板",
          "text": "心问口，口问心，自己参详： 昔日里有一个光武皇上， 他驾前有几个开国忠良。 朝房中有一个姚期老将， 东西征南北剿保定刘王。 都只为围困在南蛮之上， 小姚刚一枝枪救父回乡。 汉天子他一见龙心大喜， 在金殿封王位又赐琼浆。 郭太师在金殿把本奏上， 他奏道哪有个父子双王？ 那姚刚见没有圣论皇榜， 鸣了锣开了道行近府旁。 郭太师坐府门公然不让， 怒恼了小姚刚一命身亡。 郭娘娘上金殿把本奏上， 要刘王斩小将一命抵偿。 汉天子他本是有道皇上， 发河北去充军将事了场。 郭娘娘心不平闷坐宫墙， 灌醉了汉天子乱斩忠良。 酒醒时将郭妃亲手斩亡， 金殿上众星宿同归天堂。 我本当要斩那秦英小将， 怕的是学郭妃无有下场。 贤公主要训子莫把祸闯， 怕的是再犯罪怒恼君王。 我和你手挽手同把殿上， 万岁爷传圣旨赦回儿郎。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "好一个贤梓童宽宏大量， 午门外赦回了秦英儿郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦英上。"
