        },
        {
          "character": null,
          "type": "stage",
          "text": "长孙皇后、银屏公主、詹妃、秦英同下。徐勣上。"
        },
        {
          "character": "徐勣",
          "type": "西皮摇板",
          "text": "手捧本章金殿上， 见了万岁奏端详。"
        },
