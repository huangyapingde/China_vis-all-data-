{
  "script_id": "01004010",
  "title": "双投唐",
  "alias": [
    "双带箭；一名：断密涧"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "李密",
      "hangdang": "净"
    },
    {
      "name": "王伯党",
      "hangdang": "老生"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "李渊",
      "hangdang": "外"
    },
    {
      "name": "河阳公主",
      "hangdang": "旦"
    }
  ],
  "plot": "隋末群雄并起，纷纷割据，人才济济，初以瓦岗寨为最盛。李密主之，既而人心离叛，群雄多去密投唐。瓦\n岗渐失败，李密势日孤。所未去者王伯党一人而已。王伯党见李密兵微将寡，数为唐困，知大势已去，负隅\n无益，因劝李密降唐。李密恐唐不纳，反见辱，因先使王伯党往探李世民意。李渊父子至，悉李密有降意，\n甚喜，许以王爵，并赐公主为李密妻。王伯党复李密后，遂同投大唐。路遇李世民打围，拾得李世民射死之\n雁，借此进见。李世民引二人回见其父，厚待李密，俱如前约。在唐之待李密，固云厚矣，而李密终以为寄\n人篱下，不若独树一帜。悔念一萌，叛心顿起，酒后与公主商酌起事，公主不从，旋手刃之。王伯党闻悉大\n惊，深怪李密作事孟浪，遂劝速逃，己愿护之同行。李密遂夤夜出城，离城不远，而李世民已率追兵至矣。\n二人至断密涧，恐被擒受辱，遂自刎而死。王伯党可谓忠于李密矣，惜其择主未当，而不得善终也。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同上，王伯党上。"
        },
        {
          "character": "王伯党",
          "type": "念",
          "text": "习就百步箭穿杨，一片忠心保瓦岗。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "俺，姓王名勇，字伯党。奉了大王之命，追赶徐勣、魏征。赶到三岔路口，念 在贾家楼前结拜，将他二人释放，不免回山朦胧启奏。 众喽兵，回山去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯党、四白龙套同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，李密上。"
        },
        {
          "character": "李密",
          "type": "西皮快板",
          "text": "瓦岗寨上杀气飘， 密密层层摆枪刀。 闲来山前摆观花草， 闷在宫中乐逍遥。 将身且在我的莲花岛， 王贤弟回来问根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套引王伯党同上。"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "来在瓦岗下虎豹， 见了大王把令交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同下。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "参见大王。伯党交令。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "贤弟少礼。请坐。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "命你追赶徐勣、魏征，可曾赶上？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "他二人去远，追赶不上，特地回山交令。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "哪里是追赶不上，分明念在贾家楼前结拜，将他二人放走，回来蒙哄孤家，是 与不是？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "大王，"
        },
        {
          "character": "王伯党",
          "type": "西皮快三眼",
          "text": "大王说话太痴迷， 细听伯党把话提： 三十六人曾结义， 生死相交永不离。 二劫皇杠把祸起， 大反山东惹是非。"
        },
        {
          "character": "王伯党",
          "type": "西皮快板",
          "text": "王勇单人把唐抵， 秦琼匹马取金堤。 夜夺瓦岗非容易， 三月三日拜帅旗。 程咬金有福登龙位， 兵多将广人马齐。 自从大王到此地， 锦绣江山化灰泥。 恨飞鼠盗去仓粮米， 满山的喽罗似鹊飞。 众家弟兄丧了队， 一个东来一个西。 只剩下王勇来保你， 反说为臣把君欺。 倘若哪国刀兵起， 祸到临头悔不及。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "王贤弟说话倒有理。"
        },
        {
          "character": "李密",
          "type": "西皮快板",
          "text": "问得孤王无话提。 李密忙离我的金交椅， 背转身来自猜疑： 孤王有道天心顺， 满山的喽罗人马齐。 我好比困龙遭虾戏， 败阵的凤凰不如鸡。 扭回头来叫贤弟， 孤王的言来细听端的： 你本是堂堂奇男子， 莫做三心二意的。"
        },
        {
          "character": "王伯党",
          "type": "西皮快板",
          "text": "说什么三心二意的， 为臣怎敢把君欺。 我若保主有假意， 气化清风肉化泥。"
        },
        {
          "character": "李密",
          "type": "西皮快板",
          "text": "好一个忠良王贤弟， 亚赛当年介子推。 孤王要把良心昧， 乱箭攒身死不回。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "贤弟，瓦岗已散，究要重整瓦岗才是。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "瓦岗已散，难以重整。保定大王，前去降唐。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "唐童与孤有南牢之仇，不去逃生，反去送死！"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "愿保大王无事。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "如此，走。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "这样不能前去。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "要怎样前去？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "换了随衣小帽，方可前去。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "这身荣耀，叫孤怎样舍得？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "事到如今，舍不得也要舍。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "看衣裳换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李密换衣。〖牌子〗。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "贤弟替孤传令。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "遵命。 下面听者：大王前去降唐，你等愿随就随，不愿随者，大家散去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同下。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "传令已毕。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "贤弟与孤带马。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "来也。"
        },
        {
          "character": "李密",
          "type": "西皮原板",
          "text": "在头上取下了我的飞龙帽， 在身上脱去了我的衮龙袍。 勒住了马头用目觑， 锦绣江山化灰泥。 舍不得瓦岗风景地， 舍不得瓦岗人马齐。 此一去降唐好一比， 虎落在平阳被犬欺。"
        },
        {
          "character": "王伯党",
          "type": "西皮快板",
          "text": "大王不要暗着急， 伯党言来听端的： 江山自有兴和废， 哪个男儿不受欺？ 改邪归正投唐去， 青史名标万古提。"
        },
        {
          "character": "李密",
          "type": "西皮快板",
          "text": "怕只怕唐童把仇记， 笼中之鸟怎能飞？"
        },
        {
          "character": "王伯党",
          "type": "西皮快板",
          "text": "杀身大祸臣愿抵， 愿保大王挂紫衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李密、王伯党同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李世民引四龙套同上。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "少小英雄胆气豪， 黄石略法吕望韬。 为将名图垂千古， 替主阵前血染刀。"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "曾记当年战洛阳，可恨李密西魏王。将孤囚禁南牢内，皇兄改本转回乡。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王李世民。可恨杨广无道，国乱民愁，且喜父王驾坐长安，倒也安然。几载 干戈宁静，还有几路狼烟未灭，是小王放心不下，故尔在父王台前讨下旨意， 统领人马，往银弓山兴围打猎，二来代访贤臣。 内侍，人马可齐？"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "起驾银弓山。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "撒下围场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "李世民",
          "type": "内西皮导板",
          "text": "将人马扎在银弓山，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、四龙套同上。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "刀枪剑戟似秋霜。 五色旌旗空中荡， 强弓硬弩摆成行。 南边飞来一群雁， 字字行行闹嚷嚷。 小王搭上珠红箭， 对准鸿雁撒上弦。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "启千岁：带箭而逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "李密",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李密、王伯党同上。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "昔日螳螂取独蝉，"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "偶遇黄雀在道边。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "黄雀又被金弹打，"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "打弹之人被虎餐。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "看来一报还一报，"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "仇报仇来冤报冤。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "勒住丝缰用目看，"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "只见箭雁落马前。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "“西府秦王百发百中”。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "贤弟手拿何物？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "乃是箭雁，大王请看。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "待孤看来：“西府秦王百发百中”。贤弟，你我拿了这只箭雁，去到前村，沽 饮一回。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "且慢。有了箭雁，就有了进身之策。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "何为进身之策？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "等那秦王到此，将箭雁献上，岂不是进身之策？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "贤弟，你保得孤王便保，保不得孤王，让孤好跑。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "愿保大王无事。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "哪里等候？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "松林等候。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "从空落下雕翎箭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李密下。"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "狭路相逢天凑缘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯党下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李世民、四龙套同上。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "此雁中了雕翎箭， 百发百中不虚传。 传旨赶过桃花店， 不知箭雁落哪边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯党上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "前道因何不行？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "王勇挡道。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "王勇挡道。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "人马闪开。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "原来伯党皇兄。不在瓦岗，到此则甚？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "为臣拾得箭雁，特来献上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "乃是皇兄之功，收过了。吓，皇兄不在瓦岗扶保李密，来在荒郊何事？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "臣保定一人，前来降唐。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "但不知是哪一家？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "西魏王李密。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "何不前来相见？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "犹恐千岁提起南牢仇恨。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "只要真心归顺，南牢之事一概不提。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "今在何处？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "现在松林。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "请来相见。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "遵命。吓，千岁须要言而有信。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "将军吓，"
        },
        {
          "character": "李世民",
          "type": "西皮快板",
          "text": "皇兄不必细叮咛， 小王非是等闲人。 只要真心来归顺， 我与他皇兄御弟称。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "王伯党",
          "type": "西皮快板",
          "text": "好一个仁义二主君， 他比尧舜胜十分， 后来若是登九五， 必定不差半毫分。 松林内忙把大王请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李密上。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "心中恍惚不安宁。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "贤弟可曾见过唐童？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "也曾见过。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "南牢之仇？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "一概不究。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "好，带孤上前。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "且慢。见了唐王，怎么行礼？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "我与他打上一躬，“唐童请了请了！”"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "嗳，他乃一君，你乃一臣，必须下一全礼。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "嗳，他乃一国的王子，想孤在瓦岗寨上，也是一国的王子，叫我与他下上全礼， 那是万万不能。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "你前来作甚？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "前来降唐。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "却又来！"
        },
        {
          "character": "王伯党",
          "type": "西皮快板",
          "text": "说什么瓦岗你为君， 说什么低头不拜人。 上前去施一个君臣礼， 我保你头戴乌纱入朝门。"
        },
        {
          "character": "李密",
          "type": "西皮二六板",
          "text": "李密闻言心不准， 背转身来自思忖。 想孤在瓦岗多侥幸， 称孤道寡亚赛个朝庭。 到如今孤王来归顺， 反得要屈膝跪他人。 这才是船到江心，"
        },
        {
          "character": "李密",
          "type": "西皮快板",
          "text": "风不顺， 时衰运败鬼弄人。 罢罢罢，暂忍我的心头恨， 慢慢再定巧计生。 扭回头我对贤弟论， 孤王言来细听分明： 自要那唐童不记南牢旧仇恨， 我跪他一席待怎生。 王贤弟与孤把路引， 有罪的李密我来叩见圣明君。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "将军吓！"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "西魏王不必礼恭敬， 依礼而代入朝门。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "人言唐童似尧舜，"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "话不虚传果是真。"
        },
        {
          "character": "李密",
          "type": "西皮摇板",
          "text": "降唐的事儿心拿稳，"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "似狂风吹散了满天云。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "众将官，人马回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引李渊同上。"
        },
        {
          "character": "李渊",
          "type": "引子",
          "text": "河清海晏，五谷丰登。"
        },
        {
          "character": "李渊",
          "type": "念",
          "text": "日出东方捧祥云，笙歌嘹亮来深台。瑶台翡翠飞彩凤，殿用雀东西六龙。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "寡人，神尧高祖李渊，国号武德在位。自太原起圣，受命于天，龙飞凤舞。目 今天下升平，所有一十八路反王，年年进贡，岁岁来朝。正是："
        },
        {
          "character": "李渊",
          "type": "念",
          "text": "一人有福安天下，万国衣冠贺圣皇。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "内臣，开放龙门。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "领旨。 万岁有旨：开放龙门。"
        },
        {
          "character": "内侍",
          "type": "内白",
          "text": "秦王回朝。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "随旨上殿。"
        },
        {
          "character": "李世民",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民上。"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "兴围打猎事，奏与父皇知。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "儿臣见驾，父皇万岁。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿平身。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿郊外射猎，打得多少飞禽走兽？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "儿臣未曾打得飞禽走兽，收来二家贤臣。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "可知贤臣姓甚名谁？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "李密、王伯党前来投唐。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "唔，那李密瓦岗贼寇，从前将皇兄囚禁南牢，孤皇正要兴兵拿他问罪，他今日 自投罗网，为何不将他正法？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "若提南牢之事，又恐大事难成。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿有理。二人今在何处？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "现在午门。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "宣他二人上殿。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "父皇有旨：宣王伯党、李密上殿。"
        },
        {
          "character": "李密、王伯党",
          "type": "内同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李密、王伯党同上。"
        },
        {
          "character": "李密",
          "type": "念",
          "text": "低头入朝门，"
        },
        {
          "character": "王伯党",
          "type": "念",
          "text": "叩见圣明君。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "臣，李密，"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "臣，伯党，"
        },
        {
          "character": "李密、王伯党",
          "type": "同白",
          "text": "见驾，吾皇万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "李密，你可知罪？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "臣知罪，望吾皇开恩。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "自要你真心归顺，寡人一概不究。暂授魏国公之职，下殿。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "李密",
          "type": "念",
          "text": "暂为鸡鸣客，且做懵懂人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李密下。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "伯党听封。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "臣有本启奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿，王伯党奏道：一臣不事二主，情愿服侍李密，不愿为官。如何发落？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "他乃忠义之人，既然不愿为官，父皇还要另加爵赏。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "王将军已不愿官职，暂住李密门下。日后有功，自有封赠。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "王伯党",
          "type": "念",
          "text": "伯党生来情性刚，一臣不保二君皇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯党下。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿，李密为寇多年，野心未定。今来降唐，不可重用，恐有异心。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "启奏父皇：何不将河阳公主许配李密，招为东床驸马，反心自退。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "寡人有旨：命河阳公主招赘魏国公李密，即刻梳妆，傧相赞礼，退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、李世民同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引河阳公主同上。"
        },
        {
          "character": "河阳公主",
          "type": "引子",
          "text": "雨露似天才，夫荣妻贵堪偕。"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "驸马回宫。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "驸马回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监引李密同上。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "驸马请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "驸马今日上朝，我皇伯怎样传旨？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "皇伯传旨下来，山西贼寇造反，命本宫挂帅，前去征剿。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "不知驸马几时启程？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "明早启程。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "妾身备得有宴，与驸马饯行。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "有劳公主。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "宫娥看酒。"
        },
        {
          "character": "李密",
          "type": "西皮原板",
          "text": "皇宫内院把宴摆， 夫妻们对坐饮开怀。 停杯不饮愁眉带， 她怎知我心事揣在怀。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "驸马。"
        },
        {
          "character": "河阳公主",
          "type": "西皮原板",
          "text": "琴瑟和调真恩爱， 夫唱妇随永合谐。 今日宫中把宴摆， 驸马因何不开怀？"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "驸马为何停杯不饮？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "非是停杯不饮，我有心事在怀。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "既有心事在怀，何不对妾身讲明。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "这个……耳目甚众。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "吓，宫娥退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女同允，同下。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "驸马请讲。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "公主，想孤在瓦岗寨上，朝朝饮宴，夜夜笙歌，好不快乐人也！"
        },
        {
          "character": "李密",
          "type": "西皮快板",
          "text": "非是本宫愁眉带， 公主听我表心怀： 瓦岗为王有数载， 犹如天子坐龙台。 飞龙帽，头上戴， 绛黄蟒袍海外来， 腰束八宝白玉带， 粉底朝靴踹金阶。 也有文武参朝拜， 也有宫娥女裙衩。 闲来跨马游郊外， 闷向宫中把宴摆。 宫娥彩女解龙带， 三宫六院陪伴我好不快乐哉。 不幸散了瓦岗寨， 因此投唐到此来。 虽蒙唐王恩似海， 怎及瓦岗快乐哉？ 东床驸马我不爱， 一心还想坐龙台。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "河阳公主",
          "type": "西皮快板",
          "text": "听他言来愁眉带， 背转身来暗思裁： 皇伯恩义将他待， 奴家与他配合偕。 东床驸马他不爱， 一心只想谋龙台。 我明明知道装不解， 假意上前问开怀。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "驸马，听你之言，敢不是要谋我皇伯的龙位么？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "本宫早有此心。公主，你可知皇伯的玉玺今在何处？"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "现在昭阳正院。有了玉玺，你便怎么讲？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "公主盗来玉玺，本宫征剿山西贼寇，人马反上金殿。将你皇伯杀死，我得了大 唐天下，昭阳正宫，自然是公主的。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "自然是你的了。"
        },
        {
          "character": "河阳公主",
          "type": "西皮快板",
          "text": "听一言来牙咬坏， 驸马做事礼不该。 不幸散了瓦岗寨， 王伯党引你投唐来。 皇伯待你恩似海， 反把奴家配合偕。 非是妾身将你怪， 看起来你是个无义才。"
        },
        {
          "character": "李密",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "李密",
          "type": "西皮快板",
          "text": "听她言来牙咬坏， 大骂贱人礼不该。 既已嫁夫随夫爱， 夫唱妇随理应该。 贱人再把颜色卖， 千刀万剐死无有葬埋。"
        },
        {
          "character": "河阳公主",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "河阳公主",
          "type": "西皮摇板",
