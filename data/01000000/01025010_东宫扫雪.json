{
  "script_id": "01025010",
  "title": "东宫扫雪",
  "alias": [
    "子母炮"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "赵妃",
      "hangdang": "正旦"
    },
    {
      "name": "刘彦真",
      "hangdang": "小生"
    },
    {
      "name": "唐妃",
      "hangdang": "花旦"
    },
    {
      "name": "土地",
      "hangdang": "丑"
    }
  ],
  "plot": "剧中事实，出于五代北汉时间。观其辞意，谓北汉王偏听西宫唐妃之谗言，幽禁正宫国母，并杀宫娥多人。\n太子深恨唐妃，见面时肆行辱骂。唐妃用药酒将太子毒死，并抛尸于河内。幸得宫中土地神，大施法力，唤\n醒东宫赵妃于睡梦中，使闻太子呼救声。遂暗至河边，将太子救至河岸，纵之使逸。又恐唐妃跟踪追究，用\n裙边将雪花扫乱，以灭其足迹云。",
  "notes": "是剧正旦唱工，最为吃重。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘彦真上。"
        },
        {
          "character": "刘彦真",
          "type": "西皮摇板",
          "text": "在东宫领了千岁命， 迎接母后转回程。 暗暗出了皇宫院， 不由小王自伤情。 想起淫妇西妃女， 好叫小王恨在心。 依仗父王将你宠， 把我欺压不当人。 越思越想心头恨， 大骂西妃狗贱人！ 我兄妹与你何仇恨， 暗害我们为何情？ 今日里母后出宫未回转， 待小王去接昭阳正院尊。 行行正走来得快，"
        },
        {
          "character": "刘彦真",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "刘彦真",
          "type": "西皮摇板",
          "text": "那旁又来了对头人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女、太监引唐妃同上。"
        },
        {
          "character": "唐妃",
          "type": "西皮摇板",
          "text": "宫娥摆驾出宫门， 来了陪王伴驾人。 众星捧月朝前进，"
        },
        {
          "character": "唐妃",
          "type": "白",
          "text": "呵！"
        },
        {
          "character": "唐妃",
          "type": "西皮摇板",
          "text": "銮驾不走是何因？"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "太子接驾。"
        },
        {
          "character": "刘彦真",
          "type": "西皮摇板",
          "text": "小王一时把气忍， 战战兢兢跪埃尘。 儿臣彦真来接驾，"
        },
        {
          "character": "唐妃",
          "type": "西皮流水板",
          "text": "哀家一见怒气嗔！ 手指狗子高声骂， 骂声彦真太不仁。 你哪里来是接凤驾， 分明是前来安歹心。 狗子意高心胆大， 瞧不起西宫下院人。 不见冤家还自可， 一见狗子冒火云。 你对父王将言谏， 陷害与我为你身。 今日见了冤家面， 咱们俩结下冤仇似海深。 叫人来绑他把宫进， 治死畜生免祸根。"
        },
        {
          "character": "刘彦真",
          "type": "唱",
          "text": "彦真跌跪泪纷纷， 望姨母高开天地恩。 虽然儿臣有过犯， 也该念我母昭阳伴驾人。"
        },
        {
          "character": "唐妃",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "唐妃",
          "type": "唱",
          "text": "不提你母心不恼， 提起你母恼在心。 狗贱人曾坐昭阳院， 作践西宫不当人。 金銮殿上把言谏， 她将俺贬在寒宫冷院门。 到如今时来运转伴龙驾， 三宫六院谁不尊？ 宫娥忙把宫院进， 定叫畜生命归阴！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监绑刘彦真，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "唱",
          "text": "紫微大帝有大难， 慌得吾神不得闲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宫女扶刘彦真同上，太监引唐妃同上。"
        },
        {
          "character": "唐妃",
          "type": "唱",
          "text": "哀家带怒进宫廷， 要报冤仇把气平。 宫娥女把药酒忙看过， 灌在狗子肚腹中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐妃灌刘彦真。"
        },
        {
          "character": "刘彦真",
          "type": "唱",
          "text": "心疼气紧难扎挣，"
        },
        {
          "character": "刘彦真",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘彦真",
          "type": "唱",
          "text": "一跤跌在地埃尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘彦真倒。"
        },
        {
          "character": "唐妃",
          "type": "白",
          "text": "一见畜生赴幽冥， 叫人抬起莫消停。 将他抛在皂河内， 方与哀家免祸星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监抬刘彦真同下，众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二门神同上。"
        },
        {
          "character": "二门神",
          "type": "同唱",
          "text": "神茶玉垒上天庭， 凌霄宝殿奏分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二门神同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵妃上。"
        },
        {
          "character": "赵妃",
          "type": "西皮原板",
          "text": "哀家事毕转回宫， 不觉眼跳又心惊。 适才内侍前来报， 西妃害我小娇生。 暗暗出了昭阳院， 去到皂河查看明。 我的皇儿有灾难， 命在旦夕少救星。 时逢腊月残冬景， 天寒地冻水成冰。 鹅毛片片迷路径， 处处楼台似银城。 但愿我儿身有救， 满斗焚香谢神灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妃下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四水卒引龙王同上。"
        },
        {
          "character": "龙王",
          "type": "念",
          "text": "万里乾坤路遥遥， 江河湖海透九霄。 凌霄宝殿居水府， 清波摆动浪滔滔。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "俺，四海龙王是也。只因紫微星君，身临水府有难，须得吾神前去搭救。 水卒们，"
        },
        {
          "character": "四水卒",
          "type": "同白",
          "text": "圣寿！"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "开道皂河去也！"
        },
        {
          "character": "龙王",
          "type": "唱",
          "text": "施展法术显神通， 江河湖海冻成冰。 水卒开道皂河内， 等候皇妃到来临。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水卒、龙王同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵妃上。"
        },
        {
          "character": "赵妃",
          "type": "西皮流水板",
          "text": "赵素娘迈步往前行， 鹅毛大雪冷难禁。 狂风吹得行人冷， 一心要去救亲生。 行行来至东门外， 抬头闪目看分明： 果然不比皇宫景， 它比别门大改形。 楼上放定子母炮， 楼下密摆箭雕翎。 城左风摆旌旗动， 城右兵似一窝蜂。 哀家看罢东门景， 吸气吞声转身形。 恐怕有人来识破， 泄漏机关了不成。 忙忙转过城关境， 暗暗哀家告苍穹。 鹅毛大雪迷路径， 行动雪地有迹踪。 倘若奸妃来赏景， 被她识破不相应。 若知我儿身有救， 必然又把毒计生。 须得把雪来除净， 方与我儿免祸星。 罢罢罢，我拿裙边将雪扫， 一步一扫往前行。 行行来至皂河径， 皂河之内水成冰。 哀家施礼忙下跪， 祝告龙王在上听： 若是我儿身有救， 水化冰开显身形。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙王、四水卒、刘彦真暗同上。"
        },
        {
          "character": "赵妃",
          "type": "西皮流水板",
          "text": "赵素娘正在伤心处， 一声响亮令人惊。 果然水开冰化冻， 见一幼子出水平。 将我儿携在皂河岸， 平坦之地放身形。 叫声我儿即刻醒， 若有差池母命倾。 哀家叫喊多一会， 又听我儿哼一声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水卒、龙王暗同下。"
        },
        {
          "character": "刘彦真",
          "type": "唱",
          "text": "适才渺渺赴阴城， 奸妃害我好苦情。 何人救我还阳境，"
        },
        {
          "character": "刘彦真",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘彦真",
          "type": "唱",
          "text": "又见母后到来临。"
        },
        {
          "character": "赵妃",
          "type": "唱",
          "text": "一见我儿转还生， 哀家又喜又伤情。 喜的是母子重相会， 伤的是湿衣着体冷难禁。 忙忙脱下衣一件， 与我儿暂且挡雪并遮风。 奸妃怎样将你害， 细对为娘诉分明。"
        },
        {
          "character": "刘彦真",
          "type": "唱",
          "text": "彦真跌跪珠泪倾， 多谢母后好恩情。 若问奸妃将儿害， 儿臣说来母后听： 昨日接母进宫廷， 遇见西妃狠毒虫。 儿臣上前去接驾， 不料贼人动无名。 手指孩儿高声骂， 说我前去把刺行。 不容儿说将儿绑， 再三哀告不容情。 叫人用酒把儿灌， 霎时一命丧残生。 心疼气紧难扎挣， 为儿进了冤死城。 多亏母后来搭救， 彦真死后又复生。"
        },
        {
          "character": "赵妃",
          "type": "西皮快板",
          "text": "听罢言来怒气生， 不由立刻动无名。 奸妃倚仗君王宠， 胆敢欺压我子亲生。 有朝一日拿住你， 太后怎能擅留情。 千刀万剐难消恨， 剥皮抽筋挖眼睛。 割了贼心不算帐， 剐骨熬油点天灯。 可叹还有金定女， 不知奸妃怎待承？ 叹我儿宫中为太子， 你妹金定女俊英。 为娘所养你们俩， 兄妹二人一母生。 到如今被她来作践， 公主、太子受苦情。 母子不可贪恋住， 快些寻路去逃生。 倘若被她来知晓， 识破机关命定倾。 可怜东宫皇太子， 只落得路上受贫穷。"
        },
        {
          "character": "刘彦真",
          "type": "唱",
          "text": "彦真不由放悲声， 好似狼牙箭穿胸。 为儿欲要逃生去， 实实难舍母子情。 欲待母子常聚会， 奸妃知道不容情。 彦真必然遭擒获， 一定害我命残生。 罢罢罢，辞别母后寻路径， 哭哭啼啼步难行。 若要母子重相见， 除非是花儿重开月又明。"
        },
        {
          "character": "赵妃",
          "type": "唱",
          "text": "见儿贪恋步难行， 为娘好似箭穿胸。 最恨西妃淫邪女， 害得我母子好苦情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地上，引刘彦真同下。"
        },
        {
          "character": "赵妃",
          "type": "唱",
          "text": "趁早急出阳关境， 隐姓埋名去逃生。 叫声我儿快些走， 瞒过奸妃不知情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妃下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}