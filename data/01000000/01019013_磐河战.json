{
  "script_id": "01019013",
  "title": "磐河战",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "公孙瓒",
      "hangdang": "老生"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "袁绍",
      "hangdang": "净"
    },
    {
      "name": "公孙越",
      "hangdang": "末"
    },
    {
      "name": "吕翔",
      "hangdang": "副净"
    }
  ],
  "plot": "公孙瓒遣弟公孙越送书与袁绍，约会共取冀州。袁绍当面允许，公孙越辞回，袁绍命吕翔带领军卒，假称西\n凉马腾部下，要于半路而射杀之。公孙瓒因此起兵。赵云原在袁绍处，当一偏将，请令独自御敌，袁绍斥其\n言大而夸，即行逐出。赵云在磐河牧马，见公孙瓒危急，遂奋身往救，杀退绍兵，公孙瓒得救。",
  "notes": "汉末，群雄各据一方，互相攻伐，强吞弱肉，视兵力为转移。其时袁绍，屯聚河内，公孙瓒镇守北平，拥众\n自固。袁绍欲扩张功业，用谋士逢纪之策，暗使人驰书于公孙瓒，令进兵取冀州，约以夹攻，平分其地。又\n密报于冀州牧韩馥，云瓒兵将来。韩馥庸懦无能，闻信惊惶，遂让位于袁绍，而冀州版图，尽归袁绍一人统\n辖。公孙瓒欲践前言，使弟公孙越往见袁绍，商议平分之事。回至中途，袁绍遣手下人，冒称董卓家将，将\n公孙越乱箭射死。公孙瓒兴兵复仇，袁绍御之，战于磐河之上，瓒军大败。公孙瓒为绍将文丑所逼，几濒于\n危，突来一少年将军，战退文丑，救公孙瓒出险。问及姓名，始知赵云，字子龙，本在袁绍帐下，不获大用，\n弃袁绍而来归者也。按《三国演义》所载，如是云云。演义与剧本，两相参阅，即为不同之点也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四龙套、公孙瓒同上。〖点绛唇〗。"
        },
        {
          "character": "公孙瓒",
          "type": "念",
          "text": "汉室衰微国运倾，谗臣当道乱朝廷。各路诸侯相争胜，分疆列土动刀兵。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "公孙瓒。镇守北平一带等处。今有韩馥，坐镇冀州，袁绍每欲征讨。本帅亦欲 夺取，只为兵微将少，恐难取胜。我欲修书一封，命二弟前去，与袁绍借兵， 共打冀州。倘若得胜，与他平分疆土。 来，请二老爷。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有请二老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙越上。"
        },
        {
          "character": "公孙越",
          "type": "念",
          "text": "柳营春试马，虎帐夜谈兵。"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "参见兄长。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "贤弟少礼，请坐。"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "谢座。唤小弟前来，有何军情？"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "只因韩馥，镇守冀州，萎靡不振。愚兄有意攻取，无奈兵微将寡，恐难取胜。 今特修书一封，与袁绍共夺冀州。倘若成功，与他平分疆土。欲烦贤弟前去， 与袁绍商议。不知贤弟意下如何？"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "但不知几时起程？"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "即刻起程。兄有一言，你且听了。"
        },
        {
          "character": "公孙瓒",
          "type": "西皮原板",
          "text": "公孙瓒坐帐中一言相告， 叫一声二贤弟细听根苗： 此一番到河北见了袁绍， 就与他借兵将共动枪刀。 但愿得早把那韩馥灭了， 我与他共疆界列土分茅。 叫贤弟将书信身旁带好， 此一去早回程好立功劳。"
        },
        {
          "character": "公孙越",
          "type": "西皮摇板",
          "text": "辞别兄长跨金蹬，"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "马来。"
        },
        {
          "character": "公孙越",
          "type": "西皮摇板",
          "text": "去到河北走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙越下。"
        },
        {
          "character": "公孙瓒",
          "type": "西皮摇板",
          "text": "人来与爷把门掩， 等候二弟转回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙瓒下，四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、袁绍同上。"
        },
        {
          "character": "袁绍",
          "type": "引子",
          "text": "四世三公，保汉室，统领雄兵。"
        },
        {
          "character": "袁绍",
          "type": "念",
          "text": "金盔凤翅锦罗袍，四世三公辅汉朝。谋臣战将归帐下，统领雄兵美名标。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "吾，袁绍。镇守河北一带等处。只因韩馥坐守冀州，此人性情柔弱，不称其职。 吾久有攻取之意，但是无有机会，师出无名。 左右，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有北平公孙越，前来求见。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。公孙越上。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "请坐。未知将军驾到，有失远迎，当面恕罪。"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "岂敢。末将来得卤莽，明公恕罪。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "岂敢。将军到此，必有所为。"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "今奉兄长之命，前来有书信呈上。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "待吾看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "原来如此。吾修书不及，照书行事，便了。"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "遵命。告辞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙越下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "公孙瓒要与我借兵，共取冀州，真道岂有此理。 来，传吕翔进帐。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "吕将军进帐。"
        },
        {
          "character": "吕翔",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕翔上。"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "命你带领五百弓箭手，假扮作马腾兵马，在山后埋伏。等公孙越到来，将他射 死，不得有误。"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕翔下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁绍、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、吕翔同上。"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "俺，吕翔。奉了元帅将令，假扮马腾人马，截杀公孙越。 众将官，山后埋伏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、公孙越同上，会阵。"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "你是何人，敢挡我的去路？"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "我乃马腾帐下，大将庞德是也！奉主之命，特来杀你！"
        },
        {
          "character": "公孙越",
          "type": "白",
          "text": "满口胡言，看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕翔败下，公孙越追下。吕翔上。"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "来，弓箭手伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙越追上，四上手同射箭，公孙越下。"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "公孙越已死，回营交令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕翔、四上手同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "公孙瓒上。"
        },
        {
          "character": "公孙瓒",
          "type": "念",
          "text": "心惊肉跳，坐卧不宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：大事不好了！"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "二老爷行至中途，被袁绍差人，假充马腾兵马，将二老爷乱箭射死了！"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "将二老爷射死了！"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "公孙瓒",
          "type": "西皮摇板",
          "text": "听一言来怒气生， 大骂袁绍狗奸人。 三军与爷披挂整， 要与二弟报冤恨。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "吩咐大小三军，全身披挂，校场伺候。掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙瓒下。报子下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "颜良上，起霸。"
        },
        {
          "character": "颜良",
          "type": "念",
          "text": "大将生来力刚强，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文丑上，起霸。"
        },
        {
          "character": "文丑",
          "type": "念",
          "text": "赫赫威名振四方。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕翔上，起霸。"
        },
        {
          "character": "吕翔",
          "type": "念",
          "text": "阵前统带兵和将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上，起霸。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "单枪匹马把名扬。"
        },
        {
          "character": "颜良、文丑、吕翔、赵云",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "颜良。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "文丑。"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "吕翔。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云。"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "文丑、吕翔、赵云",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "颜良",
          "type": "白",
          "text": "今日元帅发兵，你我两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四龙套、四上手同上，袁绍上。〖点绛唇〗。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "吾，袁绍。只因公孙瓒兴兵前来，要与他兄弟报仇，不免起兵前往。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "赵云为何阻令？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "想那公孙瓒，兴兵前来，何劳元帅亲自出马？末将不才，愿讨一支将令，大战 公孙瓒。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "看你小小年纪，面黄肌瘦，岂是他人对手？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "元帅你好小量人也！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "元帅把人太小量， 细听赵云说端详： 英雄岂在容貌上， 海水焉能用斗量！"
        },
        {
          "character": "袁绍",
          "type": "西皮摇板",
          "text": "赵云说话太张狂， 不由老夫怒胸膛。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "胆大赵云，本帅正要出兵，你在帐中，絮絮叨叨。 来，叉出帐去！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、二将、公孙瓒同上，对阵。"
        },
        {
          "character": "公孙瓒",
          "type": "西皮快板",
          "text": "见袁绍，气满胸， 大骂无志狗奸雄： 我命二弟把信送， 乱箭穿身为哪宗？ 老爷兴兵威风勇， 割去尔的牛头，方解俺气满胸。"
        },
        {
          "character": "袁绍",
          "type": "西皮快板",
          "text": "公孙说话理不通， 西凉马腾把路横。 你弟被他把命送， 埋怨老夫为哪宗？"
        },
        {
          "character": "公孙瓒",
          "type": "西皮快板",
          "text": "诡计多端害人命， 擅敢狂言来逞能！ 三军与爷往前涌， 少时叫尔丧残生！ （公孙瓒、袁绍同起打，公孙瓒败下，袁绍、四龙套、四上手、颜良、文丑、吕翔同追下。颜良上，二将同 上，对阵，同败下，颜良追下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "老天无故困英雄， 浅水怎能养蛟龙？ 有朝一日春雷动， 大鹏展翅上苍穹。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺，赵云，袁绍帐下为将。可恨那厮目不识人，藐视英雄，不叫我出兵。是俺 仍在这磐河牧马……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哪里人声呐喊？登高一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上高坡。公孙瓒上，袁绍、四龙套同追上。公孙瓒败下，袁绍、四龙套同追下。"
        },
        {
          "character": "赵云",
          "type": "白",
