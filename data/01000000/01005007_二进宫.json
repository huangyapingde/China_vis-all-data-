{
  "script_id": "01005007",
  "title": "二进宫",
  "alias": [
    "击宫门"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "李艳妃",
      "hangdang": "正旦"
    },
    {
      "name": "徐延昭",
      "hangdang": "净"
    },
    {
      "name": "杨波",
      "hangdang": "老生"
    },
    {
      "name": "徐小姐",
      "hangdang": "旦"
    },
    {
      "name": "杨四郎",
      "hangdang": "小生"
    }
  ],
  "plot": "徐延昭、杨波，因初次力谏李良摄位事，李后执拗不听，故叹皇陵后，复二次入宫，竭诚奏导。时李后适因\n其父封锁朝阳，间隔内外，渐露篡夺之谋，以是心亦回悟，深知徐、杨忠诚，可托六尺之孤。且其威望骨鲠，\n足以慑服国丈。遂欲将幼主托付徐延昭，命其谋策万全，以固明室社稷。徐延昭力保杨波智勇双全，公忠\n可托，足使国丈不生反侧之心。后从其议，三人遂在宫中对天立誓，共保冲帝。卒使李良逆谋隐消，明社渐\n安，皆徐、杨二人百折不回，婉转谏奏之功也。然后之立地悔悟，从善如流，其明决亦有足多者。",
  "notes": "此剧须生黑头青衫均重唱工，且极冗长，颇难讨好。而入后三人跪地时一段快板，尤煞费力量。擅长者至此，\n唱得步步紧接，声声入彀，实觉非常动听，然非具大魄力者不辨。盖音节虽促，而声量仍须暇逸也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "李艳妃",
          "type": "内白",
          "text": "嗳，先王吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同上，李艳妃上。"
        },
        {
          "character": "李艳妃",
          "type": "二黄慢板",
          "text": "独坐在寒宫院闷忧， 看一看不觉到八月中秋。 先皇爷晏了驾太子年幼， 我与那太师爷结下冤仇。 徐小姐把守在宫中门口， 怕的是太师爷来把宫搜。"
        },
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "type": "内白",
          "text": "千岁请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐延昭、杨波、杨四郎同上。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "叹罢皇陵到朝阳，"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "宫门上锁贼李良。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "铜锤付与大人掌，"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "四郎我儿击宫墙。"
        },
        {
          "character": "杨四郎",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "杨四郎",
          "type": "二黄摇板",
          "text": "千岁、我父把令传， 那怕宫门千道栓。 铜锤一举双环断，"
        },
        {
          "character": "徐小姐",
          "type": "二黄摇板",
          "text": "你是何人击宫门？"
        },
        {
          "character": "徐延昭、杨波",
          "type": "同白",
          "text": "我儿休要动手！此乃（四公子）（徐小姐），上前见礼！"
        },
        {
          "character": "杨四郎",
          "type": "白",
          "text": "小将有礼！"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "还礼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨四郎下。"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "罢了！我儿启奏国太，徐、杨二家，宫门求见。"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "启禀国太：徐、杨二家，宫门求见。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "宣徐、杨二家进宫。"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "国太有旨，宣徐、杨二家进宫！"
        },
        {
          "character": "徐延昭、杨波",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "此番进宫，将保国之事细表一番。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "全仗千岁！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁请！"
        },
        {
          "character": "杨波",
          "type": "二黄慢板",
          "text": "千岁爷进昭阳休要慌忙， 站宫门听学生细说比方： 汉高祖曾赴会鸿门宴上， 保驾臣名樊哙、陈平、张良。 张子房背着剑把韩信访， 九里山十埋伏摆下战场。 只逼得楚项羽乌江命丧， 封韩信三齐王永镇朝纲。 他驾前有一个萧何臣相， 后宫院有一位吕后皇娘。 君臣们安排下天罗地网， 把一个汉韩信斩首未央。 千岁爷进昭阳学生不往，"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "杨波",
          "type": "二黄慢板",
          "text": "怕只怕学韩信命丧未央，死无有下场！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "说什么学韩信命丧未央， 站宫门听老夫细说比方： 先皇爷怎比得汉高皇上， 龙国太怎比得吕后皇娘。 李良贼怎比得萧何臣相， 杨大人可以比三齐的王。 这宫门今当作鸿门宴上， 有老夫好一比大将樊哙，手执铜锤，保驾身旁，料也无妨！"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "我好比鱼儿闯过了千层罗网， 受了些惊怕，着了些慌忙。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "只要你忠心把国掌， 老夫保你满门无伤！"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "千岁爷保学生满门无伤， 舍死忘生闯进昭阳。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "前面走的定国王，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "后面跟随兵部侍郎， 站立在宫门朝里望，"
        },
        {
          "character": "李艳妃",
          "type": "哭",
          "text": "先皇吓！"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "又只见龙国太，怀抱太子，两泪汪汪，口口声声哭的先皇。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "龙国太哭的是江山难掌。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "摆一摆手儿切莫要承当。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "见国太休行那君臣大礼，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "学一个文站东，"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "武立西，"
        },
        {
          "character": "徐延昭、杨波",
          "type": "同二黄原板",
          "text": "各自分班，站立两厢。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "先皇吓！"
        },
        {
          "character": "李艳妃",
          "type": "二黄慢板",
          "text": "李艳妃坐昭阳前思后想， 思一思想一想无有主张。 耳边厢又听得朝靴底响， 想必是徐、杨将进了昭阳。 有句话儿不好讲， 只落得怀抱太子，两泪汪汪，哭了声先皇。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "龙国太抱幼主把国执掌，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "你为何，恨天怨地，夹带愁肠，所为那桩？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "也非是哀家夹带愁肠， 都只为我朝中不得安康。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "我朝中有什么祸从天降？"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "何不请太师爷进宫来，父女们商量，这又何妨？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "太师爷心肠毒亚赛王莽， 他要夺我皇儿锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "太师爷娘娘的父，他本是皇亲国丈，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "他未必一旦里起下了谋位心肠，太师爷忠良！"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "你道他无有那谋位心肠， 为什么封锁昭阳，断了水火，所为那桩？"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "龙凤阁让江山，也曾把三本奏上，龙国太，你偏偏要让！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "你言道：大明朝有事无事，不用徐、杨二大奸党，赶出朝房，自立为王。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "先前的话儿休要讲， 不看哀家看先皇。 徐皇兄保皇儿登龙位上， 你的名儿万古扬！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "龙国太错把旨来降， 臣有一本启奏皇娘： 臣耳聋听不见朝皇鼓响， 眼昏花难观那阵头的枪。 老臣两鬓白如霜降， 要保国还有那兵部侍郎。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "徐王兄年纪迈难把国掌， 回头来叫一声兵部侍郎： 你保幼主登龙位上， 哀家封你并肩王。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "唬得臣低头不敢望， 战战兢兢启奏皇娘： 臣昨晚修下了辞皇表章， 今日里进宫来辞别皇娘。 为臣好比笼中鸟， 望娘娘开笼放鹊，放鹊开笼，赦臣还乡，臣乐安康！"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "他二人不把国来掌， 到叫哀家无有主张。 没奈何怀抱太子跪昭阳，"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "唬坏了定国王，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "兵部侍郎！"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "自从盘古立帝邦，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "君跪臣来臣不敢当。"
        },
        {
          "character": "李艳妃",
          "type": "快二黄二六板",
          "text": "非是哀家来跪你， 为的是我皇儿锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "锦家邦来锦家邦，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "臣有一本启奏皇娘："
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "昔日里有个李文、李广，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "弟兄双双扶保朝纲。"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "李文北门带箭丧，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "万家山前又收李刚。"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "收了一将又一将，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "一将到比一将强。"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "到后来保太子登龙位上，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "反把李广斩首庆阳。"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "这都是前朝的忠臣良将，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "那个忠良又有下场！"
        },
        {
          "character": "李艳妃",
          "type": "快二黄二六板",
          "text": "有下场来无下场， 细听哀家说比方： 昔日里有个子龙将， 长板坡前救小王。 到后来保太子登龙位上， 他的名儿万古扬！"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "困龙思想长江浪，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "虎落平阳想奔山冈。"
        },
        {
          "character": "徐延昭",
          "type": "快二黄二六板",
          "text": "国太思来国太想，"
        },
        {
          "character": "杨波",
          "type": "快二黄二六板",
          "text": "谁是忠良哪个是奸党？"
        },
        {
          "character": "李艳妃",
          "type": "快二黄二六板",
          "text": "忠良本是徐、杨将， 奸党就是我父李良。 二卿不把国来掌，"
        },
        {
          "character": "李艳妃",
          "type": "二黄摇板",
          "text": "哀家跪死在昭阳！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "铜锤一举王请上，"
        },
        {
          "character": "杨波",
          "type": "二黄摇唱",
          "text": "老杨波搀扶起定国王。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "回头来奏一道太平表章： 老杨波颁来了众家儿郎。"
        },
        {
          "character": "李艳妃",
          "type": "二黄摇板",
          "text": "听说是杨波颁兵到， 不由哀家喜眉梢。 太子付与小姐抱，"
        },
        {
          "character": "徐小姐",
          "type": "二黄摇板",
          "text": "双手付与老年高。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "用手接过大明后，"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "你保幼主坐龙楼。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "用手接过龙一条， 两眼睁睁把臣瞧。 莫不是嫌臣官卑小？ 趁此机会讨封号。 站立宫门生计巧，"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "我浑身上下似水浇，难以保朝！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "大人不必生计巧， 你的心事某猜着。 莫不是保幼主你嫌官小？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "是与不是？"
        },
        {
          "character": "徐延昭、杨波",
          "type": "同笑",
          "text": "哈哈哈哈……"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "国太！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
