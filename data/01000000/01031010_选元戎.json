  "plot": "鲁国公程咬金，唐之元勋也。热心任事，不避艰难，出入戎马之中，往往化险为夷，太宗尝称为福将，甚敬\n礼之。驸马秦怀玉，领兵平蛮，程咬金亦从征焉。初次交兵，大获全胜，迨深入重地，被蛮邦四面兜围，百\n计不得出，战又不利。秦怀玉无可如何，遣将突围求救。屡盼不到。秦怀玉焦急万状，程咬金愿亲自一行，\n遂冒险偷出敌垒，飞驰至京，朝见太宗，陈奏被围之故，请速发救兵。太宗以元戎实难其选，一班开国功臣，\n均已凋谢，后生小子，鲜有经济才，不能胜任，因此迟疑未定。程咬金言之再三，太宗终属踌躇。程咬金\n忿极，欲以身报国，撞死阶前。太宗急止之，立即准奏，问诸大臣何人可掌帅印？詹龙以弟詹虎对，程咬金\n即面斥之，请太宗亲临校场选择。盖程咬金属意秦怀玉之子秦英，智勇俱备，为后起之俊杰。太宗命与詹虎\n比武，先试力，秦英强而詹虎弱，后试刀枪，詹虎又不能支持，数合之中，詹虎为秦英所刺，遂至性命不保，\n而元戎于是乎选定矣。秦英乃统率三军，继续启行，尽歼敌虏，凯歌回朝。",
  "notes": "此系丑角唱工正剧，非名艺员不能见长。去冬在北京睹剧，七岁丑与谭富英合串，并皆佳妙。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "程咬金",
          "type": "内西皮导板",
          "text": "匹马单身离边疆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "西皮慢板",
          "text": "程咬金在马上自己思量。 都只为漠利沙兴兵反上， 有驸马秦怀玉去平反王。 怎奈那苗蛮贼兵多将广， 将驸马困至在沙漠战场。 在前番我也曾搬请兵将， 唐天子听谗言压住了本章。 无奈何我单身，"
        },
        {
          "character": "程咬金",
          "type": "西皮二六板",
          "text": "把边关闯， 不分昼夜转还乡。 此一番上殿把本上， 花言，"
        },
        {
          "character": "程咬金",
          "type": "西皮快板",
          "text": "巧言打动君王。 但愿我主龙恩放， 急速发兵救忠良。 急把苗蛮来扫荡， 驸马早日转回朝堂。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老夫程咬金，大唐驾前为臣，官拜鲁国公之职。只因漠利沙兴兵造反，圣上命 驸马秦怀玉挂帅，老夫一同前去征剿，不料漠利沙国王，联合苗蛮兵将，将驸 马困在边疆。一连三载，不能还朝，眼见得不能生还。我想我与秦二哥，在贾 家楼前结拜，亲同骨肉，倘若怀玉有个好歹，叫我程咬金怎能对得过我那秦二 哥。是我情急无奈，单人独骑，闯出重围，回转朝来，搬兵求救。但愿我主， 速速发兵，搭救忠良之后。看天色不早，就此马上加鞭。"
        },
        {
          "character": "程咬金",
          "type": "西皮摇板",
          "text": "贾家楼前曾结拜， 我与秦二哥同心怀。 怀玉被困边疆外， 一连三载未回来。 匹马单身离边塞， 搭救忠良理应该。 加鞭催马阳关外， 但愿我主早把兵排。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四朝臣同上。"
        },
        {
          "character": "房玄龄",
          "type": "念",
          "text": "位列上中下，"
        },
        {
          "character": "詹龙",
          "type": "念",
          "text": "才分天地人。"
        },
        {
          "character": "朝臣丙",
          "type": "念",
          "text": "五行生父子，"
        },
        {
          "character": "朝臣丁",
          "type": "念",
          "text": "八卦定君臣。"
        },
        {
          "character": "房玄龄",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "三朝臣",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "房玄龄",
          "type": "白",
          "text": "吾主临朝，不免在此伺候。"
        },
        {
          "character": "四朝臣",
          "type": "同白",
          "text": "香烟缭绕，圣驾来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四朝臣同下。"
        },
        {
          "character": "唐王",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二内侍引唐王同上。"
        },
        {
          "character": "唐王",
          "type": "西皮慢板",
          "text": "老王爷坐江山河清海晏， 普天下众黎民快乐安然。 各国中众番王齐把贡献， 君有道民安乐共庆丰年。 都只为漠利沙兴兵造反， 命驸马秦怀玉去定边关。 又谁知小苗蛮鬼计奸险， 将驸马围疆场不能回还。 孤朝中无勇将救他回转， 这件事倒叫孤常挂心间。 内侍臣摆銮驾九龙口站，"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "见了那众公卿细论根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "房玄龄上。"
        },
        {
          "character": "房玄龄",
          "type": "白",
          "text": "臣房玄龄见驾，吾皇万岁。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "卿家平身。上殿有何本奏？"
        },
        {
          "character": "房玄龄",
          "type": "白",
          "text": "今有鲁国公程，打从边关而来，在午门候旨。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "哦，程皇兄回来了。卿家替孤传旨，宣鲁国公上殿。"
        },
        {
          "character": "房玄龄",
          "type": "白",
          "text": "领旨。 万岁有旨：宣鲁国公上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "房玄龄下。"
        },
        {
          "character": "程咬金",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "忙将沙漠事，启奏圣明君。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣程咬金见驾，我主万岁。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "爱卿平身。赐座。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "老皇兄打从边关而来，一路多受风霜之苦，身体可曾康健？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣深受国恩，当效犬马之劳。有何德能，敢劳我主垂问。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "老皇兄此番回朝，但不知沙漠之事如何？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我主容奏。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣启万岁：老臣随同驸马秦怀玉征剿漠利沙，一连三载，各有胜败。那番帅看 我朝兵强将勇，他就联合了苗蛮的兵将，与我兵抵抗，彼众我寡，一时失机， 我军即被他围困在铁蒙山下，万分危急。那时老臣屡次乞求我主发兵帮助，可 总不见到来。也是老臣万般无奈，舍死忘生，闯出重围，转回朝来，要求兵帮 助，万岁务要恩准臣本，速速救驸马回朝要紧。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "孤王早有此意，只是我朝开国老臣大半凋谢，后起无人，不能挂帅，也是枉然。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "程咬金",
          "type": "西皮原板",
          "text": "程知节在金殿把本奏定， 尊一声万岁爷细听分明： 有驸马困至在沙漠边境， 兵又微将又寡不能回程。 此时间但自是发兵要紧， 说什么我朝中无有能人。 说什么此时间无人挂印， 说什么开国臣殂谢凋零。 秦怀玉并不是别人之后， 难道说我主爷不念功臣。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "皇兄不必把本伸， 无有统帅怎发兵。"
        },
        {
          "character": "程咬金",
          "type": "西皮摇板",
          "text": "万岁不肯把兵进， 倒叫老程无计行。 千言万语他不允， 忽有一计上在心。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣启万岁：此番老臣回朝，一来是要请万岁发兵，搭救驸马回朝。二来还有一 桩机密大事启奏。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "皇兄当面奏来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣年迈，眼花耳聋，要万岁请下龙书案来，老臣细细面奏。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "如此待孤离位就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐王下位。程咬金拉唐王玉带。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣此番不顾生死，回朝搬兵，诚非容易，万岁只是不肯发兵。既然如此，老 臣在朝即不能奉君，回至边关也无颜见那秦怀玉。我若大年纪，活也活够啦。 也罢，就碰死殿角，以报圣恩，就完啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金欲撞死。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "老皇兄休寻短见，寡人发兵就是。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "圣上发兵了？"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "发兵就是了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我也不死啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐王、程咬金同坐。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "虽然发兵，但是无人挂帅，也是枉然。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "想我朝开国以来，文臣如云，战将如雨。现在虽然大半殂谢，这将门之后，当 不乏人，驸马之子秦英也就不凡。万岁何不将朝中大臣宣上殿来，就开科取士， 谁能考得武状元，就叫谁挂印为帅。叫他们各舒己见，岂不是好。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "内侍，宣众位公卿上殿。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "众公卿上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四朝臣同上。"
        },
        {
          "character": "四朝臣",
          "type": "同白",
          "text": "臣等参见万岁。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "四朝臣",
          "type": "同白",
          "text": "万万岁。将臣宣上殿来，有何国事议论？"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "今有驸马秦怀玉被困沙漠，鲁国公回朝搬兵，无人挂帅。孤欲开科取士，考得 武状元，就叫他挂印。众卿可知这功臣之后，可有智勇之人，一一奏来。"
        },
        {
          "character": "詹龙",
          "type": "白",
          "text": "臣启万岁，臣有一胞弟，名唤詹虎，在家习学刀马，勇猛无敌，可以取中武状 元。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "空口无凭，不足为信，必须万岁当面考试，方足为凭。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "就命众卿，张贴榜文，叫那天下举子，前来应考便了。"
        },
        {
          "character": "四朝臣",
          "type": "同白",
          "text": "臣等遵命。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "内侍，退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "秦英",
          "type": "内白",
          "text": "可喜呀，可喜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦英上。"
        },
        {
          "character": "秦英",
          "type": "西皮摇板",
          "text": "时才家院一声禀， 四门之上粘榜文， 考取状元挂帅印， 即刻领兵把贼平。"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "俺，秦英。时才家院报到，鲁国公上殿奏本，请万岁发兵，搭救我父帅回朝。 只因朝中无人挂帅，万岁要开科取士，若有能人，取中状元，即叫他挂帅，征 剿苗蛮。一听此言，好不欢乐人也。"
        },
        {
          "character": "秦英",
          "type": "西皮摇板",
          "text": "皓月久被云遮掩， 一朝云散见青天。 英雄要把经纶展， 准备校场夺状元。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦英下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四童同上。"
        },
        {
          "character": "四童",
          "type": "同念",
          "text": "万岁开科取士，要展战策兵机。"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "三童",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "圣上开科，取中武状元，我等一同前去赴考。"
        },
        {
          "character": "三童",
          "type": "同白",
          "text": "大家一齐前去。"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "我等须要先见过程爷爷，才是正理。"
        },
        {
          "character": "三童",
          "type": "同白",
          "text": "好，一同前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四童同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四龙套引詹龙同上。四龙套同下，院子迎上。"
        },
        {
          "character": "詹龙",
          "type": "白",
          "text": "来，有请你二老爷。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "遵命。 有请二老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "詹虎上。"
        },
        {
          "character": "詹虎",
          "type": "念",
          "text": "膂力无穷性刚强，爱习武艺学刀枪。"
        },
        {
          "character": "詹虎",
          "type": "白",
          "text": "参见兄长。"
        },
        {
