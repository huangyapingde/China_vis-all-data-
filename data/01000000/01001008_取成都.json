{
  "script_id": "01001008",
  "title": "取成都",
  "alias": [
    "石伏岩"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘璋",
      "hangdang": "老生"
    },
    {
      "name": "刘玉",
      "hangdang": "小生"
    },
    {
      "name": "王累",
      "hangdang": "老丑"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "汉末，刘璋为刘备所困，求援于汉中张鲁。张鲁遣马超救之，不料马超至葭萌关，竟降刘备而功刘璋。刘璋\n不得已，开城降刘备。降见时，刘璋诘之曰：当日以成都让贤弟，却之再四；今日兴兵至此，意欲何为？刘\n备语塞，诸葛亮代答曰：吾主乃不得已而为之。利之所在，虽谊属同宗，情同骨肉，亦兵戎相见。刘备逼刘\n璋交印后自领益州牧。",
  "notes": "汪大头善唱此剧，声调高透，神情周到。临行时，唱二六板一段，悲歌慷慨，韵节苍凉，直欲声碎垂壶，天\n生一副好歌喉，非他伶所可望其项背也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，刘璋上。"
        },
        {
          "character": "刘璋",
          "type": "引子",
          "text": "驾坐西川，恨张松，归顺桃园。"
        },
        {
          "character": "刘璋",
          "type": "念",
          "text": "君为民爱，民为国愁。忧国忧民，何日罢休？"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "孤，姓刘名璋，字季玉。坐镇西川一带等处。可恨同宗刘备，带领人马，夺取 西川。孤在张鲁王驾前，聘请一将，名唤马超，此人有万夫不当之勇。孤命他 镇守葭萌关，前者与桃园弟兄交战，也曾命探子前去哨探，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启禀大王：马超降顺刘备，带领人马，夺取成都。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "忽听探马报一声， 胆大的马超降他人。 内臣摆驾敌楼进，"
        },
        {
          "character": "刘玉",
          "type": "内白",
          "text": "儿臣有本启奏。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "哦，"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "王儿上殿问分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘玉上。"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "千言万语父不信， 一心要做仁义人。 刘玉正在为难处， 见了父王说分明。"
        },
        {
          "character": "刘玉",
          "type": "白",
          "text": "儿臣见驾，父王千岁。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "王儿平身。"
        },
        {
          "character": "刘玉",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "刘玉",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "王儿上殿有何本奏？"
        },
        {
          "character": "刘玉",
          "type": "白",
          "text": "启奏父王，马超带领人马，夺取成都。父王为何坐视不理？"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "非是孤坐视不理，我想成都，兵微将寡，将这西川让与刘备就是。"
        },
        {
          "character": "刘玉",
          "type": "白",
          "text": "父王吓！"
        },
        {
          "character": "刘玉",
          "type": "西皮慢板",
          "text": "父王做事欠思忖， 细听儿臣说分明： 曹操杀他全家命， 不报冤仇岂甘心？ 儿臣敌楼把贼问， 一战交锋把功成。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "刘璋",
          "type": "西皮慢板",
          "text": "王儿奏本欠思论， 哪有能将去挡贼兵？ 孤王心中只把张松恨， 地理图大不该献与他人。 老严颜在巴州早已归顺， 张任不降命归阴。 刘备、孔明把城进， 大胆马超降他人。 孤欲开城将贼问， 满朝文武共起降心。 左思右想心不定， 孤倒作了进退两难人。"
        },
        {
          "character": "刘玉",
          "type": "西皮快板",
          "text": "父王说话不必惊， 细听儿臣奏分明： 刘备纵有千员将， 不让西川又怎生？"
        },
        {
          "character": "刘璋",
          "type": "西皮快板",
          "text": "刘备仁义顺天命， 诸葛贤能似陈平。 孤把好言对他论， 难道不念同宗人。"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "君臣踌躇无计定，"
        },
        {
          "character": "王累",
          "type": "内白",
          "text": "千岁等着，王累有本启奏。"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "朝房又来一老臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王累上。"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "西川人马乱纷纷， 忙上银安奏主君。"
        },
        {
          "character": "王累",
          "type": "白",
          "text": "王累见驾，愿大王千岁。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "王累",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "王累",
          "type": "白",
          "text": "启奏大王，马超降了刘备，带领人马，前来夺取成都，大王何以坐视不理？"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "孤与王儿，正为此事忧闷，何为坐视不理？"
        },
        {
          "character": "刘玉",
          "type": "白",
          "text": "儿臣敌楼答话。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "何人保驾？"
        },
        {
          "character": "王累",
          "type": "白",
          "text": "老臣保驾。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "卿家保驾，孤不忧也。"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "王儿敌楼把贼问， 大事全仗王爱卿。 四门之人安排定， 休教那马超进都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘璋下。"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "银安殿领了父王命，"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "老臣保驾随后跟。"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "卿家带路敌楼进，"
        },
        {
          "character": "王累",
          "type": "西皮快板",
          "text": "看看来的哪路兵？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘玉、王累同上城。四白龙套同上，马超上。"
        },
        {
          "character": "马超",
          "type": "西皮摇板",
          "text": "某奉军师将领遣， 打马来在都城边。 快叫刘璋把城献， 若少迟延杀进关。"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "耳旁听得人马喊，"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "只见马超立阵前。"
        },
        {
          "character": "马超",
          "type": "西皮摇板",
          "text": "城上不见刘璋面， 你是何人把话言？"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "小王刘玉掌宫殿，"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "老爷王累保驾官。"
        },
        {
          "character": "马超",
          "type": "西皮摇板",
          "text": "快叫刘璋把城献， 倘若迟延后悔难。"
        },
        {
          "character": "刘玉",
          "type": "西皮摇板",
          "text": "你降刘备该问斩，"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "卖国求荣狗肺男！"
        },
        {
          "character": "马超",
          "type": "西皮摇板",
          "text": "小子说话太鲁莽， 气的老爷怒冲冠！ 用手搭上雕翎箭， 管叫小子丧黄泉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超射死刘玉。"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "一见千岁丧了命， 滚木擂石往下沉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超、四白龙套同下。"
        },
        {
          "character": "王累",
          "type": "白",
          "text": "众将小心把守城池，待我报与千岁知道。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "呵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王累下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马超、四白龙套同上。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "且住，看那王累打下滚木擂石，不是快马如飞，险遭不测。临行之时，军师言 道，刘璋最爱百姓。不免拆毁民房，放火焚烧。 呔，众将官，四下放起火来！"
        },
        {
          "character": "四白龙套",
          "type": "同白",
          "text": "喝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超、四白龙套同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "刘璋",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘璋上。"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "适才王累进宫报， 王儿敌楼赴阴曹。 耳边厢又听得放火炮， 想必是马超贼放火将孤的民房烧。 内侍臣摆驾上城道，"
        },
        {
          "character": "刘璋",
          "type": "哭",
          "text": "王儿吓，"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "那边厢又来了贼马超。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超、四白龙套同上。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "蜀主请了。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "刘璋",
          "type": "快西皮摇板",
          "text": "见马超不由孤心中刀搅， 叫一声马孟起细听根苗： 孤王的待你是哪些不好， 你那里降刘备所为哪条？"
        },
        {
          "character": "马超",
          "type": "快西皮摇板",
          "text": "我这里降刘备也是正道， 我劝你让成都免动枪刀。"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "汉刘备他不过封你官职不小， 孤与你分疆土手足相交。"
        },
        {
          "character": "马超",
          "type": "西皮摇板",
          "text": "叫三军拆民房齐放火炮， 杀进城一个个性命难逃！"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "一言恼怒了贼马超， 放火就把民房烧。"
        },
        {
          "character": "刘璋",
          "type": "哭板",
          "text": "只听得众子民苦苦哀告， 子民吓，"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "我不让成都命难逃。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "马将军，你将人马暂退一箭之地，孤将成都让与你君臣就是了。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "须要言而有信。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "岂肯失信于你？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "众将官，将人马暂退一箭之地。"
        },
        {
          "character": "四白龙套",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "好贼子吓！"
        },
        {
          "character": "刘璋",
          "type": "慢西皮摇板",
          "text": "这也是成都的兵微将少， 眼见得锦绣春山付与水漂。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "众将官开城。"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "尊一声千岁慢开城，"
        },
        {
          "character": "王累",
          "type": "白",
          "text": "主公此城开不得！"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "怎样开不得？"
        },
        {
          "character": "王累",
          "type": "白",
          "text": "开城不要紧，我主江山有失。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "卿家你来看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "后场放火。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "四面俱是火起，为孤一人，岂可连累好百姓？"
        },
        {
          "character": "王累",
          "type": "西皮摇板",
          "text": "懦弱之人怎为君？ 千言万语劝不醒， 不如碰死在都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王累撞死。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "哎吓，"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "一见王卿丧了命， 去了擎天柱一根。"
        },
        {
          "character": "刘璋",
          "type": "哭板",
          "text": "但愿你魂灵归仙境，"
        },
        {
          "character": "刘璋",
          "type": "哭",
          "text": "王卿吓，"
        },
        {
          "character": "刘璋",
          "type": "西皮摇板",
          "text": "凌烟阁上早标名。"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "众将官开城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘璋下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖急急风〗。马超领四白龙套同上，同进城。黄忠、严颜、魏延、赵云同上。刘璋上，坐城外。黄忠、严"
        },
        {
          "character": null,
          "type": "text",
          "text": "颜、魏延、赵云同进城。四红龙套同上，车夫推诸葛亮同上，进城。刘备上。）"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，宗兄！"
        },
        {
          "character": "刘璋",
          "type": "白",
          "text": "吓，宗兄来了！"
        },
        {
          "character": "刘备",
          "type": "白",
