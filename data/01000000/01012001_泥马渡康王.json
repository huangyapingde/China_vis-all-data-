          "character": null,
          "type": "stage",
          "text": "兀术、二王爷、四太监、四大铠、四侍女同上。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "撒下围场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同喝。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "吓，御弟！"
        },
        {
          "character": "二王爷",
          "type": "同白",
          "text": "皇兄！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "你我虽享一国之荣，究竟荒山沙漠之地，万不及中原繁华。但愿早得中原，方 为万幸。"
        },
        {
          "character": "二王爷",
          "type": "同白",
          "text": "皇兄洪福齐天，中原不久垂手而得矣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同笑。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "吩咐起射。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四侍女同允。起鼓。众人各射。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好！"
        },
        {
          "character": "兀术",
          "type": "念",
          "text": "弓开如满月，箭法似寒星。狐鬼难逃避，飞鸿难纵横。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好箭法也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "吩咐操枪。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "操枪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同操枪。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "兀术",
          "type": "念",
          "text": "儿郎雄似虎，枪锋铁甲穿。舞动梅花锦，翩翩可仗先。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好枪法。哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上，过场，王爷乙追下，追虎形同上，打死虎形。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "御弟打虎之能，不弱卞庄、存孝也！"
        },
        {
          "character": "王爷乙",
          "type": "白",
          "text": "皇兄夸奖。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "侍女们！"
        },
        {
          "character": "四侍女",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "歌唱一回。"
        },
        {
          "character": "四侍女",
          "type": "同寄生草",
          "text": "三阳开泰和风至， 绿柳荫子规啼。 荒郊外空中飘舞， 飞柳絮，转过小桥西。 见几个佳人闲游戏， 见一个牧童儿头戴蓑笠，身披蓑衣，跨青牛，口吹笛。 借问声，杏花村走哪条路儿去， 牧童回言道，转过湾来芳草地。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好。回营领赏。"
        },
        {
          "character": "四侍女",
          "type": "同白",
          "text": "谢千岁！"
        },
        {
          "character": "赵构",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵构上。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "父王在上，儿臣拜见！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "二位叔父！"
        },
        {
          "character": "二王爷",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "皇儿方才坠马，怎能痊愈？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔孝上。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "儿臣此时，不过右腿疼痛，多亏崔孝槌把一回。似已痊愈。营中寂寞，特到驾 前呈欢。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "难得皇儿如此孝心。 来，赏崔孝黄金一锭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监允。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "摆宴。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "儿臣把盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "过江南牌。童儿变鸟声。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "赵构，此时不走，还有什么时候！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "赵构不走，待等何时！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哎。这是什么鸟声？孤从未听过。 吓，皇儿，倒像你南人说话一般。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "启奏父王：这是怪鸟，名叫枭鹢鸟，儿臣中原常有，鸣则不祥。况且能效人言， 他在那里骂父王。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "他骂孤什么？"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "儿臣不敢奏。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "此是鸟声，非儿之罪。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "谢父王。他骂父王“骚鸡狗，绝了你的咽喉，断了你的首”。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "唔哇哇！这孽畜十分可恶。看弓箭来过！"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "父王赐与儿臣射罢。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "也罢。看皇儿弓箭如何。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "谢父王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵构背供。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "神圣在上：倘若上苍不绝宋室之后，箭中鸟身，引孤逃命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵构射。童儿接箭下。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "带箭而逃！"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "带马追赶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔孝允。赵构追下，崔孝下。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "皇儿不要追赶！ 哎哎！这孩子，一枝箭能值几何！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同喊。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "众军为何喧嚷？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启千岁：殿下踹营而过，众军回避不及，故尔喧嚷。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "原来如此。吩咐禁止喧嚷。两厢闪开，任凭殿下出入。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。众人内同喊。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "谁敢违令喧嚷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启千岁：殿下马骤如飞，往南而去。随行军士，恐其跌落，拦住马头，小千岁 把他们斩首了！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "吓，为何斩本营将士？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "看他有回南之意。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哎呀！看此子今日变颜悦色，比旧不同，事有可疑。 军士们！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "随孤追赶。不可伤他性命，违令者斩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。兀术下。"
        },
        {
          "character": "王爷甲",
          "type": "白",
          "text": "御弟，"
        },
        {
          "character": "王爷乙",
          "type": "白",
          "text": "皇兄。"
        },
        {
          "character": "王爷甲",
          "type": "白",
          "text": "看昌平王把那个南蛮，当作掌上明珠，只怕是栽林养虎。"
        },
        {
          "character": "王爷乙",
          "type": "白",
          "text": "虎大伤人。"
        },
        {
          "character": "二王爷",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "二王爷",
          "type": "同白",
          "text": "你我一同前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二王爷同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵构、崔孝同上。兀术、二王爷、四太监、四大铠同上。赵构下。众人同追下。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "吓崔孝，你主人莫非有回南之意？"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "小人不知。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "一定是你的诡计。赶他回来，将你碎尸万段！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兀术下。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "哎吓，想我骨软筋衰，不能持戈，扶保乾坤。但愿皇天默佑，保主重兴，我当 尽忠一死，岂受千刀！哎吓，圣上吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔孝自刎，下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵构上，众人同追上。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "吓，看他头也不回，果然心变。也罢，待孤射他一箭。且住，不要伤孤爱子， 待孤射他马腿便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兀术射。赵构跌下。马童暗上，牵马，赵构上马，下。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "何人送马与他，带来见孤。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "并无人影。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "追上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵构上，众人同上。"
        },
        {
          "character": "赵构",
          "type": "白",
          "text": "哎呀，前有长江挡住，后有敌国追兵。宁做长江之鬼，不为牛犬之儿。俺赵构 今日死也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵构跳水，下。兀术上。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "皇儿何在？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "投水而亡。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "怎生得渡？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "满江大雾，不见人影。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "闪开了。 哎吓。皇儿吓！"
        },
        {
          "character": "兀术",
          "type": "西皮摇板",
          "text": "一霎时狂风起大雾满天， 盼不见孤皇儿好不惨然。"
        },
        {
          "character": "众人",
          "type": "同西皮摇板",
          "text": "莫不是他国中另有机变，"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "来，速备战船追赶！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "并无船只。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "他是怎生得渡？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "他是单人独马下江，并无船只。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哎呀儿吓！"
        },
        {
          "character": "兀术",
          "type": "西皮摇板",
          "text": "必定是遭风浪命丧九泉。 没有那擎天手不得回转，"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "兀术",
          "type": "西皮摇板",
          "text": "恨杀那崔孝贼奸计显然。 害得孤父子们心分腹变， 害得孤被人谈不识愚贤。 孤与你东宫位归期不远， 又何必舍性命误入江边。 老天爷保佑孤父子重见， 哎儿吓！ 那时节满炉香答谢上天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二王爷同上。"
        },
        {
          "character": "二王爷",
          "type": "同白",
          "text": "马来！"
        },
        {
          "character": "王爷甲",
          "type": "西皮摇板",
          "text": "闻听得小康王落水不见，"
        },
        {
          "character": "二王爷",
          "type": "同白",
          "text": "皇兄。"
        },
        {
          "character": "王爷乙",
          "type": "西皮摇板",
          "text": "何必把别家子挂在心间。"
        },
        {
          "character": "王爷甲",
          "type": "西皮摇板",
          "text": "请回归把胸中英才旋转，"
        },
        {
          "character": "王爷乙",
          "type": "西皮摇板",
          "text": "大丈夫何须被儿女为牵。"
        },
        {
          "character": "兀术",
          "type": "西皮摇板",
          "text": "听他言不由孤羞愧满面，"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "人马收回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "兀术",
          "type": "西皮摇板",
          "text": "吞着声忍着气珠泪涟涟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}