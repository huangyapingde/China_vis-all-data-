{
  "script_id": "01012001",
  "title": "泥马渡康王",
  "alias": [
    "五国城"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "崔孝",
      "hangdang": "末"
    },
    {
      "name": "赵构",
      "hangdang": "小生"
    },
    {
      "name": "兀术",
      "hangdang": "净"
    },
    {
      "name": "宋徽宗",
      "hangdang": "外"
    },
    {
      "name": "宋钦宗",
      "hangdang": "老生"
    },
    {
      "name": "崔府君",
      "hangdang": "外"
    },
    {
      "name": "王爷甲",
      "hangdang": "副净"
    },
    {
      "name": "王爷乙",
      "hangdang": "老生"
    },
    {
      "name": "马童",
      "hangdang": "丑"
    }
  ],
  "plot": "是剧出《精忠说岳》第十九至二十回，即演“崔总兵进衣传血诏”、“金营神鸟引真主，夹江泥马渡康王”\n三句之事实。《说岳》称，徽、钦二帝既北迁，被囚于五国城，惨苦万状，有前代州总兵，陷落金邦十八年\n现为金营马医之崔孝，特具羊裘二袭，牛羊脯若干斤，送往五国城。乘机令钦宗修下血诏一通，夹带出城，\n密递康王，令其遁归中原即位，以承先王祭祀。康王既得诏，一日，忽有神鸟做人语鸣曰：“赵构赵构，此\n时不走，还等什么时候”。康王遂借射鸟为名，一路向南冲营而出，至夹江边，兀术兵已追至，幸得神马力，\n引之渡江出险，乃赴南都即帝位。",
  "notes": "此剧以小达子为最擅演。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崔孝上。"
        },
        {
          "character": "崔孝",
          "type": "念",
          "text": "从龙披铠报君恩，惨遇遮天蔽日云。有志擎天无路入，英雄空自泣长城。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "老汉，崔孝。昔为雁门总兵，后遭贬谪，流于北国，医兽为生。近闻徽、钦二 圣，被囚五国城中，苦不可言。是我备得羊裘二件，前来看看我那仁主，以尽 为臣之道。正是："
        },
        {
          "character": "崔孝",
          "type": "念",
          "text": "国家颠沛随天运，空使孤臣泪满襟。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "来此已是。 吓。哪位爷在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小番同上。"
        },
        {
          "character": "二小番",
          "type": "同念",
          "text": "奉了狼主命，看守五国城。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "二位。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "吓，原来是崔老儿。咱们这里又没有马医，你来干什么？"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "请问二位，闻得我朝君王，被囚在此，可是真否？"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "是真。你问他怎么？"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "老汉离家日久，特来问问家乡光景。求二位爷方便一二，放我进去。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "呸，胡说！这是南朝两个皇帝，被俺狼主，囚在此地。命咱们提枪喝号，日夜 防守，岂容闲人出入么。不看你年老，定要拿你问罪。不要多说，做你的生意 去罢！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "二位吓！"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "可怜我离家乡二十余载， 到如今没有个音信往来。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "他是个皇帝，怎能够替你走家信，你在哪里住？"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "家住在崔家庄汴梁城外， 与君王叙叙乡谈谈心怀。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "他是君，你是民，没有什么攀谈！"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "他是君我是民乡亲有爱， 哎呀，二位爷吓！ 可怜他失国君死无埋葬。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "你苦苦要见，敢则有什么夹带么？"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "我带来羊皮袄与他遮盖， 权当作祭君王烧奠坟台。"
        },
        {
          "character": "小番甲",
          "type": "白",
          "text": "我的哥。"
        },
        {
          "character": "小番乙",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "小番甲",
          "type": "白",
          "text": "看这老头儿哭得可怜，他若做官，倒是个忠臣。"
        },
        {
          "character": "小番乙",
          "type": "白",
          "text": "他在咱们这里，二十多年，谅他没有什么奸诈，咱们放他进去罢！"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "老头儿。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "我们放你进去见面，你就要出来。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "是。就出来的。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "咱们进去喝酒，请吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小番同下。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "我那万岁在哪里？"
        },
        {
          "character": "宋徽宗、宋钦宗",
          "type": "内同白",
          "text": "苦吓！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "圣上吓！"
        },
        {
          "character": "宋徽宗",
          "type": "内二黄导板",
          "text": "忽听得呼万岁心中自揣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋徽宗上，宋钦宗上。"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "老天吓！"
        },
        {
          "character": "宋钦宗",
          "type": "二黄摇板",
          "text": "沙漠地哪还有贤臣到来！"
        },
        {
          "character": "宋徽宗",
          "type": "二黄摇板",
          "text": "心恍惚睁双眼将他观看，"
        },
        {
          "character": "宋钦宗",
          "type": "二黄摇板",
          "text": "又只见一老臣跌跪尘埃。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "罪臣崔孝，昔为雁门总兵，遭了谪贬，流于北国。今闻二主被困，臣带得羊裘 二件，前来探望。今见陛下受此凌辱，使臣寸断肝肠。但不知老王陛下何由至 此？"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "哎呀，卿家吓！这是寡人之错，误听奸贼专权。金兵起叛，被张邦昌等，蔽日 欺天，隐瞒不漏，直等金兵临城，朕才知觉。欲待开城迎敌，怎奈孤兵微将寡， 四路不通消息。只得听从奸言，命九殿下出城求和，被金人刺死。后命康王 过江，奸贼诓孤父子，囚与此地。不想太祖遗业，尽化灰尘。不但社稷倾危， 亦且断嗣灭后，说来好不痛心也。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "吓！康王殿下，也在此么？"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "闻听他已被金贼收留膝下矣。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "哎呀陛下吓！"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "听君言把我的忧心焦坏， 朝无主奸掌权怎把兵排！ 眼见得锦江山被贼所卖， 哎呀，万岁吓！ 怎得个栋梁臣扫尽狼烟。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "哎呀崔卿吓！"
        },
        {
          "character": "宋钦宗",
          "type": "二黄摇板",
          "text": "孤父子囚禁在沙漠所在， 小康王被贼哄自己痴呆。 难得你秉忠心单人入寨， 还望你搬救兵解此祸灾。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "陛下至此急难之时，罪臣粉身碎骨，理所当然！只是路途遥远，老臣骨软筋衰， 只恐无命归国，空劳君王盼望，如何是好？"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "这便怎么？"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "这……哦，有了！"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "卿有何计？"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "康王殿下，现在这本营营中。陛下可修诏书，待臣秘密投交殿下，叫他见机而 行，逃回中原，整顿大兵前来，迎救老王同陛下回国。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "此计甚好，待孤咬破指尖，扯下汗衫，草写血诏便了。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "哎呀，看陛下这等形衰，敢是饮食不足么？"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "崔卿吓！我父子在此，每日只有一粥充饥！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "唉，圣上吓！"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "可怜他九重尊如何忍耐， 每日里一餐粥饥饿难挨。 若取饭又恐怕出入有碍，"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "我只得割己肉急火煮来。 请陛下书写诏暂且等待， 有罪臣去取饭与主下怀。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "他们怎肯放你出入，还是带了诏书去罢！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "不妨。老臣在此二十余年，这些兵卒，俱已认识。陛下请写诏书。臣去就来。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "就要来吓！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔孝下。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "崔卿吓！"
        },
        {
          "character": "宋钦宗",
          "type": "二黄导板",
          "text": "有寡人修血诏珠泪满腮，"
        },
        {
          "character": "宋钦宗",
          "type": "二黄慢板",
          "text": "难得这老孤臣从空降来。 咬中指鲜血淋诏书写载，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋钦宗咬指。"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "皇儿，你、你好不疼痛也！"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "儿臣不痛。"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "十指连心，哪有不痛之理！"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "父王吓！"
        },
        {
          "character": "宋钦宗",
          "type": "二黄摇板",
          "text": "忍疼痛恐伤我父王心怀。 钦宗诏晓御弟飞马离塞， 回中原领人马早定兵灾。 老王爷同孤在五国城待， 似苏武啖毡雪倒卧尘埃。 太上皇锦江山今已损坏， 仗御弟整乾坤重理龙台。 老王爷和愚兄料难久待，"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "哎，御弟吓！"
        },
        {
          "character": "宋钦宗",
          "type": "二黄摇板",
          "text": "孤死期在目前魂掩泉台。 至阴曹听御弟颁师奏凯， 那时节瞭目心撒手去，永不挂心怀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔孝上。"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "索股儿割不上一斤一块， 充不了二主饥苦痛哀哉！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "陛下。诏书可曾修起？"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "修起好了。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "老臣烹得羊肉数片，与我主充饥。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "送与老王爷御用。"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "是。 老王爷请用。"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "哎。难得贤臣，如此忠心。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "崔卿，这样旷野之地，人烟全无，哪得有此汤水？"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "是老臣问金丁买来的。"
        },
        {
          "character": "宋徽宗、宋钦宗",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "皇儿，你也吃些。"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "儿臣怒气填胸，吞吃不下。"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "陛下暂且容忍。请问诏书上面，怎生区处？"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "哎呀崔卿吓！寡人千言万语，书之不尽。只是大宋江山，在此一举。卿家请上， 受寡人一拜！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "哎。老臣不敢！"
        },
        {
          "character": "宋钦宗",
          "type": "白",
          "text": "父王，看崔卿左手血淋淋，满脸疼痛之状，却是为何？"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "哦，崔卿，割股救我父子之饥。"
        },
        {
          "character": "宋徽宗、宋钦宗",
          "type": "同白",
          "text": "崔卿取手过来。"
        },
        {
          "character": "宋徽宗、宋钦宗",
          "type": "同哭",
          "text": "哎呀，崔卿吓！"
        },
        {
          "character": "宋徽宗",
          "type": "二黄摇板",
          "text": "只见他割了股鲜血尚在，"
        },
        {
          "character": "宋钦宗",
          "type": "二黄摇板",
          "text": "不由人悲切切感痛伤怀。"
        },
        {
          "character": "宋徽宗",
          "type": "二黄摇板",
          "text": "似这等忠良臣有谁比赛，"
        },
        {
          "character": "宋钦宗",
          "type": "二黄摇板",
          "text": "凌烟阁表芳名万古贤哉！"
        },
        {
          "character": "崔孝",
          "type": "白",
          "text": "陛下吓！"
        },
        {
          "character": "崔孝",
          "type": "二黄摇板",
          "text": "圣天子遭囚禁臣心伤坏， 纵粉身与碎骨也是应该。 请主公莫把这闲情挂碍， 有何言嘱老臣紧记心怀。"
        },
        {
          "character": "宋徽宗、宋钦宗",
          "type": "同二黄摇板",
          "text": "也无言也无语低头下拜，"
        },
        {
          "character": "宋徽宗",
          "type": "白",
          "text": "皇儿！"
        },
        {
          "character": "宋钦宗",
