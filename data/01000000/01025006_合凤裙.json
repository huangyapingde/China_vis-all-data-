{
  "script_id": "01025006",
  "title": "合凤裙",
  "alias": [
    "鸳鸯镜"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "吴小姐",
      "hangdang": "贴旦"
    },
    {
      "name": "刘公子",
      "hangdang": "小生"
    }
  ],
  "plot": "剧本所述，谓有吴、刘两姓，既订婚姻，吴为乾宅，刘为坤宅，至迎娶之日，刘氏女忽然卧病，令其弟乔装\n代嫁，及至花轿临门，吴氏子适有紧急差遣，随父他出，亦令其妹扮作新郎，为阿兄代表。一对假夫妻，竟\n实行交拜礼。合卺筵开，洞房春暖，两人本来面目，无可遮掩，互相惊异，然少年男女，未免有情，遂将错\n就错，以为天假之缘，缱绻终宵，订鸳盟于枕上焉。",
  "notes": "是剧系梆子调。二黄调中，向有《日月图》及《巧姻缘》两剧。唱口白口，虽各有别，其情节亦大致相似，\n无非从《今古奇观》小说中，《乱点鸳鸯谱》一事，脱胎而出。惟姓氏迥乎不同。\n按《合凤裙》一剧，向有全本，此系中间一段，事实虽不近情理，然于花旦戏中，亦极有趣味，尤堪发噱。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐上。"
        },
        {
          "character": "吴小姐",
          "type": "引子",
          "text": "清晨起来对菱花，蝴蝶双双闹窗纱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "启禀小姑娘：花轿到门了。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "可说是花轿到门了么？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "如此就将新人，搀进房来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "看丫鬟报道：花轿到门，已将我家新嫂嫂娶来了。我不免在绣阁等候便了。"
        },
        {
          "character": "吴小姐",
          "type": "梆子正板",
          "text": "时才间小丫鬟报了一声， 她说道我新嫂嫂娶到家门。 我只得在绣阁慢慢来等， 等候着她来时我看看新人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹牌子。丫鬟扶刘公子扮女装同上。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "丫鬟退下。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "待我将绣阁房门闭上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐关门。"
        },
        {
          "character": "吴小姐",
          "type": "梆子正板",
          "text": "我这里且把房门来掩， 陪伴着新嫂嫂坐在床前。 用手儿掀盖头仔细详看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐去盖头红巾。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "妙吓！"
        },
        {
          "character": "吴小姐",
          "type": "梆子正板",
          "text": "看她那美容颜亚赛天仙。 似这等美容颜人间罕见， 好一似月里嫦娥降下了凡。"
        },
        {
          "character": "刘公子",
          "type": "梆子流水板",
          "text": "来至在绣阁中偷眼观看， 这女子生的是赛过天仙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐看刘公子足背，以手比划，笑。"
        },
        {
          "character": "吴小姐",
          "type": "梆子流水板",
          "text": "她那里不住的将我来看， 一时间看得我面带羞惭。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "新嫂嫂，请来见礼。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "奴家还礼。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "好说。请问新嫂嫂，今年多大岁数了？"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "奴家二八一十六岁了。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "怎说是嫂嫂，今年二八一十六岁了？"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "如此说来，你倒比我家哥哥小上两岁。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "哦，我还比你家哥哥，小上两岁么？"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "小上两岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘公子两旁看。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "请问嫂嫂，看些什么？"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "奴家到此半日，为何不见你家哥哥，他往哪里去了？"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "嫂嫂，是你非知：只因朝中徐老千岁出京放粮，在此下马，我家哥哥奉了我家 爹爹之命，去往城中，办差去了。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "原来如此，但不知今晚回来不回来？"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "大概今晚是不回来的分儿多。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "你哥哥今晚若不回来，岂不耽误了奴家的好事么？"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "新嫂嫂不必忧烦，现有我家哥哥的靴帽蓝衫在此，待小妹扮做我家哥哥的模样， 陪伴嫂嫂，你看如何呀？"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "你住了罢！世界之上，只有男子配女郎，哪有女郎配女郎的道理？想你我二人， 俱是女流，此事是如何使得？"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "我说使得，就是使得。待我装扮起来。"
        },
        {
          "character": "吴小姐",
          "type": "梆子流水板",
          "text": "我这里忙取下头上钗环， 装作了我哥哥成就良缘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐入帐内换衣。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "妙吓！"
        },
        {
          "character": "刘公子",
          "type": "梆子流水板",
          "text": "小姑娘她生得真真好看， 她本是女儿家也要装男。 怕的是难逃今夜晚， 我只得假意儿来学痴颟。 将身儿且坐在绣阁里面， 等候了小姑娘再把话言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐扮男子出。"
        },
        {
          "character": "吴小姐",
          "type": "梆子原板",
          "text": "在头上戴定了方巾便帽， 在身上穿蓝衫腰系丝绦。 走上前便把那嫂嫂来叫， 我二人拜华堂凤友鸾交。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "嫂嫂，我二人同来拜天地呀！"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "此事是使不得的。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "我说使得，就是使得，你要来呀！"
        },
        {
          "character": "吴小姐",
          "type": "梆子原板",
          "text": "在绣阁打扮得男子一样， 有郎才合女貌果是一双。 走向前来把堂拜——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐作揖，刘公子作揖。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "嫂嫂，你那里怎样吓？"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "小姑娘，你是怎样吓？"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "我这里，是作揖呀！"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "我也是作揖。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "嗳，你要拜拜。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "我不会拜。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "难道你上轿的时节，你家母亲也不曾教导与你么？"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "我家母亲，并不曾教导与我。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "如此，待妹妹教导与你。这女儿家，要用手将鬓角一摸，再这么一摸，将袖儿 就是这样一摆，再用手这样一舞，这就是拜了。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "我倒学会了，用手一摸鬓角，再一摸，又这样一摆、两摆，一舞，这就是拜了。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "着吓，对了！"
        },
        {
          "character": "吴小姐",
          "type": "梆子原板",
          "text": "夫妻们同交拜成就鸳鸯。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "嫂嫂，你我一同安眠了罢！"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "这个……小姑娘先请，我随后就来了。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "你就要来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐走浪头，三次入帐。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "嫂嫂你来！"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "刘公子",
          "type": "梆子原板",
          "text": "小姑娘她扮作男子模样， 她叫我随同她共上牙床。 我若是在床上成了勾当——"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "嫂嫂你快快地来呀！"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "刘公子",
          "type": "梆子原板",
          "text": "还须要暂消停细作商量。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐出帐。"
        },
        {
          "character": "吴小姐",
          "type": "梆子原板",
          "text": "我这里出罗帏把话来讲， 叫一声新嫂嫂细听端详： 你与我同入那罗帏帐， 咱二人在牙床成就鸳鸯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴小姐扯刘公子，比划手势，刘公子遮掩三番，吴小姐入帐。"
        },
        {
          "character": "刘公子",
          "type": "梆子原板",
          "text": "无奈何我且把牙床来上， 我看她今夜晚是怎样下场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘公子入帐。拉牌子。吴小姐出帐子拔宝剑欲杀刘公子，刘公子急跪。"
        },
        {
          "character": "刘公子",
          "type": "梆子原板",
          "text": "我叫一声小姑娘，哭一声吴小姐， 哎呀呀，我的小姑娘吓！"
        },
        {
          "character": "吴小姐",
          "type": "梆子原板",
          "text": "时才把奴胆吓坏， 你为何假扮女裙钗？ 手执宝剑朝下砍——"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "小姑娘饶命吓！"
        },
        {
          "character": "吴小姐",
          "type": "梆子原板",
          "text": "你快快与我说明白。"
        },
        {
          "character": "刘公子",
          "type": "梆子原板",
          "text": "我本是前巷刘公子， 假扮裙钗到此来。 望求小姑娘将我放， 日后定要报恩来。"
        },
        {
          "character": "吴小姐",
          "type": "梆子原板",
          "text": "既然你是那刘公子， 为何改扮女裙钗？"
        },
        {
          "character": "刘公子",
          "type": "梆子原板",
          "text": "你哥哥要娶我的姐， 因此上替她扮裙钗。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "你且起来。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "多谢小姑娘。"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "此事本来是我家哥哥的不是，你今既到此地，已与奴家同床睡过，你叫我是怎 样见人？奴欲与你就此定下姻缘，不知你意下如何？"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "既蒙小姑娘搭救之恩，敢不遵命？"
        },
        {
          "character": "吴小姐",
          "type": "白",
          "text": "好！就在奴绣阁住下。明日命人送你回家，你要急速叫媒人前来提亲，才是正 理。"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "小生件件依从。正是："
        },
        {
          "character": "刘公子",
          "type": "念",
          "text": "男扮女来女扮男，"
        },
        {
          "character": "吴小姐",
          "type": "念",
          "text": "千里良缘一线牵。"
        },
        {
          "character": "刘公子",
          "type": "念",
          "text": "待等明朝回家转，"
        },
        {
          "character": "吴小姐",
          "type": "念",
          "text": "女貌郎才果一般！"
        },
        {
          "character": "刘公子",
          "type": "白",
          "text": "好一个“女貌郎才果一般”！请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹牌子。吴小姐、刘公子同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}