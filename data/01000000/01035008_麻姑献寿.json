    },
    {
      "name": "李铁拐",
      "hangdang": "净"
    },
    {
      "name": "吕洞宾",
      "hangdang": "老生"
    },
    {
      "name": "百花仙子",
      "hangdang": "旦"
    },
    {
      "name": "牡丹仙子",
      "hangdang": "旦"
    },
    {
      "name": "芍药仙子",
      "hangdang": "旦"
    },
    {
      "name": "海棠仙子",
      "hangdang": "旦"
    }
  ],
  "plot": "全剧大致谓某月某日，西池王母圣诞，一年一度蟠桃大会上，中八洞神仙无不齐临祝寿。百花、牡丹、芍药、\n海棠四仙子，往邀麻姑同赴瑶池祝寿。麻姑仙子因正在采取群花欲做百花酿，以备称觞上寿，故令四仙子\n先行，自己则一路寻采。寻至绛珠河畔觅得灵芝始归，预备酿成上献。既而李铁拐奉众仙之命，专往兜率宫\n李老君处乞题寿词，以便进祝。既而王母出场，即是蟠桃大会，瑶池开宴日矣。一班仙姑道长，换次进觞，\n次为麻姑献酒，王母命麻姑向众仙歌舞行酒，既又命玉女向园中摘取蟠桃，各赐一枚，尽欢而散。其祝寿行\n酒时之一段歌舞，颇悠扬可听，真有众仙同日咏霓裳之致。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小锣打。百花仙子、牡丹仙子、芍药仙子、海棠仙子同上。"
        },
        {
          "character": "百花仙子",
          "type": "念",
          "text": "云中化日东升浩，"
        },
        {
          "character": "牡丹仙子",
          "type": "念",
          "text": "紫霞飞雪瑞气飘。"
        },
        {
          "character": "芍药仙子",
          "type": "念",
          "text": "上苑齐献灵山宝，"
        },
        {
          "character": "海棠仙子",
          "type": "念",
          "text": "瑶池会上赴蟠桃。"
        },
        {
          "character": "百花仙子",
          "type": "白",
          "text": "我乃百花仙子是也。"
        },
        {
          "character": "牡丹仙子",
          "type": "白",
          "text": "我乃牡丹仙子是也。"
        },
        {
          "character": "芍药仙子",
          "type": "白",
          "text": "我乃芍药仙子是也。"
        },
        {
          "character": "海棠仙子",
          "type": "白",
          "text": "我乃海棠仙子是也。"
        },
        {
          "character": "百花仙子",
          "type": "白",
          "text": "众位仙子请了！"
        },
        {
          "character": "牡丹仙子、芍药仙子、海棠仙子",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "百花仙子",
          "type": "白",
          "text": "今日三月三日，金母寿诞之期，你我不免去寻麻姑仙子，一同前去上寿。"
        },
        {
          "character": "牡丹仙子、芍药仙子、海棠仙子",
          "type": "同白",
          "text": "如此甚好，请哪！"
        },
        {
          "character": "百花仙子",
          "type": "西皮摇板",
          "text": "各驾祥云往前进，"
        },
        {
          "character": "牡丹仙子、芍药仙子、海棠仙子",
          "type": "同西皮摇板",
          "text": "相请麻姑走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花仙子、牡丹仙子、芍药仙子、海棠仙子同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小跺头。麻姑上。"
        },
        {
          "character": "麻姑",
          "type": "西皮慢板",
          "text": "好景色艳阳天花林开放， 蓬莱岛众仙子齐集山岗。 每日里摘仙花酿成琼浆， 寿诞日叩金母长寿无疆。"
        },
        {
          "character": "麻姑",
          "type": "念",
          "text": "头上宝髻玉钗横，一只翠蝶梅花分。断红双脸长眉秀，绛唇一点樊素樱。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "我乃麻姑仙子是也。只因三月三日，金母寿诞之期，故而离座出得洞府，连日 采取百样花草，酿成美酒，也是与金母上寿。远远望见，众仙子来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花仙子、牡丹仙子、芍药仙子、海棠仙子同上。"
        },
        {
          "character": "百花仙子",
          "type": "西皮摇板",
          "text": "离却洞府到深山，"
        },
        {
          "character": "牡丹仙子、芍药仙子、海棠仙子",
          "type": "同西皮摇板",
          "text": "但见麻姑在面前。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "type": "同白",
          "text": "吓，麻姑仙子，稽首了！"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "众位仙子稽首。到此何事？"
        },
        {
          "character": "百花仙子",
          "type": "白",
          "text": "只因金母寿诞之期，我等相邀仙子，前去上寿。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "我亦正为此事，连日在此采取奇花异草，酿成美酒，也好与金母添寿。"
        },
        {
          "character": "百花仙子",
          "type": "白",
          "text": "如此，我等先行一步，告辞。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "恕不远送。"
        },
        {
          "character": "百花仙子",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "百花仙子",
          "type": "念",
          "text": "只为金母寿诞日，"
        },
        {
          "character": "麻姑",
          "type": "念",
          "text": "准备贡献赴瑶池。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花仙子、牡丹仙子、芍药仙子、海棠仙子同下。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "众位仙子已去，我不免准备花篮镰刀，再往后山，采取灵芝仙草便了。"
        },
        {
          "character": "麻姑",
          "type": "西皮摇板",
          "text": "到后山摘灵芝制成琼浆， 以表我虔诚心贡献佛场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。李铁拐上。"
        },
        {
          "character": "李铁拐",
          "type": "西皮摇板",
          "text": "洞府领了众仙命， 兜率宫中走一程。"
        },
        {
          "character": "李铁拐",
          "type": "白",
          "text": "我，李铁拐。只因金母寿诞之期，众仙命我去到兜率宫，请老君写副寿词，也 好前去祝寿。正是："
        },
        {
          "character": "李铁拐",
          "type": "念",
          "text": "凡人都说神仙好，做了神仙也烦恼。好手好脚不肯去，但要叫我跛子跑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李铁拐下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "麻姑",
          "type": "内西皮导板",
          "text": "离蓬莱又来到绛珠河畔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。麻姑携花篮、花镰上。"
        },
        {
          "character": "麻姑",
          "type": "西皮慢板",
          "text": "隐身儿行过了流水溪涧。 将花篮和花镰轻担项肩， 转眼间观河边灵芝一片。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "我乃麻姑仙子是也。只因金母寿诞之期，柏酿寿酒，现今百花俱全，缺少灵芝 仙草，因此来至绛珠河畔，采取灵芝。呵呀妙吓，看此处异样灵芝，甚是鲜妍， 不免采取便了。"
        },
        {
          "character": "麻姑",
          "type": "西皮原板",
          "text": "观一派天连水水又连天， 尘世上怎比得天上华严。 将花篮放置在流水溪边， 急忙忙我这里去拿花镰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑拿花镰舞。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "这一枝——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "跺头。"
        },
        {
          "character": "麻姑",
          "type": "西皮原板",
          "text": "这一枝灵芝草灵光威显，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑舞。"
        },
        {
          "character": "麻姑",
          "type": "西皮原板",
          "text": "那一枝似青云朵朵连绵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑舞。"
        },
        {
          "character": "麻姑",
          "type": "西皮原板",
          "text": "但只见溪边上玉石灿烂，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑舞。"
        },
        {
          "character": "麻姑",
          "type": "西皮原板",
          "text": "又见那碧桃花齐列坡前。 采罢了灵芝花忙回山转，"
        },
        {
          "character": "麻姑",
          "type": "西皮摇板",
          "text": "酿琼浆到瑶池把金母寿添。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅同上。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮摇板",
          "text": "离却天宫到蓬莱，"
        },
        {
          "character": "汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同西皮摇板",
          "text": "庆贺娘娘寿诞开。"
        },
        {
          "character": "吕洞宾",
          "type": "白",
          "text": "众位大仙请了！"
        },
        {
          "character": "汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "吕洞宾",
          "type": "白",
          "text": "今乃瑶池金母寿诞之期，也曾请李大仙往老君那里，写了寿词，以作寿礼，你 我就此同往瑶池庆贺便了。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮摇板",
          "text": "众仙齐庆瑶池界， 海屋添寿祝圣诞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。八龙套、四宫女引金母同上。"
        },
        {
          "character": "金母",
          "type": "二黄原板",
          "text": "喜孜孜移莲步用目观望， 看瑶池好华艳胜似天堂。 诸神仙齐来到瑶池庆赏， 因此上设寿宴齐集非常。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金母上高台。"
        },
        {
          "character": "金母",
          "type": "念",
          "text": "海屋添寿祝圣诞，福星永乐画堂前。岁岁年年逢此日，蟠桃会上集群仙。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "吾乃瑶池金母是也。上帝见我广軿九寿，常度众生，时命诸仙，齐赴蟠桃。为 此准备筵席，候众仙降临。 侍女们伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花仙子、牡丹仙子、芍药仙子、海棠仙子同上。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "type": "同念",
          "text": "画堂筵庆雀屏开，福禄荣华自天来。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "type": "同白",
          "text": "金母在上，小仙们拜寿！"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众仙子平身。"
        },
        {
          "character": "百花仙子、牡丹仙子、芍药仙子、海棠仙子",
          "type": "同白",
          "text": "圣寿无疆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅同上。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮摇板",
          "text": "银烛辉煌瑞彩草，"
        },
        {
          "character": "汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同西皮摇板",
          "text": "年年此日捧蟠桃。"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "金母在上，我等拜寿！"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众位大仙，不用拜了。"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "哪有不拜之理！正是："
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同念",
          "text": "画堂今日寿筵开，"
        },
        {
          "character": "金母",
          "type": "念",
          "text": "相邀众仙到此来。"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同念",
          "text": "殷勤祝寿瑶池界，"
        },
        {
          "character": "金母",
          "type": "念",
          "text": "共祝长生赴瑶台。"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "圣寿无疆！"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "开筵，待我把盏。"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "摆下就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅同坐。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众位大仙请！"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "金母请！ （摆席。〖吹打〗，〖牌子〗。金母、吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国 舅同吃酒毕。麻姑上。）"
        },
        {
          "character": "麻姑",
          "type": "念",
          "text": "手捧佳酿瑶池献，整束彩衣拜金阶。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "金母在上，小仙麻姑拜寿。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "麻姑仙子平身。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "圣寿无疆。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "手捧何物？"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "小仙特地制成，圣寿长生不老酒。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "何为圣寿长生酒？"
        },
        {
          "character": "麻姑",
          "type": "念",
          "text": "此酒本是百花练，灵芝仙草精益鲜。凡人若得饮此酒，可保长生永绵绵。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "如此身受你一杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。麻姑酌酒，金母饮酒。"
        },
        {
          "character": "李铁拐",
          "type": "白",
          "text": "吓，金母，麻姑仙子之长生不老酒，可能给我等饮一杯否？"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "那是理当奉敬。今日众仙驾临，乃是瑶池之幸也，现今园内蟠桃已熟，各敬一 枚，以为结缘之品。 侍女们，将蟠桃各敬一枚。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女同应，同散桃毕。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "麻姑仙子，命你在众仙面前，执壶敬酒一杯。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "遵法旨！"
        },
        {
          "character": "麻姑",
          "type": "西皮二六板",
          "text": "瑶池奉了金母命， 众仙台前把酒斟。 执壶轮流来恭敬， 但愿众仙庆长生。 仙家之酒仙家饮， 哪有凡夫俗子亦能到此行？"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众位大仙请！"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "金母请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金母、吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅同吃酒。〖牌子〗。"
        },
        {
          "character": "吕洞宾",
          "type": "白",
          "text": "众位大仙，这里现有编成上寿词一首，请麻姑仙子跳舞一奏如何？"
        },
        {
          "character": "汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "好，我等幸会。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "小仙当得奉命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑唱昆曲跳舞带做身段。笛吹凡字调。"
        },
        {
          "character": "麻姑",
          "type": "山花子",
          "text": "喜筵开处风光好，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麻姑开慢唱。"
        },
        {
          "character": "麻姑",
          "type": "山花子",
          "text": "争看寿星荣耀。 羡麻姑玉女并超， 寿同王母年高。 寿香腾，寿烛影摇， 玉杯寿酒增寿考。 金盘寿果长寿桃， 愿福如海深、寿比山高。"
        },
        {
          "character": "麻姑",
          "type": "大和佛",
          "text": "青鹿衔芝呈瑞草， 齐祝愿寿弥高。 画堂寿日多喧闹， 寿基巩固寿坚牢。 享寿绵绵乐寿滔滔， 展寿席人人欢笑。 齐庆寿诞中，祝寿词妙。"
        },
        {
          "character": "麻姑",
          "type": "红绣鞋",
          "text": "寿炉宝篆香消香消， 寿桃结子堪描堪描。 斟寿酒寿杯交歌， 寿曲寿多娇，齐祝愿寿山高。"
        },
        {
          "character": "麻姑",
          "type": "尾声",
          "text": "长生寿域宏开了， 寿烛辉煌彻夜烧。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众仙如此殷勤，乃我神之幸也。你等随我往凌霄宝殿谢恩去者！"
        },
        {
          "character": "吕洞宾、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同白",
          "text": "遵法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹大唢呐，大小锣。"
        },
        {
          "character": "金母、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同合头",
          "text": "愿岁岁年年增寿考。"
        },
        {
          "character": "金母、汉钟离、张果老、韩湘子、李铁拐、何仙姑、蓝采和、曹国舅",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}