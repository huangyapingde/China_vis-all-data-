{
  "script_id": "01002014",
  "title": "宇宙锋",
  "alias": [
    "金殿装疯"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "赵艳容",
      "hangdang": "正旦"
    },
    {
      "name": "赵高",
      "hangdang": "净"
    },
    {
      "name": "秦王",
      "hangdang": "小生"
    }
  ],
  "plot": "秦二世胡亥，荒淫暴虐，宠任奸佞赵高，置国事于不顾。赵高有女赵艳容，美而寡。秦二世幸赵府，见之大\n悦，欲纳为后，赵高欣然允之。赵艳容以秦二世淫逸放纵，灭亡可待，执意不从。赵高利禄熏心，再四逼迫。\n有哑婢教赵艳容装疯以难之，赵艳容遂胡言乱语，指天尽地，一似真有神经病若。赵高不得已以女病疯奏\n二世，秦二世不信，迎赵艳容登殿。赵艳容指秦二世大骂。秦二世佯命斩首以惧之。赵艳容痛骂狂笑如故，\n乃放还焉。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵高上。"
        },
        {
          "character": "赵高",
          "type": "引子",
          "text": "月影照纱窗，梅花绕粉墙。"
        },
        {
          "character": "赵高",
          "type": "念",
          "text": "人人说道老夫奸，我看世人心更偏。为人若无良谋智，焉能富贵两双全。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "老夫赵高，时才下朝回来，闻听外人言讲，道我儿叫那家人赵忠一声“丈夫”， 不免将我儿唤出问个明白。来，门官，"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "有，"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "请小姐出堂。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "后堂传话，小姐出堂！"
        },
        {
          "character": "丫鬟",
          "type": "内白",
          "text": "哑叭哑叭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵艳容、丫鬟同上。"
        },
        {
          "character": "赵艳容",
          "type": "念",
          "text": "杜鹃迎头泣，血泪含悲啼。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹爹，孩儿万福。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "唤孩儿出堂有何教训？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "时才为父下朝回来，闻听外人言讲，道我儿叫那家人赵忠一声“丈夫”，可是 有的？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹爹说哪里话来，想那赵忠他是甚等样人，孩儿岂肯叫他一声“丈夫”？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "待为父修下本章，明日早朝奏明圣上。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹爹恩宽。丫奴磨墨伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟磨墨。"
        },
        {
          "character": "赵艳容",
          "type": "西皮慢板",
          "text": "老爹爹恩德宽把本修上， 明早朝上金殿启奏我王。 我主爷有道君皇恩浩荡， 准此本免去了满门祸殃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引秦王同上。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "摆驾！"
        },
        {
          "character": "秦王",
          "type": "西皮摇板",
          "text": "时才间观花灯与民间乐， 观相府好一似龙楼凤阁。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "参见万岁！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "罢了。相国可在府中？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "现在表本。待蝼蚁通报。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "不用通报，退下。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官下。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "内侍摆驾。"
        },
        {
          "character": "秦王",
          "type": "西皮摇板",
          "text": "内侍掩灯相府进， 灯光之下遇美人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵艳容、丫鬟同下。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "赵高见驾，吾皇万岁！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "平身，赐坐。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "卿家在此则甚？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "在此表本。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "原来邝府之事，寡人一概不究。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "时才灯光之下见一妇人，她是何人？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "乃是老臣小女。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "孤王意欲宣进宫去同掌山河，意下如何？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "明日早朝送进宫去。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "好！太师听封：封你掌朝太师之职。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "谢主龙恩！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "摆驾回宫。"
        },
        {
          "character": "秦王",
          "type": "西皮摇板",
          "text": "内侍摆驾回宫廷， 明日早朝看美人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦王下。赵艳容、丫鬟同上。"
        },
        {
          "character": "赵艳容",
          "type": "念",
          "text": "有事在心头，终日眉头皱。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "呀，爹爹，圣驾到此为了何事？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "万岁到此将邝府之事一概不究。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "我主才是有道明君。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "本来是有道明君。恭喜我儿，贺喜我儿！"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "时才万岁见我儿生得美貌，有意带进宫去同掌山河。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹爹怎样回奏？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "明日早朝送进宫去。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹爹啊，你身为当朝首相，位列三台，连这三纲五常都不晓得了么？"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "老爹爹说此话真个可骇， 怪不得骂名儿四海喧传。 你孩儿曾念过列女真传， 岂肯做那失节妇遗臭万年？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "儿呵，难道不遵父命么？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹爹，又道是“先嫁由父母，后嫁自由身”。我看此事就用不着你了。"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "常言道“嫁鸡随鸡走”， 又道是“嫁犬犬同行”。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "难道说不遵圣名么？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹爹啊，慢说是圣命，就一把钢刀将儿首级割下也是不能遵命的了。"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "见此情一时间不能言断， 必须要生巧计才得安然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟比手教装疯。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "见丫奴在一旁挤眉绉眼， 莫非她叫我假装疯癫。 没奈何我只得青丝扯乱，"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "我这里脱绣鞋扯破衣衫。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "儿敢是疯了么？"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "听说疯我乐得随机应变， 倒卧在尘埃地信口胡言。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "儿呀，你当真的疯了么？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "疯了么？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "哈哈哈……爹爹，孩儿要上天！"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "天高上不去！"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "吓吓吓吓……爹爹，我要入地！"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "地厚无门下不去！"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "吓吓吓吓……爹爹，我那亲……"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "“亲”什么？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "亲生的儿呵！"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "赵艳容",
          "type": "反二黄慢板",
          "text": "我这里假意儿来睁杏眼， 摇摇摆摆摇摇摆摆摇向前。 我把他当做了夫君高唤，我的夫啊！"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "爹，来呀！"
        },
        {
          "character": "赵艳容",
          "type": "反二黄慢板",
          "text": "我和你红罗帐倒凤颠鸾。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "丫头",
          "type": "白",
          "text": "哑叭哑叭！"
        },
        {
          "character": "赵高",
          "type": "净白",
          "text": "呸！"
        },
        {
          "character": "赵艳容",
          "type": "反二黄慢板",
          "text": "我这里睁开眼天昏地暗，"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "我的天！"
        },
        {
          "character": "赵艳容",
          "type": "反二黄慢板",
          "text": "许多的怨鬼魂站立在门前。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "打鬼！"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "儿呀！那不是鬼，乃是太湖石。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "太湖石呀！"
        },
        {
          "character": "赵艳容",
          "type": "反二黄慢板",
          "text": "那一旁来了个牛头、马面， 玉皇爷驾祥云接我上天。"
        },
        {
          "character": "赵艳容",
          "type": "笑",
          "text": "哈哈哈，吓，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵艳容下。"
        },
        {
          "character": "赵高",
          "type": "念",
          "text": "闭门家中坐，祸从天上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵高下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦王上。"
        },
        {
          "character": "秦王",
          "type": "念",
          "text": "孤王御驾到龙庭，文臣武将朝寡人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵高上。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "启奏万岁：小女昨晚得了疯病！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "昨晚灯光之下还好，即日怎么得了疯？"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "天有不测风云，人有旦夕祸福。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "孤王赐她龙车凤辇带上金殿。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵高下。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "传御林军走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四卒同上。赵艳容、赵高同上。"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "午门外下了那龙车凤辇， 行一步来至在御驾跟前。 到于今顾不得抛头露面， 看昏王他把我怎样旨传。"
        },
        {
          "character": "赵高",
          "type": "白",
          "text": "儿呀，上面就是万岁。上前参见。"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "我晓得呦！ 上面敢是皇帝老官？恭喜你万福，贺喜你发财！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "见了寡人为何不跪？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "你大人不下跪，罗喏喏我生员是不跪的！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "原来是个疯癫女子。寡人好笑呵！哈哈哈……"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "你好笑，我也好笑！哈哈哈……"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "寡人笑你疯癫，你笑寡人何来？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "你笑我疯癫，我就笑无道的昏君！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "寡人有道，怎说无道？"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "哦，你要问你的无道，列位大人老哥了，你也听了：只因老王在世，东修岱海， 西建阿房，南修五岭，北造万里长城。直指望江山万代，谁想你这昏君贪淫 恋酒，不理朝事。我想这天下乃人人之天下，并非你一人之天下，我看你这江 山未必能长久了！"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "想此事气得我乌云扯乱， 气得我舌尖儿咬破牙关！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "殿前武士，刀门架起！"
        },
        {
          "character": "赵艳容",
          "type": "白",
          "text": "住了！我乃丞相之女，指挥老爷之妻，你们放肆大胆，还不与我退下！"
        },
        {
          "character": "赵艳容",
          "type": "西皮散板",
          "text": "我手中有镔铁定要试斩， 将这班众狂徒立斩马前！"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "再若提起疯癫，抓头来见！"
        },
        {
          "character": "赵高",
          "type": "白",
