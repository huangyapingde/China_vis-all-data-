{
  "script_id": "01037007",
  "title": "界牌关",
  "alias": [
    "盘肠大战；一名：罗通扫北"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "罗通",
      "hangdang": "武生"
    },
    {
      "name": "苏宝同",
      "hangdang": "净"
    },
    {
      "name": "王伯超",
      "hangdang": "净"
    }
  ],
  "plot": "北番兴兵犯境，番帅苏宝同，大举入寇。唐皇命秦怀玉挂帅，罗家父子罗通、罗章为先行，统领大兵征讨。\n军至界牌关，两军相拒，秦怀玉亲自出马，初颇得手，岂知被苏宝同用飞镖打伤，唐营即遭不利。既而罗通\n出战，鞭打苏宝同，彼此主帅遭挫，可称折伤相等。不意番营王伯超，用车轮战之计，率领诸番将，出与罗\n通更番轮战，以疲其力。罗通虽骁猛，怎禁得力战十数将，能无疲乏？至后手法一疏，果被王伯超一枪戳破\n腹肚，将脂肠挑出。罗通大怒拼命将肠盘绕腰腹间，重与死战。番将见之，皆大惊骇。盖惊其神勇，肠出而\n仍能力战也。一唶愕间，王伯超亦卒被罗通刺中要害而死。至是虽已力尽，乃回营而没。",
  "notes": "界牌关罗通盘肠大战王伯超，系出唐代小说中。往时昆腔中亦有此戏，江浙乱弹班，时常演奏。京徽班亦继\n之。此脚本中，纯用新水令、折桂令、侥侥令等小唢呐吹腔，可见尚是昆戈之遗音，惟辗转相传，唱白词句\n间，不无讹传尔。\n此脚本中，为罗通被创伤回营，顷刻身亡。其子罗章，立即出战，卒能刺杀王伯超，以报父仇等情，与前所\n云不同。似乎与“盘肠大战”四字，名实亦不副也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大旗上。罗通上，起霸。"
        },
        {
          "character": "罗通",
          "type": "念",
          "text": "白盔白甲白银枪，白旗白马似秋霜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗章上，起霸。"
        },
        {
          "character": "罗章",
          "type": "念",
          "text": "父子冲锋无人敌，扫尽狼烟护圣邦。"
        },
        {
          "character": "罗通、罗章",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "越国公罗通。"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "笑面虎罗章。 参见爹爹！"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "罢了。今有苏宝同打来战表，要与我主争斗江山。你我父子，去至营门候令。 带马！"
        },
        {
          "character": "大旗",
          "type": "白",
          "text": "来在营门。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "打了几鼓？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鼓响。"
        },
        {
          "character": "大旗",
          "type": "白",
          "text": "打了二鼓。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "退下。"
        },
        {
          "character": "大旗",
          "type": "白",
          "text": "呵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大旗下。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "元帅未曾升帐，你我父子，马台石打坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗通、罗章同坐。发点。四龙套、众马夫、秦怀玉同上。"
        },
        {
          "character": "秦怀玉",
          "type": "新水令",
          "text": "奉王命征战西辽邦， 领雄兵无人敢挡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦怀玉坐帐。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "报！罗通带子——"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "罗章。"
        },
        {
          "character": "罗通、罗章",
          "type": "同白",
          "text": "打恭！"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "贤弟、贤侄少礼。"
        },
        {
          "character": "罗通、罗章",
          "type": "同白",
          "text": "谢元帅！"
        },
        {
          "character": "秦怀玉",
          "type": "念",
          "text": "战鼓咚咚出皇朝，芦花荡内钓金鳌。本帅作了擎天柱，要灭西辽护圣朝。"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "本帅，秦怀玉。今有苏宝同打来连环战表，要与主上争斗江山。圣上挂我为帅。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！苏宝同讨战。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "元帅，苏宝同讨战，待我父子单枪——"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "匹马！"
        },
        {
          "character": "罗通、罗章",
          "type": "同白",
          "text": "生擒那贼进帐！"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "那贼用暗器伤人，尔等不可出马。看守大营。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "得令。 带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗通、罗章同下。"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "抬枪带马！"
        },
        {
          "character": "秦怀玉",
          "type": "新水令",
          "text": "保定锦家邦， 要把那贼一齐扫荡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦怀玉下。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、众番将、苏宝同同上。〖牌子〗。"
        },
        {
          "character": "苏宝同",
          "type": "白",
          "text": "某，苏宝同。统领人马，要夺唐室。 吧嘚喽，杀！"
        },
