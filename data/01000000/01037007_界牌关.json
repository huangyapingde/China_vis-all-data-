          "character": "苏宝同",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "苏宝同，你今侵犯，是何理也？"
        },
        {
          "character": "苏宝同",
          "type": "白",
          "text": "俺今夺取唐室天下！"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "胡说！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。苏宝同、秦怀玉同开打。苏宝同、四龙套、众番将同败下。"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦怀玉、四龙套同追下。"
        }
