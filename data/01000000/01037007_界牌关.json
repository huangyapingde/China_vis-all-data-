        {
          "character": "罗通",
          "type": "侥侥令",
          "text": "眼望着旗幡招展，似飘扬，定埋藏， 俺这里身为英勇，准备下天朝家邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯超、四下手、众番将同上，四下手、众番将同下。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "马前来将通名！"
        },
        {
          "character": "王伯超",
          "type": "白",
          "text": "大将王伯超！"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "看枪！ （王伯超、罗通同开打。王伯超败下。众番将同上，同开打。王伯超上，盘肠，罗通下。王伯超、众番将同 追下。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗通上。"
        },
        {
          "character": "罗通",
          "type": "白",
          "text": "杀败了，杀败了！哎呀哎呀！我与那贼交战，一时枪法作乱，被那贼一枪，哎 呀哎呀，把我肚腹挑破，挑出肚肠在外。圣上吓，圣上吓！只怕为臣，不能保 全江山社稷了！吓吓吓！"
        },
        {
          "character": "罗通",
          "type": "侥侥令",
          "text": "臣宰就一命亡，臣宰就一命亡， 鬼门关前走一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯超上。"
        },
