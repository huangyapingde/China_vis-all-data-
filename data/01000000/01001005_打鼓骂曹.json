{
  "script_id": "01001005",
  "title": "打鼓骂曹",
  "alias": [
    "群臣宴"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "祢衡",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "汉末祢衡，才长遇奇，目空一世，常云“大儿孔文举，小儿杨德祖，余子碌碌耳”。孔融荐之于曹操，祢衡\n见曹操，曹操傲不为礼，以傲遇傲，曹操夸张其门下人才，祢衡一一鄙薄之。适逢曹操大宴群臣，使祢衡当\n鼓吏。祢衡满腔气愤，正无发泄处，慨然允诺，擂鼓泄愤，怒击三挝，渊渊作金石声，坐客俱动容。祢衡又\n当众大骂曹操欺君罔上，擅作威福，曹操忍不与较，命祢衡持书往荆州，劝刘表来降。祢衡至荆州，刘表令\n至黄祖处。祢衡酒后触黄祖怒，被害于鹦鹉洲。此实曹操假手黄祖以杀之也。",
  "notes": "前在丹桂见七盏灯演此剧，进帐时唱二六板一段，激昂慷慨，击鼓时鼓声忽而如沙崩钜鹿，瓦碎长平。忽而\n如雁泪长空，猿啼巴峡，能使座客心向往之，亲聆正平先生渔阳操也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "引子",
          "text": "天宽地阔海无边，成败兴亡梦里眠。"
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "口若悬河语似流，舌上风云用计谋。男儿须当擎天手，自幼谈笑觅封侯。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "卑人姓祢名衡，字正平，乃山西平原郡，幼义村人氏。自幼勤习经史，深知策 略，虽怀王佐之才，惜乎未遇其主。身在孔大夫府中作幕，昨日将我荐与曹府 效用。想那曹操，名为汉相，实为汉贼，焉能敬贤礼士？我此次去至曹府，需 要见机而行。正是："
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "未遇真命主，辜负栋梁才。"
        },
        {
          "character": "祢衡",
          "type": "西皮慢板",
          "text": "平生志气运未通， 似蛟龙困在浅水中。 有朝一日春雷动， 际会风云上九重。"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "自幼儿窗前习孔孟， 壮游北海遇孔融。 他将我荐与曹府用， 要学孙膑下云梦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "三国纷纷刀兵扰， 每日思想计千条。 但愿狼烟一起扫， 四海升平乐唐尧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "一封书信忙修起， 见了丞相说端的。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军少礼，请坐。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你修书，你可曾修起？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "已经修好。命何人送去？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孔融荐举祢衡，还未见到来。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔融上。"
        },
        {
          "character": "孔融",
          "type": "西皮摇板",
          "text": "祢衡先生我请到， 见了丞相说根苗。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "少礼请坐。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡可曾唤到？"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "现在府外。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唤他进来。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "有请祢衡先生。"
        },
        {
          "character": "祢衡",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "相府门前杀气高， 密密层层摆枪刀。 画阁雕梁双凤绕， 赛似天子九龙朝。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "祢衡先生参见丞相。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "祢衡参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "下站何人？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "姓祢名衡，乃山西平原郡人氏。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "这就是祢先生。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怕老夫不知他叫祢衡？见了老夫，这等大模大样，只行常礼，其实可恼！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "哦呵呀！我道曹操敬贤礼士，却原来不识好人。吾进得相府，与他深施一礼， 他坐在上面，昂然不动，倒也罢了，反说我礼貌不周。我乃天下奇士，岂肯与 奸贼低首吓。孔文举你将我荐错了。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "人言曹操多奸狡， 果然好比秦赵高。 欺郡罔上非正道， 全凭势力压当朝。 站立在廊下微微笑， 哪怕虎穴与笼牢。"
        },
        {
          "character": "祢衡",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "为何发笑？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "我笑这天地虽阔，却无一人也。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫帐下，文能安邦，武能定国，何言无人？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你道你帐下，文能安邦，武能定国，俱是英雄豪杰，但不知文有谁高，武有谁 能？祢某愿闻一二。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你且听来：文有荀彧、荀攸、郭嘉、程昱，机深智远，虽萧何、陈平，不可及 也。武有张辽、许褚、李典、乐进，不让当年岑彭、马武。我儿曹子孝，人称 天下奇才；夏侯惇可称无敌将军。老夫兴兵以来，攻无不取，战无不克。顺我 者生，逆我者死，何言无人？"
        },
        {
          "character": "祢衡",
          "type": "笑",
          "text": "呀，哈哈哈……"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你且听道：你帐下尽都是英雄上将，以我看来，尽是无用之辈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你且听道：荀彧、荀攸，可使吊丧问奠；郭嘉、程昱，只好看墓守坟；李典、 乐进，只好牧羊放马；许褚、张辽……"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "唔……"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "只好击鼓鸣更。曹子孝呼为要钱太守；夏侯惇称为完体将军。余下诸人，尽都 是衣架饭囊，酒桶肉袋，碌碌之辈，何足道哉？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你有此狂言，有何德能？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "祢某无才，天文地理之书，无一不知；三教九流，无一不晓。上可以致君为尧 舜，下可以配德于孔颜。吾乃天下名士，岂肯与奸贼同党。孔文举你不要装痴 了。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "自幼窗前习管鲍， 兵书战策日夜瞧。 我本堂堂一秀表， 岂与犬马共同槽。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "听罢言来心烦恼， 误骂豪杰为哪条？ 三尺青锋出了鞘，"
        },
        {
          "character": "孔融",
          "type": "西皮摇板",
          "text": "将军息怒慢开刀。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张将军休要污秽老夫的宝剑。 祢衡，明日老夫大宴群臣，命你当一鼓吏，你可愿当？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "祢先生应允了吧！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "愿当鼓吏。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好，明日来早便罢，倘若来迟，按军令施行。张将军将他赶出帐去！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "丞相委用恩非小， 屈为鼓吏怎敢辞劳？ 出得帐来微微笑， 孔大夫做事也不高。 明知曹操眼孔小， 沙滩无水怎能壳藏蛟。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "满腹经纶空怀抱， 有志不能上九霄。 越思越想心头恼， 施一个巧计骂奸曹。 安排打虎牢龙套， 大虫窝内宿一宵。 罢罢罢，暂且忍下了， 明日自有我的巧妙高！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        },
        {
          "character": "孔融",
          "type": "西皮摇板",
          "text": "祢衡先生性太傲， 险些儿项上吃一刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔融下。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "辞别丞相下舆道， 相请列位走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "大宴群臣文武到， 杀鸡何用宰牛刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "祢衡",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "西皮导板",
          "text": "适才与贼来叙话，"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "气得某家泪如麻。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "咳！正是："
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "酒逢知己千杯少，语不投机半句多。 适才进得相府，与贼深施一礼，他坐在上面，安然不动，倒也罢了，反道俺的 礼貌不周。又将我辱为鼓吏。明日元旦佳节，必然当着满朝文武羞辱与我。吾 乃天下名士，焉肯为那贼羞辱！明日进得相府，是要赤身露体，百般叫骂于他， 纵然将我斩首，也落的一个青史名标！正是："
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "明知山有虎，偏向虎山行。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "明日进账将贼骂， 拼着一死染黄沙。 纵然将我头割下， 落一个骂贼名儿扬天下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四朝官同上。"
        },
        {
          "character": "朝官甲",
          "type": "念",
          "text": "日观三千策，"
        },
        {
          "character": "朝官乙",
          "type": "念",
          "text": "夜读七篇诗。"
        },
        {
          "character": "朝官丙",
          "type": "念",
          "text": "要知今古事，"
        },
        {
          "character": "朝官丁",
          "type": "念",
          "text": "还读五车书。"
        },
        {
          "character": "朝官甲",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "朝官甲",
          "type": "白",
          "text": "丞相有帖相邀，不知为了何事？我等一同去到相府。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "请。正是："
        },
        {
          "character": "四朝官",
          "type": "同念",
          "text": "五凤楼前朝金阙，相府门前拜元戎。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "门上哪为在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "吓，列位大人。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "张将军，烦劳通禀丞相，就说我等要见。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "少站一时。 有请丞相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操自下场门上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "众位大人要见。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四朝官同进。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相在上，我等大礼参拜。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫也有一拜。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相宣诏我等，有何见？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "今日老夫大宴群臣，请列位到此畅饮几杯。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "到此就要叨扰。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待老夫把盏。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "摆下就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。二旗牌自两边分上，同摆宴。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位大人，老夫帐下，新收一名鼓吏，命他在底下擂鼓，你我畅饮三杯。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "既有此事，我等瞻仰。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传鼓吏进帐。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "传鼓吏进帐。"
        },
        {
          "character": "祢衡",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": "祢衡",
          "type": "内西皮导板",
          "text": "谗臣当道谋汉朝，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "西皮慢板",
          "text": "楚汉相争动枪刀。 项羽无谋落圈套， 九里山前韩信高。 数尽失志乌江道， 盖世英雄无下稍。 高祖咸阳登大宝， 一统山河乐唐尧。 四百年来国运消， 献帝皇爷坐九朝。 后来出了奸曹操， 上欺天子下压群僚。 有心替主把贼扫， 手中缺少杀人刀。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌斟酒。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "下席坐了奸曹操， 上席文武众群僚。 狗奸贼传令如山倒， 舍死忘生在今朝。 元旦节与贼个不详兆， 假装疯迷耍耍奸曹操。 我把青衣来脱掉，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌斟酒。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "破鞋褴衫摆摆摇。 怒气不息往上跑，"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "呔！你这鼓吏，丞相大宴群臣，这样破衣褴衫，成何体统？"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "帐下儿郎闹吵吵。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "倒说我等吵闹，好笑吓，哈哈哈……"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "列位不必哈哈笑， 有一辈古人听根苗："
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "你且讲来。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "昔日太公曾垂钓， 张良拾履在荒郊。 为人受得苦中苦， 脱却褴衫换紫袍。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "你焉能比得前朝的古人？"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "你二人把话讲错了， 休把猛虎当狸猫。 有朝一日时运到， 拔剑要斩海底蛟！"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "青天白日，你在此做梦！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "休道我白日梦颠倒， 登时就要上青霄。 我把破衣齐脱掉，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌斟酒。祢衡脱衣。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "赤身露体往上跑，"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "呔！丞相大宴群臣，你倒赤身露体，丞相降罪，何人承当？"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "你丞相降罪我承招。 抽身来在东廊道， 看这奸贼把我怎开销？"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "鼓吏到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命他擂鼓三通。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "丞相命你擂鼓三通。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打鼓。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "列位大人，听这鼓吏擂鼓，好似金声玉振，我等畅饮几杯，庆贺丞相，请吓！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请吓！"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "擂鼓三通响如雷， 文武百官饮三杯。 张辽一旁牙咬碎， 孔融带愧转回归。 站立廊下观鼓吏，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打鼓。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "赤身露体廊下立。 老夫暂忍心头气， 再与祢衡说端的。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "曹操。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你为何叫老夫曹操？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你叫得我祢衡，我就叫得你曹操！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这也不计较于你。今日老夫大宴群臣，你赤身露体，成何体统？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "我露父母清白之体，显得我是清洁的君子，不必你是混浊的小人！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫身居相位，何言混浊？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你且听道：你虽居相位，不识贤愚，贼的眼浊也；不纳忠言，贼的耳浊也；不 读诗书，贼的口浊也；常怀篡逆，贼的心浊也！我乃是天下名士，你将我屈为 鼓吏，羞辱与我，犹如阳货害仲尼，臧仓毁孟子。轻慢贤士，曹操吓，曹操！ 你真匹夫之辈也！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "昔日文王访吕望， 亲临渭水求栋梁。 臣坐君乘执辔往， 为国求贤礼所当。 你只望在朝中为首相， 全然不知臭和香。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "老夫兴兵谁敢挡， 赫赫威名天下扬。 论机谋赛过姜吕望， 岂容无知小儿郎。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "曹操把话错来讲， 无水怎把蛟龙藏？ 马槽怎养狮和象， 犬穴焉能住凤凰？ 鼓打一通天地响， 鼓打二通振朝纲。 鼓打三通扫奸党， 鼓打四通国泰康。 鼓发一阵连声响，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打鼓。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "管教你奸贼死无下场。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "四朝官",
          "type": "同西皮摇板",
          "text": "众人停杯望下廊， 丞相为何怒一旁？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我与鼓吏交谈几句，故而闷坐在此。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相息怒，我等上前问来。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有劳列位大人！"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "你这鼓吏，家住哪里，姓甚名谁，一一讲的来。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "列位，"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "未曾开言心头恨， 尊声列位听分明："
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "家住哪里？"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "家住山西平原郡，"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "姓甚名谁？"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "姓祢名衡字正平。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "呀，祢先生！"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "腹中颇有安邦论， 曾与孔融当过幕宾。 他将我荐与曹奸佞， 肉眼不识俺的宝和珍。 我宁做忠良门下客， 岂作他奸贼的帐下人！"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "你真是舌辩之徒！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "你道我正平是舌辩之徒， 舌辩之徒有张苏。 苏秦六国为首相， 全凭舌尖压四座。 有朝一日展昆仑手， 要把奸贼一笔勾！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "把你比作井底之蛙，能起多风多浪？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "贼把我比作井底蛙， 井底之蛙也不差。 有朝一日云雾下， 要把你奸贼一把抓！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位大人，他道老夫奸，我奸在何处？"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "是吓，丞相奸在何处？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "列位，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "狗奸贼出巧言故意问道， 尊一声众公卿细听根苗。 自幼儿入学廉官卑职小， 他本是夏侯子过继姓曹。 到如今作高官忘了宗考，"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "贼吓贼吓，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哽。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "全不怕臭名儿万古留标。"
        },
        {
          "character": "张辽",
          "type": "西皮快板",
          "text": "听他言来心头恼， 辱骂丞相为哪条？ 三尺青锋出了鞘，"
        },
        {
          "character": "四朝官",
          "type": "同西皮摇板",
          "text": "张将军息怒慢开刀。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张将军，休要污秽老夫的宝剑。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "狗仗人势，谅你也不敢！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡，老夫有书信一封，命你去往荆州，顺说刘表来降。倘若刘表来降，保你 官职在朝。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呀呀呸！"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "要往荆州怎能够， 岂肯与你作马牛？"
        },
        {
          "character": "四朝官",
          "type": "同西皮摇板",
          "text": "丞相息怒且听候， 顺说祢衡往荆州。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有劳列位大人。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "吓，祢先生，丞相有书信一封，命你去往荆州，顺说刘表来降。你若不去，恼 了丞相，将你斩首，你家中还有妻儿老小，所靠何人？必须要再思再想吓！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "哦……"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "列位宫卿齐来劝我， 酒醒方知梦南柯。 自古道责人先责己过， 手摸胸膛自己揣摩。 罢罢罢，暂忍我的心头火，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡穿衣。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相，祢衡愿往荆州去了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓，祢衡愿往荆州去了？列位大人。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡说老夫是奸臣，奸在何处？"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相是大大的忠臣。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈，老夫是大大的忠臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四朝官同笑。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "事到头来没奈何。 走上前来忙告错， 尊声丞相听我说： 你把书信交与我， 顺说刘表作定夺。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "千错万错先生错， 话不投机半句多。 倘若刘表归顺我， 保你官职在朝阁。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "丞相息怒且请坐， 披星戴月奔江河。 顺说刘表若不妥，"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "早去早回。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "愿死他乡作鬼魔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "吾等告退。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫少送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
