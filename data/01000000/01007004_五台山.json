{
  "script_id": "01007004",
  "title": "五台山",
  "alias": [
    "五台会兄"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "杨延德",
      "hangdang": "净"
    },
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "老僧",
      "hangdang": "外"
    }
  ],
  "plot": "北宋杨家将，父子兄弟，一门为国戮力。金沙滩一役，散亡殆尽，所存者仅四郎延辉、五郎延德、六郎延昭\n三人而已。而延辉、延德，又一则没入萧邦，一则代主披剃。故令公殉国后，惟六郎一人，继父执掌兵事，\n镇守三边。一日六郎为番兵所追，单身独马，几不得脱，时已向暮，经过一山，见山上有一佛刹，遂敲门入\n避，以失路借宿为名。幸山僧慈悲，引之入别室安顿。至夜分，六郎正忧虑不能寐。忽一莽头陀酩酊归，冲\n门入，疑寄宿究非善类，入室盘诘。六郎不即应，莽头陀性本急躁者，怒甚，几至用武。既而彼此闻语，均\n觉乡音颇熟耳，各注意细诘邦族，始知莽头陀即五郎延德。盖此山即五台山也。弟兄相逢意外，悲喜交集。\n正语间，忽闻追兵人马声至，遂赖五郎下山杀退。六郎方得安然出险，挥泪而别。",
  "notes": "按剧本中所言，六郎此行系搬请令公尸骨而归。\n此剧刘永春颇擅演，永奎虽亦不恶，然不逮远矣。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "休赶吓休赶！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "踢破玉笼飞彩凤， 扭断金锁走蛟龙。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "俺，六郎延昭。奉了母亲之命，来到北国，搬请爹爹尸骨，尸骨到手，就此马 上加鞭。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "天波府奉了母亲命， 搬请尸骨走一程， 催马加鞭往前进， 只见红日往西行。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来此已是五台山，看天色已晚，不免在此借宿一宵，明日趱行。待我上前叫门。 门上哪位师父在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧上。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "嗯哼。"
        },
        {
          "character": "老僧",
          "type": "念",
          "text": "扫地恐伤蝼蚁命，爱惜飞蛾纱罩灯。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "是哪一个？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "吓，师父。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "吓，原来是位壮士。你从哪道而来？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我乃远方来的，行到此间，天色已晚，在宝刹借宿一宵，明日早行，望师父行 个方便。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "我们出家人慈悲为本，方便为门，将马带进来。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "客官，你用些什么？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "只用孤灯一盏。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "待我取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧取灯。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "明灯在此。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我在哪里安歇？"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "随我来。 就在此地。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父请便。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "是。吓，壮士，我有一徒弟，情性不好，壮士留心一二。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那个自然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧下。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看四下无人，待我将尸骸打开观看。 “杨继业尸骨”。哎呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "一见尸骨泪双淋， 怎不叫儿痛在心。 为国忠良丧了命， 爹爹吓！ 奏明了宋天子追封亡魂。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看天色不早，不免安歇了吧。正是："
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "一觉放开心头稳，昏昏沉沉到阳台。"
        },
        {
          "character": "杨延德",
          "type": "内白",
          "text": "好酒。"
        },
        {
          "character": "杨延德",
          "type": "内二黄导板",
          "text": "五台山出了家当了和尚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德上。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "天波府辞别了年迈萱堂。"
        },
        {
          "character": "杨延德",
          "type": "念",
          "text": "刀割连心肉，箭射白莲花。看破红尘路，五台出了家。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "洒家，五郎延德。是我背着师父，下得山去赴牛羊大会，是我打了几套拳，耍 了几套棍，那些施主们，赏下大坛的酒、大方的肉，不觉吃得这样醺醺大醉。"
        },
        {
          "character": "杨延德",
          "type": "吐",
          "text": "哇哇……"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "天色不早，不免回山便了。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "忆昔当年赴两狼， 狼牙虎口摆战场。 冲冲跌跌山岗上， 紧闭山门为哪桩？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "吓，这老和尚为何将山门紧闭，待我上前叫门。 呔，师父开门来，师父开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧上。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "想是小徒回来了，待我开门。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "为何这样慢腾腾的，待我打进去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德吐。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哇哇……"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "哪里吃得这样薰薰大醉？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "师父哪里知道，是我下得山去赴牛羊大会，打了几套拳，耍了几套棍，施主们 赏下大坛酒、大方的肉，不觉吃得这样薰薰大醉。"
        },
        {
          "character": "杨延德",
          "type": "吐",
          "text": "哇哇。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "我们出家人，将腌囋东西少吃为妙。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "下次改过就是。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "好吓。将山门紧闭，随为师后面安歇。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨延昭",
          "type": "内哭",
          "text": "哎呀……"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "吓，师父，哪里有人在此啼哭？"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "远方来的一位壮士，在此借宿，你不要管他。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "远方来的无有好人。待弟子上前盘他一盘。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "为师盘过了。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "待我盘他一盘。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "不用盘了。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呔，太罗嗦了！"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧下。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哈哈哈！我家师父，本来是个好人吓！待我上前看过。 来此已是伽蓝殿，待我进去。 哎，那一壮士，从哪道而来，哪道而去？ 他行路辛苦未曾听见，那厢去问。 那一壮士，你从哪道而来，哪道而去？ 待我将他惊醒。 呔，壮士醒来！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看剑。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "你从哪道而来？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来道而来。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哪道而去？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "去道而去。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哇呀呀。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "连叫三声不答应， 不由洒家动无名。 五台山杀人如戏耍，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "出家人难道胡乱杀人不成？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "出家人喜的是拜佛念经。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "那一壮士，听你之言，不像此地人氏。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "本不是此地人士。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哪里人士？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "大宋朝人士。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "不才洒家，也是大宋朝人士。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哦，师父也是大宋朝人士。我倒要盘你一盘。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哦，洒家不来盘你，你倒要盘起我来了。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "大宋朝有一天波杨府，你可知道？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "你才怎讲？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "天波杨府。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "不提天波杨府还则罢了，提起天波杨府，洒家的酒，醒了一大半了。"
        },
        {
          "character": "杨延德",
          "type": "二黄导板",
          "text": "大宋朝有一个天波杨府，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "天波府尽都是什么人？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "天波府尽都是姓杨人。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那令公爷官居何职？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "令公爷官居当朝一品，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "原配的夫人呢？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "原配夫人佘氏太君。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "太君所生几男几女？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "那太君生七男养二女，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "还有那杨八郎呢？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨八郎他本是外姓人。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那杨大郎呢？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨大郎替宋王长枪命丧，"
        },
        {
          "character": "杨延德",
          "type": "哭",
          "text": "长枪命丧！兄长吓！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那杨二郎呢？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "杨二郎，有吓。"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨二郎短剑下一命身亡。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那杨三郎呢？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨三郎被马踹尸如泥酱，"
        },
        {
          "character": "杨延德",
          "type": "哭",
          "text": "尸如泥酱！兄长吓！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那四郎、八郎？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "有吓。"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "四郎、八郎失落在番邦。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那杨五郎？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "有吓。"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨五郎弃红尘当了和尚。"
        },
        {
          "character": "杨延德",
          "type": "哭",
          "text": "当了和尚！太君吓！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那杨六郎呢？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "有吓。"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "镇守三关杨六郎。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那杨七郎？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "有吓。"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "惟有七郎死的苦， 芭蕉树上一命亡。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你乃何人？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "若问洒家名和姓？ 五郎延德是我名。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "听他言来才知情， 原来五哥到来临。 双膝跪在尘埃地，"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "问声壮士是何人？"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "五哥有所不知情， 小弟六郎到来临。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "六弟延昭，六贤弟吓吓！"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "一见六弟到来临， 怎不叫人痛在心。 手挽手儿禅堂进， 弟兄对坐叙苦情。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "六弟不在天波杨府，来在北国做甚？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "奉了母亲之命，来到北国搬请爹爹尸骨。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "尸骨可曾到手？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "已经到手。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "待愚兄观看。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "“继业尸骨”。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "一见尸骨泪双淋， 可叹你为国丧幽冥。 耳旁听得銮铃响， 贤弟带来多少兵？"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "并无一兵和一将， 后面追来韩昌兵。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "听说韩昌发来兵， 不由洒家怒气生。 手拿禅杖下山林，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "洒家一人退贼兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番上，开打，下。"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "杨家与你何仇恨， 苦苦追赶为何情！ 退罢贼兵山门进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "五哥可曾退贼兵？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "那贼已退，快快下山去罢。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "辞别五哥下山林。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "五哥有话快讲明。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "此番回去，多多拜上娘亲，就说愚兄不孝了。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "吓，五哥随小弟回去，见过娘亲，再来出家也还不迟。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哎呀，六弟吓。自古道出家容易回家难，快快下山去罢。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "辞别五哥跨金蹬， 不分昼夜转回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "杨延德",
          "type": "三叫头",
          "text": "六弟！延昭！哎哎！六贤弟吓！"
        },
        {
          "character": "杨延德",
          "type": "二黄摇板",
          "text": "一见六弟下山林， 叫人难舍又难分。 迈步且把山门进， 从今后在禅堂拜佛念经。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}