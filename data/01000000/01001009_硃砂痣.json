{
  "script_id": "01001009",
  "title": "硃砂痣",
  "alias": [
    "行善得子"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "韩廷凤",
      "hangdang": "外"
    },
    {
      "name": "吴惠泉",
      "hangdang": "老生"
    },
    {
      "name": "江氏",
      "hangdang": "旦"
    },
    {
      "name": "金氏",
      "hangdang": "老旦"
    },
    {
      "name": "媒婆",
      "hangdang": "丑旦"
    },
    {
      "name": "韩遇运",
      "hangdang": "小生"
    }
  ],
  "plot": "双州太守韩廷凤，因无子嗣，另娶江氏。新娘过门，啼泣甚哀，韩廷凤问起情由，始知江氏因夫贫病交加，\n不得已卖身救夫。韩廷凤怜之，赠银送其返家，夫妻又得团聚。江氏夫妇得知太守求子心切，为了报答，卖\n了一个孩童送给太守。韩廷凤问起孩童父母情况，并验得孩子左脚上有一颗硃砂痣，才认出就是十三年前，\n因金兵作乱，走失的儿子韩遇运。父子又得重逢。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩廷凤上。"
        },
        {
          "character": "韩廷凤",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "韩廷凤",
          "type": "二黄摇板",
          "text": "今夜晚前后厅灯光明亮， 我不想年半百又做新郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。媒婆上。"
        },
        {
          "character": "媒婆",
          "type": "念",
          "text": "新人过门厅，媒钱自然增。"
        },
        {
          "character": "媒婆",
          "type": "白",
          "text": "启老爷：新人已到。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "将轿搭上堂来。"
        },
        {
          "character": "媒婆",
          "type": "白",
          "text": "花轿搭上堂来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "轿夫、丫鬟、江氏同上。江氏出轿，轿夫下。"
        },
        {
          "character": "媒婆",
          "type": "白",
          "text": "娘子见过老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江氏坐。"
        },
        {
          "character": "媒婆",
          "type": "白",
          "text": "小人们讨赏。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "下面领赏。"
        },
        {
          "character": "媒婆",
          "type": "白",
          "text": "谢老爷。 媒人一片苦心肠，一边欢喜一边伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "媒婆下。家院下。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "丫头！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "掌灯，待我一观。"
        },
        {
          "character": "韩廷凤",
          "type": "二黄慢板",
          "text": "借灯光暗地里细观姣娘， 我看她与前妻一样风光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江氏哭。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "韩廷凤",
          "type": "二黄慢板",
          "text": "只见她愁眉皱泪流脸上， 莫不是嫌我老难配鸾凰？"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "不是。"
        },
        {
          "character": "韩廷凤",
          "type": "二黄原板",
          "text": "要穿衣锦绣衫任你掉样， 你有甚心中事细说端详，这有何妨？"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "大老爷启禀！"
        },
        {
          "character": "江氏",
          "type": "二黄原板",
          "text": "未开言不由人泪如雨降， 尊一声大老爷细听端详： 奴丈夫病沉疴久卧床上， 因此上少银钱变卖妻房。 我岂肯贪富贵痴心妄想， 可怜我好夫妻两下离分。 大老爷开大恩将奴释放， 纵死在九泉下瞑目不忘。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "韩廷凤",
          "type": "二黄摇板",
          "text": "听她言伊现有妇随夫唱， 怎奈我两下里拆散鸳鸯。 再不要做恶事天在头上， 自情愿伴孤灯永守空房。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "院子哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "老爷何事？"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "你可将这女子送回，聘礼不要，再取银子一百两，送她到家，全她夫妻恩情， 以完这女子贞节之名。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "既蒙老爷开恩仗义，不肯收留，又叨恩赐，容小妇人叩谢。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "不消了。"
        },
        {
          "character": "江氏",
          "type": "二黄摇板",
          "text": "救命银是我夫重生父样， 全贞节是难妇再世爹娘。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "回来。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "你这婚书在此。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "但凭恩人。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "当面烧化了吧！"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "多谢恩人。"
        },
        {
          "character": "江氏",
          "type": "二黄摇板",
          "text": "积阴功救难妇放开罗网， 回家去同丈夫答报商量。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院领江氏同下。"
        },
        {
          "character": "韩廷凤",
          "type": "二黄摇板",
          "text": "她言道本丈夫染病在床， 因此上卖了她好度日光。 将他人比自己俱是一样， 善与恶自有那天理昭彰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩廷凤下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴惠泉上。"
        },
        {
          "character": "吴惠泉",
          "type": "二黄摇板",
          "text": "孤单单病奄奄坐卧病床， 断送了好夫妇凤友鸾凰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院、江氏同上。"
        },
        {
          "character": "江氏",
          "type": "二黄摇板",
          "text": "黑夜里蒙送我重归故道， 好一似失群雁又来旧巢。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "来此已是我家门首，请站一时。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "丈夫开门。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "吴惠泉",
          "type": "二黄摇板",
          "text": "猛听得叫丈夫轻言俊俏， 想是我梦魂中心神颠倒。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "开门！"
        },
        {
          "character": "吴惠泉",
          "type": "二黄摇板",
          "text": "这声音似我妻江氏多姣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴惠泉开门。"
        },
        {
          "character": "吴惠泉",
          "type": "二黄摇板",
          "text": "叫得我寒毛凛胆战魂消。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "官人。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "你怎样回来的？"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "多蒙韩老爷查问情由，不忍拆散你我夫妻，将婚书烧化，聘礼不要；又赐银百 两，以成奴之贞节，故而差人将奴送回。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "哦，有这等事？何人送你回来的？"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "韩管家送我回来的。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "请他进来。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "有请管家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院进。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "啊，韩管家。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "吓，吴相公。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "你家员外怎样言道？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "我家员外言道，命我送大娘子回来，先前聘礼不要，再与银子百两，叫你保养 病体。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "世界之上，哪有这样好人？谢天谢地！"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "当谢天地！"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "娘子你我夫妻，前去叩谢才是。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "礼当如此。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "吴相公，你那贵恙才好，改日再去吧。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "吓，如今我有银子，病就好了。走吓。"
        },
        {
          "character": "吴惠泉",
          "type": "二黄摇板",
          "text": "全夫妇正人伦恩当重报，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院、吴惠泉同下。"
        },
        {
          "character": "江氏",
          "type": "二黄摇板",
          "text": "仗大义舍资财送妇归巢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江氏下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩廷凤上。"
        },
        {
          "character": "韩廷凤",
          "type": "二黄摇板",
          "text": "劝世人一个个须要学好， 皆因是自有那天里昭昭。 我当年为太守何等荣耀， 遇兵荒妻和子无有下梢。 也是我前世里未曾修道， 我若是全不为我自逍自遥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上，吴惠泉上，江氏上。"
        },
        {
          "character": "吴惠泉",
          "type": "二黄摇板",
          "text": "我和你到他家双膝跪倒，"
        },
        {
          "character": "江氏",
          "type": "二黄摇板",
          "text": "我夫妻特地来叩谢恩劳。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "韩廷凤",
          "type": "二黄摇板",
          "text": "我救人的急，全人的危，遵古训教， 此小事何须要理顺和调。 尊二位将请起施礼还到， 全大节，全忠义，遵古天条。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "大娘子，这是何人？"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "这是我丈夫吴惠泉。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "原来是吴相公，请坐请坐。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "大老爷在此，小人不敢坐。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "有话叙谈，哪有不坐之理？"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "大娘子你也坐下。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "吴相公，听大娘子之言，你有病在床，病体好了，再来不迟。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "老爷有所不知，小人得了银钱，病就好了。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "吓，有了钱，你的病就好了。如此说来，银子是好物件！"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "好物件！"
        },
        {
          "character": "韩廷凤",
          "type": "二黄垛板",
          "text": "我救你的急，救你的难，救你的贫困， 全你的节，全你的义，全你的婚姻。 我无子也是我前生造定， 我若是错婚姻，到后来留下了骂名。"
        },
        {
          "character": "韩廷凤",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "何不再娶一房，产得一子，也未可知。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "子孙之事，前生造定；若是再娶，也就不必了。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "何不买上一个孩童，将来有靠。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "这倒使得，只是本处孩子，有好些不便；或者远乡别处，饥寒贫苦的孩子，买 他一个，教他成人。若不听教训，也是一番怄气。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "小人前在四川贸易，有些账目未归，如今恩人所赐资本，目下就要起身。倘有 合适小孩，买来一个，送与恩人，以表我夫妻之情。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "那倒不消。"
        },
        {
          "character": "吴惠泉",
          "type": "白",
          "text": "娘子你我辞别恩人去吧。"
        },
        {
          "character": "江氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "韩廷凤",
          "type": "白",
          "text": "你二人要去了，我不能远送了。"
        },
        {
          "character": "吴惠泉",
          "type": "二黄摇板",
          "text": "辞别了大恩人犹如山海，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴惠泉下。"
        },
        {
          "character": "江氏",
          "type": "二黄摇板",
          "text": "到四川买一子报答恩来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江氏下。"
        },
        {
          "character": "韩廷凤",
          "type": "二黄摇板",
          "text": "他夫妻进门来双膝跪倒， 口口声叫恩人珠泪双抛。 我无子前世里未曾修道， 作恶人总有子枉费心劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩廷凤下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金氏上。"
        },
        {
          "character": "金氏",
          "type": "念",
          "text": "只说养儿得济，谁知到老养儿。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "老身权在经之妻金氏。自从那匪贼作乱，中途拾得一子，取名天赐，抚养他长 大。指望他养老，谁知丈夫去世，家业渐渐凋零。此子今年十二岁了，读书之 外，哪里辨得一件事情。还是全靠老身养活与他。我今年迈，自身难保，哪里 还有余资？倒不如将他卖了，留得几两银子，且作终身之靠。 我儿哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩遇运上。"
        },
        {
          "character": "韩遇运",
          "type": "念",
          "text": "天子重英豪，文章教尔曹。万般皆下品，惟有读书高。"
        },
        {
          "character": "金氏",
          "type": "念",
