{
  "script_id": "01023010",
  "title": "延安关",
  "alias": [
    "双阳产子；一名：反延安"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "双阳公主",
      "hangdang": "武旦"
    },
    {
      "name": "杨宗保",
      "hangdang": "外"
    },
    {
      "name": "狄青",
      "hangdang": "小生"
    },
    {
      "name": "刘庆",
      "hangdang": "副净"
    },
    {
      "name": "先行甲",
      "hangdang": "净"
    },
    {
      "name": "先行乙",
      "hangdang": "末"
    }
  ],
  "plot": "考狄青初次平西，被西番双阳公主擒去，欲招为驸马。狄青遂将计就计，盗取日月骕骦马及珍珠烈火旗二宝，\n私行回国。岂知所盗乃系赝物，午门验试之后，狄青非但无功，反招欺君之罪。赖文武力保，方得从轻治\n罪，发西北沙漠充军。先是当狄青逃回时，双阳追之未获，迨返国，其父母已为臣下所弑。双阳大愤，遂举\n兵复反，杀奔延安关。延安主帅杨宗保，屡战失利，遂调狄青到关。夫妇会阵之后，双阳痛骂无义，且泣且\n诉。狄青亦诉述获罪情形，因劝其献出二宝，投顺大宋。双阳不允，遂与激战。狄青见不能取胜，只得摆设\n五花八门阵，以擒双阳。谁知双阳怀孕适已十月，经此战阵之劳苦，遂不由人作主，一阵腹痛，而一双麟儿，\n遂呱呱堕地矣。狄青见之，亦不禁心酸泪落也。",
  "notes": "是剧系出《五虎平西》，二次征取珍珠烈火旗时。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "先行甲、先行乙同上，同拉起霸。〖点绛唇〗。"
        },
        {
          "character": "先行甲",
          "type": "念",
          "text": "将相本无种，"
        },
        {
          "character": "先行乙",
          "type": "念",
          "text": "男儿当自强。"
        },
        {
          "character": "先行甲",
          "type": "白",
          "text": "请了。今日元帅升帐，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、杨宗保同上。"
        },
        {
          "character": "杨宗保",
          "type": "粉蝶儿",
          "text": "秉忠心扶保宋朝，谁不知杨家将，建立功劳。"
        },
        {
          "character": "先行甲、先行乙",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "起过一旁。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "大将堂堂逞威风，南征北剿立奇功。杨家世代忠心耿，保定宋室锦江洪。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "老夫，杨宗保。宋室驾前为臣，官拜统兵大元帅。奉主之命，镇守延安关一带。 看帅字旗无风自动，定有军情。且等探马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "双阳讨战。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "胆大双阳，竟敢领兵前来讨战。 左右二先行听令：命你带领三千人马，大战双阳，不得有误。"
        },
        {
          "character": "先行甲、先行乙",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "先行甲、先行乙同上马，四上手引先行甲、先行乙同下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "双阳武艺高强，他二人只恐不是对手，待老夫城楼观看。"
        },
        {
          "character": "杨宗保",
          "type": "西皮流水板",
          "text": "营门以外炮声响， 人有精神马又强。 旌旗不住空飘荡， 刀枪剑戟赛秋霜。 帐中差下两员将， 去到阵前会双阳。 叫人来带过了马城楼上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上马，四龙套同转场，同下。"
        },
        {
          "character": "杨宗保",
          "type": "唱",
          "text": "去到敌楼看端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "双阳公主急跑上，趟马。"
        },
        {
          "character": "双阳公主",
          "type": "念",
          "text": "玲珑战甲扣连环，胸藏杀人巧机关。恼恨无义狄驸马，因此领兵反延安。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "奴家，双阳公主。可恨驸马狄青，在我国招了驸马，暗地盗去我国宝贝。是我 带兵追赶，也不知他用的怎么法术，将奴吓下马来，他竟自逃走。是奴回至海 外，不料我二老爹娘，俱被他们杀死。因此招兵聚将，屯军养马，来到延安， 要与那狠心强盗，见一高下。 众三军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙旗、四下手、二女兵同上。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "兵伐延安。听吾将令。"
        },
        {
          "character": "双阳公主",
          "type": "西皮倒板",
          "text": "来至在战场上传一号令，"
        },
        {
          "character": "双阳公主",
          "type": "西皮快板",
          "text": "说与大小三军听： 此番阵中来交战， 须要努力往前行。 倘若违了吾的令， 回营定斩不容情。 叫人来催马往前拥， 两军阵前大交兵。 （四上手、先行甲、先行乙同上，同起打。先行甲、先行乙同败下。四龙旗、四下手、二女兵同跑下。双阳 公主耍大刀花，下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、杨宗保同上。"
        },
        {
          "character": "杨宗保",
          "type": "四边静",
          "text": "耳听得战鼓声敲， 一阵阵马嘶人闹。 双阳武艺高， 也难免血染征袍。 到城楼且看分晓， 胜负难保。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上城。先行甲、先行乙同上，双阳公主追上，打。先行甲、先行乙同下，双阳公主追下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "看双阳杀法骁勇，待老夫亲自出马。 众三军，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、杨宗保同出城，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "双阳公主上，杨宗保上，同起打。杨宗保落马，先行甲上，双阳公主打先行甲下。"
        },
        {
          "character": "双阳公主",
          "type": "唱",
          "text": "老将被奴托下马， 霎时叫他染黄沙。 手持大刀将他砍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上。放火彩。"
        },
        {
          "character": "双阳公主",
          "type": "唱",
          "text": "又只见猛虎露爪牙。 回头便把老将叫， 走向前来把话答。"
        },
        {
          "character": "杨宗保",
          "type": "唱",
          "text": "耳旁听得有人叹， 又见双阳在阵前。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "来的老将通名。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "本帅杨宗保。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "原来是老元帅。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "老元帅。可知奴家的来意？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "公主此番前来，无非是为的江山社稷。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "奴家此来，一不是为的江山，二不是为的社稷。只求元帅，将吾国驸马狄青， 唤出城来。吾夫妻见上一面，即刻收兵。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "这有何难。待老夫调回狄青，与公主见面就是。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "如此请老元帅上马。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "提刀跨金镫，急忙转回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保下。双阳公主两看。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "众三军，收兵回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保、先行甲、先行乙同上。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "唤旗牌官走上。"
        },
        {
          "character": "先行甲、先行乙",
          "type": "同白",
          "text": "旗牌官走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "现有金牌一面，去至沙漠，速调狄先行回营。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四上手、先行甲引旗牌同上，同出城。四下手、双阳公主同上，同对先行甲。旗牌冲出，下。先行甲进城"
        },
        {
          "character": null,
          "type": "text",
          "text": "闭门。双阳公主、四下手同下。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "旗牌引刘庆、狄青同上，同转场，同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（先行甲领四上手、双阳公主领四下手自两边分上，同起打，同架枪。旗牌、刘庆、狄青同上，同闯入城。"
        },
        {
          "character": null,
          "type": "text",
          "text": "双阳公主扯狄青斗蓬，狄青跑下。先行甲入城。双阳公主看，下。）"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、先行甲、先行乙、杨宗保同上。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘庆、狄青同上。"
        },
        {
          "character": "刘庆、狄青",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "刘庆、狄青",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "将小将调回营来，不知有何军情？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "是你非知：只因你妻双阳，领兵攻打延安，十分骁勇，因此将你调回。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "既然如此，元帅传令，待小将前去会她一会。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "狄青听令：命你大战双阳，不得违误。"
        },
        {
          "character": "狄青、刘庆",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "狄青、刘庆同下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "带马观阵去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘庆上，双阳公主追上，同起打。刘庆连扑虎，败下。狄青上，双阳公主起打，架枪。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "来者敢么是驸马？"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "然也。公主请了。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "狄青呀，我把你这狠心的强盗！想你自到我国，招了驸马。你我夫妻，十分恩 爱，你不该私自逃回天朝。谁想你二次又到吾国，一盗日月骕骦马，二盗珍珠 烈火旗。宝贝到手，你就想转回天朝。是奴领兵追赶，也不知你用的怎么宝贝， 将奴吓下马来。是吾回至海外，见了吾那二老爹娘。可怜呐，可怜！"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "可怜怎么？"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "吾一双爹娘，俱被人杀死。竟害得奴，有家难奔，有国难投。今日一见，吾恨 不得食你之肉！"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "公主吓，双阳！你不提盗宝之事，倒还罢了。若提起盗宝之事，叫人好恼吓， 好恨！"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "你恨着谁来？恼的是哪个？"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "你且听道：是俺奉了圣上旨意，去到你国。一盗日月骕骦马，二盗珍珠烈火旗。 二宝到手，回转朝中。不料那圣上，派下官员，在午门验宝。谁知验宝官员 言道：这马是假马，旗是假旗。万岁闻言，龙颜大怒，就要将吾推出问斩。多 亏满朝文武，保奏下来，将我发到边外充军。叫我举目无亲，全家离散。这都 是你待我的好处呀，呀！"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "事到如今，你也不必埋怨。你随我回营去罢。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "依吾相劝，倒不如归顺天朝，倒是正理。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "你休得多言。看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "双阳公主、狄青同起打，狄青败下。杨宗保上桌，坐。双阳公主耍枪花，下。狄青上。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "启元帅：双阳公主十分骁勇，实难收服。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "这便怎好？"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "待小将摆下五花八门阵，擒她便了。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "摆上阵来。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "得令。 （狄青上马，下。四龙套、八英雄持旗同上，同摆阵。狄青上，引双阳公主入阵。狄青下。双阳公主破阵， 对八英雄，八英雄、双阳公主同起打。狄青站杨宗保身旁看。八英雄、四龙套同败下。双阳公主追下。刘庆 上。）"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "且住！看这双阳十分厉害。待吾刘庆赏他一棍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "双阳公主上，刘庆、双阳公主对打。双阳公主架刘庆大棍，刘庆抽棍打双阳公主腹。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "嗳呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "双阳公主手掩腹下。狄青随下。"
        },
        {
          "character": "杨宗保",
          "type": "唱",
          "text": "一见双阳败了阵， 不由老夫喜在心。 三军带马回营去， 先行到来便知情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（双阳公主上，急下马，坐椅，立，揉腹。狄青上，代揉腹。双阳公主扶椅做痛楚，入帐，产儿，又产儿。"
        },
        {
          "character": null,
          "type": "text",
          "text": "狄青抱二婴孩下。双阳公主做疲惫，下。）"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，杨宗保上。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "营门鼓声响，探马报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "狄青抱二婴孩上。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "启元帅：我妻双阳，产生二子。请元帅观看。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "老夫与他起名，叫做狄文、狄武便了。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "谢元帅。我妻现在帐外，请元帅定夺。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "后帐摆宴，与你夫妻贺功。待本帅奏明圣上便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹牌子。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
