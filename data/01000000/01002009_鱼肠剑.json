{
  "script_id": "01002009",
  "title": "鱼肠剑",
  "alias": [
    "子胥投吴；一名：吹箫乞食"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "专诸",
      "hangdang": "净"
    },
    {
      "name": "姬光",
      "hangdang": "老生"
    },
    {
      "name": "孙武",
      "hangdang": "老生"
    },
    {
      "name": "被离",
      "hangdang": "老生"
    },
    {
      "name": "刘展雄",
      "hangdang": "净"
    },
    {
      "name": "专诸妻",
      "hangdang": "旦"
    }
  ],
  "plot": "伍子胥逃出昭关，遇鱼丈人求渡江（剧名《芦中人》），遇濑女乞饮食（剧名《浣纱女》），且嘱勿告追兵，\n二人皆投江，以死明之。至吴国，吹萧行乞，见专诸，勇而孝，纳为兄弟。一日之市，适说吴公子阖庐出\n游，伍员随身隘巷，以箫声动之。公子闻箫声，知非常人，呼出与语。见其状魁梧奇伟，深相爱悦，载至府\n中，委以重任。并命专诸之刺王僚，卒破吴国，霸中原，皆伍子胥之力也。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "伍员",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "匹马单枪弃楚营， 龙离沧海虎奔山。 黎阳安居七夜晚， 发似银条过昭关。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺，伍员。多蒙东皋公、皇甫讷定计，救我出关。看看吴国城池不远，就此马 上加鞭。"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "一事无成两鬓斑， 恨光阴一去不回还。 日月轮流长相见， 看青山绿水在眼前。 俺伍员弃楚非本愿， 恨平王杀害我慈颜。 匹马单枪走如电， 黎阳山下遇高贤。 定计出关无风险， 马到长江有渡船。 幸得渔人行方便， 他为我投江实可怜。 浣纱女，实好善， 一饭之恩前世缘。 眼望吴国路不远， 心急求兵马加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "专诸上。"
        },
        {
          "character": "专诸",
          "type": "引子",
          "text": "爱习拳棒，论英雄，盖世无双。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸坐。"
        },
        {
          "character": "专诸",
          "type": "念",
          "text": "家住吴国在城东，孝义皆全论英雄。苍天若助三分志，拜相封侯谈笑中。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "在下专诸，乃吴国人士。胸中颇有智谋，爱习拳棒，恨俺时运未至，在这城内 开了一座肉铺。前者拉了牛二几匹牲口，帐还未清，倘若找上门来，又是一场 吵闹。正是："
        },
        {
          "character": "专诸",
          "type": "念",
          "text": "君子生平运不通，苍天为何困英雄。"
        },
        {
          "character": "牛二",
          "type": "内白",
          "text": "哽嚏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛二上。"
        },
        {
          "character": "牛二",
          "type": "念",
          "text": "可恨专诸太欺情，惹得牛儿找上门。"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "我，牛二。可恨专诸，拉了我几匹牲口，老没给钱，今天找上门去，定要与他 吵闹。正是："
        },
        {
          "character": "牛二",
          "type": "念",
          "text": "行行去去，去去行行。"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "到了。专诸开门来！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "是哪一个？"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "原来是牛二哥，请进。"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "进去就进去。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "坐下就坐下。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "牛二哥，怒气不息，为着谁来？"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "我就为你。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "为小弟何来？"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "你前两天拉了我两匹牲口，老没给钱，是何道理？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "这几日买卖不好，改日有了银钱，送上府去。"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "你没有钱，你这个店让我开了。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "哦，牛二哥要开，恭喜恭喜，开市大吉我让与你了！"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "你回来。你这个店里，什么东西都没有，等要帐的来，难道我还与你还账么？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "牛二哥不必如此，等小弟时来运转，加利奉还。"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "你还走运了，你等那走死运吧！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "专诸",
          "type": "扑灯蛾",
          "text": "牛二太欺情， 开口就伤人。 俺两膀千金力， 谁敢行凶到门厅！"
        },
        {
          "character": "牛二",
          "type": "扑灯蛾",
          "text": "专诸无理无理， 不该把我牛二欺。 恨不得一拳打死你！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛二打。三邻人、老丈同上。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "列位吓！"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "列位有所不知情， 牛二开口就伤人。 吵得街邻不安静，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛二打。"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "暂且饶你命残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸妻上。"
        },
        {
          "character": "专诸妻",
          "type": "白",
          "text": "吓，母亲唤你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸妻下。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "专诸",
          "type": "念",
          "text": "忽闻母亲唤，双手闭祸门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸下。"
        },
        {
          "character": "牛二",
          "type": "白",
          "text": "你不要逃走，出来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三邻人、老丈同相劝，三邻人、牛二同下。伍员上。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "呀。老丈请转。"
        },
        {
          "character": "老丈",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "方才这一大汉，与人争斗，出来一女子，手执拐杖，呼唤即回，莫非此人惧内 么？"
        },
        {
          "character": "老丈",
          "type": "白",
          "text": "此人名唤专诸，乃是大孝之人，这拐杖就是他母亲的拐杖，故而呼唤即回。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "敬重父母，理所当然。"
        },
        {
          "character": "老丈",
          "type": "白",
          "text": "听壮士不像此地人氏。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "本来不是此地人氏。"
        },
        {
          "character": "老丈",
          "type": "白",
          "text": "哪里人氏？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "楚国监利人氏，避难至此。"
        },
        {
          "character": "老丈",
          "type": "白",
          "text": "请到寒舍待茶。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "萍水相逢，怎好打扰。"
        },
        {
          "character": "老丈",
          "type": "白",
          "text": "改日再会。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老丈下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哦，啊呀。方才听得老丈之言：那专诸孝义兼全。我不免与他结交，若是借得 吴兵伐楚，定然助我一臂之力。正是："
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "结交要结真君子，求人须求大丈夫。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "来此已是。 吓，专兄开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸上。"
        },
        {
          "character": "专诸",
          "type": "念",
          "text": "君子不得志，低头且耐时。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "是哪一个？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "在下拜府。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "请进。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "请问老丈尊姓大名？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "在下姓伍名员，字子胥，乃楚国监利人氏。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "原来是伍将军，失敬了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "为何这等狼狈？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "专兄呀。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "恨平王无道乱楚邦， 父纳子妻乱纲常。 父兄满门具遭丧， 借兵报仇见吴王。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "今有姬千岁，招贤纳士，何不投奔那里，借兵报仇。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "本待投奔姬千岁那里，奈无机会，不敢擅入。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "就在寒舍，暂住几日。姬千岁闻知，必定前来聘请。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "若得如此，俺子胥幸也。我观专兄，孝义兼全，意欲与专兄结为昆仲，幸勿见 却。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "俺乃一介蠢夫，怎敢高攀。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺子胥真情实意，不必过谦。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "需要见过老母。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "正要叩见伯母。"
        },
        {
          "character": "专诸、伍员",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "孝意兼全人钦仰，"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "兄有事来弟挂肠。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "报仇事儿全仰仗，"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "借来吴兵灭平王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、专诸同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，姬光上。"
        },
        {
          "character": "姬光",
          "type": "引子",
          "text": "龙楼凤阁，怎能够，江山归我。"
        },
        {
          "character": "姬光",
          "type": "念",
          "text": "人无害虎意，虎有伤人心。要摘天边月，足下不生云。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "孤，姬光。适才二位先生奏道：伍子胥避难至此。不知身落何地，不免前去寻 访。 内侍，吩咐御林军走上。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "御林军走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同上。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "带马。"
        },
        {
          "character": "姬光",
          "type": "西皮原板",
          "text": "芳草青青隐翠微， 青山绿水鸟空啼。 闻得子胥到此地， 去访贤臣扶社稷。 御林军摆驾出城地， 亲自去访伍子胥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "行过东来又转西， 举目无亲独自悲。 衣衫褴褛谁周济， 竹箫焉能免得饥。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺，伍员。自从与专诸结拜，闲住苏城，衣衫典尽，衣履全无，只落的乞讨之 中。天吓，天吓，想俺伍员，堂堂奇男子，烈烈大英雄，只落得吹箫讨饭吓！"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "姜子牙无事隐钓溪， 时衰运败鬼神欺。 周姬昌梦飞熊夜扑帐里， 亲访贤臣兴社稷。 东迁洛邑王纲坠，"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "战将刀枪何日离。 伍员单人把楚弃， 父母冤仇气不息。 要借吴兵心少计， 我与姬光会无期。 英雄落魄如蝼蚁， 手拿竹箫讨饭吃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬光、四御林军、太监甲同上。"
        },
        {
          "character": "姬光",
          "type": "西皮快板",
          "text": "孤王打马出宫闱， 姑苏城内多光辉。 勒住马头用目望，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员吹箫。"
        },
        {
          "character": "姬光",
          "type": "西皮快板",
          "text": "见一老臣相貌奇： 鹤发童颜少年纪， 手拿竹箫信口吹。 勒马停蹄街头立， 且听来人他是谁。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "子胥抬头用目望，"
        },
        {
          "character": "伍员",
          "type": "西皮流水板",
          "text": "见一位官长相貌奇： 头戴金冠双龙戏， 身上穿的龙凤衣。 龙眉凤目非凡体， 想是天子下瑶池。 莫非他就是姬千岁， 有意来访我伍子胥。 上前通名去见礼， 冠破衣穿不整齐。 眉头一皱心生计， 把我冤仇提一提。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "天吓，天吓！"
        },
        {
          "character": "伍员",
          "type": "反西皮摇板",
          "text": "子胥阀阅门眉第， 到如今落魄天涯有谁知。 父母的冤仇沉海地， 我好比凤脱翎毛怎能飞？ 伍子胥，伍明辅，父母的冤仇不能报，爹娘吓！"
        },
        {
          "character": "姬光",
          "type": "西皮快板",
          "text": "听罢言来我心喜， 来的果是伍子胥。 本当向前把话启， 猛然一计在心里。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "内侍，唤那吹萧之人向前答话。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "是。 那一汉子，我家千岁，唤你上前答话。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "听说千岁传子胥， 愁人脸上笑嘻嘻。 走上前来忙见礼， 愿君福寿与天齐。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "家住哪里，姓甚名谁，一一讲来。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "千岁吓！"
        },
        {
          "character": "伍员",
          "type": "西皮二六板",
          "text": "富贵穷通不由己， 也是我时衰命运低。 我本是楚国功臣家住在监利， 我的父伍奢保华夷。 恨平王无道纳儿媳， 信用那奸贼费无极。 我的父谏奏反诛死， 又杀我满门实惨凄。 闻千岁招贤纳士多仁义， 还望你拿云仙手你把难人提。 伍子胥若得这步地， 知恩报德不敢移。"
        },
        {
          "character": "姬光",
          "type": "西皮摇板",
          "text": "闻得将军多仁义， 今日一见果是实。 内侍摆驾回宫里， 我与将军叙军机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。伍员换衣。孙武、被离同上。"
        },
        {
          "character": "孙武、被离",
          "type": "同西皮摇板",
          "text": "慢步且把宝帐进， 见了主公说分明。"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "罢了，见过伍将军。"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "吓，伍将军。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "二位先生请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘展雄上。"
        },
        {
          "character": "刘展雄",
          "type": "白",
          "text": "吓，"
        },
        {
          "character": "刘展雄",
          "type": "西皮摇板",
          "text": "正在后帐把箭比， 听说来了伍子胥。 慢步且进宝帐里， 仁兄为何白了须？"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "手挽手儿叫贤弟， 恨平王无道纳儿媳。 擅杀忠良当儿戏， 兄来借兵你莫心疑。"
        },
        {
          "character": "刘展雄",
          "type": "西皮摇板",
          "text": "仁兄点动人和马， 再与昏王见高低。"
        },
        {
          "character": "刘展雄",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "二位先生，伍将军到此，大事可能成功？"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "还是不能成功。须必要有一粗心胆大之人，方能成功。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "这粗心胆大之人哪里有？"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "自然有。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "启禀千岁：臣有一义弟，名唤专诸。此人义孝皆全，大可委用。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "内侍，带定黄金千两，随伍将军前去聘请。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "有道有德光恩义， 敬贤礼士称第一。 辞王别驾奉聘礼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、太监甲同下。"
        },
        {
          "character": "姬光",
          "type": "西皮摇板",
          "text": "得了楚国伍子胥。 孤王江山可得的？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、专诸同上。"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "有劳仁兄把我提。 进帐前行君臣礼，"
        },
        {
          "character": "姬光",
          "type": "西皮摇板",
          "text": "壮士果然世间稀。 君臣对作把话理，"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "风吹云散见虹霓。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "草民有何德能，敢劳千岁，下此聘礼。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "些些小事，何劳挂齿。二位先生，大事可能成功？"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "兄皇平常所爱何物？"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "所爱鲜鱼。"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "就把鲜鱼刺之。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "我兄皇内穿膛鳞袄，刀枪不入。"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "膛鳞袄的怕是鱼肠剑。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "鱼肠剑哪里有？"
        },
        {
          "character": "被离",
          "type": "白",
          "text": "吓，世兄，我下山之时，师傅赐我宝剑，名曰匕首，世兄请看。"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": "孙武",
          "type": "念",
          "text": "“内破膛鳞袄，外面刺王僚。”"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "正是此物。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "有了鱼肠剑，可能成功？"
        },
        {
          "character": "孙武、被离",
          "type": "同白",
          "text": "必须有酒宴前行刺之人，方能成功。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "这就难了。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "千岁，俺专诸不才，情愿行刺那王僚。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "我兄皇战将千员，壮士有性命之忧。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "千岁，草民家有八旬老母，还望千岁另眼看待。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "我若错待伯母，叫我天诛地灭。内侍，看过黄金千金，回去拜到伯母，就说孤 不不了。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "多谢千岁赐黄金， 回家禀报老娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸下。"
        },
        {
          "character": "姬光",
          "type": "西皮摇板",
          "text": "内侍将酒来摆定， 我与众卿诉军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}