        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "有人么？"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "什么人？"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "挂号过关。"
