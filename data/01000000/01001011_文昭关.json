          "text": "与图形相似。"
        },
        {
          "character": "米南适",
          "type": "白",
          "text": "传进。"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "呔！传进！"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "小人挂号的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "米南适看。"
        },
        {
          "character": "米南适",
          "type": "白",
          "text": "来，绑赴帅府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同绑皇甫讷，众人同下。"
