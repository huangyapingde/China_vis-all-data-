          "character": "王伯党",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "杀夫之仇她不想， 一心只想配鸾凰。 事已至此假言诓， 且自贪生作商量。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "要俺归顺，依俺三件大事，"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "是哪三件？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "头一件，四门俱插降旗。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "使不得！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "使得的，使得的，第二件？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "第二件，迎接瓦岗众好汉进关。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "夫人，使不得！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "也使得的，使得的。第三件？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "第三件，拜堂三天，方可成亲。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "越发使不得！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "这个，件件依从。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我来松绑。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "待我与你松绑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏松绑。〖吹打〗。东方氏更衣。〖牌子〗。东方氏、王伯党同拜，同饮酒。"
        },
        {
          "character": "老军",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军上，四龙套同暗上。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "报什么？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "瓦岗……"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "瓦岗好汉作什么？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "贼子前来讨仗。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "住了，今日夫人喜事，你敢在此胡言乱道。 来，推出斩了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套推老军同下。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "今乃良辰吉日，若斩此人，恐与花烛不利。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "夫人，新姑老爷说情是要准的。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "哦，是要准的。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "斩将赦回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套推老军同上。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "唗！看在新姑老爷份上，死罪以免，活罪难饶。 来，重责四十！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套两边同打。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "谢夫人责！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "谢谢新姑老爷！"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "谢谢夫人。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "谢姑老爷。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "谢了夫人。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "滚了出去！"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "不要推，让、让我走罢。咦，两家头作什么。 丫鬟姐姐，他们做什么？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "两家头配了夫妻呢。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "老军",
          "type": "念",
          "text": "为了小白面，拷我屁股眼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军下。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "吓，将军，今有令箭一支，迎接瓦岗弟兄进城。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "多谢夫人，请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏、丫鬟同下。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "下面听者，夫人有令：将四门大开，迎接瓦岗众好汉进城！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}