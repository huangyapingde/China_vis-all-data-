          "text": "王伯党、四龙套同上。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "众好汉，车辆伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "辛文礼、四黑龙套同上，会阵，王伯党下，辛文礼排阵，追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "单雄信、谢映登、徐国远、程咬金同上，王伯党上。"
        },
        {
          "character": "单雄信、谢映登、徐国远、程咬金",
          "type": "同白",
          "text": "辛文礼杀法厉害，如何是好？"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "待俺用箭射他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "辛文礼上，王伯党射，辛文礼中箭，下。老军上，观阵，王伯党、单雄信、谢映登、徐国远、程咬金同下。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "且住，老爷被王伯党一箭射死，不免报与夫人知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "东方氏上，丫鬟上。"
        },
        {
          "character": "东方氏",
          "type": "念",
          "text": "旌旗招展空中飘，"
        },
        {
          "character": "丫鬟",
          "type": "念",
          "text": "不知谁胜与谁强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军上。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "启禀夫人：大事不好了。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "老爷被王伯党一箭射死！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "你待怎讲。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "老爷被王伯党射死了！"
        },
        {
          "character": "东方氏",
          "type": "三叫头",
          "text": "老爷，吾夫，哎呀夫呀！"
        },
        {
          "character": "东方氏",
          "type": "西皮导板",
          "text": "停说老爷把命丧，"
        },
        {
          "character": "东方氏",
          "type": "西皮摇板",
          "text": "好似钢刀刺胸膛。 骂声贼子王伯党，"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "贼子呀！"
        },
        {
          "character": "东方氏",
          "type": "西皮摇板",
          "text": "兴兵定要扫瓦岗。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "吓，夫人点动兵将，与老爷报仇才是！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "丫鬟言之极是，传我将领：吩咐大小将官，齐穿孝服，灵堂听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏叫头，下。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "下面听者，夫人有令：大小将官，全身披挂，灵堂听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、老军同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "灵堂布景。白袍将甲上，起霸。"
        },
        {
          "character": "白袍将甲",
          "type": "念",
          "text": "老爷阵前把命丧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白袍将乙上，起霸。"
        },
        {
          "character": "白袍将乙",
          "type": "念",
          "text": "夫人领兵到战场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白袍将丙上，起霸。"
        },
        {
          "character": "白袍将丙",
          "type": "念",
          "text": "生擒活捉王伯党，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白袍将丁上，起霸。"
        },
        {
          "character": "白袍将丁",
          "type": "念",
          "text": "破腹挖心祭灵堂！"
        },
        {
          "character": "白袍将甲",
          "type": "白",
          "text": "列位请了，夫人发兵，两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同上，东方氏上，老军上。东方氏哭，祭奠。"
        },
        {
          "character": "东方氏",
          "type": "三叫头",
          "text": "老爷，吾夫，夫呀！"
        },
        {
          "character": "东方氏",
          "type": "西皮导板",
          "text": "身穿缟素在灵堂，"
        },
        {
          "character": "东方氏",
          "type": "三叫头",
          "text": "老爷，吾夫，老爷呀！"
        },
        {
          "character": "东方氏",
          "type": "西皮摇板",
          "text": "心似刀绞两泪汪。 你今出兵把命丧， 妻报夫仇灭瓦岗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。东方氏拜。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "众位将军，只因老爷，被王伯党射死。今日兴兵，乃是替夫报仇，烦众位将军， 必须奋勇当先才是。"
        },
        {
          "character": "四白袍将",
          "type": "同白",
          "text": "老爷为国忘身，我等敢不努力当先！情愿战死沙场！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "列为请上，受我一拜！"
        },
        {
          "character": "东方氏",
          "type": "西皮摇板",
          "text": "双膝跪在二堂上， 列位将军要争强。 一起同至战场上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏上马。"
        },
        {
          "character": "东方氏",
          "type": "西皮摇板",
          "text": "不报夫仇不还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同出城。单雄信上，会阵。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "老爷单雄信！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏、单雄信同开打，单雄信败下。谢映登、徐国远上同上，会阵。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "谢映登",
          "type": "白",
          "text": "谢映登！"
        },
        {
          "character": "徐国远",
          "type": "白",
          "text": "徐国远！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏、谢映登、徐国远同开打，谢映登、徐国远同败下。程咬金上，会阵。"
        },
