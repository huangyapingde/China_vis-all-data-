{
  "script_id": "01008006",
  "title": "虹霓关",
  "alias": [
    "伯党招亲；一名：替夫报仇"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "东方氏",
      "hangdang": "旦"
    },
    {
      "name": "丫鬟",
      "hangdang": "正旦"
    },
    {
      "name": "王伯党",
      "hangdang": "小生"
    },
    {
      "name": "辛文礼",
      "hangdang": "净"
    },
    {
      "name": "老军",
      "hangdang": "丑"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    }
  ],
  "plot": "隋末天下纷争，群雄扰攘，各路之中，瓦岗寨尤为劲寇，所向无敌。隋虹霓关守将辛文礼，臂力过人，勇不\n可当。瓦岗诸将屡战不能克，关为所阻，旋被王伯党以冷箭伤之。辛妻东方氏，虽绝世丽人，而蛮靴窄袖，\n枪马绝伦，誓欲为夫报仇，血刃王伯党，以洩此恨。始与瓦岗诸将遇战，不数合瓦岗将皆败北而退，继而见\n王伯党至，其部下偏裨牙卒，无不咬牙切齿，格外奋勇，以助夫人威。咸以为夫人此际，一见仇人之面，定\n必如评话家所说“怒从心上起，恶向胆边生”矣。不意方一照面，夫人甫启齿问罪，即一阵眼花缭乱，手震\n颜沩頳，娇躯险些从马上坠下，继而复四目向观：我这里觑个出神，他那里也瞧个饱，按兵不动，弄得两下\n里的兵丁都惊诧不定，并且惊诧了一阵，也都个个看呆。直至数分钟之后，被一阵擂鼓声惊醒，方再交战。\n王伯党虽勇，卒被擒获，继而押解王伯党入关。两廊众将士，均欢声雷动，庆得仇人而甘心，频频催夫人下\n令行刑，以祭主帅。惟夫人则恋恋不忍杀，反屡以软语挑王伯党。耐王伯党性甚刚勇，坚不许。夫人不得已，\n复遣侍儿往说，王伯党以三事向要，夫人无不一一允从，乃为之撮合，二人遂为夫妇焉。而王伯党于是乎\n降东方矣，而东方于是乎以虹霓关降瓦岗寨矣。呜呼是为夫妻之爱情。",
  "notes": "此剧后半本颇有可观，然极难描绘。而尤以去侍儿者为重要角色。梅兰芳最善演此，玲珑剔透，娇小聪明，\n真可儿也。贾璧云、四盏灯亦颇不弱。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四黑龙套、老军、辛文礼同上。〖点绛唇〗。"
        },
        {
          "character": "辛文礼",
          "type": "念",
          "text": "昨晚天上落将星，吉凶二字尚未明。我今镇守虹霓地，要把瓦岗一扫平。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "某，辛文礼。奉主旨意，镇守虹霓。可恨瓦岗贼子，屡次攻打。为此每日操演 兵将，以备抵御。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "瓦岗讨战。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "且住，瓦岗贼子前来讨战。 来，掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四黑龙套同下。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏、丫鬟同上。"
        },
        {
          "character": "东方氏",
          "type": "念",
          "text": "夫乃隋朝将，"
        },
        {
          "character": "丫鬟",
          "type": "念",
          "text": "皇家一栋梁。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "吓，老爷。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "夫人请坐。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "可恼吓，可恼！"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "老爷为何这等烦恼？"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "今有瓦岗贼子，屡次前来讨战。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "既然瓦岗兴兵前来，老爷就该出关迎战。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "本当出关迎敌，奈昨晚一梦，大为不祥。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "老爷身为大将，说什么“梦寐”二字。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "关中无人把守。"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "关中之事有妾身料理。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "夫人可记得西施之故事？"
        },
        {
          "character": "东方氏",
          "type": "白",
          "text": "呀，"
        },
        {
          "character": "东方氏",
          "type": "西皮摇板",
          "text": "听他言来自猜详， 羞得奴家脸无光。 双膝跪在二堂上， 过往神灵听一声： 若把夫妻恩情忘，"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "哽。"
        },
        {
          "character": "东方氏",
          "type": "西皮摇板",
          "text": "三尺青锋一命亡。"
        },
        {
          "character": "辛文礼",
          "type": "西皮摇板",
          "text": "一见夫人把誓盟， 不由某家喜在心。 夫人请到后堂进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方氏、丫鬟同下。四黑龙套同上。"
        },
        {
          "character": "辛文礼",
          "type": "西皮摇板",
          "text": "再叫众将听分明。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "众将官，迎敌去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、单雄信、谢映登、徐国远、程咬金同上，秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "千军列队伍，万马扎团营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "辛文礼讨战。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "众位贤弟，攻打头阵！"
        },
        {
          "character": "单雄信、谢映登、徐国远、程咬金",
          "type": "同白",
          "text": "遵命。 （秦琼下。辛文礼上，单雄信、谢映登、徐国远、程咬金同会阵，同开打，单雄信、谢映登、徐国远、程咬 金同败下，辛文礼追下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王伯党上，四车推粮同上。"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "奉命解粮路崎岖， 戴月披星马蹄忙。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "俺，王伯党。今奉秦二哥将令，催趱粮草，军前应用。行了数日，离大营不远。 呔，催粮前往。"
        },
        {
          "character": "王伯党",
          "type": "西皮摇板",
          "text": "粮草已缴心已放， 个个有赏升钱粮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信、谢映登、徐国远、程咬金同上。"
        },
        {
          "character": "单雄信、谢映登、徐国远、程咬金",
          "type": "同白",
          "text": "参见贤弟。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "众位大哥为何这等模样？"
        },
        {
          "character": "单雄信、谢映登、徐国远、程咬金",
          "type": "同白",
          "text": "辛文礼厉害。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "众位大哥不必惊慌，待小弟接杀一阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信、谢映登、徐国远、程咬金同下。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "呔，众好汉，迎上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "辛文礼上，王伯党上，会阵，王伯党败下，辛文礼追下。"
        }
      ]
    },
    {
