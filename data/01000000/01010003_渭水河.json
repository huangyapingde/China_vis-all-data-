{
  "script_id": "01010003",
  "title": "渭水河",
  "alias": [
    "文王访贤；一名：八百八年"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "姬昌",
      "hangdang": "老生"
    },
    {
      "name": "姜尚",
      "hangdang": "净"
    },
    {
      "name": "太子甲",
      "hangdang": "小生"
    },
    {
      "name": "太子乙",
      "hangdang": "小生"
    }
  ],
  "plot": "西伯姬昌（即文王）夜梦飞熊入帐，明日召散宜生卜之，谓主得贤臣良佐，可往山林中亲访之。文王乃出猎\n渭滨，以访遗贤。途遇释犯武吉，询其何以不投案伏罪。武吉谓因遇见渭滨一渔父，授以避脱之法。文王问\n渔父何名。武吉告以姓姜名尚，道号飞熊，年老才高，素谙韬略。文王闻之大喜，且其道号，适应其梦。乃\n令武吉引往。见姜尚童颜鹤发，悠然垂钓，意其闲适。武吉告以故，姜尚乃答礼。文王询以政事。姜尚纵横\n议论，指陈大势，如谈家常。文王惊为非常人，即亲自推毂，载之以归，拜为上相。后文王薨，子姬发立\n（即武王）。姜尚乃辅佐姬发，会师伐纣，遂启周代八百余年天下。故又名《八百八年》。",
  "notes": "此剧系本正史中“飞熊入梦”一典，并略据旧说部《封神传》中事实，以演绎而成。昆剧中亦有此戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、姬昌同上。"
        },
        {
          "character": "姬昌",
          "type": "引子",
          "text": "为立帝基，一路平安，到西岐。"
        },
        {
          "character": "姬昌",
          "type": "念",
          "text": "纣王无道宠妲己，为国忠良受凌逼。将孤发在西岐地。重整山河与社稷。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "孤西伯侯姬昌。只因那日有樵夫武吉，将孤门军打死，是孤将他问罪。那一樵 子奏道，家有八旬老母，无人侍奉。孤赐他斗米串钱，回得家去，见母一面， 再来抵罪。一去数十余天，还不见到来。 内侍，香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监同允。"
        },
        {
          "character": "姬昌",
          "type": "二黄原板",
          "text": "摇动金钱祝上苍， 八卦之中走一忙。 单对单来拆对拆， 看不见武吉身落何方。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "我道此人还在，却原来亡故了，可叹吓，可叹。 两厢退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监同下。"
        },
        {
          "character": "姬昌",
          "type": "二黄原板",
          "text": "孤王建业在西方， 为争江山昼夜忙。 东路反了姜文焕， 南路燕山有伤亡。 闷恹恹卧至在锦纱帐， 好似悠悠梦一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "飞熊上。"
        },
        {
          "character": "姬昌",
          "type": "二黄导板",
          "text": "孤王正在睡朦胧，"
        },
        {
          "character": "姬昌",
          "type": "二黄摇板",
          "text": "见一飞熊入帐中。 手使宝剑将它砍， 一阵狂风影无踪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上。"
        },
        {
          "character": "姬昌",
          "type": "二黄摇板",
          "text": "四内臣摆驾进银安， 不知吉来不知凶。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "内侍，宣散宜生进见。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "大王有旨，宣散宜生进帐。"
        },
        {
          "character": "散宜生",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "散宜生上。"
        },
        {
          "character": "散宜生",
          "type": "念",
          "text": "袖算乾坤大，怀揣日月长。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "平身赐坐。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "谢坐。宣臣进帐，有何事议论？"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "孤王昨晚三更，偶得一兆，见一飞熊入帐，将孤左膀扑了一爪。不知吉凶。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "大王郊外访贤，必得贤臣良将。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "替孤传旨。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "姬昌",
          "type": "念",
          "text": "昨夜飞熊入帐中，"
        },
        {
          "character": "散宜生",
          "type": "念",
          "text": "郊外射猎访贤臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "武吉上。"
        },
        {
          "character": "武吉",
          "type": "念",
          "text": "胆大天下能去，刚强寸步难行。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "小子武吉。前日上山砍樵，误撞千岁御道，将他门军打死。姬千岁拿我问罪。 是我奏道，家有八旬老母，无人侍奉。千岁赐我斗米串钱，回家安顿老母，限 我七日前去领罪。是我行到渭水河边，偶遇一白发渔翁，他见我面带杀气，言 道必遭凶事。我将打死门军之事，对他言讲一遍。他教我小小法儿：回得家去， 老母床前，挖一土阱，深要七尺，宽要丈二，口衔灯芯糯米，睡在里面。躲 过七七四十九日，方保无事。今乃四十八日，老母肚中饥饿，将我唤醒，上山 砍樵。正是："
        },
        {
          "character": "武吉",
          "type": "念",
          "text": "上山擒虎易，开口告人难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武吉下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "南宫适、北宫高、辛甲、辛免同上，同起霸。〖点绛唇〗。"
        },
        {
          "character": "南宫适",
          "type": "白",
          "text": "南宫适。"
        },
        {
          "character": "北宫高",
          "type": "白",
          "text": "北宫高。"
        },
        {
          "character": "辛甲",
          "type": "白",
          "text": "辛甲。"
        },
        {
          "character": "辛免",
          "type": "白",
          "text": "辛免。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "请了。主公发兵，两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、二太子、姬昌同上。"
        },
        {
          "character": "姬昌",
          "type": "念",
          "text": "点动兵和将，郊外访贤良。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "吩咐兵发郊外！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫适、北宫高、辛甲、辛免同允。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "兵发郊外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。武吉上。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "武吉当道。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "哽，胆大武吉，前番将孤门军打死，孤王将你问罪。你言道家有八旬老母，无 人侍奉。孤赐你斗米串钱，叫你回家安顿老母，限你七日前来领罪。为何一去 数十余日，该当何罪？"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "前番小人，将千岁门军打死，问罪于我，是我言道，家有八旬老母，无人侍奉。 千岁赐我斗米串钱，安顿老母。行至渭水河边，遇一白发渔翁，见我面带杀 气，说我必遭凶事。是我将打死门军之事一说，他教我小小法儿：在母亲床前 挖掘一坑，口衔灯芯糯米，躲过七七四十九日，方保无事。今乃四十八日，老 母肚中饥饿，将我唤醒上山砍樵，又撞了千岁御道。情愿领罪。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "渔翁现在何处？"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "现在渭水河边。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "放下柴担，领孤前去。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "启禀父王：郊外访贤，必须改换便衣。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。姬昌更衣。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "郊外伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫适、北宫高、辛甲、辛免、四龙套同下。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "武吉带路。"
        },
        {
          "character": "姬昌",
          "type": "二黄原板",
          "text": "樵夫道那渔翁颇有奥妙， 因此上为王的亲走这遭。 叫武吉你与我向前引导， 青的山绿的水难画难描。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜尚上。"
        },
        {
          "character": "姜尚",
          "type": "二黄原板",
          "text": "纣王无道贪色酒， 午门外造下了摘星楼。 比干丞相破心口， 贾氏夫人坠雕楼。 一步儿来至在渭水河口， 那一旁又来了西伯王侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬昌、二太子、武吉同上。"
        },
        {
          "character": "姬昌",
          "type": "二黄原板",
          "text": "太平鸟止不住空中叫， 叫得孤王心内焦。 土台上坐的是白发老道， 手提着钓鱼竿独自在逍遥。 孤看他倒有那仙家奥妙， 二皇儿上前去细问根苗。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "领旨。 渔翁请了。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "钓钓钓，大鱼不到小鱼到。用你不着，去罢。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "小王与你深施一礼，为何扬而不睬？"
        },
        {
          "character": "姜尚",
          "type": "念",
          "text": "几载未见尘劳倦，见了明君方开言。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "好大的口气。 启禀父王：那渔翁讲了两句淡话。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "哪两句淡话？"
        },
        {
          "character": "二太子",
          "type": "同念",
          "text": "几载未见尘劳倦，见了明君方开言。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "你二人敢是慢怠于他？"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "儿不敢。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太子同下。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "渔翁请来见礼。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道稽首。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "口称稽首，在哪座名山修炼？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "昆仑山修炼。稽首为尊。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "在此作甚？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "在此垂钓。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "钓的何物？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "西海鳌。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "小小钓竿，也能钓得鳌起？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "钓竿虽小，能坠千斤。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "借钓一观。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "为何用直钩垂钓？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道心直性直，愿者上钩。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "但不知谁愿谁不愿？"
        },
        {
          "character": "姜尚",
          "type": "念",
          "text": "耐烦等到春雷到，自有鱼儿来上钩。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "请问道者上姓？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道姓姜名尚字子牙，道号飞熊。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "哎呀且住，想这“飞熊”二字，正应孤的梦兆。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "请问军爷上姓？"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "西伯侯姬昌。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "原来是姬千岁，失敬了。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "不在西岐，来在荒郊作甚？"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "请先生扶保周室江山。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "才疏学浅，不敢当此重任。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "不必推辞。 武吉，封你开路先锋，准备车辇伺候。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武吉下。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "先生请。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "姬昌",
          "type": "二黄原板",
          "text": "久闻先生今相见，"
        },
        {
          "character": "姜尚",
          "type": "二黄原板",
          "text": "姜子牙八十二岁会名贤。"
        },
        {
          "character": "姬昌",
