        {
          "character": "秦仁、呼延豹",
          "type": "同白",
          "text": "趁此昏暗之间，你我越城而进，找寻高登去者！"
        },
        {
          "character": "花逢春、秦仁、呼延豹、徐世英",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "花逢春、秦仁、呼延豹、徐世英",
          "type": "同合头",
          "text": "早救取姣怯怯女娉婷， 管叫那恶贼知名， 要南阳百姓钦敬！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春、秦仁、呼延豹、徐世英同下。"
        }
      ]
    },
    {
