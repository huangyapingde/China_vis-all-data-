{
  "script_id": "01011009",
  "title": "拿高登",
  "alias": [
    "艳阳楼；一名：大破仙人担"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "高登",
      "hangdang": "武生"
    },
    {
      "name": "徐世英",
      "hangdang": "武净"
    },
    {
      "name": "花逢春",
      "hangdang": "武生"
    },
    {
      "name": "徐母",
      "hangdang": "老旦"
    },
    {
      "name": "徐飞珠",
      "hangdang": "旦"
    },
    {
      "name": "贾斯文",
      "hangdang": "丑"
    },
    {
      "name": "王氏",
      "hangdang": "花旦"
    },
    {
      "name": "奶娘",
      "hangdang": "彩旦"
    }
  ],
  "plot": "宋奸臣高俅之子高登，善武艺，好渔色。寻常每率教师走狗辈，野出打围射猎，兼籍此强抢民间妇女。南阳\n一带，颇患之如虎。其门客贾斯文，专为侦察，尤助桀为虐。日者登率诸门客，载酒出游蟠桃宫，并乘兴打\n围。时适清明节左右，遇青面虎徐世英偕其母妹扫墓。登见其妹徐飞珠貌颇娟秀，即令家人等强掠归，欲纳\n为妾。徐飞珠坚不从，高登将其藏之艳阳楼中。时青面虎见妹被抢，急奋力追赶，已不及。途遇花逢春等数\n人，向之问讯，花逢春等因见其神色匆遽，还诘情由，青面虎备述之，花逢春等即愿出相助，同往追夺。于\n黑夜越墙入，各出死力猛斗，卒被夺回，并拿获高登杀之，以除民害。",
  "notes": "此剧以杨小楼为最擅名，从前筱菊笙亦颇拿手。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八云童、四幡童仙、金刀圣母同上。〖点绛唇〗。"
        },
        {
          "character": "金刀圣母",
          "type": "赏花时",
          "text": "一片祥光，拥护五云飘。 正三春，齐集瑶池祝寿考。 恁看那鹤发来九霄， 老人欢乐，仙母年高。 帅洞府中群仙真，笑舞赴蟠桃。"
        },
        {
          "character": "金刀圣母",
          "type": "念",
          "text": "极月春时起波涛，是处歌声引仙敖。瑶池赴会歌声远，异香馥郁簇仙桥。"
        },
        {
          "character": "金刀圣母",
          "type": "白",
          "text": "吾乃金刀圣母是也。恰在瑶池，同赴蟠桃盛会。梨山老母言道：南阳徐氏飞珠， 与我有仙缘之份，后配花门为婚。此乃天运已定，岂可违误。 侍从们！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四幡童仙同允。"
        },
        {
          "character": "金刀圣母",
          "type": "白",
          "text": "驾云往南阳去者！"
        },
        {
          "character": "金刀圣母",
          "type": "清江引",
          "text": "雨雨风风感动天和召， 人寿年丰桑田不辞劳。 万民义集到，百货云风好， 烟茫茫名缰利锁绕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花逢春上。"
        },
        {
          "character": "花逢春",
          "type": "引子",
          "text": "怀揣忠勇，困风尘，一任苍天捉弄！"
        },
        {
          "character": "花逢春",
          "type": "念",
          "text": "英名气概勇绝群，风云未遇久旱停。他年若得男儿志，仗剑除奸灭佞臣！"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "俺，花逢春。吾父花荣，当日梁山结义，被奸贼所害。是我隐居南阳西村，务 农为业。今乃三月三日，乃蟠桃宫胜会之期，约定秦仁、呼延豹二位贤弟，同 去游玩，怎么还不见到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "秦、呼二位爷到。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦仁、呼延豹同上。"
        },
        {
          "character": "秦仁",
          "type": "念",
          "text": "生平不说封侯事，"
        },
        {
          "character": "呼延豹",
          "type": "念",
          "text": "务农为业第一尊！"
        },
        {
          "character": "秦仁、呼延豹",
          "type": "同白",
          "text": "兄长。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "二位贤弟少礼，请坐。"
        },
        {
          "character": "秦仁、呼延豹",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "二位贤弟，今日来得为何甚迟？"
        },
        {
          "character": "秦仁、呼延豹",
          "type": "同白",
          "text": "因挑选良马一匹，与兄长乘骑，故尔来迟。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "承领了！可曾用过早膳？"
        },
        {
          "character": "秦仁、呼延豹",
          "type": "同白",
          "text": "用过了。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "家院带了酒肴，同到蟠桃宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子允。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "啊，二位贤弟，就此去者。"
        },
        {
          "character": "秦仁、呼延豹",
          "type": "同白",
          "text": "请啊！"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "三春花柳堪玩赏， 万紫千红馥馥香。"
        },
        {
          "character": "秦仁",
          "type": "西皮摇板",
          "text": "催马扬鞭路途上，"
        },
        {
          "character": "呼延豹",
          "type": "西皮摇板",
          "text": "游人如蚁携酒觞。"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "三人玩会开怀畅， 蟠桃宫内先拈香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文上。"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "春波青草绿柳杨， 牧童吹笛在山旁。"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "学生贾斯文，乃是南阳府内第一才子。多蒙高大爷抬举，请我在府中做一幕宾 先生。恰喜大奶奶又看中了我哪，拉我每夜饮酒取乐，万一想不到的快活。今 日城外蟠桃宫胜会，高大爷带领教师爷前去玩会，叫我先去料理一切。出得城 来，果然好春色也！"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "沿路桃花齐开放， 幼女纷纷女姣娘。 催马加鞭朝前望， 游人个个说短长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春、秦仁、呼延豹同上。"
        },
        {
          "character": "花逢春、秦仁、呼延豹",
          "type": "同西皮摇板",
          "text": "催马加鞭往前闯， 那旁好似贾同窗。"
        },
        {
          "character": "花逢春、秦仁、呼延豹",
          "type": "同白",
          "text": "啊，贾兄往哪里去？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "小弟奉了高大爷之命，前往蟠桃会料理会事。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "哪个高大爷？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "就是当朝太尉高俅之子，名叫高登。"
        },
        {
          "character": "秦仁、呼延豹",
          "type": "白",
          "text": "就是那高俅之狗子！"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "啊，贾兄，彼此同窗好友，怎么为他人所事，岂不有辱斯文！"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "非也，小弟蒙高大爷十分敬重，请我为幕宾，府中大小之事，都是我一人料理。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "原来如此！同到蟠桃宫再叙。"
        },
        {
          "character": "花逢春、贾斯文",
          "type": "同白",
          "text": "请啊！"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "手提丝缰向前荡，"
        },
        {
          "character": "秦仁、呼延豹",
          "type": "同西皮摇板",
          "text": "可笑倚仗小豺狼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春、秦仁、呼延豹同下。"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "三人跨马气昂昂， 同心合意甚猖狂。 有朝触怒心头上， 叫他全家尽遭殃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、高登同上。"
        },
        {
          "character": "高登",
          "type": "西皮摇板",
          "text": "我父巍巍镇朝纲， 太尉极品非寻常。 荣华富贵谁肯让， 区区地土占南阳。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "某，高登。我父高俅，在朝官居极品。俺习学拳棒，未能精通，又蒙蔡相爷着 禁军教头楚云龙、金元伯、蔡秀、薛安等，逐日与我演习武艺，件件皆能，不 日面君受职。这且不言。今乃蟠桃宫胜会，不面带领教师，前去玩会。二来行 围射猎，酒乐一回，有何不可。 来，有请众位师爷。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有请众位师爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四教师同上。"
        },
        {
          "character": "教师甲",
          "type": "念",
          "text": "清明时节在新春，"
        },
        {
          "character": "教师乙",
          "type": "念",
          "text": "绿柳才黄半未匀。"
        },
        {
          "character": "教师丙",
          "type": "念",
          "text": "若待上林花似锦，"
        },
        {
          "character": "教师丁",
          "type": "念",
          "text": "出门俱是看花人。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "参见大爷。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "众位师爷少礼。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "唤我等出来，有何吩咐？"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "今乃蟠桃宫胜会，一同出城玩会。顺到凤凰山行围射猎，大家酒乐一回。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "我等奉陪。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "来，将射猎物件，预备齐整，就此出城去者，带马！"
        },
        {
          "character": "高登",
          "type": "金上花",
          "text": "太尉府第馨香香， 父子威名震南阳。 催马出城心欢畅， 玩会处处看红妆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。徐福上。"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "梨花开放如白玉，桃花开时似火红。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐飞珠上。"
        },
        {
          "character": "徐飞珠",
          "type": "引子",
          "text": "小圃幽雅有趣，粉黛欲穿花瑛。"
        },
        {
          "character": "徐飞珠",
          "type": "白",
          "text": "母亲万福。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "徐飞珠",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身乃徐世英之母，女儿飞珠。只因老相国亡故，我儿终日习武，若得成名之 日，徐氏门中有望。"
        },
        {
          "character": "徐飞珠",
          "type": "白",
          "text": "母亲但放宽心，兄长生性有志，武艺刚强，日后定是皇家栋梁。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": "徐母",
          "type": "西皮原板",
          "text": "思想起儿的父征辽扫荡， 回朝时论功勋封爵朝廊。 为高俅有旧恨蒙惑君上， 因此上辞官职退归南阳。"
        },
        {
          "character": "徐飞珠",
          "type": "西皮原板",
          "text": "儿女事天助就岂能相强， 劝母亲休忧虑免挂心肠。 兄别名青面虎巨口怪相， 赤须发奸人惊定是栋梁。 深闺女虽年幼训教听讲， 儿无父不孝母昧尽天良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐世英上。"
        },
        {
          "character": "徐世英",
          "type": "西皮摇板",
          "text": "三月里清明节祭扫尊长， 忙禀报老娘亲预备纸张。"
        },
        {
          "character": "徐世英",
          "type": "白",
          "text": "母亲。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我儿罢了。"
        },
        {
          "character": "徐飞珠",
          "type": "白",
          "text": "啊，哥哥回来了。"
        },
        {
          "character": "徐世英",
          "type": "白",
          "text": "贤妹。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我儿坐下。"
        },
        {
          "character": "徐世英",
          "type": "白",
          "text": "告坐。啊，母亲，今乃清明佳节，孩儿备得祭礼，请母亲同妹子前往坟台一祭。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "不是我儿提起，为娘倒忘怀了。 家院，吩咐车辆打上。"
        },
        {
          "character": "徐福",
          "type": "白",
          "text": "车辆打上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "稳坐香车穿柳巷， 家家户户沸扬扬。"
        },
        {
          "character": "徐世英",
          "type": "西皮摇板",
          "text": "清明时节看玩赏，"
        },
        {
          "character": "徐飞珠",
          "type": "西皮摇板",
          "text": "路上行人带酒觞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四教师、高登同上。"
        },
        {
          "character": "高登",
          "type": "西皮摇板",
          "text": "蟠桃胜会真美景， 还有美貌女姣娘。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "今年蟠桃胜会，果然热闹。列位师爷，就此将拳棒演习一回。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四教师同演拳，"
        },
        {
          "character": "教师甲",
          "type": "念",
          "text": "习就武艺无人挡，"
        },
        {
          "character": "教师乙",
          "type": "念",
          "text": "个个争勇似虎狼。"
        },
        {
          "character": "教师丙",
          "type": "念",
          "text": "出手就有仙人掌，"
        },
        {
