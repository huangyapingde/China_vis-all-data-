        {
          "character": "江松",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "江松",
          "type": "念",
          "text": "落在廊檐下，"
        },
        {
          "character": "侯得",
          "type": "念",
          "text": "谁敢不低头。"
        },
        {
          "character": null,
