{
  "script_id": "01001012",
  "title": "黄鹤楼",
  "alias": [
    "过江赴宴；一名：竹中藏令"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "赵云",
      "hangdang": "小生"
    },
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    }
