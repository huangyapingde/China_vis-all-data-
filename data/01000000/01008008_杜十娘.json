      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙富上，院子上。"
        },
        {
          "character": "孙富",
          "type": "念",
          "text": "闷坐在书房，思想美娇娘。"
        },
        {
          "character": "孙富",
          "type": "白",
          "text": "我孙富。爹爹在朝，官居尚书。想我年方三九，尚未婚配。今日心中不乐，不 免出外游玩一番。 来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子允。"
        },
        {
          "character": "孙富",
          "type": "白",
