      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李迁仙、杜十娘、车夫同上。船夫上。〖牌子〗。李迁仙、杜十娘同上船，车夫下。"
        },
        {
          "character": "船夫",
          "type": "白",
          "text": "启禀相公：天降大雪，不能行舟。"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "就此地停舟。 娘子，想我心中烦闷，你何不唱一小曲？"
        },
        {
          "character": "杜十娘",
          "type": "白",
          "text": "相公你我回家要紧，来到此处，天降大雪，若是唱了小曲，岸上有人听见，成 何体统。"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "不要紧，此处乃是荒山野地，没什么人来往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜十娘唱小曲。孙富坐舟上。"
        },
        {
          "character": "孙富",
          "type": "白",
          "text": "吓，此地有琴声响亮，待我看来。 哦，原来这船上在那里弹唱小曲，里面必有女人，待我假意问来。 吓，这只舟船是哪一位的？"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "娘子少坐，待我看来。"
        },
        {
          "character": "杜十娘",
          "type": "白",
          "text": "你不要去管他。"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "不妨事。 吓，是哪一位？"
        },
        {
          "character": "孙富",
          "type": "白",
          "text": "吓，原来是师兄。"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "孙富",
          "type": "白",
          "text": "我就是孙富，你我同学读书的。"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "吓，原来是孙师兄。"
        },
        {
          "character": "孙富",
          "type": "白",
          "text": "岂敢岂敢，不知师兄贵姓，我倒忘怀了。你姓这个……"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "我姓李。"
        },
        {
          "character": "孙富",
          "type": "白",
          "text": "不错，李师兄。我看你叫这个……"
        },
        {
          "character": "李迁仙",
          "type": "白",
          "text": "我叫李迁仙。"
        },
        {
          "character": "孙富",
          "type": "白",
          "text": "不错不错，你是李迁仙。请问李师兄，你舟上还有何人？"
        },
        {
          "character": "李迁仙",
          "type": "白",
