      "hangdang": "老生"
    },
    {
      "name": "张夫人",
      "hangdang": "老旦"
    },
    {
      "name": "张秀玉",
      "hangdang": "小生"
    },
    {
      "name": "家院",
      "hangdang": "丑"
    },
    {
      "name": "吕后",
      "hangdang": "旦"
    }
  ],
  "plot": "汉惠帝时，高后吕雉以帝无子，阴取后宫美人子名之，以为太子。迨惠帝既崩，吕雉即挟立少帝，自临朝称\n制，大封诸吕为王者四人，为列侯者六人，又酖杀赵隐王如意，幽死赵幽王友，逼使赵共王恢自杀，并废其\n嗣，杀燕灵王建之子以绝其后，盖欲弱刘氏，大诸吕，而阴移刘祚于吕也。然高帝有八男，尚有代王恒（即\n文帝）、齐王肥及其诸子在，吕雉恐关东诸侯王，执宗谱以危少帝，并锄去诸吕之不当王而王者。时御史大\n夫北平侯张苍，职掌刘氏宗卷，及诸图书文籍，吕雉因向张苍绐取得宗卷而焚之。适关东诸王遣田子春至，\n向丞相陈平索卷，陈平遂勒张苍交出，否则罪将赤族。张苍备受陈平奚落，归家惧极，筹思无计，欲自刎，\n忽其子张秀玉，袖出宗卷呈张苍。张苍喜极，询其故，则张秀玉预料汉室，必有萧墙之祸，故先抄录全卷，\n以备不虞。金殿所焚者，即赝本也。张苍闻语，极赞赏其子，急携卷赴陈平府。陈平得卷亦大喜，张苍又窥\n破陈平藏留田子春事，遂以向所受陈平奚落之情状，还以奚落陈平，而卒与田子春等共谋去吕之策。",
  "notes": "此剧为须生之做工戏，彼此奚落一段，虽戏情太觉离奇，似乎不类，然作者却即於此处见长。曩时小叫天曾\n一演之，今惟贵俊卿为能擅扬耳。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四宫女引吕后同上。"
        },
        {
          "character": "吕后",
          "type": "引子",
          "text": "身在深宫院，重整汉室锦江山。"
        },
        {
          "character": "吕后",
          "type": "念",
          "text": "未央宫中美翠环，珍珠玛瑙集成山。上殿见我君皇宠，方显女皇将魁元。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "哀家吕后。昨日有飞报报道：有一游方道人，来到吾国，盗取宗卷。不免宣张 苍上殿，将那宗卷，用火焚化，谅无后患。 内侍，宣张苍上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "宣张苍上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苍上。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "忽听国太宣，迈步上金銮。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "臣张苍见驾，愿国太千岁！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "千千岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "宗卷可是卿家看守？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "是臣看守。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "何不呈上殿来，哀家一看。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "待臣取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苍下。张苍捧宗卷上。"
        },
        {
          "character": "张苍",
          "type": "念",
          "text": "手捧皇家卷，急忙献君前，"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "卿家看守宗卷有功，赐卿御酒一斗，"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "谢国太！ 且住，人言吕后之酒，实实难饮，待我将酒敬过天地。 谢国太！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "想这太平年间要这宗卷何用？ 内侍，将卷用火焚了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监允。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监烧宗卷。陈平急上。"
        },
        {
          "character": "陈平",
          "type": "西皮摇板",
          "text": "金銮殿上红光现， 急忙上殿奏君前。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "陈平见驾，国太千岁！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "臣见火光一起，特地上殿，保全江山。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "卿家可知哀家火焚宗卷之事？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "国太莫非要谋汉？"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "嘿嘿，卿家果有出将入相之才。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "谢国太。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监、宫女分下，吕后下。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "呵呵！"
        },
        {
          "character": "陈平",
          "type": "西皮摇板",
          "text": "金钟三响皇退殿， 文武有怒不敢言。 撩袍端带下金殿， 但只见张苍狗肺男！ 宗卷本在孝廉殿， 谁叫你拿来献君前！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "只因国太要看。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "呀呀呸！"
        },
        {
          "character": "陈平",
          "type": "西皮摇板",
          "text": "关东十王发人马， 管叫一家难保全。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平下。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "张苍",
          "type": "西皮摇板",
          "text": "陈平老儿怒冲冠， 骂得我张苍不敢言。 宗卷本在孝廉殿， 不该拿来献君前。 关东十王兴人马， 我一家大小命难全。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苍下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小锣。田子春上。"
        },
        {
          "character": "田子春",
          "type": "西皮摇板",
          "text": "道家模样改装扮， 不分昼夜往长安。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "下官田子春。奉幼主之命，去至长安，盗取宗卷，就此走走。"
        },
        {
          "character": "田子春",
          "type": "西皮摇板",
          "text": "昔日楚汉两争强， 韩信弃楚扶汉邦。 逼死霸王乌江丧， 后来官封三齐王。 时败遇见陈仓女， 未央宫中一命亡。 汗马功劳今何在， 为国忠良无下场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田子春下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "院子引陈平同上。四青袍同上。六幺令，〖吹打〗。陈平更衣。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "老夫陈平。只因国太在金殿之上，火焚宗卷，莫非淮河有人前来盗卷，不免在 八卦之中，查看明白。 来，看香案伺侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。"
        },
        {
          "character": "陈平",
          "type": "念",
          "text": "十字口内吞，了字加一横。三人间一日，凑成田子春。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "哦哦是了，闻得幼主驾前，有一臣子，名唤田子春，此人虽然年幼，颇有胆略。 吾自有道理。 来，香案撤过， 来，传夜不收进见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "夜不收走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二衙役同上。"
        },
        {
          "character": "衙役甲",
          "type": "念",
          "text": "人平不语，"
        },
        {
          "character": "衙役乙",
          "type": "念",
          "text": "水平不流。"
        },
        {
          "character": "衙役甲",
          "type": "念",
          "text": "相爷呼唤，"
        },
        {
          "character": "衙役乙",
          "type": "念",
          "text": "急忙叩头。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "呼唤小人，有何吩咐？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "命尔等手拿灯亮火把，去到大街之上，说道：“会犯夜的前来犯夜，不会犯夜 的不要犯夜，若是犯了夜，先见都御史陈爷，然后发到有司衙门审问。”"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "启相爷：古来只有悮犯夜，哪有掌灯亮叫人犯夜之理？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "唔，还不快去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平下。"
        },
        {
          "character": "衙役乙",
          "type": "白",
          "text": "相爷改差进去了。 吓，伙计，你看我家相爷，有点老糊涂了。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "怎么着？"
        },
        {
          "character": "衙役乙",
          "type": "白",
          "text": "哪有掌灯叫人犯夜之理？"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "也不要管他糊涂不糊涂，拉他几个就结了。"
        },
        {
          "character": "衙役乙",
          "type": "白",
          "text": "有理。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田子春上。"
        },
        {
          "character": "田子春",
          "type": "西皮摇板",
          "text": "行来不觉天色晚， 冷冷清清到长安，"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "唗，诸位听者：会犯夜就犯夜，不会犯夜不要犯夜，若犯了夜，先见都御史陈 爷，然后发到有司衙门审问！"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "吓，世上只有悮犯夜，哪有点灯火把叫人犯夜之理？唔，不知这都御史是谁？ 哦，莫非又是陈平？这老儿巧计多端，我到要去领他一领，趁此将计就计。"
        },
        {
          "character": "衙役乙",
          "type": "白",
          "text": "哙，犯夜的快来吓！"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "众位，我是远方来的，又无亲友，又无宿店，我倒要犯夜。"
        },
        {
          "character": "衙役乙",
          "type": "白",
          "text": "带你去见我家老爷。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "敢是陈平？"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "掌嘴！你是何人，敢叫我家相爷的名讳！"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "不要打不要打，我是你家相爷的外甥。"
        },
        {
          "character": "衙役乙",
          "type": "白",
          "text": "也不管外甥不外甥，带他去见我家相爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平上。"
        },
        {
          "character": "陈平",
          "type": "念",
          "text": "只因焚化宗卷事，老夫昼夜把心耽。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "禀相爷：小人们拿住了一个犯夜的。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "来，见过相爷。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "是是是。 哈哈哈，好醉吓好醉！"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "他说是相爷的外甥。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "唔，皇子犯法，与庶民同罪，尔等有功之人，下面领赏。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "谢相爷，他还被小人们打了几下。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "我把你这两个狗才，相爷的外甥，岂是尔等打的么！ 来，传长班扯下去打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二衙役同下。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "唔，好醉。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "看他一点酒气没有，自言好醉。 吓，那旁敢是田？"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "这厢敢是陈？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "田大人。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "陈大人。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "如此，田大人请坐。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "田大人为何口称老夫的外甥？"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "哎，有道是，好汉不吃眼前亏。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "嘿嘿，好个“好汉不吃眼前亏”。大人到此，有何贵干？"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "奉了千岁旨意，前来盗卷。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "嘿嘿，田大人你来迟了。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "怎么来迟了？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "这宗卷，昨日国太在那金殿，用火焚化了。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "用火焚化了！"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "哎呀，不、不、不好了！"
        },
        {
          "character": "田子春",
          "type": "西皮摇板",
          "text": "听说宗卷被火焚， 唬得我三魂少二魂。 叫声吾儿慢相等， 我父子作鬼一路行。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "大人回去搭救令郎才是。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "我是不回去了。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "你在哪里居住？"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "我就住在你府。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "倘若国太知道，那是怎么？"
        },
        {
