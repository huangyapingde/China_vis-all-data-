          "text": "在这里。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "好儿子！"
        },
        {
          "character": "张苍",
          "type": "西皮摇板",
          "text": "有了宗卷怕谁人？ 叫家院掌灯把路引， 要与陈平把理评。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苍、家院同下。"
        },
        {
          "character": "张夫人",
          "type": "西皮摇板",
          "text": "一见老爷出府门， 静坐内衙等信音。"
        },
        {
          "character": null,
