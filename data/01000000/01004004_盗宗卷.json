    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "家院引张苍同上。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "张苍",
          "type": "西皮导板",
          "text": "家院掌灯往前进，"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "家院，宗卷呢？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "张苍",
          "type": "西皮摇板",
          "text": "不由我心中喜十分。 下位不坐上坐定， 他问我一言答一声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平上。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "吓，张苍你来了？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "我不来还是怕你不成？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "这是什么所在，连品级台都没有了。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "太平年间，有品级台；如今离乱年间，还有什么品级台不品级台，待你张老爷， 坐坐何妨。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "拿来。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "拿什么来？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "宗卷来吓！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "要几十部？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "只要一部吓！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "哦，要一部，你就拿了去！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "他被我唬糊涂了，拿部经史搪塞老夫来了。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "是与不是，你且看个明白。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "“初起义来在关东”…… 吓，张大人，这是宗卷吓！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "不是宗卷。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "是什么？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "是卷宗吓！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "哈哈！有了宗卷，请来上坐。国太焚化了，这哪里来的？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "相爷有所不知，只因癸未年间，下官染病在床，命小儿替我看守此卷，他看到 第七部七册上，见香国娘娘，死得可惨，故而誊写一部，以备后患。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "这皇家宗卷玉玺，怎的打在上面？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "这是小儿一时聪敏，将黄蜡镌成玉玺，打在上面。在金殿焚化的，乃是假的； 这是历代历代的老宗卷。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "如今令郎有多大年纪？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "一十四岁。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "哦，一十四岁，有此大才，日后必有出将入相之才。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "不错，我的儿子有你的位份！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "我不过奉承他几句，他在老夫面前，好起高来了！待我来唬他一唬。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "嘿嘿，张苍你好吓！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "我怎么不好？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "你私造皇家玉玺，欲谋江山之意！走！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "去见国太。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "相爷息怒，我有策悔。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "看你的策悔。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "这宗卷交待明白。 就是我与他好的什么高，知今生起祸事来了，不免与他赔个礼儿就是了。 吓相爷，方才下官的不是，这厢赔礼了。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "哎，你是父子同谋江山，作了个揖，难道就罢了么？这的不够！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "是是是，只怕不够。 哎吓是了，想是要我下一全礼，我想俱是炎汉忠良，就是下一全礼，这有何妨？ 吓，相爷，方才下官的不是，这厢赔礼了。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "张苍，何苦怕老夫？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "实实的怕相爷！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "你服老夫不服？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "服了你。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "唔。哈哈，我是与你作耍的。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "你唬出我一身冷汗来了！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "大人如今宗卷有了，你回去吧。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "如此告辞了。"
        },
        {
          "character": "张苍",
          "type": "西皮摇板",
          "text": "辞别相爷出府门，"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "哎呀且住，想那宗卷乃是我张苍看守的，他为何苦苦追究，是何缘故？哦呵是 了，想是城皋有人盗卷，待我来想他一想。哦呵是了，老皇驾前有一臣子，名 唤田子春，此人虽则年幼，颇有胆量，莫非是他前来盗卷？哼哼，陈平吓陈平 吓，无有此事便罢；若有此事，管叫你原礼退回！"
        },
        {
          "character": "张苍",
          "type": "西皮摇板",
          "text": "再与相爷理分明。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "吓，大人为何去而复返？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "非是下官去而复返，想那宗卷，乃是我张苍看守，请问相爷为何苦苦追究，莫 非城皋有人盗卷？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "田子春可是么？你窝藏奸细，意欲同谋国太江山，走走走！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "面见国太。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "我有策悔。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "你看我是好高不好高！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "咳，有了宗卷，就该平安无事，与他作的什么耍，如今反惹一场祸事来了。也 罢，与他赔个不是，也就是了。 吓，张大人，方才老朽的不是，如今与张大人作揖赔礼。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "哼哼，你窝藏奸细，有谋国太江山之意，作了个揖，难道就罢了不成么？嘿嘿， 只怕有些不够本！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "哦是了，他要老夫原礼退还。哎，我想俱是炎汉忠良，下个全礼，这又何妨？ 吓，张大人，方才老朽的不是，如今与大人磕头赔礼！"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "陈平。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "你怕我不怕？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "怕了你了。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "服我不服？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "实实的服了你了。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "抬起头来。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "不敢抬头。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "唔，下官也是与你作耍。你可有此人？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "有的，你怎么知晓？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "被我糊里糊涂，这一猜就猜着了，"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "老夫服你的猜。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "何不请来相见？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "田大人，有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田子春上。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "张大人请你相见。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "请来相见。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "待我来唬他一唬。 拿奸细！"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "这是为何？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "试试你的胆量。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "他的胆量是好的。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "如今宗卷有了。"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "宗卷被国太用火焚化，这部是哪里来的？"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "只因癸未年间，下官染病在床，命小儿替我看守此卷，他看到第七部七册上， 见香国娘娘，死得可惨，故而誊写一部，以备后患。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "田大人看，张大人的令郎，日后必有出将入相之位。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "我的儿子后来必定像他！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "你又好高起来了！"
        },
        {
          "character": "张苍、陈平",
          "type": "同笑",
          "text": "哈哈！"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "二位大人，倘若淮王兴兵前来，相烦二位作一内应。"
        },
        {
          "character": "张苍、陈平",
          "type": "同白",
          "text": "那个自然，"
        },
        {
          "character": "田子春",
          "type": "白",
          "text": "告辞了。"
        },
        {
          "character": "张苍、陈平",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田子春下。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "卑职告辞了，"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "且慢，大人不必回府，在老夫府中，吃了太平宴。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "如此要豁拳。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "八马。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "四喜红。"
        },
        {
          "character": "张苍、陈平",
          "type": "同笑",
          "text": "哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苍、陈平同下。"
        },
        {
          "character": null,
