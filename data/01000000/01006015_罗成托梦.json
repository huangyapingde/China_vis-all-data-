{
  "script_id": "01006015",
  "title": "罗成托梦",
  "alias": [
    "托兆小显"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "罗成",
      "hangdang": "小生"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "罗妻",
      "hangdang": "旦"
    }
  ],
  "plot": "罗成死后，小秦王李世民同秦叔宝、徐茂公、程咬金等亲诣其家祭奠，伴宿灵堂。罗成鬼魂降灵受祭，见李\n世民等均假寐在旁，遂入梦显灵，备诉身死惨状，及为元吉所陷害等情。并以妻子相托。",
  "notes": "前本即《罗成叫关》。此剧首场，系罗成魂率领四鬼卒绕场行唱，纯用唢呐腔。惟每唱一节，则众鬼卒必同\n堆罗汉一般，幻成种种怪戏，颇足令人发噱，是殆即世人所谓“鬼趣欢”。第二场即《灵堂托兆》亦。此场\n虽有三、四配角，然亦只需如傀儡一般足亦，故仿佛为小生之独角戏。前听朱素云唱此，又飘忽苍凉，又凄\n惨沉着，我不禁为之泪下。顿时觉场上景色，亦俱现一派愁惨气象。其工拙可知也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒引罗成同上。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "生前为良将，死后作忠魂。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "吾乃罗成鬼魂是也。只因苏烈兴兵犯界，圣上命元吉挂帅，命俺为前战先行。 黄道日不出兵，黑道日期叫俺出马。不想误陷淤泥河边，被乱箭射死。今有二 主秦王、众家国公前来吊祭，伴宿吾府。待吾前去托妻寄子，把吾的苦处细表 一番。"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "黑暗暗雾沉沉随风飘荡， 冷飕飕凄惨惨转回故乡。 我主爷来吊祭龙恩光降， 众王侯见灵位亦要悲伤。 叫鬼卒驾阴风急忙前往，"
        },
        {
          "character": "罗成",
          "type": "二黄摇板",
          "text": "可怜我英雄汉一命身亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "门子上，扫灵堂。罗妻抱罗通哭上，四青袍同上。"
        },
        {
          "character": "罗妻",
          "type": "哭",
          "text": "哎吓！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "圣驾到。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、四龙套、众国公同上。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "臣妻有何德能，敢劳二主、众家国公前来吊祭。"
        },
        {
          "character": "李世民、众国公",
          "type": "同白",
          "text": "岂敢。为国身亡，理当如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。李世民、众国公同祭灵。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "真乃有道明君。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王要在此伴灵一夜，众家国公，俱在灵堂陪伴小王一宵。"
        },
        {
          "character": "众国公",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、众国公同伏桌睡。"
        },
        {
          "character": "罗成",
          "type": "内二黄导板",
          "text": "天下荒荒无真主，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "回龙",
          "text": "上苍降下紫微星。"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "青龙投胎太原省， 那燕山降下白虎星。 俺在罗门为公子， 长大成人武艺超群。 一十六岁保唐王，"
        },
        {
          "character": "罗成",
          "type": "二黄垛板",
          "text": "俺亦曾东荡西除、南征北剿、马不停蹄、血战疆场，到如今只落得一命归阴！"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "将身儿且把灵堂进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上高台。"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "又只见吾主爷瞌睡沉沉。 众家国公俱已困， 苦命的贤妻傍伴灵。 义子罗春身带孝， 最可叹无依无靠、孤苦伶仃，三岁的罗通，好不伤心。我的苦命的儿吓！"
        },
        {
          "character": "罗成",
          "type": "唢呐西皮导板",
          "text": "恨只恨三千岁挂了帅印，"
        },
        {
          "character": "罗成",
          "type": "西皮慢三眼",
          "text": "俺罗成倒做了马前先行。 头一阵枪挑了李天寿， 有功不赏反加刑。 重责为臣四十棍， 身带棒伤还要出兵。 从早晨杀到了午时候， 午时杀到日落黄昏。 紧闭四门不得进， 他叫我单人独骑退贼兵。"
        },
        {
          "character": "罗成",
          "type": "西皮快板",
          "text": "淤泥河边遭了困， 飞蝗凑雨乱箭厝身。 望求千岁奏一本， 说俺罗成死的惨情。 母老妻姣要你照应， 三岁孤儿亦要加恩。"
        },
        {
          "character": "罗成",
          "type": "西皮摇板",
          "text": "若要君臣重相会， 大破龙门臣见君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。李世民、众国公同醒。"
        },
        {
          "character": "李世民、众国公",
          "type": "同白",
          "text": "我等告辞了。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "有送二主、众家国公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "摆驾回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}