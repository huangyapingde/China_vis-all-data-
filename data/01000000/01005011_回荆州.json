    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丁奉、徐盛同上。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "奉了都督将令，追赶刘备。一言未尽，刘备、皇姑来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、赵云、孙尚香、车夫、四白龙套同上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "好比笼中鸟，插翅腾了空。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "一路飞彩凤，金锁走蛟龙。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "为臣枪马在，哪怕百万兵。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "看枪！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟，那边有徐盛、丁奉，在前拦路。这便如何是好？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公不必惊慌，临行之时，先生赐我三道锦囊。为臣看过二道，打开三道一看， 便知明白。 为臣在马上，递与我主看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云递锦囊，刘备看。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "“江南住一年，元旦转回还。若退吴兵计，皇姑走上前。”"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，皇姑吓！丁奉、徐盛在前拦路，这便如何是好？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "贵人不必惊慌，我既随你前去，慢说退兵，就是刀山，我也敢闯。 四弟保护车辆，看他来将是谁！"
        },
        {
          "character": "丁奉、徐盛",
