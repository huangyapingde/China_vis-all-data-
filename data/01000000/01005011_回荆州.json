          "text": "孔明妙计真神人。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同念",
          "text": "或杀或放全有罪，"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "盘河大战方称心！"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "送赵将军。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "丁奉徐盛听准：你赵老爷过江以来，数月盘恒不战，你们哪一个粗心胆大，与 你赵老爷战上几十回合。权当抖抖精神，壮壮胆气！"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "孙、刘和好，何必伤了和气？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "大大的便宜尔等了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、孙尚香、车夫、四白龙套、赵云同下。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "放刘备、皇姑过去，禀报都督知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丁奉、徐盛同下。"
        }
      ]
    },
