{
  "script_id": "01005011",
  "title": "回荆州",
  "alias": [
    "美人计；一名：龙凤呈祥"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "孙尚香",
      "hangdang": "正旦"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "按《三国志》载，刘备既从孔明计，带领赵云、孙乾等，渡江赴南徐招亲。吴国太于佛寺看新郎之后，即令\n迁入甥馆，择吉成婚。乘龙之夕，刘备入洞房，见两廊枪刀簇簇，侍婢等皆佩剑悬刀，不胜惊疑。孙夫人知\n之，遂命尽行撤去，且笑谓曰：厮杀半生，尚惧兵器乎。既而孙权又用周瑜张昭之计，修葺东府，广载花木，\n盛设金玉锦绮玩好之物，并增女乐数十人，以子女玉帛玩丧其心志，并以离间关、张、诸葛之情。刘备安\n居数月，果然为声色所迷，不想回荆州，赖赵云开读诸葛亮第二锦囊，即依计奔入备室，伪作失惊状，报称\n曹操起精兵五十万，杀奔荆州，势甚危急，请主公即回去。遂刘备与孙夫人商议，幸孙夫人颇知大义，且已\n在屏后听得赵云之言，遂决计随刘备同回。先往禀明国太，诿称元旦日须夫妇同往江边祭祖。刘备先命赵云\n引军于官道左，届时果得国太允许，夫妇遂得掩出，趱程而进。时建安十五年正月元旦也，比及孙权等知讯\n命将追赶，中途又被孙夫人斥回。卒得安抵江边。为诸葛亮迎渡过江。盖皆赖诸葛亮之预为布置也，而“赔\n了夫人又折兵一语”几乎又将周郎气死。",
  "notes": "此剧从前小连生颇为擅名。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上。"
        },
        {
          "character": "孙尚香",
          "type": "引子",
          "text": "我兄把守在江南，奴为公主非平常。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "昨晚春风过池塘，荷花重开满园香。燕子落在枝头上，近看连秀蝴蝶忙。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "奴，吴侯之妹，名尚香。当年赤壁交征下荆州，又被刘备借去屯军，久借未还。 我兄与周郎定计，诓刘备过江招亲。哪里是招亲，乃是讨取荆州。我母一见 刘备，遂心合意，弄假成真，定期夫妻拜堂完婚。 侍儿们！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侍儿允。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "两廊摆设枪刀剑戟。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。侍儿摆设。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "摆设已毕。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "等贵人到来。不问便罢；倘若问起，尔就说我家皇姑好武，摆列枪刀与为迎接 宾客之理。伺候了。"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "孙尚香坐宫院自思自叹， 这才是为荆州结下凤鸾。 我兄长与周郎暗地定计， 要害那刘皇叔所为哪般？ 乔国老进宫来细讲一遍， 因此上我母后主配鸾凰。 两廊下摆枪刀威严极壮， 等贵人他到来细看一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "挂红彩铺地毡甚是气旺， 皇宫院与黎民大不一般。 行来在宫门外用目观看， 两廊下排剑戟孤躬胆寒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤躬刘备。过江以来，孙权与我建造新府，每日弹唱歌舞，好不美哉人也。来 此宫门，两廊摆设枪刀，不知为了何事，不免将侍儿唤出。一问便知。 哦哼。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "与贵人叩喜。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "侍儿，你家皇姑，两廊排下枪刀，不知为了何事？"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "我家皇姑摆设刀枪剑戟，乃是迎接贵客之理。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "侍儿对皇姑去说：撤了枪刀，方能进宫。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "回禀皇姑，贵人言道：去了枪刀，方能进宫。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "闻听人说，他弟兄大破黄巾，大小战场见过。今日一见，原来胆小之人。 侍儿们两廊撤去枪刀。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "两廊去了枪刀剑戟。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "侍儿，有请贵人。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "有请贵人。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "两廊下撤去了枪刀不见， 果然是孙权妹话不虚传。 来至在宫门口抬头观望， 见皇姑不迎接礼上不端。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我想身为皇姑，不晓大礼。哦，有了，待我进而又退。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "禀皇姑：贵人进而又退。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "哪里是进而又退，他道皇姑是孙权之妹，不晓得迎接之礼。侍儿随我来。"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "闻听得他弟兄飞魂丧胆， 说什么见枪刀心中胆寒。 论大礼我就该迎接当面，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "有请贵人。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "有请贵人。"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "只羞得孙尚香满脸红颜。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "汉刘备在宫院偷眼观看， 好一似天仙女降下临凡。 多亏了乔国老暗地撮合， 月下老配就了龙凤百年。"
        },
        {
          "character": "孙尚香",
          "type": "西皮原板",
          "text": "孙尚香站宫院偷眼观望， 三柳须耳垂肩果是贵男。 怪不得乔国老暗地夸奖， 这也是月下老配就鸾凰。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "我这里走上前把礼来见， 有孤躬把来路细对你言。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "贵人请坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "皇姑请坐，皇姑非知。只因你兄与周郎定计，要害孤躬，有什么大事，全仗皇 姑。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "那是自然，只要我母担当，谅也无妨。"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "尊贵人你不要提心吊胆， 小周郎他定下调虎离山。 但愿得我的娘心不改变， 咱夫妻这也是前世的姻缘。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "汉刘备听此话把心放定， 果然是女英雄话不虚传。 从今后把愁肠一概不管， 把愁肠一旦间不挂在心头。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "皇姑，就该差人与我二弟、三弟处报喜。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "那个自然。明日着人前去就是。"
        },
        {
          "character": "侍儿",
          "type": "白",
          "text": "请贵人、皇姑安眠。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "麟凤原来结凤鸾，"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "千里姻缘路千千。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "久住他乡归故里，"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "好一似天台赴广寒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好么，好一个“天台赴广寒”！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "贵人请。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "皇姑请。"
        },
        {
          "character": "刘备、孙尚香",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香、刘备同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周瑜引四龙套同上。"
        },
        {
          "character": "周瑜",
          "type": "引子",
          "text": "一扣玉带，紧束腰，照遂江南。"
        },
        {
          "character": "周瑜",
          "type": "念",
          "text": "七岁举法九用兵，一十二岁掌元戎。官拜水军都督印，执掌东吴百万兵。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "本督姓周名瑜字公瑾。与吴侯定下调虎离山之计。诓刘备过江招亲，分明是索 讨荆州，差去徐盛丁奉打探，为何不见到来。 伺候了。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "内同白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丁奉、徐盛同上。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "参见都督。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "站下。丁奉、徐盛，命你二人探听刘备之事如何？"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "都督容禀："
        },
        {
          "character": "丁奉",
          "type": "念",
          "text": "晓谕二堂曾报喜，国太一事全不知。"
        },
        {
          "character": "徐盛",
          "type": "念",
          "text": "吴侯差人问消息，为的荆州那是非。"
        },
        {
          "character": "丁奉",
          "type": "念",
          "text": "国太恨天又怨地，叫声都督拿主意。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "你才怎讲？"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同念",
          "text": "叫声都督拿主意！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "听你二人之言，莫非刘备在江南招亲么？"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "天吓天！想俺周瑜用计不成，可不气么！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜气。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "都督醒来！ 都督何不写书一封，叫吴侯起盖新府，每日弹唱歌舞。刘备必不肯回荆州，随 后叫他杀了关、张。这荆州岂不随手而得？都督修书，叫吴侯照书行事。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "此计甚好。容墨伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。周瑜修书。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "这有小书一封，下在吴侯那里，请他照书行事。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同西皮原板",
          "text": "都督将令往下传， 哪个胆大不听言？ 三军催马往前进， 见了吴侯说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丁奉、徐盛同下。"
        },
        {
          "character": "周瑜",
          "type": "西皮原板",
          "text": "汉刘备过江来令人可恨， 诸葛亮他本是惹祸根源。 心儿里恨诸葛恼恨曹操， 何日里杀关、张才把气消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮原板",
          "text": "主公招亲在江东， 事付南阳诸孔明。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺赵云。自我君臣过江以来，孙权与我主起造新府，每日弹唱歌舞，不想回去。 将俺押在小军队内，每日无事不提。想昔日临行之时。先生赐我锦囊三道， 不免打开二道一看，便知明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云拆锦囊，看。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "“青铜宴月出王庄，假报曹操夺荆州，君臣若不离虎口，成恐学了楚霸王。”"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "我道为了何事，原来先生命俺催主公还朝。正是："
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "周瑜小儿太无良，不该诓主过长江。大胆我把新府闯，假报曹操夺荆襄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤躬招亲在江东，事付南阳诸葛公。舍身才把牡丹戏，胜似王母斗牛宫。 俺刘备。过江以来，孙权与我起盖新府。每日弹唱歌舞，好不美哉人也。正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "天上神仙府，人间宰相家。要论真富贵，还是我帝王家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "先生军令大，谁敢不惧他。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟慌张为何？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "大事不好了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "只因曹操命夏侯惇，带领四十五万人马，索讨荆州来了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这便如何是好？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "大谅孙权准备，你我君臣，不免暗暗逃走了罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上，听。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "怎么说走得的？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "走得了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咱走。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "呀啐！什么人大胆闯进门宫，口称“主公”？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "他、他是我四弟赵云。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "你君臣，为何逃走？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "皇姑吓！只因曹操命夏侯惇，带四十五万人马，索讨荆州来了。杀得我君臣不 能相见，弟兄不得团圆。怎的不走？咱就不走，四弟你走了罢！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "哪里是夏侯惇带领人马，索讨荆州？分明是撇奴在江南。也罢，不免进得宫去， 奏与母后，母后晓谕我兄，我兄发来一哨人马，将这新府团团围住，看你哪 里走，哪里逃，我看你走在哪里！"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "皇姑吓！"
        },
        {
          "character": "刘备",
          "type": "西皮慢板",
          "text": "汉刘备在宫中双膝跪落， 叫皇姑近前来细听我说： 贤皇姑念大义搭救于我， 搭救我君臣们好出网罗。"
        },
        {
          "character": "赵云",
          "type": "西皮慢板",
          "text": "有赵云在宫院双膝跪落， 请主母近前来细听我说： 望主母你那里搭救于我， 搭救我君臣们逃出网罗。"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "他君臣在宫院双膝跪落， 倒叫我孙尚香无有话说。 走上前来忙搀起， 再叫贵人听端的。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "贵人不必惊慌，今乃元旦佳节，众百姓上坟祭祖。不免奴进宫去，禀知我母， 就说我夫妻，江边祭祖。暗暗雇上两只小船，渡过江去，你看如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟，你看皇姑虽然女流，倒有男子的肚才！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "果有男子的肚才！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟，皇姑进宫，禀知国太；四弟准备车辆伺候。正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "皇姑果然是大贤，"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "随夫逃走礼当然。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "打谅孙权无准备，"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "回在荆州答谢天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、孙尚香、赵云同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上，四龙套同上。〖点绛唇〗。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "家住南阳卧龙居，神机妙算鬼神惊。未出茅庐三分定，辅汉诸葛字孔明。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人诸葛亮。只因孙权与周郎，定下调虎离山之计，诓主公过江招亲。哪里是 招亲，分明索讨荆州。主公去了日久，今日乃我主还朝之日。众将伺候了。"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "西皮原板",
          "text": "心中恼恨诸葛亮， 作事不与某商量。 怒气不息宝帐闯， 快快还我大兄王！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "可恼吓，可恼！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁进得帐来，怒气不息，为着谁来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "就为你来！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "为山人何来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我来问你，我家大哥过江，去了久日，没有音信到来。叫俺老张怎的不恼。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "雁飞万里，必有来日。何为着恼？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生就该传令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁听令：命你带领三千人马。埋伏在芦花荡，等候周瑜到来，只拿不杀。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "为何只拿不杀？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "只因他赤壁交兵，火烧战船，有这样的功劳，不要伤他性命。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "得令。马来！"
        },
        {
          "character": "张飞",
          "type": "西皮原板",
          "text": "宝帐领了先生令， 芦花荡埋伏走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。诸葛亮更换衣服。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "山人把船上，思念小周郎。撒下钩和网，准备钓金鳌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        }
      ]
    },
