        {
          "character": "刘备",
          "type": "白",
          "text": "不、不好了！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "汉刘备过江来惹下大祸，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘璋、陈武、四龙套同上，过场，同下。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "眼巴巴我君臣逃出网罗。 耳边厢又听得马嘶人喊， 再叫皇姑听我言。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "皇姑，前面有大江，后面有追兵，如何是好？"
