{
  "script_id": "01028009",
  "title": "沙桥饯别",
  "alias": [
    "三藏取经"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "李世民",
      "hangdang": "老生"
    },
    {
      "name": "唐三藏",
      "hangdang": "小生"
    },
    {
      "name": "徐勣",
      "hangdang": "外"
    },
    {
      "name": "房玄龄",
      "hangdang": "末"
    },
    {
      "name": "殷开山",
      "hangdang": "副净"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    }
  ],
  "plot": "东汉明帝，遣使至天竺，求其道、得其书，及沙门以来，释教始入中国。琼山邱氏读史立论，谓明帝为名教\n中万世之罪人。由汉迄唐，奉佛者已盛行于世。三代以下，有道之君当推唐太宗第一，抑何迷信释教，悠谬\n若斯之甚哉？然而太宗为国计、为民生，非为一人邀福，实未可厚非也。太宗弱冠将兵，戡定祸乱。及身为\n天子，目睹夫爱国志士血染沙场，不知凡几。欲慰藉其死，须妥佑其魂。国家无戾气，庶几亿兆生存之民得\n享太平幸福。而普施广大慈悲，只佛法有此能力。恐中国佛门徒众不得心传，或者妙谛真诠仍在异域。爰命\n高僧三藏（法名玄奘，俗家姓陈）涉重洋、渡大海，往释迦牟尼（即是如来菩萨）出身之处——俗称西天佛\n国（即今英吉利属国之印度）者，求取大藏真经。冀他日回华，用以奉诵礼拜，超度遭劫之鬼。太宗不敢不\n郑重，率领群臣亲送出国门，设宴于沙桥为之饯别。而三藏亦一秉虔诚，遵旨意途云。",
  "notes": "按此剧事实，正史实未备载，惟佛经上有贞观十三年，三藏法师往西天取经之说，私家笔记亦往往有之。\n《西游记》小说一书，更为详细。如欲据为征信，则枥老所敢言。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、房玄龄、殷开山、尉迟恭同上。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "金鸡唱罢晓光寒，"
        },
        {
          "character": "房玄龄",
          "type": "念",
          "text": "五凤楼中玉漏残。"
        },
        {
          "character": "殷开山",
          "type": "念",
          "text": "文武百官齐朝贺，"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "正笏垂绅列两班。"
        },
        {
          "character": "徐勣、房玄龄、殷开山、尉迟恭",
          "type": "同白",
          "text": "下官，"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "徐勣。"
        },
        {
          "character": "房玄龄",
          "type": "白",
          "text": "房玄龄。"
        },
        {
          "character": "殷开山",
          "type": "白",
          "text": "殷开山。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "尉迟恭。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "房玄龄、殷开山、尉迟恭",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "万岁登殿，你我在此伺候。"
        },
        {
          "character": "房玄龄、殷开山、尉迟恭",
          "type": "同白",
          "text": "香烟缭绕，圣驾临朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二内侍、李世民同上。"
        },
        {
          "character": "李世民",
          "type": "引子",
          "text": "国泰民安，庆丰年，一统江山。"
        },
        {
          "character": "徐勣、房玄龄、殷开山、尉迟恭",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "徐勣、房玄龄、殷开山、尉迟恭",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "绛帻鸡人报晓筹，珮声响倒凤池头。九天阊阖开宫阙，万国衣冠拜冕旒。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤，大唐天子，贞观在位。自登基以来，风调雨顺，海晏河清。孤有意欲命唐 三藏去求西天真经，以崇佛教。但路途遥远，跋涉艰难。不免将御弟三藏宣上 殿来，与他商议。 内侍！"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "宣唐三藏上殿。"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "领旨。 万岁爷有旨，宣唐三藏上殿呐。"
        },
        {
          "character": "唐三藏",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐三藏上。"
        },
        {
          "character": "唐三藏",
          "type": "念",
          "text": "金钵日食千家饭，破衲穿来万户衣。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "贫僧三藏见驾，愿吾主万岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "御弟平身。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "谢座。万岁将贫僧宣上殿来，不知有何训谕？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤意欲悟道修真，只是天朝无有真经，未能尊崇佛教。不知真经，究在何处？"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "启奏万岁：想那佛教真经，在西域五印度梵王宫内。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "寡人意欲命御弟前去求取真经，只是路途遥远，跋涉艰难，恐怕御弟不能受此 劳苦。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "万岁说那里话来？贫僧久有此心，但是无有天朝玉牒、路引，贫僧定要被各国 番王中途阻拦。万岁既有此心，贫僧不胜欣幸。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "只是路途遥远，过于辛苦。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "唐三藏",
          "type": "二黄原板",
          "text": "唐三藏在金殿把本来进， 尊一声圣天子细听分明： 真经文吾国中无人来问， 五印度梵王宫才有真经。 但愿得吾主爷赐我路引， 哪怕那千山万水道路难行。 有贫僧受皇恩当把诚尽， 说什么一路上辛苦劳神。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "御弟呀！"
        },
        {
          "character": "李世民",
          "type": "二黄原板",
          "text": "有孤王在金殿把话来论， 叫一声唐三藏御弟细听： 我天朝真佛教无人过问， 孤也曾学空门悟道修真。 真经文在印度西域绝境， 梵王宫那才是三藏真经。 但愿得此一去把经文取定， 回朝中孤定要感谢大恩。"
        },
        {
          "character": "唐三藏",
          "type": "二黄原板",
          "text": "我主爷说什么感恩不尽， 取真经到西域是分内所应。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "此番御弟去往西天求取真经，一路上要受不尽风霜之苦。孤赐御弟锦绣袈裟一 件、禅杖一根、紫金宝钵一个、装金僧衣僧帽一袭，小童四人替御弟牵马随镫。 明日其性，孤王率领满朝文武百官，同到长亭饯别。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "贫僧有何德能，敢劳万岁圣驾出城。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "此事本是御弟代孤远行，何须辞让？ 内侍，看文房伺候。"
        },
        {
          "character": "李世民",
          "type": "二黄正板",
          "text": "提龙笔写文牒大唐国号， 孤御弟唐三藏替孤代劳。 各国内众番王休得阻道， 往西天求了经即刻还朝。 孤赐你装金镶僧衣僧帽， 孤赐你紫金钵禅杖一条； 再赐你锦袈裟霞光万道， 再赐你四童儿牵马代劳。 内侍臣与孤王将宝抬到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同抬桌摆各件放台中间，四小童同上。"
        },
        {
          "character": "李世民",
          "type": "二黄正板",
          "text": "金銮殿孤与你改换法袍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。唐三藏换衣帽。"
        },
        {
          "character": "唐三藏",
          "type": "二黄摇板",
          "text": "在金殿谢万岁皇恩深浩， 准备着到西天远走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐三藏下。"
        },
        {
          "character": "李世民",
          "type": "二黄正板",
          "text": "一见三藏下龙廷， 不由孤王喜在心。 回头来叫众卿听孤话论， 明日里文武官俱要出城。 十八家督总管皆要恭敬， 随同孤到沙桥前去饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下。"
        },
        {
          "character": "徐勣、房玄龄、殷开山、尉迟恭",
          "type": "同二黄正板",
          "text": "金殿上领了万岁命， 大家一同去送行。"
        },
        {
          "character": "徐勣、房玄龄、殷开山、尉迟恭",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、房玄龄、殷开山、尉迟恭同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四童子持幡引唐三藏同上。"
        },
        {
          "character": "唐三藏",
          "type": "西皮摇板",
          "text": "在金殿受皇恩深如四海， 赐僧衣并袈裟出了金街。 出家人皈三宝虔持斋戒， 此一去好一比直上天台。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "贫僧，唐三藏。昨日在金殿之上面奉圣旨，替万岁去至西天五印度清净世界梵 王宫中，求取宝藏真经。也曾命满朝文武、众家国公、一十八家督总管，均在 长亭沙桥以外，与贫僧饯行。看天色不早，就此前往。 童儿，带路。"
        },
        {
          "character": "唐三藏",
          "type": "西皮摇板",
          "text": "叫童儿忙带路荒郊以外， 至沙桥等候了圣驾到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐三藏、四童子同下。"
        },
        {
          "character": "李世民",
          "type": "内西皮导板",
          "text": "出离了龙凤阁荒郊外，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四战将、四太监、二内侍、徐勣、房玄龄、殷开山、尉迟恭同上，李世民上。"
        },
        {
          "character": "李世民",
          "type": "西皮原板",
          "text": "有文臣和武将随侍在两排。 唐三藏到西天清净世界， 求取到宝藏经即便归来。 有孤王在宫中也曾斋戒， 一路上设香案顶礼安排。 一霎时来至在长亭以外，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下辇。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "因何故孤御弟不见到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四童子持幡引唐三藏同上。"
        },
        {
          "character": "唐三藏",
          "type": "西皮摇板",
          "text": "白龙马随定了长幡宝盖， 今日里替圣主权做钦差。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐三藏下马。"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "贫僧有何德能，怎敢劳动万岁圣驾到此相送？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "此番求取真经，理应孤王亲往。只因朝中之事无人料理，才命御弟替孤代劳。 今日一来为御弟送行，二来尽孤王求经之诚意。孤王有言，御弟听道。"
        },
        {
          "character": "李世民",
          "type": "西皮二六板",
          "text": "孤王在长亭把旨传， 尊一声御弟三藏听根源： 天朝无有真经卷， 怎令人悟道把禅参？ 你今替孤行方便， 披星戴月去往西天。 孤念你万里征途道路远， 孤念你登山涉水跋涉艰难； 孤念你每夜里投宿在庵观寺院， 孤念你夏日受暑冬日受严寒。 但愿得一路无阻险， 御笔牒文你带在身边。 道经各国叫他们观看， 免得那番王将你阻拦。 倘若得了真经卷， 务须要急速转回还。 孤在朝命人起造寺院， 高设下钟鼓筑起法坛。 那时节令众僧人齐把真经念， 方知道西方佛祖法力无边。 那时节御弟方算是功成圆满， 孤封你参禅法师万古流传。"
        },
        {
          "character": "唐三藏",
          "type": "西皮摇板",
          "text": "谢过了万岁爷皇恩典， 再谢文武臣两班。 辞别圣驾把路趱，"
        },
        {
          "character": "唐三藏",
          "type": "白",
          "text": "带马。"
        },
        {
          "character": "唐三藏",
          "type": "西皮摇板",
          "text": "一并虔诚奔西天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐三藏下，四童子同下。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "一见三藏奔阳关， 眼望沙桥自详参。 但愿取经早回转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同大转场。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "成佛作祖是不老神仙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二内侍、徐勣、房玄龄、殷开山、尉迟恭引李世民同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}