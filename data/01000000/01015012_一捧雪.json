          "character": null,
          "type": "stage",
          "text": "更夫下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上，戚继光拉莫成同上。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "你家老爷来了。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "大人可容我主仆一见？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "正要叫你一见。 来，旗牌，去至监中，请莫大老爷前来。休要惊动严府之人。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命。"
