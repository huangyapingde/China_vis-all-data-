        },
        {
          "character": "莫成",
          "type": "白",
          "text": "是了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光上。"
        },
        {
          "character": "戚继光",
          "type": "二黄摇板",
          "text": "迈步且把大街进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成哭。"
