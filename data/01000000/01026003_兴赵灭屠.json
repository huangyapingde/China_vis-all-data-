{
  "script_id": "01026003",
  "title": "兴赵灭屠",
  "alias": [
    "屠赵仇"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "程婴",
      "hangdang": "外"
    },
    {
      "name": "屠岸贾",
      "hangdang": "净"
    },
    {
      "name": "韩厥",
      "hangdang": "末"
    },
    {
      "name": "晋成公",
      "hangdang": "小生"
    },
    {
      "name": "赵武",
      "hangdang": "小生"
    },
    {
      "name": "荀斌",
      "hangdang": "生"
    },
    {
      "name": "魏绛",
      "hangdang": "副净"
    },
    {
      "name": "羊舌职",
      "hangdang": "丑"
    }
  ],
  "plot": "春秋时，晋国屠岸贾指称赵氏为弑君罪魁，尽灭其族。赵氏门客程婴，与友公孙杵臼定计，舍子救孤，欲存\n赵氏一脉，为他日复仇起见。公孙杵臼赴义而死，程婴匿赵孤于孟山，忽忽十五年。值晋成公初即位，追念\n晋国功臣。其时韩厥执政，为中军元帅，将赵氏之冤诬，密言于晋成公，杀屠岸贾，亦尽灭其族。乃征求程\n婴赵孤，录以官爵，录以家财，从此报仇雪恨，大快人心。赵孤既能成立，程婴不欲负死友公孙杵臼，遂自\n刎而死。赵孤名武，谥文子，不数年间，亦为晋国中军元帅，名显诸侯。后来强盛，至战国时，有南面称赵\n王者，即其传留之子孙。",
  "notes": "《八义图》一出，本考第二册业已载入，是剧即《八义图》后本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "晋成公",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、内侍引晋成公同上。"
        },
        {
          "character": "晋成公",
          "type": "西皮摇板",
          "text": "金殿赐罢群臣宴， 君民长此戴尧天。 内侍摆驾皇宫院， 快宣韩厥把驾参。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "内侍，宣中军大元帅韩厥进宫。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "大王有旨：宣中军大元帅韩厥进宫。"
        },
        {
          "character": "韩厥",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥上。"
        },
        {
          "character": "韩厥",
          "type": "西皮摇板",
          "text": "忽听大王一声宣， 品级台前奏龙颜。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "臣韩厥参见大王千岁！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "谢座。大王将臣宣进宫来，有何国事议论？"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "卿家有所不知，只因众卿迎立寡人为君。即位以来，但不知君臣之内，哪家功 劳最大？卿家要一一奏来，孤好论功行赏。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "大王此言，敢是思念功臣么？"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "大王若问晋国的功臣，无有过于那赵氏者。想当年，赵衰⑴辅佐文公，赵盾扶 保襄公，俱能尽忠竭力，图霸扬威。不幸灵公失政，宠信倭臣屠岸贾⑵，专权 乱政。那老贼与赵氏素有仇恨，在后宫暗奏一本，诬赖他赵家有弑君之罪。那 时节，灵公不分皂白，兵围下宫，将赵氏满门尽行诛戮。此事人人怨恨，均抱 不平。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "如此说来，那赵家如今定然是无有后了。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "大王有所不知，也是皇天默佑忠良，赵氏遗有孤儿，名唤赵武，至今尚在。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "但不知此子怎能逃脱性命？现在何处？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "只因赵家被害之后，赵朔之妻，就是公主庄姬，逃在后宫，产生孤儿。那屠岸 贾又要斩草除根，立下千金重赏，搜索孤儿。那时赵氏门客，有一人名唤程婴， 与那门客公孙杵臼，定下一计。程婴舍了亲生之子，假充孤儿，命公孙杵臼 献于屠贼。可怜此子与公孙杵臼双双丧命。那程婴抱定真孤，隐藏在孟山之内， 至今十有五年，冤仇未报。大王今日若要赏功罚罪，大修晋政，何不追录赵 氏之功？"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "如此，就命卿家速往孟山，唤那程婴，带同赵武，前来见驾，孤家好与他报仇 雪恨。此事不可声张，须要机密。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": "韩厥",
          "type": "西皮摇板",
          "text": "说明了赵氏冤仇恨， 去到孟山唤程婴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥下。"
        },
        {
          "character": "晋成公",
          "type": "西皮摇板",
          "text": "内侍摆驾后宫进， 程婴可算忠义人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋成公、内侍、四太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程婴、赵武同上，"
        },
        {
          "character": "程婴",
          "type": "西皮原板",
          "text": "有程婴扶孤儿隐藏孟山， 到如今屈指算一十五年。 吾心中不把那别人来怨， 骂一声老屠贼卖国的佞奸。 那赵家他与你有何仇怨， 你苦苦要害他所为哪般？ 害的他一家人刀刀论斩， 一心心要断他后代的香烟。 我与那公孙兄把计来献， 狗奸贼果中了巧机关。 实可叹公孙兄年迈苍苍刀下问斩， 可怜我也绝了后代的儿男。 但愿得老天爷早早睁眼， 灭却了老奸贼早报仇冤。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "卑人程婴。想当年，救下赵氏孤儿，隐藏在这孟山之内，至今十有五载，冤仇 未报，抱恨终天。"
        },
        {
          "character": "程婴",
          "type": "叫头",
          "text": "苍天呐，天！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "难道这冥冥之中，就无有报应了么？"
        },
        {
          "character": "程婴",
          "type": "西皮摇板",
          "text": "恨苍天不与人方便， 赵氏含冤在九泉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌引韩厥同上。"
        },
        {
          "character": "韩厥",
          "type": "西皮摇板",
          "text": "时才离了皇宫院， 来寻义士到孟山。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "程兄在哪里？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "哎呀哎呀，韩大人到了，请坐请坐。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "大人到此，但不知所为何事？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "程兄有所不知：只因现在新君即位，思念功臣。老夫将你十五年前救孤之事， 一一奏明千岁。今奉圣命，唤你带领赵武进宫见驾，要与赵氏报仇雪恨。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "那屠贼何在？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "此事他是一些不知。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "此事有劳大人了。 啊哈赵公子，快来见过韩大人。"
        },
        {
          "character": "赵武",
          "type": "白",
          "text": "参见大人。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "这就是赵小将军么？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "一十五载的光阴，倒也是成人了。请坐。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "想赵氏一十五载的冤仇，多亏大人保奏。赵氏忠魂定当戴德感恩于地下也！"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "岂敢。老夫有何德能，敢劳称赞。此事俱是程兄的忠义所感。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "大人哪！"
        },
        {
          "character": "程婴",
          "type": "西皮顶板",
          "text": "说什么忠义感动人，"
        },
        {
          "character": "程婴",
          "type": "西皮二六板",
          "text": "这才是有志事竟成。 今日里赵氏得雪恨， 论忠义还要让杵臼公孙。"
        },
        {
          "character": "韩厥",
          "type": "西皮摇板",
          "text": "程兄不必太谦逊， 你二人忠义不差毫分。 你舍娇儿他舍命， 博得美名万古存。 我等一同把宫进， 报仇全仗圣明君。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "你我三人，就此进宫去者。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "韩厥",
          "type": "西皮摇板",
          "text": "赵氏含冤十五春，"
        },
        {
          "character": "程婴",
          "type": "西皮摇板",
          "text": "臣民愤怨到如今。"
        },
        {
          "character": "韩厥",
          "type": "西皮摇板",
          "text": "老夫头前把路引，"
        },
        {
          "character": "程婴",
          "type": "西皮摇板",
          "text": "背转身来两泪淋。 若能报得冤仇恨， 这才是苍天不负苦心人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥、程婴、赵武、二旗牌同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "内侍提灯上。"
        },
        {
          "character": "内侍",
          "type": "念",
          "text": "深宫领密旨，接待功臣裔。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "咱家，穿宫太监是也。主公只为赵家之事，恐怕走漏消息，特命咱家在后宫门， 等候韩大人同那义士程婴、孤儿赵武。来在宫门，待我听听谯楼打了几鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内打三更鼓。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "谯楼已交三鼓，他等想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥引程婴、赵武同上。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "公公请了！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "请啦。韩大人回来了吗？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "这二位就是义士程婴、孤儿赵武么？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "正是。 你等见过公公。"
        },
        {
          "character": "程婴、赵武",
          "type": "同白",
          "text": "参见公公！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "罢啦罢啦。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "吓，公公，但不知主公是怎样传旨？"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "主公正为此事叫咱家在此等候。你等来、来、来，随咱家进宫见驾。"
        },
        {
          "character": "韩厥、程婴、赵武、内侍",
          "type": "同白",
          "text": "正是："
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "十五年前救赵孤，"
        },
        {
          "character": "赵武",
          "type": "念",
          "text": "先人阴灵暗中扶。"
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "亲生娇儿今何在？"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "程爷呀！"
        },
        {
          "character": "内侍",
          "type": "念",
          "text": "千古应传义士图。"
        },
        {
          "character": "内侍",
          "type": "笑",
          "text": "哈哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍、韩厥、程婴、赵武同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四校尉引屠岸贾同上。"
        },
        {
          "character": "屠岸贾",
          "type": "引子",
          "text": "独立朝纲，保晋国，锦绣家邦。"
        },
        {
          "character": "屠岸贾",
          "type": "念",
          "text": "忆昔奉君在桃园，某与赵氏结仇怨。多亏程婴孤儿献，老夫才得安枕眠。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "老夫屠岸贾，晋国为臣，官拜大司寇之职。昨夜三更时分，偶得一梦，甚是不 详。今日主公升殿，只得前去朝参。 校尉们！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "吩咐外面顺轿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上。"
        },
        {
          "character": "屠岸贾",
          "type": "西皮导板",
          "text": "昨夜晚得一梦心中不定，"
        },
        {
          "character": "屠岸贾",
          "type": "西皮原板",
          "text": "梦见了斑斓虎闯下山林。 山坡下一群羊来把水饮， 遇猛虎一个个俱丧幽冥。 醒来时听谯楼三更时分， 吓得我战兢兢遍体汗淋。 清晨起查梦书主多凶信， 怕的是萧墙内大祸临身。 叫人来忙开道朝房来进，"
        },
        {
          "character": "屠岸贾",
          "type": "西皮摇板",
          "text": "今日里须得要见机而行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩厥、荀斌、魏绛、羊舌职同上。"
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "列国纷纷起战争，"
        },
        {
          "character": "荀斌",
          "type": "念",
          "text": "东杀西战动刀兵。"
        },
        {
          "character": "魏绛",
          "type": "念",
          "text": "扶立新君登大统，"
        },
        {
          "character": "羊舌职",
          "type": "念",
          "text": "保定晋国锦乾坤。"
        },
        {
          "character": "韩厥、荀斌、魏绛、羊舌职",
          "type": "同白",
          "text": "老夫——"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "中军元帅韩厥。"
        },
        {
          "character": "荀斌",
          "type": "白",
          "text": "车右将军荀宾。"
        },
        {
          "character": "魏绛",
          "type": "白",
          "text": "中军司马魏绛。"
        },
        {
          "character": "羊舌职",
          "type": "白",
          "text": "上大夫羊舌职。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "荀斌、魏绛、羊舌职",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "主公升殿，我等两厢伺候。远远望见大司寇来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四校尉引屠岸贾同上，屠岸贾下轿，四青袍、四校尉同暗下。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "列位大人请了！"
        },
        {
          "character": "韩厥、荀斌、魏绛、羊舌职",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "主公升殿，大家在此伺候，请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、内侍、晋成公同上。"
        },
        {
          "character": "晋成公",
          "type": "引子",
          "text": "罪罚赏功，忆赵氏，赐爵加封。"
        },
        {
          "character": "晋成公",
          "type": "念",
          "text": "昔年曾倚单⑶襄公，今日即位在绛城。列国不敢来侵犯，全仗文公霸业名。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "孤，姬周，即位绛城。只因赵家一事，未见分明，叫孤好恼好恨！"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "主公今日登殿，为何这等烦恼？"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "众卿有所不知，只因功臣簿上，有一事不明，故而烦恼。"
        },
        {
          "character": "韩厥、荀斌、魏绛、羊舌职、屠岸贾",
          "type": "同白",
          "text": "主公有何事不明，当面请讲。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "想那赵衰、赵盾，两世功臣，扶保晋国，为何将他满门斩首？看忠臣如此结果， 叫人焉能不恨！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "主公吓，想那赵氏，灭门已有一十五年，今日主公追念其功，但是他后辈无人， 也是枉然的了！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "你道他当真无后么？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "呣，自然是无后的了。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "内侍，附耳过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍下。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "众卿！"
        },
        {
          "character": "韩厥、荀斌、魏绛、羊舌职、屠岸贾",
          "type": "同白",
          "text": "臣！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "此事少时管叫你等明白也！"
        },
        {
          "character": "晋成公",
          "type": "二黄摇板",
          "text": "孤王金殿把话论， 叫一声众卿听在心： 赵家血海冤仇恨， 少时定要见分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。内侍引程婴、赵武同上。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "昨夜后宫参圣君， 要与赵家报怨痕。 手挽孤儿金殿进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴看屠岸贾，怒视。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "面前站定对头人。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "参见主公！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "见过满朝文武。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "呵，列位大人！"
        },
        {
          "character": "韩厥、荀斌、魏绛、羊舌职",
          "type": "同白",
          "text": "罢了。这一位小郎君，他是何人？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "众位大人有所不知，此人就是那孤儿赵武。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手同暗上。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "唔，胆大屠岸贾！你这老贼，在晋国之中，每每苦害忠良，该当何罪！今日若 不杀你，天理何在！ 刀斧手！与孤将他绑了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手同绑屠岸贾。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "主公吓！想那赵氏孤儿，乃是逆臣之后，已被为臣将他斩首。事已经过十五年 矣，今日哪里还有什么孤儿！莫听这老匹夫胡言乱道。"
        },
        {
          "character": "程婴",
          "type": "笑",
          "text": "呵哈哈哈哈哈！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "我把你这老贼，事到如今，你还醉生梦死。若不说明此事，你死在阴曹，也难 甘心瞑目。并请列位大人听者：想当年，你这老贼，搜索孤儿甚急，是我与公 孙杵臼定下一计，舍却我亲生之子，假冒孤儿，献于你这老贼。可怜他与杵臼 废命。那时节，老夫抱定赵氏真孤，藏在孟山之内。屈指算来，十有五载。今 日才的冤怨相报。你只道剪草除根，永无后患，不了这天理昭彰，报应循环。 正是："
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "暑去寒来十五秋，屠、赵两家结冤仇。今朝一报还一报，才把老贼一笔勾。"
        },
        {
          "character": "程婴",
          "type": "叫头",
          "text": "奸贼呀，屠岸贾！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "话已说明，你今日所为是自取灭亡，死后休怨我程婴也！"
        },
        {
          "character": "韩厥、荀斌、魏绛、羊舌职",
          "type": "同白",
          "text": "原来如此！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "想当年献孤儿并非是真， 狗奸贼中巧计误杀好人。 今日里他赵家雪了怨恨， 你死在阴曹府休怨我程婴。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "听他言来心内惊， 原来中了他巧计行。 只说斩草把根除净， 谁想萌芽又复生。 恨不得一足结果尔的命，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾踢。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "看昏王把我怎样行！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "刀斧手推出斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手推屠岸贾同下。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "韩厥、赵武听令：命你等带领校尉四十名，抄杀屠岸贾满门家眷。"
        },
        {
          "character": "赵武、韩厥",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人讨祭。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "祭奠哪个？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "祭奠赵氏忠魂与那公孙杵臼，不知主公准与不准？"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "焉有不准之理。 内侍退班！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "谢主公！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥、荀斌、魏绛、羊舌职、赵武、晋成公、内侍、四太监同暗下。"
        },
        {
          "character": "程婴",
          "type": "二黄导板",
          "text": "可恨老贼屠岸贾，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥、赵武带四校尉双上，同跑下。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "赶尽杀绝害赵孤。 天理循环报应到， 看他一样画葫芦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "屠岸贾",
          "type": "内二黄导板",
          "text": "号炮三声声如雷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手引屠岸贾同上。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄顶板",
          "text": "不由人一阵阵珠泪双垂。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄原板",
          "text": "悔不该与赵家苦苦作对， 害的他一家大小好不伤悲。 我只说赵门中绝了后辈， 又谁知孤儿在天网恢恢。 可叹我在晋国官居相位， 到如今只落得身披枷、项带练，午时三刻，号炮一声，把我的老命来追。 这才是，王子犯法庶民同罪， 也是我自作自受又怨着谁？ 泪汪汪哭进了法场以内，"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "到如今说什么谁是谁非！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "我当年献孤儿人人唾骂， 到如今方显出水月镜花。 将身儿来至在法场下， 那边厢绑定了对头冤家。"
        },
        {
          "character": "程婴",
          "type": "叫头",
          "text": "屠岸贾！吓！老奸贼！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "想那赵家与你何仇何恨，你苦苦害他全家一死。你只道斩草除根，永无后患， 不料天理循环，法网难逃。也有今日呵！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "奸贼做事太欺心， 苦害忠良为何情？ 你只道上天无报应， 今日里也要灭你满门。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "我与赵家结怨恨， 你是他的什么人？ 我今一死不要紧，"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "程婴呐！老匹夫！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "阴曹地府要勾你的魂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手推屠岸贾同下，斩。〖牌子〗。程婴祭。"
        },
        {
          "character": "程婴",
          "type": "三叫头",
          "text": "赵驸马！公孙兄！我那亲生的儿吓！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "在法场祭忠魂珠泪滚滚，"
        },
        {
          "character": "程婴",
          "type": "三叫头",
          "text": "赵驸马！公孙兄！我那亲生的儿吓！"
        },
        {
          "character": "程婴",
          "type": "大回龙",
          "text": "尊一声赵驸马细听原因："
        },
        {
          "character": "程婴",
          "type": "反二黄正板",
          "text": "想当年你赵家何等强盛， 秉忠心扶晋国建立功勋。 都只为晋灵公桃园失政， 老奸贼屠岸贾苦害功臣。 那奸贼在后宫暗奏一本， 他诬赖你赵家当年弑君。 也是你一家人今当丧命， 那奸贼他又要剪草除根。 那时我与公孙把苦肉计定， 舍亲生替孤儿以假混真。 可怜我亲生子法场丧命，法场丧命，我的儿吓！"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "转面来再哭声先死的公孙： 可叹你为赵家侠义耿耿， 可叹你白虎堂受尽酷刑； 可叹你年迈人死于非命， 可叹你为孤儿杀身成仁。 今日里赵氏兴报仇雪恨， 也不负你当初一片苦心。 但愿你魂灵儿早登仙境， 但愿你子子孙孙世受皇恩。 望兄长在阴曹将弟来等，将弟来等，公孙兄吓！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "等老朽我与你一路同行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。程婴拜。"
        },
        {
          "character": "内侍",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "接旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引内侍同上。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "圣旨下，跪。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "奉天承运皇帝诏曰：寡人追念赵氏功勋，今封赵武为大司寇之职，公孙杵臼与 程婴之子，仗义捐躯，其情可悯，封为忠义正神。程婴舍子救孤，侠义可嘉， 封为军政司。旨意读罢，望诏谢恩！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "且住！想我程婴，当年不死，原为孤儿尚未成人，冤仇未雪。今日已封官报仇， 我若贪图富贵，有何脸面见那公孙杵臼乎？"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "只为赵氏冤未伸， 忍辱含羞到如今。 今日已报了冤仇恨，"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "程婴",
          "type": "二黄摇板",
          "text": "九原含笑见公孙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴自刎，下。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "看程婴自刎已死，不免回宫奏于主公知道便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。〖牌子〗。内侍、四太监同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
