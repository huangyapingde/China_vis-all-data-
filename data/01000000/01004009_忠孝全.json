          "text": "令出山摇动。"
        },
        {
          "character": "秦季龙",
          "type": "念",
          "text": "严法鬼神惊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "且住，想我爹爹现在福建为官，千岁令监斩福建运粮官，莫非是我爹爹前来？ 且到法场便知明白。 打道法场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "秦洪",
          "type": "内二黄导板",
          "text": "犯官受刑身无主，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刀斧手、众人同上，同下，秦洪上。"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "二目无精好伤情。 鼓儿不住咚咚响， 锣儿铛铛要动刑。 法场上好一比森罗殿， 王公公好比那五殿阎君。 刽子手他好似催命判， 我好比怨鬼等时辰。 再不能宛平为正印， 再不能福建辖黎民。 再不能丹心忧国事， 再不能二堂训子孙。 哭一声季龙儿今何在， 父子门相逢在鬼门关。 忍泪且把法场进， 紧闭双眼命归阴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人引秦季龙同上。"
        },
        {
          "character": "秦季龙",
          "type": "二黄导板",
          "text": "营中奉了千岁命，"
        },
        {
          "character": "秦季龙",
          "type": "二黄摇板",
          "text": "监斩福建运粮官。 且进法场下金镫， 一一从头问分明。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "来，问那犯官，家住哪里，姓字名谁？典刑之后，也好收他尸首。"
        },
        {
          "character": "刀斧手",
          "type": "白",
          "text": "这一犯官，家住哪里，姓字名谁？典刑之后，也好收你尸首。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "请爷打坐近前。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "一一讲来。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "容禀。"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "未曾开言泪双淋， 尊一声监斩爷听详情："
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "家住哪里？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "家住山东莱州郡，"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "哪里有家？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "黎英县内有家门。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "哪一科得中？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "甲午年前曾中举，"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "可曾会进？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "连科得中进士身。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "初任在哪里为官？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "初任宛平为正印，"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "可曾升出？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "加升福建管黎民。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "为了何事将你斩首？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "都只为金鳌犯边境， 误卯不到问斩刑。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "可有儿子？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "犯官膝下有三子，"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "亲生还是螟蛉？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "秦季英、秦季远是我亲生子，"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "螟蛉叫什么？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "秦季龙就是我一螟蛉。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "季龙在家做些什么？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "他弃文从武不听教训， 一家四口赶出门。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "如今可想他？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "眼前若见姣生子， 虽死黄泉也甘心。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "秦洪",
          "type": "二黄慢板",
          "text": "监斩爷问我的名和姓，"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "请来看，"
        },
        {
          "character": "秦洪",
          "type": "唱",
          "text": "红旗下现有犯官名。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "秦季龙",
          "type": "二黄摇板",
          "text": "听罢言来晓其情， 原来爹爹到边庭。 刀斧手与爷忙松绑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "手下同允。"
        },
        {
          "character": "秦季龙",
          "type": "二黄摇板",
          "text": "双膝跪在地埃尘。"
        },
        {
          "character": "秦洪",
          "type": "二黄导板",
          "text": "法场上绑得我昏迷不醒，"
        },
        {
          "character": "秦洪",
          "type": "二黄摇板",
          "text": "七魄悠悠又还魂。 猛然间睁开昏花眼，"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "爹爹醒来！"
        },
        {
          "character": "秦洪",
          "type": "二黄摇板",
          "text": "问声监斩是何人？"
        },
        {
          "character": "秦季龙",
          "type": "二黄摇板",
          "text": "爹爹把孩儿忘怀了， 不孝季龙是儿名。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "儿是季龙？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "姣儿！"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "儿吓。"
        },
        {
          "character": "秦洪",
          "type": "二黄摇板",
          "text": "只说父子不能会， 谁知枯木又逢春。 烈烈轰轰身荣贵， 想起前事冷汗淋。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "慢着。替为父松绑，可有圣上的旨意？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "王公公将令？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "也没有。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "秦洪",
          "type": "二黄摇板",
          "text": "私自松绑该何罪， 知法犯法罪非轻。 父今一死又何惧， 岂能连累小姣生。"
        },
        {
          "character": "秦季龙",
          "type": "二黄摇板",
          "text": "爹爹只管放宽心， 孩儿言来听分明： 你养儿小来我养父老， 报答你养育一番恩。 人来将爷上了捆， 王公公营前求人情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王振上。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "吓，怎么？后军都府如何绑起来了？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "替父受绑。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "先前问你说没有父亲，如今这个父亲是从天上掉下来的不成？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "此乃养身之父。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "好，起来。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "哪有子站父跪的道理？"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "都起来罢。"
        },
        {
          "character": "秦洪、秦季龙",
          "type": "同白",
          "text": "谢千岁！"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "秦季龙法场救父，又有大功，待咱家与你奏转。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王振下。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "儿吓，分别之后，哪有这身荣耀？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "一言难尽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "王振",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王振上，小内监捧冠上。〖吹打〗。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "圣旨下，跪。"
        },
        {
          "character": "秦洪、秦季龙",
          "type": "同白",
          "text": "万岁。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "宣读诏曰：秦洪运粮不到，理当取斩。念在秦季龙征战金鳌有功，赦却死罪， 封为养老太师。秦季龙征剿番王，得胜回朝，可算一忠；法场救父，可算一孝， 封为忠孝王。妻一品夫人，福建知府女，正宫见喜，认为义女。钦赐半副銮 驾，归家祭祖。一路之上，旱路让成八尺，水路准备彩船，外赐尚方宝剑。先 斩后奏，动身之时。合朝文武，长亭饯行。祭祖一毕，来京供职。旨意读罢， 望阙谢恩。"
        },
        {
          "character": "秦洪、秦季龙",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "请旨意。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "多谢千岁！"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "老太师你好造化，犯罪有忠孝王求情，咱家好恨。"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "敢是恨我父子？"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "咱家身在帝王边，如羊伴虎，老太师我事不周全……"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "如此将小儿拜在膝下。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "他是忠孝王，你是老太师。咱一个太监，敢受忠孝王拜么？"
        },
        {
          "character": "秦洪",
          "type": "白",
          "text": "儿吓，拜过千岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦季龙拜。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "金豆银豆送与忠孝王。随我上殿谢恩去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}