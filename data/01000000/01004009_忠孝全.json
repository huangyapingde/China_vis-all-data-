{
  "script_id": "01004009",
  "title": "忠孝全",
  "alias": [
    "斩秦洪；一名：金鳌岛"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "秦季龙",
      "hangdang": "小生"
    },
    {
      "name": "王振",
      "hangdang": "净"
    },
    {
      "name": "秦洪",
      "hangdang": "末"
    }
  ],
  "plot": "明英宗时有秦季龙者，秦洪之子也。自幼失散在外。喜习拳棒，精通诸般武艺，膂力过人。能开五石弓，百\n发百中。后海寇金鳌作乱，英宗命太监王振，总督天下兵马粮饷，征剿金鳌。至山东招兵，募得秦季龙。王\n振颇爱其才，因遂宠任之，即令带领前锋军，往剿金鳌。既而金鳌败降，海氛悉平。秦季龙功成班师，荣宠\n无比。时王振催集天下粮饷，适福建督粮官中途因雨延误，后期而至，致触王振怒，即以军法相绳。令秦季\n龙监斩，孰意督粮官即季龙父秦洪也。父子法场相会，彼此皆抱头大哭。于是秦季龙自缚请罪，引父见王振。\n王振亦遂赦之，并为奏明英宗。旨下，特书秦季龙为忠孝王，因是剧名《忠孝全》云。",
  "notes": "此剧惟朱素云最擅入场，盖素云温文尔雅，英爽风流，其扮演少年儒将，固无剧不佳也，岂独忠孝全哉。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王振上，四小监、四龙套、四将同上。"
        },
        {
          "character": "王振",
          "type": "引子",
          "text": "日侍天颜，司礼监，国重专权。"
        },
        {
          "character": "王振",
          "type": "念",
          "text": "云里帝城近紫微，身尊炉香绕凤飞。文臣武将难定国，敕命咱家振军威。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "咱家王振。大明正德皇帝驾下……哈哈哈，一个得宠专权的内监。近日海口金 鳌作乱，这些武官儿，软弱无能；文班这些官儿，又都是白面书生。所以皇上 恩典，命咱家督兵征剿。咱家心中暗想，我有什么能干呢，还敢出头打得一战 么？必须招兵聚将，收几个有武艺的，帮助帮助。或者托天之福，能平贼立功。 中军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军允。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "你到营门口料理料理，瞧瞧有人投军没有。不要装几巴。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦季龙上。"
        },
        {
          "character": "秦季龙",
          "type": "念",
          "text": "上山擒虎易，开口告人难。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "营门哪位爷在？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "前来投军。烦老爷通报。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦季龙允。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启千岁：有一投军人求见。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "吓。 千岁传，小心了。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "是。 投军人叩见千岁。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "有何武艺？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "十八般武艺，俱属全会。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "哪样为先？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "弓马当先。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "秦季龙。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "可有弓马？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "有弓无箭缺马。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "咱家赏你箭马，下去试来。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦季龙下，内场射箭，上。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "秦季龙一马三箭，俱中中靶。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "果然好箭。秦季龙是哪里人氏？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "山东莱州府人氏。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "一家几口？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "一家四口。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "可有父母？"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "这个……没有。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "没有，孩子就说没有，有就说有，不要混说。上了军册薄句不能改的了。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "本来的没有。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "咱家看你倒很中用的样儿，赏你令箭一支，前去探看金鳌消息如何？速速回来 交令。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "站着。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "那金鳌是海寇出身，出没不常。你要见了他，可以杀就杀，不可杀就跑。孩子 人是个活的。去罢。"
        },
        {
          "character": "秦季龙",
          "type": "白",
          "text": "是。 马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦季龙下。安太上。"
        },
        {
          "character": "安太",
          "type": "念",
          "text": "头带红一缨，假充营里兵。大炮一声响，三天难做声。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "我姓安名太，河间府人氏。听得王公公投军，我前去巴结巴结。若是出头，比 这剃头修脚好吓。来此营门。 喂，攒出一个来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "唗！投军吃粮的么？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "吃凉的，我怕肚子疼，要吃就多谢热的。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "呸，吃钱粮的粮，你混说什么？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "吓，我就是来吃你的娘。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "唗。额数已足，不能添人。去罢。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "是了。弱兵在前，强兵在后，我是好的。中军老爷，求求你老报报。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "你是好的？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "吓，好的多呢。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "但看你的缘分。候着。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "禀千岁：额数已满，又有一人投军，声言大有本领。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "好的在后也未可知。也罢，传他进来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "哎呀，王公公若准了我的投军，必要考考我的武艺。我还是空肚子，且去吃碗 饭再来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安太下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "呔，投军的，千岁传你进帐。哎哎，投军的人呢？吓吓，哪里去了？"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "吓，中军呢？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "投军人呢？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启千岁：中军在营门，明明见一人前来投军，岂知乃是站着做梦呢。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "哈哈哈。好，咱家为朝廷公事，昼夜操心，份所当然。你竟站着做梦，梦见投 军的好汉，前来禀我。可见你这个心，比我还着急。来来来，赏你大元宝一锭， 以后更要留心办事。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "谢公公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安太上。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "哎呀，好贵饼，四百八十钱吃三斤。你瞧我这个肚子，饱的圆圆的。这还不是 虎背熊腰，一考必中？ 中军爷呢，可曾禀过？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "吓，你是方才投军的人呢？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "是吓。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "你往哪里去的？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "我怕肚子饿，受不住考，吃碗饭去的，回来好考。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着。 哎，我看你这付穷相，少时见了千岁爷，只怕要考出你的大粪来。 禀千岁：又有个投军的好汉。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "吓，又有个投军好汉？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "且叫他进来，我瞧瞧。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是是。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "哎吓，中军老爷说公公要考出我的大粪来，这话说得是吓。我吃了个饱，还怕 没大粪？且先去拉屎去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安太下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "吓，投军的呢？吓吓，哪里去了？ 禀千岁：中军又是做梦。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "唗，哪里是梦，你是想要发财来。把元宝追回。你戏弄咱家，本要杀你，念你 服侍我多年。 来，绑了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "孩子们，你且在营门口站着，看做梦不做梦，再来回话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允，安太上。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "钱也是钱，饼也是饼。拉总拉不出来，拉出来足有黄瓜大，这肚子松动了。 中军呢？吓，你老爷浑身上了白绫带了？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "哽，你又来了？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "我拉屎来好考。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "咳，好遭瘟。来来来，我替你说句话。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "你老有话说，想必是那话。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "附耳上来。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "吓，哎啊啊。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "投军人到。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "绑松了。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "吓，你就是好汉么？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "吓吓，我叫安太。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "会什么武艺？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "我会十九般。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "只有十八般，哪有十九般？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "我多一般。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "多一般什么？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "骂。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "哽，骂谁？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "会骂阵。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "哈哈哈。好算一能。到底哪样当先？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "手铳。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "哎，火攻吓。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "不错，火攻。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "演来我看。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "是，照枪。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "呔，怎么朝上打？"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "斩将擒王。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "唗，擒番王朝外攻。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "这免得使刀，响了没有？"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "赶出去。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "我还有大刀。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "演来。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "赶了出去。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "哎呀，千岁。我房屋田地俱已卖尽，无有粮饷与我，我死也不回去。"
        },
        {
          "character": "王振",
          "type": "白",
          "text": "也罢。念尔投军一场，赏你一名火头军。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "起来，有了钱粮了。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "有钱粮，我就起来。什么官？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "火头军。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "火头军有多大？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "出了品呢。"
        },
        {
          "character": "安太",
          "type": "白",
          "text": "出了品，我要封侯了。"
