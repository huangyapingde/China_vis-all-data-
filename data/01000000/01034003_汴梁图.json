{
  "script_id": "01034003",
  "title": "汴梁图",
  "alias": [
    "汴梁杀宫；一名：彦威造反"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "王子",
      "hangdang": "生"
    },
    {
      "name": "刘瑞莲",
      "hangdang": "旦"
    },
    {
      "name": "西宫",
      "hangdang": "旦"
    },
    {
      "name": "太师",
      "hangdang": "净"
    }
  ],
  "plot": "西宫郭妃之父，依仗内宠，其子又手握兵权。因擅权怙势，久怀不臣之心。日者欲效王莽篡弑平帝故事，于\n家中设宴，请帝妃临幸，将于酒后谋弑之。帝妃不察，即命备车驾往。惟正宫刘后，烛知其奸，力阻帝勿往。\n帝昵于西宫故不听，遂赴宴，讵竟坠计中，迨酒酣，国丈率家将拟弑之，幸内侍先闻信，急引帝遁，得不\n遇害。一面，刘后亦早派赵甫在暗中接应，乃得安然还宫。讵国丈见暗计未成，复又率领兵将，入宫搜杀，\n赖刘后与赵甫力战宫门，卒擒国丈。既而刘后欲杀西宫，帝本不忍，经西宫再三求，益不忍，盖知西宫之实\n不预谋也。然刘后盛怒卒不解，且念国家大局，终杀之。全剧精要，即在此一场。从前唱皮簧，今则都唱梆\n子秦腔亦。",
  "notes": "《汴梁图》为后五代汉周间事。前京沪各班及江湖班中，均常演奏，惟系文武旦之重头戏，顾曲者多不甚重\n视，故多排在第三、四个码子。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四小太监、大太监，王子同上。"
        },
        {
          "character": "王子",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西宫上。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "万岁在上，小妃见驾，吾皇万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童平身。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童上殿，有何本奏？"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "启奏万岁，我父府下，设摆君臣大宴，请万岁过府饮宴。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童，太师现在何处？"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "我父现在午门候旨。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童替孤传旨，宣太师上殿。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "领旨。 万岁有旨：宣太师上殿。"
        },
        {
          "character": "太师",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。太师上。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "老臣见驾，愿吾皇万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "太师平身。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "谢座。万岁宣老臣上殿，有何军情？"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "适才梓童奏道：太师设摆酒宴请孤，有何国事议论？"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "无有国家大事，请万岁饮太平酒宴。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "太师回府设宴，孤随后就到。领旨下殿。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "谢旨。 正是："
        },
        {
          "character": "太师",
          "type": "念",
          "text": "满江撒下金罗网，哪怕鱼儿不上钩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太师下。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童随孤过府饮宴。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "准备龙车凤辇，太师府饮宴。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "刘瑞莲",
          "type": "内白",
          "text": "慢、慢、慢着！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "何人保驾？"
        },
        {
          "character": "刘瑞莲",
          "type": "内白",
          "text": "刘娘娘保驾。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "刘娘娘保驾随旨上殿。"
        },
        {
          "character": "刘瑞莲",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘瑞莲上。"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮快板",
          "text": "又听万岁一声宣， 不知宣我为哪般。 行走来在皇宫院， 参罢驾来问罢安。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "小妃见驾，吾皇万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童平身。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "参见皇姐。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "不消！"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "不消就不消。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "万岁适才传旨，要想何往？"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "太师府下，设摆君臣大宴，请寡人前去赴宴。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "万岁，不可前去。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "怎么去不的？"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "我想君入臣府，此乃国家不祥之兆，万岁万万去不得。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "皇姐，万岁过府饮宴，你为何阻驾？"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "小贱妃多言！你父请万岁饮宴，你父女有谋害万岁之意么？"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "皇姐讲得哪里话来，想我父乃是当朝太师，焉有谋害万岁之意？万岁去得的。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "去不的。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "去得的。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "去不的。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "且慢，你二人不必争论，寡人龙心已定。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "且慢，小妃有本奏上。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "有本改日再奏。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮导板",
          "text": "万岁不必离宫院，"
        },
        {
          "character": "刘瑞莲",
          "type": "唱",
          "text": "小妃有言奏君前： 昔日里有个汉平帝， 他朝中又出了王莽奸贼。 他府中设下了毒药酒宴， 他要害平帝爷命归阴间。 我的主不要你过府饮宴， 这才是前朝古表在君前。"
        },
        {
          "character": "西宫",
          "type": "西皮原板",
          "text": "皇姐讲话理不该， 听妹妹把话对你言： 我父设摆君臣宴， 你怎言要害万岁命归阴间？"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮原板",
          "text": "小贱妃你还敢巧言舌辩， 万岁面前敢多言！ 我若不念万岁面， 管叫你命归黄泉。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": "王子",
          "type": "西皮导板",
          "text": "好一个胆大刘瑞莲，"
        },
        {
          "character": "王子",
          "type": "唱",
          "text": "寡人面前反了天。 内侍与孤看车辇， 看她二人谁忠谁奸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王子、西宫、四小太监、大太监同下。"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮快板",
          "text": "一见万岁出宫院， 倒叫小妃挂心间。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "赵甫进宫！"
        },
        {
          "character": "赵甫",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵甫上。"
        },
        {
          "character": "赵甫",
          "type": "念",
          "text": "娘娘三召宣，上前问金安。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "臣赵甫见驾，娘娘千岁。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "宣臣进宫，有何军情？"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "只因为万岁去至太师府饮宴，命你暗地保驾，不得有误。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "刘瑞莲",
          "type": "念",
          "text": "万岁不听小妃语，事到临头后悔迟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘瑞莲、赵甫同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "太师",
          "type": "念",
          "text": "定下牢笼套，要坐九龙朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "禀爷：万岁到。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、大太监、西宫、王子同上。〖吹打〗。大太监、四小太监同下。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "老臣接驾来迟，万岁恕罪。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "太师平身。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "酒宴可曾齐备？"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "齐备多时了。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "酒宴摆下。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "待臣把盏，万岁请酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。王子醉。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "万岁请呐！"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "万岁吃醉了。 内侍摆驾回宫。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "且慢，昏王来得去不得了。来呀，将昏王打在宴月厅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王子、西宫同下。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "家院！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "传校尉进府。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "校尉进府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同上。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "来呀，打道宴月厅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太师、四校尉同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土地上，王子、大太监同上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏万岁：大事不好了。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "太师杀进府来了。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "哎呀！内侍，奸贼杀进府来，如何是好？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "请万岁在案下藏躲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太师、四校尉同上。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "来在宴月厅。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "两下搜来。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "万岁不见。"
        },
        {
          "character": "太师",
          "type": "白",
          "text": "起过了。 且住！昏王不见，难道他上了天了？入了地了？想是他们泄漏此事，逃回宫去， 也是有的。来呀，随老夫搜宫杀院。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太师、四校尉同下。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "哎呀，内侍，奸贼走去，你我君臣哪里逃走？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "逃出府去，再做道理。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "内侍，保驾来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王子、大太监同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵甫上。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "俺，赵甫。奉了娘娘之命，暗地保护万岁，就此前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王子、大太监同上。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "参见万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "赵爱卿，奸贼杀来，哪里藏躲？"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "藏在臣府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王子、大太监同下。四校尉同上，赵甫接杀，四校尉同下，赵甫下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘瑞莲上。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "哀家刘瑞莲。只因万岁太师府饮宴不见到来，是我放心不下，暗地保护，就此 前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵甫上。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "走！ 参见娘娘！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "站下。赵爱卿，万岁现在哪里？"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "现在臣府，那奸贼杀奔宫中来了。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "赵爱卿，奸贼到来，你我杀杀杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘瑞莲、赵甫同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵甫上。四校尉、太师同上，同打下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘瑞莲、赵甫同上，太师上，打，拿住太师。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "拿住奸贼！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "绑下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王子上。"
        },
        {
          "character": "王子",
          "type": "西皮快板",
          "text": "奸贼做事心太狠， 带领人马杀寡人。 内侍摆驾宫门进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘瑞莲、赵甫同上。"
        },
        {
          "character": "刘瑞莲",
          "type": "唱",
          "text": "拿住奸贼见当今。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "小妃参见万岁。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童，你、你来了。那奸贼可曾拿住？"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "拿住了。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "好好好，你、你、你、你、你与我绑上来！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "赵爱卿，将奸贼绑、绑、绑、绑上来！"
        },
        {
          "character": "赵甫",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵甫绑太师同上。"
        },
        {
          "character": "王子",
          "type": "唱",
          "text": "一见奸贼心好恼， 不由恶心往上潮。 孤王封你太师还嫌小？ 一心杀王坐龙朝。 绑在法场与我斩！"
        },
        {
          "character": "赵甫",
          "type": "唱",
          "text": "再奏万岁听臣言。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "万岁斩不得。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "怎么斩不得？"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "如若彦威兴兵前来，如何是好？"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "依卿之见？"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "彦威兴兵前来，好做退兵之计。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "好！绑了下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵甫绑太师同下。大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏万岁，西宫娘娘到！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "将这奸妃与我绑、绑、绑、绑上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西宫上。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "不、不、不、不好了！"
        },
        {
          "character": "西宫",
          "type": "西皮快板",
          "text": "我一见皇姐变了脸， 不知杀我为哪般。 走上前来开言问， 皇姐对我说根源。"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮原板",
          "text": "小奸妃生来好大胆， 要害万岁为哪般？ 手拿宝剑将你斩， 管叫你小奸妃命归黄泉。"
        },
        {
          "character": "西宫",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "西宫",
          "type": "西皮快板",
          "text": "在宫院我把父来怨， 连了女儿遭凶险。 走上前来双膝跪， 万岁搭救活命还。"
        },
        {
          "character": "王子",
          "type": "唱",
          "text": "梓童不必跪流平， 为王不管大事情。"
        },
        {
          "character": "西宫",
          "type": "西皮哭板",
          "text": "一见万岁他不管， 倒叫小妃为了难。 开言便把万岁叫， 再叫万岁听我言： 我父定计要害万岁爷死， 与小妃一事无干。 万岁快对皇姐言， 在宫内留我活命还。"
        },
        {
          "character": "王子",
          "type": "西皮哭板",
          "text": "孤王我叫了声爱梓童，"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "呔！“爱”什么！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "“爱”什么！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "我把你贱！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "我把你昏！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "我把你贱妃呀！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "我把你昏王啊！"
        },
        {
          "character": "王子",
          "type": "西皮哭板",
          "text": "你父女定下了巧计， 要害我寡人一死。 若不是刘娘娘保驾， 你我那里想见了。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "罢了！梓童！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "贱妃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王子怕，做身段，刘瑞莲打西宫。"
        },
        {
          "character": "王子",
          "type": "西皮哭板",
          "text": "罢罢罢罢了刘梓童。 我叫了声刘梓童，孤王的刘！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "“刘”什么！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "刘！"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "“刘”什么？"
        },
        {
          "character": "王子",
          "type": "西皮哭板",
          "text": "刘、刘、刘、刘、刘娘娘， 你今将她杀死不当紧要！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "梓童你来看。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "看什么？"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "她身怀有……"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "有什么？"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "有……"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "有什么？"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "她有，她、她、她、她、她有了孕。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "近前来，呸呸呸呸！"
        },
        {
          "character": "王子",
          "type": "西皮哭板",
          "text": "他父定计要害寡人一死， 不怨孤的好梓童。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "王啊！"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮哭板",
          "text": "我叫一声万万岁， 她父设宴要害万岁一死， 不听小妃之言，到临时后悔迟了。"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮快板",
          "text": "再叫万岁听我言： 来来随我出宫院， 二人哭的泪不干。 万岁折了小妃面， 在朝保你坐江山。 万岁不看小妃面， 三尺宝剑丧黄泉。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "哎呀梓童，事要如今全凭梓童所为。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "起过！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘瑞莲杀死西宫。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "罢了！梓童啊！"
        },
        {
          "character": "王子",
          "type": "西皮快板",
          "text": "我一见梓童把命丧。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "呔！我不许你哭。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "我、我、我、我、我不、不、不、不、不哭。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "我不许你嚎。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "我、我、我、我不嚎。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "等候周兵到来，你要与我哭啊！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "我、我不哭。"
        },
        {
          "character": "刘瑞莲",
          "type": "白",
          "text": "你要与我嚎啊！"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "不、不、不嚎了。"
        },
        {
          "character": "王子",
          "type": "西皮原板",
          "text": "怎不叫人两泪汪。 将身坐在龙床上， 再叫梓童听端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵甫上。"
        },
        {
          "character": "赵甫",
          "type": "白",
          "text": "启奏万岁：周兵围困城池，请万岁定夺。"
        },
        {
          "character": "王子",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王子",
          "type": "西皮快板",
          "text": "听说彦威发来兵， 不由孤王吃一惊。 回头便对梓童论， 去到城楼看分明。"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮原板",
          "text": "万岁做事太无情， 小妃焉能上城头。"
        },
        {
          "character": "王子",
          "type": "西皮原板",
          "text": "千言万语她不听， 倒叫寡人无计行。 走上前来礼恭敬， 梓童快去退周兵。"
        },
        {
          "character": "刘瑞莲",
          "type": "西皮原板",
          "text": "万岁不必胆怕惊， 小妃前去退周兵。 赵甫带过马能行， 我一到城楼看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵甫、刘瑞莲同下。"
        },
        {
          "character": "王子",
          "type": "西皮原板",
          "text": "一见梓童出龙廷， 此去不知是吉凶。 将身回在后宫里， 梓童到来问分明。 大战周兵得了胜， 孤王江山定太平。"
        },
        {
          "character": "王子",
          "type": "哭",
          "text": "梓童啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王子下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}