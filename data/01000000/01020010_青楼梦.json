        {
          "character": "杨爱卿",
          "type": "白",
          "text": "但不知要去多少日子？"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "一月罢。"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "一月？叫奴家怎能等得了吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨爱卿哭。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "不要哭，不要哭！半个月就回。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "太多！兄台快去快来，弗要拖延，十天就可以回来哉。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "好，就是十天！"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "快去拿剪子来！"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "吓！要剪子何用吓？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨爱卿剪发。"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "这是我的头发，送给你。你要是想我，你看见头发就如同见了我一样吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨爱卿哭。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "多情哉！"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "你不要哭了！ 你们解劝解劝。"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "你有什么，也要留一点与我呀！"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "我这有一把扇儿，送给你罢。"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "我要你身体上的物件。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "我身体上的物件，怎样与你呀？"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "你的牙齿，可能送我一个？"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "嗳呀，这牙……怎么拿得下来呀？"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "一敲就下来哉。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "只怕疼得狠罢？"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "要有真心喜爱，是弗痛格！"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "我敲了！"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "一敲，就下来哉！"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "痛罢？"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "一狠，就敲下了。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "如此待我敲来。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "快快拿水来！ 漱漱口，就弗痛哉。怎样？"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "还好，不很痛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院抱银上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "少主人，银子送来了。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "你回去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "我要走了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨爱卿哭。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "不要哭了。 你们劝劝她，我十日一准回来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金不换下。曾孝仁、杨爱卿、老鸨同笑，同下。"
        }
      ]
    },
    {
