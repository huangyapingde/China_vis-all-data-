          "text": "此位相公姓金，大名不换。你等要好好伺候格！"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "请问小姐的芳名？"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "我叫杨爱卿。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "爱卿，好个名字！好！"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "请吃酒！吃酒！"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "你要少吃一杯罢。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "不要紧，不要紧！"
        },
        {
          "character": "杨爱卿",
          "type": "白",
          "text": "看伤了身子。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "不要紧，不要紧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金不换拉曾孝仁。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "我且问你，今日在这里吃酒，要花多少钱？"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "弗要紧，小事体，有限格，让吾做东道。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "那不能，要多少银钱，今日算我的。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "弗要紧，小事体，吾来把他。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "那不能，今日让我，明日再算你的。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "有限格，不过五十两银子。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "五十两？来，这是五十两，烦劳兄台交给他们罢。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
