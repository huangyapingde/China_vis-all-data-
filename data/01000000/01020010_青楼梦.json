        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "弗是格！弗是格！吾姓曾子的曾，并非是姓真格！"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "哦，姓曾，不是姓真。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "请问二位上姓高名？"
        },
        {
          "character": "尤惯路",
          "type": "白",
          "text": "我姓尤，名惯路。"
        },
        {
          "character": "金不换",
          "type": "白",
          "text": "我姓金，名不换。"
        },
        {
          "character": "曾孝仁",
          "type": "白",
          "text": "金不换，好格，好格。二位请吃饭，吾做主人。"
        },
        {
          "character": "店小二",
          "type": "白",
          "text": "今天我们老板请二位，二位是要扰的。"
        },
        {
          "character": "金不换",
