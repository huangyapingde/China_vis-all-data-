{
  "script_id": "01016011",
  "title": "骂王朗",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "王朗",
      "hangdang": "老生"
    }
  ],
  "plot": "蜀汉诸葛武侯伐魏，取天水、安定、南郡三城。魏帅夏侯楙，窜入羌中，威声大振，兵出祁山渭水之西。魏\n主曹睿大惊，命曹真为大都督，郭淮为副都督，王朗为军师。起东西两京军马二十万，以御蜀兵。王朗本属\n汉朝元老，现官魏之司徒，年已七十有六。自诩口才便给，欲以一席话折服武侯，及至两军相遇，与武侯答\n话之时，反被武侯，将王朗历史，披露于军前，尽情丑诋。王朗竟然理屈词穷，气塞胸膛，撞死于马下。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢板",
          "text": "叹先皇白帝城龙归天上， 托孤与诸葛亮扶保朝纲。 尊圣命与魏兵连打数仗， 夏侯楙无名辈奔走西羌。 取天水多亏了子龙老将， 幸喜得姜伯约前来投降。 我看他用兵法孙武一样， 将我这兵机战策传授他参详。 闷恹恹坐至在中军宝帐，"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "待等候众将归再作商量。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱、高翔、关兴、张苞同上。"
        },
        {
          "character": "马岱、高翔、关兴、张苞",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "罢了。命你等打探魏兵之事如何？"
        },
        {
          "character": "马岱、高翔、关兴、张苞",
          "type": "同白",
          "text": "启丞相：今有曹睿，命曹真为大元帅，郭淮为副元帅，司徒王朗为军师，带领 二十万雄兵，前来征战，已在渭河之西，扎了营寨，特地前来禀报。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想那曹真、郭淮，虽然带兵多年，也不足虑，那王朗老儿，擅敢逞能，甚为可 笑，明日以兵御之，谅无妨碍也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "奉了元帅命，下书到蜀营。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "营中哪位在？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "奉曹元帅之命，前来下战书。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "候着。 启丞相：魏营差人，前来下书。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "传你进帐，要小心了。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。 叩见丞相，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你奉何人所差？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "奉曹元帅所差，有书呈上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "原来如此。你道我修书不及，照书行事。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "马岱、高翔、关兴、张苞",
          "type": "同白",
          "text": "魏营中有书前来，不知所为何事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那王朗老儿，明日要在阵前，与我答话。那老儿颇有口才，明日我当随机应之。 马岱、高翔听令。"
        },
        {
          "character": "马岱、高翔",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你二人，各带三千人马，在祁山左右扎营，不得有误。"
        },
        {
          "character": "马岱、高翔",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱、高翔同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "关兴、张苞听令。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你二人明日随同老夫出阵，督率三军，不得有误。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞同下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "奉圣命统大兵山摇地震， 来至在祁山口扎下大营。 明日里与魏兵山前会阵， 会一会老王朗再退曹真。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、四龙套、四大铠同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王朗、郭淮、曹真同上。"
        },
        {
          "character": "曹真",
          "type": "引子",
          "text": "奉命西征，"
        },
        {
          "character": "王朗",
          "type": "引子",
          "text": "仗智谋，"
        },
        {
          "character": "郭淮",
          "type": "引子",
          "text": "大战蜀兵。"
        },
        {
          "character": "曹真",
          "type": "白",
          "text": "军师、将军请坐。"
        },
        {
          "character": "王朗、郭淮",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "叩见元帅。"
        },
        {
          "character": "曹真",
          "type": "白",
          "text": "命你下书，那诸葛怎样回答？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "那诸葛言道：修书不及，照书行事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "曹真",
          "type": "白",
          "text": "呀，军师，明日与蜀兵交战，必须定计而行，方可取胜。"
        },
        {
          "character": "王朗",
          "type": "白",
          "text": "元帅明日出兵，务要严整队伍，大展旌旗。只用老夫一席言语，顺说孔明，管 叫他不战而自降也。"
        },
        {
          "character": "曹真",
          "type": "白",
          "text": "如此就命郭将军点动人马，旌旗务要鲜明，军士务要强壮，刀枪明亮，鼓角整 齐。五更造饭，天明起兵，不得有误。"
        },
        {
          "character": "郭淮",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭淮下。"
        },
        {
          "character": "曹真",
          "type": "西皮摇板",
          "text": "心中恼恨诸葛亮，"
        },
        {
          "character": "王朗",
          "type": "西皮摇板",
          "text": "纵有机谋也无妨。"
        },
        {
          "character": "曹真",
          "type": "西皮摇板",
          "text": "明日阵前来较量，"
        },
        {
          "character": "王朗",
          "type": "西皮摇板",
          "text": "管叫他马前来归降。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹真、王朗同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、马岱、高翔同上。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "俺马岱。"
        },
        {
          "character": "高翔",
          "type": "白",
          "text": "高翔。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "请了。吾奉丞相将令，在祁山左右扎下营寨，准备运转劫杀曹兵，就此前往。"
        },
        {
          "character": "高翔",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱、高翔双挖门同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、郭淮、曹真、王朗同上。四龙套、四上手、关兴、张苞、诸葛亮同上，对阵。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "关兴听令。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你去至阵前，就说汉丞相请司徒阵前答话。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "得令。 曹营中将士听者：汉丞相请司徒阵前答话。"
        },
        {
          "character": "王朗",
          "type": "白",
          "text": "老夫来也。 呀，来者敢是卧龙先生吗？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "然也。阵前来者，莫非就是王司徒？"
        },
        {
          "character": "王朗",
          "type": "白",
          "text": "岂敢。久闻先生抱经世之才，隐居隆中，躬耕南阳，澹泊明志，自比管仲乐毅。 既然出山，就该扶保明主，为何扶助刘备，岂非背天道而逆人情哉？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想吾昭烈皇帝，乃大汉中山靖王之后，孝景皇帝阁下玄孙，统领义师，扫荡海 内，安汉兴刘，匡扶汉世，正合天道而顺人情，岂同那曹丕纂逆之贼哉。"
        },
        {
          "character": "王朗",
          "type": "白",
          "text": "盖天地有变，神器易更，而归有德之人，此自然之理。汉世数尽，黄巾扰乱， 天下争锋，董卓叛逆，傕汜行凶，袁术称帝于寿春，袁绍称雄于邺土；刘表占 据荆州，吕布虎吞徐郡；社稷倾覆，生灵涂炭，我太祖武皇帝，扫清四海，平 定八方，并非以权势所取，实天命所归也。世祖文帝，圣神文武，以承大统， 法唐尧禅位虞舜之道，以治天下，岂非天心人意？古人有云，顺天者昌，逆天 者亡。先生幸勿逆天行事，枉费辛劳，倘若马前归顺吾主，定不失封侯之位！"
        },
        {
          "character": "诸葛亮",
          "type": "三笑",
          "text": "哈哈，呵哈，呵哈哈哈哈！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吾道你是汉朝大老元臣，必有高论，不料你竟是一派胡言，令人好笑也！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮二六板",
          "text": "王朗你本是汉老臣， 食君之禄当报国恩。 匡扶汉世你全不论， 兴刘安汉心无毫分。 助桀为虐纂了汉鼎， 甘心愿为诌媚臣。 今敢在马前胡乱论， 细听老夫说分明。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫今有一言，要说与诸君众将听道：昔日桓、灵之世，汉统凌替，十常侍作 乱于宫中，黄巾贼扰乱于边内，董卓、傕、汜，相继而起，劫夺圣驾，残害生 民，国乱岁凶，苍生涂炭。以致狼心狗肺之徒，皆食禄于庙堂，奴颜婢膝之辈， 均垂绅于殿阁。幸皇天不绝汉嗣，昭烈皇帝，亲承汉统，践位西川，吾今奉 幼主之命，兴师前来讨贼。你既为叛逆之臣，就该藏头缩首，怎么，你还敢在 这行伍之前讲什么天数，我把你这皓首匹夫，苍髯老贼，罪孽深重，恶贯满盈， 神鬼之所共怒，天地之所不容，又道是乱臣贼子，人人得而诛之，天下之人， 恨不得食尔之肉也！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "罪恶滔天人人恨， 我活活骂死你老谗臣！"
        },
        {
          "character": "王朗",
          "type": "西皮摇板",
          "text": "一席话骂得我无言可论， 气满胸膛丧残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朗落马死，四下手抬王朗同下。曹真、郭淮、四龙套同下。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "王朗落马已死，曹兵退去。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "曹真虽然兵退，岂能甘心。今晚必来偷营劫寨，众将暂且回营去者。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "老夫奉命出西秦， 胸抱雄才敌万人。 王朗阵前已丧命， 安排人马破曹真。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}