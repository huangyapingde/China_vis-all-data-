{
  "script_id": "01011013",
  "title": "赵颜借寿",
  "alias": [
    "百寿图"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "南斗星君",
      "hangdang": "老生"
    },
    {
      "name": "北斗星君",
      "hangdang": "净"
    },
    {
      "name": "赵颜",
      "hangdang": "小生"
    }
  ],
  "plot": "赵颜借寿事，本诸《三国演义》中。系太史丞许芝，为曹操言神卜管辂（字公明）之术而并及之。据许芝言，\n一日，管辂闲行郊外，见一少年耕于田。管辂立道旁观之良久，问其姓名及年龄。少年告以名赵颜，年十\n九矣。管辂忽叹曰：“汝貌诚美，惜无寿，眉间有死气。三日必死。”赵颜急归告其父，父子同至管辂前，\n哭拜于地，请以术救。管辂始不允，继见其父子情切，乃教赵颜备酒一瓶、鹿脯一块，来日去往南山中大树\n下，见盘石上有二人对奕，一穿白一穿红者，“汝可乘其奕兴浓时，将酒及鹿脯跪进之，待其饮食毕，汝乃\n哭拜求寿，必获益算也。”次日，赵颜如其言而往，果有所遇。赵颜遂阴伺之。待其食已，即泣求。二人大\n惊曰：“此必管公明饶舌也！”但既食其酒馔，似不可却，乃为检查簿籍，添注一“九”字于“十九”之上，\n而赵颜寿遂增至九十九矣。无何，一阵香风过处，二人化作白鹤冲天而去。",
  "notes": "此戏从南、北斗对奕开场，二人对唱一段颇长。赵颜借寿时，末有“何不更添一岁，凑成百岁之”一语，足\n以调侃世人之食心不足，用意颇妙。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引北斗星君、南斗星君同上。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "观天地和日月乾坤浩荡，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "天连水水连天杳杳茫茫。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "我乃南斗星君是也。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "吾乃北斗星君是也。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "星君请了。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "你我奉了玉帝敕旨，巡查人间善恶。来此地已是南瞻部洲，不免将历代帝王细 表一番。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "自盘古分天地乾坤首创，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "生太极分两仪八卦阴阳。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "分金木水火土五行星象，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "先君臣后父子三纲五常。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "尧传舜舜传禹江山执掌，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "夏传商纣淫乱无道昏王。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "秦始皇归一统山河独掌，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "他不该焚诗书建立阿房。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "楚项羽他倒有帝王气象，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "他不该杀义帝自称霸王。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "将前朝君王事一齐慢讲，"
        },
        {
          "character": "南斗星君",
          "type": "西皮快板",
          "text": "听我把忠良臣细说端详： 淮阴侯汉韩信功高名广， 为什么被吕后斩首未央？"
        },
        {
          "character": "北斗星君",
          "type": "西皮快板",
          "text": "休提起汉韩信功高德广， 自幼儿行的事丧尽天良： 他不该困霸王乌江命丧， 因此上被吕后斩首未央。"
        },
        {
          "character": "南斗星君",
          "type": "西皮快板",
          "text": "汉萧何造律法后人瞻仰， 为什么那老儿寿命延长？"
        },
        {
          "character": "北斗星君",
          "type": "西皮快板",
          "text": "汉萧何造律法治国兴旺， 因此上那老儿寿命延长。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "有荆轲刺秦王英雄胆壮，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "有专诸刺王僚盖世无双。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "痛只痛挖心死比干丞相，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "叹只叹有苏武白发还乡。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "叹不尽前朝的忠臣良将，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "松林内摆棋盘且消愁肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "红棋先黑棋后一帅一将，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "从士相五个卒以炮为强。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "走一步当头炮风声响亮，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "先出马后走车二将着忙。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "红棋子好一比汉高皇上，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "黑棋子好一比项羽霸王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜上。"
        },
        {
          "character": "赵颜",
          "type": "西皮摇板",
          "text": "昨日里管先生对我言讲： 他道我三日后一命身亡。 来至在松林内用目观望， 又只见二星君俱在一旁。 我这里龙凤酒暗暗献上， 含着气闭着声坐在一旁。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "哪里的鹿脯酒从空下降？"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "想必是那上苍赐下琼浆！"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "我与你棋不胜且饮佳酿，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "飞来酒吃几杯又待何妨。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "二位星君。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "耳边厢又听得有人声嚷，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "猛抬头见小子跪在一旁。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "那一小子，家住哪里，姓甚名谁，慢慢讲来。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "容禀！"
        },
        {
          "character": "赵颜",
          "type": "西皮摇板",
          "text": "家住在平原县赵家庄， 我的名叫赵颜父母在堂。 昨日里管先生对我言讲： 他道我三日后一命身亡。 因此上龙凤酒鹿脯献上， 望星君发慈悲添寿一场。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "听小子说此话有些虚谎，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "但不知是何人泄漏阴阳？"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "星君，赵颜来到此地，但不知是何人泄漏天机？"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "凡间有一管辂，生来一双慧眼，能知未来之事，定是此人。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "他既前来，星君何不将他阳寿查看一番。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "待我查来：查得山西平原郡陆林村，赵家庄赵范之子，名叫赵颜，前生作恶多 端，今生只活一十九岁，夭寿而亡。 赵颜，你今年多大年纪？"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "一十九岁。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "完了！"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "叫赵颜近前来细看簿上： 三日后作注定夭寿而亡。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "二位星君，我家有父母，无人侍奉，望星君大发慈悲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜哭。"
        },
        {
          "character": "南斗星君",
          "type": "西皮摇板",
          "text": "见赵颜只哭得泪如雨降，"
        },
        {
          "character": "北斗星君",
          "type": "西皮摇板",
          "text": "临死时还不忘二老高堂。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "星君，你看赵颜哭得可怜，何不将他阳寿添上才是。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "恐上是闻知，你我吃罪不起。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "上苍有百好生之德。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "添得的？"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "添得的！"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "这便宜酒，星君你要少吃。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "你也要少饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南斗星君、北斗星君同笑。"
        },
        {
          "character": "北斗星君",
          "type": "白",
          "text": "赵颜，你一十九岁该亡，如今将“一”字改为“九”字。你寿活九十九岁而终。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "何不添上一岁，凑成了一百岁？"
        },
        {
          "character": "北斗星君、南斗星君",
          "type": "同白",
          "text": "哽！贪心不足！"
        },
        {
          "character": "赵颜",
          "type": "西皮摇板",
          "text": "辞别了二星君忙转家门，"
        },
        {
          "character": "北斗星君、南斗星君",
          "type": "同白",
          "text": "赵颜转来。"
        },
        {
          "character": "赵颜",
          "type": "西皮摇板",
          "text": "二星君呼唤我所为所情？"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "听我吩咐："
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "我本是南斗星从天而降，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "我本是北斗星降下天堂。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "我掌生他掌死分亳不爽，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "专鉴查人间事善恶昭彰。"
        },
        {
          "character": "南斗星君",
          "type": "白",
          "text": "赵颜，"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "我赐你椿萱茂富贵永享，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "我赐你福禄寿共享安康；"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "我赐你子孙多枝叶茂盛，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "我赐你财源茂金玉满堂；"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "我赐你百寿图寿屏寿帐，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "三个字拿回去供奉高堂。"
        },
        {
          "character": "南斗星君",
          "type": "西皮原板",
          "text": "到人间休得要胡言乱讲，"
        },
        {
          "character": "北斗星君",
          "type": "西皮原板",
          "text": "泄天机遭五雷击顶而亡。"
        },
        {
          "character": "北斗星君、南斗星君",
          "type": "同白",
          "text": "赵颜，那旁有人来了。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "北斗星君、南斗星君同下。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "哎！二位星君不见，待我望空一拜。"
        },
        {
          "character": "赵颜",
          "type": "西皮摇板",
          "text": "我这里忙下跪星君谢定， 回家去禀告了二老双亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}