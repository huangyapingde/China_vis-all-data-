{
  "script_id": "01022005",
  "title": "青风寨",
  "alias": [
    "娶李逵"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "李逵",
      "hangdang": "净"
    },
    {
      "name": "刘通",
      "hangdang": "副净"
    },
    {
      "name": "燕青",
      "hangdang": "武生"
    },
    {
      "name": "张员外",
      "hangdang": "末"
    },
    {
      "name": "二大王",
      "hangdang": "武丑"
    },
    {
      "name": "张女",
      "hangdang": "旦"
    }
  ],
  "plot": "大盗刘通占住青风寨，以抢劫为生涯。见近村张员外之女，携带仆从，在乡间祭扫坟墓，美丽容颜动人怜爱，\n然罗敷固有夫也。刘通即遣人向张员外说亲。张员外婉辞以却之。讵知刘通竟行强硬手段，遂将聘礼交付，\n作为文定，并约日来娶。适值梁山泊燕青、李逵奉令下山，巡哨各处。至张员外门首，天色昏黑，扣门借\n宿。张员外殷勤款待，陪二人饮酒，忽然紧蹙双眉，咳声叹气。二人不胜惊讶，固问之。张员外将刘通逼迫\n情形，备细告知。实因娶期在即，异常焦急。二人颇有义侠之概，虽居盗窟，深恨此种行为。闻言怒甚，遂\n相与计议，李逵装扮员外之女，为之替嫁。燕青冒员外之子，混进青风寨。刘通竟受之愚弄，被二人杀死。",
  "notes": "此系净、副合演，而为插科打诨之剧。亦属别开生面，尤堪发噱。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、刘通同上。"
        },
        {
          "character": "刘通",
          "type": "点绛唇",
          "text": "独霸高山，自称好汉，逞凶蛮，抢掠银钱，谁不心胆寒！"
        },
        {
          "character": "刘通",
          "type": "念",
          "text": "不种桑麻不种田，弟兄独霸在高山。有人打从山下过，必须留下买路钱。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "俺，青风寨大大王刘通。独霸山寨，每日下山抢掠，倒也逍遥自在。这几日心 中闷倦，看今日天气晴和，不免下山游玩一番。 喽啰的，带马下山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张员外、张女、丫鬟同上。"
        },
        {
          "character": "张女",
          "type": "西皮摇板",
          "text": "来在松林下车轮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张女下车。"
        },
        {
          "character": "张女",
          "type": "西皮摇板",
          "text": "不觉来到祖坟茔。"
        },
        {
          "character": "张员外",
          "type": "西皮摇板",
          "text": "走向前来忙跪定，"
        },
        {
          "character": "张员外",
          "type": "哭头",
          "text": "祖先爷呀！"
        },
        {
          "character": "张员外",
          "type": "西皮摇板",
          "text": "耳旁又听有人声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、刘通同上，同上桌子。刘通看，三笑，下。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "我们回去吧。"
        },
        {
          "character": "张员外",
          "type": "西皮摇板",
          "text": "叩罢头来抽身起， 父女一同转回归。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二大王上。"
        },
        {
          "character": "二大王",
          "type": "念",
          "text": "大哥下山去游玩，为何不见转回还？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、刘通同上。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "大哥回来了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘通三笑。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "大哥今日回山，为何这样欢喜？"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "贤弟有所不知：适才在山下，观见张员外之女，生得十分美貌，愚兄想要将她 做一位压寨的夫人。只是不能到手，也是枉然。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "这有何难，待小弟前去提亲，包管成功。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "好，就请贤弟，前去说亲。正是："
        },
        {
          "character": "刘通",
          "type": "念",
          "text": "花红彩礼交付你，"
        },
        {
          "character": "二大王",
          "type": "念",
          "text": "包管大哥端东西。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引二大王同上。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "你对你家员外言讲：就说青风寨二大王要见。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请员外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张员外上。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "青风寨二大王要见。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "说我出迎。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "员外出迎。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "啊，员外！"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "大王到此，必有所为。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "我奉大哥之命，叫我前来提亲，将你的女儿许配我大哥，做一位压寨夫人。员 外谅无推辞的了！"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "只是小女，已有了人家了，此事不能从命。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "什么有人家没有人家，我全不管。现有花红彩礼在此，三日后抬亲，告辞了。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "此事断断使不得啊！"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "好不识抬举！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大王推张员外，急下。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "张员外",
          "type": "念",
          "text": "闭门家中坐，祸从天上来。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "这是从哪里说起？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张员外下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "燕青、李逵",
          "type": "内同白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青、李逵同上。"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "山上领了大哥命，"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "弟兄下山要小心。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "俺，浪子燕青。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "黑旋风李逵。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "李二哥。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "燕小哥。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你我奉了大哥之命，下山巡查奸细，看天色已晚，你我弟兄哪里安歇？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "你抬头观看。前面黑暗暗，雾沉沉，不是一村，就是一镇。你我去到那里，投 宿一宵，你看如何？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "如此请呐！"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "迈开大步往前进，"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "不觉来到一庄门。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "来此已是大户人家，待我向前叫门。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你不会讲话。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我这么大一个人，怎么不会讲话？你听着吧。 呔，里面有人吗？走出一个来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是哪一位？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我们是远方来的，天气已晚，要在你们家里睡上一夜。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "咳，这是什么讲话？你起过一旁。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我这话，不是这么说？听你的。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "请了！我二人远方而来，行至此地，天色已晚，要在尊处，暂宿一宵，明日早 行。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "就是这么几句话呀？你早对我说，我就知道啦！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请员外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张员外上。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "外面来了两位客人借宿。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请二位。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "员外在哪里？"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "原来是二位壮士，请坐。请问二位，尊姓大名？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "在下姓燕，名乙。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我姓李……"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "他叫李二。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "不错，我叫李二。那卖豆儿的李二哥，就是我。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "请问员外，贵姓高名？"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "老夫张志善。请问二位，因何到此？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "我二人贸易至此。天色已晚，无处投奔，要在员外这里借宿一宵，明日早行。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "原来如此。二位可曾用饭？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "这个……前途用过了。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "饭倒是前途用过了，如果要有酒，倒要扰两盅。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "家院，将酒摆下。"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "多蒙员外多海量。"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "姑饮几杯又何妨？"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "停杯不饮来观望，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张员外叹气，李逵摔杯。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "你咳声叹气为哪桩？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我二人在此饮酒，你咳声叹气，莫非多嫌我等不成？"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "二位壮士，休要动怒。老夫是有心事在怀。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "员外有什么心事，对我二人言讲，与你分忧解愁。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "二位有所不知：只因青风寨上有一强人，他要娶我女儿，做一压寨夫人。无奈 小女已有了人家，故而愁烦。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "请二位转至卧房。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "员外请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张员外下。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "李二哥，你我吃了人家的酒饭，必须要搭救人家的女儿才是正理。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "但不知要怎么搭救？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "必须要想上一计。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我是忙中无计。我这身上倒有个疣子。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "我倒有一计在此。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "燕小哥，有何妙计？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你我扮做新人模样，混上山寨，杀他个里应外合。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "此计甚好，谁扮新人？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你就扮做新人。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "嘿，你看哥哥我长得三分不象人七分倒象鬼，倒是你，雪白粉嫩，一笑两个酒 窝。一个是尿窝，一个是屎窝。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "还是你扮做新人，我扮做新人兄弟模样，就可以混上山寨了。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "要扮，还没有衣服呢。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "有请员外！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张员外上。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "二位何事？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "我二人要搭救你的女儿，必须要假扮你家小姐的模样。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "倘能救得了我的女儿，老夫感恩非浅。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "只是要与你借几件女人的衣服。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "丫鬟快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "来见过二位。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "哎呀，打鬼！"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "这是何故？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "你看这一位，好像庙里的泥鬼。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我是一人，乃是天生的雉脸。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "天生的不要脸呐！"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "胡说！"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你将小姐出阁应用的衣服取来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是啦。 这有一件，哪一位穿呐？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "来，拿过来吧，我穿呐！ 嗬，这是一件什么东西？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这是裙儿。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "怎么穿法？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这是腰间系的。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "哦，你来替我系上吧。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这还有一件。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "这是什么呀？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这是衫儿。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "好，来穿上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这还有一件。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "这又是什么呀？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这叫做凤儿。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "好啊。这三样，倒是一个娘生的。裙儿，衫儿，凤儿，待我来打打吧。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "打些什么？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "恐怕里面有臭虫，我怕咬了我的脑袋。好，打扮好了。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你可会那妇人行走？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我倒不会。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "丫鬟，来教导于他。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "妇人行走，要这一摆，那一摆，用手这样一舞，要这般行走。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我学会了。想这小姐，乃是千金之体，行路必须要这样一摆，再一摆，共是二 摆，再用手这么一舞，共总是二百五，必须要这样地走。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "好，好，好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手引二大王同上。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "花轿已到，请新人上轿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张员外上。"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "呵呵，是了。 家院，叫丫鬟搀扶小姐上轿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵、燕青同上。李逵假哭，拜张员外，上轿。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "员外，这是何人？"
        },
        {
          "character": "张员外",
          "type": "白",
          "text": "这是新人之弟，乃是我的儿子。"
        },
        {
          "character": "二大王",
          "type": "白",
          "text": "原来是小舅子，随我上山去玩玩吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青看张员外，怒。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "我上了你的当了，真真岂有此理！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、刘通同上。二大王引四上手、李逵、燕青随花轿同上"
        },
        {
          "character": "刘通",
          "type": "念",
          "text": "喜气满华堂，打扮做新郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘通、李逵同交拜。傧相上。"
        },
        {
          "character": "傧相",
          "type": "念",
          "text": "今日喜相逢，刀切两颗葱。好的配好的，蚊子配臭虫。"
        },
        {
          "character": "傧相",
          "type": "白",
          "text": "先拜天地，后拜祖先。夫妻交拜，同入洞房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傧相、四上手、四下手、二大王、燕青同下。李逵哭。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "美人，不要哭了。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我想啊。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "你想哪个？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我想我姥姥。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "不要哭了。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我还想。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "你还想哪个？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我还想我妈。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "不妨，明日将她接上来，同享荣华。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "如此，我们就不哭了。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "走，同至后房，睡觉去吧。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "好，走呀。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "请美人进房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵吹灯。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "为何将灯吹灭了？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "奴家是个迷眼，最怕三光。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "怕哪三光？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "怕的是灯光、日光、月光。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "脱衣服，睡觉吧。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我们在这儿脱呐。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "睡吧。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "慢来。我们这里有个乡风，新人上床，必须要将新郎打三拳，踢三脚。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "这是什么乡风？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "为的是子孙后来兴旺。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "好，你来打吧。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "哎哟，我舍不得打你呀。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "不要灌迷汤了，打吧。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "如此，我就打、打、打！"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "美人，你怎么这般大的力气呀？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "奴家是千金之体，打下去，就有千斤之重。我还要踢。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "不踢也罢。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "如果不踢，以后养女儿，不生小子。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "看在儿子份儿上，你就踢三脚。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "你着踢！"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "李逵。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘通、李逵同起打，刘通下，李逵追下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（刘通上，二大王、四下手、四上手同上，李逵、燕青同上。李逵杀刘通，燕青杀二大王。李逵、燕青同三"
        },
        {
          "character": null,
          "type": "text",
          "text": "笑，同下。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}