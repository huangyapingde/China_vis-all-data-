  "plot": "东汉末造，献帝只成守府之君，且为曹操所挟制，盖曹操并吞群雄，自以为功德巍巍，无与伦比，乃加九锡，\n封魏王，骄横极矣，虽萌篡窃之念，犹不敢实行，所以终曹操之世，献帝尚得安于其位，及曹操死而汉祚\n从此告终矣。曹操子曹丕，嗣魏王之位，谓时机不可失，急欲攘夺，举凡魏之私人，为固宠希荣计，辄阿附\n之，且怂恿之，即朝廷大臣，亦愿为新魏之元勋，不愿为旧汉之遗老，于是众口一词，欲献帝效唐虞之揖让，\n禅位与魏。献帝之初心，不甘以大好江山，双手奉送，奈众人从事逼迫，复以童谣谶语，摇惑而耸动焉。\n献帝明知势蹙时窘，不得不允起请，愿逼迫之手段，以华歆为最辣，搜索玉玺，出自华歆之指点；返送玉玺，\n出自华歆之作为；曹丕因名誉山起见，再三推让，华歆又为划策，令献帝筑受禅台，亲奉玉玺与曹丕，藉\n以遮掩天下耳目，免滋物议，从此汉灭魏兴，而曹丕遂有魏文帝之徽号矣。",
  "notes": "是剧由汪伶隐，在沪上丹桂第一台，开始串演。须生唱工，最为吃重，中间数段原板，悲壮苍凉，大有今昔\n盛寰之慨。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、华歆、李伏、王朗、贾诩、许芝同上。"
        },
        {
          "character": "司马懿、华歆、李伏、王朗、贾诩、许芝",
          "type": "同二黄摇板",
          "text": "适才魏王把旨传， 安排妙计在心间。 列位一同上金殿， 立逼昏王让江山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、内侍引汉献帝同上。"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "孤王出了皇宫院， 眼跳心惊为哪般？ 将身来在金銮殿， 在与众卿把话言。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "众卿上殿，有何本奏？"
        },
        {
          "character": "司马懿、华歆、李伏、王朗、贾诩、许芝",
          "type": "同白",
          "text": "臣启万岁：臣等伏睹魏王，自登基以来，德布四方，仁及万物，群臣会议，尽 道汉祚将终，望万岁效尧舜之道，将江山社稷，让与魏王，万岁退位，以享清 净之福，国家幸甚，生灵辛甚！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "众卿说哪里话来？自古天下，只有争夺，哪有退让之理？想高皇帝，提三尺剑， 斩蛇起义以来，创造基业，至今四百余载。寡人虽无大才，初无大过，安忍 将这万里江山，让与他人？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "自古皇帝，有兴有废，有盛有衰，岂有不亡之国？不败之家？万岁若不相信， 可问许芝、李伏二人，便知天意。"
        },
        {
          "character": "李伏",
          "type": "白",
          "text": "自魏王登基以来，麒麟降生，凤凰来仪，黄龙出现，甘露下降，此即上天示瑞， 魏当代汉之象也。"
        },
        {
          "character": "许芝",
          "type": "白",
          "text": "臣等夜观天象，见炎汉气数以终，帝星隐暗不明。更兼上应谶语，其词曰：鬼 在边，委相连；当代汉，无可言；言在东，午在西，两日并光上下移。以此论 之。“鬼在边，委相连”者，乃是一“魏”字也；“言在东，午在西”者，乃 “许”字也；“两日并光”乃“昌”字也，此是魏在许昌，应受汉蝉也。望万 岁早早退位！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "祥瑞图谶，皆虚妄之事，岂可以此，叫孤弃祖宗之基业乎？"
        },
        {
          "character": "王朗",
          "type": "白",
          "text": "汉室相传，四百余年，延至万岁，气数已尽，宜早退避，不可迟疑。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "万岁可依臣等之议，免遭大祸。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "卿等皆食汉朝爵禄，何忍作此不臣之事？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "住口！倘若不从众议，恐祸起萧墙，悔之晚矣！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "华歆贼子天大胆， 立逼孤王让江山。 拂衣而起下金殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝下位。"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "只见华贼眼睁圆！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "事到如今，寡人就将江山，让与魏王就是。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "就请万岁交玺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝交玉玺与许芝。"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "含悲忍泪交玉玺， 万里江山化灰泥！"
        },
        {
          "character": "许芝",
          "type": "二黄摇板",
          "text": "手捧玉玺下殿去， 见了魏王说端的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许芝下。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "万岁今将江山让与魏王，那魏王同你，乃是郎舅之亲，断不能加害于你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝怒。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "事到如今，但凭他所为！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝怒下。司马懿、华歆、李伏、王朗、贾诩同笑。"
        },
        {
          "character": "司马懿、华歆、李伏、王朗、贾诩",
          "type": "同二黄摇板",
          "text": "昏王让了锦江山， 文臣冠上定加冠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、华歆、李伏、王朗、贾诩、许芝同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二内侍、司马懿、华歆引曹丕同上。"
        },
        {
          "character": "曹丕",
          "type": "二黄摇板",
          "text": "适才二卿对我言， 汉王竟肯让江山。 迈步且上银安殿， 且待许芝说根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许芝上。"
        },
        {
          "character": "许芝",
          "type": "二黄摇板",
          "text": "捧定诏玺上银安， 汉王特地让江山。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "卿家手捧何物？"
        },
        {
          "character": "许芝",
          "type": "白",
          "text": "今有汉王，将玉玺诏书，令臣送上，情愿让位。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "如此待孤收下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "爱卿为何拦阻？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "虽然诏玺送来，殿下若不让让推辞，诚恐天下怨谤。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "卿言甚何孤意，许芝下令，名你将诏玺退回，请汉王另让别家便了。"
        },
        {
          "character": "许芝",
          "type": "白",
          "text": "遵令！"
        },
        {
          "character": "许芝",
          "type": "二黄摇板",
          "text": "急忙转身下银安， 见了汉王说根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许芝下。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "为臣现有一计献上。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "卿家有何妙计？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "微臣去见汉王，叫他亲自写下诏书，高搭一台，名曰“受禅台”，择一吉日良 辰，命汉王在台下，奉呈诏玺，文武百官，台下听令，魏王在台上即位，便可 以释群疑，而绝众望。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "好！此计甚妙，照计而行便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引汉献帝同上。"
        },
        {
          "character": "汉献帝",
          "type": "二黄原板",
          "text": "汉高皇手提着三尺宝剑， 灭强秦平暴楚创下江山。 传到了桓灵帝宠信太监， 又有那黄巾贼起下狼烟。 恨曹操他父子心怀谋篡， 华歆贼在其中狼狈为奸。 忍不住泪珠儿流落满面， 但不知这江山还坐几天？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许芝上。"
        },
        {
          "character": "许芝",
          "type": "二黄摇板",
          "text": "二次撩袍上金殿， 尊声万岁听臣言。"
        },
        {
          "character": "许芝",
          "type": "白",
          "text": "启奏万岁：魏王言道，德薄无才，不肯受诏，请江山另让别家。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "看他不肯受诏，定是学曹操之奸诈也！内侍，宣文武上殿！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "文武百官上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、华歆、李伏、王朗、贾诩、许芝同上。"
        },
        {
          "character": "司马懿、华歆、李伏、王朗、贾诩、许芝",
          "type": "同白",
          "text": "万岁宣臣等上殿，有何国事议论？"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "魏王不肯受诏，此事只好罢了。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "魏王真乃尧舜之君也，事到如今，还要万岁作主！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "以卿之见？臣等已经议定，请万岁高搭一台，名曰“受禅台”，择一吉日，将 诏书玉玺，亲自送至台下，魏王定必允从。但须万岁亲写诏书。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "想这大汉江山，不料亡于今日了！"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "听一言不由人吞声隐哭， 华歆贼逼孤王亲写诏书。 背转身叫一身在天皇祖， 今日里才知道代汉当途。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "转长锤锣鼓。"
        },
        {
          "character": "汉献帝",
          "type": "二黄原板",
          "text": "提起了羊毫笔珠泪扑簌， 恨华歆逼孤王亲写诏书。 恨曹贼他父子如狼似虎， 窃神器窥大宝社稷难扶。 满朝中两班文武， 一个个胁肩媚笑，把富贵来图。 想必是这炎汉绝了气数， 弃江山如敝履冠冕泥涂。 可叹我堂堂天子被人欺负， 我只得一字字、一行行、字字行行、草写诏书，泪湿袍服！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝下位。"
        },
        {
          "character": "汉献帝",
          "type": "二黄原板",
          "text": "叫华卿与孤王前引路， 可怜我亡国君草芥不如。 但愿得受禅台遗下了——"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "寸土，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、华歆、李伏、王朗、贾诩、许芝同下。"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "看他那后辈儿孙就依样描画葫芦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四御林军、二内侍、曹丕同上。"
        },
        {
          "character": "曹丕",
          "type": "引子",
          "text": "舞凤祥麟，承汉统，四海升平。"
        },
        {
          "character": "曹丕",
          "type": "念",
          "text": "太阳一出照当空，锦绣江山掌握中。今日孤王承汉统，受禅台上庆臣功。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "孤王，曹丕。吾父曹操，统领雄兵，扫荡狼烟，官封魏王之职。只因昏王无道， 满朝文武会议，叫汉王退位让国。今当黄道吉日，受禅即位。 内侍，伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。曹洪、曹休同上，分坐台口。司马懿、华歆、李伏、王朗、贾诩、许芝、汉献帝同上。"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "来至在受禅台珠泪滚滚， 四百年锦基业让与他人！"
        },
        {
          "character": "曹洪、曹休",
          "type": "同白",
          "text": "呔！你是何人？擅敢在此摆来摆去！待吾将他衣冠剥去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪摘冠，曹休夺袍。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "汉献帝",
          "type": "二黄导板",
          "text": "听一言吓的孤心胆俱碎，"
        },
        {
          "character": "汉献帝",
          "type": "顶板回龙",
          "text": "摘去孤冲天冠、脱去了赭黄袍，可怜我，一代帝王，匍匐尘埃伤悲！"
        },
        {
          "character": "汉献帝",
          "type": "二黄原板",
          "text": "恨曹贼他父子谋夺汉位， 有华歆在其中狐假虎威。 这也是汉朝中气运当坠， 乱臣贼子当道夺权难以挽回。 欺寡人好似那屈魂怨鬼， 欺寡人好似那庙中土偶、不言不语、无能无德； 欺寡人似蜡烛迎风流泪， 欺寡人好一似撮土扬灰。 欺寡人似蛟龙离了海水， 欺寡人好一似凤褪翎毛，怎能高飞？ 欺寡人好一似飞蛾扑火身落在油内， 欺寡人好一似舟到江心、风狂浪大、悠悠荡荡、难以转回！ 众文武与孤王一起作对， 我只得三呼万……岁，珠泪双垂！"
        },
        {
