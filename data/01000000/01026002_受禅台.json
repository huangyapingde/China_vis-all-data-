        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "听一言吓得孤三魂不定， 眼见得四百载、二十四代锦乾坤一旦倾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝下，四风旗同上，过，跪，同下。曹丕昏晕。"
