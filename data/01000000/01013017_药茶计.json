{
  "script_id": "01013017",
  "title": "药茶计",
  "alias": [
    "斩浪子"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "王氏",
      "hangdang": "老旦"
    },
    {
      "name": "张浪子",
      "hangdang": "丑"
    },
    {
      "name": "王清天",
      "hangdang": "老生"
    }
  ],
  "plot": "《药茶计》者，系京都民人张浪子家，出一药茶毒死母舅之案，经官谳定欲斩。忽然遇救等情。先是张浪子\n之母与浪子大娘不和，欲图谋害，因觅得药茶，拟毒死其大娘，不料浪子之母舅到来，忽然误饮此茶，遂被\n毒毙，其母事机不妙，已误杀己弟一不做二不休，竟去鸣官，诬告大娘毒毙其弟。问官不察，大娘竟为诬服。\n谳既定，而浪子天良不昧，自愿以身代大娘受刑。遂乘县官交替之际，蒙混入狱，将大娘调出。既而斩已\n至，浪子已绑赴法场，引颈就戮。其大娘来场活祭一回而去。不意宫中忽有旨到场，命将药茶案犯人特赦并\n背进宫云而毕。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。衙役、二刽子手引王清天同上。"
        },
        {
          "character": "王清天",
          "type": "念",
          "text": "天上冷飕飕，地下滚绣球。大炮一声响，圣旨要斩头。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "下官，王清天。今有药茶一案，律应问斩。 刀斧手！"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "将浪子、郎二虎绑了上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二刽子手绑张浪子同上。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "时辰到了，将浪子、郎二虎一齐开刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王清天暗下。"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "王氏",
          "type": "内白",
          "text": "苦哇！"
        },
        {
          "character": "王氏",
          "type": "内二黄导板",
          "text": "数九寒天冷似冰，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏上。"
        },
        {
          "character": "王氏",
          "type": "叫头",
          "text": "浪子！我儿！儿呀！"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "万岁爷传圣旨要斩犯人。"
        },
        {
          "character": "王氏",
          "type": "二黄正板",
          "text": "催命鼓响咚咚追人性命， 救命锣响呛呛令人吊魂。 悲切切且把那法场来进， 阴风儿吹得我冷似冰。 我不进法场回家去罢，"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "王氏",
          "type": "二黄正板",
          "text": "岂做忘恩负义人。 祭礼放在席棚外， 舍我这老命找姣生。 大胆且把法场进，"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "呔！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王氏",
          "type": "二黄正板",
          "text": "刽子手提刀吓煞人。 望将爷在上容我禀， 我是那张浪子的大娘亲。 在法场哭坏了王氏女，"
        },
        {
          "character": "王清天",
          "type": "内白",
          "text": "传话出去：有亲探亲，有故探故，少时大炮一响，人头落地。亲故就不能相见 了。"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "传话出去：有亲探亲，有故探故，少时大炮一响，人头落地。亲故就不能相见 了。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "有哇！"
        },
        {
          "character": "王氏",
          "type": "二黄正板",
          "text": "大老爷开了那天地之恩。"
        },
        {
          "character": "王氏",
          "type": "二黄原板",
          "text": "法场上好一比森罗宝殿， 监斩官好一比五殿闫君。 刽子手好一比催命判鬼， 众犯人好一比死去猪羊，一个个等候时辰。"
        },
        {
          "character": "王氏",
          "type": "哭",
          "text": "我的儿呀！"
        },
        {
          "character": "王氏",
          "type": "二黄原板",
          "text": "众犯人在法场无有其数， 寻不着浪子小姣生。 无奈何只得挨头数，"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王氏",
          "type": "二黄原板",
          "text": "这江洋大盗吓煞人。 这边不是那厢认，"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王氏",
          "type": "二黄原板",
          "text": "我的儿受绑缚叫娘心痛。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "儿在法场之上，听为大娘道来。想儿的娘亲，与为大娘的不和，不该用杯药茶， 要将为大娘的害死。不想儿的娘舅，来在家中，将这杯药茶吞吃腹内，一霎 时七孔流血，一命身亡。儿的娘亲一见儿的母舅身死，一计不成，又生二计。 去至公堂，击鼓鸣冤，反说为大娘的害死，将为大娘屈打成招，问成死罪，下 入监牢。我儿闻知，去至监牢，搭救为大娘的性命，替为大娘的一死。多亏新 任老爷，尚未上任，如此我儿，你情愿替为大娘的认罪，将为大娘放出监牢， 将我的儿收入监内。为大娘回得家去，闻听人言，我儿今日出斩，为大娘打来 几杯浊酒，买来几文纸钱，以表我儿搭救大娘的情肠，儿要喝上几杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张浪子喝酒，吐。"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "吃不下了。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "吃不下了？"
        },
        {
          "character": "郎二虎",
          "type": "白",
          "text": "老太太，我也吃上几杯。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "大哥，你也要吃上几杯？"
        },
        {
          "character": "郎二虎",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我儿死在阴曹，你要多多照应。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郎二虎吃酒，吐。"
        },
        {
          "character": "朗二虎",
          "type": "白",
          "text": "吃不下了。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "你也吃不下了。 儿呀，为娘打来几文纸钱，与你焚化。"
        },
        {
          "character": "王氏",
          "type": "叫头",
          "text": "我儿！儿呀！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "本当为大娘的拜儿几拜，怎奈是大不拜小，只恐我儿消受不起，为大娘的望空 一拜也。"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "眼望法场深深拜， 拜上我儿听开怀： 在法场哭得如泥块，"
        },
        {
          "character": "王氏",
          "type": "哭",
          "text": "儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏下。王清天上。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "时辰可到？"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "时辰已到。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "将郎二虎开刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朗二虎下。"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二刽子手同斩朗二虎。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "将浪子开刀！"
        },
        {
          "character": "太监",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。王清天迎接。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "圣旨下，跪。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "听宣读。诏曰：今有药茶一案，律应斩首。后宫娘娘讲情，只可以赦，不可以 斩。圣意读罢，望诏谢恩哪！"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "犯人在哪儿哪？"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "现在席棚。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "让我瞧瞧。不是女人么，怎么是个男人？"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "乃前官所断。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "你倒推了个干净。 孩子们！将他给我背进宫去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监背张浪子下。"
        },
        {
          "character": "王清天",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张浪子上。"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "啊哈！"
        },
        {
          "character": "张浪子",
          "type": "念",
          "text": "法场得活命，死去又复生。"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "我，张浪子。只因我妈跟我大娘不和，要把我大娘害死。我妈将茶下上毒药， 给我大娘喝，我大娘不喝。不想我娘舅来到家中，可就把这杯药茶喝了。吃下 去七窍流血，可就死啦。我妈一见我娘舅死啦，去至公堂击鼓鸣冤，反说我大 娘害死我娘舅，将我大娘屈打成招，问成死罪。我想大娘平日待我不错，不免 去至监牢，替换我大娘一死。可巧前官升走，新官尚未上任。这么我就去拉三 班衙役，与我很有交情，我说你们将我大娘放出，我情愿替我大娘一死。这么 就把我大娘放出，将我收在监里。今日是我出斩之日，我大娘打来酒饭，前来 祭奠我来啦。正要杀我的时候，来了一群公公，将我背进宫去。瞧见我兄弟得 了进宝状元。我姐姐封为郡主。我出来接我大娘享享福。不免去至法场等候。 我大娘一定要收拾我的尸首来。呦呵，好小子郎二虎，我大娘打酒你也要吃， 现在你死啦，我打你两下。慢着，人死不记仇，我来抹你点人血。远远望见我 大娘来也。"
        },
        {
          "character": "王氏",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏上。"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "忽听大炮响一声， 我收浪子死尸临。 大胆且把法场进，"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "血淋淋人头吓煞人。 这厢不是那厢认，"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哈！"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "我儿为何得全身？ 是是是来明白了， 想是斩罪变绞刑。 打开芦席将儿卷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏卷张浪子。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "浪子！"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏吓跑。"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "跑啦，追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张浪子追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王氏上，张浪子追上。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "儿呀！为大娘的前来收拾儿的尸首，你、你、你、你不要惊吓为娘。"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "大娘，我没死。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "怎么我儿未死？"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "没死！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "为大娘的叫儿三声，儿要答应的才是。"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "叫吧。"
        },
        {
          "character": "王氏",
          "type": "叫头",
          "text": "浪子！"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "王氏",
          "type": "叫头",
          "text": "我儿！"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "大娘！"
        },
        {
          "character": "王氏",
          "type": "叫头",
          "text": "儿呀！"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "我儿为何得活命， 细据情由说娘听。"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "大娘有所不知，正要杀我那当儿，来了一群公公，把我背进宫去，我瞧见我兄 弟得了进宝状元，我姐姐封为郡主。我接您享享福。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "此话当真？"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "当真。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "果然？"
        },
        {
          "character": "张浪子",
          "type": "白",
          "text": "果然。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "如此随娘来。"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "哈哈呵浪子，我的儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏、张浪子同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}