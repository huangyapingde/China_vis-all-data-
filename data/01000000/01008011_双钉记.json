{
  "script_id": "01008011",
  "title": "双钉记",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "白金莲",
      "hangdang": "花旦"
    },
    {
      "name": "胡能手",
      "hangdang": "丑"
    },
    {
      "name": "贾有礼",
      "hangdang": "丑"
    },
    {
      "name": "债主",
      "hangdang": "丑"
    }
  ],
  "plot": "按本剧曲本所称，系一成衣匠胡某之妻，名白金莲，素与绸缎商贾有礼有染。胡某所设成衣铺又生意寥寥，\n家计甚艰窘，因之白金莲时常吵闹，常言欲与离异。既而欺胡某暗弱无能为，遂久蓄意欲谋毙胡某，以图与\n贾有礼作长久计。日者乘胡某工作醉归，适贾有礼在，遂迫贾有礼助同谋胡某，贾有礼初不允，白金莲则以\n讹罪嫁祸要挟之。贾有礼无奈，卒被胁助成其恶。白金莲计甚阴狡难测，盖以铁钉从脑后发髻钉入而致其命\n也。本剧即演到此谋毙为止。",
  "notes": "惟按是剧，应重在后本平反冤狱一段，方与“双钉”二字之剧名相称，且于剧情亦圆满无憾。若谓仅此而已\n足焉，则未免使人徒震其名。正曲者其以为何如？前见路三宝演此出，其一种凶悍之态，形容颇能尽致。此\n剧后本折狱一事，人均谓为阎罗包老之事，而或说则以为是元代姚忠肃公故事，兹不赘言，俟后本当为详考。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "白金莲上。"
        },
        {
          "character": "白金莲",
          "type": "念",
          "text": "生来命运蹇，终日受煎熬。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "奴家白氏金莲，许配胡能手为妻。吃亦不得吃，穿也没得穿，外头欠了不少的 帐，天天有人上门要账。他怎么老不死，等他死了我就好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "债主上。"
        },
        {
          "character": "债主",
          "type": "白",
          "text": "开门！"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "债主",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "债主",
          "type": "白",
          "text": "你丈夫欠我的钱，今天要了。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "大爷，我丈夫不在家，你的钱过了月底，二十五、六，一准送来。"
        },
        {
          "character": "债主",
          "type": "白",
          "text": "你要送来的吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "债主下。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "慢走不送。 你们看看，有人前来要账，他睡到这个，还不起来。 我说你该起来罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡能手上。"
        },
        {
          "character": "胡能手",
          "type": "数板",
          "text": "家住安徽石碑街，讨个老婆会卖乖。前门开的裁缝铺，后门又把窑子开。这个 买卖不发财，只是活该真活该。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老婆，叫你老子出来什么事？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你睡到这个时候，有人来要账，你可晓得？"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "哪一个问老子要钱？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你欠人家钱的么！"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老子不欠钱。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你不欠钱，王八蛋欠人家的钱！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "开门！"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老婆，有人来了。你说老子不在家。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "我说你在家。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "胡能手，张老爷叫你去做袍子套子。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "晓得了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "你快去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老婆，我老子要发财了。张老爷叫我去做袍子套子，你把我的家伙熨斗拿过来。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "家伙在这里。你有钱回来，若是无钱么，你就死在外面，不要回来呢。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老子有钱无钱总要回来的。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你没有钱，我要与你散荡。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "你要同老子散荡，什么叫做“散荡”？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你几时回来？"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老子不晓得几时回来。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你不晓得么，你就与我死了出去罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲下。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "这个娘卖毴的！她要同老子散荡，思想起来，好不命苦也！"
        },
        {
          "character": "胡能手",
          "type": "西皮摇板",
          "text": "我今低头来暗想， 可恨父母做事差。 三十六行都好做， 为什么叫我学裁缝？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡能手下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾有礼上。"
        },
        {
          "character": "贾有礼",
          "type": "西皮摇板",
          "text": "酒不醉人人自醉， 色不迷人人自迷。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "我，贾有礼。在四马路口开了一个绸缎铺。只因胡能手，欠我一匹湖绉的钱， 老不还我。他的老婆，生来不错。不免待我前去。胡能手在家，我只说要钱； 倘若他不在家，我与他老婆眉来眼去，如若此事成功，这乃是我父母的阴功、 祖上的德行也。"
        },
        {
          "character": "贾有礼",
          "type": "西皮摇板",
          "text": "三步当做两步走， 一步来到他家门。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "大嫂开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲上。"
        },
        {
          "character": "白金莲",
          "type": "西皮摇板",
          "text": "忽听门外有人声， 待我开门看分明。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "是哪个叫门？"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "原来是贾大爷。我丈夫不在家，你不要上门要账。我丈夫说，过了二十五、六， 一准送来。你慢走吓，我不送你了。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "你怎么叫我走？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你不晓得，我这样说么，间壁街坊听见，他们当你走了。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "你这一套，真真有的。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "我没有这点肚才，怎能做内掌柜的。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "大嫂你好。我不在这里，你们夫妻二人可曾吵闹么？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "哎，大爷吓！"
        },
        {
          "character": "白金莲",
          "type": "西皮摇板",
          "text": "自从大爷出门后， 天天打骂我难做人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲哭。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "你不要哭，明天把他几百两银子，叫他到别处开裁缝铺去。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你出门到哪里去的？"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "我到广东省去的，带了许多好东西来送你。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "什么好东西？"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "眼镜子，百家锒，大烟枪，你看好不好？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "这些东西，你自己留着吧。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "我今天回来，要高兴高兴。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "什么叫高兴？你快出去，我要叫呢。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "哎呀我的妈吓！你不要叫，我出去呢。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你回来。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你同你闹白相的。如此你我睡去吧。"
        },
        {
          "character": "贾有礼",
          "type": "西皮摇板",
          "text": "今日好比七月七，"
        },
        {
          "character": "白金莲",
          "type": "西皮摇板",
          "text": "牛郎织女会佳期。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲、贾有礼同进帐。胡能手上。"
        },
        {
          "character": "胡能手",
          "type": "西皮摇板",
          "text": "放开大步往前进， 不觉来到自家门。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "张老爷待我老子真真好，请我吃了大碗酒大块的肉，还把我一吊钱。我要回家 了。你们看看，青天白日把门关上，成什么样儿，待我来叫门。 老婆开门，老婆开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲出帐。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "哪个叫门？"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "我老子回来了。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "哎呀，你丈夫回来了。叫我怎么好？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你不要害怕，睡在床上，待我前去开门。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "你快开门，吓，老子回来呢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲开门。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "进来。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老子就进来了。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你怎么回来了？"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老婆，张老爷待老子真真好。袍子套子做好了，他请我吃了大碗的酒、大块的 肉，还把我一吊钱。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "钱拿来。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "慢来。你说道要同老子散荡，就散荡！"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "我与你闹着玩的，我怎么舍得你这好样子吓。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "你不要灌迷汤，钱么你拿过去。老婆，今天老子要到你房里睡去，要高兴高兴。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你今天在房外头睡吧，我的肚子痛，不能高兴。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老婆，这顶帽子是贾有礼这个婊子养的么？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "不是的。他们叫我做样子的。你睡吧。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "老婆，我同你夫妻一场，你要快点吓。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你快睡吧。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "我睡吧，咳咳，"
        },
        {
          "character": "胡能手",
          "type": "念",
          "text": "我今天脱下鞋和袜，不知明天穿不穿。"
        },
        {
          "character": "胡能手",
          "type": "白",
          "text": "哎，祖宗吓！祖宗吓！"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你睡吧，睡好，我与你盖上，好好的睡。 嘿，你快出来吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾有礼出帐。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "哎呀，我心里好害怕，你开门，我要回去了。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "什么，你要回去？"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "我要回去。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "好容易他睡在外面，你倒要回去了。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "我不回去有什么事？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "叫你把他害死了。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "哎呀我的妈呀，我从来么没有害过人。待我快快回去吧。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "好吓，你只管回去，我今晚把他害死，明日只说你叫我把他死的，看你往哪里 跑？"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "哎呀，你不要害我。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "不要回去，帮着我。你去拿钉过来。看我的，你走开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾有礼抖。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "待我动手。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲钉，胡能手死。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你看见没有，我为你把他害死，你我做一个长头夫妻。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "好了好了，我要回去了。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "慢走，我问你，几时来接我到你家去？"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "过了三七二十一天，我来接你。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "你不要忘了。"
        },
        {
          "character": "贾有礼",
          "type": "白",
          "text": "我不能忘的，你快开门，让我走吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白金莲开门，贾有礼下。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "害个把人，算不了什么，待我假意哭起来。 哎呀我的夫吓，夫吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四乡邻同上。"
        },
        {
          "character": "四乡邻",
          "type": "同白",
          "text": "大嫂子为什么啼哭？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "我丈夫死了。"
        },
        {
          "character": "四乡邻",
          "type": "同白",
          "text": "什么毛病死的？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "昨晚急病死的。"
        },
        {
          "character": "四乡邻",
          "type": "同白",
          "text": "总要请个阴阳开开亡榜。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "兄弟，我家里没有人，你替我去请吧。"
        },
        {
          "character": "乡邻甲",
          "type": "白",
          "text": "待我去。 我说阴阳先生可在家么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阴阳先生上。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "不在家。"
        },
        {
          "character": "乡邻甲",
          "type": "白",
          "text": "不在家为什么说话？"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "人不在家嘴在家。"
        },
        {
          "character": "乡邻甲",
          "type": "白",
          "text": "好，你就把嘴请出来吧。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "我连嘴连人都出来呢。你家里死了什么人？"
        },
        {
          "character": "乡邻甲",
          "type": "白",
          "text": "不是的，间隔的裁缝胡能手死了。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "他是个好人，从来没有死过，这是头一回死，待我去。"
        },
        {
          "character": "乡邻甲",
          "type": "白",
          "text": "有劳你了。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "大嫂子。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "阴阳先生。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "死人在哪里？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "大嫂子，你好大的胆子。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "不是别的，我讲你一个人在这里怕不怕。我问你，他今年多大年纪？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "四九三十六岁。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "几月里生的？"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "五月初五日午时。"
        },
        {
          "character": "阴阳先生",
          "type": "白",
          "text": "好厉害的时辰。大嫂子你听着：他这人心是直的，欢喜戴高帽子的，走的是竹 节运，脾气毛松松的，后来有两子送终。你拿去盖在面上，我要去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阴阳先生下。"
        },
        {
          "character": "白金莲",
          "type": "白",
          "text": "不送你了。兄弟，你帮着我一同扛下去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四乡邻扛胡能手同下，白金莲下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}