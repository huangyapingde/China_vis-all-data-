{
  "script_id": "01002011",
  "title": "梅龙镇",
  "alias": [
    "游龙戏凤；一名：下江南"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "正德帝",
      "hangdang": "老生"
    },
    {
      "name": "李凤姐",
      "hangdang": "旦"
    }
  ],
  "plot": "明武宗喜微行，委政江彬、刘瑾等小人，以致阉寺弄权，朝纲日坏。某日游至梅龙镇，乔装军官模样，投宿\n李龙哥家。李龙只兄妹二人，设酒肆度日。李龙适有事他出，嘱妹凤姐招待一切，帝见凤姐色艳，顿起佻达\n之意，呼茶唤酒，借端戏谑。凤姐娇羞薄怒，帝益心醉神迷，乃告凤姐以实。凤姐不信，帝解去外衣，以龙\n衮示之。凤姐大惊，跪地求恕，帝笑而慰之。从此更衣入侍。宠冠六宫，香车宝辇，管领春风。回想红炉暖\n酒时，真有天上人间之别矣。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "正德帝上。"
        },
        {
          "character": "正德帝",
          "type": "引子",
          "text": "龙游芳草地，凤绕牡丹池。"
        },
        {
          "character": "正德帝",
          "type": "念",
          "text": "大明统一锦山河，龙车凤辇难快活。孤王离了燕京地，闻得大同景致多。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "孤，大明天子正德在位。是孤来在大同，住在李龙店中。是他言道：要茶要酒， 将木马一响，有人送来。今晚夜宿梅龙镇上，好不闷煞人也。"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "有孤王坐至在梅龙镇， 想起了朝中大事情： 将玉玺授与了龙国太， 朝中大事付与了众卿。 孤王将木马一下响， 看看来的是何人呀，啊，是何人。"
        },
        {
          "character": "李凤姐",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐上。"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "自幼儿生长在梅龙镇， 兄妹卖酒度光阴。 我哥哥他也曾对我论： 他言道前边有一位军人。 李凤姐端茶是客堂进，"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哟啐！"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "李凤姐回转绣房门，啊，绣房门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐手势，下。"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "好花儿出在了僻乡间， 并无贤臣献与寡人。 孤忙将木马是二下响，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐上。"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "后面来了卖酒人。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保，酒保！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "酒保没有，倒有个酒大姐在此。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "合罕呀，这丫头自称酒大姐，本当叫她一声，怕她消受不起。也罢，以酒为名， 叫她一声酒大姐。 呀，酒大姐。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷讲些什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "方才那个稍长大汉，他是何人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他是我家哥哥。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "他叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他叫李龙。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪里去了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "巡更守夜去了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐你叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我么，没有名字的。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "人生在世，哪有没有名字的道理。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "名字倒有，说出来怕军爷你叫。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为君的不叫就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷不叫，如此我姓李。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我晓得你姓李，叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我叫李凤姐呵。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好一个李凤姐，呵呵！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "拿名字来还我。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "说出如风，怎能还你？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷方才你说不叫，怎么叫起来了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为君的就叫这一次。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "下次不可。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不次不叫就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷讲些什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这梅龙镇上，是这等酒饭不成？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有三等酒饭。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪三等？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "上、中、下三等。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这上等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "来往官员所用。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "中等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "买卖客商。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这下等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "那下等的么，不讲也罢。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为何不讲？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "讲出来怕军爷着恼。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为君的不恼就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷不恼，那下等的就是你们这样吃粮当军之人所用。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "合罕呀，吃粮当军，有这样苦处。也罢，待寡人此番回朝，发饷银十万，犒赏 三军。 呀，酒大姐，把上等的酒饭，摆上一席。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷要吃上等的酒饭？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "打个哑迷你猜。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你且讲来。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "坐船？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "船钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "歇店？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "店钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷用酒。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒后。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哟啐，酒钱都不会说，说什么“酒后”。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "听你之言，敢是要钱？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我倒不要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪个要钱？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我家哥哥回来，问我要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你家哥哥要钱，就好讲话了，将帘卷起。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "在身上取出了一锭银， 交与大姐算酒钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "拿去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "放在桌案上。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "桌子是滑的，银子是光的，滚在地下，那还了得？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "滚在地下，有我来捡。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕呀。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你怕什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕伤了大姐的腰。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "伤了我的腰，与你有什么相干？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我有些心痛。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我自己都不心痛，要你来心痛。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好不受抬举，拿去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷敢是舍不得？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我倒舍得，只怕大姐你舍不得。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呵哈且住，看这军爷，有些不老实，待我来哄他一哄。 呀，军爷进得我们店来，可曾看见一幅古画？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为君的最喜古画，古画在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在墙上。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "被这丫头骗了去了。"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "李凤姐接过了一锭银， 问声军爷几个人？"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "为君的一人一骑马，"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "一人用不了许多银。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷银子太多了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "人的饭食，马的草料。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "还多。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "送与大姐买花戴。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "多谢军爷，军爷请呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "请到哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "请到客堂。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "到你的卧房？走呀走呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "唉，客堂呵！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "噢，客堂呀。 大姐，这是哪个的卧房？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这就是我的卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我正要到你的卧房走走。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "噢，你可晓得男女授受不亲啊！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这丫头也晓得男女授受不亲啊！"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "孤龙行虎步进客堂，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "梅龙镇上好紧的门户呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐你好紧呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝下。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哟啐！"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "李凤姐带上了两扇门。 忙把酒席来端整， 请出军爷饮杯巡。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷请出来用酒，军爷请出来用酒！ 啊哟哟，你看这个人，方才叫他进去，他不进去；现在叫他出来，他又不出来 了，为他这一桌脏了我一双手。不免打水洗手便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝上，手势。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这梅龙镇上，好高大的房子啊！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "房子房子，打你一盘子！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么骂起来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "想你进得我们店来，上也瞧瞧，下也瞧瞧，想我们女人之家，有什么好看？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐长得好看，为君的爱看。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷爱看，你就看了几看。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐大方了，我倒要仔细看上几看，好！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "再看看。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好，我就再看看。好好好！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "再看看。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不用看。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我看你是我们店里的客人，要不是我们店里的客人，我就要骂你！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么骂起来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不但骂你，还要打你！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为君的出世以来，并无人打我。大姐爱打，你就打上几下。"
        },
        {
