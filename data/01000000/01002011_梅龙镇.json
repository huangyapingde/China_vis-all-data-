          "character": "正德帝",
          "type": "白",
          "text": "我是不出去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你不出去，我就要喊叫。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你喊叫什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我喊叫你杀人。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我手无寸铁，怎能杀人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你的心比刀还狠。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我自不出去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我就喊叫。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "慢来慢来。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怕你不出去。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "且住，这丫头喊叫起来，惊动乡邻地保差值当官，那还了得？有了，她若有福， 封她一宫；她若无福，打马就走。 啊，大姐，你可认识我？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你是大户长的兄弟，三户长的哥哥，你是个二混账！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不要骂人，我乃当今正德天子。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "走开，你可认识我？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我认识，你是梅龙镇上卖酒的丫头。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎，我是当今正德天子的娘啊！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "岂不折煞你丫头，自古道龙行有宝。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你就献宝。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "倘若无宝？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "献你娘的现世宝。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不要骂人，大姐观宝。"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "在头上除下来沿毡帽， 身上露出滚龙袍。 叫一声大姐来观宝， 我头上也是龙，身上也是龙，左边也是龙，右边也是龙，前面也是龙，后面也 是龙，浑身上下是九条龙，啊，五爪的龙袍。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "好宝贝。"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "怪不得昨晚得一梦， 真龙天子落房中。 我走上前来忙下跪， 望求万岁将我封。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "李凤姐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "跪在为君面前做甚？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "前来讨封。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你方才骂我是你家哥哥的大舅子，我是不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你封了我，我家哥哥是你的大舅子。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "小舅子也不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "就是小舅子。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "也不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "封一点点。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "封一微微。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "封一洩洩。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "也不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不封也罢。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我若不封，岂不羞煞你这个丫头？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怕你不封。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "凤姐听封："
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "孤三宫六院俱封尽， 封你闲游戏耍宫。"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "我叩罢头来龙恩谢，"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "用手搀起爱梓童。"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "问声君爷欲何往？"
        },
        {
          "character": "正德帝",
          "type": "二黄平板",
          "text": "为君打马奔大同。"
        },
        {
          "character": "李凤姐",
          "type": "二黄平板",
          "text": "就在这梅龙镇上宿一晚，"
        },
        {
          "character": "正德帝、李凤姐",
          "type": "同二黄平板",
          "text": "一对金杯落真龙。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "君爷请呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "请到哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "请到卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "走啊，啊，不去了。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "为何不去？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你怕什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕你家哥哥。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有我。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "有你就不要紧了，走啊，凤姐。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "君爷。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "梓童。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "摆驾进宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝、李凤姐同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}