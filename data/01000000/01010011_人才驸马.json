{
  "script_id": "01010011",
  "title": "人才驸马",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "高能",
      "hangdang": "小生"
    },
    {
      "name": "杨仙同",
      "hangdang": "小生"
    },
    {
      "name": "张天龙",
      "hangdang": "净"
    },
    {
      "name": "玉宝公主",
      "hangdang": "旦"
    },
    {
      "name": "玉珍公主",
      "hangdang": "旦"
    },
    {
      "name": "魏小生",
      "hangdang": "丑"
    }
  ],
  "plot": "剧情为两少年将，一名高能，一名杨仙同，往番营索战，遇见两公主，一名赛美人玉宝，一名赛天仙玉珍。\n彼此一见倾慕，两情相洽，各占一少年，携归营中留宿，卒至同谋将驸马张天龙杀死。",
  "notes": "此剧不悉何出处，且其“人才驸马”四字更粗鄙可笑，惟秦腔剧中有乃此等名称焉。此驸马即自称为“人才\n驸马”者，奇妙之极。且剧中似涉妖法等事，颇难索解，并毫无情理，只能博妇人稚子一笑耳。近时时髦花\n旦中，擅演此剧者颇多，然不因此戏而足多其声誉也。惟京都四喜班水仙花，曩昔曾以此擅名一时。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、张天龙、玉宝公主、玉珍公主同上，〖点绛唇〗，急急风。"
        },
        {
          "character": "张天龙",
          "type": "念",
          "text": "两膀余力似金刚，天朝大将谁敢挡。"
        },
        {
          "character": "玉宝公主",
          "type": "念",
          "text": "上阵不用多费力，"
        },
        {
          "character": "玉珍公主",
          "type": "念",
          "text": "全凭妖术把人伤。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "俺，土番国人才驸马张天龙。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "俺，赛美人玉宝公主是也。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "俺，赛天仙玉珍公主是也。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "可恨那余伏容，被某一战，围困在双沙河。事到如今，战又不战，降也不降。 二位公主，有何计哉？"
        },
        {
          "character": "玉宝公主、玉珍公主",
          "type": "同白",
          "text": "且听探马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探马上。"
        },
        {
          "character": "探马",
          "type": "白",
          "text": "天朝讨战。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探马下。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "二位公主，天朝讨战，如何是好？"
        },
        {
          "character": "玉宝公主、玉珍公主",
          "type": "同白",
          "text": "驸马不必惊慌，待我姐妹二人出马，生擒那贼进帐。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "如此二位公主听令。"
        },
        {
          "character": "玉宝公主、玉珍公主",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "命你二人攻打头阵。"
        },
        {
          "character": "玉宝公主、玉珍公主",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "玉宝公主",
          "type": "西皮摇板",
          "text": "帐中领了驸马令，"
        },
        {
          "character": "玉珍公主",
          "type": "西皮摇板",
          "text": "攻打头阵要小心。"
        },
        {
          "character": "玉宝公主",
          "type": "西皮摇板",
          "text": "人来带过能行马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉宝公主下。"
        },
        {
          "character": "玉珍公主",
          "type": "西皮摇板",
          "text": "两军阵前显奇能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉珍公主下。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "二位公主出马，是某放心不下。 番儿们带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙、众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "魏小生上。"
        },
        {
          "character": "魏小生",
          "type": "西皮摇板",
          "text": "家中领了姑母命， 土番国内走一程。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "俺，天朝大将魏小生。家中奉了姑母之命，攻打头阵，就此前往。"
        },
        {
          "character": "魏小生",
          "type": "西皮摇板",
          "text": "将身来在战场道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙上。"
        },
        {
          "character": "张天龙",
          "type": "西皮摇板",
          "text": "马前来的是何人？"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "呔！马前何人？通名受死。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "哎吓，哪里打雷的！我看看。 人高马大，这家伙可以了得。 马上通名受死！"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "你且听了：某乃土番国人才驸马张天龙。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "呵呵，不要叫我笑你呢！论驸马，不要管他；论人才，你还没有我长得好看。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "黑贼，通名上来受死。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "我天朝大将魏小生，是你一个人的活爷爷。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "哈哈哈。哇呀哇呀，黑贼还不前来投降！"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "不要吹牛毴，着家伙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏小生、张天龙开打，张天龙下。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "咦，人高马大，原来是个草包，一打就跑。有呢，他到哪里，我追到哪里。 贼子休走，你魏老爷赶来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏小生追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张天龙上。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "且住，贼子来的厉害，不免法宝擒他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏小生拦头上。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙令旗变手，魏小生变狗下。"
        },
        {
          "character": "张天龙",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏小生打张天龙肚。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "哇呀哇呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙下。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "咦，又跑呢，我还是追吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏小生下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高能、杨仙同同上。"
        },
        {
          "character": "高能",
          "type": "西皮摇板",
          "text": "兄长上阵无影信，"
        },
        {
          "character": "杨仙同",
          "type": "西皮摇板",
          "text": "倒叫二人挂在心。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "俺，高能。"
        },
        {
          "character": "杨仙同",
          "type": "白",
          "text": "俺，杨仙同。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "兄长此去还不见到来，你我迎上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏小生上。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "哎，兄长来了。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高能、杨仙同同拉魏小生。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "怎么样？怎么样？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "不要拉吓。你也拉，他也拉，把我拉散了！"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "你上哪里去的？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "我打仗去的。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "可曾见过仗来？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "打了一仗。这个家伙，人高马大，好厉害。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "哦，这个人有多大？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "这个人么有丈七八。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "丈七八。他的坐骑呢？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "他骑的马，也有丈七八。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "哦，也有丈七八。他手中的兵刃呢？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "他手中使的兵刃么，也有丈七八。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "哦，也有丈七八。他连人带马带兵刃？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "他连人带马带兵刃，也有丈七八。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "哪里来得许多“丈七八”！"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "呵，这个家伙，厉害极呢。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "依你便怎么样？"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "依我吓，跟你们弟兄俩商量商量，告诉姑妈一声：写个降书降表，降了他们吧。"
        },
        {
          "character": "高能、杨仙同",
          "type": "同白",
          "text": "住了！"
        },
        {
          "character": "高能",
          "type": "西皮摇板",
          "text": "兄长说话太屈情，"
        },
        {
          "character": "杨仙同",
          "type": "西皮摇板",
          "text": "岂能无故降他人。"
        },
        {
          "character": "高能",
          "type": "西皮摇板",
          "text": "人来带过能行马，"
        },
        {
          "character": "杨仙同",
          "type": "西皮摇板",
          "text": "不擒那贼不为人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高能、杨仙同同下。"
        },
        {
          "character": "魏小生",
          "type": "白",
          "text": "哈哈哈！倒底年轻的人，搁不住我几句话一说，马上就去打仗了。他们去打仗， 我睡觉。 哎吓，慢着。我睡觉，姑妈晓得，当我临阵脱逃，降下罪来，怎么得了。哦， 有了，他们去打仗，我在后头跟着。他们打了胜仗，我先回来领头功；他们要 是败了，我在后面先跑。就是这个主意。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏小生下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "玉宝公主、高能自两边分上，会阵，押枪碰嘴。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "呔！那员小将姓什么叫什么？你是个什么东西？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "哽，老爷姓高。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "哦，姓高，叫什么？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "俺叫高能。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "哦，高能高少爷。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "哎，要叫老爷！"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "少爷将就一点吧。我来问你，我们杀来杀去，为的什么？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "为主江山。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "哦，为主江山？打出江山，还是你坐，还是我坐？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "哧，哪有臣坐君位之理！"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "哦，你也不能坐，我也不能坐吓，咱们两个人不要打了。何不留个交情？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "什么叫作“交情”？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "你们天朝人，连个“交情”都不懂？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "俺不懂。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "哦，你不懂。顺着我手儿瞧了，这看见没有？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "这是什么地方？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "这是红罗宝帐。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "是哪一个的？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "这是我的。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "我进去打个茶围行不行？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "慢着，咱们留了交情再来。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "哦，是了。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "这个你看见没有？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "这是什么地方？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "这是黄罗宝帐。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "黄罗宝帐是哪个的？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "是我们驸马爷的。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "哦，敢是那张天龙的？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "不错。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "待我来打了他的。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "慢来，咱们留了交情，我帮你一块打。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "哦，是了。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "这个看见没有？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "这又是什么地方？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "这是素罗宝帐。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "素罗宝帐是哪个住的？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "那是我妹子的。"
        },
        {
