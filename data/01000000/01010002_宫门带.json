  "plot": "唐初高祖李渊时，秦王李世民功高才大，大太子李建成、三太子李元吉均甚忌妒之，蓄意倾陷。值李渊小病，\n李世民入视疾，亲奉汤药，行经西宫院，见李建成、李元吉在尹、张二妃宫中饮酒取乐，李世民怒其昏乱\n悖伦，无礼之至，乃取带悬系宫门以警之。孰意二妃见带，反与李建成、李元吉商通，持带迳至帝前诬奏李\n世民入宫调戏，强行非礼，妃等誓死不从，有李世民随身玉带为凭。帝闻奏大怒，即传旨欲斩秦王。长孙无\n忌入保，帝盛怒之下，亦命同斩。徐勣、秦琼等急入宫保奏俱不允。赖褚遂良抵死连奏十本，远证近譬，极\n力讼冤，并以在宫侍疾时候，证明二妃所奏之诬，王始恍然省悟，乃释秦王及长孙无忌回。并命褚遂良为之\n彻底查办此事乃毕。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，李渊上。"
        },
        {
          "character": "李渊",
          "type": "二黄慢板",
          "text": "昨日里皇儿把药煎， 今日腹中好几分。 内臣与孤金殿进， 看是何人把本申。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尹妃、张妃同上。"
        },
        {
          "character": "尹妃、张妃",
          "type": "同二黄摇板",
          "text": "急忙忙来在金殿里， 见了万岁奏端的。"
        },
        {
          "character": "尹妃、张妃",
          "type": "同白",
          "text": "妾妃见驾，吾主万岁万万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "梓童为何这等模样？"
        },
        {
          "character": "尹妃、张妃",
          "type": "同白",
          "text": "今有世子世民，昨晚二更进得宫来，调戏妾妃，万岁作主。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "尹妃、张妃",
          "type": "同白",
          "text": "玉带为证。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "一见玉带不由孤心中恼， 子淫父妃乱朝纲。 梓童暂归宫闱里， 内臣宣上李世民。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尹妃、张妃同下。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "万岁有旨：宣二世子秦王见驾。"
        },
        {
          "character": "李世民",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民上。"
        },
        {
          "character": "李世民",
          "type": "二黄摇板",
          "text": "听说父王来宣诏， 但不知所为哪一条？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "儿臣见驾，愿父王万岁万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同上。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "骂声奴才真大胆， 子淫父妃乱朝纲。 吩咐两旁武士手， 推出午门把刀开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同允，推李世民同下。长孙无忌上。"
        },
        {
          "character": "长孙无忌",
          "type": "二黄摇板",
          "text": "听说要斩二主君， 不由为臣胆战惊。 将身且把金殿进， 见了万岁奏分明。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "臣见驾，吾主万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "卿家上殿有何本奏？"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "二主身犯何罪，推出斩首？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奴才灭乱人伦，理当取斩。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "念他有十大汗马功劳，万岁只宜赦，不宜斩。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "哼，你乃一党之人。 武士，推出斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同允，推长孙无忌同下。徐勣、魏徵、程咬金同上。"
        },
        {
          "character": "徐勣",
          "type": "二黄摇板",
          "text": "听说要斩二主君，"
        },
        {
          "character": "魏徵",
          "type": "二黄摇板",
          "text": "不由吾等胆战惊。"
        },
        {
          "character": "程咬金",
          "type": "二黄摇板",
          "text": "你我上殿把本进，"
        },
        {
          "character": "褚遂良",
          "type": "内白",
          "text": "先生慢走！"
        },
        {
          "character": "徐勣、魏徵、程咬金",
          "type": "同二黄摇板",
          "text": "那旁来了文曲星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、魏徵、程咬金同下。褚遂良上。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "反了吓，反了！"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "听说要斩二主君， 斩断擎天柱一根。 保本官儿推出斩， 长孙无忌问典刑。 徐勣、魏贞不保本， 袖手旁观程咬金。 都是奸妃定下计， 我主爷以假就认了真。 我歪戴乌纱袍撒带， 假装疯魔去见当今。 怒轰轰跑上金銮殿， 与他个君不君臣不臣。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣褚遂良见驾，万岁请了！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "褚遂良，莫非你疯了不成？"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣倒不曾疯，只怕万岁你昏了！二主秦王，身犯何罪，推出午门斩首？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奴才灭乱人伦，理当取斩。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "秦王东荡西除，南征北剿，有十大汗马功劳，只宜赦，不宜斩。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "孤王龙心已定，不必多奏。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "万岁苦苦要将秦王斩首，你君心何忍，我臣心何安？"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "曾记得驾坐太原省， 三搜晋阳主为君。 二千岁大战王世充， 瓦岗收来众英雄。 美良川前收敬德， 千秋岭下战罗成。 大唐收了罗士信， 日锁五龙定太平。 争来了江山多安稳， 乐以忘忧乱斩人。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奴才灭乱朝纲，理宜斩首。你乃一类之人。 来，一同取斩！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "且慢！启万岁：臣有十道条陈，容臣奏定再斩不迟。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "你当殿奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "修本不及，乃是口奏。这头一道条陈奏的是夏禹王做了一十七代江山，享年四 百三十余载。后出了一君名曰桀王，宠爱一妃，名叫妺喜。听妺喜之言，以肉 为林，以酒为池，造下了瑶台玉床，行淫取乐，残害百姓。他驾前有一忠良， 名叫关龙逢，苦苦谏奏，反将他斩首。后来成汤王拜伊尹为帅，前来伐夏吓！"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "自古有道伐无道， 成汤王有道救黎民。 南巢山下桀王死， 万里江山一旦倾。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "将孤王比作无道君， 你与世民同斩刑。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "来，斩了！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "大胆，下去！ 臣方才言过，十道条陈奏完，再斩不迟。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：这二道条陈，奏的成汤王，做了二十八世，享年六百四十四载。后出一 君名曰纣王，他宠爱一妃名叫妲己，起造一台取名鹿台，高矗霄汉，穷极奢华， 又名摘星楼。他驾下有二佞臣，一名费仲，一名尤浑。听他等之言，造下炮 烙虿盆，剖腹验胎，敲骨视髓。天下震怒，姜国母谏奏，挖目烙手，太子遭除， 微子隐去，箕子被监，比干苦谏，剖心而亡，黄家父子反出五关。后来周武 王拜姜尚为帅，在孟津会合诸侯前来伐商。可怜那纣王，只落得火焚鹿台而死。 哎呀万岁吓！"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "这是那前朝好色君， 万里江山一旦倾。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "这都是前朝无道君， 拿着江山让外邦。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "二道不准，三道奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这三道条陈，奏的周武王十二世孙名曰幽王，宠爱一妃名叫褒姒，生 得天姿国色。无奈他进宫以来，从不带一笑容，那幽王要求他一笑，无计可施。 他驾前有一谗臣，名叫虢石夫，奏道：何不去往骊山焚起烟墩，娘娘必然欣 笑。那幽王果到骊山焚起烟墩，各路诸侯见烟墩一起，只道国家有难，一个个 人不及甲马不及鞍，不分星夜而来。赶到骊山之下，只见他君妃在那里饮酒取 乐，一个个有兴而来没兴而归。那褒姒见诸侯无故而来，她就哈哈大笑。后来 犬戎造反，那幽王无奈，又将烟墩焚起。各路诸侯见烟墩又起，内中有家诸侯 说道：你我本当前去勤王，又恐他君妃饮酒取乐，戏耍吾等，莫若各保藩地为 妙。一个个按兵不动，袖手旁观。可怜那幽王在骊山之下，死于乱军之中。哎 呀万岁，那幽王只为娘娘一笑，不值紧要，笑去了周室锦绣天下。"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "那幽王本是无道君， 骊山举火焚烟墩。 各路诸侯无救应， 万里江山一笑倾。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "将孤比作无道君， 胆大遂良乱胡行。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "三道不准，四道奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：这四道条陈，臣奏的是周朝的故事。自平王东迁之后，传至惠王，惠王 驾前有镇诸侯，名曰晋献公，那献公宠爱一妃，名叫丽姬。那丽姬每每有害申 生太子之意，在献公面前百般谗言。好一个献公，诸事不纳，不想丽姬定下一 计，奏知献公，说御花园中百花开得茂盛，带殿下前去观花，献公准奏。谁知 那丽姬暗用蜂蜜梳头，进得花园，那些蜜蜂儿，闻得蜜香，都飞落丽姬头上。 申生太子不解其情，在后面用扇儿赶开，那丽姬趁势倒在申生太子怀中。那献 公在楼台之上，一眼观见，说道这奴才，果有淫乱之心，吩咐武士推出斩首。 满朝文武挡住朝门，问起情由，齐声说道殿下既有不白之冤，何不奏明。申生 太子言道：我若奏明，父王定将丽姬斩首，怎奈我父王非丽居不安，非姬食不 饱，小王宁可一死，岂作不孝之人。哎呀万岁，看那前朝的申生太子我朝的西 府秦王俱是一样的故事。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "骂声遂良太无礼， 敢在金殿藐视君。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "四道不准，五道奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这五道条陈，奏的是楚平王去赴临潼大会，好一个伍子胥，力举千斤 鼎，剑劈梧桐勒，逼秦楚结亲。那平王看见孟嬴女生得十分美貌，怎乃是他的 儿媳，不好起齿。他驾前有一谗臣，名叫费无极，窥破平王的隐情，他就讨下 迎亲之役。行在中途，他将金顶轿改换银顶轿，孟嬴女改换马昭仪。太子芋建 不解其情，当日拜完花烛。一十三载才知其情，恨不能将费无极千刀万剐。那 费无极跑进宫中奏知平王，那平王说不妨，你且藏在龙书案下。那芈建太子， 手执宝剑赶进宫来，不见了费无极，平王羞恼成怒，说道这奴才手执宝剑，莫 非要刺杀寡人，吩咐武士推出斩首。伍奢上殿保奏，反将他满门斩首。好一个 伍子胥逃出昭关，去往吴国借兵，灭楚报仇，可怜那平王死后，还鞭八百。哎 呀万岁，这是前朝父纳子妾，不纳忠言，无道的昏君哪！"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "平王本是无道君， 父纳子妾乱人伦。 忠良谏奏反伤命， 留下臭名万古存。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "平王本是无道君， 败坏三纲没五伦。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "六、七道奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这六道条陈，奏的是吴王宠爱一妃，名叫西施，起造一台，名姑苏台。 他驾前有一谗臣名叫伯嚭，听信伯嚭之言，释放越王勾践，伍老相国谏奏不 准，反赐他宝剑自刎身亡。到后来越王勾践统领人马前来伐吴，可怜那吴王自 刎姑苏台下。这七道条陈奏的是齐宣公凭的是钟无盐娘娘压伏列国诸侯，后来 外邦进来一妃名叫夏迎春，每每有害无盐娘娘之意。后来无盐娘娘身怀六甲， 那夏迎春讨下收生代劳旨意，他暗用金丝狸猫剥去皮尾，掉换太子，启奏宣公， 说无盐娘娘产生妖魔鬼怪。宣公大怒，将无盐娘娘推出斩首，多亏满朝文武 保奏，贬入冷宫。那夏迎春一计不成又生二计，暗命心腹之人火焚冷宫，好个 无盐娘娘，他用隐遁之法，逃到钟氏家中安身。到后来鲁国吴起兴兵伐齐，吓 万岁，宣公无奈只得跪门求救。"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "宣公宠爱夏迎春， 起意谋害无盐身。 鲁国吴起来犯境， 无奈跪门求救兵。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "六、七道不准，八、九道奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣奏这八道条陈，乃是齐湣王宠爱一妃名叫邹赛花。听信邹妃之言，暗 害世子田法章，乐毅前来投齐，责打四十，赶出不用。后来乐毅投顺燕邦，金 台拜帅，前来伐齐，日晒湣王，路剐邹妃，哎呀万岁，这也是好色贪淫，不纳 忠言，无道的昏君！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣这九道，奏的是前朝文帝老王，立杨广以为东宫太子，哪哪哪，还是我主的 保官。你看那杨广弑父杀兄，欺娘奸妹，陆地行舟，扬州观看琼花。到后来天 降五花棒，哎！"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "杨广本是无道君， 欺娘奸妹乱人伦。 五花棒打死了隋炀帝， 我主爷才得驾坐西秦。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "遂良，八、九道不准，你这十道奏来，孤皇定要将你斩了。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "哎呀且住，九道条陈俱已奏完，这十道叫我从哪里奏起？ 好好好！万岁，臣十道条陈，奏的是前朝昏王与我朝的君皇俱是一样的故事！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "冤枉！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "哪个冤枉？"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "二主秦王的冤枉。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奴才调戏父妃，故尔取斩，有何冤枉？"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "请问万岁，二主秦王什么时候进宫？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "初更初点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "什么时候与我主煎药？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "二更二点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "什么时候出宫？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "三更三点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "二位娘娘奏道调戏不成，是什么时候？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "二更二点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "着着着！哎呀，万岁，想那二主秦王初更初点进宫，二更二点与吾主煎药，三 更三点出宫。二位娘娘奏道调戏不成也在二更二点，岂不是大大的冤枉？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "现有玉带为证。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "赐臣一观。 哎呀，万岁，二位娘娘奏道，调戏不成，抓袍夺带，必有一拉一扯，这带上并 无半点伤痕，请万岁详察。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "哦吓！"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "不是卿家把本奏， 孤王倒做无道君。"
        },
        {
          "character": "褚遂良",
          "type": "二黄摇板",
          "text": "万岁快把赦旨降， 午门外赦回二主君。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "褚卿家听旨：今有赦旨，午门外将二皇儿并无忌赦回。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "李渊",
          "type": "二黄摇板",
          "text": "内臣摆驾后宫进， 等候皇儿把话吟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引李渊同下。"
        },
        {
          "character": "褚遂良",
          "type": "西皮摇板",
          "text": "手捧赦旨下龙庭， 又听得两班发笑声。"
        },
        {
          "character": "褚遂良",
          "type": "西皮流水板",
          "text": "这一旁笑坏了徐勣、魏丞相， 那一旁笑坏了叔宝、程咬金。 都道我铁面无私褚遂良，"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "啊啊啊！"
        },
        {
          "character": "褚遂良",
          "type": "西皮流水板",
          "text": "险些误了大事情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "褚遂良下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四武士、长孙无忌、李世民同上。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "兄王作事太不仁， 宫门挂带害我身。"
        },
        {
          "character": "长孙无忌",
          "type": "西皮摇板",
          "text": "万岁台前不准本， 愿同二主赴幽冥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "褚遂良上。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "圣旨下，跪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、长孙无忌同跪。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "听宣读。诏曰：“朕因一时不明，误听谬言，多亏褚卿保奏，速赦西府秦王、 长孙无忌无罪，一同上殿封赠。”旨意读罢，谢恩。"
        },
        {
          "character": "李世民、长孙无忌",
          "type": "同白",
          "text": "谢主龙恩。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "多亏卿家保本，小王当面谢过。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "保奏来迟，恕罪，一同上殿复旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引李渊同上。"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "多亏遂良提醒孤， 险些做了无道君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "褚遂良上。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "启奏万岁：秦王并无忌候旨。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "宣世子、长孙爱卿一同上殿。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "万岁有旨：宣西府秦王、长孙无忌一同上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、长孙无忌同上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "儿臣谢父皇不斩之恩。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "非是孤皇不斩于你，多亏褚爱卿保本。 长孙爱卿上殿听旨。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "爱卿官还原职，下殿。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "长孙无忌下。"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "皇儿上前听旨降， 从今后无事不可入昭阳。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "谢罢父皇下殿往， 险些一命赴汪洋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "褚爱卿听封。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣不愿受封，请万岁命哪部大臣查明此事。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "就命爱卿查明回奏。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "褚爱卿上前听封赠，"
        },
        {
          "character": "李渊",
          "type": "西皮流水板",
          "text": "孤王言来听端详： 皇儿犯罪卿保本， 不避斧钺是忠良。 孤今赐你尚方剑， 朝里朝外要查明。 先斩后奏你执掌， 封你一代一个忠孝王。"
        },
        {
          "character": "褚遂良",
          "type": "西皮流水板",
          "text": "山呼万岁谢龙恩， 皆是秦王冤不明。 从今后莫信那谗臣本， 那时候普天下五谷丰登齐奏升平，道吾主有道明君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、褚遂良同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}