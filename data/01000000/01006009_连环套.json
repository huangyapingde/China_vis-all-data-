{
  "script_id": "01006009",
  "title": "连环套",
  "alias": [
    "拜山"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "窦尔敦",
      "hangdang": "净"
    },
    {
      "name": "黄天霸",
      "hangdang": "武生"
    },
    {
      "name": "报子",
      "hangdang": "丑"
    }
