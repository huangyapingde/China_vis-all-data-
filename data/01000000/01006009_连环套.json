  "plot": "河北盗魁窦二敦，善使虎头双钩，自仗武力，横行齐鲁间。先是窦尔敦与飞镖黄三泰，在李家店地方，因角\n技被挫，从此江湖间窦尔敦之威名大损，遂恼羞成怒，暗与黄三泰结不解仇，继往关外占踞连环套山寨，日\n夜图报复，后知梁千岁有钦赐千里驹一乘，遂故遣部下往盗之，且留书署明飞镖黄三泰，盖意欲藉此陷害黄\n三泰。初不知黄三泰已谢世也。时黄三泰子黄天霸，已得记名总兵之职，幸彭公知其为仇家诬陷，曲予成全，\n限期令黄天霸访拿，天霸探得为窦尔敦所盗，乃与朱光祖亲入虎口，侦缉证据，先生下山遇寇，既入连环\n套，投刺进谒，谈次，亦借献知宝马为言，以相餂取，窦尔敦果坠其计，尽将盗马始末根由和盘托出，黄天\n霸至此，复故作不信状，窦尔敦乃令部下牵马出，以证其实。黄天霸既探得御马之真凭据，及计陷其父黄三\n泰之真口供，乃始直告己名。窦尔敦闻语，赫然暴怒，立欲加害，黄天霸挺身受刀，容貌间绝无一毫惧怯，\n且知窦尔敦以好汉自命，必不出此不武手段，以真害己，故复侃侃争辩，卒至约期比武，终盗得御马而归。",
  "notes": "前见杨小楼演此，从进见彭公做起，做至下山，其精细慷慨应变传神处，洵是得未曾有，非徒以白口工架声\n调等见长已也，从前潘月樵亦颇称拿手，然叫嚣跳荡，纯乎一团粗暴之气，以视杨氏，曾不可同日语矣。按\n曲本，仅为探山一段，盖此剧本以探山为菁华也，故近时演唱此剧者，大都皆不演全本，而仅演此一场。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套引窦尔敦同上。"
        },
        {
          "character": "窦尔敦",
          "type": "西皮摇板",
          "text": "想当年李家店比武较量，"
        },
        {
          "character": "窦尔敦",
          "type": "西皮快板",
          "text": "豪杰我一怒撇家乡。 盗来了御马他就无处访， 要害三泰全家亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三头目同上。"
        },
        {
          "character": "三头目",
          "type": "同白",
          "text": "寨主，大头目下山被擒。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "哦，有这等事。来，一同下山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大头目上。"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "吓，寨主！"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "贤弟请坐，适才众位贤弟言道：你在山下被擒，因何得逃回来？"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "适才山下被擒，提起寨主威名，将俺放回，少时还要上山拜望。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "哦，想当年某家霸占河间府的时节，那些保镖达官，在窦某手中，逃脱性命不 少，今日闻听窦某在此为了寨主，上山拜望，也是他们保镖的规矩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "镖客有帖拜。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "呈上来。 “浙江绍兴府镖客黄。” 啊，他人有多大年纪？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "三十上下。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "吓，晚生下辈，叫他进来。"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "且慢，此人武艺超群，仁义过天，寨主赏他一个全脸。 中国京剧戏考 《连环套》【三本】 2"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "看在贤弟份上，赏他一个全脸。 喽罗的摆队相迎。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，摆队，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸上，二头目自下场门上。"
        },
        {
          "character": "二头目",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "俺乃你家寨主好友，上山拜望。"
        },
        {
          "character": "二头目",
          "type": "白",
          "text": "可有腰牌？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "二头目",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸、二头目同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "窦尔敦、三头目同上。黄天霸上。"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "吓，镖客，这就是寨主。 寨主，这就是镖客。"
        },
        {
          "character": "窦尔敦、黄天霸",
          "type": "同白",
          "text": "吓，（镖客）（寨主）。"
        },
        {
          "character": "窦尔敦、黄天霸",
          "type": "同笑",
          "text": "啊哈哈。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客到此，请来进山。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "不敢，寨主请。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "如此你我挽手而进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "窦尔敦、黄天霸、四头目同上。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "不知镖客到此，未曾远迎，当面恕罪。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "岂敢，少来拜山，寨主恕罪。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "岂敢，适才山下，多蒙镖客，不伤俺寨中之人，当面谢过。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "岂敢，适才山下，多蒙众位英雄，相让小弟，我这里当面谢过。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "嗳。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "适才众位贤弟言道，镖客武艺超群，何不就在山寨，共图大事。镖客断无推辞。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "待愚下将镖车护送关口，交代客商回来，还望众位英雄，携带小弟。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "想你我绿林之中，义气当先，说什么“携带”二字，镖客太谦了。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "多谢寨主。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客此番到此，还是路过荒山，还是特到草寨。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "特到宝寨。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "到此必有所为。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "愚下一来拜山，一来有一桩好买卖，献与寨主。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "什么好买卖。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "乃是一宗宝贝。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "什么奇宝。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "乃是一匹好马。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "这好马。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "嗳，我连环套甚多，算不了什么好宝贝。 中国京剧戏考 《连环套》【三本】 3"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "此马与众不同。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "何不说来大家一听。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "寨主要问，可将台坐升上一步，愚下亦好面禀。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "喽罗的打坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸打坐。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客请讲。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "寨主、众位英雄听禀。愚下保镖，路过马良关，观见一骑好马，此马生来头上 有角，肋下生鳞，左右红光两朵，名为日月骕骦。金鞍玉缛，黄罗丝缰，赤金 坠鐙，对对成双，登山越岭，如走平地，漫江过海，四蹄如飞，日行千里见日， 夜走八百不明，你我绿林，若有能人，将此马盗来，可算得骑虎夺脆，鳌里 夺尊，天下第一条英雄好汉！"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "好马吓，好马吓！"
        },
        {
          "character": "黄天霸",
          "type": "西皮摇板",
          "text": "豪杰路过马良关，"
        },
        {
          "character": "黄天霸",
          "type": "西皮快板",
          "text": "观见此马心喜欢。 空有大胆的英雄汉， 不能到手也枉然。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "好马吓，好马吓。"
        },
        {
          "character": "窦尔敦",
          "type": "西皮快板",
          "text": "忽听镖客讲一番， 此马可算兽中元。 若论大胆的英雄汉， 窦某可算胆包天。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客，此马出在什么地面？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "马良关外。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "什么人家？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "大户人家。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "待俺窦某下山盗马。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "且慢，此马的主人，日间有三百名家丁，夜晚有五百校手，不分昼夜，轮流看 守此马，寨主此去，岂能得盗。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客此番上山，还是真心与俺窦某结交，还是假意？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "自然真心。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "既是真心，俺窦某实对你说了罢。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "寨主请讲。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "今有太尉梁千岁，奉旨口外兴围，圣上恩赐御马，名为日月追风千里驹。俺窦 某施展本领，将御马盗回。何况那大户人家，日间有三百名家丁，夜晚有五百 校手，哪放在窦某心上！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "寨主，愚下讲的句句实言，寨主为何非言浮造？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "怎见得非言浮造？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "既是梁千岁奉旨口外兴围，必然是兵多将勇，如同铜墙铁壁一般，寨主慢说盗 马，连马面也是不能得见。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "谅你也是不信。 大贤弟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大头目允。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "去到槽头将御马牵来。"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大头目下。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "吓，寨主，你言道御马有何为证？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "此马金鞍玉辔，黄罗丝缰，赤金坠鐙，对对成双，平等人家，焉能敢用？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大头目牵马上。"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "御马在此。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客请来观马。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦，呵呀，果然是金鞍玉辔，黄罗丝缰，赤金坠镫，对对成双。见马如见主， 愿太尉梁千岁千千岁！ 中国京剧戏考 《连环套》【三本】 4"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "原来是个乡下人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "吓，寨主，此马受了些清福，足下未必能行。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "某家盗马时节，骑了一途，到有千里路程。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦，有千里的路程？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "千里路程。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "快的紧？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "快的紧。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "待愚下乘骑。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "带下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大头目带马下，上。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客请坐。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦，寨主请。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "镖客可曾观见此马？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "寨主你将此马盗来，是大大的废物了。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "怎见得是废物了？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "那梁千岁，失落御马，必差各府州县画影图形，找寻御马的下落，寨主不能出 外乘骑，岂不是大大的废物了！"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "我盗了此马，原不为乘骑。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "不为乘骑，盗他何用？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "只因绿林有一人，他是每每与某作对，我盗了此马，要报前仇。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "寨主，仇人是哪个？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "不是镖客提起，俺窦某到忘怀了，适才你那拜帖上面，俺那仇人，与镖客同乡。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦，与愚下同乡？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "而且还同姓。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦，还同姓？倒巧得很。他叫什么名字？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "就是那浙江绍兴府飞镖黄三泰。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哦，就是那三泰爷。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "就是那老匹夫。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "吓，寨主，你这仇报不成了。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "怎么报不成了？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "那三泰爷他归天去了。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "那老儿他死了么？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "归天去了。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "哎，还有他的满门大小！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "吓，寨主，有道是人死不记仇。何不学个宽宏大量。将御马献出，救了他全家 的性命，就是那三泰爷死在九泉，也感你的大恩大德。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "啊，听你之言，你与三泰有亲。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "有亲。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "有故。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "有故。非但有亲有故，我二人同盆净脸，同桌用饭，抵足而眠。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "三泰是你什么人？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "乃是俺家父。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "你呢。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "他子天霸。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "哇，呀呀！天霸，你好大的胆吓。天霸，我与你父结下山海冤仇，这“报仇” 二字，应在尔的头上。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "窦寨主，你与我父怎样结下冤仇？你若说得情通理顺，还则罢了；你若说得情 推理亏，窦寨主，你算不得英雄好汉。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "天霸听了。想当初你父命计全，与俺指镖借银，在黄土冈，被某家将他羞辱一 场。他在你父跟前。搬动是非，我二人在李家店比武争论。他不胜某虎头双钩， 他就暗发了甩头一子。也是某一时大意，未曾提防，被他扳倒尘埃，众家英 雄，纷纷言讲。道俺姓窦的，正在青春，不胜那五旬以外的老儿。那时某家弃 中国京剧戏考 《连环套》【三本】 5 脱了河间，求在这连环套。话也讲完，谅尔难逃公道。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "原来为此。请问寨主。想我父当初指镖借银，为着何来？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "只为搭救三河县彭朋。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "彭朋为官如何？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "为官清正。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "既然为官清正，为何罢职丢官？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "被武文华所害。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "后来呢？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "反升河间知府。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "那武文华？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "三河正法。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "如今彭朋何在？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "当今一品，位列三台。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "是忠是奸？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "大大的忠臣。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "忠臣？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "忠臣。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "着着。想我父当初指镖借银，亦非是为己，只为搭救忠良，想你我为绿林者， 敬的是忠臣孝子义仆节妇，恨的是赃官污吏恶棍土豪。你就该拔刀相助，你反 助强为恶，窦寨主，你就算不得英雄好汉。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "住了，这连环套，岂是由你弄嘴卖舌之地！ 众位贤弟，将他拿下了！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "住了！俺天霸今日上得山来，寸铁未带，你们依仗连环套的人多，是你们来来 来，将俺天霸碎尸万段，若是皱一皱眉头，算不得黄门后代！"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "擒尔何用人多，待窦某独自擒你。"
        },
        {
          "character": "大头目",
          "type": "白",
          "text": "且慢，他今来此，山下必有余党，明日下山比武，一对一个，方算英雄好汉。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "好吓。 天霸，明日山下比武。一对一个，方算英雄好汉。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "俺若不胜，情愿替父顶罪，万死不辞。寨主你呢？"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "俺若不胜，情愿将御马献出，随你们到官认罪。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "大丈夫一言。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "岂能反悔。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "窦尔敦",
          "type": "白",
          "text": "且慢，我接你上山，必须送你出寨。 喽罗的，摆队送天霸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。"
        }
      ]
    },
