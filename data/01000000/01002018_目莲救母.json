{
  "script_id": "01002018",
  "title": "目莲救母",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘清提",
      "hangdang": "老旦"
    },
    {
      "name": "目莲",
      "hangdang": "小生"
    },
    {
      "name": "大鬼",
      "hangdang": "净"
    }
  ],
  "plot": "目莲一门，素行善。目莲之母常颂经，戒杀放生。久之，目莲之兄，为佛度去。其父出门追寻，亦为佛度去。\n一日，目莲自学塾归，途中又为地藏佛度去。其母参禅未透，不知彼等已成正果，反以为彼苍梦梦，我佛\n昏昏，善恶不分，竟令我家破人亡。遂大开杀戒，停止善举，经卷佛像，毁之一空。死后，冥王怒其修正不\n果，造孽过多，令鬼卒押在丰都城，逼观刀山剑树、油锅血池、刳腹抽肠、剥皮割舌，以及煎熬磨碓种种冥\n刑；并谓冤冤相报，冥中执法如山，毫无情面，不若阳世之可以营私舞弊者也。目莲之母，属目之余，心寒\n胆裂，悔之无及。游至滑油山，适目莲寻母而至，母子相见大哭。目莲弘施佛力，救母出地狱而去。",
  "notes": "事虽近于迷信，而神道设教，未始不可挽救人心，惩劝末俗也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "大鬼",
          "type": "内白",
          "text": "哽嚇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒、大鬼同上。"
        },
        {
          "character": "大鬼",
          "type": "数板",
          "text": "阎君命我作鬼头，作鬼头，十鬼见了九鬼愁。行善的金桥走，作恶的打不休来 骂不休，哪怕小鬼作对头！"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "我乃大鬼是也。阎君朝拜佛祖去了，命我看守丰都城。不免在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "目莲上。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "阿弥陀佛！"
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "在仙山奉了师父命， 来到阴曹探望娘亲。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "小生目莲僧。奉了师父之命，来到阴曹探望娘亲，就此走走。"
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "西方路上一只鹅， 口含仙草念弥陀。 连毛倒有修行意， 人不修来待如何？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "来此已是丰都城，待我念起咒语：唵嘛呢叭咪吽……"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "啊！哪里这样惊天动地？待我看来。 原来是小师傅，姓甚名谁？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "小生目莲僧。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "到此何事？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "长官听了："
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "在仙山奉了师父命， 来到阴曹探望娘亲。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "你母亲姓甚名谁？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "听了："
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "我的母并非是别的名姓， 刘氏清提就是我娘亲。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "待我与你问来。 众鬼卒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同允。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "里面可有个刘氏清提？她子目莲僧，看望于她。有者即来打话。"
        },
        {
          "character": "刘清提",
          "type": "内白",
          "text": "有！"
        },
        {
          "character": "刘清提",
          "type": "内二黄原板",
          "text": "听一言不由我心内着惊， 耳边厢有孩儿寻找娘亲。 刘清提原本是老身的名姓， 我的儿叫罗卜，不叫莲僧。 望长官你与我盘查细问， 我母子见一面感你的大恩。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "小师父，里面有一个刘氏清提，她子不叫目莲僧。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "叫什么？"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "叫什么糖萝菔醋萝菔。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "敢是傅罗卜？"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "不错，傅罗卜。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "请上城楼，我母子相见。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "阎君知道，那还了得！"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "行个方便吧！"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "使不得！"
        },
        {
          "character": "目莲",
          "type": "念",
          "text": "唵嘛呢叭咪吽……"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "哑唷哑唷……不要如此！ 众鬼卒，将刘氏清提，押上都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘清提上，上台子。"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "一见母亲泪眼认， 怎不叫人痛在心。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "长官，将我母亲焰火去了。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "众鬼卒，将刘氏清提，焰火去了。"
        },
        {
          "character": "刘清提",
          "type": "二黄导板",
          "text": "刘清提站都城一言难尽，"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "罗卜我儿，儿呀！"
        },
        {
          "character": "刘清提",
          "type": "二黄垛板",
          "text": "叫一声我的儿细听详情："
        },
        {
          "character": "刘清提",
          "type": "二黄原板",
          "text": "儿本是阳世人相隔幽冥， 今来到阴曹府把娘找寻。 苦愁眉叫为娘心痛难忍， 观不见儿容貌只听声音。 想当初在阳间一家欢幸， 儿每日在佛堂苦读经文。 娘只说吃长斋何等侥幸， 惊动了那铁树神开花见针。 娘不该在佛堂咒骂神圣， 娘不该用荤油添了佛灯； 娘不该将白骨花园攘定， 娘不该打僧骂道，骂道打僧，不听菩言，开了五荤，身受这灾星。 我的儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "缓锣鼓。"
        },
        {
          "character": "刘清提",
          "type": "二黄原板",
          "text": "儿的父修正道西天成圣， 哪知道为娘我受此苦情。 娘只说阴曹府无有报应， 有谁知为娘我到今日，蓬头盖脸，项带铁链，口内吞火，眼中点灯，何日里逃 生？ 我的儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "缓锣鼓。"
        },
        {
          "character": "刘清提",
          "type": "二黄原板",
          "text": "求佛尊将为娘罪过改定， 放为娘出都城是瞑目甘心。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "儿吓，今当四月初八日，阎君赴龙华大会去了，你可哀告长官，将为娘放出都 城，我母子也好相见。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "长官，将我母亲放出都城。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "阎君知道，那还了得！使不得！"
        },
        {
          "character": "目莲",
          "type": "念",
          "text": "唵嘛呢叭咪吽……"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "哑唷哑唷……不要如此！ 众鬼卒，将刘氏清提，押出都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘清提出城。"
        },
        {
          "character": "刘清提",
          "type": "三叫头",
          "text": "罗卜！我儿！儿吓！"
        },
        {
          "character": "刘清提",
          "type": "二黄摇板",
          "text": "娘只说阴曹府无报应， 天网恢恢有神灵。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "儿吓，为娘披枷带锁，如何是好？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "有佛法。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "快快念来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "对准西方身拜定， 快将枷锁离娘身。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "为娘双目不明，如何是好？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "有佛法。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "快快用来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "对准西方身拜定， 取来了甘露水付与娘亲。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "刘清提",
          "type": "二黄摇板",
          "text": "娘只说母子不能见， 谁知相逢地狱门。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "儿吓，为娘肚中饥饿，如何是好？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "还有佛法。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "快快用来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "对准西方身拜定， 取来了干饭付与娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼同上。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "儿吓，这些冤鬼，超度他们。"
        },
        {
          "character": "目莲",
          "type": "念",
          "text": "唵嘛呢叭咪吽……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼同下。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "儿吓，这饭多被饿鬼抢了去了。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "还有佛法。"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "快快用来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "二次又把身拜定， 再取干饭付与娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小鬼上。"
        },
        {
          "character": "小鬼",
          "type": "白",
          "text": "报：阎君回殿来了！"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小鬼下。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "你母子快快分别了罢！"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "呵吓！"
        },
        {
          "character": "刘清提",
          "type": "二黄摇板",
          "text": "母子见面才欢欣， 霎时就要两离分。 母子们只哭得珠泪滚，"
        },
        {
          "character": "刘清提",
          "type": "白",
          "text": "儿吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘清提、目莲同下。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "呵吓且住！这些冤鬼，俱已逃生去了，阎君回来，如何是好？也罢，待我也逃 生去罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大鬼下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}