{
  "script_id": "01001006",
  "title": "捉放曹",
  "alias": [
    "中牟县；一名：陈宫计"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "陈宫",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "吕伯奢",
      "hangdang": "末"
    },
    {
      "name": "班头甲",
      "hangdang": "丑"
    },
    {
      "name": "班头乙",
      "hangdang": "丑"
    },
    {
      "name": "店家",
      "hangdang": "丑"
    }
  ],
  "plot": "汉末，曹操刺杀董卓未遂，改装逃走，至中牟县被擒。公堂上，曹操用言语打动县令陈宫，使陈宫弃官一同\n逃走。行至成皋，遇曹操父亲之故友吕伯奢，盛邀曹操、陈宫至庄中款待。曹操闻得磨刀霍霍，误认为吕伯\n奢存心加害，便杀死吕伯奢全家，焚庄逃走。陈宫见曹操如此心毒手狠，枉杀无辜，十分懊悔，宿店时，趁\n曹操熟睡后，题诗与曹操，独自离去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、门子引陈宫同上。"
        },
        {
          "character": "陈宫",
          "type": "引子",
          "text": "身受皇恩，与黎民，判断冤情。"
        },
        {
          "character": "陈宫",
          "type": "念",
          "text": "头戴乌纱奉孝先，思想开国万民欢。家严有语呼兄弟，得配汪洋水底天。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "本县姓陈名宫，字公台。幼年科甲出身。蒙主恩，特授中牟县正印。前日接到 董太师钧旨，上面写道：曹操相府行刺不成，畏罪脱逃，因此命各州县，画影 图形，捉拿刺客曹操。我也曾差王申等四门巡查，未见交签。今日升堂理事。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "班头甲上。"
        },
        {
          "character": "班头甲",
          "type": "念",
          "text": "捉拿曹操事，报与太爷知。"
        },
        {
          "character": "班头甲",
          "type": "白",
          "text": "太爷在上，小人叩头。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "班头甲",
          "type": "白",
          "text": "恭喜太爷，贺喜太爷！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "班头甲",
          "type": "白",
          "text": "曹操被小人们拿获了。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "班头甲",
          "type": "白",
          "text": "有宝剑为证。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": "班头甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫看宝剑。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "自要尔等拿得不差，解进京去，俱有千金重赏。"
        },
        {
          "character": "班头甲",
          "type": "白",
          "text": "小人们不愿领赏，愿太爷禄依高升。"
        },
        {
          "character": "陈宫",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "官升禄赏，分所当然。吩咐将刺客曹操押上堂来。"
        },
        {
          "character": "班头甲",
          "type": "白",
          "text": "伙计们，将曹操押上堂来。"
        },
        {
          "character": "班头乙",
          "type": "内白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "班头乙上。曹操上。"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "跳龙潭出虎穴逃灾避祸， 又谁知中牟县又入网罗。 怒冲冲站立在滴水檐过， 看陈宫他把我怎样发落。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "曹孟德进衙来齐声威喝， 书吏们站两旁虎占山坡。 观刺客面貌上带定凶恶， 见本县不下跪确是为何？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "下站可是曹操？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "既知我名，何必动问？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "见了本县，为何不跪？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我这双金膝，上跪天子，下跪父母，岂肯跪你这小小县令？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "岂不知王子犯法，与民同罪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我身犯何法？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "你行刺董太师，还言无罪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我行刺董太师，可是你亲眼得见？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "也非亲眼得见，现有董太师钧旨，捉拿与你，还敢强辩不成？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "听他言唬得我心似刀割， 心问口口问心自己揣摩。 说几句巧言语将他哄过， 管叫他弃县令随我逃脱。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公台，你可知朝中谁忠谁奸？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "我在廉外为官，怎知朝内之事？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "却又来，"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "你本是外省官怎知朝歌， 哪知道董卓贼奸雄作恶？ 刺杀了丁建阳文武胆破， 满朝中文共武木雕泥塑。 到如今收吕布做事太错， 一心要谋取那汉室山河。 我看你做的事广有才学， 细思量董太师奸恶如何？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "陈宫",
          "type": "西皮二六板",
          "text": "曹孟德你不必谤毁董卓， 董太师他倒有治国韬略。 灭黄巾虽无功却也无过， 十常侍乱宫帷扫荡妖魔。 又收下吕奉先威镇海角， 传将令好一似高山水过。 我将你解进京献与董卓， 千金赏万户侯加官受爵。 你好比扑灯蛾自来投火， 你好比抢食鱼自投网罗。 你好比出山虎把路走错， 既擒虎怎能够纵虎归窝？ 擒住你反放你必定伤我， 捉虎难放虎易自己揣摩！"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "你将我解进京献与董卓， 那时节见太师自有话说： 刺董卓是陈宫修书与我， 管叫你遍体排牙难以分说！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "陈宫",
          "type": "西皮快板",
          "text": "听他言吓得我双眉皱锁， 这件事好叫我无可奈何。 若放他只恐怕罪归于我， 若不放又恐怕惹出风波。 思一思想一想无计安妥， 我就是放也说个言投意合。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "陈公台说此话真个软弱， 小县令怎能够名标烟阁？ 依我劝弃县令随定与我， 约诸侯带人马杀进朝歌。 到那时灭残臣除奸剿恶， 管叫你换朝衣封官受爵！ 陈公台又道你颇有王佐， 细思量想一想心下如何？"
        },
        {
          "character": "陈宫",
          "type": "西皮快板",
          "text": "曹孟德出此言如梦出觉， 七品官岂不负经纶才学。 倒不如弃县令从他入伙， 奔天涯约诸侯重整朝歌。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "下位来与明公亲解扭锁，"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "哦……"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "书役们且退避也有发落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同下。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "手挽手与明公二堂内坐， 驾光临少奉迎望乞恕罪。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公到此，书役们得罪，望为宽恕。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "岂敢，多蒙释放，日后必当重报！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "久闻明公献剑为名，刺杀董卓。天意不随，今欲何往？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我有意奔走天涯，颁来五路诸侯，灭却董卓。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "下官有意随明公，奔走天涯，不知意下如何？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "若得公台同去便好，只是连累宝眷不便。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "不妨，老母妻子，俱在原郡；仆人使女，不在衙署。料无妨碍。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "既然如此，事不宜迟，你我连夜出城，以免百姓耳目。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "请至书房待茶，待下官料理公案，即便同行。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "暂且别。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "少刻奉陪。 来，"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "将印信付与右堂代管。说老爷领了上司公文，下乡查旱，多则一月，少则十日 就回。你附耳上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子上前，陈宫暗语。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "备马伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫、门子同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吕伯奢上。"
        },
        {
          "character": "吕伯奢",
          "type": "念",
          "text": "夜梦不详，叫人难防。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "老汉吕伯奢，乃陈留人氏。承父兄之业，颇有家财，一生广交好友。昨晚三更， 偶得一梦，也不知主何吉凶。朝晨已过，午膳将近，并无应验，我不免庄前 庄后，闲游散步一回。"
        },
        {
          "character": "吕伯奢",
          "type": "西皮慢板",
          "text": "昨晚一梦大不详， 只见猛虎赶群羊。 绵羊遇虎无逃处， 大小俱被虎来伤。 清晨起来鸦鹊噪， 吉凶二字人难防。"
        },
        {
          "character": "曹操",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、陈宫同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "八月中秋桂花香，"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "行人路上马蹄忙。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "坐立雕鞍用目望，"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "见一老丈在路旁。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "吓，那边来的敢是曹操？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓，俺不是曹操，你不要错认了。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "吓，贤侄，不要害怕，老夫吕伯奢，你父与我有八拜之交，难道就不认得了么？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哦，原来是吕伯父来了，一同下马。侄儿不知，多多有罪。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "岂敢，不知者不怪。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公，你我赶路要紧！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "是吓，伯父，本当到府，拜见伯母，奈有要事不便，侄儿告辞了。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "且慢，贤侄说哪里话来，你乃朝廷贵客，你父与我八拜之交。天色已晚，岂有 过门不入之理？请到寒舍一叙，老汉与你带马。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这就不敢。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "前面带路了。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公，去得的么？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此乃我父好友，去得的。"
        },
        {
          "character": "吕伯奢",
          "type": "西皮流水板",
          "text": "怪不得昨晚灯花放， 今日喜鹊叫门前。 只说大祸从天降， 贵客临门到我庄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿上。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "迎接家爷。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "将马带到后槽，多加草料。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "马不要下鞍！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿允，下。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "请进。"
        },
        {
          "character": "曹操、陈宫",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "此位是谁？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这就是中牟县太爷，姓陈名宫，字公台。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "哎吓，原来是我父母太爷，小老不知，多有得罪。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "岂敢，误造宝庄，望乞海涵。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "曹操、陈宫",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "贤侄为何这等狼狈？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "一言难尽。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "董卓专权乱朝纲， 欺君藐法似虎狼。 行刺不成身险丧， 因此逃出是非场。 不是公台来释放， 侄儿已作瓦上霜。"
        },
        {
          "character": "吕伯奢",
          "type": "西皮快板",
          "text": "伯奢闻言双合掌， 宽宏大量非寻常。 焚香答拜不为上， 粉身答报也应当。 老汉撩衣跪草堂， 多蒙太爷施恩光。 孟德不是你释放， 险些作了瓦上霜。"
