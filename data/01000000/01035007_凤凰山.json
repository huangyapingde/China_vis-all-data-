{
  "script_id": "01035007",
  "title": "凤凰山",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "马三保",
      "hangdang": "老生"
    },
    {
      "name": "盖贤谟",
      "hangdang": "净"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "徐勣",
      "hangdang": "老生"
    }
  ],
  "plot": "番将盖贤谟，统领十万雄兵，镇守凤凰山。唐太宗御驾亲征，行抵凤凰山。唐太宗欲出观山景，徐勣、尉迟\n元帅力阻不得。徐勣乃请先命一将，前去探山，打听虚实，然后再保驾往游。唐太宗准奏，问何人愿往探山。\n定国公马三保告奋愿往，徐勣、尉迟恭等力劝马三保勿往。马三保弗听。及往，适遇盖贤谟，被其用绊马\n索绊倒擒住。马三保誓死不降，讵知被盖贤谟刖去四肢，抛弃山中。尉迟恭出巡，见状大悲伤，欲抬归。马\n三保不可，卒以疼痛难忍，嘱尉迟恭举枪刺心，乃卒。",
  "notes": "按《凤凰山》之戏名不一。百花公主斩巴喇，也名《凤凰山》；《征东传》中薛仁贵救驾，也名《凤凰山》，\n已载本考二十册中。此剧亦名《凤凰山》，专演定国公马三保。（《说唐传》中作平）国公出兵探路，途\n遇番将盖贤谟，中计被擒，誓死不屈，惨遭毒剁之状。剧中情节，全根据《说唐征东传》中。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套、四辽兵、四平章、盖贤谟同上。〖点绛唇〗。盖贤谟上高台。"
        },
        {
          "character": "盖贤谟",
          "type": "念",
          "text": "两膀膂力似金刚，六国三川称豪强。一心要摘天边月，步星踏斗换太阳。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "某，盖贤谟。可恨唐童，来此辽东，抢关夺寨。我奉狼主之命，统领十万大兵， 镇守凤凰山，以防对敌。 巴嘟噜！"
        },
        {
          "character": "四龙套、四辽兵、四平章",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二大太监、唐王同上。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "统领人马征辽东， 要把番奴一扫平。 闷坐龙帐心烦闷， 宣上二卿问分明。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "内侍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监甲应。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "替孤传旨，宣徐勣、尉迟恭进帐。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨！ 万岁有旨：宣徐勣、尉迟恭进。"
        },
        {
          "character": "徐勣、尉迟恭",
          "type": "内同白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、尉迟恭同上。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "昨夜晚闲观天象，"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "水墨鞭保定唐王。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "山人徐勣。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老夫尉迟。"
        },
        {
          "character": "徐勣、尉迟恭",
          "type": "同白",
          "text": "万岁有旨宣诏，你我一同进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、尉迟恭同进。"
        },
        {
          "character": "徐勣、尉迟恭",
          "type": "同白",
          "text": "臣（徐勣）（尉迟恭）见驾。吾皇万岁！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "二卿平身。"
        },
        {
          "character": "徐勣、尉迟恭",
          "type": "同白",
          "text": "万万岁！宣臣等进帐，有何国事议论？"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "孤王此番，亲自出兵。今日得了三江口。闻听人言：此处有一凤凰山，美景甚 好，有心前去游逛一番，以解愁闷。军师，你看如何？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "臣启万岁：想那凤凰山，乃是辽东要路，我主既然要去，必须命人前去探路， 然后那位将军，保驾前去。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "军师言得及是。替孤传旨：若有能人，情愿前去探路，前来领旨。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "领旨！ 下面听旨：万岁有旨，我主今意游逛凤凰山。哪位将军，情愿前去探路，然后 保驾前去。"
        },
        {
          "character": "马三保",
          "type": "内白",
          "text": "且慢！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "何人答话？"
        },
        {
          "character": "马三保",
          "type": "内白",
          "text": "定国公马三保！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "哦呵吓！我情知是这老儿前来了。山人昨晚仰观天象，见一将星堕落东海，只 怕马三保此去，性命难保。有道是天机不可泄漏，少时进帐，慢慢相劝便了。 万岁有旨：马三保进帐。"
        },
        {
          "character": "马三保",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保上。"
        },
        {
          "character": "马三保",
          "type": "念",
          "text": "白发花花似银条，胸中韬略志谋高。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "臣，马三保见驾，吾皇万岁。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "马皇兄进帐何事？"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "臣听万岁有意游逛凤凰山，为臣不才，情愿前去探路。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "吓老将军，想那凤凰山，乃是辽东紧要之地，必有能将把守。老将军年迈，此 去倘若有失，如何是好？"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "先生，你此言差矣！你道凤凰山十分坚固，能将把守。老夫此去，若无贼兵便 罢，若有贼兵阻挡，老夫单枪匹马，杀他一个片甲不归。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "老将军，我闻辽东盖贤谟，有万夫不挡之勇，手下雄兵百万，战将千员。老将 军乃是先王托孤老臣，此去倘有不测，山人我吃罪不起！"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "军师！想俺马三保，当年三镇晋阳宫，保定老王，重振江山社稷。我也曾南征 北战，东挡西杀，才挣下国公之位。此去探路，若有不测，尽忠一死，理所当 然。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老将军乃年迈老臣，此番前去，岂是那反贼的对手。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "元帅，有道是虎老雄心在，年迈力刚强！"
        },
        {
          "character": "马三保",
          "type": "西皮二六板",
          "text": "军师不要把话表， 末将言来细听根苗： 三镇晋阳谁不晓， 保定先王坐龙朝。 圣上也曾探山道， 南征北战立功劳。 保主征东忠义好， 舍死忘生在今朝。 何必命人探山道， 老夫独自走一遭。 吃王爵禄当报效， 哪把番奴挂心梢。"
        },
        {
          "character": "尉迟恭",
          "type": "西皮摇板",
          "text": "老将军说话性情傲， 本帅言来听根苗： 此去山路实难找， 怕的老将把祸招。 听我相劝不去好， 本帅替你走一遭。"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "老将军说话真可笑， 说什么路远山又遥。 纵有贼兵如蒿草， 何惧番奴小儿曹。"
        },
        {
          "character": "徐勣",
          "type": "西皮摇板",
          "text": "老将军保主忠义好， 倒叫山人心内焦。 此去只防牢笼套，"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "徐勣",
          "type": "西皮摇板",
          "text": "不可中他计笼牢。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "皇兄虽然年纪老， 可算将中一英豪。 三千人马安排好， 命你探路走一遭。"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "多谢万岁恩义高， 披星戴月不辞劳。 辞别万岁跨班豹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套自两边分上，带马，同下。"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "斩杀贼人气方消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保下。"
        },
        {
          "character": "尉迟恭",
          "type": "西皮摇板",
          "text": "怕他身入笼牢套，"
        },
        {
          "character": "徐勣",
          "type": "西皮摇板",
          "text": "可叹一命赴阴曹。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "老将此去探山道， 且听探马报根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四辽兵、四平章、盖贤谟同上。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "列开旗门，探看凤凰山。"
        },
        {
          "character": "盖贤谟",
          "type": "念",
          "text": "山高万丈透九霄，山中自有凤凰朝。涧下清泉长流水，树木狼林壁岭高。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "真乃好风水也！ 巴嘟噜，安营扎寨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四辽兵、四平章同应，自两边分抄下。盖贤谟下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "马三保",
          "type": "内西皮导板",
          "text": "老夫马上哈哈笑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、马三保同上。"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "想起当年立功劳。 带领人马洛阳扫， 五龙二虎赴阴曹。 到如今他把心变了， 军师八卦也不高。 老夫马上传令号， 大小三军听根苗： 凤凰山上如蒿草， 哪把番奴挂心梢。 三军与爷催虎豹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保、八龙套同走圆场，八龙套同下。"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "好似天兵下九霄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四辽兵、四平章、盖贤谟同上。八龙套、马三保同上，会阵。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "呔！何方之将，快快通名受死！"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "番奴听了：老夫定国公马三保。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "马三保，想你主无道，听我相劝，归顺我邦，不失封侯之位。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "住了！老夫乃天朝大将，岂肯归顺你这番奴！"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "巴嘟噜杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保、盖贤谟同起打，盖贤谟败下。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四辽兵、四平章、盖贤谟同上。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "且住，这老儿十分骁勇。 巴嘟噜，绊马索伺候！"
        },
        {
          "character": "马三保",
          "type": "内白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保上，打，绊马跌。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "绑了回去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二大太监、尉迟恭、徐勣、唐王同上。"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "马皇兄一去无音信， 倒叫孤王挂在心。 但愿山道探访明， 眼跳心惊为何情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启奏万岁：今有定国公马三保被擒。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "二卿，马三保被擒，如何是好？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "待臣前去相救。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "卿家快快前去！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "领旨！ 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，领尉迟恭同下。"
        },
        {
          "character": "唐王",
          "type": "白",
          "text": "卿家吓！"
        },
        {
          "character": "唐王",
          "type": "西皮摇板",
          "text": "马三保为孤被贼擒， 怎不叫孤痛伤情。 但愿此去得了胜， 拿住番奴才称心。"
        },
        {
          "character": "徐勣",
          "type": "西皮摇板",
          "text": "贼人把守凤凰镇， 我主驾转越虎城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四辽兵、四平章、盖贤谟同上。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "来，将马三保押上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵押马三保同上。"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "盖世英雄遭圈套， 误中番贼计笼牢。 迈步且进宝帐道， 看你把爷怎开消！"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "马三保，适才两军阵前何等威风，今日被擒，为何不跪？"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "番奴番奴！老夫乃天朝大将，岂肯下跪于你！"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "你若归顺我邦，不失封侯之位。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "番奴番奴！老夫赤胆忠心，岂肯归降你番奴也！"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "老夫天朝一虎将， 只有训简不训刚。 情愿在那刀下丧， 岂肯低头把贼降！"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "你若执意不降，少时将你斩首，你家中还有妻儿老小，依靠何人？你再思再想。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "番奴，要杀开刀，何必多言！要老爷归降，除非日从西起。"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "住了！好言相劝，百般不听。 来吓，将他双手剁去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保剁手。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "马三保",
          "type": "西皮导板",
          "text": "双手剁去痛难忍，"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "咬定牙关骂贼人。 但愿我国大兵到， 杀尔狗头挂营门！"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "这老匹夫，还是叫骂。 来吓，将他双足剁去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保剁足。"
        },
        {
          "character": "马三保",
          "type": "西皮导板",
          "text": "霎时一阵痛难消，"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "心中犹如似火烧。 眼望番奴高声叫，"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "番奴番奴！"
        },
        {
          "character": "马三保",
          "type": "西皮摇板",
          "text": "纵然一死美名标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保死。"
        },
        {
          "character": "盖贤谟",
          "type": "三笑",
          "text": "哈哈，哈哈，哈哈！"
        },
        {
          "character": "盖贤谟",
          "type": "白",
          "text": "这老匹夫死在临头，还是叫骂。 来，将他拖在荒郊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套、尉迟恭同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、四辽兵、四平章、盖贤谟托马三保同上，四龙套、四辽兵、四平章、盖贤谟同下。四龙套、尉迟"
        },
        {
          "character": null,
          "type": "text",
          "text": "恭同上。）"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "尉迟恭",
          "type": "西皮摇板",
          "text": "一见老将痛难忍， 怎不叫人好伤心。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老将军醒来！"
        },
        {
          "character": "马三保",
          "type": "二黄导板",
          "text": "昏昏沉沉难扎挣，"
        },
        {
          "character": "马三保",
          "type": "二黄摇板",
          "text": "耳旁听得有人声。 咬定牙关来观看，"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "老元帅吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保哭。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "又见重伤老将军。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呀，老将军，我等怎样相劝与你，你执意不听。今身受这样重伤，好不痛杀某 也！"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "老元帅，是我不听军师之言，怒出大营。与贼人交战，身入重地，误中番奴奸 计。如今受此重大之伤，谅性命难保。今生今世，不能相报，来生来世，再相 见罢。吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马三保哭。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老将军不必悲伤，待我将你搭回营去，与万岁观看你我作武将的下场。你纵然 一死，万岁也要追封你的儿孙哪！"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "你看我这般光景，有何面目，去见那满朝文武。求元帅照看我那妻室孩儿。见 了万岁，说我保主江山社稷吓！"
        },
        {
          "character": "马三保",
          "type": "二黄摇板",
          "text": "有劳转奏把本提， 不能与主保社稷。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老将军，你的妻室孩儿，只管放心，有我供养。还是跟随本帅回营才是。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "老元帅，你看我这般光景，痛疼难忍，你若念同殿之谊，一枪将我刺死，我也 甘心瞑目呀！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "我与你同殿为臣，焉能下此毒手。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "老元帅，你看我死又死不了，活又活不成，你若一枪将我刺死，倒救了我了。 老元帅，你与我快些罢！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "听此言不由人心中不定， 尉迟恭我只得把心一横。 手使金枪忙刺定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭刺，想，下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}