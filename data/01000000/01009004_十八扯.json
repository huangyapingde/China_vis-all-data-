{
  "script_id": "01009004",
  "title": "十八扯",
  "alias": [
    "小磨房；一名：兄妹串戏"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "孔怀",
      "hangdang": "丑"
    },
    {
      "name": "孔秀英",
      "hangdang": "花旦"
    }
  ],
  "plot": "剧情从何摭取，初无所本，但知为孔怀哥，因其兄孔亨晋京求取功名，久无音耗，其母将媳妇（即亨妻，怀\n哥之嫂）施以种种酷待，虐令在磨房终日磨粉，日仅饲以糠麸粥糜二餐而已，时且自往督勤，稍拂其意，则\n即以鞭笞被其体。怀哥因是大不忍，拟偷闲入磨房代嫂分劳，俾嫂得少休力，适遇其妹，因与妹同入代磨。\n磨有顷，二人苦无聊，遂出其嬉皮滑脸之村童故态，相与串扮戏剧，变兄妹为夫妇，作种种丑态，以消遣而\n行乐，真无稽之极，直不知其命意之何在也。",
  "notes": "《十八扯》即昆曲中梆腔杂剧类中之《磨房》、《串戏》两折也。原系乱弹腔，后京班中也袭其大概情节，\n翻为京戏，其所串各戏，亦与昆派不同。从前尚京昆杂串，近十年来则昆戏渐渐删汰略尽，单串京戏，此亦\n随乐风时会之趋势而变迁也。惟昆派演此，有一定规模，不能以意增删改串它戏，京班中从前亦尚如此，年\n来则各伶工人自为谋，大都皆就己所长随意串演，以便卖弄其技能，藉以博得拿手擅长之名誉，故所串戏之\n多少，亦无一定，其大致几与《戏迷传》相仿佛矣。以李百岁、吕月樵等为最擅名，坤角恩晓峰亦善唱此剧。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "孔怀",
          "type": "内白",
          "text": "哽哼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀上。"
        },
        {
          "character": "孔怀",
          "type": "念",
          "text": "怪哉怪哉真怪哉，柳树上掉下烧饼来。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "小子孔怀，妹妹孔秀英。可恨我母亲其心不良，将我嫂嫂打在磨房挨磨，是我 心中不忍，不免去至磨房，替我嫂嫂挨上几磨，就此前往。"
        },
        {
          "character": "孔秀英",
          "type": "内白",
          "text": "哽哼。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "那不是妹子么？"
        },
        {
          "character": "孔秀英",
          "type": "内白",
          "text": "那不是哥哥么？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "妹子快来。"
        },
        {
          "character": "孔秀英",
          "type": "内白",
          "text": "哥哥等着，妹子来呢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英上。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "你干什么去？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "我抱柴火去。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我不让你过去。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "我打这边走。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我拦住你。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "我打那边去。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我挡住你。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "中间走。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我与你堵上。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "道路。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "不要闹着玩。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "你手里拿的什么？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "没什么。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我看手。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "你看。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "一个斗，两个斗，三个斗，四个斗，五个斗。看那只手。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "你看。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "六个斗，七个斗，八个斗，九个斗，十个斗。两手一齐看。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "你看见戏戏画没有？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "什么叫做戏戏画？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "一个喜鹊两个脑袋。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "在那里飞呢。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "咦，热得不走，走到坝沟里去了。你走两步我看看。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "哦，你看看。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "走过去，这是什么？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "幺二三。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "什么幺二三？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "鞭子。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "干什么用的？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "打嫂子的。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "你这个人没有良心，嫂子替你梳头裹脚，你还要打嫂子，不跟你玩呢。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "不打嫂子呢。把这个抛去。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "咱们找嫂子玩去。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "走。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "行行去去。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "去去行行。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "转弯抹角。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "抹角转弯。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "到呢。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "不要到，喂狗。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "不要闹。进去喊嫂子。"
        },
        {
          "character": "孔怀、孔秀英",
          "type": "同白",
          "text": "嫂子！嫂子！"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "嫂子不在家。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "猫叼去了？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "嫂子出去了。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哦，出去了。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "嫂子出去了。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我们干什么玩？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "我妈说的，姑娘不给小子玩。给小子玩了要烂手指头。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我妈说的，小子不给姑娘玩。给姑娘玩了要烂脚指头的。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "我们回去吧。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "慢着。我们兜圈子。到张园白相去。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "不好。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我们进城，湖心亭吃茶去。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "也不好。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我们唱戏玩吧。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "唱什么戏？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "唱《庞德下书》。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "谁的元帅，谁的先行？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我的元帅，你的先行。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "我的元帅，你的先行。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哎，哪有个母元帅。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "哎，女元帅。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "不错，女元帅。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "没有行头。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哎，戏房里行头多得很，随便你穿。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "那么哥哥等着，我妹子扮戏去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英下。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我妹子扮戏去呢。待我也扮起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀扮。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "打吓打吓，怎么不打。哦，没有吃大烟呢，待我自家来。哒呛。"
        },
        {
          "character": "孔怀",
          "type": "引子",
          "text": "小生小生，我的儿子，唱老生。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "孤王王世充，可恨曹操带兵前来，与孤争斗，不免修书一封，颁来孙二娘，大 破天门阵。"
        },
        {
          "character": "孔怀",
          "type": "西皮导板",
          "text": "在宝帐闷坏了秦叔宝，"
        },
        {
          "character": "孔怀",
          "type": "西皮慢板",
          "text": "小罗成渭水河乱箭身亡。 一步儿来至在宝帐以上， 手提着没毛笔细写端详： 上写拜上多拜上， 拜上梁山小宋江。 你那里早发兵和将，"
        },
        {
          "character": "孔怀",
          "type": "西皮快板",
          "text": "搭救孤王转汴梁。 一封书信忙修整， 打发庞德走一程。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "庞德进帐。"
        },
        {
          "character": "孔秀英",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英上。"
        },
        {
          "character": "孔秀英",
          "type": "stage",
          "text": "【《庞德下书》】"
        },
        {
          "character": "孔秀英",
          "type": "西皮快板",
          "text": "正在后帐把酒饮， 忽听前帐传一声。 迈步且把宝帐进， 元帅差我哪里行？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "元帅在上，庞德参见。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "庞德听令。这有令箭一枝，走到北京城，颁来小叫天大战刘鸿声。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀下。"
        },
        {
          "character": "孔秀英",
          "type": "stage",
          "text": "【《定军山》】"
        },
        {
          "character": "孔秀英",
          "type": "西皮二六板",
          "text": "黄罗宝帐领将令， 气坏老将黄汉升。 曾记得当年大战在长沙， 阵前得罪二将军。 俺中了他人的拖刀计， 俺的百步穿杨射他的盔缨。 弃暗投明归真主，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀扮龙套上。"
        },
        {
          "character": "孔秀英",
          "type": "西皮快板",
          "text": "食王的爵禄当报王的恩。 孝当竭力把忠尽， 再与师爷把话明： 一不用战鼓咚咚响， 二不用虎将随后跟； 只要黄忠一匹马， 匹马单刀取定军。 十日之内攻得胜， 军师大印输我身； 十日之内攻不胜， 愿将首级挂营门。 来来来带过了爷的马能行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀允，带马，下。"
        },
        {
          "character": "孔秀英",
          "type": "西皮摇板",
          "text": "要把那定军一扫平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英下。孔怀上。"
        },
        {
          "character": "孔秀英",
          "type": "stage",
          "text": "【《龙虎斗》】"
        },
        {
          "character": "孔怀",
          "type": "引子",
          "text": "龙争虎斗，这砂锅，何日打破？"
        },
        {
          "character": "孔怀",
          "type": "念",
          "text": "天上有日头，山上有石头。海里有浪头，嘴里有舌头。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "孤，乾德王赵。可恨欧阳藩，将孤诓下河东，围困七载，内无粮草，外无救兵， 也曾命黄信四路打探，未见回报。"
        },
        {
          "character": "孔秀英",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英上。"
        },
        {
          "character": "孔秀英",
          "type": "念",
          "text": "打探军情事，报与主公知。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "报，探子告进。主公在上，探子参见。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "探子打探哪路军情，一一奏来。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "听我奏你。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "慢动手。"
        },
        {
          "character": "孔秀英",
          "type": "数板",
          "text": "探子报，主公听，一时一刻发来兵：苏秦六国为元帅，姚期马武为先行，主公 不发人和马，看看杀到紫金城，看看杀到紫金城。"
        },
        {
          "character": "孔怀",
          "type": "数板",
          "text": "报得好，报得妙，赏你二张假钞票。白日去洗澡，夜里陪我来睡觉。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英下。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哎呀，且住。时才黄信报到，罗家山发来一哨人马，昨日鞭坠白龙，今日叫骂 御营。看将起来，孤王的江山不久了。"
        },
        {
          "character": "孔怀",
          "type": "二黄原板",
          "text": "探马儿止不住飞来报， 他报道罗家山兵发一标。 杏黄旗不住地空中飘绕， 吓坏了御营中大小英豪。 这一旁打罢朝王鼓，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀播鼓。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "鼓又不响了。它又响了。"
        },
        {
          "character": "孔怀",
          "type": "二黄原板",
          "text": "那一旁再撞景阳钟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀撞钟。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "钟也不响了。它又响了。 【《洪羊洞》】"
        },
        {
          "character": "孔怀",
          "type": "二黄原板",
          "text": "宗保儿搀为父病房来进， 休惊动后堂内年迈太君。 【《斩李广》】"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "金牌宣，银牌诏，宣李广上殿。"
        },
        {
          "character": "孔秀英",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英上。"
        },
        {
          "character": "孔秀英",
          "type": "西皮慢板",
          "text": "乌鸦不住叫连天， 叫得李广心胆惊。 莫不是哪国贼犯境， 莫不是哪国起狼烟。 是是是明白了， 莫不是我三弟酒席筵前打骂来。 是与不是金殿上， 参王驾来问王安。 【《上天台》】"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "臣姚期见驾，吾皇万岁。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "姚皇兄，你可知罪？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "臣知罪。不知罪犯哪条？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "姚刚将郭太师打死，何言无罪？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "启陛下：郭老太师也有一行大罪。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "他得何罪？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "府门外私立三尺禁地，文官下轿，武将离鞍，但不知万岁可曾传旨。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "寡人有言在先，未曾降旨。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "万岁无旨，斩者无亏。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "好一个斩者无亏。 绑坏了！ 殿角下绑的何人？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "三子姚刚。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哦呀，不要绑坏孤的小爱卿。 内侍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀允。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "快快松绑。 领旨。 谢万岁不斩之恩。 非是寡人不斩于你，孤王有言在先，汉不斩姚，姚不反汉，将你发在湖北宛子 城，你父子午门一别，下殿去罢。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "孔怀",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "奴才。"
        },
        {
          "character": "孔秀英",
          "type": "二黄摇板",
          "text": "万岁爷赦了姚霸林， 好似枯木又逢春。 手拉娇儿下龙庭， 再叫我儿听分明： 此去湖北万事忍， 儿不要提刀乱杀人。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "儿来看！"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "看什么？"
        },
        {
          "character": "孔秀英",
          "type": "二黄摇板",
          "text": "为父的年迈苍苍白如银，姚刚我的儿吓， 好一似瓦上霜风前烛能活几春。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "孔怀",
          "type": "二黄摇板",
          "text": "爹爹不必泪悲惨， 姚刚珠泪洒胸膛。 在朝为官有什么好？ 半点不到有损伤。 上前辞别了生身父， 回府去拜上老萱堂。"
        },
        {
          "character": "孔怀",
          "type": "三叫头",
          "text": "爹爹，我父！哎，爹爹吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀下。"
        },
        {
          "character": "孔秀英",
          "type": "三叫头",
          "text": "姚刚，霸林！哎，儿吓！"
        },
        {
          "character": "孔秀英",
          "type": "二黄摇板",
          "text": "金殿去了姚霸林， 父子们相逢再不能。 转过金阶梧桐树， 告职还乡乐安宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英下。孔怀上。"
        },
        {
          "character": "孔秀英",
          "type": "stage",
          "text": "【《挡谅》】"
        },
        {
          "character": "孔怀",
          "type": "西皮摇板",
          "text": "得胜猫儿强似虎， 败阵凤凰不如鸡。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "大元帅。 有。 看看什么旗号。 遵命。"
        },
        {
          "character": "孔怀",
          "type": "西皮摇板",
          "text": "陈元吉打马到土台， 只见儿郎闹该该。 杏黄旗上写大字， 无敌将军康茂才。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "乃是康字旗号。 待我谢天谢地。 事到如今，还谢什么天地？ 大元帅，想那康茂才与孤有八拜之交，上前哀告，放你我君臣逃去，也未可知。 臣杀不得了。 不用你杀了，后面歇息去罢。"
        },
        {
          "character": "孔怀",
          "type": "西皮摇板",
          "text": "听说来了康茂才， 不由孤王笑颜开。 走上前来把礼拜， 问声贤弟可安泰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英上。"
        },
        {
          "character": "孔秀英",
          "type": "西皮快板",
          "text": "军师爷将令把咱催， 站立在土台抖雄威。 刘基不识英雄辈， 他道豪杰少计策。 打赌曾把牙咬碎， 气得某家两眼黑。 想起前朝兵对垒， 好汉英雄出在三国。 关公曾挡华容道， 要拿奸贼曹孟德。 战鼓儿不住咙咚咙咚响， 救命的铜锣点连点连紧紧催。 前面走的陈友谅， 后面跟随一伙贼。 半像人，半像鬼， 个个脸上带土灰。 好似佛爷离了位， 罗汉缺少袈裟披。 损兵折将悔不悔， 事到头来埋怨谁？ 康茂才便把良心昧， 土台下来的尔是谁？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英下。"
        },
        {
          "character": "孔怀",
          "type": "西皮摇板",
          "text": "康贤弟比孤年纪小， 耳不聋来眼不黑。 明明知道陈友谅， 为什么假装不认得？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀下，上。"
        },
        {
          "character": "孔怀",
          "type": "stage",
          "text": "【《捉放曹》】"
        },
        {
          "character": "孔怀",
          "type": "西皮摇板",
          "text": "辞别伯父把马跨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英上。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "老丈。"
        },
        {
          "character": "孔秀英",
          "type": "西皮摇板",
          "text": "陈宫心中似刀扎。 多蒙老丈恩义大， 好意反成恶冤家。 急忙里难说你我的知心话，"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "老丈，"
        },
        {
          "character": "孔秀英",
          "type": "西皮摇板",
          "text": "你休埋怨我陈宫你只怨他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔秀英下。"
        },
        {
          "character": "孔怀",
          "type": "西皮摇板",
          "text": "孟德下马语发诈， 陈宫为何泪如麻？ 莫不是家下人说闲话， 急忙回家问根芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀下，孔秀英上。"
        },
        {
          "character": "孔怀",
          "type": "stage",
          "text": "【《忠孝图》】"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "且住。俺曹庄不在家中，这贱人打骂老娘。不免唤他出来，相劝与他。若听还 则罢了，倘若不听，俺举拳就打，吾提刀就杀。 焦氏！焦氏！呔！贱人，走出来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀上。"
        },
        {
          "character": "孔怀",
          "type": "唱",
          "text": "奴在房中绣麒麟， 忽然间想起了我们那个心腹上的人，常常奴家挂在心。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哎哟哟。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "焦氏！"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哎呀，饫死我呢。我道是谁，原来是我们那一口子他回来呢。 曹郎你回来呢，你回来呢。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "放老诚些。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "叫我出来，有何话讲。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "搬张椅儿过来，为丈夫有话对你讲。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哦，搬张椅子过来。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "太近了。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "太近呢。你也不是十七，我也不是十八，谁离不开谁。咱们就远着一点。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "太远了。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哎呀！近也近了，远也远呢，怎么老摆不对你那个眼儿？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "摆椅子的地方。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "放在这里。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "放在这里。有什么话你说罢。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "俺曹庄不在家中，你——"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哦，你要喝茶，我与你倒茶去。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "回来。不用。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "不用。你有什么话你说。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "俺曹庄不在家中，你打——"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哦，你要吃饭。我与你端饭去。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "回来，亦不用。为丈夫与你讲话，你三番两次敢是打搅不成？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "我不打搅，有什么话你说罢。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "想俺曹庄不在家中，你打骂老娘，是何道理？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "你说的是谁吓？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "咱的老娘！"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "老羊？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "母鸡？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "呸！照打！"
        },
        {
          "character": "孔怀",
          "type": "梆子摇板",
          "text": "哎哎哎！我那曹郎夫吓。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "跟你拆拼头了。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "焦氏吓，哈哈哈，想我母亲年迈，你要在他跟前行孝才是。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "你要依我三件大事。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "哪三件？这头一件？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "头一件，你手使大棒一条，将你母亲赶出在外，你可使得？你可愿意？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "这焦氏吓，哈哈哈，想我母亲年迈，若是赶出在外，叫旁人知道，就是你我夫 妻的不孝了，使不得。这第二件？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "第二件，你写张休书把我休了，你可愿意，你可舍得？"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "这啊，哈哈哈，有道是无故不休妻，休妻有是非。我与你恩爱夫妻，焉能舍得 休你。这第三件？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "这第三件，我说出来，只怕你姓曹的做不出来。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "你说得出来，俺姓曹的就做得出来。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "你拿把刀来。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "要刀何用？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "你把我杀了吧。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "当真？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "当真。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "果然？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "果然。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "好贱人！"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "怎么样了？"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "出了血呢。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "我这里是假刀。"
        },
        {
          "character": "孔怀",
          "type": "白",
          "text": "不要闹呢。咱们回去吃饭吧。"
        },
        {
          "character": "孔秀英",
          "type": "白",
          "text": "走吓走吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔怀、孔秀英同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}