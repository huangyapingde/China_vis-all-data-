    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "柳林春试马，虎帐夜谈兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童上。"
        },
