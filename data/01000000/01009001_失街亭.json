          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、王平、马岱、马谡分两边站。四红龙套同上，诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "羽扇纶巾，四轮车，快似风云。阴阳反掌定乾坤，保汉家，两代老臣。"
        },
        {
          "character": "赵云、王平、马岱、马谡",
          "type": "同白",
          "text": "丞相在上，末将等参见。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "赵云、王平、马岱、马谡",
          "type": "同白",
          "text": "谢丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "忆昔当年居卧龙，万里乾坤掌握中。扫尽中原归汉统，方显男儿大英雄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人，复姓诸葛，名亮，字孔明，道号卧龙，官拜武乡侯之职。蒙先帝托孤之 重，一要扫清中原，二要重整汉室。虽然龙御殡天，此言独然在耳。昨日探马 报到，司马懿带兵攻取街亭，吾想街亭乃是汉中咽喉之要道，必须要派一能将 把守，方保无虑。众位将军，"
        },
        {
          "character": "赵云、王平、马岱、马谡",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今有司马懿带兵前来，夺取街亭。哪位将军领兵前去镇守街亭者，当帐请令。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "且住，丞相传下将令，并无人应声，待俺进帐讨令。 启丞相：末将不才，愿带领人马镇守街亭！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马将军，那司马虽然年迈，用兵如神，将军不可轻视。"
        },
