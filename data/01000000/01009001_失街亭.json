          "character": "诸葛亮",
          "type": "白",
          "text": "街亭虽小，干系甚重。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "如有错误，愿照军令施行！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军无戏言。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "愿立军状！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "当帐写来。"
        },
        {
          "character": "马谡",
          "type": "白",
