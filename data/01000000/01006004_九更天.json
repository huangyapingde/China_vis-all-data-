          "text": "官差不自由。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "请了，今日无事，衙前走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯花嘴上。"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "二位头儿。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "侯大爷。"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "二位，此地出了人命，你们可晓得？"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "什么人命？"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "米进途调戏寡嫂，寡嫂不从，他将寡嫂杀死。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "你怎么晓得的？"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "他家后门，正对我家前门，故尔晓得。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "侯大爷，你到衙内去打报呈。"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "正是到衙前而去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯花嘴下。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "伙计，你我前去叫门。 来此已是，开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马义上。"
        },
        {
          "character": "马义",
          "type": "白",
          "text": "哪个叫门？"
        },
        {
