          "type": "同白",
          "text": "米进途可在里面？"
        },
        {
          "character": "马义",
          "type": "白",
          "text": "灵前守孝。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "叫他出来。"
        },
        {
          "character": "马义",
          "type": "白",
          "text": "有请二东人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "米进途上。"
        },
        {
          "character": "米进途",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "马义",
          "type": "白",
          "text": "外面有二公差要见。"
        },
        {
          "character": "米进途",
          "type": "白",
          "text": "待我出去。"
        },
        {
          "character": "马义",
          "type": "白",
          "text": "二东人出迎。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "你可是米进途？"
        },
        {
          "character": "米进途",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "带了。"
        },
        {
          "character": "马义",
          "type": "白",
          "text": "为何将我二东人带去？"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "衙门里见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二衙役带米进途同下。"
        },
        {
          "character": "马义",
          "type": "白",
          "text": "且住。来了两个公差，将我二东人带去，不知为了何事？有了，待我衙前打听 便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马义下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引知县同上。"
        },
        {
          "character": "知县",
          "type": "引子",
          "text": "官居县令，与黎民，判断冤情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯花嘴上。"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "侯花嘴参见老父母。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "到此则甚？"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "前来打报呈。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "什么报呈？"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "米进途杀死寡嫂。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "他与你有亲？"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "无亲。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "有故？"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "无故。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "无亲无故，你打什么报呈？"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "他家后门，正对我家前门，恐怕牵连在内。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "三日后听审。下去。"
        },
        {
          "character": "侯花嘴",
          "type": "白",
          "text": "多谢老父母。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯花嘴下。米进途、二衙役同上。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "来，带米进途。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "拿到。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "押上堂来。"
        },
        {
          "character": "米进途",
          "type": "白",
          "text": "参见老父母。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "米进途，你乃读书之人，难道不知礼义，为何将寡嫂杀死，从实招来。"
        },
        {
          "character": "米进途",
          "type": "白",
          "text": "生员守兄之灵，并无此事。"
        },
        {
          "character": "知县",
          "type": "白",
          "text": "暂押班房，待我尸场回来，再作道理，带下去。 来，开道尸场。"
