        {
          "character": null,
          "type": "stage",
          "text": "姜永志上，扒拦杆下。"
        },
        {
          "character": "赵小姐",
          "type": "唱",
          "text": "又听得谯楼上更鼓齐响。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外、赵夫人同下。"
        },
        {
          "character": "赵小姐",
          "type": "西皮摇板",
          "text": "叫丫鬟暂退去将门掩定， 卸梳妆入罗帷睡卧沉沉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜永志上，拨门。"
        },
        {
          "character": "赵小姐",
          "type": "白",
          "text": "你是何人？来到我的卧房？"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "我乃绿林好汉，行至此地，缺少盘费，要与你借些金银。"
        },
        {
          "character": "赵小姐",
          "type": "白",
          "text": "箱中现有金银，拿些使用，快快走去。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "好一个绝色女子。我说那一女子，你若与我成却好事，我便即走。"
        },
        {
          "character": "赵小姐",
          "type": "白",
          "text": "你快快走去，如若延迟，我便喊叫。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "你若喊叫，我便杀你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵小姐喊。姜永志杀死赵小姐，搜财帛。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "明人不作暗事，将花蝴蝶一朵留在此地，待我喊叫。 呔！你家有贼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜永志下。丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有请员外夫人。"
        },
        {
          "character": null,
