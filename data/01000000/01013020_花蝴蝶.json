          "type": "白",
          "text": "今有贼人将小姐杀死，留下花蝴蝶一朵。"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "同哭",
          "text": "儿啊！"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "今有包公在此下马，待我前去投告便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外、赵夫人、丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、卢方、蒋平、徐庆、白玉堂、展昭、包拯同上。"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "铜锣开道人呐喊，"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "谁人不知包青天。 我身边随带着张龙、赵虎、王朝和马汉， 三口铜铡神鬼寒。 一路上断了些个无头案， 捉恶霸，断土豪，灭却赃官。 黑驴告状真奇案， 夜断乌盆伸过冤。 只因错断颜查散， 地府阴曹铡判官。 十里长亭铡包勉， 有那屈死枉魂速来伸冤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官上，接包拯、四龙套、卢方、蒋平、徐庆、白玉堂、展昭同进城，同下，同上。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "卑职参见老大人。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "此地民情如何？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "官是清官，民是顺民。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "回衙理事。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "多谢大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外上。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "冤枉！"
        },
        {
