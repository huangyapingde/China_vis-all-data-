        {
          "character": null,
          "type": "stage",
          "text": "赵小姐上。"
        },
        {
          "character": "赵小姐",
          "type": "白",
          "text": "参见爹娘。"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "白",
          "text": "罢了。今当中元佳节，大家畅饮一回。"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "唱",
          "text": "中元节一家人举杯畅饮， 我二老终日里快乐安宁。"
        },
        {
          "character": "赵小姐",
          "type": "唱",
          "text": "但愿得二爹娘身体强胜，"
