        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庆、蒋平同上。"
        },
        {
          "character": "徐庆、蒋平",
          "type": "同白",
          "text": "弟兄们均在此地。请坐。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "为何不见五弟？"
        },
        {
          "character": "卢方",
          "type": "白",
          "text": "想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白玉堂上。"
        },
        {
          "character": "白玉堂",
          "type": "白",
          "text": "众位兄长。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "请坐。你等为何这等打扮？"
        },
        {
          "character": "卢方",
          "type": "白",
          "text": "大哥有所不知，今有大胆贼人，盗去桃花玉马，临行留下花蝴蝶一朵，万岁命 包大人捉拿。赵员外家中小姐被杀，盗去金银，临行也留蝴蝶。想这两桩奇案 是一人所作。大哥久闯江湖，定知此人来历。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "愚兄略知一二。"
        },
        {
          "character": "卢方、蒋平、徐庆、白玉堂、展昭",
          "type": "同白",
          "text": "大哥请讲。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "此人姓姜，名永志，人称花蝴蝶。每逢偷盗，定要采花。一日三餐邓家堡，与 邓车交好。众位贤弟，方才所言，定是此人了。"
        },
        {
          "character": "卢方、蒋平、徐庆、白玉堂、展昭",
          "type": "同白",
          "text": "既然如此，待我等前去。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "且慢，后面用了酒饭，大家一同前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、邓车同上。〖点绛唇〗。"
        },
        {
          "character": "邓车",
          "type": "念",
          "text": "相貌堂堂胆包天，全凭袖箭镇江南。结交天下英雄汉，坐地分赃乐安然。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "俺，邓车。霸占邓家堡，倒也逍遥自在。我有一好友，名叫姜永志，去到东京 偷盗皇家桃花玉马，去有多日，未见归来。 左右，伺候了。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "二寨主到。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜永志上。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "贤弟请坐。贤弟一路行来，多受风霜之苦。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "玉马之事如何？"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "已被小弟盗来。大哥请看。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "好马呀，好马！"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "大哥想必有爱马之意？"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "好马人人皆爱。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "如此就奉送大哥。多谢贤弟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜永志望。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "贤弟看什么？"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "为何不见二位嫂嫂？"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "来，请你家二位主母。"
        },
        {
          "character": "下手甲",
          "type": "白",
          "text": "有请二位主母。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二夫人同上。"
        },
        {
          "character": "二夫人",
          "type": "同念",
          "text": "闻听寨主唤，迈步到跟前。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "二位嫂嫂。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "来，看酒伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启禀寨主：庄外来了许多车辆。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "待小弟前去走走。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "些些小事，何劳贤弟，众喽兵出庄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四青袍、欧阳春同上。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "我当是谁，原来是欧大哥。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "原来是邓贤弟。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "请到庄中一叙。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "正要拜庄。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下，同上。欧阳春望。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "欧大哥，看些什么？"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "为何不见二寨主？"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "有请你二寨主。"
        },
        {
          "character": "下手甲",
          "type": "白",
          "text": "有请二寨主。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜永志上。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "啊哈！"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "贤弟见过欧大哥。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "原来是欧大哥。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "久闻大名，如雷贯耳。今日一见，真乃名不虚传。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "大哥夸奖了。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "备得有酒，与大哥畅饮。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "到此就要叨扰。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "来，将酒摆下。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "闻听人言，二寨主曾到东京，盗了皇家桃花玉马，可算英雄好汉。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "此乃是小弟作了一桩不才之事，何劳大哥称赞。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "但是一件。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "万岁有旨，曾命包公差人前来拿你。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "慢说包公手下之人，就是天神下界，我姜某何惧。"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "休出狂言，后悔无及。告辞。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "不送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卢方、徐庆、蒋平、白玉堂、展昭同上，欧阳春转回。"
        },
        {
          "character": "邓车",
          "type": "白",
          "text": "大哥为何去而复转？"
        },
        {
          "character": "欧阳春",
          "type": "白",
          "text": "非是我去而复转，包公已差人前来拿你。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "待我会他一会。"
        },
        {
          "character": "展昭",
          "type": "白",
          "text": "胆大花蝴蝶，私盗皇家国宝，该当何罪？"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "休得胡言，看镖！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜永志、展昭同起打，八股连环下。"
        },
        {
          "character": "蒋平",
          "type": "白",
          "text": "花蝴蝶甚是厉害，如若败下，必从水道而逃，我不免在鸳鸯桥下等候便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜永志上。"
        },
        {
          "character": "姜永志",
          "type": "白",
          "text": "且住！那厮杀法厉害，不免从水道而逃便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。姜永志被擒。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}