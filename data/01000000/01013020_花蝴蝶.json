          "text": "待我等前去拿获。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢，卢方、展昭听令，命你二人扮作犯人解差模样，私访贼人，不得有误。"
        },
        {
          "character": "卢方、展昭",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "徐庆、蒋平听令，命你二人，扮作扮作一僧一道，捉拿贼人，不得有误。"
        },
        {
          "character": "徐庆、蒋平",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "白玉堂听令。命你各处暗访，不得有误。"
        },
        {
          "character": "白玉堂",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "大家一同前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
