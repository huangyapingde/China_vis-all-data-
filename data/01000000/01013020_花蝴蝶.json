          "type": "白",
          "text": "堂口有人喊冤。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "带上来！"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "参见包年兄。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "原来是赵年兄，可有状纸？"
        },
