{
  "script_id": "01004011",
  "title": "飞虎山",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "安敬思",
      "hangdang": "小生"
    },
    {
      "name": "李克用",
      "hangdang": "净"
    },
    {
      "name": "周德威",
      "hangdang": "老生"
    },
    {
      "name": "李嗣源",
      "hangdang": "老生"
    },
    {
      "name": "李存信",
      "hangdang": "净"
    },
    {
      "name": "康君利",
      "hangdang": "丑"
    }
  ],
  "plot": "裨官说部中：相传南唐，晋王义子，十三太保李存孝，系铁石星下凡，原名安敬思。自幼寄养邓员外家，为\n牧羊飞虎山中。一日，晋王李克用夜梦猛虎入帐，晓令左右详解，咸称主得虎将。李克用遂率领群臣，在荒\n郊大开围场，亲往围猎。途遇神樵引至飞虎岗中，得遇安敬思，时安敬思方十二龄。李克用令试演诸般武艺，\n无不精熟。且又力能扛鼎，言语爽朗，毫无小儿畏怯之态。李克用见之大喜，知非凡器。遂收为第十三太\n保。赐名李存孝。",
  "notes": "惟剧情与裨官所载已稍有出入，故较诸正史则更远。吾国旧戏，大都如此，李存孝大约即李存勖之误耳。\n此剧尤为朱素云之拿手杰作。神化自然，唱做兼工，迥生反响。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安敬思上。"
        },
        {
          "character": "安敬思",
          "type": "引子",
          "text": "思亲伤心泪，愁锁两道眉。"
        },
        {
          "character": "安敬思",
          "type": "念",
          "text": "有母无父奇生养，想起叫人实惨伤。养育多蒙邓员外，每日牧羊在山岗。 小子安敬思。乃是有父无母，多蒙南庄邓员外，抚养成人。如今年已一十二岁， 每日在那山岗牧羊。哦，今日天气晴和，不免将那群羊，赶往南山去者。"
        },
        {
          "character": "安敬思",
          "type": "西皮导板",
          "text": "安敬思生来命不强，"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "朝朝暮暮在山岗。 遭不幸吾的母命早丧， 撇下了安敬思来牧羊。 自那日闲游独龙岗， 偶遇道人叙衷肠： 他道我容貌非凡相， 定是那皇家治国安邦的栋梁。 闲话虽然如此讲， 命中注定何须忙。 将羊赶在南山上， 怕风怕雨不怕虎狼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李克用上，四将、四龙套同上。"
        },
        {
          "character": "李克用",
          "type": "念",
          "text": "山上插宝剑，斩断清水泉。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "参见父王。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "兵发郊外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "念",
          "text": "领了玉帝命，搭救铁石星。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "吾乃当方土地是也。只因铁石星难期已满，不免前去指引于他。"
        },
        {
          "character": "土地",
          "type": "念",
          "text": "一变二变，樵夫出现。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "远远望见晋王来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用、四将、四龙套同上。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "樵夫挡道。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "土地",
          "type": "唱",
          "text": "我本山中一尊神， 霎时变做砍樵人。 少刻晋王来到此， 引他去见铁石星。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "砍樵吓，砍樵吓。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "听那樵夫作歌蹊跷，将他唤下山来。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "樵夫，我家大王唤你。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "在此做甚？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "在此砍樵。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "樵夫在此砍樵，怎么不怕豺狼虎豹？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "此地无有豺狼虎豹。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "哪里有？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "前面有座飞虎岗，惯出豺狼虎豹。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "哦，飞虎岗！"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "呵呀，想这“飞虎”二字，正应孤王的梦兆。樵夫将那樵担，放在此地，引孤 去到飞虎岗。多把银钱与你。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "愿领千岁前去。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "带路。"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "适才樵夫对我讲： 前面有座飞虎岗。 但愿得此去收良将， 兴唐灭巢在这场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安敬思上。"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "高峰叠翠人来往， 青山绿水心欢畅。 将身且把山岗上， 清风拂面百花香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思睡。土地引李克用、四将、四龙套同上。土地下。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "昨晚猛虎卧宝帐， 周德威进帐把梦详。 他叫孤王撒围场， 此去必然得栋梁。 大队人马往前闯，"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "樵夫不见。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "樵夫不见为哪桩？ 儿郎带路把山岗上， 青山绿水好清凉。 耳旁忽听风声响，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "只见猛虎下山岗。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "猛虎来也。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "弓来。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "开弓就把雕翎放， 学个唐童定辽邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用射，虎形下。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "带箭而逃，老虎不见。有一娃娃在此打睡。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "此处有一娃娃打睡，不要伤他性命。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "醒来！"
        },
        {
          "character": "安敬思",
          "type": "西皮导板",
          "text": "耳旁忽听人喧嚷，"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "想是猛虎吃了羊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思反身捽下。虎形上。安敬思上，打虎形，虎形死。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "娃娃无礼也！"
        },
        {
          "character": "李克用",
          "type": "西皮二六板",
          "text": "娃娃做事太莽撞， 不该将孤的家虎伤。 那猛虎本是孤王养， 打死家虎孤要尔抵偿。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "安敬思",
          "type": "西皮二六板",
          "text": "羊、虎俱是一条命， 谁是弱来谁是强。 猛虎既是千岁养， 不该将我家羊伤。 打死你虎赔你虎， 要你赔羊也应当。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "娃娃说话有志量， 亚赛当年的张子房。 回言便把太保叫， 你把大话唬儿郎。"
        },
        {
          "character": "李嗣源",
          "type": "西皮快板",
          "text": "父王一旁把话讲， 讲两句大话唬儿郎。 将身跳过小溪涧， 父王唤你有话商量。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "我虽不及萧何相， 前去见他有何妨。 将身跳过小溪涧， 千岁有何话商量？"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "家住哪州并哪庄？ 可有父来可有娘？"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "安敬思，启禀上： 无有父来只有娘。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "娃娃把话错来讲， 孤家言来听端详： 天无日月少阴阳， 说什么无父只有娘。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "千岁吓！"
        },
        {
          "character": "安敬思",
          "type": "西皮二六板",
          "text": "千岁屡次问端详， 提起前情话便长： 吾母亲自幼未配郎， 姐妹们玩耍在山岗。 闲游来在荒郊外， 八个石人站立在两旁。 姐妹们抛球闲谈讲， 要将那石人配我娘。 归家已是黄昏后， 只见石人进娘房。 言语之中将娘戏， 要与吾母配鸾凰。 十月怀胎生下我， 无衣无食来牧羊。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "低下头来暗思想， 原来是铁石星君下天堂。 你母如今在何处往？ 接她到来，孤王有话商量。"
        },
        {
          "character": "安敬思",
          "type": "西皮散板",
          "text": "千岁问起我亲娘，"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "十一年前早已亡。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "娃娃不必泪悲伤， 哪有人死又还阳！ 你道孤王是哪一个？ 孤就是沙陀国的老大王。 只为黄巢反边疆， 因此上领兵保大唐。 孤有太保十二个， 一个一个在朝奉君王。 你若是真心把孤降， 孤封你太保一十三郎，又待何妨。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "久有此心来归降， 奈无引见拜君王。 多蒙千岁恩德广， 躬身一礼拜父王。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "安敬思改为李存孝， 从今后休离孤的身旁。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "谢过父王改名姓， 李存孝三字永不忘。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "搏虎的武艺果然高， 但不知韬略强不强？"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "打从太极山前过， 曾与道人叙衷肠： 十八般武艺件件精， 三略六韬腹内藏。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "李淳风，袁天罡， 鬼谷，王禅，周文王。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "众将将那虎皮剥下，与你十三王爷，造身虎皮盔甲，不得违误。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "众将将孤的龙驹宝马带上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允，同带马。安敬思试。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "不称儿骑。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "周将军，唐营之中，无有存孝的坐骑，如何是好？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "启父王：天差良将，自有良马。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "好一个天差良将，必有良马。儿有什么武艺当先？"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "件件精通。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "将孤的九九八十一斤的定唐宝刀抬上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允，同抬刀。安敬思试。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "不称儿手。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "将孤的丈八蛇矛抬上来。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同抬枪。安敬思试。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "不称儿手。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "周将军，唐营之中，无有存孝的兵刃，如何是好？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "天赐良将，兵刃自然有的。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "儿臣有一兵器，现在土地祠内。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "快快取来，"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思下。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "周将军，想孤收了存孝，可胜得过那黄巢？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "胜得过那黄巢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思取杵上。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "前去看来。"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "待儿臣看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源看。"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "不认识。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "唔，身为大将，连兵器都不认识。"
        },
        {
          "character": "康君利",
          "type": "白",
          "text": "我倒认识。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "你既认识，前去看来。"
        },
        {
          "character": "康君利",
          "type": "白",
          "text": "这个是药店里大块的鸡爪黄连。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "滚开些罢！ 待孤看了。呵呵，连孤也不认得。 周将军，此物何名？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "启父王：此乃“笔眼神抓”，又名“混唐杵”。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "儿可会耍？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "不会。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "儿臣使得。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "耍来为父的观看。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思耍，下。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "周将军，孤家有意，将先锋大印，交与存孝执掌，你的意下如何？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "尤恐众将不服。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "依儿之见，就在此地百步之外，立一标竿。标竿上面，红袍一件。有人将红袍 射下，先锋大印付他执掌。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "听孤令下："
        },
        {
          "character": "李克用",
          "type": "西皮散板",
          "text": "坐在山岗传令号， 大小众将听根苗： 你们哪个的武艺好， 个个前来射红袍。"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "李嗣源",
          "type": "西皮散板",
          "text": "父王山岗传令号， 百步之外射红袍。 弓箭搭上珠红扣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源射。"
        },
        {
          "character": "李嗣源",
          "type": "西皮散板",
          "text": "三箭之中中二条。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源下。李存信上。"
        },
        {
          "character": "李存信",
          "type": "西皮散板",
          "text": "父王山岗把令传， 百步竿上射红袍。 挽弓搭上雕翎箭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李存信射。"
        },
        {
          "character": "李存信",
          "type": "西皮散板",
          "text": "三箭一箭都不着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李存信下。康君利上。"
        },
        {
          "character": "康君利",
          "type": "西皮快板",
          "text": "父王山岗传令号， 这旁来了将英豪。 开弓就把雕翎放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康君利射。"
        },
        {
          "character": "康君利",
          "type": "西皮散板",
          "text": "三箭之中无一条。"
        },
        {
          "character": "李克用",
          "type": "西皮散板",
          "text": "斗大的金钱射不着， 还在唐营称英豪。 不念昔日把唐保， 一捆四十定不饶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康君利下。安敬思上。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "校场来了李存孝， 争名夺利在今朝。 下得马来上箭道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思射。"
        },
        {
          "character": "安敬思",
          "type": "西皮散板",
          "text": "射中红心箭三条。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "下面听者：谁敢前来与你王爷比箭！"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "周德威来也！"
        },
        {
          "character": "周德威",
          "type": "西皮散板",
          "text": "存孝休要夸口讲， 俺的武艺比你强。 开弓就把雕翎放，"
        },
        {
          "character": "李克用",
          "type": "西皮散板",
          "text": "周德威休要惩刚强。 存孝本是小儿郎， 不看存孝看父王。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "启父王：儿意欲射断柳梢，坠落红袍。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "儿吓，你若射不中，就不要射。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "儿臣能够。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "射不中。"
        },
        {
          "character": "安敬思",
          "type": "西皮散板",
          "text": "适才我对父王道， 射断柳梢坠红袍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思射袍。"
        },
        {
          "character": "李克用",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "李克用",
          "type": "西皮导板",
          "text": "儿射得中来射得妙，"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "箭箭不差半分毫。 慢说众将不如你， 儿比孤王还要高。 将酒宴摆在麒麟道， 父子们饮一个醉酕醄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}