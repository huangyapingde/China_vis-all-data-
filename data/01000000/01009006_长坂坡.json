          "character": "张飞",
          "type": "白",
          "text": "哎，赵云怎么不回？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "三将军请了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀，四弟，速请过桥，追兵到来有俺老张挡之。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云过桥，下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且住，看那曹军如同潮水一般，遮天盖地而来，只有老张一人在此，岂是他人 敌手？这这便如何是好？呵呵，有了，来吓，与我将那柳梢砍下，拴于马尾之 上，在柳林飞跑，以作尘土之计。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同允，同砍树。张飞上桥。"
        },
        {
          "character": "张飞",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四大铠引曹操、张郃、徐晃、许褚、李典、曹洪、张辽、曹休、乐进、夏侯杰同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "前导为何不行？"
        },
        {
          "character": "张郃、徐晃、许褚、李典、曹洪、张辽、曹休、乐进、夏侯杰",
          "type": "同白",
          "text": "来此当阳柳林。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "夏侯杰",
          "type": "白",
          "text": "启丞相：桥上站着一人，末将有些害怕。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "前去问来。"
        },
        {
          "character": "夏侯杰",
          "type": "白",
          "text": "呔，桥上之将，通名受死！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "听者，俺乃大将翼德张！"
        },
        {
          "character": "夏侯杰",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯杰吓死。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀众将，我昔日在白马坡前，曾闻云长言道：他三弟翼德，在那百万军中， 取上将之首级，如探囊取物耳。今日一见，话不虚传！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、徐晃、许褚、李典、曹洪、张辽、曹休、乐进同允。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "燕人张翼德在此，谁敢前来决一死战！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "战又不战，退又不退，却是何故？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，将人马退回！ （张郃、徐晃、许褚、李典、曹洪、张辽、曹休、乐进同允，张郃、徐晃、许褚、李典、曹洪、张辽、曹休、 乐进、曹操、四红文堂、四大铠同下。）"
        },
        {
          "character": "张飞",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来，将这桥梁拆断。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同允，同拆桥，张飞、四上手同下。"
        }
      ]
    },
