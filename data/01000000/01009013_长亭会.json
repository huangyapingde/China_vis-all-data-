{
  "script_id": "01009013",
  "title": "长亭会",
  "alias": [
    "伍申会"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "申包胥",
      "hangdang": "净"
    }
  ],
  "plot": "伍员方从樊城战退武城黑，挂袍江边以疑追者，而倍道向东南而来。正仓皇奔走时，忽邀见前途有大队楚兵\n至，心甚惊疑。既而探悉系故人申包胥归国，方始安然，私计申包胥乃自幼好友，谅必不翻脸加害，遂出会\n叙，直告冤情。并数述平王不道之罪，他日誓必借师以图报复。申包胥闻言，则力劝不可，谓“君父无酬，\n万无报复之理”。伍员坚执不允。申包胥亦谓然深怜其志之苦。至临别，申包胥与伍员约曰：“他日子能覆\n楚，吾必复楚。各尽其力，各行其志可也。”语时词气激昂，忠诚形于色，遂纵之去。伍员亦深威其德。",
  "notes": "此剧即接《战樊城》之后。后为伍员与申包胥相遇中途，彼此各言其志之一段事实，故又名《伍申会》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、中军、申包胥同上。〖点绛唇〗。"
        },
        {
          "character": "申包胥",
          "type": "念",
          "text": "奉王旨意出朝堂，各国催贡转帝邦。扶保吾主良为上，保定平王锦家邦。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "俺，申包胥，楚国为臣。奉了平王旨意，各国催贡。催贡已毕，回朝交旨。 众将官，今乃黄道吉日，正好班师回朝。 中军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军允。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "班师回朝。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "班师回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套同喝。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺，伍员。幸喜逃出樊城，去到吴国借兵雪恨。你看前面来了一哨人马，旗帜 上面斗大的“申”字，想必是申包胥贤弟到此。等他到来，我将满腹含冤对他 一表。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、中军、申包胥同上。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "八龙套",
          "type": "同白",
          "text": "伍爷挡道。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "人马列开！ 吓，兄长为何这等狼狈？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "贤弟，一言难尽！"
        },
        {
          "character": "伍员",
          "type": "西皮二六板",
          "text": "未曾开言泪双流， 尊一声贤弟听从头： 临潼关上曾为首， 我也曾举鼎压诸侯。 双挂明辅印二口， 各国不敢统貔貅。 只恨平王无道贪色酒， 父纳子妻礼还周？ 我的父谏奏反斩首， 只杀得伍家鸡犬也不留。 对天发下洪誓咒： 不杀平王死不休！"
        },
        {
          "character": "申包胥",
          "type": "西皮快板",
          "text": "兄长说话没来由， 愚弟言来听从头： 君叫臣死定斩首， 父叫子亡谁敢留？ 得放手来且放手， 得罢休来且罢休。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "贤弟说话没来由， 愚兄言来听从头： 君不正来臣要走， 父不正来子外游。 杀了我家丁数百口， 这等冤仇怎罢休？"
        },
        {
          "character": "申包胥",
          "type": "西皮快板",
          "text": "你若兴兵来争斗， 我为公来你为仇。 个人怀恨莫泄漏， 急速打马把吴投。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "申包胥与我把舌斗， 背转身来自己愁。 走上前来兄叩首， 有劳你放我往东流。 今日相别阳关路， 日后相逢在楚吴。 辞别贤弟跨走兽， 扬鞭打马把吴投。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "申包胥",
          "type": "西皮快板",
          "text": "一见兄长跨走兽， 不由包胥两泪愁。 本帅阳关传一令， 大小三军听分明： 有人回朝风走漏， 定将满门刀割头！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套同喝。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}