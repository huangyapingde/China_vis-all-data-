{
  "script_id": "01010005",
  "title": "忠孝牌",
  "alias": [
    "忠孝牌坊"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "薛广",
      "hangdang": "老生"
    },
    {
      "name": "王春娥",
      "hangdang": "正旦"
    },
    {
      "name": "薛保",
      "hangdang": "外"
    },
    {
      "name": "薛倚哥",
      "hangdang": "小生"
    }
  ],
  "plot": "薛广在镇江营业数年，后弃贾就仕，以兵功荐升至兵部，乃请假归里。三娘、薛保见之，惊骇无措，以为见\n鬼。经薛广一再数述历来状况，方悉前情，彼此均悲喜交集。薛广悉张、刘二氏，均下堂改嫁，不胜愤恨。\n方谈询间，忽闻锣声喧填，报薛倚哥及第，衣锦还乡。薛倚哥入门，初不认父，继经三娘、薛保说明，乃参\n拜谢罪。即而朝廷因知薛氏一门节义可风，又遣中使赍诏至。敕赐“忠孝节义”四字牌匾，以旌表之，并令\n建坊表扬。此即昆剧中《见鬼》、《赍诏》、《诰圆》三折也。惟昆剧中，尚多大娘、二娘匍匐登门，求收\n覆水等事实。",
  "notes": "此剧与《三娘教子》出，均出昆剧《双官诰》。惟《双官诰》中，系景泰间冯京故事：三娘即何碧莲；老薛\n保即老仆冯仁；薛倚哥即探花冯雄；主人冯京者即本剧中薛子奇（名广）也。按京剧作今按本剧脚本，多不\n载矣。近来京沪各园演此剧者，多以绑子青衫去之。前见崔灵芝演此颇佳，四盏灯亦足与崔瑜亮。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛广引四青袍同上。"
        },
        {
          "character": "薛广",
          "type": "引子",
          "text": "为国尽忠义，常怀一片心。"
        },
        {
          "character": "薛广",
          "type": "念",
          "text": "云淡风轻近午天，旁花随柳过前川。时人不识余心乐，将谓偷闲学少年。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "下官薛子奇。镇守镇江有功，皇上见喜，官封上大夫之职。今特辞去官职，不 免回家祭祖。 左右！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同允。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "看衣更换！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛广换衣。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同下。"
        },
        {
          "character": "薛广",
          "type": "二黄慢板",
          "text": "昨日里有人对我论， 这件事倒叫我挂在心。 朱买臣幼年间不得地， 他也曾休去了不贤妻。 一路上我把这古人来讲， 怕的是叫人话短长。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "来此已是。 薛保哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛保上。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "是哪个叫门？"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "你老爷还家。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "哽。我家老爷镇江已死，人死哪有复生之理？"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "镇江死的是王文。不要多言！家中还有何人？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "现有三娘。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "有请你三娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王春娥上。"
        },
        {
          "character": "王春娥",
          "type": "念",
          "text": "昨夜灯花落地，必有喜事临门。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "恭见三娘。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "薛保何事？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "我家老爷回来了！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "哽。你家老爷命丧镇江已死，人死哪有复生之理？"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "老奴亦是这样言讲。他言道镇江死的王文。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "领我去看。 行路人在哪里？行路人在哪里？"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "三娘！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "哽。你是什么人，叫我三娘？ 薛保叫他往下站！"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "往下站！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "薛保你去问他：当年怎样失散？怎样离别？说得字字相同，就是老爷回家。倘 若一字有差，送在公堂办理。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘问你：当年怎样失散？怎样离别？说得字字相同，就是老爷回家。倘若一 字有差，送在公堂办理。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "三娘，薛保，不要动怒，听我道来。"
        },
        {
          "character": "薛广",
          "type": "二黄慢板",
          "text": "叫三娘、老薛保莫要乱嚷， 听丈夫把此话细对你讲： 想当年家贫难以顾瞻， 因此上去买易投奔外乡。 出门去遇王文中途路上， 我二人做伙伴去到镇江。 到后来有王文镇江命染， 老薛保错搬尸转回家乡。 尊三娘你何不前思后想， 哪有个人死后又来还阳？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "王春娥",
          "type": "二黄慢板",
          "text": "王春娥听一言喜从天降， 幸喜得奴丈夫转回家乡。 想当年我的夫青春模样， 到如今三绺须打落在胸膛。 人人说个个讲儿夫命丧， 哪有个人死后又来还阳？ 常言说人一死休要妄想， 阴曹府哪有个放鬼的阎王？ 莫非是夫妻们梦中相望……"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "王春娥",
          "type": "二黄慢板",
          "text": "猛抬头又只见红日当光。 一霎时腹内事明星亮亮， 不枉奴王春娥守节一场。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "不知老爷回家，多有得罪。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "好说！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "老爷请进。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "老爷请坐。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "有坐！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "老爷看些什么？"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "为何不见大娘、二娘，哪里去了？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "休要提起，一言难尽！"
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
          "text": "未开言不由人泪流面上， 听为妻把此话细对你讲： 恨张、刘她二人与你吵嚷， 怒恼了你老爷投奔外乡。 人人说薛老爷镇江命丧， 老薛保错搬尸转回家乡。 将尸首放至在梨花枕上， 咱三人身穿白哭倒灵堂。 二贱婢一不哭二不望， 不满了三个月改变心肠。 二贱婢反罗裙去把荣享， 把三从和四德放在哪厢？ 撇下了你的儿无有教养， 妻送他学房中苦读文章。 喜只喜汉王爷开了考场， 你的儿去赶考未见回乡。"
        },
        {
          "character": "薛广",
          "type": "二黄原板",
          "text": "听一言气得我火焚心上， 这件事倒叫我箭穿胸膛。 从今后把荣华休要妄想， 二贱婢无有福另嫁夫郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "小东人回家！"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "小东人回家！"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "吓，夫人，哪个小东人回家？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "想必你我儿子得中回来。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "叫他进来！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "慢着。既然得中回来，必须下一请字。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "里面有请！"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "里面有请！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "你我迎上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛倚哥、四龙套同上。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "不认识了！"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "母亲在哪里？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "我儿在哪里？我儿在哪里？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "哎，母亲请上，受孩儿一拜。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "堂前现有你父，拜过你父，再拜为娘。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "我父镇江命丧，人死哪有复生之理？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "镇江死的那是王文。不要多言，上前拜过。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "爹爹请上，受孩儿一拜。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "慢着。堂前现有你母，哪有为父？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "哎，老爷！你我儿子，不知者不怪罪。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "好，不知者不怪罪。受我儿一拜。 薛保受过千辛万苦，受我俱家一拜。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "薛倚哥",
          "type": "念",
          "text": "一十三载未见亲，今日才见我父身。幸喜父子重相见，好似花开月团圆。"
        },
        {
          "character": "薛广",
          "type": "念",
          "text": "当年离家从头起，"
        },
        {
          "character": "王春娥",
          "type": "念",
          "text": "教子成名费心机。"
        },
        {
          "character": "薛倚哥",
          "type": "念",
          "text": "我母贞守在机房，"
        },
        {
          "character": "薛保",
          "type": "念",
          "text": "月中丹桂连生枝。"
        },
        {
          "character": "薛广、王春娥、薛倚哥",
          "type": "同白",
          "text": "好一个“月中丹桂连生枝”！"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "忠孝儿，随为父来吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛广、薛倚哥同下。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "薛保，你随我来罢。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王春娥、薛保同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张永、四小太监同上。"
        },
        {
          "character": "张永",
          "type": "白",
          "text": "咱家张永。今有薛子奇镇守镇江有功，万岁爷命咱家前去封官。 孩子们，催骑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛广上。"
        },
        {
          "character": "薛广",
          "type": "念",
          "text": "三娘贤惠无比，才得教子成名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛倚哥上。"
        },
        {
          "character": "薛倚哥",
          "type": "念",
          "text": "机房受母教管，恩情何日报来。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "忠孝儿。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "儿在！"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "有请你母亲。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "有请母亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王春娥上。"
        },
        {
          "character": "王春娥",
          "type": "引子",
          "text": "教子登高，不用我，枉费心劳。"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "吓，夫人。凤冠霞帔为何不穿戴？"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "凤冠霞帔自有大娘、二娘穿戴，哪有我穿戴的？"
        },
        {
          "character": "薛广",
          "type": "白",
          "text": "三娘！"
        },
        {
          "character": "薛广",
          "type": "二黄摇板",
          "text": "二贱婢福薄无有份， 她怎能受荣华头戴凤冠？ 三娘受过雪里寒， 这凤冠霞帔理当穿。"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "听一言气得我团团打颤， 听为妻将前事细说一番： 想当年有一封家书回转， 一字字一行行写在上边。 书函上写的是张、刘二氏， 并无有王春娥添上一言。 一大二小三奴婢， 为奴婢我怎把霞帔来穿？"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "薛倚哥",
          "type": "二黄原板",
          "text": "薛忠孝来用目看， 我只见爹爹为了难。 手拿凤冠双膝跪， 尊一声母亲听儿言： 母亲受过雪里寒， 这凤冠霞帔理当穿。"
        },
        {
          "character": "王春娥",
          "type": "二黄摇板",
          "text": "我的儿跪面前把我来劝， 为娘的摇手不敢担。 将儿的凤冠霞帔桌上放， 自有你大娘、二娘穿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛保上。"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "薛保抬头用目看， 看他二人为了难。 手捧凤冠双膝跪。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三娘，"
        },
        {
          "character": "薛保",
          "type": "二黄原板",
          "text": "这凤冠霞帔理当穿。"
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
          "text": "见薛保哭得我心中悯怜，"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "老薛保，老薛保。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "母亲穿戴了罢。"
        },
        {
          "character": "王春娥",
          "type": "二黄原板",
