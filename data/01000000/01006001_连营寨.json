{
  "script_id": "01006001",
  "title": "连营寨",
  "alias": [
    "火烧连营七百里"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "陆逊",
      "hangdang": "小生"
    },
    {
      "name": "关兴",
      "hangdang": "武生"
    },
    {
      "name": "张苞",
      "hangdang": "净"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    }
  ],
  "plot": "蜀先主刘备，因关公、张飞相继丧亡，遂与东吴结不解之仇，誓欲沼灭孙吴，以报二弟，于异姓手足之谊，\n诚无间矣。惜太愤历，忘汉室之公敌，而但急己身之私义，舍重谋轻，逆于理势，且复过于骄盈操切，不知\n乘胜转机，以是卒被大创，至身丧白帝，遗恨吞吴。呜呼，偏安之局，蜀祚之暂，盛衰成败，实消长于此！\n按蜀志章武二年二月，黄忠既战殁于彝陵，先主益愤吴，誓必灭此朝食，遂会军猇亭，分路进攻，连营七百\n里，初出兵，颇胜利，死其主帅甘宁，孙权大惧，遂遣程秉（剧本作诸葛瑾）奉使来议和，愿割荆州还蜀，\n并函归张飞首级。先王适盛怒之余，不许，程秉还，吴廷束手。乃拔陆逊于书生，拜为大将。先主闻之，颇\n易视陆逊。时适盛暑，兵苦炎渴，先主不察，令移营林木丛茂处，遂犯兵家包原失闲之忌，致为陆逊所败，\n全军覆没，几不能脱。方马良赍图入川，诸葛亮见之，即顿足叹恨，欲图补救，知已不及。幸得赵云往援，\n先主乃退入白帝城养疴。是役也，祭酒程畿、番王沙摩柯，及傅彤、冯习、张南等，均死于难。",
  "notes": "此剧前见谭鑫培去刘备，沉着悲痛，苍凉激越，深合白帝城以前之一种神气。叫天而外，当推王又宸为第一。\n今客串华彦臣君，亦深得此戏三味，洵于谭、王外能独树一帜者，诚未易材也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩当、周泰、糜芳、傅士仁、马忠、夏旬同上，同起霸。〖点绛唇〗。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "俺，"
        },
        {
          "character": "韩当",
          "type": "白",
          "text": "韩当。"
        },
        {
          "character": "周泰",
          "type": "白",
          "text": "周泰。"
        },
        {
          "character": "糜芳",
          "type": "白",
          "text": "糜芳。"
        },
        {
          "character": "傅士仁",
          "type": "白",
          "text": "傅士仁。"
        },
        {
          "character": "马忠",
          "type": "白",
          "text": "马忠。"
        },
        {
          "character": "夏旬",
          "type": "白",
          "text": "夏旬。"
        },
        {
          "character": "韩当",
          "type": "白",
          "text": "请了，元帅起兵征剿西蜀，命我等在此伺候。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八红小军、四大铠、甘宁同上。〖点绛唇〗。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "甘宁",
          "type": "念",
          "text": "战鼓响惊天震地，杀气腾鸟不敢飞。帐下有雄兵百万，号令出敢不遵依！"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "本帅甘宁。蒙圣恩拜我为帅，征讨西蜀，今乃黄道吉日。 众位将军，人马可齐？"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "具已齐备。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "起兵前往。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "众将官起兵齐往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、瓜头大铠、关兴、张苞、张南、刘备同上。〖上半段泣颜回〗。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "眼观江夏水沧沧，好似汉阳对武昌。常德、武陵依然在，虎口内面藏荆襄。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤，刘备。带领倾国人马，与二、三弟报仇，兵出川口，擒城夺市，杀关斩将， 皆赖二、三弟之神威也。孔明先生，在成都闻得黄忠去世，发来蛮兵十万， 以助其阵，只因蛮兵初到内地，不知兵势若何。 张南，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张南允。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "传番王沙摩柯上将台听点。"
        },
        {
          "character": "张南",
          "type": "白",
          "text": "番王沙摩柯上将台听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "沙摩柯上。"
        },
        {
          "character": "沙摩柯",
          "type": "白",
          "text": "这金里金波，伊里波，藏安呵，沙摩柯，嗑膝。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你兵初入内地，不知兵势若何，传令开操，待孤一观。"
        },
        {
          "character": "沙摩柯",
          "type": "白",
          "text": "这蛮兵们开操。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八蛮兵、四长枪、四短刀同上，操演，同下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤观你兵势，倒也精壮，令人难敌也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖下半段泣颜回〗。"
        },
        {
          "character": "沙摩柯",
          "type": "白",
          "text": "就此合操。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "沙夫人上，合操完。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报，韩当、周泰等兵打蜀营。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "沙摩柯，带领你兵攻打头阵，张苞、关兴，随后接应。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、张南同下。"
        },
        {
          "character": "沙摩柯、关兴、张苞",
          "type": "同白",
          "text": "众将官起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场，甘宁上，会阵，开打。甘宁追蛮兵同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "沙摩柯、关兴、张苞、众人同上。〖上半段千秋岁〗。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "甘宁厉害如何是好？"
        },
        {
          "character": "沙摩柯",
          "type": "白",
          "text": "不妨，他若来时，乱箭齐发，哪怕他飞上天去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘宁追上。四长枪手、四蛮兵同放箭，甘宁带箭下。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "紧紧追赶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖下半段千秋岁〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "内喊，甘宁上。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "罢了吓，罢了！ （甘宁唱越恁好牌第一段。关兴、张苞、沙摩柯同追上，过场，同下。韩当、周泰、糜芳、傅士仁、马忠、 夏旬、龙套同上，同下。）"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "哎呀，且住！蜀兵来得厉害，我军不能取胜，主上吓主上，臣不能保全社稷了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘宁唱越恁好牌第二段，自刎。韩当、周泰、糜芳、傅士仁、马忠、夏旬、龙套同上。"
        },
        {
          "character": "韩当",
          "type": "白",
          "text": "主帅已死，不能复生，须得拜本进京，请兵救援。"
        },
        {
          "character": "周泰",
          "type": "白",
          "text": "只是江南岸无人把守。"
        },
        {
          "character": "马忠、麋芳",
          "type": "同白",
          "text": "我等把守江南岸。"
        },
        {
          "character": "韩当、周泰",
          "type": "同白",
          "text": "我等把守江北岸。 众将官，把守去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大凯引韩当、周泰同下。"
        },
        {
          "character": "马忠",
          "type": "白",
          "text": "将军，此乃咽喉之地，须要小心把守。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马忠下。"
        },
        {
          "character": "麋芳、傅士仁",
          "type": "同白",
          "text": "众将，此乃咽喉之地，小心把守。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳、傅士仁同下。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "列位将军，看蜀兵每每得胜，此地难保，不免将麋芳傅士仁的首级，献于刘备， 岂不是头功！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "言之有理，请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "麋芳、傅士仁同上。"
        },
        {
          "character": "麋芳",
          "type": "白",
          "text": "哎吓将军，方才三军言到，要杀你我，献于刘备，如何是好？"
        },
        {
          "character": "傅士仁",
          "type": "白",
          "text": "不妨，趁此无人，将马忠杀死，献于刘备，岂不是好？"
        },
        {
          "character": "糜芳",
          "type": "白",
          "text": "言之有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳、傅士仁同下。马忠上，麋芳、傅士仁同上，杀马忠，马忠下。"
        },
        {
          "character": "麋芳、傅士仁",
          "type": "同白",
          "text": "趁此无人，就此走了罢，正是："
        },
        {
          "character": "糜芳",
          "type": "念",
          "text": "瓦罐不离井上破，"
        },
        {
          "character": "傅士仁",
          "type": "念",
          "text": "将军难免阵前亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳、傅士仁同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吕范、诸葛瑾、阚泽、赵咨同上。"
        },
        {
          "character": "吕范",
          "type": "念",
          "text": "五云露出催晓箭，"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "九重春色醉仙桃。"
        },
        {
          "character": "阚泽",
          "type": "念",
          "text": "旌旗日暖龙蛇动，"
        },
        {
          "character": "赵咨",
          "type": "念",
          "text": "金殿风和燕雀高。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "下官吕范。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "下官诸葛瑾。"
        },
        {
          "character": "阚泽",
          "type": "白",
          "text": "下官阚泽。"
        },
        {
          "character": "赵咨",
          "type": "白",
          "text": "下官赵咨。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "主公登殿，排班伺候。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引孙权同上。"
        },
        {
          "character": "孙权",
          "type": "引子",
          "text": "终日焦劳，恨刘备，心似咆哮。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "臣等见驾，主公千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "千千岁。"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "昔日曹瞒下江东，全凭周郎巧计攻。如今刘备来征讨，只怕山河落了空。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤，姓孙名权，字仲谋。受父兄之基业，所辖江东一带等处，可恨刘备占去城 池，我兵不能取胜，孤心甚是忧虑也。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "启主公：今有韩当、周泰拜本前来，请主公观看。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕范呈本，孙权看。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "“甘宁阵亡”。哎吓，卿家吓！“请兵救援”！咳，昔日有周郎，周郎之后有 子敬，子敬之后有吕蒙，如今国空邦虚，有谁解孤之危也？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "主公可将范疆、张达并张飞首级，解至蜀营，待臣前去讲和。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "就命卿家，将范疆、张达并张飞首级，解至蜀营讲和。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾下。"
        },
        {
          "character": "赵咨",
          "type": "白",
          "text": "臣观诸葛瑾，此去必不转来。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "不必多奏，退班。"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "一字压群寮，文武且退朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权下，众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二太监引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "梦寐坐卧恨吴狗，灭却东吴方罢休！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞同上。"
        },
        {
          "character": "关兴",
          "type": "念",
          "text": "心中怀旧恨，"
        },
        {
          "character": "张苞",
          "type": "念",
          "text": "不共戴天仇。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "启皇伯：今有麋芳、傅士仁，解马忠首级来见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二贼来了！绑上来！"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "绑上来！"
        },
        {
          "character": null,
          "type": "stage",
