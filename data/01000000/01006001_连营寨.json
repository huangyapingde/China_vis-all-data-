      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞、张南、刘备同上，四文堂同上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "龙麟起坐如反掌，干戈霸业定太平。"
