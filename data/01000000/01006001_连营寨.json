        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "众将官移营去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞同下。"
        }
      ]
