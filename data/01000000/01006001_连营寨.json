        {
          "character": null,
          "type": "stage",
          "text": "马良上。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "启主公：东吴拜陆逊为帅，兵扎蓆亭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "陆逊是甚等样人？"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "乃九江太守陆绩之后，一介书生，虽则年幼，颇有谋略，智取荆州，乃此人之 计也。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "嗳，原来乳子诡计，害孤二弟，此时正当擒之。 关兴、张苞，吩咐起兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞同允。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "且慢，主公请息怒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "陆逊非比周郎，不可轻敌。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咳，我用兵老矣，难道不如那黄口孺子么？"
        },
        {
          "character": "张南",
          "type": "白",
          "text": "臣等每每骂阵，陆逊紧守不出，如之奈何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不妨，孤这里兵精粮足，就与他对守何惧？"
        },
        {
          "character": "张南",
          "type": "白",
          "text": "只是天气炎热，兵扎离火之中，又恐汲水不便，三军多生疾病。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不妨，孤将营寨，移于茂林深处，炎夏一过，秋时与他拼一死仗，东吴自然休 矣。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "我兵若动，倘陆逊踹营，如之奈何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唔，孤命关兴、张苞，各带兵五万，埋伏山谷之中，倘陆逊踹营，趁势可擒也。"
        },
        {
          "character": "张南",
          "type": "白",
          "text": "主公妙计，臣等不及也。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "主公要移营寨，可画成地图，问过丞相。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咳，孤用兵老矣，些许小事，何必又问丞相？"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "古语云：“兼听则明，偏听则暗”，望陛下详之。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "也罢，就命卿家，将各营四至八图，画成全幅，去问丞相；若有不便，即来回 奏。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马良下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "张苞、关兴，就此移营。"
