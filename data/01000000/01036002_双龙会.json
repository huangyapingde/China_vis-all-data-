  "plot": "《双龙会》故事出旧小说《杨家将》、《金枪传》中，为北赵匡义时事，即“八虎闯幽州”是也。《四郎探\n母》中，所称“十五年前沙滩赴会”，即指此事。大旨谓辽邦萧天庆与潘洪串通，骗诱宋帝到幽州被困，又\n设双龙会，伪约宋帝赴宴议款，盖效项王鸿门宴，欲图当筵杀死宋主也。一面亦效《取荥阳》中纪信替主故\n事，令杨大郎延平假扮宋帝代主而往，其余自二郎以次至八郎，均保护同往，此即所谓“八虎闯幽州”。既\n至会，大郎见势不佳，因拼一死，用先发制人之计，以弩射死辽主萧天庆，遂闹成一场恶战。虽能杀出重围，\n使辽兵败退，然大郎、二郎均战死，三郎踏死马蹄下，四郎、八郎均被擒，所剩生还者，只五、六、七郎\n三人而已。宋兵元气从此大伤，而杨家将忠心保主之名，则亦从此永久传于世。",
  "notes": "《双龙会》本到此而止。惟此剧本中，又代演五郎代主出家之前段，为《五郎出家》剧中所无。非但足与\n《五台山》紧此衔接，且此段纯系唱工，颇为重头。盖演其与宋主及老父、兄弟等辞别也，中多摇板、二六，\n足动听。若得名角改词演唱，其声价当不在《珠帘》下也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小军引杨继业同上。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "狼烟何日息，吾主日夜忧。股肱怀社稷，将士宿沙堤。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "老夫杨继业。只因潘仁美诓驾游玩幽州，被困重围。仁美临阵脱逃，我君臣何 日脱离虎口，方才听得号炮一声，想是番兵攻城。 小军，"
        },
        {
          "character": "四小军",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "带马巡城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二太监引赵匡义同上。"
        },
        {
          "character": "赵匡义",
          "type": "引子",
          "text": "塞外烽烟起，边庭动干戈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳上。"
        },
        {
          "character": "赵德芳",
          "type": "念",
          "text": "怀恨潘洪贼，何日回朝歌。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "侄儿见驾，叔王万岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "寡人赵匡义，国号雍熙。被仁美诓驾幽州，围困番邦，水泄不通，也曾命杨老 将军前去巡城，未曾回旨。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军引杨继业同上。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "忠心贯义胆，哪怕胡儿兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军同下。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "臣杨继业见驾，愿吾主万岁，贤爷千岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "老将军，巡城一事如何？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "韩延寿兵临城下，要请万岁亲自答话。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "哎呀，这就为难了。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "叔王请退，待儿臣前去看个明白。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "甚好，老将军保驾。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡义下。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "番兵围困如水洗， 待小王上城楼看端的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四手下引韩延寿同上。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "城上来的可是大朝皇帝？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "吾主未到，贤爷在此。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "原来是八千岁，马上参拜。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "韩驸马领兵何往？"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "我狼主在四十里金沙滩设下双龙大会，请你君臣赴宴，同议两邦和好之事。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "既然如此，驸马将人马暂退，待我君臣即来赴会。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "来者君子，不来者小人。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "住口。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩延寿、四手下同下。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "不好了。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "一计不成又一计， 君臣好似网内鱼。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "有请叔王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡义上。"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "君臣围困番邦地， 不知何日转华夷？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "叔王不好了：韩延寿兵临城下，他说道已在四十里金沙滩设下双龙大会，请我 君臣讲和番国。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "哪里是讲和番国，分明摆下杀人战场。也罢，皇儿同老将军，各自逃生去吧。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀万岁呀！"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "到如今才把奸贼怨， 诓请御驾来北番。 四十里沙滩摆下宴， 此处吉凶难保全。 君臣正在为难处，"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哦，有了。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "除非扮一个假宋君。 杨继业紧铠出宝帐， 众家孩儿听端详： 哪一个孩儿像宋王， 替主赴会到沙场？"
        },
        {
          "character": "杨延平",
          "type": "内白",
          "text": "孩儿应去。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "答话儿郎哪一个？"
        },
        {
          "character": "杨延平",
          "type": "内白",
          "text": "长子延平。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "好吓。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "出帐来父子们做商量。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延平上。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "孩儿拜揖。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "罢了。儿吓，你可情愿替主赴会？"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "孩儿情愿替主赴会。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "好，随为父来。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "父是英雄儿好汉， 杨家出了假宋王。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "臣延平见驾，愿吾主万岁。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "臣长子延平愿替主赴宴。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "皇儿，看小将军面貌如何？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "果然像叔王一些不差。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "赵延平",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "小将军可愿替寡人？"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "臣愿替主赴会。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "好，更换寡人八宝龙袍。"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "头上取下飞龙帽， 身上脱下衮龙袍。 救得寡人回朝转， 凌烟阁上把名标。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "杨延平",
          "type": "西皮摇板",
          "text": "南宋营盘二君王， 两国不和动刀枪。 向前辞过爹爹驾，爹爹吓，"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "我儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延平同哭。"
        },
        {
          "character": "杨延平",
          "type": "西皮摇板",
          "text": "天波府拜上老萱堂。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿吓，"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "我的儿不必悲声放， 痛哭犹恐惊君王。 出得营外一声叫， 众家儿郎听端详： 哪几个儿郎有胆量， 保你大哥赴会到番邦。"
        },
        {
          "character": "杨延定、杨延广、杨延辉、杨延德、杨延昭、杨延嗣",
          "type": "内同白",
          "text": "孩儿们都愿去。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "答应的孩儿们都愿去吗？"
        },
        {
          "character": "杨延定、杨延广、杨延辉、杨延德、杨延昭、杨延嗣",
          "type": "内同白",
          "text": "都愿去的。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "好吓。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "二郎、三郎一声叫， 四、五、六、七、八郎听端详： 去时保定尔兄长， 回来还父的假宋王。 在营中与你八员将， 回来与我人四双。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "众孩儿！"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "尔大哥若有长和短， 我要你弟兄们把命偿。 辞别万岁把马上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "七郎转来，为父有一言嘱咐于你。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "儿在那酒席筵前紧要提防。"
        },
        {
          "character": "杨延嗣",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "杨延嗣",
          "type": "西皮摇板",
          "text": "辞别爹爹泪汪汪，"
        },
        {
          "character": "杨延嗣",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "杨延嗣",
          "type": "西皮摇板",
          "text": "舍死忘生到番邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延嗣同哭，杨延嗣下。"
        },
        {
          "character": "杨继业",
          "type": "三叫头",
          "text": "大郎，延平！哎，我的儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业哭。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "一见儿郎出宝帐， 回头启奏吾君王。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "启奏万岁：众家儿郎俱已前去赴会，城内虚空。请主回至五台，再做道理。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "带龙驹过来。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "六幺令。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、萧天庆同上。"
        },
        {
          "character": "萧天庆",
          "type": "引子",
          "text": "虎踞萧邦，愿一统归吾掌。"
        },
        {
          "character": "萧天庆",
          "type": "念",
          "text": "几次兴兵破宋朝，屡遭败北费心劳。双龙会上讲和国，但愿一统镇家邦。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "孤天庆王，虎踞萧邦，龙蟠塞地。屡次兴兵破宋，总被杨家杀得大败。只因潘 仁美诓驾幽州，孤在四十里金沙滩，设下双龙大会，请他君臣前来赴会，孤这 里暗藏埋伏甲兵，将他君臣一鼓擒拿。 来！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "传萧天佐进帐。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "传萧天佐进帐。"
        },
        {
          "character": "萧天佐",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧天佐上。"
        },
        {
          "character": "萧天佐",
          "type": "念",
          "text": "身穿袍儿马蹄袖，一心要与宋王斗。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "开膝。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "命你带领人马三千，埋伏席前，将他君臣一鼓擒拿。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧天佐下。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "再传耶律休哥。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "传耶律休哥进帐。"
        },
        {
          "character": "耶律休哥",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "耶律休哥上。"
        },
        {
          "character": "耶律休哥",
          "type": "念",
          "text": "喜吃羊肉面，爱的打蜡酥。"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "开膝。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "命你带领人马三千，埋伏帐后，宋王到此，一鼓擒拿。"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "耶律休哥下。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "传公主进帐。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "传公主进帐。"
        },
        {
          "character": "公主",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公主上。"
        },
        {
          "character": "公主",
          "type": "念",
          "text": "闲来操弓演箭，闷时琵琶三弦。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "开膝，开膝。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "命你带领人马三千，埋伏帐左，宋王到此，一鼓擒拿。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公主下。韩延寿上。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "报：大宋皇帝到。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "吩咐摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩延寿、众将同允，分下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延平、杨延定、杨延广、杨延辉、杨延德、杨延昭、杨延嗣、杨延顺同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖吹打〗，四太监引萧天庆同上，杨延平、杨延定、杨延广、杨延辉、杨延德、杨延昭、杨延嗣、杨延顺"
        },
        {
          "character": null,
          "type": "text",
          "text": "同上，会阵。）"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "吓吓，大朝皇帝。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "国主。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧天庆、杨延平同笑。众人同下，同上。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "不知大朝皇帝驾到，孤未曾远迎，有罪。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "国主相召，有何国事议论？"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "大朝皇帝有所不知，只因二国不和，屡动干戈。可怜军民遭了涂炭之苦。特请 大朝皇帝到来立约为盟，插标为界，显息干戈，使黎民也得安业。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "此是国主仁德之心。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "二太监",
          "type": "同白",
          "text": "宴齐。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "看宴。待孤把盏。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "不消，摆下就是。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "来，"
        },
        {
          "character": "二太监",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "将宴摆开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监同上宴。杨延嗣上，搜席，看。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "大朝皇帝请。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "国主请。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "耶律休哥，"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "舞剑奉酒。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "不用。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "不用呢。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "告便。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "哎哟，我看天庆王有害孤之心。哦，有了。有道：“打人不如先下手”。 天庆王向前答话。"
        },
        {
          "character": "萧天庆",
          "type": "白",
          "text": "有何话讲？"
        },
        {
          "character": "杨延平",
          "type": "白",
          "text": "着大郎袖箭。 （杨延平打袖箭，萧天庆中箭死。杨延平、萧天庆同下。众人同杀，同下。耶律休哥杀杨延定死，同下。韩 擒杨延顺同下。耶律休哥、韩延寿、公主同上，同杀，众人同下。杨延德、杨延昭、杨延嗣同下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩延寿、公主同上。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "哎呀！我道是宋王，原来是杨大郎假扮宋王前来赴会。公主回去保定国母登基。 待咱追赶宋王便了。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩延寿、公主同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延德、杨延昭、杨延嗣同上。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哎呀！二位贤弟，众哥哥丧命番邦，一同报与爹爹知道。"
        },
        {
          "character": "杨延昭、杨延嗣",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德、杨延昭、杨延嗣同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引潘仁美同上。"
        },
        {
          "character": "潘仁美",
          "type": "念",
          "text": "棋下一着错，满盘尽皆输。"
        },
        {
          "character": "潘仁美",
          "type": "白",
          "text": "老夫，潘仁美。只因圣上被诓驾幽州，为此兵败董家岭。是我新收四将，陈林、 柴干、郎千、郎万。不免前去救驾，恐恕我之罪，也未可知。 来，转至董家岭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。六幺令。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡义、赵德芳、杨继业同上。〖合头〗。内喊声。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "启万岁：贼兵追来了。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "老将军抵挡一阵。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "领旨。 （赵德芳、赵匡义同下。韩延寿上，开打，杨继业下。陈林、柴干、郎千、郎万、潘仁美同上，同开打，韩 延寿下。）"
        },
        {
          "character": "陈林、柴干、郎千、郎万",
          "type": "同白",
          "text": "那贼大败。"
        },
        {
          "character": "潘仁美",
          "type": "白",
          "text": "转至五台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。六幺令。众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。赵匡义、赵德芳、杨继业同上。陈林、柴干、郎千、郎万、潘仁美同上。"
        },
        {
          "character": "潘仁美",
          "type": "白",
          "text": "臣潘仁美见驾，愿吾主万岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "住了！大胆奸贼，临阵脱逃，还敢见朕。 老将军，推出斩了。"
        },
        {
          "character": "潘仁美",
          "type": "白",
          "text": "且慢。启奏万岁：念臣在董家岭救驾有功，将功按罪，不及问斩。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "念你董家岭救驾有功，免却一刀之罪，叉出去！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "去吧。"
        },
        {
          "character": "潘仁美",
          "type": "白",
          "text": "哎哟哟！"
        },
        {
          "character": "潘仁美",
          "type": "念",
          "text": "用手捧尽湘江水，难洗今日满面羞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘仁美下。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "寡人脱离虎口，皆得老将军之功劳也。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "老臣粉骨，何足为奇。只是众儿郎替主赴会之事，不知吉凶如何。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "等候他们回来，便知明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德、杨延昭、杨延嗣同上。"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "叩见万岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "叩见贤爷。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "爹爹，孩儿交令。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "吓，你们都回来了吗？你大哥？"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "长枪刺杀。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀！你二哥？"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "短剑身亡。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你三哥？"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "马踹如泥。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你四哥和八顺呢？"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "失落番邦。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你怎么讲？"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "失落番邦。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀！不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业昏。"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "爹爹醒来！"
        },
        {
          "character": "杨继业",
          "type": "西皮导板",
          "text": "听一言来刀刺心，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延德、杨延昭、杨延嗣同哭。"
        },
        {
          "character": "杨继业",
          "type": "哭",
          "text": "哎呀众孩儿吓！"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "头顶凉水怀抱冰。 大郎长枪来刺死，"
        },
        {
          "character": "杨继业",
          "type": "哭头",
          "text": "大郎吓！"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同哭头",
          "text": "大哥吓！"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "二郎短剑一命身亡。 三郎马踹如泥浆，"
        },
        {
          "character": "杨继业",
          "type": "哭头",
          "text": "三郎呵！"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同哭头",
          "text": "兄长吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延德、杨延昭、杨延嗣同哭。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "四郎、八顺失落在番邦。"
        },
        {
          "character": "杨继业",
          "type": "哭头",
          "text": "四郎、八顺吓！"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同哭头",
          "text": "哎，四哥、八弟吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延德、杨延昭、杨延嗣同哭。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "出府来父子人九个， 回去把什么交还你的娘？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延德、杨延昭、杨延嗣同哭。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "昨晚一梦大不祥， 梦见猛虎赶群羊。 却原来应在杨家将， 一个个都丧在番邦。"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "老将军休把悲声放， 职上加官在朝堂。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "老臣亦非嫌官小， 可叹儿郎丧边疆。 在生不能把福享， 死后焉望封神将。"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "大郎替朕丧了命， 孤封他神位平帝君。 二郎他在剑下死， 封他花花太岁神。 三郎马踹如泥浆， 封他龙华会上第一尊。 四郎、八顺无音信， 在生封官死后封神。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "继业闻言谢龙恩， 谢过万岁封他们。"
        },
        {
          "character": "杨延昭",
          "type": "哭",
          "text": "爹爹吓。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "见六郎哭得如酒醉，"
        },
        {
          "character": "杨延昭",
          "type": "哭",
          "text": "爹爹。"
        },
        {
          "character": "杨继业",
          "type": "哭",
          "text": "哎呀儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延德、杨延昭、杨延嗣同哭。"
        },
        {
          "character": "杨延嗣",
          "type": "哭",
          "text": "爹爹吓。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "听七郎一旁放悲声。"
        },
        {
          "character": "杨延嗣",
          "type": "哭",
          "text": "爹爹。"
        },
        {
          "character": "杨继业",
          "type": "哭",
          "text": "哎呀儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延德、杨延昭、杨延嗣同哭。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "爹爹吓。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "五郎犹如刀割肉，"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "好一似群鹰抓群鸡。 我曾记你母亲送我到门上， 手挽铠甲泪汪汪： 交与你弟兄八员将， 回府去要还她人四双。 到如今为国在边庭丧，哎呀儿吓， 回府去怎见得儿的娘？"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "把六郎、七郎一声宣， 圣旨再宣五将军： 六郎三关为总镇， 七郎斩龙大将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延嗣同谢拜。"
        },
        {
          "character": "杨延昭、杨延嗣",
          "type": "同白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "五郎为朕把力竭， 亏你五台搬救兵。 总军总督何嫌小， 靴尖不离午朝门。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "万岁吓。"
        },
        {
          "character": "杨延德",
          "type": "西皮导板",
          "text": "杨五郎闻言头低下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德哭。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哎呀，万岁吓！"
        },
        {
          "character": "杨延德",
          "type": "西皮摇板",
          "text": "不住两眼泪巴巴。 可怜我弟兄们死的苦，大哥，二哥，三哥，哎呀，我的哥吓！"
        },
        {
          "character": "杨延德",
          "type": "西皮二六板",
          "text": "为主江山把命亡。 这才是朝也杀来暮也杀， 杀来杀去杀自家。 刀刀割的心头肉， 箭箭射的白莲花。 杨五郎解开其中意， 要把金刀削头发。 取下了银盔卸铠甲，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延嗣同哭。"
        },
        {
          "character": "杨延德",
          "type": "西皮二六板",
          "text": "禅堂受戒去出家。 六弟、七弟一声叫， 愚兄言来听根芽： 我杨家秉忠心功劳皆大， 众兄弟一个个命丧黄沙。 潘仁美在朝中私把书发， 暗地里瞒圣驾把幽州下。 这一阵杀得我心中害怕， 你一刀我一枪谁肯让咱。 回府去见老母传声虚话， 就说是杨五郎死在天涯。 父年老母年迈寿高白发， 早晚间你二人侍奉爹妈。 八姐姐和九妹尚未出嫁， 兄和弟与姐妹早寻婚家。 杨五郎诉不尽衷肠苦话， 狠着心别高堂削去头发。 上前来苦哀求万岁爷驾， 万岁爷吓，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德哭。"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "容小臣到五台削发出家。"
        },
        {
          "character": "赵匡义",
          "type": "西皮快板",
          "text": "小将军说的是哪里话， 讲什么到五台削发出家？ 怎不念你父母年纪高大， 怎舍得骨肉恩削了头发。"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "昔日庄王求殿下， 所生公主貌如花。 不愿皇宫招驸马， 白鹊寺中出了家。 刳目烙手全不怕， 修到莲台做菩萨。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "你是凡人，怎么比得。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "万岁吓，"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "臣虽然是凡人不敢来比她， 也免去轮回苦不受波渣。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "寡人不准。"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "万岁爷不准臣的本， 回头哀告八贤君。 没奈何哀告千岁驾，千岁爷吓！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "五将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德哭。"
        },
        {
          "character": "杨延德",
          "type": "哭",
          "text": "哎呀，千岁爷吓！"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "容小臣去五台修学道法。"
        },
        {
          "character": "赵德芳",
          "type": "西皮快板",
          "text": "将军说话没来由， 怎忍别父把母丢？ 杨家功劳阵阵有， 后来个个觅封侯。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "千岁吓！"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "大帝山河数十秋， 人心怎比水常流？ 古来多少忠良将， 汗马功劳不到头。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "小王不允。"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "八千岁不准臣的本， 转身哀告老爹尊。 向前来哀告严亲父，爹爹吓！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "五郎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德哭。"
        },
        {
          "character": "杨延德",
          "type": "哭",
          "text": "哎呀，爹爹吓！"
        },
        {
          "character": "杨延德",
          "type": "西皮快板",
          "text": "儿要去五台山拜师修行。"
        },
        {
          "character": "杨继业",
          "type": "西皮快板",
          "text": "小奴才说的是哪里话， 讲什么五台去出家？ 六弟年小不多大， 七弟还是小娃娃。 八姐九妹未出嫁， 亏你狠心别爹妈。 父子回朝辞王驾， 火塘寨上做庄家。 我二老死后儿把孝挂， 又好坟前把土抓。 你今出家到还罢，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业哭。"
        },
        {
          "character": "杨继业",
          "type": "哭",
          "text": "哎呀，我的儿吓！"
        },
        {
          "character": "杨继业",
          "type": "西皮快板",
          "text": "天波府还有儿的老白发。"
        },
        {
          "character": "杨继业",
          "type": "西皮滚板",
          "text": "我哭，哭一声杨五郎！ 我叫，叫一声杨延德！ 哎哎哎，我的五儿呀！ 父子们出兵犹如九只虎， 到今日一战，死的死，走的走，儿又在此要出家。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿来看——"
        },
        {
          "character": "杨继业",
          "type": "西皮滚板",
          "text": "为父白发苍苍， 犹如那风前烛，草上霜。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿吓，既要出家，随为父到天波府，见过你的母亲一面，再来出家，也还不迟 了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业哭。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "爹爹吓！把孩儿只当作众家哥哥，死在边庭。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "唗！为父的不开口，谁敢出家。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哎呀呀，爹爹吓。"
        },
        {
          "character": "杨延德",
          "type": "西皮摇板",
          "text": "再三再四苦哀告， 爹爹执意不肯抛。 今日不将儿来舍，"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "罢，"
        },
        {
          "character": "杨延德",
          "type": "西皮摇板",
          "text": "撞死五台不回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延嗣同扶杨延德坐。"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "千言万语劝不转， 哭得为王心内焦。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "五台出家有什么好，"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "万岁、贤爷！"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "他全然不念父年老。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "老将军舍了吧。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "叫老臣如何舍得？"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "只当替了寡人吧。 唤长老。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "长老上。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "五将军金刀削发。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小和尚同上，扶杨延德。杨延德回头看，哭下。赵匡义、赵德芳同下。"
