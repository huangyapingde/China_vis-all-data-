        },
        {
          "character": "杨继业",
          "type": "叫头",
          "text": "七郎！"
        },
        {
          "character": "杨延嗣",
          "type": "叫头",
          "text": "爹爹！"
        },
        {
          "character": "杨继业",
          "type": "叫头",
          "text": "哎呀，儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、杨延昭、杨延嗣同下。"
        }
      ]
    },
