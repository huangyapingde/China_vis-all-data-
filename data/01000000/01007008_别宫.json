{
  "script_id": "01007008",
  "title": "别宫",
  "alias": [
    "别皇宫"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "孙尚香",
      "hangdang": "正旦"
    },
    {
      "name": "吴国太",
      "hangdang": "老旦"
    }
  ],
  "plot": "孙尚香自荆州回到东吴以后，听说刘备伐东吴失败，死于白帝城，痛不欲生。当即进宫辞别母后吴国太，到\n江边遥祭丈夫，祭后投江而死。",
  "notes": "《别宫祭江》本系一本两折，应连续演唱，其剧情方始完足。盖“别宫”者，原为“祭江”而别，因出场即\n去江边哭祭，于剧中关目，似少曲折，故先将《别宫》反衬，此编剧之本旨也。惟唱工冗长，前本西皮，后\n本转为二黄反调，演者颇嫌吃力。故近来每每仅演《祭江》，而不连《别宫》一段，亦积习使然。其剧情详\n《祭江》出中。此剧吴彩霞颇擅名，票友江梦花亦不弱。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上，二宫女同上。"
        },
        {
          "character": "孙尚香",
          "type": "引子",
          "text": "身坐宫院，怎能消，终日愁闷。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "别君常挂念，难忘故日情。虽无千丈锦，万里惊人心。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "奴家孙氏尚香。配夫刘使君，夫妻倒也恩爱。回转荆州三载，儿夫领兵征西， 谁知周郎用计诓我，言说我母后染病在床，将我接回江东，母女见面，我母未 曾染病，是我不能回去，在此住了数载，思想起来，好不愁闷人也。"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "孙尚香坐宫院心中寂寞， 思一思想一想奴好命薄。 遭不幸我父王早已亡故， 遗下了兄仲谋执掌江河。 坐江南八九郡有何不可， 一心要取荆州惹动干戈。 将奴家定一计诓虎离窝， 又谁知弄假成真反配嫦娥。 嫁荆州未三载将我诓过， 因此上与皇叔恩爱相割。 奴好比走风船失了艄舵， 奴好比抢食鱼自投在网罗； 奴好比花正开不曾结果， 奴好比织女星隔断银河。 恨兄王把我的牙关咬破， 那一旁又来了报事宫娥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女上。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "参见公主。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "罢了。起来。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "谢公主。有大事不好。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "皇叔白帝城晏驾。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "你话怎讲？"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "皇叔白帝城晏驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香哭。"
        },
        {
          "character": "孙尚香",
          "type": "叫头",
          "text": "皇叔，我夫，哎吓夫吓！"
        },
        {
          "character": "孙尚香",
          "type": "西皮导板",
          "text": "听一言不由我心如刀剜，"
        },
        {
          "character": "孙尚香",
          "type": "叫头",
          "text": "皇叔，我夫，夫吓！"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "我夫君为江山性命不全。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且住。我想皇叔一死，吾在东吴苦守无益，不免备下祭礼，身穿孝服，往江边 祭奠，以表夫妻之情。 来，看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香换衣。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "叹先帝下江南报仇起意， 叹兄王用陆逊巧定兵机。 用火攻烧连营七百余里， 最可叹汉皇叔一命归西。 我与他鸾凤交三载恩义， 奴不免见母后细说端的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香、宫女同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "吴国太",
          "type": "内西皮导板",
          "text": "一日偷闲一日安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴国太、二宫女同上。"
        },
        {
          "character": "吴国太",
          "type": "西皮慢板",
          "text": "光阴迅速不回还。 孙权他把大事管， 每日兴兵不时闲。 只恨曹丕把位篡， 篡夺汉室锦江山。 吾婿刘备重兴汉， 称孤道寡坐西川。 闻说白帝把驾晏， 叫人暗地泪涟涟。 将身且坐皇宫院， 等候尚香把我参。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上，二宫女同上。"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "宫娥女摆驾养老院， 见了母后把驾参。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "儿臣见驾，母后千岁。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "王儿平身。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "谢母后。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "吓，儿吓，今日进宫，为何不戴凤冠，不穿霞帔，身着孝服来见为娘，所为何 事？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后有所不知，今有刘皇叔在白帝城晏驾，因此上儿臣身穿缟素。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "吓，刘先主晏驾了？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "可叹吓可惜！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "启奏母后：儿臣要到江边一祭，以表夫妻之情。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿虽然与刘先主有夫妻之份，况且分别数载，他与你兄王又有敌国之仇，你还 祭他则甚？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后吓，"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "母后说话言语颠， 细听孩儿把话言： 男大当婚愁眉散， 女大须嫁礼当然。 孩儿青春二十满， 未曾与儿配婚男。 都只为荆州未讨转， 将奴定计礼不端。 不说东吴见识浅， 反道他人礼不然。 孤衾独枕谁人伴， 年少青春独自眠。 儿好比南来失群雁， 叫人泪涟不泪涟。"
        },
        {
          "character": "吴国太",
          "type": "西皮慢板",
          "text": "我儿不必来埋怨， 细听为娘说根源： 不幸你父寿命短， 早年一命丧黄泉。 抛下基业无人管， 江南九郡付孙权。 只为荆州讨不转， 才将我儿配凤鸾。 定计本是周郎想， 以免将士不安然。 儿嫁刘备娘心愿， 送儿荆州有三年。 接儿回转是周善， 母女分别又团圆。 江边祭奠空祭奠， 一滴何曾到九泉。"
        },
        {
          "character": "孙尚香",
          "type": "西皮快板",
          "text": "母后说话理太偏， 往日贤来今不贤。 说什么江边祭奠空祭奠， 一滴何曾到九泉？ 老母枉把弥陀念， 从前事儿想一番。"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "蠢才不必强舌辩， 细听为娘把话言： 夫妻好比同林鸟， 大限来时各一边。 我儿曾把书来念， 一生须当孝为先。 孙权他把大事管， 膝下不敢乱胡言。 我儿本是闺中女， 开口反道娘不贤。 要到江边去祭奠， 为娘不准枉徒然。"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "母后不必把脸翻， 有辈古人请听言： 昔日姬妃大交战， 战死沙场命不全； 姜氏痛哭长城断， 千里寻夫万古贤。 儿虽然学不得姜氏女， 一点诚心到江边。"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "任儿说得莲花现， 讲什么古来论什么贤。 为娘坐在皇宫院， 看哪个大胆到江边。"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "今日不容儿祭奠，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "不如一死染黄泉。"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "我儿休要寻短见， 为娘送你到江边。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "我儿一定要去，为娘也不再三阻拦于你，待为娘同你前去就是了。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "不烦母后前往，儿有宫娥相伴。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "这却使得。 宫娥们，此番同郡主去往江边祭奠，须要早去早回，休令主公知道。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "孩儿知道。母后请上，受孩儿拜别。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿吓！分别一时，何言“拜别”二字？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "礼当拜过母后吓。"
        },
        {
          "character": "孙尚香",
          "type": "西皮二六板",
          "text": "虽然暂时别宫院， 人生须当礼为先。 去了愁容换笑脸， 双膝跪在地平川。 儿愿老母身康健， 儿愿老母福寿全。 叩罢头来回身转， 心中有事不敢言。 宫娥摆驾出宫院， 要想回头难上难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引孙尚香同下。"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "娇儿出宫去祭奠， 袖内机关不好言。 怕的是娇儿寻短见， 一心要学古圣贤。 尚香女若有长和短， 暮景逢春谁问安。 将身且坐皇宫院， 日落西山望儿还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴国太下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}