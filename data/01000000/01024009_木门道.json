    }
  ],
  "plot": "蜀汉诸葛武侯伐魏，五出祁山。魏主曹睿，委任司马懿，倾兵抵御。司马懿令张郃为先锋，与武侯决胜负。\n武侯营中乏粮，其时陇上麦熟，欲割麦以资军用，为司马懿所识破，防备周密。武侯运用遁甲法，唤姜维、\n魏延、马岱，与武侯同样装束，军士俱披发仗剑，分四路而出，魏兵追赶不及。司马懿不知是人是鬼，惊疑\n不定，奔入上邽城，闭门不出。所有麦田，已为蜀兵割尽，运往卤城打晒。司马懿与副都督郭淮，分兵攻击，\n复遭大败。调雍凉人马，暗袭剑阁，被武侯侦知，半路截杀，几至全军覆没。武侯正在筹思进行之策，忽\n接李严告急书，言东吴与魏联合，有兴兵入寇消息，武侯因此退回西川。司马懿命张郃追之，亲自引兵，随\n后接应。武侯已预定计划，暗嘱魏延、关兴引张郃至木门道，塞断归路，万弩齐发，将张郃射死。",
  "notes": "是剧即《三国志演义》所载《出陇上诸葛妆神，奔剑阁张郃中计》第一百零一回之事实。\n按《三国志演义》，武侯与司马懿斗阵，擒获乐琳、张虎，当在四出祁山；司马懿受巾帼女衣，当在六出祁\n山。剧本牵连一处，几乎前后倒置，然参看剧情，尚能贯通融洽，如此点缀，不足为是剧之玷。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延、关兴、马岱同上，同起霸。"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "为国勤劳分所当，"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "扫灭狼烟辅帝邦。"
        },
        {
          "character": "关兴",
          "type": "念",
          "text": "少年慷慨英雄将，"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "凌烟阁上美名扬。"
        },
        {
          "character": "姜维、魏延、关兴、马岱",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "姜维。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "魏延。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "关兴。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "众位将军请了。丞相升帐，不知为的那路军情？"
        },
        {
          "character": "魏延、关兴、马岱",
          "type": "同白",
          "text": "想必是为了失了街亭之事。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "候丞相升帐，便知分晓。我等辕门伺候，请。"
        },
        {
          "character": "魏延、关兴、马岱",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延、关兴、马岱同下。四龙套、四上手、中军、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "道合神明，保社稷，全凭地理天文。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "先皇托孤在白帝，竭力惮心保华夷。误用马谡山人过，失却街亭后悔迟。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫，复姓诸葛名亮，字孔明，道号卧龙。只因误用马谡，街亭失利，追悔不 及，因此重整干戈，以复前仇。 来。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传众位将军进帐。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "众位将军进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延、关兴、马岱同上。"
        },
        {
          "character": "姜维、魏延、关兴、马岱",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "姜维、魏延、关兴、马岱",
          "type": "同白",
          "text": "谢丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人今日兴兵，要报街亭之仇。尔等须要人人努力，个个争先，千万不可怠慢。"
        },
        {
          "character": "姜维、魏延、关兴、马岱",
          "type": "同白",
          "text": "某等遵命。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "兴兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延、关兴、马岱同允。〖泣颜回〗。众人同绕场，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "乐琳、张虎、张郃同上。"
        },
        {
          "character": "乐琳",
          "type": "念",
          "text": "大将生来胆气豪，"
        },
        {
          "character": "张虎",
          "type": "念",
          "text": "全凭一杆雁翎刀。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "东荡西除为上将，"
        },
        {
          "character": "乐琳、张虎、张郃",
          "type": "同念",
          "text": "南征北剿立功劳。"
        },
        {
          "character": "乐琳、张虎、张郃",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "乐琳",
          "type": "白",
          "text": "乐琳。"
        },
        {
          "character": "张虎",
          "type": "白",
          "text": "张虎。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张郃。 二位将军请了。都督升帐，两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "引子",
          "text": "自愧不曾进西城，失却机关事难成。"
        },
        {
          "character": "乐琳、张虎、张郃",
          "type": "同白",
          "text": "参见都督。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "乐琳、张虎、张郃",
          "type": "同白",
          "text": "谢都督。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "丹心为国栋梁材，职受督师拜帝台。龙虎上将分左右，大小儿郎两边排。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本督，司马懿。悔不听次子之言，走了孔明，失了机会，真可惜也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "孔明兵出祁山。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，孔明兵败未久，又出祁山，此来必有诡计。我若不与他，决一雌雄，怎得 干戈休息。 吓，张老将军。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "都督。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "孔明五出祁山，必有诡计，欲烦老将军，作一先行，不知你意下如何？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "末将遵命。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "老将军效力，大事无忧矣。 乐琳、张虎听令。"
        },
        {
          "character": "乐琳、张虎",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "老夫命你二人，以为左右二先锋，带领大兵十万，前往渭河，安营下寨。老夫 大兵随后。"
        },
        {
          "character": "乐琳、张虎",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "乐琳",
          "type": "念",
          "text": "军中领将令，"
        },
        {
          "character": "张虎",
          "type": "念",
          "text": "渭水扎大营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乐琳、张虎同下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "老将军，此番兴兵，必有一番苦战，老将军年迈，诸事须要小心在意。老夫有 言，你且听道。"
        },
        {
          "character": "司马懿",
          "type": "西皮原板",
          "text": "本督帐中开言论， 尊声老将听分明： 西蜀兵将多英俊， 姜维不是等闲人。 马岱、王平威风凛， 还有张苞与关兴。 魏延上阵屡得胜， 孔明诡计不非轻。 老将军年迈八十整， 虽然英勇少精神。 得胜之时莫追赶， 留心提防埋伏兵。"
        },
        {
          "character": "张郃",
          "type": "西皮摇板",
          "text": "都督不必细叮咛， 张郃出兵定小心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃下。"
        },
        {
          "character": "司马懿",
          "type": "西皮摇板",
          "text": "前番不把西城进， 怕他城中有伏兵。 孔明胆量如天大， 我只道他是把稳人。 今日五出祁山整， 定要同他见输赢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、四龙套、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手引诸葛亮同上，四龙套、四下手引司马懿同上，对阵，过场。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "来者敢么是诸葛丞相？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "然也。车前来的，敢是司马都督？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "正是。丞相，我与你在西城一别，未能进城，同你畅叙寒温，不期今日相逢， 可谓三生有幸。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "司马都督，前番大驾，兵临西城，山人那时，城内兵不过千，将不满十，只得 将城门大开，等候都督大驾。不想你竟不辞而去，山人闻之，刻刻在心，渴想 已极，未陪大驾，那才是三生有幸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮冷笑。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "岂敢呐，岂敢。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请问都督，带兵何往？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本督带领人马，要捉拿那些不知天命的山野耕夫。请问丞相带兵何往？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人奉了圣命，带领人马，搜山射猎，要捉拿那些野马鹿獐。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "诸葛丞相，想吾主受禅，相传二帝，坐镇中原，容你主霸占西蜀一方，乃是我 主的仁慈，不忍加害你主，以免生灵涂炭之苦。你乃南阳耕夫，不知天命，勉 强争斗。依本督相劝，何不倒戈弃甲，告职归山，尚可保全性命。再若执迷不 悟，本督兴动大兵，剿灭西蜀，那时管叫你，悔无及矣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "司马懿，你此言差矣。想吾主乃金枝玉叶，帝王根本，起义数十余年，要兴兵 剿灭魏贼，归成一统。是山人不忍残害生灵，屡次谏奏，以免百姓涂炭之苦。 你今既生于人世，因何不知天命，你主乃是乱臣贼子，人人得而诛之。你尚敢 出此妄言，好不知羞耻也。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "丞相，你我今日交兵，也不必以唇舌相斗。你还是斗兵、斗将、斗阵？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "但凭都督。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "你我就斗阵如何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你且摆来，山人观看。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "请来营寨，待吾摆来你看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "众将，将阵式摆开者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "十六龙旗、四方旗同上，同摆阵。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "孔明，你可认得此阵么。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此乃是三仙一气阵。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "可摆得好？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "摆倒摆得好，可惜未曾摆全。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "怎么你道本督还摆得不全？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "正是。你且将阵势收了，待山人也摆上一个小小阵式，要叫你也学学见识。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "好。本督倒要领教。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官，将八卦阵势排开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙旗、四八卦旗、四飞虎旗同上，同摆阵。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "仲达，请来观阵，可认得么？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "此阵摆得，与本督一样，怎么不认得。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "非也。你方才所摆，乃是三仙一气阵。山人所摆，乃九宫八卦阵。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哦，原来是九宫八卦阵，倒也威严整齐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你可破得此阵么？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哪有破不得之理。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
