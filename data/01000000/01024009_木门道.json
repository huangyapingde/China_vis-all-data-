          "character": "张虎",
          "type": "唱",
          "text": "报与都督得知情。"
        },
        {
          "character": "乐琳、张虎",
          "type": "同白",
          "text": "启都督：时才陇上，有许多天兵神将，特来禀报。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "竟有这等之事。带马。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "乐琳、张虎报一信， 倒叫本督吃一惊。 催马来在祁山顶，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿上桌子。姜维引四龙套同上。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "坐定雕鞍看分明。 车上坐的诸葛亮， 跣足蓬头不像人。 天兵神将齐助阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延引四龙套同上。"
        },
        {
          "character": "乐琳",
          "type": "白",
          "text": "又来了一起。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "山下来了二孔明。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "又是一个孔明。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "车夫不像人模样， 仗剑摇旗怕煞人。 乐琳上前听一令， 急速下山追一程。"
        },
        {
          "character": "乐琳",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乐琳下。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "诸葛本是凡人体， 为何一气化三清？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴引四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "又来了一个孔明。共有三个了。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "张虎上前听一令， 前去追赶要小心。"
        },
        {
          "character": "张虎",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张虎下。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "越思越想心不定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引马岱同上，过场，同下。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "一时来了四孔明。 我兵追赶如风卷， 他的车子慢慢行。 众将缘何赶不上， 张老将军快出兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃领四龙套同追下。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "左思右想拿不定， （姜维、魏延、关兴、马岱同上，诸葛亮引四八卦旗同随上，过场，同下。乐琳、张虎、张郃领四龙套同上， 同追下。）"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "因何来了五个孔明？"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "吓得我浑身冷汗淋。 催马且下祁山顶， 此事听吾解不清， 但不知他弄的什么鬼？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哦喝是了。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "他用的六丁六甲神。 三军与爷忙传令， 快快叫他们去出兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延、关兴、马岱、四龙套同上。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "众将官，快快与俺割麦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗，〖牌子〗。"
        },
        {
          "character": "姜维、魏延、关兴、马岱",
          "type": "同白",
          "text": "呔，魏营听者，俺丞相多谢尔的麦粮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延、关兴、马岱同笑，同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "心中只怕是孔明，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃上。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "割去麦粮恨煞人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "那天兵天将俱是蜀营中假扮的。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "都督，如今还是发兵的好。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "还是守的好。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "都督吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃拉式。〖急三枪〗。张郃怒下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "看张老将军，一怒出帐而去，他不知兵法，诚恐有失。待老夫带兵随后接应者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。司马懿、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引姜同上。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "俺，姜维。奉了丞相之令，引张郃进木门道。 众将官，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引魏延同上。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "俺，魏延。奉丞相之命，引张郃进木门道。 众将官，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引马岱同上，四龙套引关兴同上。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "俺，马岱。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "俺，关兴。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "请了。你我奉了丞相之名，截杀张郃，引他入木门道，就此分兵前往。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、四龙套、马岱、四龙套同双下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜维、四龙套同上，张郃迎上，同起打。张郃败下，姜维追下。张郃上，关兴迎上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "关兴。来将通名。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "大将张郃。想你父在日，吾尚不惧，何况你这小儿。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "一派胡言。放马过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张郃同起打，关兴败下。马迎上，同起打，马岱败下。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "藤牌手何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八藤牌同上。"
        },
        {
          "character": "八藤牌手",
          "type": "同白",
          "text": "参见将军。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "一同追赶关兴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、八藤牌手同绕场。"
        },
        {
          "character": "八藤牌手",
          "type": "同白",
          "text": "关兴不见。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "人马收回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、八藤牌手同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马岱引四龙套同上，同断山口。四龙套、八藤牌手引张郃同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "四龙套、八藤牌手",
          "type": "同白",
          "text": "柴木断阻归路了。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "列开旗门。 众将，此是什么所在？"
        },
        {
          "character": "四龙套、八藤牌手",
          "type": "同白",
          "text": "此地名木门道。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "不好了。大将最忌犯了名讳，这獐入木门，定无生理。待俺转去。哎，大丈夫 只有向前，哪有后退之理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "俺来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延、张郃同起打，破藤牌。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "众将，放箭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃中箭死，下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、司马懿同上。探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "张老将军中箭而亡。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "不好了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹牌子。魏延追上。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "呔，司马懿听者：俺丞相兴围打猎，欲射一马，误中一獐。再若来时，定被吾 所擒也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延三笑，下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "众将官，收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同绕场，同下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哎，老将军呐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}