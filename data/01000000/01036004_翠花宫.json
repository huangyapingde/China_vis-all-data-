  "plot": "因护国公死（护国公即秦叔宝），徐茂功、尉迟恭、程咬金三老公爷，同往吊奠。三人知翠花宫妃张金定，\n亦必来吊，因与护国公夫人等，商量安排定当，待其来时，故意怠慢，引其恼怒，与之打架。程咬金出面劝\n解，再加调弄，百般羞辱，以出心头之恨。旋张妃来，果如所云，卒坠计中，被夫人厮打，甚至剥裤落鞋，\n踉跄不堪，且被程咬金调笑一番而去。",
  "notes": "《翠花宫》一剧，按阅剧中事实，系出初唐时代，当在薛仁贵征东前后，然按诸说唐扫北征东等各说部中，\n均无此事。全剧没头没脑，不可捉摸，究不知以何仇怨，而至欲如此被辱。考《征东传》，秦叔宝死于家，\n系在太宗御驾亲征、尉迟恭挂帅之时，徐勣、程咬金等亦均随往，均不在京，未尝有护国公死徐勣、程咬金\n等同往吊奠之事。至张士贵之妹，与秦府究有何亲戚关系，而必欲屈其贵妃之尊，亲往祭吊，亦无考据。既\n往吊矣，又有何大怨仇，而竟欲如此折辱，均难索解。秦腔中剧本，大半如是。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐勣上。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "地为阴来天为阳，九宫八卦腹内藏。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "山人，徐勣，唐皇驾前为臣。今因护国公已死，是山人要请诸位国公，前去吊 祭。天到这般时候，为何不见到来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "禀爷：诸位国公到。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。尉迟恭、程咬金同上，同进门，入座。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "不知国公驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "程咬金、尉迟恭",
          "type": "同白",
          "text": "岂敢。我等来得鲁莽，先生恕罪。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "程咬金、尉迟恭",
          "type": "同白",
          "text": "吓先生，邀请到此，有何军情议论？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "护国公已死，要请一同前去，过府吊祭，国公心下如何？"
        },
        {
          "character": "程咬金、尉迟恭",
          "type": "同白",
          "text": "吓先生讲得哪里话来？同在朝中奉君，焉有不去之理？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "好，你我去到后面，用过酒宴，一同前去。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "吓先生，我想张士贵之妹张金定，必然前去吊祭。你我拿她取笑一场，方去了 我心头之恨。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "吓国公，此事万万使不得。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不要紧，全有我哪！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "全仗国公。请在后面。"
        },
        {
          "character": "程咬金、尉迟恭",
          "type": "同白",
          "text": "先生请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "院子上，打扫灵堂。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请管家爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "管家上。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "打扫已毕。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你且退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦夫人上。〖吹打〗。秦夫人哭。"
        },
        {
          "character": "秦夫人",
          "type": "梆子二六板",
          "text": "见灵堂不由我泪流满面， 止不住泪珠儿打落胸前。 叩罢头来身站定， 再叫管家听我言。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "吓管家，如若有人前来吊祭，早禀我知。伺候了。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "吓吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦夫人下。院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启禀管家爷：诸位国公前来吊祭。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦夫人上。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "诸位国公前来吊祭。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。徐勣、尉迟恭、程咬金同上，同祭奠。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "众位国公请坐。"
        },
        {
          "character": "徐勣、尉迟恭、程咬金",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "众位国公前来吊祭，奴家当面谢过。"
        },
        {
          "character": "徐勣、尉迟恭、程咬金",
          "type": "同白",
          "text": "当得一祭。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "吓众位国公，我想今日，翠花宫张金定这奸妃，必来吊祭。她若到此，全仗众 位国公之力。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不要紧，奸妃到此，有我咬金，打发她回去。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "你又来多事。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "众位国公，请在后面摆宴。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老黑，且到后面吃酒，吃得饱饱的。等奸妃到来，打她一回，出出我们大家气。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你我等候便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、尉迟恭、程咬金、秦夫人同下。大太监跑上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "哈哈哈哈哈，别走了，我家娘娘还未摆驾哪，我先出来了。瞒了上了，待我请 驾。 有请娘娘。"
        },
        {
          "character": "张金定",
          "type": "内梆子导板",
          "text": "翠花宫又来了张金定，"
        },
        {
          "character": "张金定",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二宫女引张金定同上。"
        },
        {
          "character": "张金定",
          "type": "梆子慢板",
          "text": "我去到护国公去看分明。 他本是我朝中一员上将， 东挡西杀如今归了阴城。 我念他为江山功劳之大， 因此上去吊祭表表美名。 内侍臣摆驾往前来进， 又听得内侍报一声。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏娘娘：来到国公府，请娘娘住驾。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太与我更衣来。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。张金定当场换衣。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太保驾来。"
        },
        {
          "character": "张金定",
          "type": "梆子二六板",
          "text": "叫张太保驾往前行， 你听我把话说分明： 此去若有别的事， 早奏摆驾速回宫。 正行用目来观定， 吊祭一毕转回程。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏娘娘：来此府门。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "侍儿们退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二宫女同下。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "娘娘什么事？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "我想起事情来了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "想起什么事？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "想我们在翠花宫里无一不乐，今日出得宫来，有点不开心。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "我说娘娘，我们出宫作什么来？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "我们来吊祭来了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "这不完了。吊祭说吊祭的话，什么又不开心了。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太，吊祭还要说什么话？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "哎呀，怎么连吊祭的话，都不会说么，都不会说么？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太你想，我也无有出过门，晓得说什么？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "你无有出过门，你们家里就无有死过人哪？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "胡说。我问你晓得不晓得哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "我倒晓得一点。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "你是晓得的？你们家里常常死人哪！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "别玩笑。你在这里坐坐，我去看看。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "你回来。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "你说翠花宫娘娘吊祭来了，对不对？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "我与你对了——"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "什么呀？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "花头儿。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "快快去说。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "晓得了。 我看看这门外头，连一个人也无有，不像办事的来头。许是我们走错了，快快 回去。且慢，要是回去，不是白来了。待我上前叫一声。 呔！里面有人么？滚出一个来！"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "这是什么人，怎么说话呀？有人滚出一个来？我也不是鸡蛋。我看看是什么人？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "呔！快快地滚出来吧！"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "哈哈！我当是什么人哪，原来是亲家。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "可不是我。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "好王八蛋！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "亲家，你怎么骂我呀？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "我不是骂你，骂我把亲家耽误了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "这是什么话？今日亲家见亲家。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "亲家是我儿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "我儿是亲家。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "别玩笑。我说亲家你好？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "好好。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "老爷子、老太太全好？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "全好。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "我们亲家母也好？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "她也好。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "亲家你那大儿可好？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "也好。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "他做什么生意哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "现在戏园子里卖票哪。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "听说你又得了一个姑娘。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "可不是还小哪。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "多大了？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "才三个月。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "哎呀，少来贺喜，亲家别怪。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "亲家，你我全是自家人，不过套言，当面谢谢。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "好说好说。我来问你：你是个内监，怎么还有许多的儿女哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "我是半路出家。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "我看你这儿女，全是我的种儿，是不是？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "你可把我们骂苦了。什么东西，别玩笑啦。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你做什么来的？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "往里去说：翠花宫张千岁前来吊祭。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "哦，张金定这个奸妃，前来吊祭来了？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你们吊祭，带来什么祭礼哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "我们来得急速，把祭礼忘了。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "我看你们不是吊祭来了，不晓得又是害人来了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "别胡说。我有祭礼。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "拿出来，我们看一看。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "给你看，这不是祭礼？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "哪里偷来的两张白纸，到这里来吊祭。快快拿回去，上你们家的坟去吧。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "什么话，礼轻人情重，快快地说去，我们还有事哪。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你再等等，待我去说。 有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦夫人、徐勣、尉迟恭、程咬金同上。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "今有翠花宫张金定前来吊祭。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "怎么说？这个奸妃前来吊祭来了？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "对她去说：在朝今日害文，明日害武，害来害去，害到这里来了。叫她回去， 不必吊祭了。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "是。 那小子过来。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "那小子叫谁哪？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你过来吧！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "里面怎么说的？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "我们夫人说了：张金定这个奸妃，今日在朝害文，明日害武，害来害去，又到 这里来害我们来了。叫她快快回去，不必吊祭了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "哈哈，你们好大的架子。 启奏娘娘：他们说出话来了。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "他们怎么说哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "哈哈，好你个张金定，今日在朝害文，明日在朝害武，害来害去，害在我们头 上来。快快叫她滚回去，不必吊祭了。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "好你个奴才，还敢骂我！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "回禀娘娘：这话全是他们说的。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "好一小贱人，说出无情之话。待我回宫，自有道理。 内侍摆驾回宫。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "且慢回宫。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太，为何阻驾？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏娘娘：我们做什么来了？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "前来吊祭来了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "这不完了。特来吊祭，连个人的面也无有相见，有何脸面回去哪。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "你说这话不差，依你怎么样哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "依我说呀，你听听对不对：我们占的大，他们占的小，今日前来吊祭，给他们 多大面子，他们给脸不要脸，叫见也得，不叫见也得，今日偏要见定了。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "你这说的倒是人话，快快去说。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "是。 呔！那小子！再给我滚出来吧！"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "又是什么哪？ 哈哈你这小子，又来做什么？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "对你说，我们张千岁说了：她占的大，你们占的小，今天到你们这里来吊祭， 给你们多大的面子，怎么叫我们回去？我们千岁，有点难为情，你们给脸不要 脸，叫见也得见，不叫见也得见，今天见定了。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你们真不要脸。不叫见，快快滚回去，这不是在你们家里，那想说什么就是什 么，今天一定不叫见。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "一定要见。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "一定要见，无有你们什么好处。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "少说废话，快去说。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "禀夫人：张金定又说，叫见也得见，不叫见也得见，今天一定要见。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "吓，众位国公，张金定今天一定要见，可容她一祭？"
        },
        {
          "character": "徐勣、尉迟恭、程咬金",
          "type": "同白",
          "text": "我等在此，还有什么大事？叫进来一祭。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "是。 那小子，我们夫人叫你进去一祭快快地。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "晓得了。 回禀娘娘：他们说了，叫我们进去一祭。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "怎么，叫我吊祭？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太保驾来。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "又怎么不去？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "娘娘你想，他叫我们去，这话有点不好听。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "怎么不好听？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "要加一个“请”字，那才成话。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "对呀。你去说去。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "待我去说。 呔！那小子出来！"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你这小子，又讲什么？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "我们千岁说：我们是客，怎么叫我们进去？连个“请”字都无有？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你这叫请不是一样，给你进去就完了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "什么话！还是“请”字好听。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "就算“请”字。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "这不得了。 回禀娘娘：里面有请。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "这还罢了。张太，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "娘娘。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "保驾来。"
        },
        {
          "character": "张金定",
          "type": "梆子二六板",
          "text": "又听得里面一声请， 我心明来她不明。 张太保驾往前进，"
        },
        {
          "character": "程咬金、尉迟恭",
          "type": "同白",
          "text": "呔！我想那张金定，今日进得府来，是要打她一个样儿出来。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "吓国公，少时张千岁到来，不要莽撞。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "先生不要你管。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "我说这个张太，我看见里面，有许多人说话，那都是什么人呀？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "娘娘不认得他们？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "不认得。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "那就是我朝的众国公。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "哦，那就是我朝里国公？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "我来问你，那一个白胡子老头，他是什么人？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "那就是保朝的徐勣老臣。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "这就是了。张太，你看那一个戴香炉帽子的，他是什么人哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "他就是尉迟恭敬德。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "哦，老黑老黑就是他呀？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "还有那一个，脸上长的像花鸡蛋似的，他叫什么？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "那就是鲁国公程咬金。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "哦，他就是咬金哪？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太，他们在这里，许多不便，我们回去吧。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "回禀娘娘：我们是君，他们是臣，见见何妨？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "见得的？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "见得的。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太保驾来。"
        },
        {
          "character": "张金定",
          "type": "梆子二六板",
          "text": "许多的人为何情？ 将身来到灵堂上， 叫一声国公在上听： 你为江山丧了命， 你的子孙有了功。 叩罢头来身站定， 再叫张太听分明。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "奴家见驾，娘娘千岁！"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "不消。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "不消就不消。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "吓国公，娘娘到此，还不上前见驾？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "要见你们见，某家不见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "这个老黑，见见她费了什么？待我前去见驾，我还要调戏她一回。 臣程咬金见驾，娘娘千岁！"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "罢了。看看你好不好，长得真不错。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "不要胡说。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "先生，你别做好人了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "待我来见驾。 老臣见驾。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "我看这大年纪，不见也罢。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "这倒罢了。哈哈哈哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣下。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你们看先生对了心思了，乐了，真真不错。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "我说夫人，你过来。你们这里，哪里来的许多乱人哪？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "吓嫂嫂，她骂你是贱人。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "吓千岁，你为何骂我是贱人？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "哎呀你听错了，我说你们这里，哪里来的许多乱人？哪一个说是贱人啦？"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "你本来骂我是贱人。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "哈哈，我这里说无有骂你，你一定说我骂你。你想想，我占的大，你占的小， 漫说无有骂你，就是骂你，还敢把我怎么样？"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "你要骂，我也要骂你！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "嫂嫂自管骂她，有我在。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "你骂我什么？"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "我骂你张金定！"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "哈哈，好大的胆子！叫我张金定。进前来。"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "讲说什么？"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "招打！"
        },
        {
          "character": "秦夫人",
          "type": "白",
          "text": "哈哈！你真打呀！咱二人打打看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张金定、秦夫人同入帐子。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哈哈，她们二人打起来了。我看看打人的。哈哈哈哈。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "好，来的不错。他们这里讲打呀，我也找一个来打打看。"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "哈哈，好一个张金定，到我们这里来讲打呀，好好好，我也找一个来打打看。 呔！那小子过来！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "管家",
          "type": "白",
          "text": "你们真不讲理，到这里打我们，今天咱们二人，也要打打看！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "来打打看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监、管家对打，管家追大太监同下。张金定、秦夫人同出帐子，对打。秦夫人将张金定打倒下。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "张太保驾来！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "快快搀起我来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "娘娘起来，是我。"
        },
        {
          "character": "张金定",
          "type": "白",
          "text": "哎呀我的妈呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张金定跑下，秦夫人追下。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哈哈哈哈，真真好看，我去叫他们看上一看，哈哈哈！ （程咬金下。张金定、秦夫人同上，对打，秦夫人脱张金定裤子，张金定跑下，秦夫人追下。程咬金、徐勣、 尉迟恭同上。）"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "吓先生、老黑，他们打起来了，走走走，看看去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金拾裤子。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "吓，你手拿何物？"
        },
        {
