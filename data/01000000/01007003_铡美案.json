{
  "script_id": "01007003",
  "title": "铡美案",
  "alias": [
    "不认前妻"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "秦香莲",
      "hangdang": "旦"
    },
    {
      "name": "陈士美",
      "hangdang": "老生"
    },
    {
      "name": "公主",
      "hangdang": "旦"
    },
    {
      "name": "国太",
      "hangdang": "老旦"
    }
  ],
  "plot": "韩琪既自杀，秦香莲遂拾取其刀，迳投包拯处控告。包拯准之，方欲招陈士美，适陈士美亦至，以盗杀韩琪\n事来谒。包拯遂以秦香莲状递陈士美阅看，并劝其相认。讵陈士美力讳无妻。包拯命秦香莲面质，陈士美一\n味以势相恐吓，卒不认。包拯怒甚，命左右褫陈士美衣。执付铡刑口。公主及太后闻信相继至争救。包拯始\n犹豫，似觉进退两难。既见太后等，徒以皇亲势相凌，遂决弃官殉法，乃自免其冠，卒铡陈士美。",
  "notes": "此剧为《柳林池·韩琪杀庙》之后本。刘永春演此，气旺神流，尊威严重，真有凛凛不可犯之概。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "包拯引张龙、赵虎同上。"
        },
        {
          "character": "包拯",
          "type": "引子",
          "text": "忠心赤胆，扶宋室，锦绣江山。"
        },
        {
          "character": "包拯",
          "type": "念",
          "text": "铁面无私做南衙，文臣武将胆战麻。任他皇亲并国戚，犯法难逃虎头铡。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老夫包拯。时才下朝回来，偶遇秦香莲，拦轿喊冤，状告当朝驸马陈士美，杀 妻灭子。老夫命她前去写状，为何不见到来？左右伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉引秦香莲同上。"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "叩见相爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "呈状。"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓！老夫命你前去写状，为何还是白纸呈上？"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "状告当朝驸马，无人敢写。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哦。状告当朝驸马，无人敢写。来，将她带在官代书写状。有人不写，抓来见 我。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉引秦香莲同下，圆场，同上。"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "呈状写毕，大人过目。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "呈上来： “具告状氏女秦香莲，年三十二岁，状告当朝驸马陈士美，杀妻灭子，后婚男 儿，招为东床驸马。” 来，将状押过，带下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，拿我名帖，请驸马过府一叙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉允。"
        },
        {
          "character": "太监",
          "type": "内白",
          "text": "驸马到。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "驸马到。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哦，我正要请他，他倒来了。有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、一小太监引陈士美同上。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马，"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "明公。"
        },
        {
          "character": "包拯、陈士美",
          "type": "同笑",
          "text": "哈哈哈。"
        },
        {
          "character": "包拯、陈士美",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "不知驸马驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "岂敢。本宫来得卤莽，明公恕罪。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马到此，必有所谓。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "我命家人韩琪，出府私访，被响马杀死，特到明公台前审问。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "响马可曾带到？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "已经带到。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "何不带上堂来？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "来，带响马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监引王朝同上。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "参见相爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓。你可是王朝？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "正是王朝。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "为何项带铁链？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "驸马爷言道韩琪是小人杀死，故而项带铁链。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你可招认？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "招认了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓。人命关天，尔就不该招认。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "小人若不招认，驸马爷焉能过府？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓。驸马，此乃是臣府王朝，怎说是响马？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "明明响马，怎说王朝？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "王朝也罢，响马亦好。来，将他铁链去掉。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "且慢！走脱响马，那还了得？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马你来看，走脱了响马，走不脱臣老包。铁链去掉。 吓，驸马，真响马被为臣拿住了。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "哦，被明公拿住了？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "并非一人？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "三五成群。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "何不带上堂来？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，带响马秦氏香莲。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "香莲走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲上。"
        },
        {
          "character": "秦香莲",
          "type": "西皮摇板",
          "text": "忽听相爷一声叫， 急忙上前问根苗。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "一见贱人心头恼， 三番两次把我招。 三尺龙泉出了鞘， 管叫一命赴阴曹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马你太莽撞了，哈哈哈。她母子找上京来，你就该相认才是。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "住了！本宫命你审问响马，怎么你到盘起本宫来了。来，搭轿。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "回府。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "只恐你来得去不得！"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "包龙图打坐在开封府，"
        },
        {
          "character": "包拯",
          "type": "西皮快三眼",
          "text": "尊一声驸马爷细听端的： 曾记得端午日朝贺天子， 在朝房与驸马相过了面皮。 我相你左眉长来右眉短， 左膀高来你的右膀低。 眉长眉短有儿女， 膀高膀低你定有前妻。 我劝你相认是正理， 祸到临头后悔迟。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "明公，"
        },
        {
          "character": "陈士美",
          "type": "西皮原板",
          "text": "明公说话言太浅， 细听本宫表家园： 甲子年前开科选， 天下的举子来求官。 头一名就是陈士美， 御笔亲点为状元。 跨马三日游宫院， 金枝玉叶配良缘。 一无证，二无见， 叫我招认为哪般？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马，"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "驸马爷不必巧言讲， 现有凭据在公堂。 人来看过香莲状，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝递状。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马，"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "驸马爷仔细看端详： 上写着秦香莲三十二岁，状告当朝驸马郎。 欺君主，灭皇上， 后婚男儿招东床。 将状纸押在爷的大堂上， 尊一声驸马听端详： 劝你相认回府往， 咬定牙关你就为哪桩？"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "既是有人将我告， 就该升堂问根苗。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "口似沙糖舌如刀， 心似狼虎未长毛。 叫我升堂有什么好， 霎时叫你魂魄消！ 人来击鼓站堂道， 带上了秦香莲，叫她认夫豪。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "香莲走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲领二小孩同上。"
        },
        {
          "character": "秦香莲",
          "type": "西皮摇板",
          "text": "忽听相爷一声叫， 急忙上前问根苗。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "大堂坐的陈士美， 看他把你怎开销？"
        },
        {
          "character": "秦香莲",
          "type": "西皮摇板",
          "text": "听说儿夫驾来到， 不由香莲喜眉稍。 走上前来忙跪到，"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "一掌打在地埃尘！"
        },
        {
          "character": "秦香莲",
          "type": "西皮摇板",
          "text": "上前挖了你的眼，"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "这一足要你命归阴！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲、二孩子同哭。"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "二娇儿哭得珠泪滚， 铁石人儿也伤心。 本当上前将妻认， 包拯是我对头人。 咬定牙关不招认， 看他把我怎样行？"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "你命韩琪行霸道， 来在我的公堂你敢不招！"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "我命韩琪谁知晓？"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "现有你府杀人刀。"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "为何有刀没有鞘？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "秦香莲",
          "type": "西皮摇板",
          "text": "刀鞘现在韩琪腰。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "土地祠内取刀鞘，"
        },
        {
          "character": "王朝",
          "type": "西皮接唱",
          "text": "刀鞘付于相爷瞧。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "着着着！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "大堂之上刀对鞘， 件件是实你敢不招？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "大堂之上刀对鞘， 寻个计策好脱逃。 人来与我忙搭轿，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "我和你上殿奏当朝。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "开封府有人将你告， 你先打官司后上朝。"
        },
        {
          "character": "陈士美",
          "type": "西皮摇板",
          "text": "既是有人将我告， 你把我东床驸马怎开交？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "慢说你是驸马到， 就是哪龙子龙孙我也不饶。 头上摘去你的乌纱帽， 身上再脱去你的滚龙袍。 芦席捆了陈士美，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "陈驸马，"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "包明公。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "陈士美，"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "包黑子。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "忘恩无义不可交。 曾对老天来祝告， 贪财误国怎姓包？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "刽子手，"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "将陈士美搭在铡口到， 我将他正了国法，再奏当朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、二宫女引公主同上。"
        },
        {
          "character": "公主",
          "type": "西皮慢板",
