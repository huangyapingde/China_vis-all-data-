{
  "script_id": "01009010",
  "title": "伐子都",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "公孙阏",
      "hangdang": "武生"
    },
    {
      "name": "颖考叔",
      "hangdang": "净"
    },
    {
      "name": "郑庄公",
      "hangdang": "老生"
    }
  ],
  "plot": "考《列国志》，载郑庄公约定齐、鲁二国，会师伐许，先在国中行大阅告天之礼，特制鍪弧大旗，旗幅方一\n丈二尺，竿长三丈三尺，建于铁车之上，下令有能举大旗，步履如常者，拜为前锋，并赐以辂车。大夫瑕叔\n盈先举，次，颖考叔复出，拔旗飞舞如游龙，舒卷自如，绝不变色，观者咸惊服。庄公即以车赐颖考叔，不\n意有公孙阏（即子都）者，抢出欲与颖考叔争夺，且自谓亦能舞旗。颖考叔即右手举旗，左手挟铁车而走，\n子都拔画戟出追，几至用武决斗，幸郑庄公即传语和解，三人各得赐车而散。适七月伐许，兵临许城，初攻\n不下，至第三日，颖考叔身先士卒，奋勇执鍪弧，从车一跃，首先登陴，不意子都忌其功，遂从暗中阴发一\n箭，颖考叔竟被殪，大旅亦倒，几误大局。幸瑕叔盈愤极，随亦挟旗登城，并绕城疾走大呼曰：“郑伯已登。”\n众军望见鍪弧，无不格外奋勇争先，遂乘势一涌而上，乃入许国。此志载夺功时之大略也。后既平许，\n班师归国，郑伯厚赏瑕叔盈，并思念颖考叔，深恨阴伤颖考叔之人，而不得其名。乃使随征各将士，分若干\n队，各宰鸡犬猪羊等牲，召巫史为文，以咒诅之。讵咒诅至日，而公孙子都，竟蓬头垢面，迳造郑伯之前，\n跪哭沥陈其冤，身为子都所害云云。语讫，即以手自扼其喉，喉破血注而死。此则志载冤报时之大略也。",
  "notes": "惟与剧本，则均有大同小异之处。此剧系东周列国故事。本出《左传》，惟《左传》只有与瑕叔盈夺鍪弧先\n登一事，并无与颖考叔争功射死各节。惟与《列国志》演义中，则大致相符，然剧中所谓惠南王，则亦不知\n何本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、马夫同上。〖吹打〗。公孙阏上。〖点绛唇〗。"
        },
        {
          "character": "公孙阏",
          "type": "念",
          "text": "头带二龙凤翅盔，银叶铠上雪花飞。跨下白龙马一骑，上阵袖箭把命追。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "俺，复姓公孙，名阏，字子都，郑庄公驾前为臣。奉了大王旨意，四乡查旱， 查旱已毕，回朝复命。 家将，起兵回朝，带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "颖考寇、白吉同上。"
        },
        {
          "character": "颖考寇",
          "type": "念",
          "text": "站在朝堂下，"
        },
        {
          "character": "白吉",
          "type": "念",
          "text": "同是忠义臣。"
        },
        {
          "character": "颖考寇",
          "type": "白",
          "text": "下官考寇。"
        },
        {
          "character": "白吉",
          "type": "白",
          "text": "下官白吉。"
        },
        {
          "character": "颖考寇、白吉",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "颖考寇",
          "type": "白",
          "text": "惠南王打来连环战表，要夺我主江山，大王升殿，一同启奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四小太监、大太监引郑庄公同上。"
        },
        {
          "character": "郑庄公",
          "type": "引子",
          "text": "笙歌嘹亮乐安康，文武定国保朝纲。"
        },
        {
          "character": "郑庄公",
          "type": "念",
          "text": "平顶冠上九龙头，太阳一出照九州。蓝田宝带朝北斗，龙眉一皱百官愁。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "孤王，郑庄公。登基以来，四方宁静，八面安然，可算太平之象，今当早朝。 众卿有本早奏，无本退班。"
        },
        {
          "character": "颖考寇、白吉",
          "type": "同白",
          "text": "臣等有本：今有惠南王，打来战表，请大王御览。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "呈上来，待孤观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "哎呀，原来惠南王，不遵国法，要夺孤王江山。 考爱卿，"
        },
        {
          "character": "颖考寇",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "命何人挂帅前去征讨？"
        },
        {
          "character": "颖考寇",
          "type": "白",
          "text": "启千岁：就命吾儿考叔挂帅，不知大王意下如何？"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "准奏。宣考叔上殿。"
        },
        {
          "character": "颖考寇",
          "type": "白",
          "text": "大王有旨：宣考叔上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "分班。颖考寇、白吉同下。"
        },
        {
          "character": "颖考叔",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔上。"
        },
        {
          "character": "颖考叔",
          "type": "念",
          "text": "朝靴踏地响，上殿见君王。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "臣考叔见驾，愿大王千岁！"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "今有惠南王打来战表，要夺孤王江山。你父保奏，命你挂帅前去征讨，卿可愿 否？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "为将者理当报效朝廷，岂可坐食君禄。请大王圣旨，臣愿往。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "就命卿家挂帅，前去征剿，得胜回朝，另加升赏。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "公孙阏",
          "type": "内白",
          "text": "子都上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏上。颖考叔抱印与公孙阏对面，颖考叔下。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "臣子都见驾，大王千岁。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "孤命你下乡查旱，怎么样了？"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "臣奉命查旱，四方安静。正要上殿交旨，行至午门，观见考叔，抱元帅大印， 他往何处征剿？"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "爱卿不知：今有惠南王，打来战表，要夺孤王江山，特此命他挂帅前去征讨。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "启千岁：我想考叔父子，身无寸箭之功，官卑职小，怎能挂帅印？臣有本启奏。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "大王容禀：此帅印，本是我父南征北剿，挣得元帅印信。臣愿效犬马之劳，千 岁将帅印追回，命臣前去征剿惠南王。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "如此殿角伺候。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "内侍，宣考叔上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "考叔上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔上。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "臣去的好好，千岁追回，是何意见？"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "孤家命你挂帅，子都心怀不服。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "待臣去见。 公孙大人请了。现有惠南王打来战表，要夺我主江山，千岁命我为帅，你心中 不服，是何道理？"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "考大人，我想这帅印，乃是我父南征北剿，挣来的功劳，是我分内之事，被你 挂去，俺便不服。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "公孙大人，岂不知："
        },
        {
          "character": "颖考叔",
          "type": "念",
          "text": "上有皇王三略法，"
        },
        {
          "character": "公孙阏",
          "type": "念",
          "text": "文韬武略定邦家。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "俺也曾南征北战。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "我也曾东荡西除。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "你杀过哪个？"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "你征战哪个？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "小畜生！"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "老匹夫！"
        },
        {
          "character": "颖考叔、公孙阏",
          "type": "同白",
          "text": "看笏！"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "且慢！为孤江山，二卿不要争斗。老王留下铜旗铁车，有人举起铜旗，拉动铁 车，就为元帅。"
        },
        {
          "character": "颖考叔、公孙阏",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔、公孙阏自两边分下。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "内侍，看车辇校场去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、马夫、公孙阏同上。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "俺，子都。奉了大王之命，去至校场，举旗拉车，斗赌输赢。 家将催马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、马夫、颖考叔同上。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "俺，考叔。奉了大王旨意，举旗拉车，以赌输赢。 家将催马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、大太监引郑庄公同上。〖牌子〗。四文堂、马夫、公孙阏同上。四下手、马夫、颖考叔同上。"
        },
        {
          "character": "颖考叔、公孙阏",
          "type": "同白",
          "text": "来在校场，哪个先举？俺要先举！"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "二卿不必争论，为主江山，子都往后，考叔举来。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "颖考叔",
          "type": "西皮导板",
          "text": "吾主校场把旨传，"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "哪个胆大不尊言。"
        },
        {
          "character": "颖考叔",
          "type": "西皮快板",
          "text": "校场以内把衣换，"
        },
        {
          "character": "公孙阏",
          "type": "西皮摇板",
          "text": "举旗拉车各争先。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。颖考叔举旗拉车。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "且住，观见考叔举动铜旗，拉动铁车，待俺紧紧追上，俺这一剑，杀这老匹夫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏追颖考叔同下。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "哎吓，且住！观见子都面带凶恶，恐其考叔有伤。 内侍将尚方宝剑挂起。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏、颖考叔同上，同下。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。公孙阏、颖考叔同上。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "臣等举旗拉车已毕。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "考叔以为正帅，子都与为副帅。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "且住，金殿之上，挂他以为正帅，俺为副帅，但等阵前，用袖箭伤尔的性命。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "内侍看酒，孤与二卿饯行。"
        },
        {
          "character": "郑庄公",
          "type": "西皮原板",
          "text": "吩咐内侍看琼浆， 孤与二卿饯阳关。 但愿得胜回朝转， 孤王迎接午门前。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "吾主金殿设琼浆， 为臣校场点儿郎。 不是为臣夸大口， 管叫各国来投降。 辞别主公下殿往， 不杀考叔不还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏下。"
        },
        {
          "character": "颖考叔",
          "type": "西皮散板",
          "text": "惠南王作事好大胆， 无故起意夺江山。 辞别大王下金殿， 不杀南王不回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔下。"
        },
        {
          "character": "郑庄公",
          "type": "西皮散板",
          "text": "侍臣与孤搀车辇， 且在宫中乐安然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、马夫、公孙阏同上。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "俺，子都。兵行两军阵前，是俺不听老匹夫将令，独自出兵先抢头功。 众将杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四手下、四下手、四女兵、惠王公、惠正公、惠南王同上。〖牌子〗。"
        },
        {
          "character": "惠南王",
          "type": "白",
          "text": "俺，惠南王。"
        },
        {
          "character": "惠王公",
          "type": "白",
          "text": "惠王公。"
        },
        {
          "character": "惠正公",
          "type": "白",
          "text": "惠正公。"
        },
        {
          "character": "惠南王",
          "type": "白",
          "text": "可恨郑庄公行事不正，将太后打在牛皮山下受罪，为此统领人马，与国太报仇。 呔，巴都儿，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、马夫、颖考叔同上。〖牌子〗。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "俺，考叔。适才家将报道：副元帅独自出兵，恐其手失。 家将催马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四手下、四下手、四女兵、惠王公、惠正公、惠南王同上。四文堂、马夫、公孙阏同上。两边会阵。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "马前来的敢是惠南王？"
        },
        {
          "character": "惠南王",
          "type": "白",
          "text": "然也！"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "大胆南王，吾主有何亏负于你，胆敢兴兵犯界！"
        },
        {
          "character": "惠南王",
          "type": "白",
          "text": "可恨庄公行事不正，无故将太后打在牛皮山，为此统领下兵，前来与太后报仇。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "休得胡言，看枪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。惠南王败，公孙阏子追。四下手、马夫、颖考叔同上，开打。颖考叔败下，公孙阏追下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四手下、四下手、四女兵、惠王公、惠正公、惠南王同上。"
        },
        {
          "character": "惠南王",
          "type": "白",
          "text": "且住，他等杀法厉害，今晚三更时分，偷营劫寨，必然成功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、马夫、颖考叔同上，四文堂、马夫、公孙阏同上。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "方才两军阵前，多亏副元帅救我回营。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "军队胜败，古之常理。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "众将官，今晚人不卸甲，马不离鞍，就此安营下寨。 （起三更。四手下、四下手、四女兵、惠王公、惠正公、惠南王同上。开打。惠南王败下，众人同追下。众 人同上，颖考叔劈惠南王。众人同进城。四文堂、马夫、公孙阏同上。）"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "且住，一步来迟，老儿占了城池。趁此机会，下得马去，俺的袖箭成功。 城上敢是正元帅？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "城下敢是副元帅？"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "可曾得了城池？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "已得。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "末将到此，因何不开城池？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "哪有不开之理。 众将官开城。 副元帅请进。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "你敢是正元帅？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "请来见礼。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "还礼。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏打袖箭，颖考叔中箭，下。"
        },
        {
          "character": "公孙阏",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏下。马夫上。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "且住，观见子都，将我家元帅射死，待俺进城与他辩理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏上，四下手、马夫同上。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "呔，子都！将我元帅射死，是何道理？"
        },
        {
          "character": "子都",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "子都",
          "type": "白",
          "text": "小小跟人，说此狂言！"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "说此狂言，你敢把俺怎么样！"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "向前讲话。 看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫下。"
        },
        {
          "character": "下手",
          "type": "同白",
          "text": "马夫带箭。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "搭下去。 可惜了本帅一箭，射死他主仆二人。 众将官，吩咐带马，与我打得胜鼓，就此班师回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马夫上，起霸，洗马。〖吹打〗。四下手同上，过场。公孙阏上，众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒、马夫、颖考叔同上。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "我乃考叔鬼魂是也。可恨惠南王打来战表，圣上命我为帅。子都小儿，心中不 服，大王传旨教场，举旗拉车，那时俺举起铜旗，拉动铁车，千岁挂我为帅。 子都私自出兵，家将报知，是我一马赶至阵前，刀劈惠南王，占了城池。子都 来迟，开城迎接，谁知他用袖箭，将俺射死城下。玉帝见俺可惨，封为忠孝将 军。今奉上帝敕旨，回朝讨封，二来辞别我父，三来要伐子都。 众神将驾云前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒同允。众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "颖考寇、白吉同上。"
        },
        {
          "character": "颖考寇",
          "type": "念",
          "text": "子都回朝转，"
        },
        {
          "character": "白吉",
          "type": "念",
          "text": "上殿奏当朝。"
        },
        {
          "character": "颖考寇、白吉",
          "type": "同白",
          "text": "请了。香烟缭绕，圣驾临朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引郑庄公同上。"
        },
        {
          "character": "郑庄公",
          "type": "引子",
          "text": "凌烟阁上文和武，全凭子都保华夷。"
        },
        {
          "character": "颖考寇、白吉",
          "type": "同白",
          "text": "启大王：子都得胜回朝。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "孤王有言在先，二卿得胜回朝，孤亲自相迎。 内侍，车辇伺候，摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖吹打〗。四鬼卒、马夫、颖考叔同上，过场，同下。四太监、颖考寇、白吉、郑庄公同上。四文堂、马"
        },
        {
          "character": null,
          "type": "text",
          "text": "夫、公孙阏同上，过场，同下。四鬼卒、马夫、颖考叔同上，过场，同下。四文堂、马夫、公孙阏同上。）"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "爱卿不必下马，孤敬酒三杯。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "臣不敢。"
        },
        {
          "character": "颖考寇、白吉",
          "type": "同白",
          "text": "臣代劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 17,
      "name": "第十七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四鬼卒、马夫、颖考叔同上高台。四太监、颖考寇、白吉、郑庄公同上。四文堂、马夫、公孙阏同上。文"
        },
        {
          "character": null,
          "type": "text",
          "text": "堂、马夫同下。）"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "臣子都见驾。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "为主江山血染战袍，内侍与爱卿当殿卸甲。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "臣参见千岁！"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "二卿扶起。"
        },
        {
          "character": "颖考寇、白吉",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "吓，子都，为何不见正元帅回来？"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "那正元帅，命丧阵前了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同哭。〖牌子〗。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "爱卿得胜回朝，内侍摆宴，与副元帅贺功，待孤把盏。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "臣不敢。"
        },
        {
          "character": "颖考寇、白吉",
          "type": "白",
          "text": "命臣代劳。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "郑庄公",
          "type": "西皮慢板",
          "text": "忠臣良将应褒奖， 血染战袍回朝房。 传旨我把二卿叫， 速替孤王赠琼浆。"
        },
        {
          "character": "颖考寇",
          "type": "西皮散板",
          "text": "大王旨意往下传，"
        },
        {
          "character": "白吉",
          "type": "西皮散板",
          "text": "为臣怎敢不听言。"
        },
        {
          "character": "颖考寇",
          "type": "西皮散板",
          "text": "即忙斟上一杯酒，"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "二大人。"
        },
        {
          "character": "公孙阏",
          "type": "西皮散板",
          "text": "大人递酒忙向前。 用手接过梨花盏， 霎时间来在鬼门关。 刀劈了惠南王功劳威显，"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "小马童也算得战将魁元。 小子都行此事暗地短见， 用袖箭射死我一命归天。 站立在银銮殿用目观看， 又只见小子都站立面前。 上前来抓住了丝鸾宝带， 今日里拿住儿要报仇冤。 文武臣对我言圣驾来到， 念在那同朝班把你恕饶。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "抬头只见老爹尊， 孩儿把话对你言： 可恨子都太短见， 袖箭害儿染黄泉。"
        },
        {
          "character": "颖考寇",
          "type": "白",
          "text": "哦，好子都！将我儿害死，老夫岂肯与你甘休！吓，儿啊！"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "抬头观见白氏妻， 丈夫言来听端的： 恼恨奸贼太无理， 还望我妻报冤屈。"
        },
        {
          "character": "白吉",
          "type": "白",
          "text": "老夫白吉，哪个是你妻？"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "转身来在金銮里， 列位大人听端的。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "子都小奴才，曾记得老王晏驾，二殿下登基，大太子心中不悦，用药酒毒死二 殿下，太后上殿保本，将太后打在牛皮山下受罪。你老爷阅边赏军，夜宿宁州， 城隍托梦。"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "跨下一骑虎骊豹， 牛皮山前逞英豪。 城隍土地把梦保， 搭救太后转回朝。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "老爷回朝，金殿奏本，迎接太后回宫。谁想惠南王不遵国法，打来战表。主上 命我为帅，子都心中不服，大王命我二人教场举旗拉车。"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "惠南王逞强好大胆， 连环战表夺江山。 我二人比武教场里， 举旗拉车我占先。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "你老爷举动铜旗，拉动铁车。大王命我与为正帅，子都为副帅。两军阵前，是 我刀劈惠南王，占了城池，你用袖箭将我射死城下！"
        },
        {
          "character": "公孙阏",
          "type": "西皮快板",
          "text": "子都行事太短见， 袖箭射我丧阵前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙阏下。"
        },
        {
          "character": "颖考叔",
          "type": "西皮摇板",
          "text": "半空中霹雳响一声绕点， 一口气吹散了云雾满天。 亦非是深山中妖魔鬼怪，"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "你是哪个？"
        },
        {
          "character": "颖考叔",
          "type": "西皮快板",
          "text": "臣本是颖考叔来诉屈冤： 惠南王打来了连环战表， 有为臣领人马去到阵前。 刀劈了惠南王臣把命丧， 启吾主论功劳臣占先。"
        },
        {
          "character": "郑庄公",
          "type": "西皮快板",
          "text": "别的神位不封你， 封你忠孝将军归上天。"
        },
        {
          "character": "颖考叔",
          "type": "西皮快板",
          "text": "在空中叩谢了我主恩典， 我这时朝玉帝三十三天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔下。颖考寇哭。"
        },
        {
          "character": "郑庄公",
          "type": "白",
          "text": "卿家不必痛哭，孤请高僧高道，超度于他。 众卿退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}