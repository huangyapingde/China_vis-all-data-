{
  "script_id": "01006016",
  "title": "探亲相骂",
  "alias": [
    "探亲家"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "胡妈妈",
      "hangdang": "彩旦"
    },
    {
      "name": "李奶奶",
      "hangdang": "小旦"
    },
    {
      "name": "胡老头儿",
      "hangdang": "外"
    },
    {
      "name": "野花",
      "hangdang": "旦"
    },
    {
      "name": "李相公",
      "hangdang": "小生"
    }
  ],
  "plot": "乡下亲家母胡妈妈背着口袋、骑了牲口到城中女婿家探望女儿野花。野花见了娘亲，便诉说一番苦处。等到\n和城里亲家母李奶奶见面以后，一村一俏，处处显出相形见绌的情形。谈吐当中，胡妈妈时被李奶奶奚落。\n后来又谈到野花傻蠢的地方，李奶奶苛求责备，胡妈妈却处处庇护。于是争执相骂，结果弄得不欢而散。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈上。"
        },
        {
          "character": "胡妈妈",
          "type": "引子",
          "text": "农夫日夜忙，幸逢今岁得安康。"
        },
        {
          "character": "胡妈妈",
          "type": "念",
          "text": "乡里庄家昼夜忙，勤劳耕种受风霜。树到深秋黄叶落，真乃人生梦一场。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "老身胡妈妈的便是。所生一女，名叫野花，嫁在城中李家为媳。只因终日农忙， 老没有去看看女儿。今日闲暇无事，不免去到城中探亲一回。呀，只是没有 好的穿戴，也不带点儿什么，这便如何是好？"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "指望进城，探望一门亲， 思想怎好上他的门，急煞人。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哦，我就拿些面食饽饽、刀豆扁豆儿，杂八碎儿吧。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "饽饽、扁豆儿，蒜苗带几斤， 寒豆儿虽小，也能蒙过人。 打扮完全就好起程， 吩咐我老头儿看好也么门。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "我的老头儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡老头儿内允。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "与我备骡儿，就把骡儿整， 与我备骡儿，就把骡儿整。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡老头儿上。"
        },
        {
          "character": "胡老头儿",
          "type": "吹腔",
          "text": "老头儿今年七十也么春， 有个女儿离了家门常挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈换装上。"
        },
        {
          "character": "胡老头儿",
          "type": "白",
          "text": "妈妈，你打扮齐整，干什么去？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "上城中去探望女儿。"
        },
        {
          "character": "胡老头儿",
          "type": "白",
          "text": "就是家常衣服也不要紧。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "老头儿，你不明白，见了亲家母，不成个样儿。"
        },
        {
          "character": "胡老头儿",
          "type": "白",
          "text": "说的是啊。"
        },
        {
          "character": "胡老头儿",
          "type": "吹腔",
          "text": "趁着天气晴， 快去莫留停。 城中路上要小心， 说我年迈不得出门。 吩咐我女儿么， 休要挂在心，我的妈妈呀！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "胡老头儿",
          "type": "吹腔",
          "text": "问亲家就把亲家问， 问亲家就把亲家问。"
        },
        {
          "character": "胡老头儿",
          "type": "白",
          "text": "妈妈，你进城去，理当拜别邻居一声。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "说的有理啊。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "出得儿门来拜街也么坊，"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "喂，张大妈，李大娘！"
        },
        {
          "character": "邻居",
          "type": "内同白",
          "text": "胡大妈，你打扮齐整，上哪里去？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "上城中去探望女儿。家中诸事，有劳你们照应照应。"
        },
        {
          "character": "邻居",
          "type": "内同白",
          "text": "是了。你见了姑娘，烦你道个好儿。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "有劳你们。少陪了。 老头儿，东西收拾好了没有？"
        },
        {
          "character": "胡老头儿",
          "type": "白",
          "text": "收拾好了。"
        },
        {
          "character": "胡老头儿",
          "type": "吹腔",
          "text": "饽饽、扁豆儿口袋里装。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "梢在牲口上，老头儿与我拉拉衣裳，"
        },
        {
          "character": "胡老头儿",
          "type": "吹腔",
          "text": "你去就回家，家中农事忙。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "你也休要街坊去闲荡，我的老头儿呀！"
        },
        {
          "character": "胡老头儿",
          "type": "白",
          "text": "妈妈，这匹骡儿才买，你且试骑试骑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈接鞭骑，下。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "我便关上门，就把门关上， 我便关上门，就把门关上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡老头儿下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈上。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "一进了城来把眼也么望， 两旁铺面尽开张。 闹嚷嚷，经纪鱼行贩，还有摆摊场， 走江湖，还有医卜星象。 行来已到女儿门旁， 跨下鞍鞒，叫一声姑娘，我的宝贝儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "野花上。"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "来啦。是谁呀？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你妈来啦！"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "哦，原来是母亲，里边请坐。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "啊，儿啊，捧过了骡儿，上点儿草料。"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "上草料，我把草料上， 上草料，我把草料上。"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "母亲，见过礼儿。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "罢了罢了，自己娘儿什么礼儿啊。"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "见过了亲娘笑颜也么装， 爸爸因何不同往？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "儿啊，你在家中时晓得的啊。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "家中事体忙，"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "爹爹可安康？"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "儿爹身子好， 老健倒安康。 阖家大小全无恙，"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "女儿的苦楚么，告诉我的娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "野花哭。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "好端端的，怎么哭起来？"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "婆婆的不贤么， 女儿实难当，我的亲娘呀！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "她心肠变，我也变心肠， 她心肠变，我也变心肠。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "儿啊，你妈今儿个特来看看你，你怎么就有许多的闲话？你在这儿作媳妇，比 不得在你娘家，你要忍耐些儿啊。"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "我真忍耐不住了。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "咳，儿啊！"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "娘劝女儿喜笑也么喜， 口袋里东西递与闺女。 饽饽和了韭菜馅的，"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "婆婆不在家。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "我儿先尝些，等婆婆回来拿了过去。"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "什么好东西？"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "虽不是好东西， 你爸爸只么推只么推，累得极。我的姐儿呀！"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "真累极，却是不容易。 真累极，却是不容易。"
        },
        {
          "character": "李奶奶",
          "type": "内白",
          "text": "众姐妹，告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李奶奶上。"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "未曾下庄放下了牌，"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "婆婆回来了。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "什么事情？"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "我家母亲来了。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "怎么着，你妈来了吗？"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "哎，我妈来了。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "亲家太太在哪儿呢？亲家太太在哪儿呢？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "亲家母，您好啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈、李奶奶同推见礼。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "呦，亲家太太老没见了。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "可不是吗。太太老没见了。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "你倒少相了。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你倒木瓜了。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "呦，什么木瓜呀？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "呦，什么少相啊？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "你长得面嫩就为少相。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你长得俊，就是木瓜。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "姐儿俩老没见了，咱们拉拉手。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "多么难为情啊。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "那么咱们亲热亲热？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "嗳唷！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "怎么哪？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你那儿是什么顶着我这儿啦？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "是么？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "可不是么！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "让我摸摸。啊，是了，你亲家公下班把鼻烟壶交给我哪，顺便带在身上。咱们 姐儿俩一亲热，必是我这儿顶着你那儿哪。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "拿出来让我瞧瞧。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "啊，我们这是破鼻烟壶，拿不出手来。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "我当什么，原来是个破夜壶。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "取笑呐。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "请坐吧。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李奶奶坐，胡妈妈两手撑地，将两脚放在椅子上，背与臀部齐平。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "亲家母，您那个坐法儿是什么啊？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "我这叫鸭子嘴儿。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "您瞧我哪？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "您那是怎么坐哪？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "我这是板凳腿儿。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "那么舒坦吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈摔倒在地。李奶奶对野花愤怒。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "快把你妈妈给搀起来吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "野花搀胡妈妈起。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "你瞧，你妈来了半天，连口水都没有喝。倒茶去！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "我不要喝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "野花将茶捧给李奶奶。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "先给你妈，连里外都不懂，哪个混蛋大脚老婆养的！"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "是啦，婆婆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "野花将茶捧给胡妈妈。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "亲家太太，请来。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "呦，亲家太太，您可真香啊。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "亲家太太不香，这个茶香。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "亲家奶奶，这是什么茶啊？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "这叫毛尖。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "呦，这叫毛尖啊？怪不得我说是哪儿来的这些毛哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈伸手入茶杯，退出手，作掷茶叶状。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "啊，亲家太太，你干什么哪？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "我这是在捞毛哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李奶奶轻笑。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "咳，这个茶叶名字叫做毛尖，这里头没有毛。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "照你这么说，那我不白捞了吗？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "取笑哪。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "亲家奶奶，你这水怎么这么快啊？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "我们城里头使的是煤油火炉，用的是薄沙吊子，才上一点儿水，做在火上。要 是亲家太太您来哪，不大工夫就滚啦！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你说什么啊？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "那个水啊。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "啊，亲家奶奶。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "怎么哪？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "啊，亲家奶奶，你到我们乡下来，你也不是一样吗？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "呦，亲家太太长了咀皮子哪！说话不吃亏吗！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "亲家奶奶，见礼吧。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "倒不必哪。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "见过了礼儿把话也么搭。"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "问声庄稼？"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "今年的庄稼不怎么， 借贷了银钱栽了几亩瓜。 老天爷不把雨来下，"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "亲家太太，您盼着吧。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "蝗虫虺虫满田爬，我的亲家母啊！ 本利算来不能到家， 本利算来不能到家。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "这一季不好，下季就好了。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "我们乡下虽有几亩田，要是收成不好，也就完了。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "今天辛苦你来。你若是不来，我还要打发阿哥来请您哪。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "这倒不必客气。亲家太太，但不知道有什么事情？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "为的就是她！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李奶奶指野花。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "怎么，为的就是她？为她什么哪？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "哽，进得我门来，连个响屁都没放！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "那么，你怎么能够单怪她哪！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "亲家太太，我有两句话说，你可别恼。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "有话就快说，有屁就请放！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "我就恕个罪儿吧，恕个罪吧。"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "亲家母请坐，细听我说： 你的女儿生来的傻，小心多。 有了二斤肉来不会下锅， 一双鞋做了半个月还多。 谁家的媳妇敢骂婆婆， 撒谎调皮算她头一个，我的亲家母呀！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "气死我啦可就气死我， 气死我啦可就气死我。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "气死我哪！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "呦，亲家奶奶，你的话中听吗？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "呦，我说的话，有什么不中听的吗？"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "我说你的话，简直的不中听！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "有话请说，有屁就请放。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "她在娘家理当我管，如今嫁到你家来作媳妇，就是你家的人了，理当你作婆婆 的教导于她。哼哼，难道叫我作娘的陪着她一同嫁到这里来不成么？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "倒不必哪。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "听她言来怒气也么生， 亲家母说话不受听，恼人心。 出了我家门就是你家人， 你不会教训反把我来问。 你打你骂我也不心疼， 死是你家鬼，活是你家人，我的亲家母呀！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "气闷人真叫人气闷， 气闷人真叫人气闷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈气。"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "是我闻言怒气发， 这是你从小惯的她。 脚也不裹裤腿也不扎， 气煞人儿你把人气煞，我的亲家母啊！ 气煞人你把人气煞！"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "是我闻言怒气也么发，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈转向野花。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "骂一声小贱人歪辣，气煞了咱。 枉我养你十七八， 不痴又不傻，眼睛也不瞎。 你忘了在家嘱咐你的话， 远巴巴前来看你，什么惹得你婆婆嘴里邋遢，你这孽障儿啊！"
        },
        {
          "character": "野花",
          "type": "哭",
          "text": "呦……"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "气煞人真把人气煞， 气煞人真把人气煞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈气，转身以背向李奶奶。李奶奶气，转身以背向胡妈妈。李相公上。"
        },
        {
          "character": "李相公",
          "type": "念",
          "text": "家中多活计，日用斗量金。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "啊，岳母，小婿拜揖。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哎，拜你妈的揖，臭杂种！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "啊？这是什么缘故？ 母亲，孩儿拜揖。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "又不是年，又不是节，拜什么揖？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "母亲因何这等烦恼？啊，是了！"
        },
        {
          "character": "李相公",
          "type": "吹腔",
          "text": "听她们语言明白也么了， 儿劝亲妈休要放刁，好心焦。 她路途远来把女儿瞧， 虽然她不是求娘饶恕了。 闹闹吵吵恐被旁人笑， 嘴里噜苏见得唠叨。 自己不知也么道，我的亲妈哎！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "李相公",
          "type": "吹腔",
          "text": "焦躁人也么人焦躁， 焦躁人也么人焦躁。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "冤家啊！"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "是我闻言怒气也么生， 骂一声冤家小畜生！ 我今养下你，你倒有外心， 从今以后滚出我的门，我的冤家哎！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "滚出去来你就滚出我的门， 滚出去来你就滚出我的门。"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "听她言语我泪如麻， 你儿疼我就骂着他，眼巴巴。 离家多么远，难得上你家， 惹得你嘴里乱打牙。 女儿交与你，如有半点差， 看你把她杀也么剐，你这泼妇儿哎！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "胡妈妈",
          "type": "吹腔",
          "text": "你太撒泼也么她泼撒， 你太撒泼也么她泼撒。"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "是我闻言怒气也么消， 乡下的人儿也会撒刁。 上吊有绳子，抹脖子有钢刀， 写一张休书你把我来告。 定盘心儿错打了， 睁开你的狗眼瞧一瞧，我的泼妇哎！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "真可臊真可臊， 真可臊真可臊。"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "呵呵，你好骂！你骂！你骂！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "可臊来哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈、李奶奶浑打，李相公劝。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "母亲不必如此。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "哎呀，甩了我的腰哪！"
        },
        {
          "character": "野花",
          "type": "白",
          "text": "妈呀，不必如此了。"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "儿劝亲娘泪如也么梭， 再劝妈妈心内休苦，随她把我磨。 哪怕她家有熬人油锅， 看她做什么？ 命中该死逃不过， 儿到阴司去见阎罗，我的妈妈啊！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "野花",
          "type": "吹腔",
          "text": "难过人实在真难过， 难过人实在真难过。"
        },
        {
          "character": "李奶奶",
          "type": "吹腔",
          "text": "是我闻言怒气也么撞， 骂她一声小贱娼，仗着娘。 我就当着她打又何妨，"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你骂谁哪！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "骂你哪！骂你哪！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你过来！"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "你过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡妈妈、李奶奶互打。"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "接嘴巴！"
        },
        {
          "character": "胡妈妈",
          "type": "白",
          "text": "你打我？"
        },
        {
          "character": "李奶奶",
          "type": "白",
          "text": "咱们打官司去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李相公劝李奶奶，野花劝胡妈妈。李相公、李奶奶、野花、胡妈妈自两边分下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}