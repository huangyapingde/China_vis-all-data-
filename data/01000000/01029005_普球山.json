          "character": "四英雄",
          "type": "白",
          "text": "启禀寨主：我等拿住奸细三名。"
        },
        {
          "character": "邹应龙",
          "type": "白",
          "text": "想是那赃官差人前来，探听金牌之事。"
        },
        {
          "character": "四英雄",
          "type": "同白",
          "text": "寨主要将金牌收好，以免他人盗去。"
        },
        {
          "character": "邹应龙",
          "type": "白",
          "text": "金牌现藏在山后石洞之内，就是大罗神仙也难知晓。众位英雄，请至后面一叙。 将奸细押在马棚之内。"
        },
        {
          "character": "四英雄",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
