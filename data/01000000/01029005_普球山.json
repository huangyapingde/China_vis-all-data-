  "plot": "大盗邹应龙，绰号大鹏金翅鸟，霸占普球山，哨聚喽啰数千，打家劫舍。且与官场暗通声气，得以安居巢窟。\n惟彭公素恶此辈，饬属下认真缉拿，正以国法。钦授河南巡抚，将次到任。普球山正河南该管之地。邹应\n龙恐为彭公所访闻，要于半路夜入公馆内，盗去御赐金牌一块。彭公之护卫张耀宗，央求岳父母铁幡杆蔡庆、\n金头蜈蚣窦氏，邀旧友数人如杨香武、万君兆等，以及公馆中众护卫，围攻普球山，邹应龙率领头目喽啰\n尽力抵御。杨香武施展飞檐走壁之能，暗至后山石洞，盗回金牌，复助众人厮杀，邹应龙乃成擒焉。",
  "notes": "是剧事实出于《彭公案》说部。剧本与书本大不相同。书本所载，彭公就任河南，半路为群盗所劫，张耀宗\n独挡群盗。彭公误入连洼庄，恶霸武连看破行藏，在身上搜得御赐金牌，推落土牢，杜清、杜明仗义救出。\n武连携带全家逃奔紫金山，将金牌献于邹应龙。彭公探听得实，会集众英雄剿灭紫金山，邹应龙乘间脱身，\n至普球山依其弟邹应虎，众英雄跟踪而来，亦剿灭之，擒获邹应龙。彭公随即审讯，供出金牌已抛落紫金山\n后寒泉穴内。命高恒下水搜寻，因年老不胜其任，竟然冻死，其子高源，继父之志，方始取出。《盗金牌》\n一事情节甚多，不能殚述，参阅书本，自知详细。按紫金山系邹应龙霸占，普球山即北邙山，系邹应龙之弟\n邹应虎霸占，剧本合而为一，未知有何依据。然说部所载人名地名，辄以生花妙笔意想而为之，孰是孰非，\n无从研究。武场戏只取热闹、串演一方面，达于工力悉敌之地点，俾观剧诸君，可以赏心悦目，不必沾沾于\n事实之如何也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "邹应龙上。"
        },
        {
          "character": "邹应龙",
          "type": "点绛唇",
          "text": "武艺高强，英雄胆壮，习拳棒，练学刀枪，绿林俺为上。"
        },
        {
          "character": "邹应龙",
          "type": "念",
          "text": "铁背熊腰胆包天，绿林之中美名传。练就一对镔铁锏，威名独振普球山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同暗上。"
        },
        {
          "character": "邹应龙",
          "type": "白",
          "text": "吾，姓邹名应龙，人称大鹏金翅鸟。可恨赃官彭朋，每每与绿林作对。圣上曾 赐他金牌一面。闻听人言，他在此下马，俺不免夜入公馆，盗走他的金牌，也 叫他晓得俺的厉害。正是："
        },
        {
          "character": "邹应龙",
          "type": "念",
          "text": "安排打虎牢笼套，准备铁锁钓金鳌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邹应龙、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二院子提灯引彭朋同上。"
        },
        {
          "character": "彭朋",
          "type": "西皮摇板",
          "text": "本院奉旨出朝廊， 捉拿恶霸与强梁。 将身且坐二堂上， 又听谯楼更鼓忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭朋睡。邹应龙自桌跳下，拨门，盗金牌，跳桌子下。〖起更鼓〗。二院子同上。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "大人醒来。"
        },
        {
          "character": "彭朋",
          "type": "西皮摇板",
          "text": "耳边厢又听得人声嚷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭朋看。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "彭朋",
          "type": "西皮摇板",
          "text": "金牌不见为哪桩？"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "圣上所赐金牌不见，桌案之上有钢刀一把，不知何方盗贼前来行刺。 来，有请众位英雄。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "有请众位英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐盛、四英雄、高通海、刘德泰同上。"
        },
        {
          "character": "徐盛、四英雄、高通海、刘德泰",
          "type": "同白",
          "text": "参见大人！"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "众位少礼，请坐。"
        },
        {
          "character": "徐盛、四英雄、高通海、刘德泰",
          "type": "同白",
          "text": "谢坐。大人有何吩咐？"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "昨晚不知有何处贼寇大胆前来，盗去吾的金牌，桌案之上留下钢刀一把，众位 请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐盛接刀。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "此必是有名贼寇，列位英雄可知此处有什么著名之盗？"
        },
        {
          "character": "四英雄、高通海、刘德泰",
          "type": "同白",
          "text": "我等不知。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "此地系大名所管，若将大名府总镇玉面虎张岳宗调来一问，便知分晓。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "奉吾令箭，速调张岳宗前来，不得有误。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "彭朋",
          "type": "念",
          "text": "混浊不分鲢共鲤，"
        },
        {
          "character": "徐盛、四英雄、高通海、刘德泰",
          "type": "同念",
          "text": "水清方见两般鱼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蔡庆、蔡金花、李桂莲同上。"
        },
        {
          "character": "蔡庆",
          "type": "西皮摇板",
          "text": "自幼儿闯江湖独自为首， 大英雄走天涯四海名留。"
        },
        {
          "character": "蔡庆、蔡金花、李桂莲",
          "type": "同白",
          "text": "吾——"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "铁幡杆蔡庆。"
        },
        {
          "character": "蔡金花",
          "type": "白",
          "text": "蔡金花。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "李桂莲。"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "是吾来到大名，沿途卖艺，为女儿的亲事，幸遇玉面虎张岳宗，人才出众，武 艺超群，因此就与女儿金花给了婚姻。不免回庄说与吾妻窦氏知道便了。"
        },
        {
          "character": "蔡庆",
          "type": "西皮摇板",
          "text": "催马加鞭往前进， 见了吾妻说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡庆、蔡金花、李桂莲同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四英雄、张岳宗同上，同跑圆场，同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐盛、四英雄、高通海、刘德泰同上。"
        },
        {
          "character": "徐盛",
          "type": "念",
          "text": "命人去调张岳宗，为何不见转回程？"
        },
        {
          "character": "张岳宗",
          "type": "内白",
          "text": "张岳宗到！"
        },
        {
          "character": "徐盛、四英雄、高通海、刘德泰",
          "type": "同白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。张岳宗上。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "众位英雄！"
        },
        {
          "character": "徐盛、四英雄、高通海、刘德泰",
          "type": "同白",
          "text": "请坐！"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "有坐。大人令箭调我前来，不知为了何事？"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "仁兄有所不知：只因此处有大胆的贼寇，夜入公馆，盗去大人金牌，并留下钢 刀一把，因此大人调仁兄前来捉拿盗牌之人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张岳宗接刀看，气倒。"
        },
        {
          "character": "张岳宗",
          "type": "西皮导板",
          "text": "听一言吓得我魂飞天外，"
        },
        {
          "character": "张岳宗",
          "type": "西皮摇板",
          "text": "恨贼人胆包天私盗金牌。 是何人他与我结下冤债， 这件事好叫我难解难猜。"
        },
        {
          "character": "英雄甲",
          "type": "白",
          "text": "张大人既在此处为官，定知此处的英雄。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "这……在下虽然此处官居总镇，这有名的盗贼一概不晓。"
        },
        {
          "character": "高通海",
          "type": "白",
          "text": "此处盗贼纵然不知，但是有名的英雄好汉只恐也不能少了。况且久在江湖上的 英雄，洗手不干退归林下之人，定然也有。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "此处有座普球山，内有一位英雄，名叫邹应龙。"
        },
        {
          "character": "高通海",
          "type": "白",
          "text": "敢么是那大鹏金翅鸟么？"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "英雄甲",
          "type": "白",
          "text": "如此说来，这金牌定要应在此人的身上。"
        },
        {
          "character": "张岳宗、徐盛、高通海、刘德泰、三英雄",
          "type": "同白",
          "text": "怎见得？"
        },
        {
          "character": "英雄甲",
          "type": "白",
          "text": "如老朽前在红旗李玉家中，曾遇着凤凰张七。他曾经言道：邹应龙与武文华交 好。前者大人在清河县将武文华正法，莫非此人要与武文华报仇也未可知。"
        },
        {
          "character": "高通海",
          "type": "白",
          "text": "既然如此，必须想一妙计，看是谁同邹应龙常在一处，能够找他做一内应，方 好擒拿。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "想吾岳父蔡庆，乃是绿林中的老英雄，就在此处不远。若要同他商议，或可成 功。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "好，如此大家一同前往。"
        },
        {
          "character": "英雄甲",
          "type": "白",
          "text": "我等禀明大人一同前去。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "徐仁兄带俺见过大人。"
        },
        {
          "character": "徐盛、四英雄、高通海、刘德泰",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "万君兆上。"
        },
        {
          "character": "万君兆",
          "type": "西皮摇板",
          "text": "家中奉了母亲命， 一路行来不消停。"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "俺，八臂哪吒万君兆。奉了母亲之命，寻访蔡庆。看前面已是蔡家堡，就此马 上加鞭。"
        },
        {
          "character": "万君兆",
          "type": "西皮摇板",
          "text": "一马来在阳关上， 又只见三人走慌忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高通海、刘德泰、张岳宗同上。"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "来者敢是张仁兄？"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "原来是万贤弟！"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "正是。请问此位？"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "敢么是不相认？来来来，见过万贤弟。 此乃是彭大人手下，高通海，此位是刘德泰。"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "原来是高、刘二位。"
        },
        {
          "character": "高通海、刘德泰",
          "type": "同白",
          "text": "江湖上人称八臂哪吒就是阁下吗？"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "高通海、刘德泰",
          "type": "同白",
          "text": "久仰得了不得。"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "大哥欲向何往？"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "只因彭大人失去金牌，我等欲寻吾岳父同拿盗牌之人。"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "好，小弟也正要到令岳处有事相商，你我一同前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李佩、杨香武同上。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "原来是二位叔父。"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "参见岳父！ 吓，杨叔父。"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "你等欲向何往？"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "只因彭大人失落金牌，特地投往蔡家堡，要求吾岳父同拿盗牌之人。"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "好，我等也正为金牌之事而来，就此同往。"
        },
        {
          "character": "李佩",
          "type": "西皮摇板",
          "text": "催马一齐往前进， 蔡家堡内走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "窦氏上。"
        },
        {
          "character": "窦氏",
          "type": "念",
          "text": "自幼生来专好武，人人道我是母老虎。打街骂巷谁不怕，因此独霸蔡家堡。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "吾，金头蜈蚣窦氏，嫁于蔡庆为妻。膝下无儿，只有一女，名唤金花，今年一 十八岁，还靡有人家呐。我们老头子也因为此事，常常挂念，因此带着女儿云 游四海，要寻一个才貌双全的女婿，日后也好给我们老两口送终。但是我们那 一个老头子眼力不高，有人送他几句好话，奉承奉承他，他就说这是好人。他 们去的日子也不少啦，为何还不见回来。正是常言道的好："
        },
        {
          "character": "窦氏",
          "type": "念",
          "text": "生儿莫养女，养女多劳心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡庆、蔡金花、李桂莲同上，院子迎上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "老寨主回来了。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "你们都回来啦。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "大妈，你能好吓？"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "好吓李姑娘，越长越俊啦！"
        },
        {
          "character": "蔡金花",
          "type": "白",
          "text": "母亲。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "罢啦，你们姊妹后头歇息歇息去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡金花、李桂莲同下。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "我说老头子，你为女儿的亲事去了这许多天，到底有点意思没有呀？"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "女儿的亲事已经说定了。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "你怎么也不回来同我商量商量，你就作主定下啦！是什么人家？"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "此人大大有名，姓张名岳宗，人称玉面虎。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "你算了吧，想我在家中，人人皆称我是母老虎，你怎么又弄了一个什么玉面虎， 岂不是个白虎？这白虎进宅，无故生灾，这件亲事，据吾看，做不得！"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "姻事已定，哪有反悔之意！"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "想女儿乃是我生的，总要我答应才算数。"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "女儿是我的，我要给谁，你也不能拦阻。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "什么不能拦阻，我不答应，你就没法子想。"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "你不能！"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "我偏能！"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "你不能！"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "我偏能！我偏能！"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "你招打。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "要打，哈哈，好，你来吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦氏、蔡庆对打，院子劝。蔡金花、李桂莲同上，拉窦氏同下。"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "蔡庆",
          "type": "西皮导板",
          "text": "为女儿婚姻事常挂心下，"
        },
        {
          "character": "蔡庆",
          "type": "西皮流水板",
          "text": "走南北闯西东云游天涯。 择定了张岳宗武艺高大， 相貌堂堂也不差。 今日才得回家下， 她倒不住地埋怨咱。 开口骂，举手打， 我只为年老夫妻我就让着她。 但愿得张岳宗早到我家下， 看她爱他不爱他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李佩、杨香武、万君兆、张岳宗、高通海、刘德泰同上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "众位英雄到！"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "李佩、杨香武、万君兆、高通海、刘德泰",
          "type": "同白",
          "text": "老英雄！"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "岳父！"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "众位英雄请坐。"
        },
        {
          "character": "李佩、杨香武",
          "type": "同白",
          "text": "为何不见嫂嫂？"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "来，有请主母。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请主母。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦氏引蔡金花、李桂莲同上。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "姑娘，你看看外面是谁来啦？"
        },
        {
          "character": "蔡金花",
          "type": "白",
          "text": "我不去，有他在那儿呐，妹子你去吧。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "我去看看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李桂莲看。"
        },
        {
          "character": "李桂莲",
          "type": "白",
          "text": "我不去啦，有他在那儿呐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡金花、李桂莲同下。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "好，你也有他，她也有他，难道说我就没有他啦吗。等我把他调出来。 哦咳！"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "你叫我何事呀？"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "我问问你，来的都是谁呀？"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "那一少年，就是你我的女婿张岳宗。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "我，这就是咱们的姑爷，真不含糊，顶瓜瓜小白脸。老头子，你真会办事！"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "你不同我打架啦吧！"
        },
        {
          "character": "李佩、杨香武",
          "type": "同白",
          "text": "嫂嫂。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "兄弟来啦，你好吓！"
        },
        {
          "character": "万君兆",
          "type": "白",
          "text": "伯母。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "罢啦。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "吓，岳母！"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "哦呵呵呵呵，姑爷，你坐着。"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "大家请坐。"
        },
        {
          "character": "张岳宗",
          "type": "白",
          "text": "今有彭大人在此下马，不料金牌被邹应龙盗去，小婿特来要求岳父岳母帮同小 婿，捉拿此贼。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "姑爷你坐着，何必这么多礼。但不知是哪一个邹应龙？"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "就是当年在我们这里当过喽啰的邹应龙。"
        },
        {
          "character": "窦氏",
          "type": "白",
          "text": "就是那个龙儿吓！该，他如今也要装人。不要紧，这件事情，妈妈我足办的了。"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "今晚我二老，带同张、万二位，随同金花、桂莲，同去盗牌便了。"
        },
        {
          "character": "李佩、杨香武",
          "type": "同白",
          "text": "我二人暗中接应。"
        },
        {
          "character": "蔡庆",
          "type": "白",
          "text": "同至后面用饭。正是："
        },
        {
          "character": "蔡庆",
          "type": "念",
          "text": "一边撒下青丝网，"
        },
        {
          "character": "窦氏、李佩、杨香武、万君兆、张岳宗、高通海、刘德泰",
          "type": "同念",
          "text": "哪怕鱼儿不上钩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、邹应龙同上。"
        },
        {
          "character": "邹应龙",
          "type": "唱",
          "text": "身在绿林情性暴， 盗来金牌逞英豪。 将身且坐二堂道， 但听喽啰报根苗。"
