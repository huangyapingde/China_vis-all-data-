        {
          "character": "蔡金花",
          "type": "白",
          "text": "我说妈呀，还不打这杂种了得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同打连环十二股荡。邹应龙被擒下。蔡庆三笑。众人同下。"
