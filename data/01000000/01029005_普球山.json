      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、徐盛引四英雄同上，杨香武随上。"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "金牌到手，邹应龙追来啦！"
