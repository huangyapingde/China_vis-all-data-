{
  "script_id": "01012011",
  "title": "赶三关",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "老生"
    },
    {
      "name": "代战公主",
      "hangdang": "旦"
    },
    {
      "name": "马达",
      "hangdang": "丑"
    },
    {
      "name": "江海",
      "hangdang": "丑"
    },
    {
      "name": "莫老将军",
      "hangdang": "丑"
    }
  ],
  "plot": "薛平贵在西凉十八年，既赘为驸马，后又嗣业为西凉国主，显荣已极，惟思家恋旧之心，来尝一日忘。日者\n正思念王宝钏不已，忽有一宾鸿衔书至，薛平贵见系王宝钏血书，遂急欲回国探望。然恐代战公主不允，因\n设策用酒灌醉代战，己乃盗令而出。一路偷过三关，尚安然无事。方抵国境，欲叫关而进，而代战已率众追\n至。城上守关将，尚疑神疑鬼，不敢开关。既以数事为证，乃始开纳。甫入关，而代战已兵临城下，索薛平\n贵出会话。薛平贵不得已，乃上城楼，告以心事。代战闻薛平贵有妻，且欲归去，初不允，几至决裂。继见\n薛平贵再三哀求，乃始回意，与以金翎鸽子一头，贝便传信，并要约数事而别。",
  "notes": "此“赶三关”，与《查头关》中之“三关”不同。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、四太监、大太监同上。"
        },
        {
          "character": "薛平贵",
          "type": "引子",
          "text": "驾坐西凉，蒙公主，扶保孤王。"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "离长安一十八载，思宝钏常挂心怀。恨魏虎将孤谋害，这冤仇何日解开！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "孤，薛平贵，乃大国长安人氏。只因那年征战西凉，魏虎挂帅，以孤为前战先 行。是孤得胜回来，魏虎假意庆功，用酒将孤灌醉，绑在红鬃烈马之上，放与 西凉。又被公主擒来，献于老王。蒙老王不曾将孤杀害，反将公主匹配。只因 老王晏驾，多蒙公主扶保孤王登基，一十八载。今当设立早朝。 内侍，闪放龙门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老仙上。"
        },
        {
          "character": "老仙",
          "type": "白",
          "text": "平贵无道，平贵无道！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启禀大王：宾鸿大雁，口吐人言。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "侍孤看来。"
        },
        {
          "character": "老仙",
          "type": "白",
          "text": "平贵无道，平贵无道！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哦呵呀！看这宾鸿大雁，骂孤无道，此乃不祥之兆。 内侍，看弓弹伺候。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "自从盘古立地天， 哪有宾鸿吐人言？ 人来看过弓和弹， 对准宾鸿撒了弦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老仙下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启禀大王：宾鸿大雁不见，有血书在此。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监呈信，薛平贵看。"
        },
        {
          "character": "薛平贵",
          "type": "三叫头",
          "text": "宝钏，贤妻，哎呀妻吓！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "见书信不由孤泪流满面，"
        },
        {
          "character": "薛平贵",
          "type": "三叫头",
          "text": "宝钏，贤妻，哎，妻吓！"
        },
        {
          "character": "薛平贵",
          "type": "西皮慢板",
          "text": "点点的珠泪儿洒落在胸前。 常随官与孤把班散，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监、四太监同下。"
        },
        {
          "character": "薛平贵",
          "type": "西皮慢板",
          "text": "一字字一行行写得周全： 上写着拜上多拜上， 拜上儿夫无义男。 自从儿夫西凉战， 妻为你在寒窑受尽熬煎。 早来三天还相见， 迟来三天不能团圆。 看罢书信望长安，"
        },
        {
          "character": "薛平贵",
          "type": "哭头",
          "text": "王三姐，宝钏，吓吓吓，我的妻吓！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "夫妻们相逢难上难。 低下头来心思转， 猛然一计上心间。 撩袍端带上银安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "快宣公主把驾参。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "公主上殿。"
        },
        {
          "character": "代战公主",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主上。"
        },
        {
          "character": "代战公主",
          "type": "西皮二六板",
          "text": "适才教场操兵转， 又听得大王把咱宣。 宫娥摆驾银安殿， 参王驾来问王安。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "妾妃见驾，大王千岁！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "谢座。大王宣咱家上殿，有何国事议论？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "公主连日操兵辛苦，孤王备得有宴，与公主同饮。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "如此待咱家把盏，宫娥看酒伺候。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "摆下就是。 内侍看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监允。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "夫妻们对坐饮琼浆， 她怎知血书袖内藏。 江山虽然孤执掌， 怕的是南朝动刀枪。"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "大王爷但把宽心放， 细听咱家说端详： 哪怕南朝兵将广， 咱一人能挡百万儿郎。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "公主虽然韬略广， 一人怎挡百万郎？"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "一来是大王爷洪福大， 咱家精心礼该当。 宫娥女将酒忙斟上， 这杯酒愿大王福寿绵长。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "公主敬酒王心爽， 多吃几杯有何妨。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "公主连日操兵辛苦，孤王要把敬你三大杯。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "大王，咱家这酒，比不得从前。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "从前能饮多少？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "从前有百杯之量。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "五十双杯。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "还是一样！ 内侍看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵敬酒，代战公主饮酒，醉。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "公主醉了！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你也醉了！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "一见公主醉银安， 中了平贵巧机关。 内侍与孤把衣换，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵换衣。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "番邦令箭别腰间。 不辞公主跨雕鞍，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "倘若公主问道大王，如何回答？"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "难舍公主十分贤。 桌案现有笔和砚， 字字行行写一篇： 春夏秋冬四季天， 孤王亲自去阅边。 你若念在夫妻义， 带领人马赶三关； 你若不念夫妻义， 西凉国改为女儿川。 番儿带过红鬃战， 公主醒来对她言，孤去阅边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "公主醒来！"
        },
        {
          "character": "代战公主",
          "type": "西皮导板",
          "text": "时才酒醉银安殿，"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "不见大王在哪边。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "大王往哪里去了？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "阅边去了。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "可留下什么？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有书信一封，公主请看。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "侍咱家看来。"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "上写春秋四季天， 孤王亲自去阅边。 公主若念夫妻爱， 带领人马赶三关； 公主不念夫妻恩， 西凉改作女儿川。 看罢书信心思算，"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "哦，是了，"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "原来大王回长安。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "叫咱家带兵追赶。 内侍，吩咐马达、江海，全身披挂，教场伺候。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "公主有令：吩咐马达、江海，全身披挂，教场伺候。"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "大王做事礼不端， 不该私自回长安。 点齐人马将他赶， 追赶大王问一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主、大太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同骑马上。"
        },
        {
          "character": "马达",
          "type": "念",
          "text": "家住在北国，"
        },
        {
          "character": "江海",
          "type": "念",
          "text": "说话不利落，"
        },
        {
          "character": "马达",
          "type": "念",
          "text": "吃的是牛羊肉，"
        },
        {
          "character": "江海",
          "type": "念",
          "text": "骑的是大骆驼。"
        },
        {
          "character": "马达",
          "type": "白",
          "text": "马达。"
        },
        {
          "character": "江海",
          "type": "白",
          "text": "江海。"
        },
        {
          "character": "马达",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "江海",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "公主发兵，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，代战公主上。"
        },
        {
          "character": "代战公主",
          "type": "念",
          "text": "点动兵和将，追赶无义男！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "参见公主！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "罢了。人马可齐？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "俱巳齐备。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "吩咐，巴图鲁，兵发头关！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "巴图鲁，兵发头关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "番官、小番同上。"
        },
        {
          "character": "番官",
          "type": "念",
          "text": "奉了公主命，把守在头关。"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "孩子们带路上关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呔，开关！"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "哪里来的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "奉了公主将令，出关另有公干。"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "可有公主将令？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "孩子们开关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵过关，下。代战公主、马达、江海、四龙套同上。"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "参见公主！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "罢了，我且问你，可见大王爷过关无有？"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "人有一个过关，不知可是大王？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "你连大王爷都不认识，来，与我打！兵发二关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
