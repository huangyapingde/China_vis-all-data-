        {
          "character": "梅秀英",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "儿吓，你我母子，不是此处人氏。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "哪里人氏？"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "乃是山西麻邑县人氏。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "因何来到此地？"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "你父在家打铁为生。自从那年，你父投军去了，刘贼造反，将为娘抢上山来， 勒逼为婚。本当不从，怎奈身怀有你这冤家！为娘今日话也说明，报仇也在你， 不报仇也在你。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "有钢鞭为证，儿去看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林看鞭。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "“尉迟敬德”，“尉迟宝林”。啊！"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "一见钢鞭过是真， 反把仇人叫爹尊！ 一把宝剑拿在手，"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "去到前堂杀仇人！"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "儿吓！有道是“单丝不能成线，独木焉能成林”？你明日去往两军阵前，父子 相认，然后再杀那刘贼不迟。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "只是孩儿恶气难消！"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "暂将恶气屯腹内，"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "母亲，今晚且做梦中人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林下。"
        },
        {
          "character": "梅秀英",
          "type": "叫头",
          "text": "宝林，我儿！哎呀，儿吓！"
        },
        {
          "character": "梅秀英",
          "type": "二黄摇板",
          "text": "一见姣儿出房门， 要想相逢万不能！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅秀英下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、尉迟恭同上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "辕门战鼓响，儿郎报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "小将讨战！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "昨日阵前来见阵， 娃娃武艺果然能。 人来带过马能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲带马。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "小心了！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "战他不过把我的老命拼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、尉迟恭同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林、四白龙套同上。"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "二堂领了母亲命， 两军阵前认爹尊。 催马来在战场等， 老将到来说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、四龙套同上。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "昨日阵前饶尔命， 今日又来送残生。 手使钢鞭朝下打，"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "这一鞭不打看在父子情。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃敢是怯战？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "老将，非是俺怯战，前面有座柳林，你可敢去？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃，慢说小小柳林，就是龙潭虎穴，你老爷何惧？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "你要来吓！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "怎地不来！"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "你要来吓！"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "叫声老将忙随定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林下。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "这娃娃又有什么巧计生？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林上。"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "催马加鞭到柳林， 不见唐营众三军。 下得马来忙跪定， 老将到来认爹尊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "催马加鞭到柳林， 只见娃娃跪埃尘。 马上擒爷擒不住， 诓爷下马万不能。 你老爷日抢三关夜夺八寨， 夜探白璧介休城。 唐天子解带传鞭某才归真主，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃，"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "个个闻名害头疼。"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "老将休要怒气生， 我是你孩儿认……"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "认什么？"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "认爹尊！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "战我不过就该走， 为什么阵前认父亲？"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "我说此话你不信， 我母名叫梅秀英！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "娃娃提起梅秀英， 想起当年大事情： 家住山西麻邑县， 夫妻们打铁度光阴。 上山得了两件宝， 造就雌雄鞭二根。 别的来历我不问， 有何宝物做证凭？"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "水流千遭归大海， 钢鞭拿去看分明。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "“尉迟敬德”，“尉迟宝林”！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "一见钢鞭过是真， 父子相逢在柳林。 钢鞭挑起亲生子，"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "翻身上了马能行。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "欺母仇人哪一个？"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "白良关前刘国珍。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "我儿带路关前进，"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "为父去杀刘国珍！"
        },
        {
          "character": "尉迟宝林",
          "type": "二黄摇板",
          "text": "且稍停来慢稍停， 里应外合杀仇人。 假战三合败了阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林下。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄摇板",
          "text": "钢鞭一举叫三军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘国珍上。"
        },
        {
          "character": "刘国珍",
          "type": "念",
          "text": "眼跳心惊，坐卧不宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林上，打死刘国珍，下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、四龙套同上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "那贼可灭？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "那贼已灭。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你母亲？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "悬梁自尽！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "随为父转至龙庭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林允。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}