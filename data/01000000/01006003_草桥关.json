{
  "script_id": "01006003",
  "title": "草桥关",
  "alias": [
    "威镇草桥"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "姚期",
      "hangdang": "净"
    },
    {
      "name": "刘秀",
      "hangdang": "老生"
    },
    {
      "name": "马武",
      "hangdang": "净"
    },
    {
      "name": "岑彭",
      "hangdang": "老生"
    },
    {
      "name": "杜茂",
      "hangdang": "老生"
    },
    {
      "name": "郭妃",
      "hangdang": "旦"
    },
    {
      "name": "郭荣",
      "hangdang": "净"
    }
  ],
  "plot": "东汉光武帝刘秀，中兴汉室，灭除新莽，全赖后世所传云台二十八将之力。海内既平，诸功臣皆封爵锡土，\n在朝伴帝，惟姚期虽然年迈，因威望素著，尚坐镇草桥。草桥关者，当时备边重镇也。一日，刘秀忽思念姚\n期，遂令吴汉、岑彭、杜茂等奉诏往代，去召姚期进京。姚期因二子姚刚、姚能，生性粗莽，不畏强权，恐\n其好勇斗很，在外贾祸，故挈同进都，不令远离。既抵京觐见，刘秀特御太和殿，亲赐御酒三大爵。皇恩优\n渥，荣宠逾席。",
  "notes": "前见金秀山在新新舞台演此，声调宏亮，气度雍容。当执鞭上马时，在威严静穆之中，流露出一段顾盼自雄\n之态，与老年威重、及英雄气魄，两种神情，均能顾到。描摹姚期气概，可称入细，洵足令人想见当年英武\n弈弈之老将神威也。秀山之外，惟刘永春与金秀山工力悉敌，足相伯仲，此外则皆稍逊一筹矣。秀山每唱此\n剧，必连演第二本姚刚击死国丈、绑子上殿请罪、至蒙恩赦免为止，他净则均不接演也。\n考《汉书》二十八将中，只有铫期，此“姚”字乃沿传之讹。二子一名丹，一名统，传中事实，与此绝异。\n按吴汉，剧本作马武。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郭荣、岑彭、杜茂、马武同上。〖牌子〗。"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "老夫郭荣。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "本爵岑彭。"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "本爵杜茂。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "本爵马武。"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "列位大人请了！"
        },
        {
          "character": "岑彭、杜茂、马武",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "今当万岁千秋之日，少时登殿，一同拜寿。香烟渺渺，圣驾临朝，分班伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引刘秀同上。"
        },
        {
          "character": "刘秀",
          "type": "引子",
          "text": "香烟缠渺，"
        },
        {
          "character": "刘秀",
          "type": "念",
          "text": "宝篆冲开紫气临，白水起义坐龙廷。黄道吉日登九五，五谷丰登乐太平。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "寡人，汉光武。昔走南阳，多亏众位皇兄帮助，邓先生妙算，削除莽贼，重兴 汉室。自登基以来，四海安静，真乃福泽无疆。众卿衣冠齐整，所为寡人圣寿。"
        },
        {
          "character": "郭荣、岑彭、杜茂、马武",
          "type": "同白",
          "text": "万岁，臣等拜寿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "内侍传孤旨意：命光禄寺大摆御宴，君臣同乐。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "可叹吓，可叹！"
        },
        {
          "character": "郭荣、岑彭、杜茂、马武",
          "type": "同白",
          "text": "圣上龙心不悦，臣等未解其情？"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "众位皇兄，俱已在朝与寡人庆寿，惟有姚皇兄镇守草桥关，受尽风霜，孤心不 安。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "万岁既然思念姚皇兄，何不将姚家父子，调进京来，陪王伴驾？"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "且慢！万岁将姚皇兄调进京来，倘若柳蛮反上，何人抵挡？有道是：一载干戈 动，十载不太平！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "万岁何不命马、杜、岑三人镇守草桥，料然无事！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "就依三位皇兄所奏，尊朕旨意：至草桥关，调换姚期，即日回都。退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭荣、岑彭、杜茂、马武分班，四太监引刘秀同下。八手下自两边分上。"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "同白",
          "text": "众将官，带马草桥去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌引姚期同上。"
        },
        {
          "character": "姚期",
          "type": "引子",
          "text": "终朝边塞征胡奴，扫灭蛮夷定河山。"
        },
        {
          "character": "姚期",
          "type": "念",
          "text": "塞北干戈起战争，南征北剿拜元戎。将令一出山摇动，镇守边关扫烟尘。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "老夫，伴驾王姚，汉室为臣。奉命镇守草桥。可恨王郎贼子，约齐各洞苗夷， 屡次攻打草桥，被俺父子血战争先，才得两家罢兵停仗。咳！不知何日才能卸 甲。正是："
        },
        {
          "character": "姚期",
          "type": "念",
          "text": "旌旗电闪遮日月，辕门鼓响震天阙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "龙虎台前出入，貔貅帐内传唤。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启王爷：圣旨下。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "何人押旨前来？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "马、杜、岑三位王爷。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "吩咐摆队相迎！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，同摆队，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马武、杜茂、岑彭、八手下同上，过场。姚期、四龙套同上，同出城。杜茂上前。"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "吓，姚皇兄！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "吓，杜皇兄！"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "待我下马。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "不必下马，请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武上前。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "吓！姚皇兄，待我下马。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "马皇兄不必下马，请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭上前。众人同进城，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姚期、马武、岑彭、杜茂、四龙套同上。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "见，圣旨下，跪！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "宣读诏曰：孤王思念功臣，调姚皇兄进京陪王伴驾。草桥之事，付与马、杜、 岑三位皇兄执掌。钦哉谢恩！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "万万岁！ 有劳三位皇兄奉旨前来，一路之上，多受风霜之苦！"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "同白",
          "text": "岂敢！姚皇兄镇守草桥，柳蛮不敢犯界，吾等佩服！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "夸奖了！"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "同白",
          "text": "我等到此，就该开度。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "中军看印！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武、杜茂、岑彭同拜印。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "三位皇兄镇守草桥，可喜可贺！"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "白",
          "text": "岂敢！姚皇兄几时起程？我等长亭饯行。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "准备明日起程。告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同待马，姚期下。"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "同白",
          "text": "明日准备酒宴，长亭饯行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姚夫人、姚刚、姚能同上。"
        },
        {
          "character": "姚夫人",
          "type": "念",
          "text": "夫君正朝堂，使我乐安康。"
        },
        {
          "character": "姚能",
          "type": "念",
          "text": "文韬武略广，"
        },
        {
          "character": "姚刚",
          "type": "念",
          "text": "力大逞刚强。"
        },
        {
          "character": "姚能、姚刚",
          "type": "同白",
          "text": "母亲！"
        },
        {
          "character": "姚夫人",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "姚能、姚刚",
          "type": "同白",
          "text": "谢母亲！父亲今日上关，这般时候，还不见回来？"
        },
        {
          "character": "姚夫人",
          "type": "白",
          "text": "想你父镇守草桥，那得一时安闲？坐在一旁，听为娘道来："
        },
        {
          "character": "姚夫人",
          "type": "二黄摇板",
          "text": "但愿得四下里狼烟扫尽， 一家人回朝转乐享安宁！"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "王爷回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期上。"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "马、杜、岑奉王命草桥来镇， 调老夫回朝转侍奉当今。"
        },
        {
          "character": "姚夫人",
          "type": "白",
          "text": "王爷！王爷今日下关，为何甚迟？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "夫人那里知道！今有圣上思念功臣，圣旨到来，调老夫进京，陪王伴驾。草桥 之事，付与马、杜、岑三位执掌。"
        },
        {
          "character": "姚夫人",
          "type": "白",
          "text": "我主乃有道明君！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "夫人那里知道！今有郭荣在朝专权，有道是："
        },
        {
          "character": "姚期",
          "type": "念",
          "text": "伴君如伴虎，昼夜不安宁。一朝龙颜怒，四体不周全！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "吓，爹爹！俺父子镇守边塞，有十大汗马功劳，怕那奸贼何来？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "哽！夫人你看姚刚性情倔强，力大无比，此番进京，夫人要严紧教训！"
        },
        {
          "character": "姚夫人",
          "type": "白",
          "text": "想二子自有妾身照管，王爷不必过虑。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "好！姚刚、姚能打点行李，随为父明日起程。"
        },
        {
          "character": "姚刚、姚能",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "姚期",
          "type": "念",
          "text": "交付兵权印，"
        },
        {
          "character": "姚夫人、姚刚、姚能",
          "type": "同念",
          "text": "回朝见明君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马武、杜茂、岑彭、四龙套同上。姚期、姚刚、姚能、四龙套同上。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "吓，三位皇兄，俺姚期有何德能，怎敢劳动众位皇兄，长亭饯行？"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "同白",
          "text": "姚皇兄，你我亦非一日之交，何出此言！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "姚刚、姚能，见过你三位叔父。"
        },
        {
          "character": "姚刚、姚能",
          "type": "同白",
          "text": "是。 参见三位叔父！"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "同白",
          "text": "罢了。此二位是谁？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "两个犬子。"
        },
        {
          "character": "马武、杜茂、岑彭",
          "type": "同白",
          "text": "原来是少王爷，日后必是皇家栋梁！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "夸奖了！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "来来，看酒！姚皇兄，待俺老马把敬你三大杯！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "讨饶了！"
        },
        {
          "character": "姚期",
          "type": "西皮快板",
          "text": "众皇兄赐我的饯行酒， 大家同饮太平瓯。 长亭拜别我就拱拱手， 回朝参王在那五凤楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期、姚刚、姚能、四龙套同下。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "众将官，将姚字旗号砍倒，换上马、杜、岑旗号。"
        },
        {
          "character": "杜茂、岑彭",
          "type": "白",
          "text": "且慢！倘若柳蛮反上，何人抵挡？"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "二位皇兄，那柳蛮不来便罢；倘若来时，你我三马连环，出得城去，杀他个落 花流水！"
        },
        {
          "character": "杜茂、岑彭",
          "type": "白",
          "text": "好！众将官，好好把守！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允。众人同下。"
