{
  "script_id": "01021007",
  "title": "雪夜访普",
  "alias": [
    "际会风云；一名：君臣乐"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "赵普",
      "hangdang": "净"
    },
    {
      "name": "张千",
      "hangdang": "丑"
    },
    {
      "name": "赵夫人",
      "hangdang": "正旦"
    },
    {
      "name": "曹彬",
      "hangdang": "小生"
    },
    {
      "name": "石守信",
      "hangdang": "副净"
    },
    {
      "name": "王全斌",
      "hangdang": "外"
    },
    {
      "name": "潘仁美",
      "hangdang": "末"
    }
  ],
  "plot": "宋太祖赵匡胤，自陈桥兵变，黄袍加身，开创一统之基业，天生令主，其历精开治之心，实有加人一等者，\n盖于受禅后，天下未曾大定。隅据群雄，尚有数处。太祖实不敢高拱深宫，以逸乐宴安为事。凡臣下有所奏\n陈，必咨取访问，不厌其烦。赵普为太祖所信任，位冠百僚之上，尝言以半部《论语》，佐太祖平治天下，\n无论军情政事，均与计议。太祖往往易服出行，至赵普私第接治。是夜风雪甚大，赵普以为可以无事矣，仍\n取《论语》，在书房细心检读，咀嚼其中趣味。突闻叩门声，命人探视，而太祖已翩然入内。相与酌酒围炉，\n极尽君臣之乐，遂定出兵之计纲，分遣将校，征讨诸乱焉。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵普上。"
        },
        {
          "character": "赵普",
          "type": "引子",
          "text": "执掌经纶，调鼎鼐，辅佐乾坤。"
        },
        {
          "character": "赵普",
          "type": "念",
          "text": "官居黄阁近丹阶，调元辅襄位三台。盐梅落落调羹手，舟楫堂堂济川才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千上。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "老夫，赵普。宋室驾前为臣，官居当朝首相。今日天下，虽已稍定，还有四处， 尚未平靖。圣上意欲发兵讨贼，与老夫商议。怎奈我日夜焦思，一时无策。 看今夜，风雪漫天，不免到书房中，去检阅史书。来，"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "掌灯，书房去者。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "赵普",
          "type": "二黄原板",
          "text": "有老夫在二堂心中烦闷， 想不出巧计策扫荡妖氛。 叫张千，"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "赵普",
          "type": "二黄原板",
          "text": "你与我把路引， 去到书房检阅书文。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "张千，好好看守府门，倘有什么紧急军情，速报我知。正是："
        },
        {
          "character": "赵普",
          "type": "念",
          "text": "捡今阅古聊为伴，独坐挑灯暂息眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普下，张千下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "江山一统坐汴京，几处干戈尚未平。独坐深宫天气冷，乔装私出访元臣。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤，赵匡胤。自从陈桥兵变，黄袍加身，即登大宝。天下虽然粗定，尚有江南、 两广、西川、吴越四处未平。今夜风雪漫天，因此私自出得宫闱，到丞相赵 普府中，商议平定贼寇大事。出得禁廷，好一派雪景！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "都只为边庭上贼兵骚扰， 在龙床睡不宁私自出朝。 寒风起更鼓催人声寂悄， 但只见半空中降下鹅毛。 五凤楼碧玻璃全不见了， 好一似粉装成玉宇琼瑶。 来至在丞相府门已闭了， 孤这里且向前轻把门敲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千上。"
        },
        {
          "character": "张千",
          "type": "念",
          "text": "侯门深似海，不许外人来。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "是哪个敲门？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "叫门官休叫我名姓通上， 我有言来你细听端详： 今夜晚特把你丞相来访， 你就说来了个赵大郎。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "你住了！"
        },
        {
          "character": "张千",
          "type": "二黄原板",
          "text": "说什么赵大郎来赵二郎， 细听我张千说端详： 丞相现在书房上， 他在灯下看文章。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "你家相爷看文章， 我也要去听听讲。"
        },
        {
          "character": "张千",
          "type": "二黄原板",
          "text": "俺这里是三公府， 并非寺院与佛堂。 你若是要听讲， 何不前去找和尚？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "我冒雪冲寒来相访， 有机密大事待商量。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "你既然有机密大事，何不早对我说？也免得费这许的唇舌。你且候着，待我与 你通报。 有请相爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普上。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "外面来了一人，说有机密大事要见。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "你去问他，是何处的官员，有什么紧急之事？这等时候，才来禀报！"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "方才也曾问过他来，他说他叫什么“赵大郎”。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "哦哈哈呀！原来是圣驾到了，快请夫人出堂。开正门，一同接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。赵夫人上。赵普、赵夫人同跪。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣赵普，不知圣驾到此，有失迎接，望吾主恕罪。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你等休要多礼，一同平身。"
        },
        {
          "character": "赵普、赵夫人",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普、赵夫人同起。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "张千，快取茶汤来。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千献茶。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "今夜如此风雪，万岁为何私出禁廷？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "爱卿呀！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "孤王在宫闱把龙床上， 不愿深宵梦高唐。 青衣便服出宫闲望， 特到此访贤卿同叙衷肠。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣启万岁：为臣有一书斋，颇可御寒，请万岁圣驾，到那里闲坐。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如此，卿家带路。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "领旨。张千，掌灯伺候。正是："
        },
        {
          "character": "赵普",
          "type": "念",
          "text": "君入臣门第，蓬荜又生辉。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣启万岁：臣有百花美酒，可以解寒。待臣持壶，臣妻把盏。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "既有佳酿，寡人自当叨扰。但烦皇兄自斟，何敢烦劳贤嫂？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣受君恩深重，愚夫妇理当孝敬。张千看酒伺候！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "卿家在此，所看何书？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "乃是《论语》。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "想这《论语》，乃是幼堂儒子所读，卿看它则甚？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "这《论语》，虽是儿童所读之书，但是那齐家治国平天下，都在上面。非比凡 书也！"
        },
        {
          "character": "赵普",
          "type": "二黄摇板",
          "text": "《论语》虽是儿童读讲， 经济权衡治朝纲。 圣道如天不可量， 一统山河定有方。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "听一言来心清气爽， 看此书果能够治国安邦。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "酒到。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "待臣妾与万岁把盏。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有劳皇嫂。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "雪夜里在相府同饮琼浆， 初登基庆丰年君明臣良。 老皇兄在筵前来斟佳酿， 老贤嫂在席间亲捧霞觞。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣糟糠之妻，何敢劳圣上，以“贤嫂”称之？"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "卿道是糟糠妻不下堂， 孤与卿贫贱交更不可忘。 孤好比周文王卿比姜尚， 你夫妻比梁鸿匹配孟光。 酒过了三巡甚是欢畅， 老贤嫂且回避孤有话商量。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤与卿家，有天下大事商量，贤嫂且请后堂歇息。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "万岁，万万岁！"
        },
        {
          "character": "赵夫人",
          "type": "念",
          "text": "臣妾裣衽归香阁，准备烹茶待圣人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵夫人下。"
        },
        {
          "character": "赵普",
          "type": "二黄摇板",
          "text": "天寒夜静雪纷纷， 何故私自出宫廷？ 国事明朝同众臣论， 圣驾何必亲降临？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "卿家呀！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "孤心中恨的是钱、李两王， 有刘银和孟泉更觉猖狂。 行霸道去仁义万民失望， 众黎民同受害各处遭殃。 命何人守西川，谁定两广？ 那江南同吴越无人主张。 我朝中哪一个是员良将？ 哪一个韬略广是架海金梁？ 定江山扶社稷要选能将， 还仗着老皇兄仔细参详。"
        },
        {
          "character": "赵普",
          "type": "二黄原板",
          "text": "万岁爷听为臣把本奏上： 定江山平疆土且莫着忙。 依臣见取西川后去上党， 再领兵去征剿江南的李王。 倘若是破刘银得了两广， 然后再除却那吴越的钱王。 这一班酒色徒不难扫荡， 旗开得胜定然是奏凯朝堂。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "卿家所奏，甚是有理。但有良策，应命何人前往？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣启万岁：想那孟泉、刘银、钱、李二王，皆是些酒色之徒，昏庸无道，暴虐 待人，民心怨恨。若命曹彬下江南，王全斌取西川，潘仁美定两广，石守信收 吴越，自必旗开得胜，马到成功。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "此四人之韬略，孤亦尽知。就命卿家，速速遣人，将四将唤进府来。急速着他 们，领兵前去。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "领旨。 张千，速速将四将，传进府来，不得有误。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "少刻四将到来，就命卿家，替孤传旨，不得有误。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千引曹彬、石守信、王全斌、潘仁美同上。"
        },
        {
          "character": "曹彬、石守信、王全斌、潘仁美",
          "type": "同念",
          "text": "江山本是将军定，还得将军定太平。深夜相爷传谕唤，同到相府请令行。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "四将到。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "圣驾在此，你等向前见驾。"
        },
        {
          "character": "曹彬、石守信、王全斌、潘仁美",
          "type": "同白",
          "text": "臣等见驾，愿吾皇万岁，万万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众卿少礼平身。"
        },
        {
          "character": "曹彬、石守信、王全斌、潘仁美",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众卿到此，丞相代孤传旨。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "赵普，今奉圣上谕旨，命曹彬带领五千人马，征剿江南，不得有误！"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "石守信，带领五千人马，攻打吴越，不得有误！"
        },
        {
          "character": "石守信",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "王全斌收取西川，须要小心！"
        },
        {
          "character": "王全斌",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "潘仁美，扫荡两广，须要在意！"
        },
        {
          "character": "潘仁美",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "明日校场，点动人马，即速兴兵前往。"
        },
        {
          "character": "曹彬、石守信、王全斌、潘仁美",
          "type": "同白",
          "text": "臣等，蒙圣上洪恩录用，当效犬马之劳。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众卿站立两厢，听寡人道来："
        },
        {
          "character": "赵匡胤",
