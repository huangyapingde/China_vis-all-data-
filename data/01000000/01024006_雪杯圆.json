      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "戚继光、莫文豪、莫文禄、莫怀古同上。"
        },
        {
          "character": "莫怀古",
          "type": "念",
          "text": "一家曾失散，"
        },
        {
          "character": "莫文豪、莫文禄",
