          "text": "〖吹打〗，〖牌子〗。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "待等选下良辰吉日，当将小女送到戚贤弟的衙门，一同齐拜华堂。贤弟意下如 何？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "但凭仁兄。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "后堂摆宴，大家痛饮一回便了。"
        },
        {
          "character": "莫怀古、陆炳",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。众人同下。"
