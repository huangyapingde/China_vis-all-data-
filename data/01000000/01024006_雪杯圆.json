{
  "script_id": "01024006",
  "title": "雪杯圆",
  "alias": [
    "一家团聚"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "莫怀古",
      "hangdang": "老生"
    },
    {
      "name": "戚继光",
      "hangdang": "末"
    },
    {
      "name": "陆炳",
      "hangdang": "外"
    },
    {
      "name": "莫文豪",
      "hangdang": "小生"
    },
    {
      "name": "傅氏",
      "hangdang": "老旦"
    }
  ],
  "plot": "蓟州总兵戚继光，与莫怀古交情甚厚。自莫成替主代戮，私放莫怀古至河北暂避。数年以来，不获晤面。招\n至署中，叙契阔之情。适直新巡按到任，戚继光迎接入城，在总镇衙门稍憩。巡按于途中感冒风寒，口中枯\n渴特甚。戚继光欲接钦差大员之欢心，即将一捧雪杯，斟茶奉上。而巡按睹物伤心，传命绑缚戚继光。逼问\n杯之出处。盖巡安非他，即莫怀古之子莫文豪。当初年纪尚幼，只知乃父为一捧雪杯，受戮于蓟州；不知戚\n继光暗中救护，得保身名一节。所以认出此杯，系家传之物，欲与戚继光为难。于是戚继光立唤莫怀古上前，\n父子相逢，悲喜交集。从前承审是案之刑部官陆炳，奉旨昭雪莫氏之冤。道经蓟州，相见之下，始悉严嵩\n势力已倒，抄没家产，父子治罪。遂设筵宴庆幸，于席间互订婚姻，且互为媒妁：陆炳之女，许配莫文豪；\n戚继光之女，许配莫文禄。均为之择吉成亲云云。",
  "notes": "前后《一捧雪》之剧，本考曾载三出（详见十二、十四、十五册内）。是剧为《一捧雪》中之二本《雪杯圆》\n。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军、戚继光同上。"
        },
        {
          "character": "戚继光",
          "type": "引子",
          "text": "深习兵机，扶大明，锦绣华夷。"
        },
        {
          "character": "戚继光",
          "type": "念",
          "text": "防御京畿数十秋，威风杀气贯斗牛。胸中韬略般般有，统领雄兵镇蓟州。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "本镇，戚继光。大明驾前为臣，官拜蓟州八台总镇。昔年曾与莫仁兄相交多年， 亲同骨肉。恼恨汤勤，在严府搬动是非，暗害莫仁兄的性命。幸喜掌家莫成， 替主身死。莫仁兄逃往河北避难。至今数载有余。吾也曾修书前去，请他到 此。为何还不见到来？ 左右，伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允。探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "莫大老爷到！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅氏引莫文禄同上，戚继光见。傅氏拱手。傅氏引莫文禄同下。莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "戚贤弟！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "莫仁兄！请坐。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁兄一路行来，多受风霜之苦。小弟未曾远迎，当面恕罪。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "岂敢。想昔年，多承贤弟搭救性命之恩。愚兄当面谢过！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "但不知当年愚兄去后，严府怎生了结？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁兄再休提起。自从仁兄去后，弟即将掌家莫成斩首，将首级装入木桶，交与 严府校尉带回京都。不想那汤勤，又在严世藩前搬动是非。他言道头是假：仁 兄脑袋，有三台肉枕，此头无有，分明是假。那严世藩大怒，当将小弟也拿问 进京，统交总都部堂审问。幸喜遇着陆炳。陆仁兄见此案分明是那汤勤狗男女， 中国京剧戏考 《雪杯圆》【二本】 2 贪爱雪艳嫂嫂美貌，要害仁兄。竟将此案，糊涂了结。但是陆仁兄，做了一 桩不才之事。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "什么不才之事？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "陆仁兄竟将雪艳嫂嫂，就断给了那汤勤了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "此事做的大大无才！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "但不如此，那汤勤依旧说人头不真，焉能结案？今將雪艳嫂嫂断给了那厮，他 竟自回复严府，此事可也就完了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁兄方才言道，陆仁兄无才。哪知他却倒是有才。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "那雪艳嫂嫂虽然应允，不料她进得洞房，暗藏利刃。用酒将汤勤劝醉，将汤勤 一刀就刺死了。仁嫂那时忙中无计，无处逃脱，她也就自刎而死。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "自刎而死。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "哎呀，妻呀！"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "听一言来吃一惊， 不由得怀古泪双淋。 恨汤勤他把天良丧尽， 暗夺我妻昧天伦。 屡屡设计将我害， 多亏掌家小莫成。 蓟州堂替我丧了命， 汤勤又把巧计生。 他说人头乃是假， 一心要雪艳来成亲。 陆仁兄将计就计果应允， 洞房刺死小汤勤。 可怜你为人多贞静， 可怜你为我丧残生。 这才是天理循环有报应， 善恶到头甚分明。 哭一声我的妻早归仙境，"
        },
        {
          "character": "莫怀古",
          "type": "哭头",
          "text": "我的妻呀！"
        },
        {
          "character": "莫怀古",
          "type": "二黄摇板",
          "text": "万古流芳落美名。"
        },
        {
          "character": "戚继光",
          "type": "二黄摇板",
          "text": "仁兄不必泪淋淋， 小弟言来听在心： 仁嫂报仇雪了恨， 冤冤相报不差毫分。 汤勤已死有何论， 仁嫂可算是节烈妇人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启总爷：按院大人在此下马。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "知道了。 吓仁兄，少坐一时。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "贤弟，按台在此下马，愚兄是见不得他的。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "无妨。仁兄就暂且隐藏校尉身后，料也无妨。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "但凭贤弟。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古下。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "众将官，整齐队伍，迎接按台去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光脱蟒袍、盔甲，上马。〖风入松〗。戚继光、四龙套、中军同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《雪杯圆》【二本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手、四龙套、四大铠、中军、二门子同上。"
        },
        {
          "character": "莫文豪",
          "type": "内西皮导板",
          "text": "奉王旨意出帝京，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文豪上。"
        },
        {
          "character": "莫文豪",
          "type": "西皮原板",
          "text": "为国为民哪得安宁。 扫除强梁和恶棍， 贪官污吏怎胡行！ 心中常常怀怨恨， 杀父之仇要报清。 人役催马往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手引戚继光同上，同出城，同迎上。戚继光跪。"
        },
        {
          "character": "戚继光",
          "type": "西皮原板",
          "text": "蓟州总镇迎接大人。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启大人：蓟州总镇戚继光，迎接大人。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "察院伺候。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "蓟州镇察院伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同入城，同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手、四龙套、四大铠、中军、二门子、莫文豪、戚继光同上。莫文豪升帐。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "蓟州总镇戚继光，参见老大人！"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "贵镇卸了盔甲，再来讲话。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "多谢老大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。戚继光换袍纱帽、捧册子上。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "参见大人！"
        },
        {
          "character": "门子甲",
          "type": "白",
          "text": "起，免，打恭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手、四龙套、四大铠同喊。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "谨将公文花名清册呈上。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "贵镇免礼。请坐。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "我且问你：这蓟州目仓库如何？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仓库充满。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "兵丁将士？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "兵丁强壮，将士威严。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "营中器械？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "刀枪明亮，盔甲鲜明。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "城中街道？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "四门齐整，街巷清尘。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "且住！本院只望要报父仇，寻他的短处。怎奈他为官清廉，办事谨慎，这便怎 处？好不闷坏吾也！"
        },
        {
          "character": "莫文豪",
          "type": "西皮摇板",
          "text": "杀父之仇不能报， 怎不叫人心內焦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文豪吐。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "中军老爷请过来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大人得的是何病症？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "只怕是途中受了风寒，得了伤风病症。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "如此待我取杯茶来与大人所用。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "好，你快去取来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光取茶递中军，中军递莫文豪，莫文豪饮。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "大人醒来！"
        },
        {
          "character": "莫文豪",
          "type": "西皮导板",
          "text": "一霎时气得我昏迷不醒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文豪看杯。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "吓！ 中国京剧戏考 《雪杯圆》【二本】 4"
        },
        {
          "character": "莫文豪",
          "type": "西皮摇板",
          "text": "见此杯想起了居家满门。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "来，将戚继光与我绑了！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大人为何将我绑起来了？"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "我且问你：这支杯子本是我家之物，你是哪里来的？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大人若要问这杯子，却有杯主。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "这杯主是哪一个？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "就是钱塘的莫怀古。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "他如今还在么？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "怎么不在？"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "现在哪里？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "现在卑镇的衙中。"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "你快快请他前来。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "哎呀大人呐！似这样绳捆索绑，是怎样去唤他呀？"
        },
        {
          "character": "莫文豪",
          "type": "白",
          "text": "中军，与他松绑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光下堂叫。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "莫仁兄快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "贤弟你也来同吃一杯呀！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "你还吃的是什么酒？大人叫我前来唤你。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "吾乃是有罪之人，如何能去见他呀？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁兄有所不知：适才大人到此，忽然得下风寒之症。弟因他是朝廷钦差，不敢 怠慢。因将仁兄传家之宝与他看了一杯香茶。大人用下，病体果愈。不料他看 见了杯子，就将小弟绑起。他说杯子是他家之物，追问此杯从何得的？我一时 无奈，可就把你给端出来了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "既然如此，这便怎样呢？"
        },
        {
          "character": "戚继光",
