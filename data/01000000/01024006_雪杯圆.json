          "character": "莫怀古",
          "type": "白",
          "text": "好一个“相逢仍在蓟州城”。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古、戚继光、莫文豪同笑，同下。"
        }
      ]
