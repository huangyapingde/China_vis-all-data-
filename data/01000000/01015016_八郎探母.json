        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "吓，母亲，她是何人？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "他就是你四嫂。"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "上前来见四嫂把礼恭敬， 为叔的有一言细听分明： 吾四哥在番邦也曾相认， 对四嫂他言道不久就要回营。"
        },
        {
          "character": "四夫人",
          "type": "白",
          "text": "多谢八叔，这是他说的？"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "转面来就把我老母来问， 我六哥这几日可在宋营？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "现在营中，人来，叫他前来相会。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "不要，不要，"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "吾弟兄相会了说话不尽， 误过了五更时大事难成。 有千言和万语难以说尽， 想起了贤公主一片人情。"
        },
        {
          "character": "俞氏",
          "type": "白",
          "text": "哦，母亲，不要放八将军回去。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "这个自然。"
        },
        {
          "character": "杨延顺",
          "type": "西皮导板",
          "text": "喜呵呵笑盈盈把母来敬，"
        },
        {
          "character": "杨延顺",
          "type": "西皮二六板",
          "text": "尊一声老太君吾的娘亲： 番邦女临行时有言说定， 一桩桩一件件记挂在心： 送老母万寿球头上戴定， 送老母珍珠串可修空门； 送老母菱花镜容颜照定， 送老母护心镜不可离身。 送老母长寿珠颈上挂定， 愿老母长生不老，不老长生你是个老寿星！ 众嫂嫂上前来有礼恭敬， 送嫂嫂长寿帕随带在身； 送妹妹绫罗带身上挂定， 表一表番邦女一片好心。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "多谢了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "俞氏哭。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "俞氏妻在一旁珠泪滚滚， 说两句好言语宽她的心： 自那年下幽州打下一阵， 为丈夫失了计被他所擒。 高堂上老太君蒙你孝顺， 你本是吾杨家大孝之人！"
        },
        {
          "character": "俞氏",
          "type": "哭",
          "text": "夫呀！"
        },
        {
          "character": "俞氏",
          "type": "慢西皮二六板",
          "text": "手挽手站营门珠泪滚滚， 尊一声杨八顺吾的夫君： 自那年下幽州打下一阵， 吾的夫失了计被他所擒。 高堂上老婆婆无人侍奉， 吾国中大小将哪里找寻？ 妻为你茶和饭不去沾唇， 妻为你每日里懒整乌云； 妻为你在营外常常问信， 妻为你各古庙去求神明； 妻为你每日里五荤戒尽， 妻为你绣房中独伴孤灯； 妻为你每夜里思夫不寝， 妻为你梦中间泪沾衣襟； 妻为你分别了一十二春， 到如今你那里才回宋营。 有千言和万语说之不尽， 天波府好一似带发修行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "打更。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "谯楼上打过了四更鼓尽， 想起了番邦女就要回营。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎吓，母亲吓！孩儿回去，与四哥说明，带了妻小回朝，岂不两全其美？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿吓，不要去罢！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "此番不去，一双儿女，岂不断送他人之手？"
        },
        {
          "character": "俞氏",
          "type": "白",
          "text": "婆婆吓，他乃脱身之计！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "贱人吓！"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "俞氏妻在一旁多言多论， 误过了五更时大事难成！ 硬心头别老母忙上能行，"
        },
        {
          "character": "俞氏",
          "type": "西皮摇板",
          "text": "有妻子上前来扯住衣襟！ 吾哭一声杨八顺吾的夫君，"
        },
        {
          "character": "俞氏",
          "type": "哭",
          "text": "夫君吓！"
        },
        {
          "character": "俞氏",
          "type": "西皮摇板",
          "text": "夫妻们分别了十二春！ 到今日你回营未把话论， 怎能够今夜间即要回程？"
        },
        {
          "character": "俞氏",
          "type": "哭",
          "text": "八顺，吾的夫吓！"
        },
        {
          "character": "俞氏",
          "type": "西皮摇板",
          "text": "奴这里只哭得珠泪难忍， 怎舍得高堂上年迈太君？"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "一家人都哭得珠泪滚滚， 吾腹内好一似钢刀刺心！ 顾不得妻和母扳心难定， 马上加鞭回番营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺下。"
        },
        {
          "character": "众嫂嫂",
          "type": "同白",
          "text": "叔叔回来吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺上。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "母亲吓，俞氏吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众嫂嫂、杨延顺同下。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "吾儿八顺吓！"
        },
        {
          "character": "俞氏",
          "type": "白",
          "text": "杨八顺，吾的夫吓！夫吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
