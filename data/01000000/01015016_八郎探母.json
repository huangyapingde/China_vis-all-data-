          "character": "杨延顺",
          "type": "哭",
          "text": "公主吓！"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "不到五更回番营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺下。"
        },
        {
          "character": "碧莲公主",
          "type": "西皮摇板",
          "text": "一见驸马上马行， 不由咱家挂在心。 泪眼含悲宫门进， 但愿驸马早回程。"
        },
        {
          "character": "碧莲公主",
          "type": "哭",
          "text": "驸马吓……"
