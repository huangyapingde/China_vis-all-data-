  "plot": "宋辽失和，屡次动兵，自金沙滩双龙会（即八虎闯幽州）一役，为辽所败，杨老令公之子，或死或亡，承欢\n膝下者，只有六郎。后令公被困两狼山，撞死李陵碑下，父子尽忠于王事，后之人皆称道勿衰也。佘太君亦\n有军事知识，及六郎为帅，太君年虽耄老，每在营中参赞机宜。当初八郎失在辽邦，改姓名为王司徒，萧太\n后配以碧莲公主，生有子女，为辽邦驸马。荏苒已十二年矣。辽又伐宋，宋命六郎征之。八郎得悉佘太君同\n在一处，意欲乘机探望老母，谋于公主初则不许，继欲杀子以要求，惧而许之，入太后宫，代为盗出令箭，\n赠于八郎，约定黎明即返，不得逗留。",
  "notes": "剧本事实，无从考证，本考载有《四郎探母》一出，同一用意，编排者大约胎息于此，惟唱口白口，绝不相\n同。即是《雁门关》第一、第二两本，腔调全是西皮。前见北京四喜班名伶，如余紫云、梅巧玲、时小福等，\n串演此剧，唱做工夫，极璧合珠联之妙。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "萧燕宗、杨延顺、韩延寿、韩延庆同上。"
        },
        {
          "character": "萧燕宗",
          "type": "念",
          "text": "锦衣上绣花，"
        },
        {
          "character": "杨延顺",
          "type": "念",
          "text": "朝阳骑骏马。"
        },
        {
          "character": "韩延寿",
          "type": "念",
          "text": "待漏朝女王，"
        },
        {
          "character": "韩延庆",
          "type": "念",
          "text": "大将长尾巴。"
        },
        {
          "character": "萧燕宗",
          "type": "白",
          "text": "俺，萧燕宗。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "本宫王司徒。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "韩延寿。"
        },
        {
          "character": "韩延庆",
          "type": "白",
          "text": "咱，韩延庆。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "列位请了，太后登殿，在此伺候，请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、萧太后同上。"
        },
        {
          "character": "太监",
          "type": "同白",
          "text": "咦咦咦咦。"
        },
        {
          "character": "萧太后",
          "type": "念",
          "text": "双凤绕花梁，珠帘黄罗帐。"
        },
        {
          "character": "太监",
          "type": "同白",
          "text": "咦咦。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "臣等参见太后千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "列位卿家，可知征剿杨家之事如何？"
        },
        {
          "character": "韩延庆",
          "type": "白",
          "text": "但等探马报来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "他国人马勇，难以占头功。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "孩子见驾，愿太后千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "命你打听杨家之事，如何下落？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启奏太后：头一阵把杨六杀的大败。那杨六回到天波府，搬来他母亲，他身边 有一个他妈的杨排风，十分厉害，杀得吾国孩子大败，望太后就发兵对敌！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "王驸马，"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "千岁。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "命你挂帅征剿杨家，不得有误。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "杨延顺",
          "type": "叫头",
          "text": "咳，亲娘呀！"
        },
        {
          "character": "杨延顺",
          "type": "西皮导板",
          "text": "宋皇爷有道坐龙楼，"
        },
        {
          "character": "杨延顺",
          "type": "西皮慢板",
          "text": "萧太后打战表累战无休。 吾六哥打一战兵败寨口， 搬来了吾的母驾到幽州。 吾本当回宋营把母问候， 尤恐怕贤公主不放吾回头。 左一思右一想珠泪双流，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主上。"
        },
        {
          "character": "碧莲公主",
          "type": "西皮慢板",
          "text": "驸马爷你为何泪双流？"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "呀，公主请坐。呀，公主可曾听得本宫说的什么？"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "呀，驸马，方才说的是天朝之事。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "咳，泪似湘江水，一点一声愁！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "驸马今日为何这等模样？"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "咳，事到如今，我也不瞒公主了，你吾打坐一旁，听吾道来。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "驸马请坐。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "母亲吓！"
        },
        {
          "character": "杨延顺",
          "type": "西皮慢板",
          "text": "未开言不由吾双泪飘， 尊一声贤公主细听根苗： 自那年沙滩会血染战袍， 可怜吾父子们死故亡逃。 吾大哥替宋主把忠尽了， 吾二哥短剑亡血染荒郊。 吾三哥马踹死把命丧了， 吾四哥无形影不见回朝。 吾五哥抛红尘削发修道， 吾六哥镇三关常把阵剿。 吾七哥被奸贼乱箭花标， 有本宫杨八顺来到你朝。 蒙太后不杀吾恩同再造， 贤公主待本宫情"
        },
        {
          "character": "杨延顺",
          "type": "西皮快板",
          "text": "重义高！ 多只为今早朝探马报到： 他报到吾的母驾临北朝。 吾本当辞公主把母来孝，把母来孝，公主吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺哭。"
        },
        {
          "character": "杨延顺",
          "type": "西皮快板",
          "text": "望公主开鸿恩放吾回朝！"
        },
        {
          "character": "碧莲公主",
          "type": "西皮慢板",
          "text": "听他言不由我心中忧闷， 却原来杨八顺来到番营。 咱与你做夫妻一十二春， 说什么今日里要回宋营。 在吾朝享荣华何等清净， 怎舍得儿和女骨肉离分。"
        },
        {
          "character": "杨延顺",
          "type": "西皮快板",
          "text": "说什么享荣华何等清净， 说什么儿和女骨肉离分。 常言道生养儿不把母孝， 要什么儿和女接代根苗？ 没奈何上前来双膝跪倒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺哭。"
        },
        {
          "character": "杨延顺",
          "type": "哭头",
          "text": "公主吓！"
        },
        {
          "character": "杨延顺",
          "type": "西皮快板",
          "text": "发慈悲全忠孝恩比天高！"
        },
        {
          "character": "碧莲公主",
          "type": "西皮摇板",
          "text": "驸马爷休得要再三哀告， 吾母后若知道颈上加刀！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "呀吓！"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "贤公主她那里把脸变了， 拿太后压本宫怒气难消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子、姑娘同上。"
        },
        {
          "character": "公子",
          "type": "西皮摇板",
          "text": "咱的爹咱的母二堂吵闹， 叫一声贤妹妹细听根苗： 兄妹们上前来双膝跪倒， 尊一声咱的爹休回天朝！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "儿吓，起来！他不是你家老子，不要跪他！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "唉吓！"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "这贱人说此话心如刀绞， 不由吾一阵阵怒气难消！ 吾这里执宝剑将儿杀了！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "儿吓，来！"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "我杀了儿和女各自奔逃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺、公子同下。"
        },
        {
          "character": "姑娘",
          "type": "白",
          "text": "吓，母亲大事不好了！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "什么大事？"
        },
        {
          "character": "姑娘",
          "type": "白",
          "text": "爹爹杀阿哥去了！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "这还了得，快快前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主、姑娘同下。公子哭上，杨延顺上。"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "杨八顺执宝剑要杀儿命……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主上。"
        },
        {
          "character": "碧莲公主",
          "type": "西皮摇板",
          "text": "有妻子上前来扯住衣衿： 咱和你做夫妻一十二春， 为什么杀姣生所为何因？ 今日里一心心要回宋营， 你不该执宝剑要杀姣生。 你要去探母亲咱也依允，驸马吓！"
        },
        {
          "character": "碧莲公主",
          "type": "西皮锁板",
          "text": "你杀姣生吾痛心！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "杨延顺",
          "type": "西皮快板",
          "text": "非是本宫心肠狠， 只为老母挂在心。 公主放吾回宋营， 结草衔环不忘恩！"
        },
        {
          "character": "碧莲公主",
          "type": "西皮快板",
          "text": "本当放你回宋营， 怕你一去不回程。"
        },
        {
          "character": "杨延顺",
          "type": "西皮快板",
          "text": "公主怕吾不回程， 吾对苍天把誓盟： 八顺探母不回程， 死在千军万马营！"
        },
        {
          "character": "碧莲公主",
          "type": "西皮快板",
          "text": "一见驸马把誓明， 不由咱家喜在心。 吾到深宫盗一令， 盗令回来早动身。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "有劳公主了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主下。"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "一见公主去盗令， 不由本宫喜在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "萧太后上。"
        },
        {
          "character": "萧太后",
          "type": "西皮摇板",
          "text": "可恨杨家兵将勇， 王驸马难以占头功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主、公子同上。"
        },
        {
          "character": "碧莲公主",
          "type": "西皮摇板",
          "text": "手挽姣儿銮庭进， 见了母亲礼相迎。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "儿臣见驾。母后千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "王儿平身，赐坐。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "谢坐。母后，征剿杨家之事如何？"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "王儿有所不知，只因二驸马，被杨家杀得大败而回。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "母后传下将令，待孩儿前去征剿杨家。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "好，停兵三日，就命吾儿前去。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "多谢母后！ 哦，儿吓。这是母后金鈚御令，拿在手内做什么？"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "儿要玩的！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "这是玩不得的。"
        },
        {
          "character": "公子",
          "type": "白",
          "text": "儿要玩！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "你不丢下来，吾要打你小杂种！"
        },
        {
          "character": "公子",
          "type": "哭",
          "text": "哎呀！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "小孩子打他做什么？"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "母后的金鈚御令，他要玩。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "小孩子，他晓得什么？今晚要玩，明晚五鼓送进宫来就是。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "多谢母后了。"
        },
        {
          "character": "碧莲公主",
          "type": "西皮摇板",
          "text": "谢罢母后出宫庭， 袖内机关怎知情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主、公子同下，萧太后下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺上。"
        },
        {
          "character": "杨延顺",
          "type": "西皮摇板",
          "text": "公主后宫去盗令， 这时为何无信音？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主、公子同上。"
        },
        {
          "character": "碧莲公主",
          "type": "西皮摇板",
          "text": "带领姣儿宫门进， 见了驸马说分明。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "呀，公主来了。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "来了。"
        },
        {
