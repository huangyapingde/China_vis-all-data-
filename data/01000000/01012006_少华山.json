{
  "script_id": "01012006",
  "title": "少华山",
  "alias": [
    "富贵图；一名：烤火落店"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "倪厚",
      "hangdang": "小生"
    },
    {
      "name": "殷碧莲",
      "hangdang": "花旦"
    },
    {
      "name": "大王",
      "hangdang": "净"
    },
    {
      "name": "喽罗",
      "hangdang": "丑"
    },
    {
      "name": "丫鬟",
      "hangdang": "彩旦"
    }
  ],
  "plot": "相传有宦家女殷碧莲，因事背父偕婢宵遁。女流不识路径，蹀躞中途误经少华山。少华山本盗窟，殷碧莲遂\n被盗魁劫之上山。适有书生倪顺田在山，托词解救，以一言脱殷碧莲于难。书生盖盗魁所敬礼，而待之如上\n宾者，故非但听其言，且当场即以殷碧莲配书生。令二人交拜天地，行夫妇礼，乃送之入洞房（本剧从此处\n做起）。不意在殷碧莲则嫁得如意郎君，心中十分满意；而书生反矢口已有糟糠，竭力坚辞。且谓此次系晋\n京应试，志在功名，决不以儿女之情，自阻其鹏程。遂终夜烤火危坐，不敢实行夫妇之礼。经殷碧莲再四劝\n告，乃商定挈同下山，以出殷碧莲于险。而殷碧莲则抱定宗旨，谓形式上已成夫妇，事非儿戏，万无他适之\n理，誓必委身于君也。及明，书生请于盗魁，遂同下山。盗魁当赠“富贵图”一帧而别（本剧即至此而终）。\n然烤火之后，继以落店。",
  "notes": "尚有《池水驿》一段，当接连演唱。即夫妇二人偕同落店之后，书生将殷碧莲托诸旅店女主人，而孤身晋京\n应试之一段别离情形也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。丫鬟、喽罗同搬物件上，倪厚、殷碧莲同上，丫鬟下。"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "解元爷，请过来见礼。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "仁兄施礼为何？"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "方才在山下迎接，是我。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "多亏仁兄。"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "我这里还有一礼。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "又施礼为何？"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "适才山前游玩，也是我来。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "也多亏仁兄。"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "我这里还有一礼。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "哎呀呀，哪有许多的礼吓。"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "自古道，“礼多人不怪”。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "好一个“礼多人不怪”！又施礼为何？"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "今夜洞房花烛……"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "让与仁兄！"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "这就不敢！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "我要与你叙谈叙谈。"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "待我搬把椅儿来，与你叙谈叙谈。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "哎，为何将门倒扣？"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "我家大王之吩咐。里面一床一被一盆火，随你怎么做法。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "我要便。"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "大便有马桶，小便有夜壶，喝茶有茶壶。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "我要游玩游玩。"
        },
        {
          "character": "喽罗",
          "type": "白",
          "text": "前山有巴虎，后山有老虎，出来咬了你的屁股。哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "喽罗下。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "仁兄转来，仁兄转来。吓，想是走远了。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "解元爷请来见礼。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "小娘子讲些什么？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "适才在大王面前，刀下救我不死。当面谢过！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "些须小事，何劳一谢。请坐。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "有坐。请问解元爷，家住哪里？姓甚名谁？因何到此，与大王同伙？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "生姓倪名厚，表字顺田，新驿县人氏。此山大王，乃是我的好友，请我饮宴， 并无别事。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "这就是了。请问解元爷，家中还有什么人？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "小娘子既问，听生一言："
        },
        {
          "character": "倪厚",
          "type": "西皮慢板",
          "text": "有小生少年时父亡母寡， 娶舍妻也算得贤良姣娃。 住几间破草房房屋不大， 家贫穷全靠着仿写字画。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "听解元爷之言，家中还有婆婆、大娘子么？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "啊？适才大王面前，救你不死，你倒当起真来了？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "吓，解元爷，在大王面前拜罢天地，入了洞房，这婚姻之事，何以为假？"
        },
        {
          "character": "殷碧莲",
          "type": "西皮慢板",
          "text": "拜天地入洞房何言为假？ 尊一声解元爷细听根芽： 你救我不死那钢刀之下， 像这样大人情怎样报答？"
        },
        {
          "character": "倪厚",
          "type": "西皮原板",
          "text": "适才间我救你钢刀之下， 不过是恻隐心暂且允答。 你本是贵人妻必真不假， 说这些不中听惹人笑话。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "如此说来，奴多口了。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "你忒以地多口吓！"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "解元爷请过来拜揖！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "小娘子有何话讲？"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "你看天夜深了，你我上床安眠。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "小娘子请上床安眠，我在此地，一旁烤火。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "如此，不恭了。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "礼该。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "占先了。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "得罪了。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "岂敢岂敢哪。"
        },
        {
          "character": "殷碧莲",
          "type": "西皮慢板",
          "text": "解元爷只生得十分好看， 他好比小潘郎俱是一般。 我只得上床去罗帐高悬， 今夜晚但看他怎样终场？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "哎，妙吓！小娘子睡在床上，如同酒醉海棠一般，叫我年少之人，如何忍耐得 住？吓，不免上床与她安眠了罢。慢、慢、慢、慢着！"
        },
        {
          "character": "倪厚",
          "type": "西皮原板",
          "text": "想起了我的娘吩咐之话： 她叫我中途路少要贪花。 我本是鱼得水还未变化， 此一去跳龙门舞爪伸牙。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "好困吓。看天到这般时候，他还在那里烤火。不免下床与他明讲了罢。 吓，解元爷，上床安眠。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "还是下面奉陪。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "解元爷请安眠。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "你请上床安眠。我在此地奉陪。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "解元爷，奴有下言告禀。"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "小娘子有话，落坐请讲。"
        },
        {
          "character": "殷碧莲",
          "type": "白",
          "text": "奴家姓殷，小字碧莲。我父官居一品，自幼将奴许配张郎为妻。是奴见他生得 丑陋，无心于他。因此我主仆连夜逃出潼关。路过此山，被大王抢上山来。蒙 解元爷救我不死，当着大王拜罢天地，入了洞房。这婚姻之事，托付你身上了。"
        },
        {
          "character": "殷碧莲",
          "type": "西皮慢板",
          "text": "与解元对坐在洞房之下， 你听我把此话细说根芽： 我本是闺门女必真不假， 为什么今夜晚不睬奴家？"
        },
        {
          "character": "倪厚",
          "type": "西皮原板",
          "text": "今夜晚非是我装聋卖哑， 都只为少华山男女混杂。 但愿得咱二人同把山下， 你往东我往西各奔天涯。"
        },
        {
          "character": "殷碧莲",
          "type": "西皮原板",
          "text": "解元爷讲的是离别之话， 倒叫我一阵阵意软心麻。 到明天我二人同把山下， 下山去咱二人再作计法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大王上，四龙套同上。"
        },
        {
          "character": "大王",
          "type": "白",
          "text": "仁兄起床来了？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "起床来了。"
        },
        {
          "character": "大王",
          "type": "白",
          "text": "为何起得这等甚早？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "弟的功名要紧。告辞！"
        },
        {
          "character": "大王",
          "type": "白",
          "text": "这里有“富贵图”一轴、银子二百、大马二匹，仁兄收下！"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "“富贵图”、银子收下，大马不用。"
        },
        {
          "character": "大王",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "倪厚",
          "type": "白",
          "text": "路中行走不便。"
        },
        {
          "character": "大王",
          "type": "白",
          "text": "来，带马送解元爷下山！正是："
        },
        {
          "character": "大王",
          "type": "念",
          "text": "但愿此去上九重！"
        },
        {
          "character": "倪厚",
          "type": "念",
          "text": "星散月落上元黄。"
        },
        {
          "character": "大王",
          "type": "念",
          "text": "幸喜洞房花烛夜，"
        },
        {
          "character": "倪厚",
          "type": "念",
          "text": "哪知我今晚恨夜长！"
        },
        {
          "character": "倪厚",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪厚、大王同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}