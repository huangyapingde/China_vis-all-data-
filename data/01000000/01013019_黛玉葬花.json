{
  "script_id": "01013019",
  "title": "黛玉葬花",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "林黛玉",
      "hangdang": "旦"
    },
    {
      "name": "贾宝玉",
      "hangdang": "小生"
    }
  ],
  "plot": "林黛玉夜访贾宝玉，丫鬟恶语相对，拒不开门。林黛玉疑是贾宝玉故意不见，很懊恼。次日，见园中落花无\n主，乃荷锄葬花，并赋《葬花词》，以遣秋思。贾宝玉适至，表明心迹，二人又言归于好。",
  "notes": "林黛玉葬花，为《石头记》中大观园十二影事之一，即第二十七回“埋香冢黛玉泣残红”之一段，固已尽人\n皆知，亦无待大错赘述。至编入戏剧，则曾闻樊樊山，已先为兰芳梅郎编排之。梅郎于京师已曾串演，其扮\n演此戏之摄影，曾见诸本馆所出之游戏杂志中，洵歌场韵事也，惟其脚本则吾未之见。然传闻梅郎于此剧，\n练成之后，亦不常演。《红楼梦》剧之难编难演，即斯可想见矣。此脚本系予倩所编，复经冥飞尘因为之润\n词，其唱白句语，悉从原书中剪裁而出，风雅细腻，洵于剧本中得来未曾有。惟程度过高尚，戏情过曲深冷\n淡，恐终非今日戏世界中，其一般普通听戏之眼光者，所欢迎也欤。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉上。"
        },
        {
          "character": "林黛玉",
          "type": "引子",
          "text": "春去无痕，莽天涯，怎不销魂？"
        },
        {
          "character": "林黛玉",
          "type": "念",
          "text": "长安三月踏春阳，处处春阳总断肠。红瘦绿肥人寂寞，杜鹃声里吊余芳。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "奴家林黛玉。幼失怙恃。多蒙外祖母史太君抚养，寄居荣国贾府之中。诸姑伯 姊，却也是另眼相看，只有宝玉哥哥，偏偏要无理取闹，昨晚偶过怡红院，他 却是闭门不理。咳，这也是寄人篱下的苦处，怎不叫人伤感也！"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "叹春光都付与多愁多病， 奈何天辜负了美景良辰。 可怜奴无家雁霜天只影， 好比那萍和梗一样飘零。 花如烟柳如卷落花成阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉抚琴，叹。"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "这焦桐却为何弹不成声？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉翻书。"
        },
        {
          "character": "林黛玉",
          "type": "念",
          "text": "“良辰美景奈何天，赏心乐事谁家院？”"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "咳，这乃杜丽娘伤春之词，怎么她也是这样的情怀哪！"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "似这般无聊赖春将人困， 我只得对鹦鹉却诉衷情。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "呵，鹦鹉，这几年来，我与你相依为命。想我黛玉，自幼父母双亡，又无兄弟 姊妹，独自一人，零丁孤苦。如今离乡别井，寄居舅母家中。虽然是长者慈爱， 怎么比得自己的双亲。只有表哥宝玉，嗳呀，再休提起！想我这畸零之身， 哪里还有人体谅我的苦衷，哪里还有人知道我的心事呵。鹦鹉鹦鹉，怎么你也 无言。难道说他厌弃我，你也厌弃我不成咳？黛玉呵，黛玉，你真好命苦呵！"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "似有情却无情教人深恨， 能言鸟竟无语安慰奴心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃上。"
        },
        {
          "character": "紫娟",
          "type": "白",
          "text": "姑娘的痴病又发了，必定又是宝二爷得罪了他。 呵，姑娘，今日乃是饯花盛会，各房的奶奶姑娘，都在园里送春，等候姑娘前 去，联诗饮酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉如不闻。"
        },
        {
          "character": "林黛玉",
          "type": "念",
          "text": "炉烟如我瘦，辛苦未成灰。"
        },
        {
          "character": "紫娟",
          "type": "白",
          "text": "姑娘，各房的奶奶姑娘们在园子里送春，等姑娘前去。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "怎么……送春？"
        },
        {
          "character": "紫娟",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "春去了么，到哪里去了，怎么不叫她回来？"
        },
        {
          "character": "紫娟",
          "type": "白",
          "text": "春去无言，叫我那里寻找？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "林黛玉",
          "type": "念",
          "text": "春去消息谁知，除非问取黄鹂呵。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "紫鹃，安顿花锄，我要葬花去了。"
        },
        {
          "character": "紫娟",
          "type": "白",
          "text": "外面春风似剪，姑娘不去也罢。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "咳，你看花谢花飞一片片沾泥随水。想世间薄命的人儿，还不是同落花一样么？"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "扫愁帚贮香囊花锄一柄， 我且到沁芳桥葬玉埋春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉下。"
        },
        {
          "character": "紫娟",
          "type": "白",
          "text": "我们姑娘，跟宝玉自幼十分相爱。哪里晓得越相爱，越烦恼。年纪一天大似一 天。据我想来，彼此既然真心相爱，就要彼此原谅，每日里牵愁惹恨，又何苦 呢？正是："
        },
        {
          "character": "紫娟",
          "type": "念",
          "text": "两情只要能长久，岂在朝朝暮暮愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫娟下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉上。"
        },
        {
          "character": "贾宝玉",
          "type": "唱",
          "text": "昨夜晚怨东风无端蹂躏， 满园春吹变了一片愁云。 林妹妹他本是惜花如命， 却为何这时候不到园林？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "小生宝玉。今日一来是赴饯花盛会，二来这几日林妹妹有些恼我，必然是小生 得罪了他，等见着他，赔个礼儿要紧。"
        },
        {
          "character": "贾宝玉",
          "type": "唱",
          "text": "我这里扫残红独穿花径， 早来到埋香处流水孤坟。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "到此已是林妹妹葬花之所，你看梨花飘雪，柳絮飞棉，倘若林妹妹看见，必定 是十分的伤感，待我收拾起来，也好安慰于她。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉扫花，望。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "远望一女子，隐约行过花丛，好像是林妹妹来了，待我闪躲一旁，听她讲些什 么？正是："
        },
        {
          "character": "贾宝玉",
          "type": "念",
          "text": "隔林听燕语，掬水奠花魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        },
        {
          "character": "林黛玉",
          "type": "内哭",
          "text": "呵吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉上。"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "碧云天芳草地蜂愁蝶怨， 乱莺声啼不住似水流年。 绕疏篱穿曲径遮遮掩掩， 又只见一抔土谁荐寒泉。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "来此已是葬花之所。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉看。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "哪个有心人替我扫了一堆花瓣在此？莫非是那宝……嗳，他哪里有这样细腻的 心情哪！"
        },
        {
          "character": "林黛玉",
          "type": "反二黄慢板",
          "text": "林黛玉把花锄无限凄怆， 繁华尽花事了难怨东皇。 可怜你经过了一年冷淡， 可怜你消受得几日风光。 可怜你软红尘芳魂四散， 可怜你温柔性付与汪洋。 说什么护花枝金铃十万， 说什么渡花魂宝筏一航。 侬葬花人道我落了情障， 要知道侬与花一样下场。 我这里赋招魂泪和花葬， 夜漫漫春寂寂地老天荒。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "侬今葬花人笑痴，他年葬侬知是谁。一朝春尽红颜老，花落人亡两不知。 呵呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉在假山后偷窥，失声哭，衣兜中花撒落满地。林黛玉惊祝。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "我道是谁，原来是即狼心短……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉、贾宝玉同绕场，林黛玉欲行，贾宝玉止。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "妹妹，不要走。且等我说完这一句话。大家撩开手就是了。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "宝二爷有何吩咐？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "既有今日，何必当初？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "当初怎么，今日又怎么样？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "想当初妹妹与我，是怎样的要好，彼此一处长大，每日一同吃饭，一同玩耍。 有我爱吃的，看见妹妹也爱吃，就留着等妹妹同吃。丫头仆妇们，有想不到的， 我替他们想到，怕叫妹妹生气。为的就是既然要好，总要比别人都好，才显 得真好。可怜我并无同心的亲兄弟亲姐妹，只有妹妹一人，能够体谅我的心事。 谁指望妹妹人大心大，偏不和我要好，反去和那外四路的什么凤姐姐、宝姐 姐要好，拿我三日不理四日不睬。我也不知道怎么得罪了妹妹，妹妹就是打我 骂我，千万休不理我，叫我有冤无处诉，就是死了也是个屈死鬼。任凭高僧高 道超度，还要妹妹说明了原故，才能够托生呢……妹妹也忍心不答应我一声么……"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "你休来骗我。你还是回去关上你的门罢！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "妹妹，此话从何而起？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "昨晚我到怡红院去，你为何闭门不理？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "哪有此事？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "还说没有此事，我站在门外，脚也站酸了。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "真正没有此事。妹妹若不相信，待我对天盟誓。 皇天在上：我宝玉若有半句虚言，叫我落在水里，变个大大的王八，等到林妹 妹百年之后，替妹妹驮石碑。妹妹这可相信了罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉、贾宝玉互视，同笑。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "还不快快的起来。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "妹妹，这你可相信了。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "大约是你家大丫头偷赖不来开门，也是有的。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "待我回去教训她们。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "也应当教训教训。得罪了我，不要紧，倘若得罪了什么宝姑娘、贝姑娘，那还 了得？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "她又提起宝姐姐了！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "你今日来此则甚？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "妹妹呀！"
        },
        {
          "character": "贾宝玉",
          "type": "唱",
          "text": "都只为收拾那残脂剩粉， 怕东风吹散了艳魄芳魂。 我怜它好一似昙花泡影， 因此上摄香土聊当饯春。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "如此说来，这香冢之旁，那堆花瓣，是你扫来的？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "你怎么知道？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "嗳呀。还是他有这细腻的心情呵！"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "听他言不由我芳心辗转， 一样春愁两地牵。 你我问春春不管， 伤春肠断有谁怜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉、贾宝玉同叹。紫鹃上。"
        },
        {
          "character": "紫娟",
          "type": "白",
          "text": "他们又是怎么样了？待我诳她回去。 呵，姑娘，老太太等你吃饭了。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "晓得了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉做身段，林黛玉、紫娟同下。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "贾宝玉",
          "type": "念",
          "text": "流水斜阳春去尽，独留青冢向黄昏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}