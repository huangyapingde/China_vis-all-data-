      "hangdang": "丑"
    }
  ],
  "plot": "薛平贵既回窑，与魏虎在王允府中争斗。继至御前算粮后，唐帝即予以生杀之权，命其自行发落。于是还登\n回龙阁，先传妻父王允至，薛平贵怒其欺贫重富，势利熏心，不顾父女之情，即欲处死刑，以泄其忿。幸亏\n王宝钏至，力保得免。然薛平贵方盛怒，仍不以翁婿礼待允，命坐殿角而巳。继传魏虎至，夫妇二人，先向\n之历数罪状。然后斩之。既而西凉代战公主适至，遂与王宝钏相见，彼此亲爱如姊妹。薛平贵乃率同二妻，\n迎请岳母王老夫人上坐，叩谢十八年周恤之恩而毕。",
  "notes": "此为薛平贵戏最后之终剧。夫妇团圆，既富且贵。德者报德，怨者报怨，一生恩仇了了。诚大丈夫得志于时\n之所为也。曾见王凤卿演此，落落大方，雍容华贵，颇合登殿时薛平贵之身分神气。唱亦不激不随，四平八\n稳。洵可谓当行出色之作。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "龙凤阁内把衣换，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、马达、江海引薛平贵同上。"
        },
        {
          "character": "薛平贵",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "薛平贵",
          "type": "西皮慢板",
          "text": "薛平贵焉有今日天。 马达江海把旨传： 你就说孤王我驾坐在长安。 龙行虎步上金殿，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "猛然间想起了彩楼前。 马达江海一声宣： 在寒窑内快宣那王氏宝钏。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "领旨。 万岁有旨：宣王娘娘上殿。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "忽听万岁一声宣， 寒窑来了王宝钏。 站立金殿用目看， 原来是我夫坐金銮。 大摇大摆——"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "上金殿， 参王驾来问王安。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "你为孤受苦十八年， 后宫去把凤衣穿。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "谢罢万岁下金殿， 从今后不穿破衣裳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "忙把王允押上殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "一见老贼怒冲冠！ 先前定计将孤害， 今日也要报仇冤。 马达江海推去斩， 杀他的人头挂高竿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同允，同绑王允，同押下。王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "听说要把我父斩， 吓得宝钏心胆寒。 急急忙忙上金殿， 要斩我父为哪般？"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "先前定计将孤害， 今日拿他报仇冤。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "先前本是父不好， 我母待你恩如山。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "定斩不赦！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "万岁一定将父斩， 不如碰死在金銮。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "御妻休要行短见， 午门外赦回王相官。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "解下桩来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允上。"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "千层浪里翻身转， 百尺高竿得命还。 站立金殿用目看， 那旁站立王宝钏。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "哽，要叫娘娘千岁。"
        },
        {
          "character": "王允",
          "type": "西皮摇板",
          "text": "娘娘千岁，宝钏我的儿吓！ 适才万岁将我斩， 何人救我活命还？"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "适才万岁将父斩， 女儿救父活命还。"
        },
        {
          "character": "王允",
          "type": "西皮摇板",
          "text": "我儿救得父不死， 可算忠孝两双全。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹吓！"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "说什么忠孝两双全， 女儿言来听根源： 大姐配的苏元帅， 二姐配的魏虎谗。 惟有女儿命运苦， 彩球单打薛平男。 先前道是花郎汉， 到如今花郎坐金銮。 来来来随儿上金殿， 谢万岁不斩还要封官。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "殿角赐你金交椅， 事平之后再封官。"
        },
        {
          "character": "王允",
          "type": "西皮摇板",
          "text": "万岁休把老臣怨， 俱是魏虎起祸端。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "忙将魏虎押上殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏虎绑上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "一见贼子怒冲冠！ 先前定计将孤害， 仇报仇来怨报怨。 马达江海推去斩，"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "妾妃还要问一番。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "但凭于你。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "人来打坐向前骂， 骂声魏虎狗奸谗： 先前定计将我害， 一一从头说根源。"
        },
        {
          "character": "魏虎",
          "type": "西皮摇板",
          "text": "有魏虎跪殿脚， 尊一声三姨妹……"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "哽，要叫娘娘千岁。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "我们是亲戚。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "这时六亲不认。"
        },
        {
          "character": "魏虎",
          "type": "西皮摇板",
          "text": "娘娘千岁、三姨妹，细听我说： 你今若是饶了我， 从今以后念弥陀。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "马达江海推去斩， 斩他人头挂高竿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海押魏虎同下。马达、江海同上。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "魏虎斩首已毕。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "斩魏虎方称孤心愿， 快宣公主把驾参。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "万岁有旨：宣代战公主上殿。"
        },
        {
          "character": "代战公主",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主上。"
        },
        {
          "character": "代战公主",
          "type": "西皮二六板",
          "text": "来在他国用目观， 看他国我国不一般。 他国穿的绫罗缎， 我国穿的羊毛毡。 大摇大摆上金殿，"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "参见公主。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "马达江海，万岁爷台前，哪里来的这么一位眼光娘娘？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "就是大王在三关讲的：王宝钏——王娘娘，就是她。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "哦，大王在三关，提的王宝钏王娘娘，就是她？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "长得构个交个。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "不错。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "那么着咱们回去吧。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "为什么？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "有了她，还要咱们娘娘做什么？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "公主上前见礼。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "哦，咱们见个礼？见礼吧。"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "上面坐的王宝钏。 走上前施一个番邦礼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主施礼。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "马达、江海，咱家与她见礼，她怎么要飞？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "不是要飞，咱们那里行礼，是放闪燕大厂门。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "她们呢？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "她们是兔子捣对。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "怎么着，这不成了捣对了吗？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "不错，是要捣对。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "总得捣对，咱们捣对吧。"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "她为正来我为偏。 走上前来把礼见， 娘娘千岁，"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "看着！"
        },
        {
          "character": "代战公主",
          "type": "西皮摇板",
          "text": "驾可安？"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "王宝钏抬头用目看， 代战女打扮似天仙。 怪不得儿夫不回转， 被她缠绕一十八年。 宝钏若是男儿汉， 也到她国住几年。 我本当不把礼来见， 她道我宝钏礼不端。 走上前，用手搀，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "贤妹好。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "姐姐好。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "尊一声贤妹听我言： 儿夫西凉你照看， 多亏你照看他一十八年。"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "姐姐说话言太欠， 小妹言来听根源： 说什么儿夫我照看， 可怜你受苦一十八年。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "手挽手儿上金殿，"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "参王驾来问王安。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "孤王金殿用目看， 二梓童打扮似天仙。 宝钏封在昭阳院， 代战公主掌兵权。 赐你二人龙凤剑， 三人同掌锦长安。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "叩罢头来谢恩典，"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "你为正来我为偏。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "说什么正来讲什么偏， 姐妹二人俱一般。 三人同掌昭阳院，"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "学一对凤凰伴君眠。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "宝钏近前听旨传： 相府去把岳母搬。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "辞别万岁下金殿， 相府去把老娘搬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "孤王金殿出赦条， 晓谕黎民得知晓： 一赦钱粮并钱钞， 二赦囚犯出监牢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同允，同拿诏下。王母、王宝钏同上。"
        },
        {
          "character": "王母",
          "type": "西皮摇板",
          "text": "来在午门下车辇， 有劳三姐把娘颁。"
        },
        {
          "character": "王母",
          "type": "西皮快板",
          "text": "我的儿一双好尖眼， 十八年才得龙椅盘。 站立在殿角用目看， 上面坐的是薛平男。 先前道他是花郎汉， 到如今头戴皇帽、身穿蟒袍、腰横玉带、足蹬朝靴、端端整整、整整端端，驾 坐在金銮。 宝钏儿搀娘上金殿，"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "这是何人？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这就是代战公主。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "哦，这就是代战公主？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "老太太，咱们有礼了。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "随我来吓，"
        },
        {
          "character": "王母",
