{
  "script_id": "01002017",
  "title": "黑风帕",
  "alias": [
    "牧虎关；一名：背鞭认子"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "高旺",
      "hangdang": "净"
    },
    {
      "name": "杨八妹",
      "hangdang": "旦"
    },
    {
      "name": "高来",
      "hangdang": "丑"
    },
    {
      "name": "张保",
      "hangdang": "小生"
    },
    {
      "name": "鞑婆",
      "hangdang": "旦"
    },
    {
      "name": "张兰英",
      "hangdang": "老旦"
    }
  ],
  "plot": "宋，杨氏父子，为潘仁美所害。有部将高旺，愤权臣骄横，忠良屈死，弃其妻子，出关逃隐。后天堂六国叛\n宋，使佘太君率兵征之。太君使杨八妹乔扮男装，颁取高旺回国，以资臂助。高旺情不可却，允之。行至牧\n虎关，守关者即高旺之妻子，高旺不知也。高旺叫关，其子张保出见，不许过关。高旺辱骂，张保出与敌，\n败回关上。易其媳出战，使黑风帕困高旺，而高旺之黑风帕，更高三尺。一切法术，均为高旺破。高旺见女\n将袅袅婷婷，忽发狂态，以游词戏弄之，媳抱惭而回。旺抵关下，见城上一白发婆娑者，直呼己名。异而询\n之，始知即老妻也。高旺妻开关迎旺及八妹入，数年阔别，一旦聚首，悲喜交集。即唤子媳来见，高旺见媳\n大惭，高旺妻笑而解之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高旺上。"
        },
        {
          "character": "高旺",
          "type": "引子",
          "text": "扶保王家，倒做了，野草鲜花。"
        },
        {
          "character": "高旺",
          "type": "念",
          "text": "二十年前挂铁衣，曾与宋王扶社稷。如今倒做姜吕尚，渭水河边把钓垂。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "老夫姓高，名旺，字道遁。昔年宋室为臣。可恨昏王听信谗言，将我谪免雅志 府为民。今日闲暇无事，不免庄前庄后游玩一番便了。"
        },
        {
          "character": "高旺",
          "type": "西皮慢板",
          "text": "独坐在雅志府心中烦闷， 到庄前和庄后游玩散心。 出庄来又只见怪风一阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "风旗上，杨八妹上，过场，下。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "高旺",
          "type": "西皮慢板",
          "text": "让风头抓风尾细算分明。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "哑唷，吓！老夫出庄游玩，只见怪风一阵。让过风头，抓着风尾，待我屈指一 算，哑唷吓！原来是天堂六州，反了角头和尚，杨贤妹前来搬兵。是老夫当年 发下誓愿：永不与宋王出力报效，这便什么处？有了，府下有一高来，生得聪 明伶俐，不免唤他出来，想个不发兵之计。 高来哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来上。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "咳哩！"
        },
        {
          "character": "高来",
          "type": "念",
          "text": "忽听叫高来，眉毛往前攒。高来是我，我是高来。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "爷爷在上，高来丢揖！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "什么叫做“丢揖”？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "我与别人作揖，别人还我一揖；我给你作揖，好有一比。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "好比何来？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "长虫吃扁担——"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "直棍一条。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "不好，还是作揖。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "就是作揖。唤我出来，有何屁放？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "唔！“有何话讲”！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "不错，有何话讲？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "适才你爷爷出庄游玩，只见怪风一阵。让过风来，抓着风尾，屈指一算，原来 是杨国母前来搬兵。唤你出来，想一个不发兵之计。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "计到没有，屁股上有一个猴子。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "计策之计！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "待我想来。有了！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "你剃得光光头，抬上一篓油，扯上一匹牛，头望油篓里一染，望牛鼻里一钻。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "这叫什么计！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "只叫“钻头不顾尾”。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "不好！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "不好，我无计了。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "你爷爷倒有一计在此。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "少时你杨国母到此，就说你爷爷赴牛羊大会去了。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "几时去的？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "说去就去。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "几时回来？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "说来就来。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "到底在哪儿？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "书房里面藏躲。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": "高旺",
          "type": "念",
          "text": "我今吩咐你，"
        },
        {
          "character": "高来",
          "type": "念",
          "text": "怎敢少迟延！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高旺下。杨八妹上。"
        },
        {
          "character": "杨八妹",
          "type": "西皮摇板",
          "text": "天波府奉了太君命， 来到雅志搬救兵。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "来此已是。看那旁好象高来。 吓！高来，高来。 睡着了？待我骗他一骗。 这地下二百铜钱，是哪一个的？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "是我的，是我的！"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "呵吓，杨国母！"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "你家爷爷可在府中？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "不在府中。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "哪里去了？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "赴牛羊大会去了。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "几时去的？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "说去就去。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "几时回来？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "说来就来。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "呵吓且住！看高来说话，颠三倒四，待我吓他一吓。 高来，我与你带的红绣花鞋。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "在哪儿？"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "马鞍桥下。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "待我去拿。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "呵吓，杨国母饶命！"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "你爷爷到底哪里去了？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "待我来告诉你，在书房里头藏躲。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "叫他出来。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "他知道你搬兵来的，他不出来。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "你代我想个计策。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "大家想来。我有个计了！"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "你有什么妙计？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "我当看麦子的，你当放羊的。你的羊吃了我的麦子，我叫你轰开，你不轰开， 我就要骂，你就要打。我爷爷一听见打我，他就要跑出来的！"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "好！我们来试演试演。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "唗！谁家的羊，吃了我的麦子了？"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "是我家的羊。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "你与我轰开！"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "我不轰开。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "我就要骂。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "我就要打！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "哀哀哀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高旺上。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "什么人打我的高来？"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "吓，兄长！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "吓，贤妹！ 高来，杨国母到此，为何不来通报？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "你不许我通报。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来下。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "贤妹请坐！"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "有坐！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "贤妹不在天波杨府，来到雅志则甚？"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "奉了太君之命，前来搬兵。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "兄有一言，贤妹听了："
        },
        {
          "character": "高旺",
          "type": "西皮导板",
          "text": "杨贤妹打坐在雅志府，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来上。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "报！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "报什么？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "你的大钢鞭，在那儿乱蹿乱跳。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "多加两条闩。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "连我的裤带结上去多不行！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "我倒明白了。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "你明白何来？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "要到两军阵前打两员上将！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来下。"
        },
        {
          "character": "高旺",
          "type": "西皮摇板",
          "text": "听愚兄把当年事细说分明："
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来上。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "报！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "又报什么？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "一只马在那里乱叫。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "多加草料。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "连我的枕头吃了多不行！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "我倒又明白了。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "明白何来？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "要到两军阵前喝些人血！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来下。"
        },
        {
          "character": "高旺",
          "type": "西皮摇板",
          "text": "为江山跑坏了我的乌骓马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来上。"
        },
        {
          "character": "高来",
          "type": "哭",
          "text": "咳咳！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "高来为何啼哭？"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "我在前头扫地，丫头在那里烧火。他放了一个屁赖我！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "那是一桩小事。"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "杨国母搬兵大事，你不去！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "放屁！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "不臭！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "下去！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "水冷！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "打嘴！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "拈鱼！"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "呸，滚下去！"
        },
        {
          "character": "高来",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高来下。"
        },
        {
          "character": "高旺",
          "type": "西皮原板",
          "text": "为社稷战断了我的宝雕弓。 你国为上我国为下， 两国不和屡动刀兵。 我国的狼主宣战表， 他命我高旺押表文。 宋王爷把开了从头看， 吓坏了满朝的文武臣。 黄花女金殿挂帅印， 杨贤妹倒做了马前先行。 头一阵会见了黄花女， 娃娃的武艺不算能。 第二阵会见了杨贤妹， 贤妹的花枪果然能。 你爱愚兄黑风好， 愚兄爱你花枪能。 花枪好，好黑风， 二人结拜去见宋君。 天堂六州贼反进， 要想发兵万不能。"
        },
        {
          "character": "杨八妹",
          "type": "白",
          "text": "嗳！"
        },
        {
