          "character": null,
          "type": "stage",
          "text": "鞑婆、四青袍同下。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高旺下。"
        }
      ]
