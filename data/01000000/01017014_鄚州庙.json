{
  "script_id": "01017014",
  "title": "鄚州庙",
  "alias": [
    "拿谢虎；一名：访拿一枝桃"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "黄天霸",
      "hangdang": "武生"
    },
    {
      "name": "谢虎",
      "hangdang": "武净"
    },
    {
      "name": "贺仁杰",
      "hangdang": "武生"
    },
    {
      "name": "施世纶",
      "hangdang": "老生"
    },
    {
      "name": "王殿臣",
      "hangdang": "外"
    },
    {
      "name": "郭起凤",
      "hangdang": "末"
    },
    {
      "name": "朱光祖",
      "hangdang": "武丑"
    }
  ],
  "plot": "此剧事实，载于说部《施公案》后集。施公自山东放赈回京，路过任邱县，驻节驿馆。有二民诉冤，询问姓\n名，一称周荣，一称蒋旺，周荣之女为人所杀，蒋旺之妻亦为人所杀，不知是谁，均无头绪，只见粉壁上画\n一枝桃花。施公明知采花恶贼，允为捕缉。与诸卫士商议，黄天霸自请出外访查。接连数日，踪影全无。至\n茶馆小憩，遇一穷汉，与黄天霸攀谈，方知系属旧交，绿林中称为神眼计全者。两人细述衷曲，黄天霸将访\n查采花贼之情，一一告知。计全曰，此人是谢虎，诨名一枝桃，狠毒而好淫，亦绿林中有名人物。左耳朵有\n红痣五粒，形如花瓣，每逢采花，即画一枝桃，以作暗记。现寄居鄚州北门外玄天庙。黄天霸闻言，即引计\n全禀明施公，又派郭起凤、王殿臣二人，帮同拿捉。在半路上酒店暂歇，恰好谢虎亦到，得以认清面貌。及\n至玄天庙，黄天霸与谢虎晤后，直告以奉施公之命，前来破案。遂互相用武，谢虎知黄天霸有家传金镖，名\n重一时，恐非敌手，遂用先发制人之计，伪作败逃状，出其不意，发出连珠毒药镖。黄天霸不及避，反为所\n伤，谢虎因得脱身。后由朱光祖，向李玉讨得解药，始获痊愈。",
  "notes": "剧本所述，与说部上多有不同处。编排者点缀热闹，不足为怪。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "施世纶、王殿臣、郭起凤",
          "type": "内同白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施世纶、王殿臣、郭起凤同上。"
        },
        {
          "character": "施世纶",
          "type": "吹腔",
          "text": "急急忙忙往前进， 不管高低路难行。 来至在街前来观定， 不觉来到了酒楼门。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "来此已是酒楼，你我进去，且饮几杯。"
        },
        {
          "character": "王殿臣、郭起凤",
          "type": "同白",
          "text": "好，一同进去。 酒保在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "酒保",
          "type": "念",
          "text": "生意兴隆通四海，财源茂盛达三江。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官三位，可是饮酒的么？"
        },
        {
          "character": "王殿臣、郭起凤",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "请到楼上坐。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "带路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同上楼。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "取酒来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是。 暖酒一壶吓！ 酒到。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "放在案上，唤你再来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保下。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "二位请。"
        },
        {
          "character": "施世纶",
          "type": "吹腔",
          "text": "举杯痛饮消愁恨， 思想狂徒怒在心。 霸占民田干律禁， 抢夺妇女天怎容！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸、计全同上。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "来此已是酒楼，待我沽饮几杯。 酒保！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "二位是喝酒的么？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "请到楼上。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "带路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸、计全、酒保同上楼。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "吓！上面乃是大……"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "这……大……大家吃酒，大家打钱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸坐。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我说客人，这一张桌子，你老可是不能坐。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "为何坐不得？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "这张桌子，乃是谢九太爷的座位。他不定是什么时候来，如若来时，我们可是 吃罪不起。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "我们暂且坐了，等他到来，再让与他便了。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "既然如此，我在外面招呼着；他一来，你们二位，可就起来。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "休得多言，拿酒来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "伙计们，拿暖酒一壶吓！ 酒到。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "唤你再来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保下。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "请吓！"
        },
        {
          "character": "施世纶",
          "type": "吹腔",
          "text": "恨强徒行事太胆大， 欺压良民罪可杀。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "咳！可恼吓，可恼！"
        },
        {
          "character": "郭起凤",
          "type": "白",
          "text": "可惨吓，可惨！"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "可恶吓，可恶！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "咳！可恨吓，可恨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保急上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客人快快请开，九太爷一会就来！你快请到那边去坐，我好把桌子收拾干净。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "有俺在此，料无妨碍。等他到来，俺与他答话。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "这个事儿不妥当，只怕要闹糟糕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保下。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "二位请酒。"
        },
        {
          "character": "王殿臣、郭起凤",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "施世纶",
          "type": "吹腔",
          "text": "他言道强徒就来到， 等他来时观看分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "可了不得了，谢九太爷已经来到啦！客官，快躲一躲吧！"
        },
        {
          "character": "谢虎",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。谢虎上，上楼，看，翻桌。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "呔！俺正在此饮酒，你将桌儿打翻，是何道理？"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "住了！尔莫非瞎了尔的狗眼！你九太爷在此，是谁人不知，谁人不晓？俺这靴 尖一动，管叫你死无有葬身之地！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "你口出狂言，莫非吃了熊心豹胆！"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "前有一松林，你可敢去，与俺较量么？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "慢说松林，就是虎穴龙潭，你老爷何惧！"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "走！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸、谢虎同下，计全追下，施世纶、王殿臣、郭起凤同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四头目、秃子同上。"
        },
        {
          "character": "秃子",
          "type": "白",
          "text": "众好汉，你我同到郊外！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四头目、秃子同转场，同下。黄天霸、谢虎同上。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "来此松林，你我怎样比试？"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "你九太爷自出世以来，从不杀这无名之辈。尔且通上名来！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "你且听了：你老爷家住江南绍兴府金华县，飞镖黄三泰之子、四霸天赛罗成黄 天霸！"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "天霸，你既生在绿林，就该以义气当先，为何苦害天下英雄，每每与绿林作对？ 今日遇见你九太爷，只怕你难逃性命！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "呀呀呸！想你这厮在此，不安本分，霸占民女，欺压良民，就该随俺到施大人 台前认罪，尔还敢出此狂言！今日相逢，可谓冤家对头了。休走，看刀！"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "且慢。你我今日比武，不许用暗器伤人。如用暗器伤人，算不得英雄后代。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "丈夫一言。"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "岂能反悔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸、谢虎同起打，对单刀。谢虎下，黄天霸追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贺仁杰、王殿臣同上。"
        },
        {
          "character": "贺仁杰、王殿臣",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "贺仁杰",
          "type": "白",
          "text": "贺仁杰。"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "王殿臣。"
        },
        {
          "character": "贺仁杰",
          "type": "白",
          "text": "请了。你我二人，私访恶霸，就此走遭也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺仁杰、王殿臣同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四头目、秃子同上，施世纶、郭起凤同上。秃子看。"
        },
        {
          "character": "秃子",
          "type": "白",
          "text": "你看那人好似那赃官的模样，我等赶上前去，将他掳掠便了。 （四头目、秃子抢施世纶同下。贺仁杰、王殿臣同上，四头目、秃子、施世纶同上，贺仁杰截打，四头目、 秃子同下。）"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "天霸与谢虎，在松林比武，你快去帮助便了。"
        },
        {
          "character": "贺仁杰",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺仁杰下。施世纶、王殿臣、郭起凤同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "谢虎上。"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "且住。看天霸杀法厉害，毒药镖伤他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸追上，开打，谢虎败，上桌。黄天霸追上，谢虎持镖打，黄天霸倒地。"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "天霸吓，天霸！你往日英名，哪里去了！待俺将他的首级割下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谢虎下桌，砍。"
        },
        {
          "character": "谢虎",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺仁杰上，踢刀落地。贺仁杰、谢虎同起打。谢虎败下，贺仁杰背黄天霸下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、王殿臣、郭起凤、朱光祖、金大力、李堃、施世纶同上。"
        },
        {
          "character": "施世纶",
          "type": "念",
          "text": "心中恨谢虎，定要把贼除。"
        },
        {
          "character": "王殿臣、郭起凤、朱光祖、金大力、李堃",
          "type": "同白",
          "text": "大人受惊了。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "黄天霸可曾回衙？"
        },
        {
          "character": "王殿臣、郭起凤、朱光祖、金大力、李堃",
          "type": "同白",
          "text": "并未回衙。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "他与那谢虎比武，本院也曾命贺仁杰前去帮助，怎么这时候，还不见回来？"
        },
        {
          "character": "王殿臣、郭起凤、朱光祖、金大力、李堃",
          "type": "同白",
          "text": "想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺仁杰背黄天霸上，扶黄天霸卧椅。"
        },
        {
          "character": "贺仁杰",
          "type": "白",
          "text": "叩见大人。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "罢了。这天霸是怎么样了？"
        },
        {
          "character": "贺仁杰",
          "type": "白",
          "text": "黄叔父被谢虎暗用金镖，将他打倒，故而如此。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "他为何昏迷不醒？"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "启禀大人：那谢虎惯用金镖伤人，但是他的镖，俱用毒药冶过，打在身上，有 一个时辰，药性发作，只用七天，这性命可就不保了。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "如此便怎么样救他性命才好？"
        },
        {
          "character": "李堃",
          "type": "白",
          "text": "朱爷与谢虎，乃是一师之徒，难道说这毒药镖就无有解救之法么？"
        },
        {
          "character": "贺仁杰、王殿臣、郭起凤、金大力",
          "type": "同白",
          "text": "是吓。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "解救之法倒有，必得我师父红旗李玉，在集贤村居住。"
        },
        {
