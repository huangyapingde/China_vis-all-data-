{
  "script_id": "01016005",
  "title": "未央宫",
  "alias": [
    "斩韩信"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "韩信",
      "hangdang": "老生"
    },
    {
      "name": "吕后",
      "hangdang": "旦"
    },
    {
      "name": "萧何",
      "hangdang": "外"
    },
    {
      "name": "陈仓",
      "hangdang": "小旦"
    }
  ],
  "plot": "考《西汉演义》，高祖伪游云梦，擒楚王韩信，降封淮阴侯。废置咸阳，赫赫功勋，付诸流水。无怪韩信之\n郁郁不乐，而羞与降灌为伍也。陈豨奉高祖命，平代州番寇，往辞韩信。韩信动以利害，嗾其起反，且约为\n内应。陈豨至代州，遂自立为王。高祖亲征之，委托吕后及丞相萧何监国。临行犹再三谆嘱，注意韩信之举\n动。韩信与陈豨两处，均有函札往来。家仆谢公箸，醉后漏言，韩信欲杀未果。谢公著迳至丞相府告变，吕\n后即与萧何定计，伪称高祖已杀陈豨，诱韩信入贺。至未央宫前。突出武士数十人，缚见吕后，宣以反状，\n证以家仆，斩于长乐殿钟楼之下，并夷其三族。后之人无不为之痛惜，当夫楚汉争衡之际，若非韩信赞助，\n高祖万万不能得天下。乃坐未安席，而擒之废之，且又杀之族之，高祖之不仁实甚矣，虽属吕后之主谋，高\n祖不有疑忌之心，不敢为此。焉知非高祖临行时，授意於吕后耶。《二十四史》中，残暴之君，指不胜屈，\n当推汉高祖为第一。",
  "notes": "剧本让吕后斩韩信。在高祖宴驾之后，与演义中所载不同。至于宫女用厨刀斩信，及韩信自述天道报应等语，\n编排者点缀剧情，不能不强加以附会。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "萧何上。"
        },
        {
          "character": "萧何",
          "type": "念",
          "text": "燮理阴阳官极品，调和鼎鼐列三台。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "老夫，萧何。昨日在金殿之上，曾奉国太之命，言道三齐王韩信，统领天下兵 将，兵权过重；倘若一起反心，汉室江山难保。特命老夫，将他诱入宫中，问 他死罪，以防后患。我也曾命人邀请，还不见到来，想必来也。"
        },
        {
          "character": "韩信",
          "type": "内西皮导板",
          "text": "操演将士出校场，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩信上。"
        },
        {
          "character": "韩信",
          "type": "西皮摇板",
          "text": "午门外来了三齐王。 撩袍端带朝廊上， 只见萧何在朝堂。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "吓，萧丞相，"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "三齐王。"
        },
        {
          "character": "韩信、萧何",
          "type": "同笑",
          "text": "吓，哈哈哈哈……"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "丞相来得甚早？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "老夫已在此等候多时了。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "今乃三、六、九日，操演之期，是俺在校场点卯，因此来迟，还望丞相海涵。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "丞相见招，不知有何国事议论？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "昨日太后，曾在金殿传旨，叫你我二人，今日一同进宫，有国事议论。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "但不知为了何事？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "这……老夫却也不知。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "如此你我一同进宫便了。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "三齐王请！"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "萧丞相请！"
        },
        {
          "character": "韩信",
          "type": "西皮原板",
          "text": "龙国太因何故把旨传？ 倒叫我韩信难以详参。 众诸侯并未曾兴兵造反， 各番国又无有来犯边关。 四方平靖河清海晏， 五谷丰登共庆丰年。 江河一统归炎汉， 宣召我进宫去所为哪般？"
        },
        {
          "character": "萧何",
          "type": "西皮原板",
          "text": "三齐王休得要乱狐疑， 细听老夫说端的： 东荡西除功劳盖世， 南征北剿谁敢对敌？ 到如今乐享太平世， 满朝中文武臣可算第一。 令日里宣你进宫去， 定然是受赏把功题。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "吓，丞相，今日这朝房之内，为何文武百官，一人不见，是何原故？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "今日太后不曾临朝，在宫内宣召我等。想必他们无事，各自散去了。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "他们无事，各自散去了？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "吓，丞相，太后既然在宫那召见我等，为何这宫中太监、内侍，一个也不看见？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "国太既在宫中，这内侍、太监等，想必均在宫中伺候一切。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "在宫中伺候一切？如此请。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "老夫告便。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧何下。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "你看这萧何老儿，年纪衰迈，言语颠倒，令人好笑。吓，这老儿转眼不见，他 往哪里去了？想这皇宫内院，我并不曾走过；倘若错走，可就吃罪不起。嗳， 想那萧何老儿，乃是当朝首相，既然可以穿宫入院，难道我韩信，身居王位。 反倒不能在宫走走么？待我一人前去便了。"
        },
        {
          "character": "韩信",
          "type": "西皮摇板",
          "text": "萧何虽然为首相， 俺韩信官封三齐王。 纵然进宫有谁敢挡？ 来在宫门看端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、吕后暗同上，吕后坐帐内。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "来此深宫，侍我看来。 “未央宫”，“未央宫”。呵哈哈呀，来此已是未央宫！侍我在此。等侯萧何 老儿便了。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "宫外何人讲话？"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "三齐王韩信。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "你走近前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同撩帐。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩信跪。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "胆大韩信，你私自闯进宫来，哀家正在沐浴之际！你私犯圣驾，该当何罪？"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "启太后：今有萧何对臣言讲，国太传旨，宣我二人进宫，有国事议论。是以臣 才敢前来。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "那萧何今在何处？"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "今在宫外。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "宫娥。外面看来，可有萧何？"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女出帐，看。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "并无一人。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "唗！大胆韩信，你此番进宫，哀家倒也明白了：想是你看高皇晏驾，你要谋篡 汉室社稷！既有谋反之心，又敢私犯圣驾。罪不容诛！ 宫娥们！"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "宣金瓜武士进宫！"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "金瓜武士进宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、二太监同上。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "将韩信与我绑了！"
        },
        {
          "character": "吕后",
          "type": "西皮摇板",
          "text": "好一大胆小韩信， 私闯宫闱为何情！ 人来与我将他捆， 定斩人头不容情！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人捆韩信。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "国太吓！"
        },
        {
          "character": "韩信",
          "type": "西皮摇板",
          "text": "国太且莫怒气生， 细听为臣奏原因： 萧何带臣把宫进， 臣不该一人乱胡行。 一时懵懂入宫禁， 冒犯圣驾有罪名。 望太后念臣功劳盛， 念臣在朝秉忠心。 将功折罪理应顺， 望国太开放天地恩。"
        },
        {
          "character": "吕后",
          "type": "西皮摇板",
          "text": "你道你的功劳盛， 未尝不存造反心。 人来推出将他斩， 斩却人头挂午门！"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "想我韩信，统带天下将士，看哪一个敢来斩我？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈仓上。"
        },
        {
          "character": "陈仓",
          "type": "白",
          "text": "我来斩你！"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "吓，你是何人，胆敢出此大言，你叫什么名字？"
        },
        {
          "character": "陈仓",
          "type": "白",
          "text": "你问我么，我名叫陈仓。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "这“陈仓”二字，好像在哪里见过，怎么一时想它不起？呵哈是了，想当初癸 未年间，我在淮阴避祸之时，失迷路途。遇一谯夫，名叫陈仓。那时蒙他指引 路径，是我一时起了不良之心，恐怕他泄漏我的机关，是我将他杀死。莫非就 是此人，转世投胎，前来索命么？待我向前来。 吓陈仓，你今年多大年纪了？"
        },
        {
          "character": "陈仓",
          "type": "白",
          "text": "我今年一十六岁了。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "哎呀，自癸未年算到如今，刚刚一十六载。苍天呐，天！这报应循环疏而不漏 也！"
        },
        {
          "character": "韩信",
          "type": "西皮摇板",
          "text": "听说此女叫陈仓， 倒叫韩信着了忙。 他指引路途把命丧， 如今投胎到朝堂。 一十六年报冤枉， 今日我韩信命必亡。 事到头来想一想， 自有天理暗昭彰。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "且住。想高皇命我统领天下将士，所有兵器上面，俱铸有“韩信”二字，只恐 无刀可以杀我！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "想这兵器之上，具有“韩信”字样，这便怎么处？"
        },
        {
          "character": "陈仓",
          "type": "白",
          "text": "启太后：宫中现有厨刀，料必无有“韩信”二字。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "好。快快取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈仓下，持厨刀上。"
        },
        {
          "character": "陈仓",
          "type": "白",
          "text": "果然无有“韩信”二宇。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "你叫他看来。"
        },
        {
          "character": "陈仓",
          "type": "白",
          "text": "是。 韩信你看这把厨刀，可能杀你？"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "唉，不好了！"
        },
        {
          "character": "韩信",
          "type": "西皮二六板",
          "text": "一见厨刀我心惊胆颤， 想起了当年事一端： 壬辰年遇相士把我的命算， 他算我七十二岁命归天。 怎奈我行事太短见， 伤天害理难以保全。 劝人生在世须要行善， 莫学我韩信作恶多端： 悔不该受高皇二十四拜， 曾损我阳寿有八年； 淮阴不该活埋母， 折我青春寿八年； 逼霸王在乌江把命丧， 损我寿数又八年； 背水阵害死兵丁十数万， 又去了阳寿有八年； 悔不该又把陈仓斩， 折我青春寿八年。 屈指从头仔细算， 五八折去四十年。 命中应活七十二， 三十二岁染黄泉。 只道苍天无明鉴， 谁知报应有循环。 末央宫今日身遭斩， 方知道天网恢恢在眼前。"
        },
        {
          "character": "陈仓",
          "type": "西皮摇板",
          "text": "手执厨刀将他斩， 管叫他一命丧黄泉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈仓斩韩信，韩信下。"
        },
        {
          "character": "陈仓",
          "type": "白",
          "text": "首级献上！"
        },
        {
          "character": "吕后",
          "type": "西皮摇板",
          "text": "好一个刚强小陈仓， 竟比男儿胆量强。 钢刀一举命即丧， 盖世功劳付汪洋。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "内侍，宣萧何进宫。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "国太有旨：宣萧何进宫。"
        },
        {
          "character": "萧何",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧何上。"
        },
        {
          "character": "萧何",
          "type": "西皮摇板",
          "text": "忽听国太宣一声， 来了开国保驾臣。 想必是斩了小韩信， 急忙进宫问分明。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "臣萧何见驾，国太千岁！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "千千岁！宣臣进宫，有何国事议论？"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "韩信已经斩首，就命卿家将他尸首用棺木，成殓起来，埋葬在咸阳城外山麓之 下，立一碑碣，以表他的功劳。领旨出宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕后下。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "萧何",
          "type": "西皮摇板",
          "text": "在宫中领了国太命， 背转身来自沉吟： 韩信未央丧性命， 可怜他汗马功劳化灰尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧何下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}