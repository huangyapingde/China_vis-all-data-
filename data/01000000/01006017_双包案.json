{
  "script_id": "01006017",
  "title": "双包案",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "假包拯",
      "hangdang": "净"
    },
    {
      "name": "施俊",
      "hangdang": "小生"
    },
    {
      "name": "假施俊",
      "hangdang": "小生"
    }
  ],
  "plot": "此剧大致谓包公放粮回京，途遇黑鼠精，亦变作包公模样，与之混搅。一时法堂之上，但见一包老变为两包\n老；一罪犯变为两罪犯；两皂快变为两两皂快；四青袍变为两四青袍。真假辨认不清。",
  "notes": "此剧剧情奇幻，本属不经，毫无做工可取。惟取其听两净角对唱，以辨别妍媸耳。洵足令妇人、稚子发笑也。\n惟近来往往有《双双包案》，同时有四包公、六包公同出同唱者，则更是胡闹矣，真不值识者一笑。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "引子",
          "text": "一片丹心，保宋主，锦绣龙廷。"
        },
        {
          "character": "包拯",
          "type": "念",
          "text": "黑暗暗乌纱盖顶，明亮亮玉带围身。上金殿君王见喜，下朝房文武皆尊。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老夫，包拯。宋室驾前为臣。今奉圣命陈州放粮，且喜放粮已毕，不免回朝交 旨复命。 王朝、马汉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同允。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "人役可齐？"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吩咐外厢开道。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "外厢开道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上。"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "奉王命散君粮出了朝道，"
        },
        {
          "character": "包拯",
          "type": "西皮慢板",
          "text": "一路上断了些恶棍土豪。 随带着王朝、马汉、张龙、赵， 又收下小豪杰御猫展昭。 白玉堂闹开府盗过了三宝， 又收下五义士暗保宋朝。 叫王朝和马汉急忙开道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、王朝、马汉同下。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "为国家哪顾得昼夜勤劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小妖引黑鼠同上。"
        },
        {
          "character": "黑鼠",
          "type": "西皮摇板",
          "text": "修炼千年道法高， 变化人形乐逍遥。"
        },
        {
          "character": "黑鼠",
          "type": "白",
          "text": "我乃黑鼠大仙是也。今有包拯陈州放粮而回，打此经过，不免变作假包模样， 搅乱一回。 众小妖，命你等变作王朝、马汉，三班衙役模样，速速变来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众小妖同下，假王朝、假马汉、四青袍同上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "看我等变得可像？"
        },
        {
          "character": "黑鼠",
          "type": "白",
          "text": "你等变得倒像。待我变来。"
        },
        {
          "character": "黑鼠",
          "type": "西皮摇板",
          "text": "忙将包拯来变好，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑鼠下，假包拯上。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "哇呀呀！"
        },
        {
          "character": "假包拯",
          "type": "西皮摇板",
          "text": "开封府内走一遭。 人来与爷忙开道， 带上了二施俊细问根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施俊、假施俊同上。"
        },
        {
          "character": "施俊、假施俊",
          "type": "同白",
          "text": "参见大人。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "你二人谁是真的，谁是假的？从实招来。"
        },
        {
          "character": "假施俊",
          "type": "白",
          "text": "我是真的，他是假的。"
        },
        {
          "character": "施俊",
          "type": "白",
          "text": "我是真的，他是假的。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "你们都是真的，难道老包是假得不成？"
        },
        {
          "character": "施俊",
          "type": "西皮摇板",
          "text": "大人有所不知情， 他是假来我是真。"
        },
        {
          "character": "假施俊",
          "type": "西皮摇板",
          "text": "大人有所不知情， 他是假来我是真。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "假包拯",
          "type": "西皮摇板",
          "text": "你是真的我知道， 你是假的哄老包。 真施俊用刑把假的拷， 霎时间管叫你性命难逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王朝、马汉、四青袍同上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "来在衙前下了轿，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "开封府因何有二老包？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "呔，何方妖魔，变化人形，敢坐老夫法堂！"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "呔，何方妖魔，变化人形，敢坐老夫法堂！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "岂不知龙图阁大学士，兼理开封府尹包拯。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "岂不知龙图阁大学士，兼理开封府尹包拯。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "我劝你早早现出原形便罢。如若不然，老夫的照妖镜厉害。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "我劝你早早现出原形便罢。如若不然，老夫的照妖镜厉害。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "王朝、马汉，看宝镜伺候。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "王朝、马汉，看宝镜伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、假包拯同照。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓，老夫怎么照不出它的原形来了？"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "哽，老夫怎么照不出他的原形来了？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "王朝、马汉，将他拿下了！"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "来，王朝、马汉，将他拿下了！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "怪道吓，怪道吓！"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "不由老夫心头恼，"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "怪道吓，怪道吓！"
        },
        {
          "character": "假包拯",
          "type": "西皮导板",
          "text": "不由老夫心头恼，"
        },
        {
          "character": "包拯",
          "type": "西皮慢板",
          "text": "大宋朝又出了二老包。"
        },
        {
          "character": "假包拯",
          "type": "西皮慢板",
          "text": "大宋朝又出了二老包。"
        },
        {
          "character": "包拯",
          "type": "西皮慢板",
          "text": "龙图阁大学士断阴阳，谁人不晓？"
        },
        {
          "character": "假包拯",
          "type": "西皮慢板",
          "text": "龙图阁大学士断阴阳，谁人不晓？"
        },
        {
          "character": "包拯",
          "type": "西皮慢板",
          "text": "胆大的小妖魔假冒臣僚。"
        },
        {
          "character": "假包拯",
          "type": "西皮慢板",
          "text": "胆大的小妖魔假冒臣僚。"
        },
        {
          "character": "包拯",
          "type": "西皮慢板",
          "text": "我劝你早把那原形现了，"
        },
        {
          "character": "假包拯",
          "type": "西皮慢板",
          "text": "我劝你早把那原形现了，"
        },
        {
          "character": "包拯",
          "type": "西皮慢板",
          "text": "少若迟管叫你性命难逃。"
        },
        {
          "character": "假包拯",
          "type": "西皮慢板",
          "text": "少若迟管叫你性命难逃。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "妖魔胆量真不小， 敢与老夫絮叨叨。 真老包，假老包， 真假老包不差半分毫。 人来与爷你就忙开道， 天师面前把表烧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王朝、马汉、四青袍同下。"
        },
        {
          "character": "假包拯",
          "type": "西皮快板",
          "text": "一见真包他去了， 不由假包内心焦。 真老包，假老包， 真假老包不差半分毫。 人来与爷你就忙开道， 搬来了众小妖，与他闹糟糕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "假包拯、假王朝、假马汉、四青袍同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王朝、马汉、四青袍同上，包拯拈香，众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "天神、天将、众小妖同上。开打，同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}