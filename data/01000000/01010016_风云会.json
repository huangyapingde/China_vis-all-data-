{
  "script_id": "01010016",
  "title": "风云会",
  "alias": [
    "龙虎斗"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "呼延赞",
      "hangdang": "净"
    }
  ],
  "plot": "宋太祖赵匡胤，被困河东。欧阳方专权，擅杀功臣呼延寿廷。时呼延寿廷家属在乐家寨，闻报，其子呼延赞，\n年未弱冠，而臂力过人。闻信，急欲报仇，遂率师犯河东。宋军当之，无不披靡。赵匡胤得报大惊，不得\n已亲自临阵会战。不数合，被呼延赞击至大败。旋见呼延赞似在马上瞌睡，赵匡胤举鞭欲击，忽现黑虎形，\n遂止。既而呼延赞欲击赵匡胤，亦见有金龙出现，鞭不能下。呼延赞知赵匡胤确是真主，乃即离鞍投地，拜\n降赵匡胤于马下，立誓扶保大宋，铲除诸寇云。",
  "notes": "此剧与《下河东》相接。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八龙套引赵匡胤同上，四太监同上。"
        },
        {
          "character": "赵匡胤",
          "type": "引子",
          "text": "龙争虎斗，这干戈，何日里罢休？"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "蛟龙无水困沙滩，似却明珠土内埋。奸贼诓孤河东地，不知何日转回还。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤，乾德王赵。可恨欧阳藩将孤诓至河东，七载有余。困得孤内无粮草，外无 救兵。命黄兴前去打探，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄兴上。"
        },
        {
          "character": "黄兴",
          "type": "念",
          "text": "打探军情事，奏与万岁知。"
        },
        {
          "character": "黄兴",
          "type": "白",
          "text": "臣黄兴见驾，吾王万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "打探哪路军情，一一奏来。"
        },
        {
          "character": "黄兴",
          "type": "白",
          "text": "臣探得罗家山发来一哨人马，昨日鞭坠白龙，今日叫骂御营，特来奏与万岁得 知。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "黄兴",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄兴下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "且住，黄兴奏道：罗家山发来一哨人马，昨日鞭坠白龙，今日叫骂御营。此誓 叫孤难解也！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄慢板",
          "text": "探马儿不住得飞来报： 他报道罗家山兵发一哨。 杏黄旗不住得空中飘摇， 吓坏了满营中大小英豪。 恨河东刘冲贼打来战表， 他要夺孤王的锦绣龙朝。 欧阳藩在金殿帅印挂了， 呼寿廷倒作了马前先行。 困河东有七载须发白了， 但不知何日里才的回朝？ 在头上摘下了飞龙帽， 在身上脱下了滚龙袍。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤的玲珑吓！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄慢板",
          "text": "玲珑铠甲丝条绕， 杀人妙计有千条。 御林军与孤巡营哨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套同下。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄慢板",
          "text": "把守御营要勤劳。 叫槽头将孤的龙驹马鞍韂备好，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。马童上，备马。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "请爷上马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄慢板",
          "text": "这是孤无能将亲把兵交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、马童同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。呼延赞、八龙套同上。"
        },
        {
          "character": "呼延赞",
          "type": "笑",
          "text": "哈哈哈，吓，哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延赞、八龙套同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "催马来在战场道， 会一会罗家山那家英豪。"
        },
        {
          "character": "呼延赞",
          "type": "内二黄导板",
          "text": "乌骓马不住得吮声吼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延赞上。"
        },
        {
          "character": "呼延赞",
          "type": "二黄慢板",
          "text": "打将鞭一举鬼神愁！ 催马儿来至在御营口，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "呀呔！"
        },
        {
          "character": "呼延赞",
          "type": "二黄慢板",
          "text": "叫一声乾德王快出营头！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄慢板",
          "text": "只见他乌油盔乌油甲， 皂罗袍上绣团花。 跨下了一骑乌骓马， 打将钢鞭手内拿。 问一声小将名和姓， 通上名来好动杀法！"
        },
        {
          "character": "呼延赞",
          "type": "二黄慢板",
          "text": "家住在河南汴梁城， 我的父名叫呼寿廷。 若问小将名和姓， 呼延赞，"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "就是少爷的名！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "孤道呼家无有后， 原来还有后代根。 不通名姓走了罢，"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "钢鞭不打无名人！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "乾德王现在黄罗帐， 我是他驾前一小军。"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "看你不像军家样， 定是御营乾德王！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "少有关西闯帝邦， 岂肯过伏小儿郎？ 若问孤王名和姓， 孤就是御营乾德王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、呼延赞同开打，赵匡胤下，呼延赞追下。赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "催马来在战场下， 小将到来顺说他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延赞上。"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "我父身犯何条律， 为何一命问斩刑？"
        },
        {
          "character": "赵匡胤",
          "type": "二黄导板",
          "text": "小将军暂息雷霆怒，"
        },
        {
          "character": "赵匡胤",
          "type": "二黄慢板",
          "text": "细听孤王说分明： 恨河东刘冲贼战表打定， 他要夺孤王的锦绣龙廷。 欧阳藩在金殿挂了帅印， 你的父倒作了马前先行。 三更时那胡儿前来偷营， 满营中俱言道反了寿廷。 一个斩字未曾出口， 欧阳藩拔宝剑杀尔的父亲！"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "君不传旨谁敢斩？ 哪一个大胆乱杀人！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "兵权落在奸贼手， 孤王也要听令行。"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "不会为君死了罢， 苍天再降紫微星！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "小将保孤回朝转， 孤封你前殿王？"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "后殿王？"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "一十八驾总兵王？"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "万里江山我不要， 一心要报杀父仇！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "小将不必逞刚强，"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "罗家山前自为王！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "孤王与你分上下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、呼延赞同开打，赵匡胤下，呼延赞追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "龙形、虎形同上。赵匡胤上，呼延赞追上。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄导板",
          "text": "人困马乏难交战，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "只见小将睡雕鞍。 手使金锏朝下打， 只见黑虎奔了山！"
        },
        {
          "character": "呼延赞",
          "type": "二黄导板",
          "text": "梦儿里梦见了我父到，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "呼延赞",
          "type": "二黄摇板",
          "text": "只见昏王睡鞍鞒。 手使钢鞭朝下打， 只见赤火龙一条！ 扳鞍离镫下战马， 三呼万岁饶恕咱！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "耳边厢又听得三呼万岁，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮慢板",
          "text": "想必是我朝中发来救兵。 猛然间睁开了丹凤眼，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮慢板",
          "text": "又只见，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "小将跌跪在马前。 在马上擒孤擒不住， 诓孤下马难上难！"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "万岁不必心害怕， 呼延赞保你坐中华！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "你若保孤坐中华， 可对苍天把誓发？"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "万岁命我把誓发， 尊一声苍天听根芽： 呼延赞保主若有假， 死在千军万马踏！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "一见小将把誓发， 不由孤王喜笑发。 左思右想不下马， 金锏挑起小卿家。"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "走上前来参王驾，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "孤王传旨且平身。"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "杀父仇人哪一个？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "欧阳藩是尔对头人！"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "问声奸贼今何在？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "随孤来，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "不在前营在后营。"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "辞王别驾跨战马， 后营去把奸贼杀！"
        },
        {
          "character": "呼延赞",
          "type": "三笑",
          "text": "哈哈哈，吓，哈哈哈！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "喜呵呵来笑呵呵， 孤王收了黑阎罗。 今日收了这员将， 哪怕胡儿动干戈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、呼延赞同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}