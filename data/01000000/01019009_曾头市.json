{
  "script_id": "01019009",
  "title": "曾头市",
  "alias": [
    "英雄义；一名：一箭仇；一名：拿捉史文恭"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "史文恭",
      "hangdang": "武生"
    },
    {
      "name": "卢俊义",
      "hangdang": "生"
    },
    {
      "name": "二女将",
      "hangdang": "武旦"
    },
    {
      "name": "三将",
      "hangdang": "净"
    },
    {
      "name": "阮小二",
      "hangdang": "丑"
    },
    {
      "name": "阮小五",
      "hangdang": "丑"
    },
    {
      "name": "家将",
      "hangdang": "副净"
    }
  ],
  "plot": "梁山水泊首领晁盖率众攻夺曾头市，曾氏教师史文恭为之设法保守。拒战时箭射晁盖，中其要害，回山随即\n毙命。宋江继续为山寨之主，复启夺马之衅，与晁盖报仇。分调五路作进兵之计划，曾氏亦扎立五处寨栅，\n皆由史文恭指挥，互相抵制。虽属武艺精明，奈智不敌吴用，卒为所破，曾氏父子六人均死于乱军之中。史\n文恭乘间逃窜，被卢俊义截住，奋勇向前将史文恭擒获。",
  "notes": "剧本中情节，与《水浒传》所载颇有参差。传中则谓宋江不欲卢俊义上前厮杀，拨步军五百名埋伏平川小路，\n与史文恭不期而遇。剧本中则谓卢俊义为总帅调遣兵将，史文恭由阮氏三雄在水中擒获，以此比较即为异\n点。然此剧系武工重头，必得超等武生始能串演，剧情总以热闹为主，不必斤斤计较于事实也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "史文恭上。"
        },
        {
          "character": "史文恭",
          "type": "引子",
          "text": "武艺高强，论枪法，盖世无双。"
        },
        {
          "character": "史文恭",
          "type": "念",
          "text": "志气冲霄武艺能，曾头市上逞威风。一箭射死贼晁盖，要把梁山一扫平。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "某，史文恭。自幼曾拜周侗为师，习练全身武艺。只因梁山贼寇，恃蛮横行， 每每打家劫舍，扰害黎民。前有段景住，在口外得了一匹好马，名为追风千里 驹，曾要献与宋江，那时他打从我庄经过，被某将此马夺来。谁想那段景住， 去至梁山，搬动是非。那晁盖带领人马前来，是俺一箭，将他射死，梁山众贼 寇，定必要与他报仇。俺也曾命庄丁暗地打探，未见回报到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四英雄暗同上。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "左右，"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八庄丁同上。"
        },
        {
          "character": "八庄丁",
          "type": "同念",
          "text": "忙将梁山事，报与庄主知。"
        },
        {
          "character": "八庄丁",
          "type": "同白",
          "text": "参见庄主。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "尔等回来了？"
        },
        {
          "character": "八庄丁",
          "type": "同白",
          "text": "回来了。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "打探梁山之事，怎么样了？"
        },
        {
          "character": "八庄丁",
          "type": "同白",
          "text": "今有宋江，拜卢俊义为帅，带领忠义堂众好汉，一并前来，要扰乱我庄。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "那梁山贼寇，要扰乱我庄？"
        },
        {
          "character": "八庄丁",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "想那卢俊义，与俺同窗学艺，他若前来拜庄，速报我知。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史文恭下，众人同随下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、二女将、阮小二、阮小五、三将、林冲、燕青、武松、卢俊义同上。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "众位哥嫂请了。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "我等奉了大哥将令，来到此处，待俺随同林贤弟与燕小哥，前去拜庄。众家哥 嫂，在庄外埋伏不得有误。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二女将、阮小二、阮小五、三将、武松同下，龙套、上手同转场。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "有人么，走出一个来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "卢俊义前来拜庄。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "候着。 有请庄主。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四英雄、史文恭同上。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "副净",
          "type": "白",
          "text": "卢俊义前来拜庄。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "副净",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "吓，师兄。"
        },
        {
          "character": "卢俊义、林冲",
          "type": "同白",
          "text": "（贤弟）（师兄）。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "请坐。未知师兄贤弟驾到，某家未曾远迎，面前恕罪。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "岂敢。愚兄来得卤莽，贤弟海涵。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "岂敢。吓，师兄为何这样打扮？"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "贤弟有所不知，只因梁山及时雨宋公明，招贤纳士，结交天下英雄，除暴安良， 替天行道，特命愚兄前来，邀请贤弟，同上梁山，安享富贵。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "师兄此言差矣。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "不差。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "想你我弟兄三人，同拜周侗为师，同窗学艺，练就全身武艺，谁不闻名丧胆。 林贤弟因被奸臣所害，无处可归，投奔梁山躲避，事出无奈。想师兄久居大名， 家财万贯，坐享安乐，为何也投那梁山贼寇！"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "只因你将晁天王射死，忠义堂好汉，纷纷议论。你若执意不肯归顺，梁山众弟 兄，就要报那一箭之仇！"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "师兄吓！"
        },
        {
          "character": "史文恭",
          "type": "急三枪",
          "text": "一箭仇，却因为相争斗。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "贤弟，事要三思，免生后悔。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "想俺史文恭！"
        },
        {
          "character": "史文恭",
          "type": "急三枪",
          "text": "俺全凭枪法优， 纵有梁山贼寇， 凭来将，俺相候， 哪怕你人马稠。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "好言相劝，执意不听，少时被擒，悔之晚矣！"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "听你之言，敢么是要与小弟较量么？"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "正是要与你这匹夫比试。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "哪个是匹夫？"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "你是匹夫。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "你是匹夫。来打！ （史文恭、卢俊义、林冲同起打，打群场，众人同下。史文恭、卢俊义比枪，打快枪，夺枪双扯下。燕青上， 对八庄丁，败下，众人同追下。燕青出庄，家将上。）"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "众庄丁，好生把守庄门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将下，四上手、二女将、三将、武松同上，燕青上。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "众家弟兄一同前往！ （四上手、二女将、三将、燕青同下，武松耍刀下。众人同上，会阵打连环，同下。史文恭、卢俊义夺枪同 扯上，起打，卢俊义看。）"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "你敢么是怯战么？"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "看天色已晚，你我明日再战。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "来者？"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "君子。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "不来？"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "小人。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卢俊义、众人同下。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "众庄丁，后面歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "且住，我与那卢俊义，数载不见，他的枪法越发精壮了，待等明日前来，只怕 此庄有些难保。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史文恭拉势子。"
        },
        {
          "character": "史文恭",
          "type": "风入松",
          "text": "我看他枪法，甚是高强， 盘旋围绕似秋霜。 任你英雄武艺壮， 怎当俺横冲直撞。 好一似搅海翻江， 管叫你一命亡。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "我看他等初到此处，未必准备，不免三更时分，偷营劫寨便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史文恭拉势，下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "卢俊义、众人同上。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "众弟兄，今晚要饱餐战饭，谨慎小心防备那贼前来劫寨。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "大家小心了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史文恭、众人同上，起打八股荡，史文恭败下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "阮小二、阮小五同上。"
        },
        {
          "character": "阮小二",
          "type": "白",
          "text": "我，追魂太岁阮小二。"
        },
        {
          "character": "阮小五",
          "type": "白",
          "text": "我，短命二郎阮小五。 哥哥，你我奉了大哥之命扮做打鱼的模样，等候史文恭，你我就此前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮小二、阮小五同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "史文恭上，翻跟头。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "卢俊义十分骁勇，待我逃走。 吓，渔船快快摆过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮小二、阮小五同上。"
        },
        {
          "character": "阮小二、阮小五",
          "type": "同白",
          "text": "我们是打鱼的船，不渡人。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "多把银钱与你。"
        },
        {
          "character": "阮小二、阮小五",
          "type": "同白",
          "text": "多给银钱就好，待我搭了扶手。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史文恭上船，上桌。"
        },
        {
          "character": "阮小二、阮小五",
          "type": "同白",
          "text": "船到了江心，给钱罢。"
        },
        {
          "character": "史文恭",
          "type": "白",
          "text": "到岸再给。"
        },
        {
          "character": "阮小二、阮小五",
          "type": "同白",
          "text": "不行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史文恭推阮小二、阮小五下水，阮小二、阮小五同扯史文恭下，对打，史文恭被擒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}