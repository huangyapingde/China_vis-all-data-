        {
          "character": "施世纶",
          "type": "白",
          "text": "何言“受屈”二字，请讲。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "大人请看，后山有一石洞，恩公暂且安身，小人每日送些茶饭，在外打听黄天 霸下落，与他送信，慢慢定计，再救恩公出去。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "依你之计，若能离了虎穴，自当另眼相看，请上受我一拜！"
