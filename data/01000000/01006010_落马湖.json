        },
        {
          "character": "李大成",
          "type": "西皮摇板",
          "text": "小人知恩当报恩。"
        },
        {
          "character": "施世纶",
          "type": "西皮摇板",
          "text": "但愿除却莫怀介，"
        },
        {
          "character": "李大成",
          "type": "西皮摇板",
          "text": "大人为何面带惊？"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "大人为何这等惊慌？"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "哎呀，义士呀，方才被获，身带印信失落了。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "恩公，印信在这里。"
        },
        {
          "character": "李大成",
          "type": "西皮摇板",
          "text": "看来苍天有默佑， 巧遇当年旧恩人。 怀中取出总漕印， 双手捧过与大人。"
        },
        {
          "character": "施世纶",
          "type": "西皮摇板",
          "text": "好个聪明李大成， 可算忠义智谋人。 多蒙在此救我命， 留下美名万古存。"
        },
        {
          "character": "李大成",
          "type": "西皮摇板",
          "text": "暂请台驾将身隐，"
        },
        {
          "character": "施世纶",
          "type": "西皮摇板",
