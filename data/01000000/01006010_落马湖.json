        },
        {
          "character": "李大成",
          "type": "白",
          "text": "大人随我来。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "哎，强盗啊！"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "大人来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施世纶下。于亮暗上。"
