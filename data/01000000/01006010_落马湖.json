        {
          "character": "于亮",
          "type": "白",
          "text": "呔，那赃官哪里去了？"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "推下水去了。"
        },
        {
          "character": "于亮",
          "type": "白",
