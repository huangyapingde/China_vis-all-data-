{
  "script_id": "01006010",
  "title": "落马湖",
  "alias": [
    "望江居"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "黄天霸",
      "hangdang": "武生"
    },
    {
      "name": "施世纶",
      "hangdang": "老生"
    },
    {
      "name": "李大成",
      "hangdang": "老生"
    },
    {
      "name": "朱光祖",
      "hangdang": "武丑"
    },
    {
      "name": "褚彪",
      "hangdang": "武老生"
    }
  ],
  "plot": "据说部施公案所载，施世纶亲率黄天霸等众英雄，同往殷家堡擒寇，归时分头而走，不意半途，施世纶为落\n马湖水盗绰号称铁臂猿猴李佩所擒。擒至寨中，李佩欲杀害，幸为李大成设计保全，暗将施公藏匿山洞，日\n饲茶饭。先是，施公任江都县时，布商李大成贩布淮扬间，为盗所劫，幸施公遣黄天霸等，立拿群盗而去，\n李大成始得归乡。不意后二次经商，复为李佩所擒。既擒去，李佩见李大成诚实，遂认为子侄，留在寨中。\n此次施公适发落在李大成之手，以是得救。惟虽得保全性命，仍无力可以救之出险。久欲送信与黄天霸等悉\n知，患无机遇。日者值李佩生辰之日，李大成出湖买办一切，适遇黄天霸于湖干望江居酒楼。盖黄天霸等分\n头访寻施公，已数日，毫无端倪。黄天霸焦急万分，因行至海州褚家庄，拜望褚彪，方探得落马湖水寇一处，\n因欲入湖缉访。故得与李大成邂逅于此。幸李大成感激不忘，尚认识黄天霸面貌，遂与通款洽，备告一切，\n并指示入湖暗号。及湖中设伏之处，乃使分别。黄天霸卒以是得救出施公，实皆李大成一人之力也。",
  "notes": "按落马湖今淮海间，于扬州宝应县相近。旁按他地名，知当时亦即此落马湖也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "牌使者、四青袍、四龙套、四大铠、施安同上。"
        },
        {
          "character": "施安",
          "type": "念",
          "text": "奉官尊差重，不敢一时闲。"
        },
        {
          "character": "施安",
          "type": "白",
          "text": "在下，施安。前日预备官船迎接大人，为何连日不见回来。 众人请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "施安",
          "type": "白",
          "text": "今日大人若不回，你等四下打听便了。"
        },
        {
          "character": "黄天霸",
          "type": "内白",
          "text": "打道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸上。四官接马同下。关泰、李堃、金大力、何路通、朱光祖、计全同上，同上船，黄天霸上船。"
        },
        {
          "character": "施安",
          "type": "白",
          "text": "列位老爷，因何来迟？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "前在殷家堡交了一战，擒来众寇，特请大人审问。"
        },
        {
          "character": "施安",
          "type": "白",
          "text": "我等在此等了三日，大人未曾回来。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "啊，大人未曾回来？"
        },
        {
          "character": "施安",
          "type": "白",
          "text": "未曾回来。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "众位英雄！"
        },
        {
          "character": "关泰、李堃、金大力、何路通、朱光祖、计全",
          "type": "同白",
          "text": "黄爷！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "我等未离殷家堡，大人先行八日，此时众人俱回，大人不见音信，难道又遇凶 险不成？"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "哎呀，我的老兄弟，我想大人若遇凶险，你打个主意才好！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "列位英雄，一半看守人犯，一半随我下船，打听大人。众兵丁在此湾船不可自 乱，若是本处官员，前来参见，就说大人染病在船，一概免见。众位英雄听我 吩咐："
        },
        {
          "character": "黄天霸",
          "type": "西皮摇板",
          "text": "周参将、朱千总随我改扮， 金大力、何路通巧装下船。 各处里暗打听计全神眼， 带官兵押人犯李五公然。"
        },
        {
          "character": "王殿臣",
          "type": "内白",
          "text": "走哇。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "黄天霸",
          "type": "西皮摇板",
          "text": "耳听得江岸上人声叫喊， 见一人慌张张飞奔官船。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王殿臣上，搭扶手，上船。"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "列位英雄，大事不好！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "何事惊慌？大人今在何处？"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "哎呀，众位英雄！我与大人，同雇小舟过江，不想那船家看破机关，将我打入 江中，大人一定死在他人之手！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸昏。金大力打王殿臣。"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "打死你这无用的东西！"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "哎哎，先莫打他，救活的要紧。"
        },
        {
          "character": "关泰、李堃、金大力、何路通、朱光祖、计全",
          "type": "同白",
          "text": "黄爷醒来！"
        },
        {
          "character": "黄天霸",
          "type": "二黄导板",
          "text": "累次不幸遭凶险，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸哭。"
        },
        {
          "character": "黄天霸",
          "type": "二黄摇板",
          "text": "平白江下起祸端！ 苍天不抱忠良念， 暂忍恨怒问根源。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "王殿臣，你可知那船家住在哪里，姓甚名谁？"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "那人要伤大人性命，卑职与他动手相争，也未曾问他姓名，只见是一光头大汉。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "列位英雄，久在江湖，可知水路之中，谁为首领？"
        },
        {
          "character": "关泰",
          "type": "白",
          "text": "李五爷，想你执掌白旗多年，可知水路英雄，何人为首？"
        },
        {
          "character": "李堃",
          "type": "白",
          "text": "俺执掌白旗，若是旱路英雄，无有不晓；水面之中，我却不晓。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "何爷。"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "朱爷。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "你做水路的买卖，可知何人为首？"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "我在水面行走，单人独本，从不同伴，况且江面并无水路之人在内。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "啊，你们俱以不知？"
        },
        {
          "character": "关泰、李堃、金大力、何路通、朱光祖、计全",
          "type": "同白",
          "text": "不知。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哎呀，苍天哪！想俺黄天霸，自投施公以来，并无半日清闲，指望落个忠义二 字，不负先君之命，如今大人音信全无，难遂平生之愿。也罢！ 列位英雄！"
        },
        {
          "character": "关泰、李堃、金大力、何路通、朱光祖、计全",
          "type": "同白",
          "text": "黄爷！"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "多蒙你等弃暗投明，屡次勤劳，皆因俺天霸累及，众位各归旧业，安然自在， 你们在那绿林之中，休管俺天霸之收梢也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关泰、李堃、金大力、何路通、朱光祖、计全同哭。"
        },
        {
          "character": "黄天霸",
          "type": "二黄原板",
          "text": "并非是贪功名荣华安享， 都只为遵父命报答君王。 功不成名不就痴心妄想，"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "黄天霸",
          "type": "二黄原板",
          "text": "舍一命我情愿投在长江！"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "哎呀，我的老兄弟！何不差我们下得官船，寻访大人下落，若是有了大人，两 全其美；若是无有大人，咱们要死死在一块！谁要不愿，与我把他妈……"
        },
        {
          "character": "金大力",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "真叫我着急！"
        },
        {
          "character": "关泰",
          "type": "白",
          "text": "啊，黄爷，何不差我等，下得官船，访问大人要紧。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "好，难得各位同心。访问大人，关爷协同金、李二位，东路打探，若有下路， 即速回船。"
        },
        {
          "character": "关泰、金大力、李堃",
          "type": "同白",
          "text": "遵命，打扶手！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关泰、金大力、李堃同下。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "王殿臣，带领朱、何二位，去往西北两岸打探，若有音信，即速回船！"
        },
        {
          "character": "王殿臣、何路通、朱光祖",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王殿臣、何路通、朱光祖同下。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "计仁兄，看守众寇，我往南路访问大人，若得老天保佑，有了下落，自有音信 回来。哎呀，计仁兄，倘访不着大人，我在他乡不回来了——"
        },
        {
          "character": "黄天霸",
          "type": "二黄摇板",
          "text": "殷家堡拿获了众多贼寇， 回官船料不想又起祸端。 似明月照芦花音信不晓， 去打听好叫我路走哪条。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "哎呀，计仁兄，我此番前去，访问大人下落，若有音信，即速回船，若无大人， 纵死他乡，我也不回来了。走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸下。"
        },
        {
          "character": "计全",
          "type": "白",
          "text": "众水手，将船湾在江心，看守贼寇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。摆帐子。"
        },
        {
          "character": "施世纶",
          "type": "内西皮导板",
          "text": "入龙潭遭贼害忠良自叹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水手押施世纶同上。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "唉，万岁啊！"
        },
        {
          "character": "施世纶",
          "type": "西皮原板",
          "text": "眼望着京都内泪撒胸前。 食君禄一心要除奸救难， 过江南又谁知起下祸端。 落马湖遭围困水势凶险， 四下里重叠叠岐岭高山。 眼见得众英雄不能相见， 在此间丧性命心血不干。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八喽罗、四大将、于亮、李大成、李佩同上。〖牌子〗，〖吹打〗。"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "毛如虎命丧他人之手，今日将他绑于灵前，祭奠与你，以表师徒之义。替那屈 死绿林，冤冤相报。"
        },
        {
          "character": "李佩",
          "type": "西皮摇板",
          "text": "十载怀恨常思念， 师生之情不虚言。 斟酒焚香来祭奠， 有冤当报理当然。"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "刀来！"
        },
        {
          "character": "李佩",
          "type": "西皮摇板",
          "text": "今杀贼官除后患！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地上，用拐杖打刀断。李佩惊。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "李大成",
          "type": "西皮摇板",
          "text": "将计就计忙开言。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "叔父不必动怒，小侄有计献上。"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "你有何计？"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "刀炸两段，想他乃朝中大臣，不该死在刀下。这落马湖内山水连天，待我将他 绑至后山，推下江去，叫他死在江中，岂不是好？"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "也罢，留他个全尸！将他交与你，推在湖中。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "领命！解下桩来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李大成、施世纶同下，土地随下。"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "且住！想施公在此丧命，闻他标下有些余党，恐有奸细前来。你等各驾小舟， 把守湖口，防备有人窥探。"
        },
        {
          "character": "于亮",
          "type": "白",
          "text": "寨主放心，这湖内三面是水，一面是山，上有竹城，下有铁网，水底埋伏弩箭 钢刀，就是会水的，不能睁眼，准死湖中，何况那些旱路官兵，插翅也飞不进 湖口。"
        },
        {
          "character": "李佩",
          "type": "白",
          "text": "我岂不知，你们千万不可大意，听我吩咐！"
        },
        {
          "character": "李佩",
          "type": "西皮摇板",
          "text": "昼夜巡防在江面， 休放湖口入官船！ 安排刀枪弓和箭， 齐心协力莫偷闲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李佩下。"
        },
        {
          "character": "于亮",
          "type": "白",
          "text": "寨主吩咐：大家各路把守去者！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李大成、施世纶同上。"
        },
        {
          "character": "施世纶",
          "type": "西皮导板",
          "text": "适才一命遭凶险，"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "大人醒来。"
        },
        {
          "character": "施世纶",
          "type": "西皮摇板",
          "text": "悠悠七魄又还魂。 昏昏沉沉睁双眼，"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "大人受惊了。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "施世纶",
          "type": "西皮摇板",
          "text": "见一壮士跪面前。"
        },
        {
          "character": "李大成",
          "type": "西皮摇板",
          "text": "当年多蒙大恩典， 幸亏相逢在此间。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "小人救护不周，身该万死！"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "你是何人，搭救我命，本院一时想你不起。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "恩公，小人当年，在淮扬贩卖布匹，被盗抢劫，流落他乡，无奈何江都县叩告， 多蒙恩公拿住盗贼，追还货物，一家团圆，此恩未报。小人就是李大成！"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "啊，你就是江都县的李大成？"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "本院当年救你还家，怎么落在此地？"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "小人后来，贩货船行江内，被他们擒进落马湖，小人无奈，将布匹银两送与那 李佩，只求一命。不料李佩无儿，将小人认为同宗侄儿，留在此处。先前本当 营救，又恐被他解破机关，望恩公恕罪！"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "不是你在此，本院早就赴黄泉了。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "恩公自居钦命，当年那位黄天霸哪里去了？"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "天霸另有公干，故而有此大祸。你能救我出去，本院自当重谢。"
        },
        {
          "character": "李大成",
          "type": "白",
          "text": "恩公，此地水势凶险，有如铜墙铁壁，如何出去。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "哎，罢了哇！"
