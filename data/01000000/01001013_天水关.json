{
  "script_id": "01001013",
  "title": "天水关",
  "alias": [
    "初出祁山；一名：取三郡"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "姜维",
      "hangdang": "净"
    },
    {
      "name": "刘禅",
      "hangdang": "小生"
    }
  ],
  "plot": "三国，诸葛亮平南后，出师北伐，兵出祁山。魏使夏侯渊子夏侯楙御之。诸葛亮使人诈称夏侯楙受困，请各\n郡援救，待彼出兵后，即使赵云袭取其城。各郡守将多中计，遂得二郡。至天水，守将马遵闻信，急欲出救，\n为姜维所阻，谓：都督固宜救援，而天水亦不可不备，恐诸葛亮用声东击西之计以袭天水，甚可虑也。乃\n设计请马遵提兵出城，待蜀兵来，回击之，内应外合，以困蜀兵。马遵从之，离城不远。赵云果至，马遵与\n姜维夹击之，赵云大败而回。诸葛亮大惊，深赞姜维之能。探知姜维甚孝，派兵往冀城取其母。姜维闻信提\n兵往救，诸葛亮乃择军中貌似姜维者，乔扮姜维，夜半功城，谓姜维已降汉。马遵骇甚。黎明伪姜维即退，\n适真姜维回天水，请马遵开城。马遵以为诳己也，乱箭射之。姜维拟投他郡，为诸葛亮伏兵所困，不得已遂\n降。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，刘禅上。"
        },
        {
          "character": "刘禅",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "刘禅",
          "type": "念",
          "text": "先皇晏驾白帝城，满朝文武不安宁。多亏相父来扶助，孤皇才得坐龙庭。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤，刘禅。登基以来，风调雨顺，国泰民安。今当早朝。 内侍，"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "闪开龙门。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "领旨。 闪开龙门。"
        },
        {
          "character": "诸葛亮",
          "type": "内白",
          "text": "唔咳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "代理山河，掌丝纶，运筹帷幄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣诸葛亮见驾，陛下千岁。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "相父平身。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "相父手捧何物？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣有出师表章，我主龙目一览。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍接上。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "哦，呵呀！才得干戈宁静，又要出兵。叫孤心中难舍。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢板",
          "text": "先帝爷白帝城龙归海境， 传口诏命老臣常挂在心。 命老臣保陛下江山重整， 命老臣把孙曹定要扫平。 臣上本并非是别的议论， 望我主准臣本臣要发兵。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "老相父奏的是治国经纶， 一桩桩一件件孤皇在心。 你前番剿孟获狼烟扫尽， 年迈人理应该乐享太平。 待孤皇在金殿传下御旨， 文武臣摆酒宴长亭饯行。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "食君禄报皇恩当把忠尽， 臣敢劳我主爷长亭饯行。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "内侍臣摆御驾后宫来进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同下。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "明日里待孤皇长亭饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅下，诸葛亮下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "魏延、马岱、关兴、张苞同上。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "大将生来盖世雄，"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "万马营中逞威风。"
        },
        {
          "character": "关兴",
          "type": "念",
          "text": "耀武扬威英雄将，"
        },
        {
          "character": "张苞",
          "type": "念",
          "text": "斩将擒王立大功。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "俺魏延。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "俺马岱。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "俺关兴。"
        },
        {
          "character": "张苞",
          "type": "白",
          "text": "俺张苞。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "马岱、关兴、张苞",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "老元戎发兵，你我在此同候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同上，赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "白发苍苍似雪飘，东灭孙权北剿曹。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "参见老元戎。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "多谢老元戎。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "圣驾到此，一同接驾。"
        },
        {
          "character": "太监",
          "type": "内白",
          "text": "圣驾到。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "一同接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监同上，诸葛亮、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "手挽手与相父长亭来进， 众将官一个个杀气腾腾。 看过了大纛旗香案设定， 尊一声众神灵细听分明： 但愿得此一去旗开得胜， 但愿得此一去马到功成。 内侍臣看过了皇封御饮， 我与你老相父特来饯行。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "我主爷赐皇封臣不敢饮， 背转身谢过了天地尊神。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "四皇叔孤赐你皇封御酒， 但愿你此一去奏凯回程。"
        },
        {
          "character": "赵云",
          "type": "二黄原板",
          "text": "臣年迈仗我主洪福天定， 食君禄必须要答报皇恩。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "我朝中有二臣忠心秉正， 蒋公琰、费文炜二大贤臣。 臣去后诸国事与他们议论， 宫中事朝中事臣不欺君，君不瞒臣，以礼而行。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "君臣们在长亭话叙不尽，"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "谢我主龙驾归臣要发兵。"
        },
        {
          "character": "刘禅",
          "type": "二黄摇板",
          "text": "内侍臣摆御驾皇城来进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四大铠同下。"
        },
        {
          "character": "刘禅",
          "type": "二黄摇板",
          "text": "得胜回孤接到十里长亭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅下。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "众将官齐上马擂鼓三通，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "擂鼓。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "文武官且免送响炮起营。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官，兵出祁山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同带马，车夫上，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马遵上。"
        },
        {
          "character": "马遵",
          "type": "念",
          "text": "威镇天水关，儿郎心胆寒。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "本帅马遵，只因孔明带领人马，要夺天水关，命人前去打探，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报，韩德父子五人落马。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "再探！ 来，免战高悬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套允。"
        },
        {
          "character": "姜维",
          "type": "内白",
          "text": "哽唬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维上。"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "一颗明珠土内藏，几载未曾放毫光。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "俺，姓姜名维，字伯约。正在后帐观看兵书，忽听都督免战高悬。待我进帐， 问个明白。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "姜维告进。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "将军少礼，一旁坐下。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "将军无令，进帐有何军情议论？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "末将正在后帐歇息，忽听都督免战高悬，也不知所谓何事？"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "只因韩德父子五人落马，故而免战高悬。"
        },
        {
          "character": "姜维",
          "type": "叫头",
          "text": "都督！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "赐某将令一支，到两军阵前，生擒赵云进帐。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "你有此胆量？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "有此胆量。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "姜维听令。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "命你带领本部三千人马，大战赵云，不得迟误。"
        },
        {
          "character": "马遵",
          "type": "念",
          "text": "传令山摇动，"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "接令鬼神惊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马遵下。四绿龙套自两边分上。"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "参见将军。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "姜维",
          "type": "西皮导板",
          "text": "众将官站两厢听我令下，"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "姜维",
          "type": "西皮原板",
          "text": "叫一声众三军马步英豪： 刘玄德坐西川其心诡诈， 全凭着五虎将立下功劳。 关美髯过五关谁人不晓， 他三弟张翼德喝断霸桥。 西凉将小马超世间稀少， 还有那老黄忠惯使大刀。"
        },
        {
          "character": "姜维",
          "type": "西皮快板",
          "text": "此一班五虎将大半丧了， 只剩下赵子龙老迈年高。 小阿斗坐西川年纪幼小， 有关兴和张苞不算英豪。 三军随爷战场道，"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套同带枪下。"
        },
        {
          "character": "姜维",
          "type": "西皮快板",
          "text": "捉孔明擒赵云只在今朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同上，赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "奉将令出营门要把贼剿， 有谁人敢敌俺画杆银苗！ 叫三军你引我忙上战道， 那边厢又来了送死儿曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套同上，姜维上。"
        },
        {
          "character": "姜维",
          "type": "西皮摇板",
          "text": "催马来在战场道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四绿龙套同下。"
        },
        {
          "character": "姜维",
          "type": "西皮摇板",
          "text": "叫老儿通上名好把兵交！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "三国中赵子龙谁人不晓！ 问一声黄毛贼哪家儿曹？"
        },
        {
          "character": "姜维",
          "type": "西皮摇板",
          "text": "你老爷名姜维伯约旗号， 今日里擒住你要立功劳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、赵云同杀。关兴上，救赵云下。四绿龙套自两边分上。"
        },
        {
          "character": "姜维",
          "type": "西皮摇板",
          "text": "正要擒那赵子龙， 忽然闪出一孩童。 手使大刀劈面砍， 雅赛过当年美髯公！ 三军打罢得胜鼓，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套同喝。"
        },
        {
          "character": "姜维",
          "type": "西皮摇板",
          "text": "都督台前立头功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套、姜维同下。"
        }
      ]
