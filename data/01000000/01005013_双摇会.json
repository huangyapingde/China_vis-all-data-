{
  "script_id": "01005013",
  "title": "双摇会",
  "alias": [
    "二美夺夫"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "王氏",
      "hangdang": "旦"
    },
    {
      "name": "小妾",
      "hangdang": "旦"
    },
    {
      "name": "李相公",
      "hangdang": "小生"
    },
    {
      "name": "老街坊",
      "hangdang": "丑"
    },
    {
      "name": "小街坊",
      "hangdang": "丑"
    },
    {
      "name": "书童",
      "hangdang": "丑"
    }
  ],
  "plot": "此剧形容妻妾争风丑态，演时诙谐杂出，颇足另人捧腹。某士人家有一妻一妾，出外时妾每为妻所欺。一日\n某作客归，先入妾房卧宿，不意为妻所知，蹑至房外窃听。妾正在彼所说被大娘打骂苦情，妻遂大骂，打门\n冲进。从此二人吵闹不休，某亦无法止住，惊动另局到来排解，同她们并半均分，妻、妾各住半月。二人虽\n听从邻居之言，惟仍争夺上半月。邻居又想出双摇会之法，点色大者得上半，小者得下半。遂如法而行，卒\n为二娘所得。",
  "notes": "此剧虽以滑稽出之，然一片婆心，颇欲针砭末俗，使要妾者知系自讨烦恼。惜乎观剧者不采其精意，而徒视\n为逢场取乐之具也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王氏上。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哽哼！"
        },
        {
          "character": "王氏",
          "type": "念",
          "text": "为人莫当家，当家累如麻。每日要早起，油盐酱醋茶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏坐。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我，王氏。配夫李相公为妻，是一个教书的，常常在外。不晓得听了什么人的 话，又娶了一个二奶奶。没有娶她的工夫，我们两口子，不提多好呢；如今娶 了她，把我就甩了。今天相公不在家，我把她叫出来，帮我作作活。她要不好 好地作，趁着相公不在家，我打她两下，出出我的气。 二娘！二奶奶！唬！跟我滚出来罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小妾上。"
        },
        {
          "character": "小妾",
          "type": "念",
          "text": "忽听大娘唤，迈步到跟前。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "大奶奶，我们这里有礼呢。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "罢了，坐下罢。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "大奶奶，把我叫出来有什么事情？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我打娘家带的活来，叫你帮我做做，行不行？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "行。在哪里做？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "在我屋里做。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "你屋里怪黑的，在我屋里做去。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "你屋里有点腥气味儿，我不去。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "在哪里做？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "大厅上做去罢。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "走吓。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "走吓。"
        },
        {
          "character": "王氏",
          "type": "西皮摇板",
          "text": "姊妹好比一支花，"
        },
        {
          "character": "小妾",
          "type": "西皮摇板",
          "text": "十人见了九人夸。"
        },
        {
          "character": "王氏",
          "type": "西皮摇板",
          "text": "将身来在厅堂下，"
        },
        {
          "character": "小妾",
          "type": "西皮摇板",
          "text": "姊妹二人把活拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏、小妾同坐。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "大奶奶，我做什么？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我替你找找。你做这双鞋，我做这条裙子。我告诉你，今个做活，谁也不许瞧 谁的。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "谁要瞧谁的了？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "谁就是忘八蛋杂种。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "就是这么说的吓。"
        },
        {
          "character": "小妾",
          "type": "西皮摇板",
          "text": "大奶奶在厅前说出此话， 他那里说的是羞煞奴家。 这一边绣的是海棠花， 这一边绣的是鱼水鸳鸯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小妾睡。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "好好做，快着一点做。 你瞧做生活，睡着了！ 二奶奶醒醒，二娘醒醒。吓，我说你醒醒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小妾醒。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "吓，大奶奶什么事？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "你怎么做生活，睡着了？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "我早做完了你了。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "……这双鞋。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "拿来我瞧瞧。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "咦，方才你说的，今个做活，谁也不瞧谁的。谁要瞧谁的，谁就是忘八蛋杂种。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我要告诉你，今个只许我瞧你的，不许你瞧我的。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "今个偏不给你瞧。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "今个偏要瞧。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "偏不给你瞧！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "要瞧瞧定了！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "给你瞧！你瞧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小妾把鞋往在地下一掷。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我来瞧。 哎吓，自来旧！这花怎么做的？ 我问你，你这个花谁教与你的？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "这个活，我妈教与我的。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "看这个活，连你妈都不是人造的！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "你妈才不是人造的！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "好吓，要价还价。你道相公不在家，我就不敢打你？你过来，我跟你说话！好 贱人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏打小妾。"
        },
        {
          "character": "王氏",
          "type": "西皮快板",
          "text": "贱人说话真可气， 每日做事把我欺。 手执家法将你打， 管叫你小贱人一命归西！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "哎吓，大奶奶！饶了我罢，不要打了！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "饶了你容易，好好的叫我一声，我就饶你了。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "如此“大奶奶”！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "谁要你叫大奶奶？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "叫你什么？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "连叫人你都不会么？我教你。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "我学学。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "亲亲的，热热的，象牙筷子挑凉粉，一挑一夺索，一夹一长往，长长往往的小 干妈！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "要你叫我！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "哦，要叫你，你听着：亲亲的，热热的，象牙筷子挑凉粉，一挑一夺索，一夹 一长往，长长往往的小干妈！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "儿子答允吓！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "吓，大奶奶光顾了打我，忘了佛前烧香了！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "对吓。顾住跟你呕气，忘了佛前烧香了，起来罢。正是："
        },
        {
          "character": "王氏",
          "type": "念",
          "text": "口念千声佛，早晚一炉香。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "罢罢，阿弥陀佛！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "我把你老……"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "“老”什么？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "……老姐姐。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "本来是老姐姐。你要来奉承我，我告诉你：今个打也打了你，骂也骂了你了。 相公回来，不许你告诉。你要告诉了，我这一脚，把你的养孩子的紫肠踹折了， 让你一辈子养不了孩子。哎呀，闪了腰了。罢罢罢，阿弥陀佛！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "我把你老贱人！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "啊唷，没有听见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏下。"
        },
        {
          "character": "小妾",
          "type": "叫板",
          "text": "贱人吓！"
        },
        {
          "character": "小妾",
          "type": "西皮摇板",
          "text": "贱人作事心太狠， 终日打骂实难忍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李相公上，书童上。"
        },
        {
          "character": "李相公",
          "type": "西皮摇板",
          "text": "书童带路往前行， 不觉来到自家门。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "到了，相公。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "前去叫门。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "晓得。 大奶奶开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小妾上。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "门外有人叫门，想必相公回来了。待我开门。 啊，相公。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "吓，二娘。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "相公请。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "二娘请进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小妾坐，李相公关门。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "咦，关上门了？ 开门来，开门来！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "哦，想是书童在外，待我开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童进。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "相公这个马拴在哪里？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "拴在槽头上。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哦，拴在槽头上。咦，相公相公，你怎么把我带在烟花里来了？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "这是什么话？是你二娘。去见过。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哦，这是二师娘，我当是烟花馆。 参见二师娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小妾打。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "相公相公，回头我在哪里吃饭？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "在厨房里吃饭。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "相公相公，吃完了饭在哪里拉屎？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "疕房里拉屎！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "相公相公，拉完了屎在哪里睡觉？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "在厢房内睡觉！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "哦，厢房。相公相公，这个……"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "滚下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童下。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "吓，二娘。卑人出门之后，大娘待你如何？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "相公吓！"
        },
        {
          "character": "小妾",
          "type": "西皮摇板",
          "text": "自从相公出门庭， 终日打骂实难忍。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "二娘不必如此。明日待我打她几下，与二娘出出气。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "既然如此，今个在哪个房里睡觉？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "自然在你房里睡。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "大娘知道了？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "大娘知道有我。请。"
        },
        {
          "character": "李相公、小妾",
          "type": "同西皮摇板",
          "text": "今日好似七月七， 牛郎织女会佳期。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李相公、小妾同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王氏上。"
        },
        {
          "character": "王氏",
          "type": "西皮摇板",
          "text": "耳边厢听得有人声， 不知相公转门庭。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "吓，这个乃是相公的。好吓，不声不响的，拉到她房里去了。我来听听。"
        },
        {
          "character": "李相公",
          "type": "内白",
          "text": "啊，二娘。自从卑人出门之后，大娘待你如何？"
        },
        {
          "character": "小妾",
          "type": "内白",
          "text": "自从相公出门之后，大娘在家终日打，每日骂，叫我们好难受。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哎吓，可要我的命了！ 你们都滚出来罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童上，王氏打书童，书童下。李相公、小妾同上。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "辛苦辛苦！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "好说有偏！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "不要脸，不要脸！这不是相公么？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "他是相公。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我知道。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "你知道不要问。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "偏要问！偏要问！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "养伤罢！"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我说相公，昨晚回来，怎么不声不响的，到了她房里去了？我这里交给谁呢？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "那么上你房里，我这里交与谁呢？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "你吓，贴张招租罢。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "你才贴招租呢。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "好吓，你道相公在家，我不敢打你！你过来，好贱人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏打小妾，李相公生，拿椅子。老街坊、小街坊同上。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "请吓！"
        },
        {
          "character": "老街坊",
          "type": "梆子",
          "text": "忽听得街坊上闹吵声，"
        },
        {
          "character": "小街坊",
          "type": "梆子",
          "text": "吵得我二人睡也睡不着。"
        },
        {
          "character": "老街坊",
          "type": "梆子",
          "text": "睡不着，你就该攒着……"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "老街坊",
          "type": "梆子",
          "text": "那个烟袋，"
        },
        {
          "character": "小街坊",
          "type": "梆子",
          "text": "如不然，我二人去看分明。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "到底是年纪大的，见面就见礼。我也还一礼，请了。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "你可曾听见？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "这什么讲法？我又来，老头子，你看见一样东西没有？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "在那里。你说什么话？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "怎么呢？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "你才怎么呢？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "你可曾听见李相公家里，三更半夜放着觉不睡，打打呱呱，骂骂咧咧。常言道： 一家有事，四邻不安。我们去看看什么事。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "好，老头子。我帮着你去。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "走。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同念",
          "text": "行行走走，走走行行。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "到了。哎，半掩门。我二人与他一个大开门。李相公在哪里，李相公在哪里？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "吓，原来是二位。到此何事？"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "三更半夜，你们放着觉不睡，为什么打打呱呱，骂骂咧咧。什么原故？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "吓，二位！家务之事，一言难尽！"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "他说一言难尽，你懂不懂？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "我懂。你懂不懂？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "我倒不晓得。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "亏了我在这里，告诉你听听。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "领教领教。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "这个一言难尽吓……"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "这个一言难尽，就是一言难尽。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "你不说，我倒明白；你这么一说，我更糊涂了。这个事情，是要问问当家大奶 奶。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "好，去问问大奶奶。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "哈哈哈哈。我道是谁，原来是二位老忘八。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "不错，是你的老人家。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "你说什么？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我说二位老人家。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "不错，二位老人家。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "你们二位，三更半夜，放着觉不睡，哼，我知道了，不知道哪家倒尿壶，打你 们二位冲出来了。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "好，变了屎蛋了。你们三更半夜放着觉不睡，为什么打打呱呱，骂骂咧咧。到 底什么原故？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我说二位老人家，别人家的事情，你们不知道；我们家里事情，你们还不知道 么？"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "人家事情，我们不知道；你们家里事情，我们更不知道。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我们这位相公，是教书的。在家日子少，出外日子多。在外头不晓得听了哪个 狗杂子忘八蛋的话……"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "你是狗杂子。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "你是忘八蛋。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "都差不多。怎么样？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "如今要了这位二奶奶。没有要她的功夫，我们不提多好呢。自从娶了她，把我 好一比……"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "好比什么？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "伤风的鼻涕——刻就甩了！"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "李相公没有良心。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "好容易相公昨天回来了，来不及拉她房里去了。有知道的，她没大没小；不知 道的，当我们娘们争风吃醋。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "哎吓，好醋好醋！怎么吃下肚去了。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "咳，这个好东西，吃下肚去，消痰化气，不放臭屁！"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "不要闹了。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "这个是一面之词，不可听。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "去问问二奶奶。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "对，去问问。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "二奶奶在哪里，二奶奶在哪里？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "我道二位是谁，原来二位老乌鸡。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "什么？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "哦，二位老邻居。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "不错，二位老邻居。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "三更半夜，放着觉不睡……哦，我知道了，听说我们相公回来了，跟我们佃腰 来了？"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "我们当不了那个差事。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "干什么来的？"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "你们三更半夜，放着觉不睡，为什么打打呱呱，骂骂咧咧。到底什么原故？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "二位老邻居，别人家事情，你们不知；我们家事情，难道说你们也不知道的？"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "人家事情，我们不知；你们家里事情，我们有知道的，有不知道的。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "今有我们这位相公，要了这位大奶奶，有七、八年没有开过怀。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "什么？你打听打听，我在娘家养过七、八个！"
        },
        {
          "character": "老街坊、小街坊、小妾",
          "type": "同白",
          "text": "什么什么？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "不要着急，养过七、八个小猫小狗。"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "大奶奶猫狗养的。你说你的。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "二位老人家，你们可知道，相公娶我来，是为什么？"
        },
        {
          "character": "老街坊、小街坊",
          "type": "同白",
          "text": "到底是为什么？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "为的是生儿养女。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "你是哥哥。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "你是妹妹。不要闹了。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "你想着，春天不下种，苗从何处生？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "好，我看你怎么样。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "老头子，你吃了，我不吃。摆在这里，让她受了日精月华，好变条小狗。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "不要闹了。小伙子，你可知道为什么事？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "不晓得。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "因为吃醋。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "唬，这么多年纪，怎么说这个话？不是吃醋，吃的陈醋。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "更酸。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "他们这么吵，你有什么主意没有？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "我有主意。让他们分家罢。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "人家过的好好日子，不能分家。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "这分家跟那个分家不同。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "怎么不同？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "一个分上半月，一个分下半月，就不吵了。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "这倒不错。老头子你说话。李相公、大奶奶、二奶奶都跕过来。老头子你抄起 来。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "我抄哪一个？"
        },
        {
          "character": "王氏、小妾",
          "type": "同白",
          "text": "什么造的？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "哎，叫你抄话，谁叫你抄人？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "我弄错了。李相公、大奶奶、二奶奶，你们常常闹，也不是事情。依我老汉的 主意，把这个家分了罢。"
        },
        {
          "character": "王氏、小妾",
          "type": "同白",
          "text": "我们过的好好日子，不分家。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "分家跟分家不同。一个上半月，一个下半月。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "如此说来，我要上半月。"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "我要上半月。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "我要上半月，我要上半月！"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "我要上半月，我要上半月！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二街坊同劝。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "慢来慢来。你们都要上半月，下半月叫我上哪里去？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "下半月上老头子家里去。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "上你家里去。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "老头子你这个主意不好。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "不好我没有了。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "看我的大奶奶、二奶奶你们不要吵，你们不要吵，你们来抽签罢。谁抽着，谁 是上半月。"
        },
        {
          "character": "王氏、小妾",
          "type": "同白",
          "text": "抽签有假。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "抽签有假，摇会罢。"
        },
        {
          "character": "王氏、小妾",
          "type": "同白",
          "text": "什么？摇会？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "三粒色子，摆在碗里。谁摇的点大，谁是上半月；谁摇的点小，谁是下半月。"
        },
        {
          "character": "王氏、小妾",
          "type": "同白",
          "text": "好，听信罢。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "老头子，有色子没有？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "好吓，出来劝架，不带色子么？大奶奶有色子没有？"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "又没有。二奶奶有色子没有？"
        },
        {
          "character": "小妾",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "二奶奶江北人说没得；老头子来劝架，怎么不带色子来？"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "我倒忘了。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "我来与你拿出来罢。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "这个色子。"
        },
        {
          "character": "老街坊",
          "type": "白",
          "text": "吓我一跳。"
        },
        {
          "character": "小街坊",
          "type": "白",
          "text": "老头子你看看，四平头！这个色子多好！"
