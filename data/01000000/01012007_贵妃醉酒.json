{
  "script_id": "01012007",
  "title": "贵妃醉酒",
  "alias": [
    "百花亭"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "杨贵妃",
      "hangdang": "花旦"
    },
    {
      "name": "裴力士",
      "hangdang": "小生"
    },
    {
      "name": "高力士",
      "hangdang": "丑"
    }
  ],
  "plot": "唐玄宗先一日与杨贵妃约，命其设宴百花亭，同往赏花饮酒。至次日，杨贵妃遂先赴百花亭，备齐御筵候驾，\n孰意迟待移时，唐玄宗车驾竟不至。迟之久，迟之又久。乃忽报皇帝已幸江妃宫，杨贵妃闻讯，懊恼欲死。\n杨贵妃性本褊狭善妒，尤媚浪，且妇女于怨望之余，本最易生反应力。遂使万种情怀，一时竟难排遣，加\n以酒入愁肠，三杯亦醉，春情顿炽，忍俊不禁。于是竟忘其所以，放浪形骸，频频与高力士、裴力士二太监，\n作种种醉态，及求欢猥亵状，乃始倦极回宫。",
  "notes": "此剧为花旦做工兼唱工戏，纯以身段软柔见长。惟识者见之，甚觉其无谓。且亦形容太过，若遇恶劣之花旦\n演之，则每每描摹过当，尤觉不堪，直令人作三日恶。当年路三宝演此，颇为一般人所称许。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "裴力士、高力士同上。"
        },
        {
          "character": "裴力士",
          "type": "念",
          "text": "天上神仙府，"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "人间宰相家。"
        },
        {
          "character": "裴力士",
          "type": "念",
          "text": "若要真富贵，"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "除非帝王家。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "今日万岁爷同娘娘前往百花亭饮宴，你我小心伺候。香烟缭绕，想必娘娘来也！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "你我分班伺候。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴力士、高力士分站。"
        },
        {
          "character": "杨玉环",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四宫女同上，杨玉环上。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "海岛冰轮初转腾， 见玉兔又转东升。 冰轮离海岛，乾坤分外明， 皓月当空，恰便是嫦娥离月宫。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "娘娘千岁！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "二卿平身。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "杨玉环",
          "type": "念",
          "text": "独坐皇宫有数年，圣驾宠爱我占先。宫中冷落多寂寞，辜负嫦娥独自眠。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "妾乃杨玉环，蒙主宠爱，钦点贵妃，这且不言。昨日圣上命我往百花亭大摆筵 宴。 吓，高、裴二卿摆驾！"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "好似嫦娥下九重， 凄凄冷落广寒宫。吓，广寒宫。"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "启娘娘：来此已是玉石桥！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "摆驾。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "玉石桥斜依把栏杆靠，"
        },
        {
          "character": "高曲",
          "type": "内白",
          "text": "金丝鲤鱼朝见娘娘！"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "欢见鱼戏水，金丝鲤鱼在水面上漂，水上漂。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "当空雁儿飞来了！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "当空雁儿飞腾， 闻奴声影落画屏。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "启娘娘：来此百花亭！"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "正行时宫人来禀， 轻移来在百花厅。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "高、裴二卿，"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "娘娘。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "待圣驾前来，速便通报。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "公爷，这事瞒不过去，咱俩就禀了罢。 启娘娘：驾转西宫去了！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "驾转西宫去了！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "起过了！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "谢娘娘！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "呀，昨日圣上命我百花厅设宴。哎，怎么今日驾转西宫？哦，谅必是这贱人之 意！咳，由他去罢！吓，高、裴二卿看宴，待你娘娘自饮！"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "启娘娘：宫娥们敬酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "敬的什么酒？"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "龙凤酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "何为龙凤酒？"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "乃是圣上与娘娘所饮之酒，名曰龙凤酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "好，呈上来。"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "启娘娘：奴婢敬酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "敬的什么酒？"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "太平酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "何为太平酒？"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "满朝文武所做，名曰太平酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "好，呈上来。"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "启娘娘：奴婢敬酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "你敬的什么酒？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "通宵酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "唗！呀呀啐！哪个与你同什么宵！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "启娘娘：不要动怒，此酒也是满朝文武不分昼夜所造，故尔叫做通宵酒。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "好，呈上来。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "同宵捧金盅， 高裴二卿接手捧。 人生在世如春梦， 奴且开怀饮数盅。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "看娘娘酒性不足，只恐还饮酒，你我小心伺候。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "高、裴二卿，你娘娘酒性未足，看大觥伺候。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同窝下。〖柳腰金〗。裴力士、高力士同上。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "你我打扫打扫，摆试起来。有请娘娘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同上，杨玉环穿宫妆上，做身段。杨玉环下腰饮醉三斗醉。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "圣驾到，圣驾到！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杨玉环",
          "type": "二黄导板",
          "text": "听报道万岁驾到百花亭，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "娘娘酒性差不多了，你我来接驾。娘娘速去接驾。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "急急忙忙跪在地埃尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同跪。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "妾妃杨玉环接驾来迟，望万岁恕罪。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "启娘娘：奴婢诓驾。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢诓驾。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "呀呀啐！"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "自古道酒不醉人人自醉， 色不迷人人自迷。哎，人自迷。 裴力士在哪里？"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "娘娘有话对你说： 你若是称了我的心，合了我的意， 我便来，来，来，来朝一本奏当今，卿家吓，管叫你官上加官职！"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "奴婢不敢。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "裴力士",
          "type": "白",
          "text": "奴婢没有胆子。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "哎，"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "你若不称奴的心，不合奴的意， 我便来，来，来朝一本奏当今，唗，狗才吓，管叫你一命见阎君，哎，见阎君！ 高力士在哪里？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "娘娘有话对你说： 你若称了我的心，合了我的意， 我便来，来，来一本奏当今，卿家吓，管叫你官上加官职！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨玉环取高力士帽戏弄。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢没有这个……"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢想倒是想，可惜干不了！"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨玉环打高力士，高力士下。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "啐啐啐！"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "狗才吓！你若是不称我的心，不合我的意， 我便来，来，来朝一本奏当今， 唗，狗才吓， 管叫你革职为庶民，哎，为庶民！ 安禄山在哪里？ 想你当初进宫之时你娘娘怎生待你，何等爱你？ 至今日你忘恩负义， 玉美人倒在鞧韆驾上。"
        },
        {
          "character": "裴力士、高力士",
          "type": "同白",
          "text": "天色已晚，请娘娘回宫。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "摆驾！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "扶好了。"
        },
        {
          "character": "杨玉环",
          "type": "二黄平板",
          "text": "去也去也，回宫去也！ 唐明皇将奴骗，辜负好良宵。 骗得我欲上欢悦， 万岁，只落冷清清独自回宫去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}