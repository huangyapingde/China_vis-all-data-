{
  "script_id": "01018006",
  "title": "煤山恨",
  "alias": [
    "崇祯归天"
  ],
  "source": "《戏考》",
  "characters": [
    {
      "name": "崇祯",
      "hangdang": "老生"
    },
    {
      "name": "周后",
      "hangdang": "旦"
    },
    {
      "name": "王承恩",
      "hangdang": "末"
    }
  ],
  "plot": "李闯围困京城，襄城伯李国桢竭力守御，屡战屡败，奏请帝出奔以避锐。帝不从，忽报杜勋杜秩亨降贼，已\n献彰仪门。帝急极回宫，令周后自裁，手刃公主，使内监负太子逃难，将铁冠道人所进画图三轴拽开观看。\n第一、第二轴系官员民众，难散之状；第三轴有一小像，宛似御容，披发中悬，左足袜履完全，而右足则跣，\n知非吉兆。帝乃入太庙痛哭，拜别列祖列宗，追念各路诸将帅，尽节死难之事，一一历数之，而深为惋惜，\n大骂廷臣误国，以致不可收拾，并抚躬自责，斥为不肖子孙，遂往煤山（即北京紫禁城北上门外景山）缢\n焉。衣襟上有题字一行曰：听凭分裂朕尸，毋许伤朕百姓。帝真仁慈之主也，至于失国，实天数使然，呜呼\n伤哉！",
  "notes": "此即《排王赞》后本，二剧总名《铁冠图》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崇祯、王承恩同上。"
        },
        {
          "character": "崇祯",
          "type": "西皮流水板",
          "text": "朝王殿看罢了排王赞， 眼含龙泪走进宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太子、公主、周后同上。"
        },
        {
          "character": "周后",
          "type": "白",
          "text": "臣妾接驾。"
        },
        {
          "character": "崇祯",
          "type": "西皮流水板",
          "text": "叫声梓橦事不好， 闯贼不住把城攻。"
        },
        {
          "character": "周后",
          "type": "白",
          "text": "那王忠呢？"
        },
        {
          "character": "崇祯",
          "type": "西皮流水板",
          "text": "算来总是朕的错， 决不该用了贼王忠。 他通了闯贼将城献， 堪堪攻破彰仪门。"
        },
        {
          "character": "周后",
          "type": "西皮流水板",
          "text": "既然贼人将城临， 臣妾焉敢去逃生。 我今舍了娇生两个子， 顾不得金枝玉叶人。 低下头来忙跪倒， 二十四拜辞主公。 我抽身就往御园走，"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "梓橦，你要怎么样？"
        },
        {
          "character": "周后",
          "type": "西皮流水板",
          "text": "御果园内去丧生。"
        },
        {
          "character": "太子",
          "type": "白",
          "text": "皇娘，难道舍了孩儿不成？"
        },
        {
          "character": "周后",
          "type": "白",
          "text": "孩儿呀！"
        },
        {
          "character": "周后",
          "type": "西皮流水板",
          "text": "倘然闯贼将宫进， 你皇娘千载落丑名。 我宁可今朝舍一死，"
        },
        {
          "character": "周后",
          "type": "哭",
          "text": "孩儿呀！"
        },
        {
          "character": "周后",
          "type": "西皮流水板",
          "text": "可怜你兄妹两个人。 从此母子生拆散， 要相逢除非一梦中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周后下。崇祯哭。"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "眼看梓橦投井死，"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "咳，梓橦呀！"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "却把为王摘了心。 俺这里忙把侍臣叫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内监上。"
        },
        {
          "character": "内监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "你快把太子领出宫。 你领着逃出京城外， 改名换姓去逃生。 回头来看娇生女， 不由我满眼落泪痕。 你虽是生长昭阳院， 反不如民间作穷人。 为父的出于无可奈， 手向腰间拔青铜。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "咳，父王呀，难道杀了孩儿么？"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "为父的出于无可奈， 望着姣生下绝情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公主下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "万岁爷，不好了，贼把彰仪门打开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "启我主，贼把彰仪门打开，我主快快换衣服，溜出城门，再作商量。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "今大事已去，你叫朕往哪里逃走去。"
        },
        {
          "character": "崇祯",
          "type": "西皮摇板",
          "text": "满京城尽都是贼的人马， 却叫孤家哪里行？ 我宁可死在昭阳院， 不肯丧在贼手中。 王承恩前面引着路， 为王前到万寿亭。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "崇祯",
          "type": "西皮摇板",
          "text": "四面八方烟尘起， 火炮不住响连声。 忽想起铁冠道人留图画， 他说过事到紧急看分明。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "王承恩，把铁冠道人昔日进的画图取来。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "奴婢取来。 万岁，画图在此。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "展开呀。"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "为王一见痴呆了， 不由我顶上走真魂。 我看他蓬头跣足发盖面， 脖子排了一条绳。 这分明是王真形象， 他数年以来算得清。 罢罢罢，原来天数安排定， 为王焉能逆天行。 这就是无能臣子误了朕， 为王误了天下民。 我明家大数虽然尽， 可惜我多少保国臣。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "王承恩，你把以前边上报来，阵中亡身，骂贼殉难，这些死节的忠臣图挂起。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "奴婢晓得。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "王承恩。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "若是朝中大臣，亡身为国，得似这些武将，焉有今日！"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "为王一见痛伤情， 两眼不住落泪痕。 你今日为国将身丧， 万古千秋落好名。 可惜那湖广左良玉， 昌平州好一个李子修； 金所聪保定头撞破， 夜裸贼营孙传廷； 居庸关总兵好马岱， 陕西城又死了赵昔云； 吕青箭骂贼身遭铚， 宣府里杀了朱之文； 蔡茂德太原身缢死， 可怜那福州洪苏云； 有一个米脂县的边大寿， 雪夜里前去刨贼坟； 宁武关总兵周遇吉， 可怜他乱箭丧了身； 母子夫妻俱尽节， 一家团团用火焚； 襄城伯巡城受尽了苦， 赤胆忠心只有这王承恩。 有几个骂贼刀剁死， 有几个阵上丧了生； 有几个抱城遭贼死， 有几个连营分了身； 有几个一门儿女全忠孝， 有几个满城老幼送了生。 耳边厢不住人马喊， 霎时间震得天地昏。 回头来忙把承恩叫， 你且引朕向前行。 急速快把煤山上， 煤山以上看分明。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "贼子此地将人砍， 大炮连天把屋焚。"
        },
        {
          "character": "崇祯",
          "type": "白",
          "text": "咳，皇天呀！"
        },
        {
          "character": "崇祯",
          "type": "唱",
          "text": "我舍了祖宗创来的花世界， 我舍了十六帝的众皇陵； 我舍了三官六院嫔妃女， 我舍了忠君保国众能臣； 我舍了皇家太子并公主， 我舍了安分守己好良民。 我扯下了衮龙袍一片， 咬破了玉指血淋淋。 我写着闯贼休掳索， 你须要按字行行看分明： 失了天下朕的罪， 造罪原是朕一人。 你宁可问我儿子罪， 千万莫害众黎民。 我百姓连年遭兵火， 十七年寸草不收成。 撞见你等兴人马， 扰得他东奔西逃不安宁。 父子夫妻不相顾， 田产家园去个清。 你若是杀害众百姓， 天地鬼神也不容。 一幅血诏写完了， 可怜为王自伤情。 伸手解下了丝绦带， 煤山上缢死我崇祯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇祯下。王承恩下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}