{
  "script_id": "01003012",
  "title": "彩楼配",
  "alias": [],
  "source": "《戏考》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "正旦"
    },
    {
      "name": "薛平贵",
      "hangdang": "小生"
    },
    {
      "name": "游人甲",
      "hangdang": "老生"
    },
    {
      "name": "游人乙",
      "hangdang": "末"
    },
    {
      "name": "游人丙",
      "hangdang": "小生"
    },
    {
      "name": "游人丁",
      "hangdang": "丑"
    },
    {
      "name": "月老",
      "hangdang": "老旦"
    }
  ],
  "plot": "王允之女王宝钏，父母颇钟爱。定于二月二日高结彩楼，抛球招婿。先期，王宝钏夜梦斗大红星入怀。明日\n在花园见一花子，名薛平贵。卧处有红光罩身，心异其人，料其必贵。因唤至济给银米，并许以终身。告知\n彩楼抛球事，嘱其届时到来接球。及期，一般翩翩公子，走马王孙，无不前望接球。希望天赐美妻。不意果\n中一花郎薛平贵，众遂失望而散。",
  "notes": "后本即《三击掌》。按彩球招亲，昆剧《彩楼记》中，系吕蒙正故事，女为刘氏千金。招亲后为父逐出，同\n居破窑，日后夫婿发达显贵等情，与此大致相同，未知孰是。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引王宝钏同上。"
        },
        {
          "character": "王宝钏",
          "type": "引子",
          "text": "孝子是王祥，烈女是孟姜。"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "闺中幼女不知愁，梳妆打扮上高楼。忽见陌头杨柳色，悔教夫婿觅封侯。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "奴家王宝钏，爹爹王允，现居朝堂一品，位列三台。可叹膝下无儿，生我姊妹 三人。大姊金钏，许配苏龙；二姊银钏，配与魏虎。只有奴家尚未婚配，这且 不言。只因昨晚三更时分。偶得一梦，见一斗大红星，坠落卧房，将奴惊醒， 浑身是汗，不知主何吉兆？不免去到花园，焚香祷告。 丫鬟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟允。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "捧定香炉，带路花园。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "昨夜晚一梦甚跷奇， 斗大红星坠落在房里。 将奴惊醒汗满体， 不知凶来主何吉。 叫丫环带路花园里， 双膝跌跪在丹墀。"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "夜梦红星是跷奇， 不知凶来主何吉？ 因此清晨斋戒起， 到花园叩神祗。 叩罢头来抽身起，"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "且坐花园散心机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "肚中饥饿路难往， 身上寒冷实难挡。 将身来在大街上， 抬头只见大门墙。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "俺薛平贵，乃长安人氏，时运不佳，落在乞讨之中。来此已是王相府花园门首， 待我打睡片时便了。正是："
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "一心推开心头事，昏昏沉沉睡阳台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵睡。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "丫鬟，我闷坐花园，哪里玩耍才好？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "花园门外玩耍。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此带路。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "遵命。 小姐大事不好了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "外面有火。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待我看来。 丫鬟你远看，"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是火。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你近看，"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是一花郎。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "将那花郎唤醒，带进花园，奴有话问。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "遵命。 花郎醒来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵醒。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "原来丫鬟姐，唤我何事？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我家小姐有话问你。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有劳了，丫鬟姐带路。 难人参见小姐。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "罢了。 且住，看这花郎，两耳垂肩，双手过膝，后来必有大贵，为何落在乞讨之中？ 我自有道理。 你这花郎，家住哪里？姓甚名谁？一一讲来，要周济于你。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐容禀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "小姐在上容我禀， 细听难人说分明： 家住本国长安地， 父母早已命归西。 若问小生名和姓， 薛平贵就是我的名。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "听他言来自思忖， 看他不像受苦人： 两耳垂肩贵相品， 龙眉凤目帝王尊。 夜梦红星是有准， 想必应在花郎身。 彩楼之事对他论，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀，"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "又恐丫鬟一旁听。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "丫鬟请些银米过来，周济花郎，快去。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "那一花郎，我听你言父母双亡，家中可有……"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有什么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "可有妻室否？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐说哪里话来，落在乞讨之中，哪有银钱娶妻室呢？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "奴有一言，不好启齿。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐有何金言，当面赐教。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我父亲为我终身大事，二月二日，在十字街前，高搭彩楼，抛球招婿。你若前 去，倘若姻缘有分，亦未可知。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "里面都是王孙公子，哪有花郎之分？"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "二月二日事有准， 切莫错过这光阴。 倘若姻缘有福分， 便是蟠桃会上人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐，银米在此。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "付于花郎去罢。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多谢小姐。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "辞别小姐出园门，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "小姐有话快些言。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "你若不来失了信， 休做忘恩负义人。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "小姐不必细叮咛， 平贵岂是无义人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "奴家婚姻天注定， 二月二日定终身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四游人同上。"
        },
        {
          "character": "游人甲",
          "type": "念",
          "text": "春游芳草地，"
        },
        {
          "character": "游人乙",
          "type": "念",
          "text": "夏赏绿荷池。"
        },
        {
          "character": "游人丙",
          "type": "念",
          "text": "秋饮黄花酒，"
        },
        {
          "character": "游人丁",
          "type": "念",
          "text": "冬吟白雪诗。"
        },
        {
          "character": "四游人",
          "type": "同白",
          "text": "请了。今有王相府，高搭彩楼，抛球招婿。你我前去走走，请了请了。"
        },
        {
          "character": "游人甲",
          "type": "西皮摇板",
          "text": "二月二日龙抬头，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官上。"
        },
        {
          "character": "游人乙",
          "type": "西皮摇板",
          "text": "三姐打扮上彩楼。"
        },
        {
          "character": "游人丙",
          "type": "西皮摇板",
          "text": "但愿彩球到我手，"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "列位，"
        },
        {
          "character": "游人丁",
          "type": "西皮摇板",
          "text": "我与三姐轧姘头。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你们各位可是接彩的？请进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三游人同下。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你这老头儿做什么？"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "我也是接彩的。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你年纪大了，不能进去的。"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "我人老心不老。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "不能进去。"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "我与你商量商量：没有胡子，可能进去？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "等你没胡子，再作商量。"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "剃头的等着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "游人丁下。薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "急急忙忙往前行， 高打彩球闹盈盈。 迈步且把花园进，"
        },
        {
          "character": "门官",
          "type": "西皮摇板",
          "text": "胆大花郎哪里行？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我是来接彩的。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "里面俱是王孙公子，哪有花郎之份？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "他们接他们的，我也好接的。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "不许你进去。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "偏要进去。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "赶出去！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "薛平贵",
          "type": "哭板",
          "text": "听说门官不放进，"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "唬得我胆战心又惊。 大街上哭坏了俺薛平贵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "月老上。"
        },
        {
          "character": "月老",
          "type": "西皮摇板",
          "text": "这旁来了一仙翁。 上前遮住门官眼， 我今带你彩楼前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、月老同下。游人丁上。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你这老头儿又来了，这只手怎么不放下来？"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "放下来有点难为情。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "不要紧。"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "我就放下来。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你这胡子哪里去了？"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "剃头的没有，找了一个修脚的，一根一根的修去了。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "还是不能进去。"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "到底年纪大了。"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "我有个脾气，你让我不进去，我偏要进去；你叫我进去，我就不进去了。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "哦，我来试验试验。 老头子，我不让你进去——"
        },
        {
          "character": "游人丁",
          "type": "白",
          "text": "我偏要进去！"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "我让你进去吧——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "游人丁溜进，下。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "我上了他的当了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "四游人",
          "type": "内同白",
          "text": "远远三姐来也。"
        },
        {
          "character": "王宝钏",
          "type": "内西皮导板",
          "text": "梳妆打扮出绣房，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、四丫鬟同上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "在后堂辞别了二老爹娘。 老天爷若得随奴愿上， 彩球打着薛平郎。 叫丫鬟带路彩楼上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四游人同上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "手扶着栏杆——"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "看端详： 也有王孙公子样， 也有士农与经商。 楼下人儿纷纷嚷， 到叫奴含羞带愧脸无光。 举目抬头四下望，"
        },
        {
          "character": null,
