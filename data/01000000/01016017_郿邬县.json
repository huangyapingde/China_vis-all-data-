    }
  ],
  "plot": "宋巧姣痛未婚夫傅朋，遭不白之冤，适值太后驻法门寺，冒死叩阁。太后命刘瑾缉底查究。刘瑾即着郿邬县\n令赵廉，将案中各犯，限三日内解到，亲自审讯，案遂因之平反。杀刘彪、刘公道，念刘媒婆年老，从轻发\n落，仍交县令管束。傅朋复还指挥原职，以之定谳。宋巧姣、孙玉姣二女，太后即在寺中召见，传出懿旨，\n均赐于傅朋为妻，命刘瑾主婚，为之成婚礼。",
  "notes": "此剧即《法门寺》后本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "傅朋、宋巧姣同上。"
        },
        {
          "character": "傅朋",
          "type": "西皮快板",
          "text": "共同患难女豪杰， 监内许把鬼缘结。 秋风吹动竹帘挂， 金菊芙蓉一样花。"
        },
        {
          "character": "宋巧姣",
          "type": "西皮快板",
          "text": "宋氏巧姣才学大， 得意太尉动杀法。 奴有娥眉并书画， 水中明月镜中花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋、宋巧姣同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二衙役同上，刘媒婆、刘公道、赵廉同上。"
        },
        {
          "character": "刘媒婆",
          "type": "西皮流水板",
          "text": "畜牲胆比天还大， 为何起意将人杀。 绣鞋不用火焚化， 反道为娘做事差。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘彪上。"
        },
        {
          "character": "刘彪",
          "type": "西皮摇板",
          "text": "有刘彪站大街哈哈大笑， 尊一声老娘亲细听根苗： 此一去见千岁儿的人头不要， 二十年儿又是好汉一条，还要耍刀！"
        },
        {
          "character": "刘公道",
          "type": "西皮摇板",
          "text": "千差万查是吾差， 不该打死宋家娃。 先前事儿倒还小， 如今弄成这么大。 打板子，夹棍夹， 坐监牢，又戴枷。 割去头，碗大疤瘌， 纵然打死也不走他！"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "禀太爷：刘公道不走！"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "看板子打这奴才！"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "不曾带来。"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "重打一百马鞭。"
        },
        {
          "character": "刘公道",
          "type": "白",
          "text": "打死老子，也不走了！"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "打死他，也不走了！"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "罢，老爷的马，与他骑了罢。"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "老爷呢？"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "老爷步行就是了。 哎呀，奴才！"
        },
        {
          "character": "赵廉",
          "type": "西皮流水板",
          "text": "你当乡约常在衙，"
        },
        {
          "character": "刘公道",
          "type": "白",
          "text": "不差，常在衙门里。"
        },
        {
          "character": "赵廉",
          "type": "西皮流水板",
          "text": "难道不知这王法？"
        },
        {
          "character": "刘公道",
          "type": "白",
          "text": "知法儿，把法犯么！"
        },
        {
          "character": "赵廉",
          "type": "西皮流水板",
          "text": "打人下井如玩耍，"
        },
        {
          "character": "刘公道",
          "type": "白",
          "text": "吾是一时之错。"
        },
        {
          "character": "赵廉",
          "type": "西皮流水板",
          "text": "难免钢刀将你杀。"
        },
        {
          "character": "刘公道",
          "type": "白",
          "text": "后悔也是晚了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵廉、刘媒婆、刘彪同下。"
        },
        {
          "character": "刘公道",
          "type": "西皮流水板",
          "text": "刘公道在马上珠泪双抛， 也是吾前世里短把香烧。 吾不该隐人头不去呈报， 今日里犯王法性命难逃。 孙家庄孙寡妇无有家教， 生一女年二八名叫玉姣。 她不该在门前迎风卖俏， 小傅朋从此过玉镯失掉。 刘媒婆诓绣鞋嘴尖舌巧， 她不该将此事说与刘彪。 傅公子与刘彪大街争吵， 也是吾去解劝起下祸苗。 孙家庄杀二命无人知晓， 将人头丢吾家起祸不小。 也怨吾一时间思想不到， 因此才将人头井内去抛。 宋兴儿在一旁俱已知道， 可怕他孩子家嘴口不牢。 因此才下毒手将他害了， 可怜个小娃娃性命一条。 假作了一张状反将他告， 吾害他黑夜里盗物脱逃。 郿邬县糊涂官得状准了， 断给吾十两银人命案销。 宋国士有一女名唤巧姣， 法门寺告御状女中英豪。 千岁爷差校尉县令提到， 刘媒婆对千岁细说根苗。 郿邬县在一旁真魂吓掉， 那一边喜坏了宋氏巧姣。 千岁爷限三日人犯提到， 倘若是少一名项上加刀。 劝世人作经商俱要学好， 吾已经良心丧无有下梢。 回头来叫一声二位年高， 吾与你素日里茶酒相交。 你二人解绳索将吾放了， 到来生变犬马报你恩劳。 你二人不放吾胆儿真小，"
        },
        {
          "character": "二衙役",
          "type": "同白",
          "text": "怎么样？"
        },
        {
          "character": "刘公道",
          "type": "西皮流水板",
          "text": "我就肏你们两个姥姥！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘公道、二衙役同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伯父、傅朋、孙玉姣同上。"
        },
        {
          "character": "伯父",
          "type": "唱",
          "text": "一路行来常磕牙， 谁人不道是葛瓜。 已经不怕人唾骂， 哪里还顾人笑话。"
        },
        {
          "character": "傅朋",
          "type": "西皮快板",
          "text": "宋女年幼才学大， 洗起雀角动旧牙。 若得太尉开罪话， 孙氏女好比墙外花。"
        },
        {
          "character": "伯父",
          "type": "白",
          "text": "下马在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾桂上。"
        },
        {
          "character": "贾桂",
          "type": "念",
          "text": "天上神仙府，人间宰相家。若得真富贵，还是帝王家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "衙役甲上。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "郿邬县人役，与爷叩头。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "有何事情？"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "人马解到。特来投文。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "你们是宋巧姣，替夫辩冤的那一案么？"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "你们知县官，来了没有？"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "还在后边。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "你们哪里劳动的起咱家与你投文呢！"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "郿邬县人役，二次投文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾桂见银。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "这是怎么？"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "孝敬公公茶食。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "你倒是个聪明之人，待咱家与你投文进去。你们在白衣庵伺候，等知县到，即 传。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾桂下。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "我导你们到白衣庵去。"
        },
        {
          "character": "孙玉姣",
          "type": "念",
          "text": "此府甚森严，官员放堂家。"
        },
        {
          "character": "傅朋",
          "type": "念",
          "text": "既在矮檐下，怎敢不低头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋国士上。"
        },
        {
          "character": "宋国士",
          "type": "念",
          "text": "我儿丧溜沙，反当贼作拿。狠心刘公道，断送我根芽。"
        },
        {
          "character": "伯父",
          "type": "白",
          "text": "宋先生见礼了。"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "有礼。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "令婿与孙氏到了。"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "可是傅公子么？"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "今在何处？"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "岳父拜谒。"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "贤婿有礼。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "伯父万福。"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "大姐也来了。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "宋先生手执何物？"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "告你老爷状子！"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "我家老爷申详，已将刘公道定了凌迟之罪，将公道产业，归于宋先生管业。"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "你老爷，不该追我十两赃银。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "在下作保，赔补百两如何？"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "岳父，快头言之有理。且看刘公道不死，再告他不迟。"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "就依贤婿。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "将状子拿来吧！"
        },
        {
          "character": "宋国士",
          "type": "白",
          "text": "便宜了你家老爷！ 孙大姐到白衣庵，同小女在禅堂居住。我与贤婿在佛殿安身。"
        },
        {
          "character": "衙役甲",
          "type": "白",
          "text": "甚好。告辞。"
        },
        {
          "character": "衙役甲",
          "type": "念",
          "text": "公子本县已开话，"
        },
        {
          "character": "伯父",
          "type": "念",
          "text": "专等太尉坐早衙。"
        },
        {
          "character": "傅朋",
          "type": "念",
          "text": "男女且归佛殿下，"
        },
        {
          "character": "孙玉姣",
          "type": "念",
          "text": "免得旁人耻笑咱。"
        },
        {
          "character": "衙役甲",
          "type": "念",
          "text": "傅公子不说此言罢，久后你们是一家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "衙役甲下。傅朋、孙玉姣、宋国士、伯父同下。赵廉上。"
        },
        {
          "character": "赵廉",
          "type": "念",
          "text": "太尉朝中第一人，见他如同见圣君。身托重任押凶犯，口含谒舌申详文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾桂上。"
        },
        {
          "character": "贾桂",
          "type": "念",
          "text": "朝事家事似海深，日日夜夜费辛勤。一般都是阉割了，何为臣子何为君！"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "公公大人作揖。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "请了。咱家将你详文，奏与千岁，千岁喜你未违三日之限，将人犯都解到了。"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "解到了。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "少等，我去请驾。"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "仗庇公公大人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵廉下。贾桂下。四龙套、刘瑾、贾桂同上。"
        },
        {
          "character": "刘瑾",
          "type": "念",
          "text": "细阅郿邬县，此事真奇闻。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "郿邬县知县进见。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "郿邬县知县进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵廉上。"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "郿邬县知县赵廉，参见千岁。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "你那详文怎么办的？那事儿也做的明白。怎么无缘无故，把一员指挥官儿，收 在监中，你还有什么理辩？你说！"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "千岁息怒。千岁息怒。一宗无头人命，孙氏招出他来，叫臣不得不疑。"
        },
        {
          "character": "赵廉",
          "type": "西皮快板",
          "text": "孙氏把他赠玉镯， 因此将他来捕捉。 臣审口供有差错， 行权不敢乱发落。"
        },
        {
          "character": "刘瑾",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "本尉与你对玩，看吓的这个样子！这详文做得好。也罢！ 内侍，与赵知县捡个座。"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "千岁在此，哪有臣的坐处？"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "赐座当坐。"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "谢恩！"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "宣傅朋进见。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "傅朋进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋上。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "傅朋愿太尉千岁千千岁！"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "傅朋，你是衣冠中人物，何须赠玉镯，调戏民女？"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "臣是无心而遗，孙氏是有意拾去。"
        },
        {
          "character": "傅朋",
          "type": "西皮快板",
          "text": "凶徒夤夜动干戈， 竟从玉镯起风波。 遍体排牙说不过， 久待青天作定夺。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "你既是个指挥，何不上京，早早就职？"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "父制在身刚完满，又被官司累身，未能上京。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "你且下边伺候。"
        },
        {
          "character": "傅朋",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋下。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "传孙玉姣。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "呔！孙玉姣进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙玉姣上。"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "犯女孙玉姣，愿太尉千岁千千岁！"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "你用绣鞋去勾引傅朋，为何又告他，杀你娘舅娘母呢？"
        },
        {
          "character": "孙玉姣",
          "type": "白",
          "text": "犯女心中意中，惟有一个傅朋。问官用起刑来，因此无心说出他来。"
        },
        {
          "character": "孙玉姣",
          "type": "西皮快板",
          "text": "拾玉镯想起终身托， 夜夜灯下问卜课。 问官检验追问我， 因此权应一声诺。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "启千岁：太君老佛要见孙玉姣。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "这倒是个有福的孩子，引进后堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾桂引孙玉姣同下。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "唤刘彪进来。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "呔！带犯人刘彪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘彪上。"
        },
        {
          "character": "刘彪",
          "type": "白",
          "text": "犯人刘彪与千岁叩头。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "你立杀二命，你有个什么理辩别呢？"
        },
        {
          "character": "刘彪",
          "type": "白",
          "text": "小人原想捉奸，不料酒后闯祸。"
        },
        {
          "character": "刘彪",
          "type": "西皮摇板",
          "text": "独居夜夜睡不着，"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "撤！我把你这个王八羔子！睡不着就想杀人么？"
        },
        {
          "character": "刘彪",
          "type": "白",
          "text": "唉，千岁！"
        },
        {
          "character": "刘彪",
          "type": "西皮快板",
          "text": "一心要想结丝罗。 一男一女同床卧， 钢刀一举两个人头落。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "你倒也杀得干净。一刀就杀了两个。 赵廉，这该问他个什么罪呢？"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "但凭千岁。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "这就便宜他了。 武士，将刘彪推出斩首。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同杀刘彪。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "唤刘公道进来。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "呔！带犯人刘公道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘公道上。"
        },
        {
          "character": "刘公道",
          "type": "白",
          "text": "犯人刘公道，与千岁叩头。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "刘公道，你藏匿人头不报，又打死雇工下井。既当乡约，难道你就不知王法么？"
        },
        {
          "character": "刘公道",
          "type": "白",
          "text": "不想小人知法又犯了法了！"
        },
        {
          "character": "刘公道",
          "type": "西皮摇板",
          "text": "日听王法当乡约，"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "撤！老倭瓜的！你日听王法当乡约，就该把雇工打死井内反告他盗物逃走？难 道说还有理么？"
        },
        {
          "character": "刘公道",
          "type": "西皮快板",
          "text": "只为人头无下落。 打死兴儿免后祸， 天网恢恢跑也跑不脱。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "赵廉，这该问他个什么罪呢？"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "千岁，此人家有余业，臣将他的产业断与宋门，以赎诓告害命之罪，将他定了 凌迟。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "有了年纪，哪里搁得还住？ 武士推下去杀了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套推刘公道同下。四龙套同上。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "唤刘婆子进来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "犯人刘媒婆来见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘媒婆上。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "犯妇刘媒婆与千岁叩头！"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "你把孙氏绣鞋卖奸，大伤风化。你也有理？"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "千岁，始初实与做媒，希图花红。我儿搜出绣鞋，只说他用火烧化。岂料有此 大祸。"
        },
        {
          "character": "刘媒婆",
          "type": "西皮快板",
          "text": "希图花红当媒婆， 谁想儿子又作恶。 小事弄成天大祸， 从今再不当媒婆。"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "千岁，你把犯妇放回，从今以后，再也不敢当媒婆了！"
        },
        {
          "character": "刘媒婆",
          "type": "西皮快板",
          "text": "千岁你把我可怜， 剩我一个守家园。 从今不把闲事管， 学诵真经学参禅。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "赵廉！"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "刘婆子也不过希图花红，也没什么大罪，这该回本县发落才是。"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "尽在千岁发落。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "刘媒婆，你回本县发落，下去吧！"
        },
        {
          "character": "刘媒婆",
          "type": "白",
          "text": "谢过千岁！ 咳，可够了，我再也不敢拉皮条了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "衙役甲扯刘媒婆同下。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "宋巧姣，凶徒齐斩了，你丈夫亦有了官了。"
        },
        {
          "character": "宋巧姣",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "太君老佛，要见宋巧姣。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "引进后堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾桂、宋巧姣同下。贾桂上。"
        },
        {
          "character": "贾桂",
          "type": "白",
          "text": "启千岁：太君老佛，吩咐下来，孙、宋二女不分大小，俱配傅朋为妻。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "正合吾意。 赵廉，孙玉姣与傅朋为妻，与宋巧姣不分大小，这可也使得么？"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "千岁明鉴！"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "赵廉，你不该听信乡约刘公道之言，将宋巧姣寄在监中，反追她十两赃银，错 判此事。你该怎样发落呢？"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "唉，千岁！"
        },
        {
          "character": "赵廉",
          "type": "唱",
          "text": "告贼情盗物走臣才准下， 也不得不查访暗把贼拿。 刘公道生诡计鬼神不晓， 尊千岁在宝座仔细详查。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "也罢。依本尉将你罚了吧！"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "尽在千岁。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "罚你二千两银子，权当为孙、宋二女的妆奁，你可愿意？"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "臣愿意。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "赵廉，这桩事赔了本了，青州府缺开，你到那厢上任，捞捞本钱去吧！"
        },
        {
          "character": "赵廉",
          "type": "白",
          "text": "谢千岁天恩！ 咳呀，阿弥陀佛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵廉下。"
        },
        {
          "character": "刘瑾",
          "type": "白",
          "text": "内侍，取指挥官诰，金带一条，就此拜了花堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅朋、宋巧姣、孙玉姣同上，同拜，同下。"
        },
        {
          "character": "刘瑾",
          "type": "念",
          "text": "金带指挥职不薄，二位夫人不为多。一对织女牛郎会，专等鹊桥渡银河。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘瑾下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}