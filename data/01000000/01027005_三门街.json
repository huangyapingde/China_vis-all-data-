    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李广、张谷、桑黛、楚云、胡逵、广明同上。"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "豪杰威名天下震， 一同去看史锦屏。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "众位贤弟请了。"
        },
        {
          "character": "张谷、桑黛、楚云、胡逵、广明",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "今日史锦屏开擂之期，你我前去一观。"
        },
        {
          "character": "楚云",
          "type": "白",
          "text": "小弟此番到了擂台之上，定要将史家丫头打下擂来，叫她知道我楚云之厉害。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "贤弟，史锦屏虽是奸贼之女，为人却与她父大不相同。况且此次摆擂，又是奉 命而来。倘若贤弟打她不过，岂不是一世英名尽付流水？"
        },
        {
          "character": "楚云",
          "type": "白",
          "text": "大哥说哪里话来。小弟此番前来，原为的是打擂。吾兄为何再三拦阻？"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "那史锦屏乃一女流，贤弟就便将她打下擂来，也无有什么体面。倒不如不上台 为是。"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "大哥与楚贤弟也不必争论，等到了擂台看事行事便了。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "言之有理。就此前往。"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "大家一同往前进，"
        },
        {
          "character": "张谷、桑黛、楚云、胡逵、广明",
          "type": "同唱",
          "text": "去到擂台看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、八女兵、史锦屏同上。"
        },
        {
          "character": "史锦屏",
          "type": "唱",
          "text": "将身来在擂台上， 尊声众位听端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李广、张谷、桑黛、楚云、胡逵、广明同上，四游人同随上。"
        },
        {
          "character": "史锦屏",
          "type": "白",
          "text": "众位听者：奴家史锦屏，乃是当朝首相史洪基之女。奉了圣上旨意，在扬州摆 下百日擂台，要挑选天下的英雄，同保大明社稷。若有能人，请上台来，与奴 较量一二。"
        },
        {
          "character": "丑丫鬟",
          "type": "白",
          "text": "启禀小姐：天气尚早，打擂的还没有来呐。小姐请到后面歇息歇息罢。"
        },
        {
          "character": "史锦屏",
          "type": "白",
          "text": "若有打擂的到来，速速通报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史锦屏下。二打擂者同上。"
        },
        {
          "character": "打擂者甲",
          "type": "白",
          "text": "走吓！ 来此已是，待你上去先打一回。"
        },
        {
          "character": "打擂者乙",
          "type": "白",
          "text": "你先上去。如打不过她，我且上去。"
        },
        {
          "character": "打擂者甲",
          "type": "白",
          "text": "待吾先上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "打擂者甲飞脚上，与丑丫鬟打。丑丫鬟打打擂者甲下。打擂者乙上台，打。丑丫鬟打打擂者下。"
        },
        {
          "character": "广明",
          "type": "白",
          "text": "看这个丑丫头，十分猖獗。待洒家收拾他。 中国京剧戏考 《三门街》【九、十本】 9"
        },
        {
          "character": null,
          "type": "stage",
          "text": "广明上台，打丑丫鬟倒。"
        },
        {
          "character": "丑丫鬟",
          "type": "白",
          "text": "有请小姐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史锦屏上，起打。史锦屏打广明下。胡逵上台，起打。史锦屏打胡逵下。桑黛上台，打对手，扯打。"
        },
        {
          "character": "四游人",
          "type": "同白",
          "text": "天气不好，雨来了！"
        },
        {
          "character": "李广、张谷、楚云、胡逵、广明",
          "type": "同白",
          "text": "雨来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史锦屏托桑黛拳。"
        },
        {
          "character": "史锦屏",
          "type": "白",
          "text": "天降大雨，我等明日再来比试如何？"
        },
        {
          "character": "桑黛",
          "type": "白",
          "text": "明日再与你见个高下。"
        },
        {
          "character": "史锦屏",
          "type": "白",
          "text": "来者？"
        },
        {
          "character": "桑黛",
          "type": "白",
          "text": "君子。"
        },
        {
          "character": "史锦屏",
          "type": "白",
          "text": "不来？"
        },
        {
          "character": "桑黛",
          "type": "白",
          "text": "不来是小人。请了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}