        {
          "character": null,
          "type": "stage",
          "text": "钱塘知县下。"
        },
        {
          "character": "捕役甲",
          "type": "白",
          "text": "伙计，县太爷叫咱们去拿牛洪。那牛洪是什么样的人我们也没有见过，这个人 叫我们到哪里去拿？"
        },
        {
          "character": "捕役乙",
          "type": "白",
