  "plot": "九、十本开幕，“范安、范保，中途逢侠客”、“张谷二次用乾坤袋，土牢内救出范丞相”、“吕纯阳仙师，\n命徐文亮下山打擂”、“钦差到任，杭州府、钱塘县出境迎接”、“传齐人证，范丞相亲审命案”、“赌\n输情急，典押铜钗”、“当铺门前，两捕役擒获巨憨”、“牛洪认供，徐文炳出狱”、“众英雄扬州大聚会”\n、“奉旨摆擂台，史锦屏耀武”。串演至此，即为终场。",
  "notes": "按是剧自沪上大舞台开始，逐渐风行一时。观剧一方面非常欢迎，每逢串演，卖座为之一空。所以有如此魔\n力者，生旦丑末，无不备具。且文武各尽其能，兼之布景新鲜，电光石火，掩映于眼帘中，如游华阴道上，\n有不暇转瞬之胜概，不禁矍然欢曰：观止矣。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张谷上。"
        },
        {
          "character": "张谷",
          "type": "西皮摇板",
          "text": "招英馆奉了大哥命， 去到杭州走一程。"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "俺，张谷，绰号半枝梅。奉了大哥之命，去到杭州送信。来此已是镇江地面， 不免就此前往。"
        },
        {
          "character": "张谷",
          "type": "西皮摇板",
          "text": "迈开大步往前进，"
        },
        {
          "character": "范安、范保",
          "type": "内同白",
          "text": "走吓！"
        },
        {
          "character": "张谷",
          "type": "西皮摇板",
          "text": "二人慌张为何情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范安、范保同上。张谷推范保倒。"
        },
        {
          "character": "张谷",
          "type": "stage",
          "text": "中国京剧戏考 《三门街》【九、十本】 2"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "嘿！你怎么走路不张眼睛？往人身上碰吓！"
        },
        {
          "character": "范安",
          "type": "白",
          "text": "我二人有心事在怀。壮士休要见怪。"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "你有什么心事？对我说说，我听听，与你分忧解愁。"
        },
        {
          "character": "范安",
          "type": "白",
          "text": "壮士有所不知：我名范安，他叫范保，乃是范其鸾范丞相的家将。只因我家相 爷，来到镇江，下船私访那刘彪。不料被那贼看破，将我家相爷暴打了一顿， 打在土牢。因此我二人跑回，要到城中报官，好搭救我相爷的性命。"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "嗳呀慢着。想这范老丞相此番出京，本是为查办徐二哥的冤狱而来。今日若被 这刘彪害死不至紧要，我徐二哥的冤枉，怎生昭雪？我不免前去搭救与他便了。 我说二位不必着急，你二人就在前面小庙里头等候。待我去救你家相爷，你看 如何？"
        },
        {
          "character": "范安",
          "type": "白",
          "text": "嗳呀壮士吓！那贼府中人多势重，你一人前去恐难成功。"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "我自有道理，你休得多言。我去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火彩。张谷下。"
        },
        {
          "character": "范安",
          "type": "白",
          "text": "看此人一转眼就不见了，想是仙家到此。我二人且到庙中等候他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范安、范保同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "史锦屏上。"
        },
        {
          "character": "史锦屏",
          "type": "引子",
          "text": "独坐绣房，习兵法，武艺无双。"
        },
        {
          "character": "史锦屏",
          "type": "念",
          "text": "性情激烈貌娆娇，不习针黹爱枪刀。打遍天下英雄汉，方显巾帼女英豪。"
        },
        {
          "character": "史锦屏",
          "type": "白",
          "text": "奴家史锦屏。爹爹史洪基，官居首相。奉了圣上旨意，命奴在这扬州城内，摆 下百日擂台，要打遍天下的英雄。百日擂满之后，上朝复命交旨。且喜擂台造 齐，不免唤出众丫鬟，一同前去。 众丫鬟走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八丫鬟同上。"
        },
        {
          "character": "八丫鬟",
          "type": "同念",
          "text": "不学闺房刺绣，每日习练刀兵。"
        },
        {
          "character": "八丫鬟",
          "type": "白",
          "text": "参见小姐。"
        },
        {
          "character": "史锦屏",
          "type": "白",
          "text": "今日擂台造齐，随我一同前往。"
        },
        {
          "character": "八丫鬟",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "史锦屏",
          "type": "西皮摇板",
          "text": "老爹爹在朝中官居一品， 奉圣命摆擂台要赌输赢。 奴虽是闺房女武艺精通， 论拳棒讲兵法件件都能。 纵有那大英雄本领出众， 奴一人也定要把他来擒。 众丫鬟忙带路一同前进， 同到那擂台上细看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史锦屏、八丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐文亮上。"
        },
        {
          "character": "徐文亮",
          "type": "白",
          "text": "俺，徐文亮。只因那日，同兄长转回杭州，路过丹阳，一时失足，落在江中。 多亏吕纯阳将我救去，带到蓬莱岛，教我全身武艺。言道我与史锦屏有姻缘之 分，命我前去扬州打擂，沿途访友。不免就此前往。"
        },
        {
          "character": "徐文亮",
          "type": "西皮摇板",
          "text": "只因失足落长江， 幸遇仙师吕纯阳。 传授武艺无人挡， 奉命打擂转回乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐文亮下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《三门街》【九、十本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范安、范保同上。"
        },
        {
          "character": "范安、范保",
          "type": "同白",
          "text": "我二人在此等了多时，怎么还不见那人回来？莫非也被那贼擒住不成？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张谷自桌上翻跟头下。"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "你二人在此讲些什么？"
        },
        {
          "character": "范安",
          "type": "白",
          "text": "我二人不曾讲什么。请问壮士，吾家相爷怎么样了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张谷取袋。放火彩。范其鸾上。"
        },
        {
          "character": "范安、范保",
          "type": "同白",
          "text": "嗳呀相爷吓！"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "吾是怎生到此？"
        },
        {
          "character": "范安、范保",
          "type": "同白",
          "text": "只因这位壮士，闻听相爷被刘贼加害，壮士就前去打救相爷，叫我二人在此等 候。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "原来如此。 请问壮士高名上姓？"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "在下张谷，绰号半枝梅。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "莫非你是神仙下界？怎么竟将老朽救出？"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "吾受仙人传授，有此乾坤宝袋。无论有多少人，俱能装入袋内。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "请问恩人仙乡何处？老朽改日要登门叩谢。"
        },
        {
          "character": "张谷",
          "type": "白",
          "text": "在下与小孟尝李广皆是结拜的兄弟。吾要到杭州与他家中送信。吾去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火彩。张谷下。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "此人如同神仙一般，想是剑侠一流人物。 范安、范保速速回船去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范其鸾、范安、范保同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杭州知府、钱塘知县同上。"
        },
        {
          "character": "杭州知府",
          "type": "白",
          "text": "朝中派了范老丞相来在钱塘审讯案件，不免前去迎接。钱塘县！"
        },
        {
          "character": "钱塘知县",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杭州知府",
          "type": "白",
          "text": "一同迎接。"
        },
        {
          "character": "钱塘知县",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杭州知府、钱塘知县同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四校尉、四刽子手、中军、范安、范保、范其鸾同上。杭州知府、钱塘知县同迎上。"
        },
        {
          "character": "杭州知府、钱塘知县",
          "type": "同白",
          "text": "（杭州府）（钱塘县）迎接老相爷。"
        },
        {
          "character": "范安、范保",
          "type": "同白",
          "text": "察院伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四校尉、四刽子手、中军、范安、范保、范其鸾同入城，同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四校尉、四刽子手、中军、范安、范保、范其鸾同上。范其鸾升堂。"
        },
        {
          "character": "杭州知府、钱塘知县",
          "type": "同白",
          "text": "（杭州府）（钱塘县）参见相爷。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "起，免，打恭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同喊。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "老夫奉命而来，特为审问徐文炳一案。速将原、被人犯一齐提到。"
        },
        {
          "character": "杭州知府",
          "type": "白",
          "text": "遵命。 带徐文炳！ 中国京剧戏考 《三门街》【九、十本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "禁卒押徐文炳同上。"
        },
        {
          "character": "徐文炳",
          "type": "白",
          "text": "叩见老相爷。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "你既在学的生员，为何逼杀梅氏？要从实招来！"
        },
        {
          "character": "徐文炳",
          "type": "白",
          "text": "生员自幼读书，焉敢持刀杀人？望大人明察呀！"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "你既不曾杀人，为何自行招出？今日尚敢翻案么！"
        },
        {
          "character": "徐文炳",
          "type": "白",
          "text": "嗳呀大人吓！生员那日为母有病，去至街坊兑换参苓，路过黄氏家门。正逢梅 氏倾倒面水，将生员衣衫泼湿。梅氏过意不去，将生员请到她家中，代生员烘 烤衣衫。当时与梅氏也不过说了三两句闲言，衣衫烘好，生员即同梅氏作别归 家。次日即经本县将生员拿到，严刑审讯，说生员因奸杀死梅氏。生员再三申 诉，只是县官不容，屈打承招。望求大人开恩拯救吓！"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "既然如此，这摺扇是从哪里而来？"
        },
        {
          "character": "徐文炳",
          "type": "白",
          "text": "这扇子是生员当日遗失在梅氏的案上。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "看此人乃是少年书生，懦弱无力，焉能持刀杀人？ 来，将徐文炳带下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "禁卒押徐文炳同下。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "带黄贵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄贵上。"
        },
        {
          "character": "黄贵",
          "type": "白",
          "text": "叩见大人。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "你妻子究竟被何人所杀，要从实招来。"
        },
        {
          "character": "黄贵",
          "type": "白",
          "text": "小人妻子实系徐文炳因奸所杀。现有扇子为凭。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "住口！你那日既不在家中，定是有意卖奸。此事定是卖奸不遂，你嫁祸于人。 看来就该掌嘴！"
        },
        {
          "character": "黄贵",
          "type": "白",
          "text": "启禀大人：那日小人因有事出外，次日清晨回来叫门不开，因此踢开了门，见 妻子被人杀死。扇子一把，系徐文炳之物，因此到县鸣冤。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "吓贵县，此事你就也太大意了。想那徐文炳乃一年少懦弱书生，纵然与梅氏有 奸，将她杀死，他怎能不走大门，难道他还能飞墙越壁不成？"
        },
        {
          "character": "钱塘知县",
          "type": "白",
          "text": "此事是卑职糊涂。望相爷宽恕。"
        },
        {
          "character": "范其鸾",
          "type": "白",
          "text": "人命重案，讲什么宽恕？还不退了下去！"
        },
        {
          "character": "钱塘知县",
          "type": "白",
          "text": "咳，完了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钱塘知县下。"
        },
        {
          "character": "范其鸾",
          "type": "白",
