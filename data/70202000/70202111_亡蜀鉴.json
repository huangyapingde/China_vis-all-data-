{
  "script_id": "70202111",
  "title": "亡蜀鉴",
  "alias": [
    "江油关"
  ],
  "source": "程砚秋剧本选",
  "characters": [
    {
      "name": "李夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "三国末年，魏将邓艾袭蜀，偷渡阴平，直取江油。江油守将马邈，见兵败国危，意欲投降。其妻李氏晓以大\n义，苦口相劝，马邈佯为允诺，暗地开门降魏，李氏愤而自刎。",
  "notes": "这个剧本，是程砚秋同志在1933年根据川剧改编的。当时日本帝国主义者，正在逐步向华北进行侵略，\n国民党反动政府采取不抵抗主义，准备投降。砚秋同志乃在北京演出此剧，以抒公愤；演出不过两场，即被\n迫停演。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵、四将引邓艾上。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "本帅邓艾，奉魏主旨意，晋王千岁将领，夺取西川，且喜将士忠勇，渡过阴平。 军士们，你等看此处有一空寨，想是刘禅撤了防守，真乃庸才也。只是在过前 面，就是江油，兵精粮足，我等孤军深入、无有接济，前进可活，后退即死， 还要奋勇当先，夺取江油，才是生路。"
        },
        {
          "character": "四将、四魏兵",
          "type": "同白",
          "text": "我等自然奋勇当先。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "如此听我一令：尔等饱餐战饭，安歇一宵，明日五鼓杀奔江油去者！"
        },
        {
          "character": "四将、四魏兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "俺江油关探子是也。探得魏国大将邓艾带领数千精兵，凿山开路，攀崖滚壁， 偷渡阴平，好似从天下降，不分昼夜，杀奔江油而来。不免报与太守知道便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、二家将同上，马邈挂剑上。"
        },
        {
          "character": "马邈",
          "type": "引子",
          "text": "镇守江油，心内忧愁。"
        },
        {
          "character": "马邈",
          "type": "念",
          "text": "此是存亡危机秋，偏安王业恐难留。国家大事何须问，只有浮沉寡怨尤。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "下官马邈，汉室为臣，奉命镇守江油。连日接得边报：魏兵入寇，姜维兵败于 剑阁，蒋舒献了阳平关，傅佥战死沙场，看来我这江油也就险得很了！幸有阴 平险要，魏兵定难飞渡也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上，跪。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启太守：邓艾偷渡阴平，快要杀奔江油来了！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "哎呀且住！探马报道：邓艾偷渡阴平，杀奔江油而来，眼看大事去矣！咳！我 想兴是兴他刘家的江山，灭是灭他刘家的社稷；这国家兴败，与我何干？魏兵 不来便罢，来则降之，这叫做“在王驾下愿王兴，王不兴来我变心”。我的降 意已决，不免请出夫人商议商议。 家将，请夫人出堂。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "有请夫人出堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人上，丫鬟、仆妇抱儿随上。"
        },
        {
          "character": "李夫人",
          "type": "引子",
          "text": "恨作女儿身，空负了，义气凌云。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "将军。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "夫人请坐。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "有座。将军唤妾身何事？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "今日天气寒冷，要与夫人围炉饮酒。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "今乃操演之期，将军理应先到校场；待阅操已毕，你我夜饮不迟。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "寒天大雪，我已免操了。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "国家多事之秋，为何轻易免操？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "因有一事比操演更为紧要，故此免操。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "不知你们做武将的，更有何事比操演还要着急？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "这个……耳目甚众。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "这也奇了！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "家将将酒摆下，你们退去。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马邈解剑放桌上。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "夫人教丫鬟仆妇回避。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "你们抱了小公子外面玩耍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、仆妇同允，四蜀兵、二家将同下，丫鬟、仆妇同下。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "将军有何要事？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "请夫人先饮三杯再讲。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "妾身性急，请将军讲了再饮。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "下官性慢，请夫人饮了再讲。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "怪道哇，怪道！"
        },
        {
          "character": "李夫人",
          "type": "西皮摇板",
          "text": "闻言如在雾中走， 因何露尾又藏头！ 没奈何只得先饮酒， 饮过三巡你说根由。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "将军，妾身已经饮过三杯，将军请道其详。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "夫人有所不知，我连日接得边报：魏兵入寇，姜维兵败于剑阁，魏兵夺了阳平 关。适才探马报道：邓艾偷渡阴平，来取江油，只恐我国大势去矣！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "不知江油有多少人马？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "五千人马。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "粮草如何？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "粮草可支一年。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "却又来！既有五千人马，粮草又可支持一年，怕那魏兵作甚？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马邈背供。"
        },
        {
          "character": "马邈",
          "type": "京白",
          "text": "这个娘们真糊涂，把我的死活全都不管啦！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "啊夫人，你可知道镇守阳平关的蒋舒、傅佥？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "蒋舒、傅佥便怎么样？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "蒋舒知天命，降了魏邦，不失将军之位；傅佥不降，教魏兵给杀啦！谁给他偿 命啊！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "好，这叫做："
        },
        {
          "character": "李夫人",
          "type": "念",
          "text": "一日舒忠愤，千秋仰义名。宁为傅佥死，不作蒋舒生！"
        },
        {
          "character": "李夫人",
          "type": "西皮快板",
          "text": "钟会领兵来入寇， 傅佥在阳平御强仇。 只杀得魏兵卸甲走， 蒋舒归降作马牛。 傅佥与贼决死斗， 血染袍，马倒地，自刎而休！ 为国捐躯大义就， 可算人间第一流。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "得啦，你不用说啦！傅佥是白死啦，一点益处也没有，我才不那么傻哪！我总 得想个主意。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "着啊！"
        },
        {
          "character": "李夫人",
          "type": "西皮流水板",
          "text": "邓艾孤军难奋斗， 无粮缺草怎淹留？ 将军不战理应守， 以逸待劳逞奇谋。 坚壁清野制穷寇， 管教邓艾指日休。 你若是能把亡国救， 比那傅佥又胜一筹。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "啊夫人，想傅佥当年大战长城岭，活捉王真，锏打李鹏，杀得司马昭丧胆亡魂。 如今也教魏兵杀死！想我本领平常，怎能挡得他过？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "步入坚守城池。他孤军深入，料难久持。待等数日，他军不战自乱矣。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "慢来，我想邓艾既已渡过阴平，这小小的江油关，如何能保守得住？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哦，将军，魏兵到来，就该出战；既不出战，就该守城；如今你不战不守，意 欲何为？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "一个字。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哪一个字？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "降！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "怎么，你要降魏么？哎呀将军哪！想蜀中立国并非容易；你若归降，恐怕这四 百年的汉室，从此灭亡了！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "嗳！想天下非一人之天下，乃有德者居之！主上昏庸，不理国事。我看这国家 换换主人，也就不错！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哎呀，这岂是将军所说之话？好好的国家，岂可教他灭亡！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "你说咱们这一国不该亡么，我说他有两样该亡。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哪两样该亡？这第一？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "第一，姜维九伐中原，忠心耿耿；主上却听信黄皓谗言，不加重用；他只落得 屯田避祸。这样对待忠臣，你说该亡不该亡？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "第二呢？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "第二，黄皓专权，见钱就要；上上下下贿赂公行，主上反而非常的信任，你说 该亡不该亡？我们这西蜀要是不亡，倒是没有天理了！我今天是降定啦！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "将军哪！想当年先帝败走当阳，荆州百姓冒死相从者十余万人！比那曹操父子 欺君扰民，世代为奸，屠杀忠良，真乃一仁一暴。你若弃明投暗，枉落个千载 的骂名！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将甲上。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "启老爷：魏兵直奔江油而来！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "知道了，再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将甲下。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哎呀将军，想那魏兵远道而来，孤军深入，我们若不与他交锋，那魏兵粮草不 继，定然不战自乱；那时正是将军建功立业之日了。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马邈想。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "夫人好言相劝，下官如梦方醒，待我传齐众将，商议战守之策便了！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "我升堂去了。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "快去，快去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马邈下。李夫人凝想，猛悟。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哎呀且住！想夫君素多心计，今日升堂，不知是议战守之策，还是要去投降？ 我不免到屏风后面听个明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人走圆场。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "来此已是，待我侧耳细听。"
        },
        {
          "character": "马邈",
          "type": "内白",
          "text": "升堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。马邈上，四蜀兵同上。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "众位将军，魏兵到此，你等愿意抵挡，还是愿意归降？"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "但凭将军！"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "魏兵十分厉害，依我之见，不如归降魏国。"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "这个……"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "有不降者，军法从事！"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "就依将军。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "真乃识时俊杰，带马出城！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马邈下，四蜀兵同下。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "李夫人",
          "type": "西皮散板",
          "text": "果然他是卖国手， 眼见江油一旦休！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哎呀且住，方才我苦口相劝，要那马邈为国宣劳；谁知他口是心非，甘心卖国， 竟自带了满城文武降顺仇敌去了！天哪天！这等之人，岂可与他生同食，死 同穴？他甘为亡国之人，我不愿作降人之妇；我不免就此碰死了罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人欲碰。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哎，且慢！想我生有一子，将将周岁，还要我自己哺乳；我不免去到后堂将姣 儿安顿一番，再行自尽便了！"
        },
        {
          "character": "李夫人",
          "type": "西皮散板",
          "text": "嫁夫如此伤非偶， 又把姣儿虎口投。 花未发芽根已朽， 恩情从此一笔勾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵、邓艾同上。"
        },
        {
          "character": "邓艾",
          "type": "西皮摇板",
          "text": "旌旗浩荡笼星斗，"
        },
        {
          "character": "邓艾",
          "type": "西皮流水板",
          "text": "人马纷纷奔江油。 三军戮力往前走， 管取此城一旦休。"
        },
        {
          "character": "魏兵",
          "type": "同白",
          "text": "探子求见。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "队伍列开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上，跪。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启都督：今有江油太守马邈，带领大队人马杀出城来。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "众将官迎敌去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵同反抄，四蜀兵同反上，对阵，马邈上，跪。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "啊！你是何人？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "小官伪江油太守马邈，情愿弃暗投明，出城归顺。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "既愿归顺，为何带领人马出城，莫非诈降？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "本待都督兵临城下，开城迎接，奈因城中百姓思念那死鬼刘备、诸葛亮的假仁 假义；纵然都督进城，还恐有人抵挡。依小官之见，都督在城外放火焚烧民房， 城内百姓害怕，自然不敢胡为。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "呸！你真乃匹夫之辈！本帅吊民伐罪，岂肯焚烧民房？自古用兵之人，若是残 民以逞，必受天下笑骂，纵然城中有变，本帅自有机谋。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "请都督随我进城。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "江油城中多少人马？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "五千人马。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "粮草如何？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "粮草可支一年。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "既然有兵有粮，如何不战而降？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "小官颇知顺逆，岂敢扭天行事！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "本帅听你之言，想起一辈古人来了。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "不知哪辈古人？"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "本帅想起断头将军严颜来了。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "那严老将军，到底不曾断头，依然做了个降将军；依小官看来，他也是识时务 的呀！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "哼！你国人多半如此，这也难怪于他！今日本帅进城，要在你府上歇马。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "小官有家眷，恐其不便。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "住了，你既已做了亡国之人，还顾得什么家眷？且随本帅进城，不许回到私宅； 等待本帅安民已毕，带你同到后堂，抄查你的家财，犒赏军士。起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马邈起，背供。"
        },
        {
          "character": "马邈",
          "type": "京白",
          "text": "哎呦！连损带挖苦，外带罚跪，还要抄家，这个滋味，敢情也不大舒坦。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "来！将他的兵马器械一齐收了。众将官，起兵进城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "李夫人",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人上。"
        },
        {
          "character": "李夫人",
          "type": "二黄摇板",
          "text": "国破家亡何处走？ 苍天生我是女流！ 夫君怕死迎强寇， 乱中无计洗奇羞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "夫人可了不得啦！城里头塌天动地，一会儿就要换魏国的旗号啦！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哦！有什么塌天动地之事，你这样大惊小怪？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "魏兵杀进城来啦！老爷去投降人家，夫人还不知道吗？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "我知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仆妇抱儿暗上。"
        },
        {
          "character": "仆妇",
          "type": "白",
          "text": "啊夫人，想蜀中自开国以来，待我们百姓倒还宽厚！如今江油失守，只恐蜀国 休矣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人叹。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "仆妇",
          "type": "白",
          "text": "但不知老爷是真降，还是诈降？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "他真心降顺，不是诈降。"
        },
        {
          "character": "仆妇",
          "type": "白",
          "text": "怎么讲？那马邈当真降魏了！李氏啊李氏，那马邈降魏便是国贼，你便是国贼 之妻，我老人家是蜀国百姓，不是魏国黎民；我如今不伺候你了！来来来，这 是你们的逆种，抱过去，抱过去！我走了，气死我也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仆妇递儿，下。李夫人呆，哭。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "李氏，你瞧你们家干的事，连这个老梆子都不服啦！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "啊！你、你为何这样讲话？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "为什么跟你这样讲话？告诉你说：这个江油城从今不属你们管啦！我跟着你们， 你们也养活不起我！干脆，我另找新主儿去啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "唉！这才是贤愚不等啊。"
        },
        {
          "character": "李夫人",
          "type": "二黄散板",
          "text": "那一个咬牙切齿骂贼寇， 这一个低头甘心去事仇。 两人辱骂难忍受，"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "李夫人",
          "type": "二黄散板",
          "text": "不如一死殉江油。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "儿啼。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "我方才要哺乳姣儿，一时忿怒竟尔忘怀！不免将儿哺乳一番，这正是："
        },
        {
          "character": "李夫人",
          "type": "念",
          "text": "怀抱姣儿血泪流，恩情从此一旦休。一家不料成吴越，"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "马太守哇！马将军！"
        },
        {
          "character": "李夫人",
          "type": "念",
          "text": "我替你无面对江油！"
        },
        {
          "character": "李夫人",
          "type": "二黄导板",
          "text": "李氏女哺姣儿顷刻分手！"
        },
        {
          "character": "李夫人",
          "type": "哭头",
          "text": "我儿，姣生，哎呀儿呀！"
        },
        {
          "character": "李夫人",
          "type": "回龙",
          "text": "儿年幼怎知娘万苦千愁。"
        },
        {
          "character": "李夫人",
          "type": "二黄慢板",
          "text": "那魏国强欺弱兴兵入寇， 我蜀邦文贪武斗政事不修。 贼兵到不投降便要逃走， 眼见得好山河付与东流。 但愿得儿长大洁身自守， 洒热血报国耻一洗父羞。 也不负娘今日江油刎首，"
        },
        {
          "character": "李夫人",
          "type": "哭",
          "text": "哎呀！我儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人放儿，欲自刎，儿啼，李夫人抱儿坐。"
        },
        {
          "character": "李夫人",
          "type": "哭",
          "text": "哎呀儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人晕，儿摔地，李夫人惊醒。"
        },
        {
          "character": "李夫人",
          "type": "二黄散板",
          "text": "啊啊啊！可怜儿好命苦摔闭咽喉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人看儿，冷笑。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "啊，你死得好！"
        },
        {
          "character": "李夫人",
          "type": "二黄散板",
          "text": "儿死去倒免作亡国之囚。 到此时一身轻无可留守， 愿国人齐努力共保神州。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人自刎。四魏兵、马邈、邓艾同上。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "这妇人为何自尽？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "待小官看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马邈看。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "启元帅：这是小官之妻李氏，不愿归降，他母子一齐丧命了。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "真乃义烈妇人！尸首搭了下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵抬李夫人同下。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "元帅，小官只为归顺贵国，妻子皆亡，可算为国忘家的忠臣了。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "你愿作忠臣？"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "我本是大大忠臣。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "叫你做个忠臣。 左右，推去斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵同绑马邈。"
        },
        {
          "character": "马邈",
          "type": "白",
          "text": "天哪！想我马邈哇！"
        },
        {
          "character": "马邈",
          "type": "二黄散板",
          "text": "只望富贵能长久， 甘心卖国献江油。 迎新弃旧夸能手， 事到头来不自由！ 这样死后还丢丑， 也是我卖国求荣的下场头！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵推马邈同下。四魏兵同上，报斩。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "李夫人尸首好生埋葬，本帅亲自祭奠！歇兵三日，攻取绵竹。"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾、四魏兵同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}