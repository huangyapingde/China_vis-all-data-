        {
          "character": "中军",
          "type": "白",
          "text": "呔！做什么的？"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "烦劳将军通禀：我是吴国伯嚭，前来求和来了！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着！ 有请元帅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡上。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "伯嚭辕门求和。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "叫他报门而进！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "伯嚭！元帅叫你报门而进！你要仔细了，你要与我打点了！报门！"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "报！伯嚭告进！ 伯嚭与元帅叩头！"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "下跪可是老太宰？"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "什么老太宰？我是有罪的伯嚭在这里。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "你做什么来了？"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "奉了我家大王之命，前来求和来了。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "叫你主前来，本帅有话问他。快去！"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "喔！是是是！ 哎！求和的事儿有边儿呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夫差上。"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "范元帅唤你。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "待我进去。 范元帅请了！"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "大王到此，本帅未能远迎，多有得罪呀！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "范大夫，孤家放你主回国，就该感激孤王大恩才是。不该带领人马，攻我都城， 是何理也？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "本帅奉命前来伐吴，说大王有六行大罪，大王可知否？"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "孤有哪六行大罪？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "你且听道！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "伍员曾立大功，大王杀之，大罪一也！公孙圣无罪被你斩首，大罪二也！信任 奸贼伯嚭，大罪三也！北伐齐晋，生灵涂炭，大罪四也！越国乃是邻邦，并吞 疆土，大罪五也！越国与吴国先王久有仇恨，反将越王释放回国，大罪六也！ 大王有此六项大罪，本帅不能以小之剑，加于大王之头，请大王三思！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "夫差",
          "type": "西皮散板",
          "text": "统领雄兵去伐齐， 败国亡家后悔迟！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "且住呀！范蠡说孤六项大罪，一字不差。有何面目偷生人世？难道说，还学越 王看马不成么？"
        },
        {
          "character": "夫差",
          "type": "西皮散板",
          "text": "先王创业不容易， 不该错杀伍子胥。 仰面长叹一口气， 不如一死命归西！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夫差自刎。"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "哎呀大王啊！"
        },
        {
          "character": "伯嚭",
          "type": "西皮散板",
          "text": "大王一死心好惨 保定我主丧黄泉。"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "啊哈哈哈！啊范元帅！如今我家大王已死，元帅大功已成。我想此事，多亏我 伯嚭。若不是我，越国不能复兴，我吴国也不能灭亡。看将起来，我的功劳实 实不小。咳！快快奏与那越王知道，当封我什么爵禄哇？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "嘿……来，绑了！"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "元帅，因何将我绑起呀？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "推出斩首！"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "唉！这也是我卖国求荣的下场头哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伯嚭下。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "众将官，班师还朝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        },
        {
          "character": "范蠡",
          "type": "stage",
          "text": "【第十七场：归途】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "銮驾、西施同上。"
        },
        {
          "character": "西施",
          "type": "西皮摇板",
          "text": "朝歌暮舞如梦境， 残山剩水只伤情。 催动车辇向前进， 苎萝村内叩家门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "銮驾、西施同下。"
        },
        {
          "character": "西施",
          "type": "stage",
          "text": "【第十八场：迎美】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "勾践上。"
        },
        {
          "character": "勾践",
          "type": "西皮摇板",
          "text": "越王勾践破吴归。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍上。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "西施娘子回国，已到北门！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "摆驾相迎！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "摆驾相迎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。勾践、内侍同下。銮驾、西施、范蠡同上，勾践、内侍同迎上。"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "西施参见大王千岁，千千岁！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "娘子平身。"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "啊！西施娘子，想孤已然国破家亡，身为奴隶。多亏西施娘子一心救国，困住 吴王，真乃是为国为民！理当请上，受孤家一拜！"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "大王说哪里话来？臣妾乃越国之人，忠于越国理所当然。大王如此加恩，臣妾 惭愧无地！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "孤王下拜了！"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "折煞了！大王厚恩，臣妾没齿不忘。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "啊，西施娘子，暂且请至馆驿，候孤旨下。"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "摆驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "勾践",
          "type": "stage",
          "text": "【第十九场：劝文】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "勾践、范蠡、文种、四太监、稽郢、计然、泄庸同上。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "范相国，想你与西施娘子同立大功，暂且回府歇息，候孤旨下。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "范蠡",
          "type": "西皮摇板",
          "text": "谢罢大王回府往， 功成身退乐徜徉。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "文大夫！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "臣在。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "传旨全营将士，加升三级。满朝文武，明日早朝另有封赠。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "朝事已毕，退班。"
        },
        {
          "character": "稽郢、计然、文种、泄庸",
          "type": "同白",
          "text": "请驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "勾践下。四太监、稽郢、计然、泄庸同下。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "带马回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种上马。四龙套同下。家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "范大夫有书信一封，大人请看！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "下面伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。文种看信。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "“呈文大夫亲拆！” 范相国有书信到来，待我拆开观看： “子可记我主言欤！‘狡兔死，走狗烹，敌国破，谋臣亡。’越王为人长颈乌 喙，忍辱妒功，可与共患难，而不可与共安乐。子今不去，祸必不免。” 子今不去，祸必不免？"
        },
        {
          "character": "文种",
          "type": "笑",
          "text": "嘿……"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "少伯呀！少伯！你忒多心了！方今大仇新雪，百政待理。你身为国家重臣，怎 么竟自去了？也罢！待俺亲自赶他回来，再做道理。来，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种上马。"
        },
        {
          "character": "文种",
          "type": "二黄原板",
          "text": "狡兔死走狗烹谁能不信？ 又道是为臣的国尔忘身。 说什么我主爷乌喙长颈， 大丈夫百年事总为斯民。 揽丝缰催坐骑忙往前进， 寻见那范相国去问分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种下。"
        },
        {
          "character": "文种",
          "type": "stage",
          "text": "【第二十场：游湖】"
        },
        {
          "character": "范蠡",
          "type": "内西皮导板",
          "text": "整顿山河心事了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡、西施、船娘同上。"
        },
        {
          "character": "西施",
          "type": "西皮原板",
          "text": "五湖烟水任逍遥。 浮云——"
        },
        {
          "character": "范蠡",
          "type": "西皮原板",
          "text": "浮云富贵回头早， 功成——"
        },
        {
          "character": "西施",
          "type": "西皮原板",
          "text": "功成身隐是英豪。 远望——"
        },
        {
          "character": "范蠡",
          "type": "西皮原板",
          "text": "远望西山颜色好， 桃花——"
        },
        {
          "character": "西施",
          "type": "西皮原板",
          "text": "桃花千树逞新娇。 云水——"
        },
        {
          "character": "范蠡",
          "type": "西皮原板",
          "text": "云水光中来放棹，"
        },
        {
          "character": "西施",
          "type": "西皮散板",
          "text": "一行白鹭上春潮。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "啊，娘子，你我二人功成身退，浪游五湖，好不快乐人也！"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "相公言得极是！看前面桃花千树，又是何等什么所在？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "乃是西塞山！"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "何不前去游逛一番？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "好！ 船家将船开往西塞山去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡、西施、船娘同下船，船娘摆酒。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "啊，娘子，你我二人在此饮酒，无拘无疑。皆是娘子去往吴邦，得建大功，才 有今日。想卑人得享如此清福，皆娘子你所赐的了哇！"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "相公说哪里话来？妾身忍辱事仇无非为国，是功是罪，都听后人的评论，提它 怎么？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "啊，娘子，何不乘此酒兴，将当日吴宫之事，细说一回？"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "提起来惭愧得很！相公容禀。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "慢慢地讲。"
        },
        {
          "character": "西施",
          "type": "西皮二六板",
          "text": "提起了吴宫心惆怅， 犹如一梦熟黄粱。 朝朝暮暮在姑苏台上， 馆娃宫西畔又建响屧廊。 三千粉黛人人怅惘， 一身宠爱迷惑吴王。 佯欢假媚多勉强， 柔肠百转度流光。 功成喜见贤君相，"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "相公啊！"
        },
        {
          "character": "西施",
          "type": "西皮散板",
          "text": "这才是天从人愿配才郎。"
        },
        {
          "character": "范蠡",
          "type": "西皮散板",
          "text": "听她言来心欢畅， 果然妙策世无双。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "这破吴霸越之功，是令千古女流吐气的了哇！"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "相公夸奖了！"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "天色不早，我们回去吧！"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "我们回去吧。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "杯盘拿下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡、西施、船娘同上船。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "开船哪！"
        },
        {
          "character": "范蠡",
          "type": "西皮散板",
          "text": "猛抬头又只见江山似锦，"
        },
        {
          "character": "西施",
          "type": "西皮散板",
          "text": "博得个浣纱女万古留名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡、西施、船娘同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}