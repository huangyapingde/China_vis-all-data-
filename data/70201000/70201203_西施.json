{
  "script_id": "70201203",
  "title": "西施",
  "alias": [],
  "source": "梅兰芳剧本选",
  "characters": [
    {
      "name": "西施",
      "hangdang": "旦"
    },
    {
      "name": "范蠡",
      "hangdang": "老生"
    },
    {
      "name": "文种",
      "hangdang": "小生"
    },
    {
      "name": "夫差",
      "hangdang": "净"
    },
    {
      "name": "勾践",
      "hangdang": "老生"
    },
    {
      "name": "伯嚭",
      "hangdang": "丑"
    },
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "旋波",
      "hangdang": "旦"
    }
  ],
  "plot": "吴王夫差灭越，越王勾践用范蠡之计，在苎萝村访得美女西施，献于夫差。夫差被惑，伍员谏阻不成反被杀。\n夫差沉迷酒色，国事日益败坏，终被越所灭。范蠡功成身退，弃官隐居，与西施同泛五湖。",
  "notes": "见《史记·越世家》、《孤本元明杂剧》、明梁辰鱼《浣纱记》传奇。罗瘿公编，梅兰芳首演于1923年\n9月8日。为了丰富乐队的表现能力，梅兰芳首创在此剧伴奏乐器中加了二胡。原分上、下二本，后改为一\n晚演完。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "内侍、伍员、王孙骆、彭同、夫差同上。"
        },
        {
          "character": "夫差",
          "type": "西皮散板",
          "text": "锦绣山河吴地景， 倾城颜色越邦人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伯嚭上。"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "臣伯嚭见驾大王千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "有何本奏？"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "今有越国范大夫范蠡，带同美人，现在午门候旨。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "喔，替孤传旨，范蠡带同美人上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡、西施同上。"
        },
        {
          "character": "范蠡",
          "type": "念",
          "text": "前来吴殿上，"
        },
        {
          "character": "西施",
          "type": "念",
          "text": "低首拜君王。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "贱臣范蠡见驾，大王千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "范蠡，所献美人叫何名字？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "名叫西施。"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "西施参见大王！大王千岁，千千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "叫她抬起头来。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "掌起面来。"
        },
        {
          "character": "夫差",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "夫差",
          "type": "西皮散板",
          "text": "一见此女心欢庆， 果然倾城倾国人。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "真有倾国倾城之貌！ 内侍，快将娘娘送进宫去，"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "谢大王！ 正是："
        },
        {
          "character": "西施",
          "type": "念",
          "text": "一朝承恩宠，谁识浣纱人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监、西施同下。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "范蠡一片诚心，进献美人，孤当重加封赏。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "大王隆恩，贱臣十分感激。但是越王现在拘囚之中，臣不愿领赏。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "越王在此三载，十分谨慎。当日孤家身染重病，也曾为孤尝粪，可算得十分忠 义！今日范大夫进献美人，看在美人的分上，将越王释放回国，叫他君臣相会 便了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "卿家为何阻旨？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "臣启大王：想那越王勾践乃阴险之人，若放他回国，必然兴兵前来报仇。大王 就该将他斩首，以除后患。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "嗳！越王勾践感激孤王大恩，焉有报仇之理？卿家你不要多疑！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "大王不纳忠言，只恐大夫要学那越王在石室之中牵马坠镫，那时为臣心中不忍。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "唗！胆大伍员！竟敢胡言乱语！若不念你前日的功劳，一定将你斩首！ 武士们，将他推出朝门！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "下殿去吧。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "忠言反逆耳，亡国在眼前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "这个佞臣该死，带我上殿参他一本。 臣启大王：前者伍员出使齐国之时，曾将他子寄居外邦，显有异心。今大王若 不赐他死罪，定成后患。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "哦！卿家之言虽是有理，但是伍员也曾立过大功，怎能将他斩首？"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "不可不除啊！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "也罢！ 内侍，将此剑赐与伍员，看他自杀之后，回宫交旨，不得有误！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "遵旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍下。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "越王勾贱王服上殿。"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "大王有旨：勾贱王服上殿！"
        },
        {
          "character": "勾践",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "勾践上。"
        },
        {
          "character": "勾践",
          "type": "念",
          "text": "三载吴地为囚虏，今日生还再见天。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "臣勾贱见驾，大王千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "平身！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "越王在此三载，十分谨慎，今日放你回国，治理臣民，永为我邦属地，需要小 心。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "臣蒙大王有天高地厚之恩，杀身难报，便当子子孙孙永为属国，答报隆恩！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "范蠡，送你主回国，好生辅佐于他，不要忘了孤家的大恩大德。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "不忘吴王今日之恩也！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "好，回国去吧！"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "多谢大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡拉勾践同下。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "摆驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "夫差",
          "type": "stage",
          "text": "【第七场：归越】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四朝臣、文种同上。四卒、勾践、范蠡同上。勾践三哭。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "大王且免悲伤！今日回国君臣同心，何愁大仇不报！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "范卿之言甚是。孤今日回国，自当卧薪尝胆，励志图强。摆驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        },
        {
          "character": "勾践",
          "type": "stage",
          "text": "【第八场：馆娃宫】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监同上。"
        },
        {
          "character": "太监甲",
          "type": "念",
          "text": "奉了大王命，"
        },
        {
          "character": "太监乙",
          "type": "念",
          "text": "掸扫馆娃宫。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "公公请了！"
        },
        {
          "character": "太监乙",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "今日大王与娘娘在馆娃宫夜宴，你我掸扫已毕。远远望见，大王、娘娘来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。夫差、西施同上。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "妃子，你看皓月当空，银河泻影，风景甚佳。何不歌舞一回，娱此良宵？"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "妾妃领旨。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "内侍，旋波进见！"
        },
        {
          "character": "二太监",
          "type": "同白",
          "text": "领旨！ 旋波进宫啊！"
        },
        {
          "character": "旋波",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旋波上。"
        },
        {
          "character": "旋波",
          "type": "念",
          "text": "荷香迎鼻爽，莲动百花洲。"
        },
        {
          "character": "旋波",
          "type": "白",
          "text": "旋波参见大王千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "旋波",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "命你陪伴娘娘歌舞一回！"
        },
        {
          "character": "旋波",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "内侍，与娘娘更衣者！"
        },
        {
          "character": "二太监",
          "type": "同白",
          "text": "遵旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西施下。"
        },
        {
          "character": "西施",
          "type": "内西皮导板",
          "text": "长天无云冰轮上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西施上。"
        },
        {
          "character": "西施",
          "type": "西皮快板",
          "text": "十二栏杆接晚凉。 曼舞筵前君王笑赏，"
        },
        {
          "character": "夫差",
          "type": "笑",
          "text": "哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖望家乡〗。西施舞翎。"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "内侍看酒来！看酒来！哈哈……请！再饮几杯，"
        },
        {
          "character": "西施",
          "type": "白",
          "text": "妾妃醉了！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "孤家也大醉了，内侍！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "服侍娘娘回后宫去者！ 【第九场：越宫】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种、泄庸、计然、稽郢同上。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "我乃上大夫文种。"
        },
        {
          "character": "泄庸",
          "type": "白",
          "text": "大司马泄庸。"
        },
        {
          "character": "计然",
          "type": "白",
          "text": "大夫计然。"
        },
        {
          "character": "稽郢",
          "type": "白",
          "text": "大夫稽郢。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "列位大人请了！"
        },
        {
          "character": "泄庸、计然、稽郢",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "越王升殿，你我分班伺候。"
        },
        {
          "character": "文种、泄庸、计然、稽郢",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引勾践同上。"
        },
        {
          "character": "勾践",
          "type": "引子",
          "text": "励志图强，十年聚，誓报冤仇！"
        },
        {
          "character": "文种、泄庸、计然、稽郢",
          "type": "同白",
          "text": "参见大王千岁！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "文种、泄庸、计然、稽郢",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "勾践",
          "type": "念",
          "text": "三载困吴邦，幽囚实可伤。同心破罗网，励志要图强。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "孤，越王勾践。自从归国以来，举国上下，生聚教训。国人已备三载之粮，纷 纷请缨伐吴雪耻。孤也曾命范相国操练人马，待时而动。 内侍，宣范相国上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "范相国上殿。"
        },
        {
          "character": "范蠡",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范蠡上。"
        },
        {
          "character": "范蠡",
          "type": "念",
          "text": "忠心扶社稷，上殿见君王。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "臣范蠡见驾，大王千岁！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "相国平身。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "谢座！宣臣上殿，有何国事议论？"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "命你操练人马，可曾练熟？"
        },
        {
          "character": "范蠡",
          "type": "白",
          "text": "人马俱已练熟。闻得吴王有意伐齐，大王正好乘此机会报仇雪恨。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "好！如此就命卿以为征吴大元帅，见机而行。"
        },
