        {
          "character": "范蠡",
          "type": "白",
          "text": "劝你马前归顺，免得生灵涂炭！"
        },
        {
          "character": "夫差",
          "type": "白",
          "text": "哼！太宰与我擒来！"
        },
        {
          "character": "伯嚭",
          "type": "白",
          "text": "领旨！ 看剑！"
        },
        {
          "character": "四龙套",
          "type": "同白",
