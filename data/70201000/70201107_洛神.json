{
  "script_id": "70201107",
  "title": "洛神",
  "alias": [],
  "source": "梅兰芳剧本选",
  "characters": [
    {
      "name": "洛神",
      "hangdang": "旦"
    },
    {
      "name": "曹植",
      "hangdang": "小生"
    },
    {
      "name": "汉滨游女",
      "hangdang": "旦"
    },
    {
      "name": "湘水神妃",
      "hangdang": "旦"
    }
  ],
  "plot": "三国时，曹植拜见其兄曹丕，曹丕赐他以玉缕金带枕，归途宿于洛川驿中，夜中有神女示梦，自称宓妃，嘱\n明日赴洛川一会。曹植如约往，果有汉滨游女、湘水神妃引至洛川与宓妃相会，宓妃告诉曹植与之有前缘。",
  "notes": "取材于曹植《感甄赋》（即《洛神赋》）。这个戏是梅兰芳先生中期代表之一。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖西皮小开门〗。四御林军、四小太监、二大太监引曹植同上。"
        },
        {
          "character": "曹植",
          "type": "引子",
          "text": "帝城春老，杜宇催归早。"
        },
        {
          "character": "曹植",
          "type": "念",
          "text": "洛阳冠盖地，车马分驱驰。崇台接烟起，翠阁与云齐。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "本藩，雍邱王曹植。承恩北阙，备位东陲。今日朝觐礼毕，承命归藩。 内侍！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "仪仗可曾齐备？"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "俱已齐备！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "吩咐起程！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "是。 外面起程啊！"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹植",
          "type": "西皮导板",
          "text": "金殿上辞圣驾缓御东返，"
        },
        {
          "character": "曹植",
          "type": "西皮原板",
          "text": "适才间背伊阙又越轘辕。 一路上经通谷把景山来践， 不觉得日西坠车殆马烦。 税蘅皋秣芝田忙催前站， 猛然见马头前已是洛川。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴可铭迎上。"
        },
        {
          "character": "吴可铭",
          "type": "念",
          "text": "春完古驿无莺语，日落荒郊有马嘶。"
        },
        {
          "character": "吴可铭",
          "type": "白",
          "text": "洛川驿驿丞吴可铭，叩接王爷！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "引路！"
        },
        {
          "character": "吴可铭",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "曹植",
          "type": "西皮摇板",
          "text": "一阵阵晚鸦声归心似箭， 猛抬头来到了洛水驿前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "洛神",
          "type": "内二黄导板",
          "text": "满天云雾湿轻裳，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八云女引洛神同上。"
        },
        {
          "character": "洛神",
          "type": "二黄散板",
          "text": "如在银河碧汉旁。 缥缈春情何处傍？ 一汀烟月不胜凉。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "吾乃，洛川神女是也。掌握全川水印，修成一点仙心。因与曹王子建尚有未尽 之缘，犹负相思之债。今日闻他驻扎本驿，为此御云而来，对他略表因由，藉 通诚愫。 侍儿们！"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "洛川驿中去者！"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "是！"
        },
        {
          "character": "洛神",
          "type": "二黄散板",
          "text": "思想起当年事心中惆怅， 再相逢是梦里好不凄惶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖二黄小开门〗。吴可铭、二大太监、曹植同上。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "你且退下！"
        },
        {
          "character": "吴可铭",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴可铭下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "长途跋涉，好生困倦。唉！你看冷驿萧条，春光潦草，碧云已合，美人不来， 这情怀好难安顿也！"
        },
        {
          "character": "曹植",
          "type": "二黄散板",
          "text": "身不惯长途苦好生困倦， 恶情怀无聊赖待向谁言！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴可铭上。"
        },
        {
          "character": "吴可铭",
          "type": "白",
          "text": "王爷请用晚膳。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "不消！我要静息片时，你且回避！"
        },
        {
          "character": "吴可铭",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴可铭下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "唉！夜静更长，怎生消遣！哦，有了，前日入朝之时，圣上以甄后遗物——玉 镂金带枕见赐，当此枯坐无聊，不免在灯下抚玩一番。 内侍！"
        },
        {
          "character": "二大太监",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "将圣上所赐玉镂金带枕取来！"
        },
        {
          "character": "二大太监",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。二大太监分取灯、枕。"
        },
        {
          "character": "二大太监",
          "type": "同白",
          "text": "金带枕在此。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "放下。尔等回避。"
        },
        {
          "character": "二大太监",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监同下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哎呀呀，好一个枕儿也！"
        },
        {
          "character": "曹植",
          "type": "二黄原板",
          "text": "手把着金带枕殷勤抚玩， 想起了当年事一阵心酸。 都只为这情丝牵连不断， 好教我终日里意马心猿。 一霎时只觉得神昏意懒， 无奈何我只得倚枕而眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植睡。〖起三更鼓〗。八云女引洛神同上。"
        },
        {
          "character": "洛神",
          "type": "二黄散板",
          "text": "野荒荒星皎皎夜深人静， 驾云来转瞬间已到驿门。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "来此已是驿中，待我进去。 侍儿们。"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "外厢伺候。"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八云女同下。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "唉，看他早已酣睡也！"
        },
        {
          "character": "洛神",
          "type": "二黄散板",
          "text": "进门来暗昏昏一灯摇影， 可怜他伏几卧独自凄清。 我有心向前去将他唤醒， 羞怯怯只觉得难以为情。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "看他怀抱之中，乃是玉镂金带枕。睹物伤情，益增悲感。待要将他唤醒，怎奈 难以为情。这便怎么处！哦，有了。不免梦中约他明日川上相会便了。 子建哪，子建！我与你未了三生，尚须一面。来日洛川之上，专待君临，牢牢 紧记！小仙去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八云女同暗上。"
        },
        {
          "character": "洛神",
          "type": "二黄散板",
          "text": "明日里洛川前将君来等， 莫迟疑休爽约紧记在心。 出门来唤众仙祥云驾定， 待来朝见了面再说前尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八云女引洛神同下。〖起四更鼓〗。"
        },
        {
          "character": "曹植",
          "type": "二黄导板",
          "text": "猛然间睁开了朦胧睡眼，"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "曹植",
          "type": "二黄散板",
          "text": "适才见一女子好似天仙。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "好奇怪呀！方才朦胧睡去，分明见一神女，水佩风裳，姿容绝世，似在哪里见 过一般，兀的不教人想煞也！我想这梦还去得不远，待我唤它转来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植招手。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "我那神女呢？喂！我那仙姬呢？唉！竟自去远了。我想人生在世，似这等佳梦， 能有几场？偏是醒得这样快法。唉！我好恨也！"
        },
        {
          "character": "曹植",
          "type": "二黄摇板",
          "text": "荒陲内乱鸡声把好梦惊散， 倒教我何处里再觅婵娟。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "那梦中神女分明约我明日在川之上相会，我不免早些安歇，明日也好前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监持灯同上。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "夜已深了，请王爷后殿安寝！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "带路。正是："
        },
        {
          "character": "曹植",
          "type": "念",
          "text": "好梦难寻容易掉，柝声偏向枕边敲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植、二大太监同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "汉滨游女、湘水神妃同上。"
        },
        {
          "character": "汉滨游女",
          "type": "念",
          "text": "昔日曾游汉水滨，肌肤凝雪玉裁身。"
        },
        {
          "character": "湘水神妃",
          "type": "念",
          "text": "同心执掌南湘水，六幅轻罗碧纱裙。"
        },
        {
          "character": "汉滨游女",
          "type": "白",
          "text": "吾乃汉滨游女是也。"
        },
        {
          "character": "湘水神妃",
          "type": "白",
          "text": "吾乃湘水神妃是也。"
        },
        {
          "character": "汉滨游女",
          "type": "白",
          "text": "仙姑请了！"
        },
        {
          "character": "湘水神妃",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "汉滨游女",
          "type": "白",
          "text": "今有洛川仙姐相召我等，不知为了何事？"
        },
        {
          "character": "湘水神妃",
          "type": "白",
          "text": "既蒙相约，自当前去才是。"
        },
        {
          "character": "汉滨游女",
          "type": "白",
          "text": "如此请。"
        },
        {
          "character": "湘水神妃",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "汉滨游女",
          "type": "二黄摇板",
          "text": "姊妹双双出洞门，"
        },
        {
          "character": "湘水神妃",
          "type": "二黄摇板",
          "text": "仙姐相召必有因。"
        },
        {
          "character": "汉滨游女",
          "type": "二黄摇板",
          "text": "驾起祥云朝前进，"
        },
        {
          "character": "湘水神妃",
          "type": "二黄摇板",
          "text": "不觉来到仙府门。"
        },
        {
          "character": "汉滨游女、湘水神妃",
          "type": "同白",
          "text": "门上哪位在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八云女同上。"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "二位仙姑到此何事？"
        },
        {
          "character": "汉滨游女、湘水神妃",
          "type": "同白",
          "text": "烦劳通禀：就说我等应邀前来。"
        },
        {
          "character": "八仙女",
          "type": "同白",
          "text": "是。 有请仙子。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神上。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "八仙女",
          "type": "同白",
          "text": "二位仙姑驾到。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "八仙女",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖二黄小开门〗。洛神出迎。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "二位仙妹请。"
        },
        {
          "character": "汉滨游女、湘水神妃",
          "type": "同白",
          "text": "仙姐请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神、汉滨游女、湘水神妃同进。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "二位仙妹驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "汉滨游女、湘水神妃",
          "type": "同白",
          "text": "岂敢。相召我等，有何见教？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "二位仙妹有所不知：只因雍邱王曹植与小仙前生尚有未尽之缘，今日闻他在此 经过。此人颇识风情，深明礼义；意欲相烦两位仙妹同定小仙，去往川上游戏 一番，藉了前缘。不知二位仙妹意下如何？"
        },
        {
          "character": "汉滨游女、湘水神妃",
          "type": "同白",
          "text": "小仙等甚愿奉陪。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "如此甚好，小仙先行一步，二位仙妹带同仪仗，即刻前来。"
        },
        {
          "character": "汉滨游女、湘水神妃",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉滨游女、湘水神妃同下。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "侍儿们。"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "随我前往！"
        },
        {
          "character": "洛神",
          "type": "二黄散板",
          "text": "云鬓罢梳慵对镜， 罗袂轻扬出殿门。 众位仙真把路来引， 一派清光不见人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神站立云端，八云女环绕侍立。曹植上。"
        },
        {
          "character": "曹植",
          "type": "二黄摇板",
          "text": "加鞭催马到洛滨， 烟水茫茫何处寻！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "来此已是洛川，待我紧行几步者！"
        },
        {
          "character": "曹植",
          "type": "二黄摇板",
          "text": "一片诚心往前进， 但愿得见梦中人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植看洛神。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "远而望之，皎若太阳升朝霞；近而察之，灼若芙蕖出绿波。真乃仙人也！看她 脉脉含愁，盈盈欲语，待我听她说些什么。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "子建啊，子建！你我彼此一别，十有余年，可还记得小仙么？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哎呀呀！她那里明明说着本藩。不知几生修到，有此奇遇。只是仙凡异体，不 能亲近仙姿，这便如何是好！有了，待我祝告于她。 啊，仙姬，既蒙以色身相示，何妨接近一谈呀！"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "感君相念，也是前缘，只是不可越礼。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "是，是，是。 待我望空拜她一拜，感动于她，或者得相亲近，也未可知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植拜。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "啊，仙姬，既云与本藩有缘，敢请稍停仙趾，追话前因！"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "如此，侍儿们！"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "祥云下降。"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神下云端。八云女同暗下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "承蒙仙姬下降，小王这厢有礼了。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "子建休要如此，你可还记得我么？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "恍惚曾在梦中见过。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "几时？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "昨夜啊！"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "唉！蒙君见爱，已非一朝，怎么说是昨夜才见呢？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "怎么，难道仙姬从前就与小王相识么？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哎呀！怎么小王就想它不起。仙姬来踪去迹，望乞说个明白。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "若问我的踪迹么？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "说起来和你要远就远，要亲就亲。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "怎说要远就远？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "你我二人，从未交过一言。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "这要亲就亲呢？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "这要亲就亲么……"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "唉！这就难说了！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "怎么又难说了哇？"
        },
        {
          "character": "洛神",
          "type": "念",
          "text": "絮果兰因难细讲，意中缘分任君猜。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哎呀呀，小王益发糊涂了，还求明教。这要亲就亲是怎么讲？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "这要亲就亲么……"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "唉！你也曾为我忘餐废寝，与他人生过气来。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "啊？怎么，小王还与他人生过气来？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "真是罪该万死，怎么就会忘怀了。莫非小王此时还是做梦不成？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "是梦是醒，后来便知。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "还求仙姬明教！"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "唉！殿下呀！"
        },
        {
          "character": "洛神",
          "type": "二黄原板",
          "text": "提起前尘增惆怅， 絮果兰因自思量。 精诚略诉求鉴谅， 难得同飞学凤凰。 劝君莫把妾念想，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "哑笛。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "殿下呀！"
        },
        {
          "character": "洛神",
          "type": "二黄摇板",
          "text": "莺疑燕谤最难当。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "仙姬既与小王有缘，何妨请降临敝府，共证前因。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "你我相契以神，不过空中爱慕；一涉形迹，便生魔障。千古多情之人，从无越 礼之事；小仙一到尊府，则悠悠之口，何患无辞。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "既是不能下临敝府，为何昨夜又到驿中呢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神羞。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植拉洛神。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "去去何妨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神甩脱。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哎呀，我得罪了。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "无妨。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "仙姬啊！"
        },
        {
          "character": "曹植",
          "type": "二黄摇板",
          "text": "既然是与小王前有情分， 又何妨赐颜色暂屈同行。 非敢望与仙姬影连肩并， 只不过到客邸略话前尘。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "说了半日，还不知仙姬名姓，敢请以实相告。小王回去，也好香花供奉。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "要知我的端的么？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "如此，子建！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "是，是，是，来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神、曹植同走圆场。洛神向曹植招手，下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哎呀，且住！正要问她端的，为何忽然不见，又要教我随她前去，不知这是什 么意思！也罢，待我急急赶上者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监同上。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "王爷为何一人在此发闷？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哦，尔等来了。适才看见一位美女，不知是何神仙，尔等可知否？"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "但不知是怎样的面貌？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "秾织得中，修短合度；肩若削成，腰如约素；委实美丽得很哪！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "小人闻得洛川之神，名曰宓妃，王爷所见，莫非就是她吗？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "一定是的，尔等暂且退后，待我再上前观看一回。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "王爷多加小心。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "无妨，尔等暂退。"
        },
        {
          "character": "二大太监",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监同下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "前路不知又有何等景象，不免急忙前去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植走圆场。"
        },
        {
          "character": "曹植",
          "type": "二黄散板",
          "text": "她那里柔情态娇羞满面， 闪得我心振荡无语无言； 为什么一霎时踪影不见， 难道说我此时还在梦间。"
        },
        {
          "character": "洛神",
          "type": "内西皮导板",
          "text": "屏翳收风天清明，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开幕。洛神、汉滨游女、湘水神妃同站立云端。十童子分执伞、扇、采旄、挂旂同侍立左右。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "原来这里有这许多美丽的仙妹，倒要仔细地看过一番，不要错过这机会呀！"
        },
        {
          "character": "洛神",
          "type": "西皮慢板",
          "text": "过南岗越北沚杂沓仙灵。 一年年水府中修真养性， 今日里众姊妹同戏川滨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神、汉滨游女、湘水神妃同起舞。"
        },
        {
          "character": "洛神",
          "type": "西皮慢板",
          "text": "乘清风扬仙袂飞凫体迅， 拽琼琚展六幅湘水罗裙。"
        },
        {
          "character": "洛神",
          "type": "西皮原板",
          "text": "我这里翔神渚把仙芝采定， 我这里戏清流来把浪分；"
        },
        {
          "character": null,
          "type": "stage",
          "text": "回回曲牌。"
        },
        {
          "character": "洛神",
          "type": "西皮原板",
          "text": "我这里拾翠羽斜簪云鬓，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "山坡羊牌。"
        },
        {
          "character": "洛神",
          "type": "西皮原板",
          "text": "我这里采明珠且缀衣襟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "万年欢牌。"
        },
        {
          "character": "洛神",
          "type": "西皮原板",
          "text": "众姊妹动无常若危若稳，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一枝花牌。"
        },
        {
          "character": "洛神",
          "type": "西皮原板",
          "text": "竦轻躯似鹤立婉转长吟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "回回曲牌。"
        },
        {
          "character": "洛神",
          "type": "西皮原板",
          "text": "桂旂且将——"
        },
        {
          "character": "洛神",
          "type": "西皮二六板",
          "text": "芳体荫， 免他旭日射衣纹。 须防轻风掠云鬓， 采旄斜倚态伶俜。 齐舞翩跹成雁阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洛神、汉滨游女、湘水神妃渐走下云端。"
        },
        {
          "character": "洛神",
          "type": "西皮快板",
          "text": "轻移莲步踏波行。 翩若惊鸿来照影， 宛如神龙戏水滨。 徙倚彷徨行无定， 看神光离合乍阳阴。 雍丘王他那里目不转瞬，"
        },
        {
          "character": "洛神",
          "type": "西皮散板",
          "text": "心振荡默无语何以为情！"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哎呀呀，妙极呀，妙极！小王可以算得奇遇了！这一定是宓妃无疑了，待我一 拜。"
        },
        {
          "character": "汉滨游女、湘水神妃",
          "type": "同白",
          "text": "此位就是雍邱王么？"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "正是。待我向前。 啊子建，不要如此。小仙偶蹈尘缘，昔日曾在宫中，与殿下两相爱慕，难道果 真忘怀了么？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哦，是，是，是。小王如梦初醒，想起前情，令人可恨！"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "如今仙凡路殊，得此一会，也是前缘。小仙这里有常戴耳珠一颗，特奉殿下， 已报知己。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "受此重赐，何以报德！小王这里也有常带玉佩一事，敬献仙姬，聊作琼瑶之报。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "多谢殿下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "殿下，你我言尽于此，后会无期。殿下万千珍重，小仙告别了。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "侍儿们。"
        },
        {
          "character": "八云女",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "回府去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。洛神、汉滨游女、湘水神妃、八云女同驾云上升，分站原位。"
        },
        {
          "character": "洛神",
          "type": "白",
          "text": "殿下保重，小仙去也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植怅然。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}