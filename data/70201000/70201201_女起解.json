{
  "script_id": "70201201",
  "title": "女起解",
  "alias": [],
  "source": "梅兰芳剧本选",
  "characters": [
    {
      "name": "苏三",
      "hangdang": "旦"
    },
    {
      "name": "崇公道",
      "hangdang": "丑"
    }
  ],
  "plot": "王金龙在妓院钱财用尽，被鸨儿轰出，苏三私赠银两使回南京。王金龙走后，鸨儿把苏三骗卖给山西商人沈\n燕林作妾。沈妻与人私通，毒死沈燕林，反诬告苏三。县官受贿，判苏三死罪。解差崇公道提解苏三自洪洞\n去太原复审。途中苏诉说自身的遭遇，崇公道加以劝慰，并认苏三为义女。",
  "notes": "此剧由梅兰芳伯父梅雨田亲自传授。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "崇公道",
          "type": "内白",
          "text": "啊哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道上。"
        },
        {
          "character": "崇公道",
          "type": "念",
          "text": "你说你公道，我说我公道，公道不公道，嗳，自有天知道。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "在下崇公道，在洪洞县当差。因我嘞上了几岁年纪，为人又老诚，所以太爷命 我代管女监。这且不言。按院大人在省中下马，太爷命我将苏三解往到太原复 审。天也不早啦，监中走走，官事官办。 嗳，到了。挑开，挑开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "禁卒上。"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "嗳，坐监的吗？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，什么呀？"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "喔！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "我来啦！"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "上差到啦！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "来来来，进来，进来。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "这不结啦！"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "啊上差，您好哇。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，好末！"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "老没有见啦。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "可不吗？"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "您坐下，坐下。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，坐着。"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "上差，您干什么来啦？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "提股差事。"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "提谁呀？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "你把苏三给我提出来。"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "喔，苏三哪？好，您这儿等一等。 啊，苏三走动啊！"
        },
        {
          "character": "苏三",
          "type": "内白",
          "text": "苦哇，喂呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三上。"
        },
        {
          "character": "苏三",
          "type": "二黄散板",
          "text": "忽听得唤苏三我的魂飞魄散， 吓得我战兢兢不敢向前。"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "上差到啦！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "苏三",
          "type": "二黄散板",
          "text": "无奈何我只得来把礼见， 崇老伯呼唤我所为哪般？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "老伯在上，苏三有礼。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，罢啦，罢啦，罢啦！苏三哪，你大喜啦！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "啊！我苏三喜从何来？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "今有按院大人在省中下马，太爷命我将你解往在太原复审。你的冤枉官司有了 头绪啦，岂不是一喜呐？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "但不知是何人的长解？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，自然是我的长解嘞。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "喔，就是老伯的长解。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "不错，不错。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "啊老伯，几时起程呢？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "马上飞，这就走！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "如此，老伯打点行囊，待我在此收拾收拾，也好赶路。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "得，就那么办。回头见啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道下。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "苍天哪，天！想我苏三，遭此不白冤枉，直到今日啊！"
        },
        {
          "character": "苏三",
          "type": "反二黄慢板",
          "text": "崇老伯他说是冤枉能辩， 想起了王金龙负义儿男。 想当初在院中何等眷恋， 到如今恩爱情又在哪边！ 我这里将状纸暗藏里面， 到太原见大人也好伸冤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道上。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "苏三哪，你收拾好啦？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "收拾好了。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "好啦好啦，把这个刑枷来戴上啊！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "怎么？还要戴上刑枷么？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "朝廷的王法哪有不带的？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "喂……呀……"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "好，耐点儿烦吧！啊！ 挑开，挑开！回头再见，啊！"
        },
        {
          "character": "禁卒",
          "type": "白",
          "text": "回头见啊！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "我不放心，得洗洗她！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "啊！老伯。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "怎么着？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "你前去投文，我在那厢等你呀！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳！罢了，真是打官司的老在行。那儿等我吧！领文书要紧哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三下。狱官暗上。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳！哪位先生听差啊？"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "干什么的？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "苏三起解嘞，您把文书赏下来吧！"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "听点。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "长解一名崇公道。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "护解一名崇公道。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "咳，你怎么一个人充当二役，是怎么档子事情？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唉！不瞒你说，这趟差事啊，苦点儿。领的盘川不多，两个人不够，一个人儿 又富余点儿；况且又是一口女犯，半道上也没有什么事情。您闭闭眼，我们就 过去咧。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "有的，你真能说啊！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "实话。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "解往什么地方儿啊？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "太原省城。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "喔，太原省城啊，那儿出好箩儿。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "敢情。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "给你两个钱儿，给我带个箩儿。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "就这两个钱儿还买骡儿啦？尾巴也买不回来呀。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "什么箩儿啊？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "您说什么骡儿？"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "我说的是马尾箩儿。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "要马尾箩儿干什么用啊？"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "筛松香。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有什么使项？"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "粘取灯。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，粘取灯不用松香。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "用什么？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "黄蜡。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "蜡黄！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗯，冰糖！"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "绵羊。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗯，真是怪事，打什么哈哈呐，拿来吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "狱官下。崇公道下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苏三上。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "喂……呀……"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "苏三离了洪洞县， 将身来在大街前。 未曾开言我心内惨， 过往的君子听我言： 哪一位去往南京转， 与我那三郎把信传， 言说苏三把命断， 来生变犬马我当报还！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道上。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唉，苏三哪，走着走着，你不走啦；跪在这个地方，是祝告天地呀？还是哀求 盘川哪？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "一非祝告天地，二非哀求盘川。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "那么跪在这儿干什么呀？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "求老伯问一问过路的客商，可有往南京去的无有？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "喔，有往南京去的，怎么样呐？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "若有往南京去的，好与我那三郎，带个信儿……啊……"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "咦，哈哈哈哈哈哈，您瞧嗳，她到了这步田地啦，还不忘她心上那个儿人儿呢！ 咳！做妓女的，都像她似的，嗳，总算是个有良心的呐。好事！ 我给你问去啊！ 咳，我说店里的掌柜的请啦。"
        },
        {
          "character": "掌柜",
          "type": "内白",
          "text": "做什么？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "咳，您这儿的客人有往南京去的没有啦！"
        },
        {
          "character": "掌柜",
          "type": "内白",
          "text": "往南京去的前三天都走啦。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "那么这会儿都上哪儿去的？"
        },
        {
          "character": "掌柜",
          "type": "内白",
          "text": "净剩上热河、巴沟、喇嘛庙拉骆驼的啦！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "这倒好，出了口啦！ 唉，苏三哪，我给你问来啦：往南京去的客人哪，前三天就走啦。净剩了上口 外热河、巴沟、喇嘛庙拉骆驼的咧！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "唉，我苏三好命苦……哇……"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "半道儿上人多着哪，咱们再打听打听啊！"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "人言洛阳花似锦， 偏奴行来不是春。 低头离了，"
        },
        {
          "character": "苏三",
          "type": "西皮散板",
          "text": "洪洞县境，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "哎哟，坐下，好热的天吓。"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "老伯不走为何情？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "啊老伯，你为何不走啊？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唉，不是我不走哇，你瞧这个天儿够多热。空身人儿走道还出汗呢，何况你， 女流之辈，扛着这么重的枷。这不是出了城了吗？这么办，把这个枷卸下来， 慢慢儿的溜达着走。等离着省城不远，咱们再戴上进城，你说好不好呢？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "慢来，慢来。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "此乃朝廷王法，如何能去得呢？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唷，得，咳，在这儿等着我呐！什么王法呀，这是瞒上不瞒下；出城由着我， 没有关系。来来来，趁着没有人儿，赶紧卸下来。 咳，你瞧这个松快不松快！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "看将起来，你倒是个好人哪！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "咳，好人怎么着，你瞧我这个岁数啊，连个儿子都没有！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "哎呀呀，这样的好人，都会没有儿子啊！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗯，非但没有儿子，把个孙子也给耽误啦！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "取笑了！老伯若不弃嫌，情愿拜在老伯名下，认为义女。不知意下如何？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唉，那可使不得，没有那规矩。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "爹爹请上！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "干什么？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "待女儿大礼参拜。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，别拜、别拜呀；别拜，别拜。起来，起来，起来，起来。嘻哈哈哈哈哈哈…… 嗳，您瞧，这都是想不到的事情。我这个岁数嘞，又收了这么一个干女儿。你 瞧瞧，她的五官相貌多体面哪，真是啊眉清目秀，粉面桃腮，比花、花添雨， 比玉、玉生香。这样的品貌，将来一定是个有造化的啦。哈哈哈哈……得，这 个干女儿收着啦。可惜穷干爹，要什么没有什么，拿什么做见面礼儿呢？真是， 唉！得，还是拿这根棍儿，遮遮羞脸儿吧！ 苏三哪！我这儿有根棍儿，权当见面礼儿，你拄着它走，咱们三条腿儿，且比 两条腿儿省劲儿多。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "如此你我父女，一同走哇！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳，咱走哩！"
        },
        {
          "character": "苏三",
          "type": "西皮导板",
          "text": "玉堂春含悲泪忙往前进，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "别忙，慢慢儿的溜达着走。"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "想起了当年事好不伤情！ 每日里在院中缠头似锦， 到如今只落得罪衣罪裙！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "你说什么，“想当初在院中缠头似锦，到如今只落得罪衣罪裙”。今非昔比， 你知道啦，这打上官司啊，比不得你在怡春院，穿绸裹缎，每日花天酒地是快 乐非常，那是鸨儿拿你当作了摇钱树，好常年的给她赚钱，那何日是了哇。你 瞧这一会儿身穿罪衣，蓬头垢面，心里头哪儿有不难过的呐？你啊！就盼着吧！ 到了省城见了都天大人，判明冤枉，没有你的罪啦，那必然有你一条生路。 那个称心的日子，还在后头呐！不用发愁，有希望，耐点儿烦，咱们走吧！"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "一可恨爹娘心太狠， 大不该将亲女图财卖与娼门！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳唷孩子，你说这两句话，我听着，心里头好难过哇！“什么爹娘做事心肠狠， 不该将你卖入娼门”。这话呢，倒是有你这么一说呀。本来么，做父母的， 应当教养儿女成人，决不该卖女儿为娼。话虽如此啊，可别埋怨你父母。但是 这个娼妓你不知道从什么时候儿有的，这是我听人说过呀！这是列国齐桓公霸 诸侯一匡天下，用管仲为相，他兴的这个，设立了三百处乐户；专让你们这些 美貌青年的妇女，日施胭脂花粉，接待各国的商贾，得钱钞，满归齐桓公所有。 就为他富国，不管妇女们的痛苦。你想，从那时到而今，这几千年来，也不 知伤害了多少良家的妇女啊！你说他们缺德不缺德呀！要恨哪，你就恨他，实 在是有伤人道哇！这个臭根儿啊，是他留下的，埋怨你父母干什么呀？走吧！"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "二可恨山西沈燕林， 他不该与我来赎身。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唉！孩子，你要是说这个话，可就算没良心啦！那沈大官人，花那么些银子钱 替你赎身，出节为良，乃是一件好事。你怎么倒埋怨人家呢？唉！按说那个沈 燕林他可也不对啊！既有媳妇儿哪，干什么又把你给弄到家里去？一夫二妻， 都是这个岁数儿。那沈大官人，他再厌故喜新，在你的屋里日子多，她那屋里 日子少，这日子长啦，哪儿能呕不吵？啊呀，这个沈燕林，虽然把你救出了火 坑啊，这一下反倒把你害了。咳，他虽然有两个糟钱儿啊！买了个家宅不安， 他这是自找其祸。走吧！"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "三可恨皮氏狗贱人， 施毒计用药面害死夫君。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "什么，皮氏不该用药面害死夫君，你也不想想，那个皮氏素常素往，一个人儿 过惯了的；你要是得了宠，没有她的地步啦，哪有不生歹心的？那一天弄了一 碗毒药面哪，指望是把你给毒死啊！没有想到那个倒霉的沈燕林，他替你吃了， 这才呜呼哀哉，闹出这么大的事来。嗳，这倒是个警世文儿啊！我想人生在 世，不可任意胡为啊！咳！这个闺房的事情呐，夫妻总要商量好了。如其不然， 真有性命之忧哇！这个事儿危险啦，啊！走罢！"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "四可恨春锦小短命， 贪欢乐私通那赵监生。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "咳！春锦一个使唤丫头，你恨她干什么？再一说，这也是个苦命的孩儿，皮氏 拿银钱把她买来的，不向着皮氏，她敢向着你吗？你再说，那个丫头也老大不 小的啦！也不张罗着给她找个人家。那个皮氏既跟这个赵监生有了关系啦，日 久天长，那个春锦还用说吗？再一说，他们的事情，你管得了吗？那是好鞋不 踩臭狗屎，没有事儿烦这一个牢头干什么呀？得了，得了，得了，走吧，走吧， 走吧！甭说嘞！"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "五可恨贪赃王县令，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嘿！嘚，说来说去，倒说到我们“座儿上”了！什么知县贪赃，你也不打听打 听，他那个官员怎么来的，也是贩本儿贩利儿拿银钱运动来的。所以到任以来， 吃的、喝的、使的、用的，哪一样又不是民脂民膏嘞呐，衙门口儿冲南开， 有理无情拿钱来。你就甭说啦，这个黑幕大啦！走吧！"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "六可恨众衙役分散赃银。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唷，说到我们“六扇门儿”来啦。什么众衙役不该分散赃银。你也不打听打听， 大堂不种高粱，二堂不种黑豆，吃什么呀，还不吃你们打官司的？就说那一 笔钱，连我还穿了一双鞋呐！说这个干什么？我就不爱听！真是的，嗯……"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "七可恨屈打来承认，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗳唷傻孩子！屈打招认，不打你，这皮氏就花钱了么！不用说这个傻话啦，走 吧！"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "八可恨那李虎他骗我招承。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "什么？“李虎骗你招承”，嗳唷那种人哪，也是受了皮氏拿银钱运动好了的嘞！ 他是就管自个儿合适，不管人的死活，称得起损人利己、伤天害理哟！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "哎。"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "九也恨来十也恨， 洪洞县内是无好人！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "什么？“洪洞县没有好人”？甭说我也在其内啊！真没有良心哪，挺热的天， 这么重的枷我拿着，连我都不是好人啦？官事官办，来，把枷戴上，戴上，戴 上！你真要气死我嘞，这是哪儿说起！唉……这是哪儿的事……嗯……"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "一句话儿错出唇， 爹爹一旁把气生。 走向前来我把好言奉敬，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗯。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "干什么呀？甭理我！嗳唷！气死我啦！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "嗯……"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "唯有你老爹爹，"
        },
        {
          "character": "苏三",
          "type": "回龙",
          "text": "是个大大的好人。"
        },
        {
          "character": "崇公道",
          "type": "笑",
          "text": "喔，哈哈哈……嗳唷，哈哈……"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "您瞧瞧她这个小嗓子够多柔嫩呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道学苏三唱腔。"
        },
        {
          "character": "崇公道",
          "type": "唱",
          "text": "“唯有你老爹爹是个大大的好人”"
        },
        {
          "character": "崇公道",
          "type": "笑",
          "text": "哈……啊呀哈哈。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "她气呀能把我气死，这一乐啊，我又乐活嘞！ 嘿嘿！得嘞，跟你没有气生！瞧见没有，离着省城不远了。戴上刑枷，该进城 啦！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "怎么着？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "女儿有话要与爹爹你商议商议。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "趁早说！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "爹爹呀，女儿遭此不白冤枉，监中有人不服，替我写下伸冤大状，又恐被人搜 去。望爹爹你想个法儿带了进去。少时见了都天大人，也好伸冤……哪。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "喔……这事儿啊，好办。你把它交给我，夹在枷里头。见了都天大人，是当堂 劈栓开枷，自然就递上去了，没有错儿。拿来，拿来，拿来！"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "适才父女把话论， 又恐路上有人听。 远远望见太原省，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "你走哇。"
        },
        {
          "character": "苏三",
          "type": "西皮散板",
          "text": "怕的是此去有死无生。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "唉！没有那个事，慢慢儿赶着走吧！ 喔！洪洞县的差使到喽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三、崇公道同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}