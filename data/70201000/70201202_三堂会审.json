{
  "script_id": "70201202",
  "title": "三堂会审",
  "alias": [],
  "source": "梅兰芳剧本选",
  "characters": [
    {
      "name": "苏三",
      "hangdang": "旦"
    },
    {
      "name": "王金龙",
      "hangdang": "小生"
    },
    {
      "name": "刘秉义",
      "hangdang": "老生"
    },
    {
      "name": "潘必正",
      "hangdang": "老生"
    },
    {
      "name": "崇公道",
      "hangdang": "丑"
    }
  ],
  "plot": "苏三被解至太原，山西巡按适为王金龙。王金龙查阅案卷，见有苏三谋死亲夫一案，遂偕同藩司潘必正、臬\n司刘秉义共同审理。公堂上，苏三在供词中详述前情，王金龙心情激动，不能自持，乃称病委托潘必正、刘\n秉义审理。随后审明了案情，平反冤狱。王金龙、苏三破镜重圆，终成姻眷。",
  "notes": "此剧由梅兰芳伯父梅雨田亲自传授。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王金龙上。"
        },
        {
          "character": "王金龙",
          "type": "念",
          "text": "任凭皇亲国戚，哪怕侯伯公卿。王子犯法同庶民，俱要按律而行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子上。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "本院，王金龙。蒙圣恩放我八府巡按，奉命巡查山西。也曾在洪洞县下马，查 得旧案之中，有谋杀亲夫一案，不知我那苏三，因何牵连在内？因此将人犯提 到太原复审。少时升堂，就先审此案。正是："
        },
        {
          "character": "王金龙",
          "type": "念",
          "text": "一朝身荣耀，岂能忘旧情？"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "布、按二位大人到。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "启大人：布、按二位大人到。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "有请二位大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正、刘秉义同上。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "大人出京以来，望重德斗。所到之地，百草皆生，万民无不瞻仰。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "大人出师，路过几省？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "路过三省。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "何处下马？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "洪洞县下马。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "可曾查得民情？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "也曾查得民情，内有谋死亲夫一案，不知连累多少好人在内。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "有个贤愚而不等。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "好个“贤愚而不等”。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "大人今日升堂，先审哪一案？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "自然先审谋死亲夫一案。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "大人升堂，司吏等仪门伺候。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "请！ （潘必正、刘秉义向王金龙躬身施礼，同出门，王金龙起身揖送。潘必正、刘秉义施礼，同下。王金龙回身 进门。）"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "吩咐开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王金龙下。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "是。 开门！ （门子下。四刀斧手、四龙套同上，分站两边。门子上。王金龙上，坐中间。潘必正、刘秉义同上，行礼， 两旁落座。崇公道暗上。）"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "传长解。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "传长解。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "报！ 长解告进——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道俯身进门，面里跪下。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "叩见三位大人。公文呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道递公文与门子。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "公文一份，当堂拆封。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子拆封。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "听点！长解一名崇公道。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "护解一名崇公道。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "嗯——长解是你，护解又是你，一人敢当二役，分明是一刁棍！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "请刘大人用刑！"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "来！扯下去打！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "且慢！下役有下情回禀。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "有话朝上回。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "启禀三位大人：下役好比大人胯下之驹，扬鞭就走，勒僵即住。公文之上，有 下役的名字，方敢应声；若无下役的名字，怎敢应声？请大人谅情！"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "长解回明，其刑可免。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "免！带犯妇！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "带犯妇！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道起立，至上场门口。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "犯妇走动啊！"
        },
        {
          "character": "苏三",
          "type": "内白",
          "text": "苦哇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三披枷戴锁上。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "喂呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刀斧手、龙套同喊堂威。"
        },
        {
          "character": "苏三",
          "type": "西皮散板",
          "text": "来在都察院， 举目往上观。 两旁的刽子手， 吓得我胆战心又寒。 苏三此去好有一比，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "苏三",
          "type": "西皮散板",
          "text": "鱼儿落网有去无还。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "按院大人能开脱你的死罪。"
        },
        {
          "character": "苏三",
          "type": "唱",
          "text": "啊！崇爹爹啊！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "犯妇告进。犯妇当面。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "掌起面来！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三略抬头，王金龙两次注视苏三。苏三俯首。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王金龙",
          "type": "西皮散板",
          "text": "本院抬头来观看， 犯妇果然是苏三！ 一霎时只觉得神昏意乱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王金龙昏倒堂上。"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "带了下去！ （崇公道带苏三同下。刘秉义、潘必正、四刀斧手、四龙套同下。门子示意旗牌军请医，下。医生上，童儿 背药箱跟上。医生到大帐前为王金龙诊脉，从医箱取药置桌上后，下。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "大人醒来。"
        },
        {
          "character": "王金龙",
          "type": "南梆子",
          "text": "三魂渺渺得回还。 猛然间睁开了昏花眼， 又听得堂下闹声喧。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "吩咐升堂！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "遵命。 升堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手、四龙套自两边分上。潘必正、刘秉义自两边分上，坐原位。"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "大人贵恙，还是新得的呀？还是旧有？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "乃是旧病新发。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "有此贵恙，此案不审也罢。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "朝廷大典，焉有不审之理？"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "大人真乃爱民如子啊！"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "夸奖了。 来，带犯妇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道带苏三同上。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "犯妇当面。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "犯妇你可有诉状？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "有诉状。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "呈！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "这——无！"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "嗯！本院问你可有诉状，你道有。叫你呈，又道无。是何缘故？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "刘大人用刑。"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "来！掌嘴！"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "哎呀，大人哪！犯妇有话，未曾回明。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "有话朝上回。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "是。启禀都天大人：犯妇之罪，并非自己所为，乃皮氏大娘花了银钱，将犯妇 买成一行死罪。临行起解之时，监中有人不服，替犯妇写下申冤大状，又恐被 皮氏等搜去，因此藏在刑枷之内。望求大人开一线之恩，当堂劈桎开枷。哎呀 大人哪！犯妇纵死九泉，也是甘心瞑目的了哇……"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "犯妇回明，其刑可免。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "传长解。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "长解！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "当堂劈桎开枷！"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道为苏三劈桎开枷，取出状纸呈上。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "三日后领回文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道下，门子呈状纸与王金龙。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "犯妇！将状纸上的情由一一诉来，本院开脱于你。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "都天大人容禀！"
        },
        {
          "character": "苏三",
          "type": "西皮导板",
          "text": "玉堂春跪至在都察院，"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "嗯！状纸上面，写的是苏三，你为何口称玉堂春？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "请刘大人用刑。"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "分明是一刁妇。 来！"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "看拶！"
        },
        {
          "character": "苏三",
          "type": "回龙",
          "text": "大人哪！"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "两厢退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手、四龙套同下，门子下。"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "脸朝外跪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三转面向外跪。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "“玉堂春”三字是何人与你取的名字？讲！"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "玉堂春本是公子他取的名。"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "鸨儿买你时，多大年纪？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "鸨儿买奴七岁整，"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "你在院中住了几载？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "在院中住了整九春。"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "七九一十六岁，可以开得怀了，头一个开怀的是哪一个？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "十六岁开怀是那……"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "是那王……啊！"
        },
        {
          "character": "潘必正、刘秉义",
          "type": "同白",
          "text": "“王”什么？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "王公子啊！"
        },
        {
          "character": "刘秉义",
          "type": "白",
          "text": "原来是个姓王的。他是何等样人？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "他本是吏部堂上的三舍人。"
        },
        {
          "character": "王金龙",
          "type": "白",
