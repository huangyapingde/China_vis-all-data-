{
  "script_id": "70005110",
  "title": "哭祖庙",
  "alias": [],
  "source": "汪笑侬剧本选",
  "characters": [
    {
      "name": "刘谌",
      "hangdang": "老生"
    },
    {
      "name": "刘禅",
      "hangdang": "末"
    },
    {
      "name": "崔夫人",
      "hangdang": "正旦"
    },
    {
      "name": "黄皓",
      "hangdang": "丑"
    },
    {
      "name": "二小王",
      "hangdang": "小生"
    }
  ],
  "plot": "三国末期，魏大将邓艾逼成都，北地王刘谌哭谏后主力战，不从，回府杀夫人、小王，哭祭祖庙，自刎而死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四士卒引刘谌同上。门官急上，跪。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "启禀王爷：今有邓艾围困成都，吾主明日出城纳降。特来禀知。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "回府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官下。刘谌中坐。"
        },
        {
          "character": "刘谌",
          "type": "念",
          "text": "凤子龙孙自不同，为子当孝臣当忠。腰悬三尺龙泉剑，夜作龙吟虎啸声。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "本爵，北地王刘谌。适才从教场归府，门官报道：邓艾贼暗渡阴平，破了绵竹， 围困成都。我父王听了谯周、黄皓之言，明日就要开城纳降。国家存亡，就 在今日，时势危急，不免进宫谏劝父皇一番，再作道理。两厢退下。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "邓艾贼子渡阴平， 团团围着我都城。 进宫劝谏去奏本， 背城一战退贼兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘禅上。"
        },
        {
          "character": "刘禅",
          "type": "西皮流水板",
          "text": "邓艾贼子渡阴平， 团团围着我都城。 曾命黄皓将神师请， 如何未见进宫廷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄皓上。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "叩见万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "罢了。命你去请神师进宫，可曾请到？"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "已在宫门候旨。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫上，上坐，刘禅起立，跪。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "吾乃西川土神是也。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "参见上神。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "相请吾神到来，有何见谕？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "只因邓艾贼子暗渡阴平，袭了绵竹，进围成都。那满朝文武，有愿战的，有愿 降的，纷纷不一。寡人毫无主见，不能定夺。因请上神驾临一卜，还是战的好， 还是降的好？"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "依吾神之见，你若投降邓艾，都管保你天下太平，晏安无事。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "谨遵仙命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫作神退惊醒。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "哎呀！万岁爷圣驾在此，参见万岁爷！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "黄皓，命你赏她白银千两，送她出宫去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫出，刘谌上。刘谌视女巫作切齿怒目，女巫忙走下。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "父皇一味妖巫信， 恐怕江山难保存。 撩袍端带宫门进， 见了父皇说分明。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "儿臣见驾，父皇万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "皇儿进宫，有何本奏？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "那邓艾贼子，围困成都，父皇为何坐视不理？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "非是为父坐视不理。只因满朝文武，有愿战的，有愿降的，议论纷纷，并无定 见。孤想与其劳动干戈，胜败不测，不如投降邓艾，免得涂炭生灵。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "自古以来，哪有将大好的江山，白送人家的道理？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤也曾问过神师，那神师言道：投降邓艾，都管保孤天下太平，晏安无事。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "父皇休听那妖巫一派荒诞之辞！想邓艾孤军深入，利在速战。儿臣不才，愿率 领众将背城一战，何愁邓艾不灭！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "唗！动不动就要开城战！战胜了还则罢了，若是败了，岂不是要了你老子的命 吗？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "刘谌控背忙躬身， 尊声父皇龙耳听： 妖巫之言不可信， 儿愿领兵灭敌人！"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "皇儿不必苦争论， 神师之言敢不尊？"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "千言万语父不信， 在宫中难坏小刘谌。 走向前来忙跪定， 抱着父皇放悲声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌跪。"
        },
        {
          "character": "刘谌",
          "type": "西皮二六板",
          "text": "未曾开言泪难忍， 尊声父皇仔细听： 贼邓艾孤军深入渡阴平， 团团围困锦绣的都城。 到不如父子君臣背城一战战必胜， 杀得他大小三军、马步儿郎，弃甲丢盔，败走无门。 孩儿的言语不肯信， 祖宗基业莫当轻！"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "为父龙心业已定， 午时三刻便开城。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "今日的堂堂天子尚称朕， 明朝就是亡国君。 天下后世看公论， 骂父的词儿不忍云。 若谓孩儿言不逊， 开刀先杀我小刘谌。"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "奴才说话言不逊， 胆敢当面骂天伦。 恨不得一足要尔命， 不杀你我还念父子之情。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "不必多言，出宫去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌起立。"
        },
        {
          "character": "刘谌",
          "type": "西皮摇板",
          "text": "刘谌奏本父不信， 一足踢我出宫门。 国破家亡心何忍？ 先王啊！ 我先杀妻、后杀子，再杀自身！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌下。"
        },
        {
          "character": "刘禅",
          "type": "西皮摇板",
          "text": "黄皓与孤安排定， 投降之后享太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅、黄皓同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "董敏领二小王同上。"
        },
        {
          "character": "董敏",
          "type": "二黄摇板",
          "text": "自幼净身入宫院， 算来到今数十年。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "咱家董敏。奉了夫人之命，去到御花园游玩，看天气不早，我们回去吧。"
        },
        {
          "character": "董敏",
          "type": "二黄摇板",
          "text": "手拉世子回府转， 但愿国家早治安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏领二小王同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人抱小儿上。"
        },
        {
          "character": "崔夫人",
          "type": "二黄正板",
          "text": "贼邓艾渡阴平十分危险， 眼见得围成都黎民不安。 我丈夫每日里把兵操练， 为什么这时候不见回还？"
        },
        {
          "character": "刘谌",
          "type": "内二黄导板",
          "text": "怒冲冲出离皇宫院，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌上。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "不由本爵怒冲冠！ 未曾进宫先拔剑，"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "呀，王爷！"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "这才是儿女情长、英雄气短，我的手足酸！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "呀，王爷！今日进宫，为何拔剑出鞘？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "你乃女流之辈，不问也罢！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "王爷说哪里话来？有道是：朝里有事，君臣议论；家中有事，夫妻商量。哪有 丈夫有事，妻子不问的道理？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "哎呀！夫人有所不知！今有邓艾围困成都，父皇听信谯周、黄皓之言，明日就 要开城投降，本爵意欲拔剑出鞘，殉国一死！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "哎呀！如此说来，妾请先死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人将小儿放桌上。"
        },
        {
          "character": "崔夫人",
          "type": "二黄摇板",
          "text": "将娇儿放在青玉案， 心中好似滚油煎。 人生百岁终有死， 恩爱夫妻不团圆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人撞死。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "死的好！"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "一见夫人寻短见， 心中好似乱刀剜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌将崔夫人头割下。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "忙用宝剑人头割，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌手指桌案上小儿。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "我三岁的婴儿也要被刀斩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌杀死小儿。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "手提人头出宫殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏引二小王同上。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "一见二子眼睁圆。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "哎呀！王爷呀！一言不发为何要杀那二位殿下？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "想我国破家亡，死了倒也干净！"
        },
        {
          "character": "二小王",
          "type": "同白",
          "text": "父皇要杀孩儿却也不难，容孩儿进宫，见我母亲一面，再杀不迟！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "儿要见你母亲么？儿来看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小王同惊跑圆场，刘谌杀小王甲，小王乙、董敏同跪。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "哎呀，王爷呀！杀了一个留下一个，也好接续后代香烟。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "念你苦苦哀求，出宫去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏起立，挽小王乙。刘谌赶杀小王乙。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "看二位殿下已死，国破家亡，俺不免也碰死了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏撞死。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "好一个忠心董太监， 留下美名万古传。 忙将人头一齐割， 祖庙之中祭祖先。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌手提四人头下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘禅面缚舆榇上，出城迎降下。邓艾引四士卒同上，三笑，进城同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘谌提人头持剑上，进祖庙。"
        },
        {
          "character": "刘谌",
          "type": "二黄导板",
          "text": "进祖庙不由人心中悲悼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌插剑，三次分献四人头，奠酒，拜跪，起立。"
        },
        {
          "character": "刘谌",
          "type": "三叫头",
          "text": "先皇呀！昭烈帝！皇祖哇！"
        },
        {
          "character": "刘谌",
          "type": "回龙",
          "text": "将人头供神案祭奠祖先。"
        },
        {
          "character": "刘谌",
          "type": "反二黄慢板",
          "text": "高皇帝手提着三尺宝剑， 灭强秦破暴楚才定江山。 至孝平国运衰王莽谋篡， 毒药酒鸩先帝龙驾归天。 光武爷走南阳迁都为东汉， 全仗着云台将二十八员。 传位到桓灵帝信宠太监， 黄巾贼遍地起四乡狼烟。 先皇祖灭黄巾威名振显， 宴桃园三结义牛马祭天。 遭不幸在徐州弟兄们失散， 到后来会古城才得团圆。"
        },
        {
          "character": "刘谌",
          "type": "反二黄原板",
          "text": "走荆州依刘表重兴炎汉， 不料想蔡夫人为人不贤。 跳潭溪吾皇祖身遭危险， 水镜庄夤夜间才遇高贤。 隔墙壁吾皇祖龙耳听见， 他言道伏龙凤雏得一人天下可安。 徐元直走马把诸葛亮荐， 那先生三顾请才下高山。 博望坡新野县两次交战， 用火攻烧曹兵心胆俱寒。 吾皇祖长坂坡又遭大难， 皇祖母乱军中命丧井泉。 好一个赵将军他浑身是胆， 百万军中救主还。 出重围撩铠甲低头细看， 那时节吾皇父，睡怀中，昏昏沉沉睡梦间，直到如今，睡了几十年！ 奸曹操领兵将八十三万， 玄武池练水军吞并江南。 东吴的武将们个个要战， 文部官个个的袖手旁观。 鲁子敬过江来把诸葛亮见， 那先生一帆风去到江南。 他也曾舌战群儒光辉坛站， 他也曾草船借箭在大雾间。 他也曾祭东风七星台上面， 他也曾赤壁鏖兵火烧曹瞒。 唾手儿得荆州未遂心愿， 张永年献地图才得西川。 报弟仇与东吴两家开战， 烧连营七百里火焰连天。 兵败在白帝城身遭大限，吾的先皇祖哇！ 才知道得江山创业艰难。 贼邓艾渡阴平十分的冒险， 吾皇父闻此言心胆皆寒。 满朝的文武将不敢开战， 老谯周在一旁一味地谈天。 有本爵闻此事心忙意乱， 进皇宫双膝跪倒在父皇前。 吾言道：势已危急，到不如君臣父子、背城一战， 再不然，学当年、破阵李左车，坚壁清野、计出万全。 贼邓艾孤军深入利在速战， 那时节，吾父子们，烧了成都、退守深山。 率领着，军民人等、文武百官、再围都城战， 贼邓艾，在成都、他进也不能进、退也不能退、战也不能战、守也不能守、既 无有粮、又无有草、三军自乱、杀得他片甲不还！ 吾父皇不听儿良言相劝， 反将我踢出宫满面羞惭。 众弟兄一个个无颜相见， 莫奈何杀妻子祭奠祖先。 吾皇祖在天灵可曾看见？ 念皇孙，国又破、家又亡、妻又杀、吾的子又斩、以身殉国、倒不如死也心甘！ 想起了先皇祖令人悲叹， 叹先皇，数十年、南征北战、东挡西杀、昼夜杀砍、马不停蹄、才得来这三分 帝鼎、一隅的江山、他断送在眼前！ 我皇父太昏庸不听良谏， 每日里在深宫苟且偷安。 投降后何面目把臣民来见， 九泉下见先皇有何话言。 想当年让成都刘璋好惨， 到如今吾皇父，焚符弃玺、反缚舆榇、率领着文武百官、军民人等、匍匐尘埃、 投那邓艾，比刘璋更加可怜！ 莫不是我汉家气数已满， 才知晓创业难守成更难。 在祖庙哭得吾肝肠寸断，肝肠寸断！"
