{
  "script_id": "70005104",
  "title": "博浪锥",
  "alias": [],
  "source": "汪笑侬剧本选",
  "characters": [
    {
      "name": "张良",
      "hangdang": "武生"
    },
    {
      "name": "苍海公",
      "hangdang": "净"
    },
    {
      "name": "秦始皇",
      "hangdang": "净"
    }
  ],
  "plot": "秦时，张良蓄谋反秦，遣友苍海公刺杀秦始皇未遂，海公慷慨就义。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张良武装佩剑上。"
        },
        {
          "character": "张良",
          "type": "引子",
          "text": "堂堂好男子，最好沙场死。死只一回勿浪死，不报国仇誓不止！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "唉，秦始皇吓！你并吞六国，安坐江山，也就罢了！还要造长城，筑阿房，焚 书坑儒。百姓们说了你半个暴字，就立刻性命难保！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良拔剑怒视。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "我张良若不设法除你，也没有人心天理了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良收剑。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "前日见了苍海公，可敬他不顾自己身体，情愿为百姓除害，我不免助他一臂之 力，一为百姓除害，二为韩国报仇！好不快活也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良走圆场。"
        },
        {
          "character": "张良",
          "type": "西皮慢板",
          "text": "可恨那秦嬴政昏荒无道， 他本是西戎种混乱中朝。 灭六国篡江山位登大宝， 变封建为郡县起祸根苗。 把公产当私财行同强盗， 把人民当奴隶滥逞英豪。 筑长城一万里到处骚扰， 阿房宫三百里内藏娇娆。 焚了书坑了儒种种不道， 若民间有私议性命难逃。 他还想传万世"
        },
        {
          "character": "张良",
          "type": "西皮快板",
          "text": "天命当保， 他还想成神仙快乐逍遥。 只恨我穷书生身微力小， 空怀着报仇志昼夜心焦。 望国民起义师恭行天讨， 到如今还不见草泽英豪。 好让那虎狼秦多行凶暴， 只苦了众百姓受尽煎熬。 我想把好乾坤重新构造， 我想把专制君万剐千刀。 本是我祖国仇理应当报， 恨不能学专诸刺杀王僚！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内嚷。"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "秦皇帝来到，还不早躲么！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良作惊。"
        },
        {
          "character": "张良",
          "type": "西皮摇板",
          "text": "猛听得众百姓纷纷嚷道， 待鄙人走向前细问根苗。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "诸位请了！所嚷何事？"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "秦皇帝又东游泰山，昨日路过阳武，就此驻驿了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良作惊喜。"
        },
        {
          "character": "张良",
          "type": "笑",
          "text": "呵哈哈哈哈！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "我正想锄刈此贼，无法可施。不料他竟自先来送死，真令我好欢喜也！"
        },
        {
          "character": "张良",
          "type": "西皮摇板",
          "text": "我正想起义兵诛锄无道， 谁料他入罗网插翅难逃。 我不免访苍海把细情说了， 替祖国报公仇就在今朝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良走圆场。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "来此已是苍海公家，不免上前叩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良叩门。苍海公上。"
        },
        {
          "character": "苍海公",
          "type": "念",
          "text": "眼中黑白要分明，天谴魔君杀不平。"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "外面何人叩门？"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "我是张良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苍海公开门。"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "原来是子房兄！请里面谈话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良、苍海公同入。苍海公关门。张良、苍海公分坐。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "苍海公，"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "子房兄。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "我已打听明白，那暴君明日从博浪沙经过，请公就在此地行事如何？"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "子房兄见教极是，但是子房兄须要躲避才是啊。"
        },
        {
          "character": "苍海公",
          "type": "西皮摇板",
          "text": "尊一声张公子且宽怀抱， 你赶紧整行装事先奔逃。 但愿我此一去大功成了， 且免得事不成遗累英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良执苍海公手，起立。"
        },
        {
          "character": "张良",
          "type": "西皮摇板",
          "text": "尊一声苍海公你见识太小， 自古道共患难与子同胞。 你心中休得要自寻烦恼， 我与你早已订生死之交。"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "公子差矣！"
        },
        {
          "character": "苍海公",
          "type": "西皮摇板",
          "text": "我非是将公子有心取笑， 我要想留一个恢复根苗。 要知道我此去凶多吉少， 为什么要同去枉死一遭。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "既然如此，即当遵命了！苍海公在上，受我一拜！"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "我也有一拜！"
        },
        {
          "character": "苍海公",
          "type": "西皮摇板",
          "text": "苍海公在尘埃将身拜倒， 生辞别张子房盖世英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良起立执手。"
        },
        {
          "character": "苍海公",
          "type": "西皮摇板",
          "text": "倘若是我此去事机不妙， 逃走了这魔道世外逍遥。 还望你施妙计将仇来报， 莫把这弥天恨抛在九霄。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "勇士前往，但请放心。"
        },
        {
          "character": "张良",
          "type": "西皮摇板",
          "text": "秦始皇灭六国冤仇非小， 为天下除此贼天日昭昭。 我若是昧良心忍辱不报， 我死在九泉下万劫难逃。"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "既是如此，公子就请起程。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "遵命了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良更衣。家院上，牵马。张良揖别。"
        },
        {
          "character": "张良",
          "type": "西皮摇板",
          "text": "辞别了苍海公把路行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良上马，哭。"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "子房好男子，为何作此儿女之态？"
        },
        {
          "character": "张良",
          "type": "西皮摇板",
          "text": "等候了苍海公成就大功！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良催马，下。"
        },
        {
          "character": "苍海公",
          "type": "笑",
          "text": "呵哈哈哈哈！"
        },
        {
          "character": "苍海公",
          "type": "西皮摇板",
          "text": "听一声秦嬴政位离大宝， 我这里霎时间怨气全消。 我想他一年年淫乐怠傲， 扰害得众百姓啼哭嚎啕。 想是他恶满盈天算已到， 今日里要在我锥下……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苍海公观锥。"
        },
        {
          "character": "苍海公",
          "type": "西皮摇板",
          "text": "狗命难逃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苍海公收铁锥，下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四御林军同上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "咦咦咦咦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦始皇戴王帽、穿黄龙蟒袍上。"
        },
        {
          "character": "秦始皇",
          "type": "引子",
          "text": "竹帛烟消，兵气销。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦始皇坐。"
        },
        {
          "character": "秦始皇",
          "type": "念",
          "text": "法律由专断，威权种祸胎。生不访家贼，死上断头台。"
        },
        {
          "character": "秦始皇",
          "type": "白",
          "text": "朕，秦始皇。因前日百姓不服，私下议论纷纷，所以朕特颁一条极严法律：倘 若有人，私下议论，立刻问斩，以免后患。又观东南王气正盛，所以命驾东巡， 察看那里的民情，这正是为君的难啊！"
        },
        {
          "character": "秦始皇",
          "type": "西皮原板",
          "text": "百姓们不知是朕即国家， 朕立意除净那民党萌芽。 有爪牙和心腹护卫孤家， 又何怕有刺客在博浪沙。"
        },
        {
          "character": "秦始皇",
          "type": "白",
          "text": "唉！话虽如此，但是古人说得好，有备无患，方是这个主意呵！"
        },
        {
          "character": "秦始皇",
          "type": "西皮摇板",
          "text": "叫一声内侍臣，"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "秦始皇",
          "type": "西皮摇板",
          "text": "安排副车， 张姓冠李姓戴莫要喧哗。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苍海公穿短衣、腰插铁锥上。"
        },
        {
          "character": "苍海公",
          "type": "念",
          "text": "准备窝弓擒猛虎，安排香饵钓鳌鱼。"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "来此已是博浪沙，远听得车马声响，不免登高一望。 （苍海公登高探望。四太监、四御林军同上，车夫推假秦始皇同上。苍海公跳下，拔锥打杀二太监，打死假 秦始皇。四御林军同拔刀相打，苍海公被擒。众人同下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引秦始皇同上。"
        },
        {
          "character": "秦始皇",
          "type": "西皮摇板",
          "text": "若非巧计安排定， 已作黄泉新鬼魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦始皇里位坐。二御林军同上。"
        },
        {
          "character": "二御林军",
          "type": "同白",
          "text": "启奏万岁：刺客拿着了！"
        },
        {
          "character": "秦始皇",
          "type": "白",
          "text": "绑上来！"
        },
        {
          "character": "二御林军",
          "type": "同白",
          "text": "绑上殿来！"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二御林军押苍海公背绑同上。"
        },
        {
          "character": "苍海公",
          "type": "西皮摇板",
          "text": "悲哉秦人真虎狼， 欺侮六国囚侯王。 亦知兴废古来有， 但恨不见秦先亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二御林军同跪。"
        },
        {
          "character": "二御林军",
          "type": "同白",
          "text": "刺客解到。"
        },
        {
          "character": "秦始皇",
          "type": "白",
          "text": "大胆刺客，你受何人主使，胆敢前来行刺？从实招来，免尔一死。"
        },
        {
          "character": "苍海公",
          "type": "白",
          "text": "尔这暴君，人人想食尔肉！我为民除害，有何人主使？有也不向尔说！你杀我 一人，也难安安稳稳，长保你金銮殿上这把金交椅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦始皇气。"
        },
        {
          "character": "秦始皇",
          "type": "白",
          "text": "好毒骂啊！啊哈，好毒骂呀！御林军与朕剁作肉泥骨酱！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "御林军拔刀，苍海公撞柱自死。御林军举刀乱砍。"
        },
        {
          "character": "御林军",
          "type": "同白",
          "text": "刺客死了！"
        },
        {
          "character": "秦始皇",
          "type": "白",
          "text": "这人是一夫之勇，暗中必有主使。左右与朕大搜十日！"
        },
        {
          "character": "御林军",
          "type": "同白",
          "text": "遵旨！"
        },
        {
          "character": "秦始皇",
          "type": "白",
          "text": "斩草除根，方免后患！呵哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张良急上。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "闻得苍海公已死，暴君命人各处搜杀主使之人，这、这、这、这便如何是好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良低头想。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "哈哈有了！我有故人项伯，在下邳居住，不免到他家躲避便了！唉！苍海公呵！ 苍海公！我误你的命了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良向空拜。"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "起驾。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "这暴、暴、暴、暴……"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良慌忙逃下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}