{
  "script_id": "70005101",
  "title": "战蚩尤",
  "alias": [],
  "source": "汪笑侬剧本选",
  "characters": [
    {
      "name": "黄帝",
      "hangdang": "老生"
    },
    {
      "name": "蚩尤",
      "hangdang": "净"
    },
    {
      "name": "元后",
      "hangdang": "旦"
    }
  ],
  "plot": "蚩尤背反黄帝，大战于涿鹿之野，势甚猛，黄帝军不敌。帝妃元后献造战车之策，两军对敌时，并请来雾神，\n战车在浓雾中摧毁蚩尤军营，黄帝军大胜。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "歧伯、雷公、大挠、祝融同上。"
        },
        {
          "character": "歧伯",
          "type": "念",
          "text": "九天阖闾开宫殿，"
        },
        {
          "character": "雷公",
          "type": "念",
          "text": "万国衣冠拜冕旒。"
        },
        {
          "character": "大挠",
          "type": "念",
          "text": "日色才临仙掌动，"
        },
        {
          "character": "祝融",
          "type": "念",
          "text": "香烟欲傍衮龙浮。"
        },
        {
          "character": "歧伯",
          "type": "白",
          "text": "我乃左丞相歧伯。"
        },
        {
          "character": "雷公",
          "type": "白",
          "text": "右丞相雷公。"
        },
        {
          "character": "大挠",
          "type": "白",
          "text": "大司徒大挠。"
        },
        {
          "character": "祝融",
          "type": "白",
          "text": "大司马祝融。"
        },
        {
          "character": "歧伯",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "雷公、大挠、祝融",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "歧伯",
          "type": "白",
          "text": "今日我主早朝，大家在此伺候。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、黄帝同上。"
        },
        {
          "character": "黄帝",
          "type": "引子",
          "text": "凤巢阿阁，麟游郊原。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "歧伯、雷公、大挠、祝融同参拜。"
        },
        {
          "character": "黄帝",
          "type": "念",
          "text": "茫茫宇宙远无疆，朗朗乾坤照万方。海晏河清称盛世，民康物阜乐安邦。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "朕，轩辕皇帝在位。自登基以来，创立甲子，振兴文化，制造兵戈以修武备， 政教大昌，天下太平。昨晚仰观天象，彗星出现北方，恐不免有刀兵之乱。今 日早朝，不免将此预兆宣与满朝文武，同商应付之策。诸位爱卿！"
        },
        {
          "character": "歧伯、雷公、大挠、祝融",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "侍立朝班，朕有言说与众卿听者！"
        },
        {
          "character": "黄帝",
          "type": "二黄原板",
          "text": "自从朕创基业普天同庆， 命大挠作甲子文化流行。 有歧伯和雷公灵柩厘定， 采医药疗疾病救护人群。 蚩尤氏他把那兵戈整顿， 为的是防苗人率众来侵。 昨夜晚观天象彗星入境， 但只怕边塞地要起刀兵。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "众卿，那彗星出现北方，恐刀兵难免，众卿以为如何？"
        },
        {
          "character": "祝融",
          "type": "白",
          "text": "臣祝融有本上奏。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "祝爱卿有本，平身奏来！"
        },
        {
          "character": "祝融",
          "type": "白",
          "text": "谢万岁！自从我主命那北伯侯蚩尤创造干戈，不想他擅自征伐，横行无忌，去 年灭了九国诸侯，今年又并吞小国十二，昨接密报，此贼正在秣马厉兵，大有 进攻涿鹿之势，是此贼叛形已著，彗星即应他身，若不及早消除，诚恐患生不 测！"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "呜呼呀！"
        },
        {
          "character": "黄帝",
          "type": "西皮摇板",
          "text": "那蚩尤恃强权兴兵作乱， 全不想众黎民苦受颠连。 金殿上点人马亲自出战， 为只为灭反贼早把民安。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "众卿传朕旨意，点齐人马，择定黄道良辰，随朕御驾亲征者！"
        },
        {
          "character": "歧伯、雷公、大挠、祝融",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "山都、烈侯同上。"
        },
        {
          "character": "山都、烈侯",
          "type": "引子",
          "text": "兵精将广，谁人敢挡。"
        },
        {
          "character": "山都",
          "type": "白",
          "text": "某，大将山都是也。"
        },
        {
          "character": "烈侯",
          "type": "白",
          "text": "某，大将烈侯是也。"
        },
        {
          "character": "山都、烈侯",
          "type": "同白",
          "text": "我主升帐，此处伺候。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马甲引蚩尤同上。"
        },
        {
          "character": "蚩尤",
          "type": "引子",
          "text": "巧夺天功，谋大业，何患不成。"
        },
        {
          "character": "蚩尤",
          "type": "念",
          "text": "奉命造干戈，暗藏兵器多。盔甲人难挡，要把尊位夺。"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "孤，蚩尤是也。前在黄帝驾前为臣，幼年学得冶金之法，因此黄帝命我采葛卢 山之铜，创造干戈，是我暗制盔甲多副，希图革命，两年以来吞并二十余国， 正是兵强将勇，地大人众，一旦兵占涿鹿，那黄帝江山，即刻到了我手。 二位将军，人马可曾点齐？"
        },
        {
          "character": "山都、烈侯",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "择定吉日就要起兵！"
        },
        {
          "character": "蓝旗",
          "type": "内白",
          "text": "报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蓝旗上，跪报。"
        },
        {
          "character": "蓝旗",
          "type": "白",
          "text": "启禀我主，黄帝亲率大兵前来征讨，前锋离此不远，请令定夺。"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "蓝旗",
          "type": "白",
          "text": "咋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蓝旗下。"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "呜呼呀！孤家正待进兵涿鹿，不想昏王自来送死。 二将何在！"
        },
        {
          "character": "山都、烈侯",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "与孤竖立旗纛，率领人马迎杀涿鹿，不得有误。 昏君呀昏君！管叫你来时容易去时难，猛虎如何擅出山。 杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、歧伯、雷公、大挠、祝融、黄帝同上。"
        },
        {
          "character": "黄帝",
          "type": "念",
          "text": "兵临涿鹿城，要把蚩尤擒。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "孤家率领大兵征讨蚩尤，人马进据涿鹿，适才探马报到，那蚩尤果然带领叛兵， 前来迎敌，如此胆大妄为，实属罪不容赦，只得督军进剿，扫除余孽。 众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄帝、蚩尤自两边分上。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "蚩尤！好一个蚩尤！朕命你镇守边关，为何无故造反？"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "昏君，你终日修仙学道，不理朝政，不配为君，你今日到此休想回去！"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "逆臣胡言！"
        },
        {
          "character": "黄帝",
          "type": "唱",
          "text": "自盘古立纲常到了如今， 哪见过为臣子敢来叛君。 孤劝你弃甲兵早早归顺， 免得孤捉着你剥皮抽筋！"
        },
        {
          "character": "蚩尤",
          "type": "唱",
          "text": "自古帝王人有份， 说什么臣子来叛君。 我的计划早已定， 不得江山不甘心。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "一派胡言，众卿与朕擒了此贼。 （黄帝、蚩尤自两边分下。歧伯、雷公、大挠、祝融、山都、烈侯同开打，歧伯、雷公、大挠、祝融同败下。 蚩尤、四马甲同上。）"
        },
        {
          "character": "马甲",
          "type": "念",
          "text": "鹰鹞擒燕雀，必定得胜回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "山都、烈侯同上。"
        },
        {
          "character": "山都、烈侯",
          "type": "同白",
          "text": "启禀我主，黄帝大败而逃。"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "天色已晚，传令不必追赶，收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引元后同上。"
        },
        {
          "character": "元后",
          "type": "西皮原板",
          "text": "我主爷领雄兵扫灭贼寇， 全凭着文共武百万貔貅。 那蚩尤他本是用兵妙手， 怕只怕我主爷不是对头。 祝上苍保我主凯歌早奏， 准备着满朝臣共贺龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "元后坐。"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "哀家，元妃西陵氏嫘祖是也。因蚩尤作乱，圣上统领大兵前去征讨，闻说那蚩 尤生来足智多谋，先后并吞二十余国，声势浩大，兵精粮足，我主此去胜败有 些难测，已差宫人前去探问，为何不见到来，思想起来好不烦闷人也！"
        },
        {
          "character": "元后",
          "type": "西皮摇板",
          "text": "可恨那蚩尤贼一时狂逞， 无故地起人马挑起战争。 只顾他逞野心争强斗胜， 却不想丧天理残害生灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女上，跪奏。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "启禀国母千岁：奴婢探得前宫消息，圣上出兵涿鹿，与那蚩尤几次交战，皆因 蚩尤盔坚甲固，难以取胜。如今在休兵防守，另图攻取之策呢！"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "啊，果有此事！我想那蚩尤全凭利器制胜，若不改变战略，恐怕此贼难平。哀 家自幼曾受过仙人传授，能呼风唤雨，驱鬼使神，此时正该助我主灭贼成功， 不免星夜赶奔涿鹿，见了我主再作道理。 宫娥们！前宫传旨：预备一支人马，随哀家赶赴涿鹿，不得有误！"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "与哀家更衣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、太监引黄帝同上。"
        },
        {
          "character": "黄帝",
          "type": "唱",
          "text": "那蚩尤戴铜盔护心铁镜， 沙场上一见了胆战心惊。 有长枪和短刀不能取胜， 看起来一时间此贼难平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启万岁：娘娘驾到。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "国母到来必有大事，快快召她进见。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "圣上有旨：国母进见。"
        },
        {
          "character": "元后",
          "type": "内白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "元后上。"
        },
        {
          "character": "元后",
          "type": "念",
          "text": "袖中藏韬略，特来佐圣明。"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "参见吾皇万岁！"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "皇后少礼请坐。"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "皇后不在宫中，到此何事？"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "昨日宫中得报，蚩尤用利器战胜吾皇，臣妾放心不下，故而前来问讯。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "那蚩尤十分凶恶，孤王战他不过，如何是好？"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "万岁，那贼盔甲虽然能避刀剑，就该用马助战。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "用马驾车冲锋猛进，那些盔甲士兵必被一齐荡倒。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "马车冲阵虽然不难，但不知此车如何造法？"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "臣妾有图在此，请我主一观！"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "待朕看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄帝看图。"
        },
        {
          "character": "黄帝",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "真妙策也！"
        },
        {
          "character": "黄帝",
          "type": "西皮摇板",
          "text": "贤梓童虽女流才学甚广， 用冲车制盔甲计划周详。 扶孤家这江山亏你力量， 任凭他铁甲兵怎能抵挡。"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "陛下用此冲车，必须借着大雾，才免敌人见了躲避。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "哎呀，这初秋天气，哪来大雾！"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "陛下非知，臣妾幼年得逢九天玄女，授以呼风唤雨，使鬼驱神之法。设坛七日 大雾立见。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "哎呀，贤妃有此神妙之法，何愁大事不成。皇后听旨！"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "设坛祭雾，助朕平贼，不得有误！"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "元后下。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "内臣！宣歧伯、雷公进见。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "歧、雷二臣进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "歧伯、雷公同上。"
        },
        {
          "character": "歧伯、雷公",
          "type": "同念",
          "text": "忽听圣旨宣，联步到阶前。"
        },
        {
          "character": "歧伯",
          "type": "白",
          "text": "臣歧伯，"
        },
        {
          "character": "雷公",
          "type": "白",
          "text": "雷公，"
        },
        {
          "character": "歧伯、雷公",
          "type": "同白",
          "text": "见驾，愿吾皇万岁。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "平身！朕命你二人照此图样赶造冲车千辆，钦此！"
        },
        {
          "character": "歧伯、雷公",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岐伯、雷公同下。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "内臣传旨：暂将免战牌挂起，众将官只许防守，不许出战，违令者斩！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "圣上有旨：免战牌高悬，众将只许防守，不准出战，违令者斩！"
        },
        {
          "character": "歧伯、雷公、大挠、祝融",
          "type": "内同白",
          "text": "咋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "老宫役、少宫役同上。"
        },
        {
          "character": "老宫役",
          "type": "念",
          "text": "有道是好铁不打钉，"
        },
        {
          "character": "少宫役",
          "type": "念",
          "text": "好人不当兵，"
        },
        {
          "character": "老宫役",
          "type": "念",
          "text": "如今晚好铁打了钉，"
        },
        {
          "character": "少宫役",
          "type": "念",
          "text": "好人当了兵。"
        },
        {
          "character": "老宫役",
          "type": "白",
          "text": "伙计，适才黄帝有旨，高设神坛，预备娘娘作法，好灭叛贼蚩尤。现在神坛搭 妥，就请娘娘登坛作法吧。"
        },
        {
          "character": "少宫役",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "老宫役、少宫役",
          "type": "同白",
          "text": "神坛香案备好，请娘娘升坛！"
        },
        {
          "character": "元后",
          "type": "内二黄导板",
          "text": "在金殿领了万岁命，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "元后上。"
        },
        {
          "character": "元后",
          "type": "回龙",
          "text": "设神坛祭大雾要退贼兵。"
        },
        {
          "character": "元后",
          "type": "唱",
          "text": "来至在神坛下将身立定， 叫宫娥看香酒来把衣更。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "香酒备妥，请娘娘更衣。"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "元后过场，开门更衣毕。"
        },
        {
          "character": "元后",
          "type": "唱",
          "text": "穿罢了仙衣神坛站定， 忙把宝剑空中擎。 又把那聚神咒口中默诵， 高擎水酒喷雾云。 管叫那掌雾神坛前听令， 但等他降临时细说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雾神上。"
        },
        {
          "character": "雾神",
          "type": "白",
          "text": "娘娘唤来小神有何法旨？"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "雾神听旨：七日以后要你在涿鹿之野。布满大雾，不得有误！"
        },
        {
          "character": "雾神",
          "type": "白",
          "text": "遵法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雾神下。"
        },
        {
          "character": "元后",
          "type": "白",
          "text": "祭雾已毕，侍儿回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人下同。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引黄帝同上。"
        },
        {
          "character": "黄帝",
          "type": "念",
          "text": "免战牌高悬，安排巧机关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "歧伯、雷公同上。"
        },
        {
          "character": "歧伯、雷公",
          "type": "同白",
          "text": "冲车已经造齐，特来启奏。"
        },
        {
          "character": "黄帝",
          "type": "白",
          "text": "如此甚好，传朕旨意：今夜晚上，三漏用饭，五漏出兵，一涌前进，不得有误！"
        },
        {
          "character": "歧伯、雷公",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蚩尤领山都、烈侯、四马甲同上。"
        },
        {
          "character": "蚩尤",
          "type": "念",
          "text": "心惊肉战，为着哪般。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兵卒上。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "报！黄帝大兵一直杀进大营来了！"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "好生厉害，二将军杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雾神执旗上，放雾，下。"
        },
        {
          "character": "蚩尤",
          "type": "白",
          "text": "好奇怪呀！孤家正要进兵，忽然天降大雾，想必天助我成功。 众将官！冒雾冲杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大开打。冲车上冲。蚩尤、盔兵自相践踏，众人擒蚩尤同下。"
        },
        {
          "character": "歧伯、雷公、大挠、祝融",
