{
  "script_id": "70005112",
  "title": "刀劈三关",
  "alias": [],
  "source": "汪笑侬剧本选",
  "characters": [
    {
      "name": "雷万春",
      "hangdang": "老生"
    },
    {
      "name": "郭章",
      "hangdang": "净"
    },
    {
      "name": "万花公主",
      "hangdang": "旦"
    }
  ],
  "plot": "唐，郭章沟通辽国，假传圣旨，谋害大将雷万春。雷万春捉住奸细，搜出书信，拘押了郭章，率兵连克三关，\n逼辽投降。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "人行千里路，马过万重山。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "俺，辽邦下书人是也。今奉我国狼主之命，与郭相前去下书。就此马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引郭章同上。"
        },
        {
          "character": "郭章",
          "type": "引子",
          "text": "调和鼎鼐，位列三台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭章坐。"
        },
        {
          "character": "郭章",
          "type": "念",
          "text": "身为当朝一品臣，满朝文武谁不尊。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "老夫郭章，唐室驾前为臣。只因西辽邦，与老夫常有书信来往，欲夺唐室天下， 里应外合，这江山岂不是唾手而得。 来！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同允。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "来此已是郭相府。门上哪位在？"
        },
        {
          "character": "手下",
          "type": "白",
          "text": "哪里来的？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "下书人求见相爷。"
        },
        {
          "character": "手下",
          "type": "白",
          "text": "少站。 启相爷：下书人求见。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "叫他进见。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "参见相爷。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "罢了！奉何人所差？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "奉狼主之命，前来下书。相爷请看！"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子呈书。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "待老夫拆开观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "回复你家狼主，修书不及，照书行事。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同允。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "打道上朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金殿。四太监、大太监同上。〖小开门〗。唐僖宗上。"
        },
        {
          "character": "唐僖宗",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "唐僖宗",
          "type": "念",
          "text": "金阙当头紫阁重，仙人掌上玉芙蓉。太平天子朝元日，五色祥云驾六龙。"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "孤，大唐天子僖宗在位。自登基以来，风调雨顺，国泰民安，今当设立早朝。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "展放龙门。"
        },
        {
          "character": "郭章",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭章上。"
        },
        {
          "character": "郭章",
          "type": "念",
          "text": "手捧假战表，上殿奏当朝。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "臣，郭章见驾，吾皇万岁！"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "今有西辽邦，打来战表，我主龙目御览。"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "待孤看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "哦呵呀！原来西辽邦打来战表，要与孤王争斗江山。卿家何计安哉？"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "启奏万岁，何不命雷万春挂帅，带领三子，镇守三关，料无妨碍。"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "替孤传旨：宣雷万春上殿。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "领旨！ 万岁有旨：宣雷万春上殿。"
        },
        {
          "character": "雷万春",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷万春上。"
        },
        {
          "character": "雷万春",
          "type": "念",
          "text": "怀揣忠义胆，保主锦江山。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "臣雷万春见驾，吾皇万岁。"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "万万岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "今有西辽邦打来战表，要与孤争斗江山，故命卿挂帅，征战西辽。未知卿家意 下如何？"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "食王爵禄，当报王恩。"
        },
        {
          "character": "唐僖宗",
          "type": "白",
          "text": "好！就命卿带领三子，并与陈休为随营参谋，平定番邦。得胜回朝，另加升赏。 领旨下殿，退班！"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "请驾回宫！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "臣领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐僖宗、大太监、四太监同下。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "将军此番新挂帅印，真乃可喜可贺！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "多蒙相爷提拔！"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "请元帅回府点兵，待老夫明日长亭饯行。相见便了！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "雷某有何得能？敢劳相爷长亭饯行！"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "明日长亭相见便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷万春下。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "且住！待老夫明日长亭与他饯行之时，带了蒙汗药酒，将他灌醉，再为图谋。 雷万春啊，雷万春啊！管叫你明枪容易躲，暗箭最难防！ 来！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "打道回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭章下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "雷一振、雷一胜、雷一鸣同上。〖粉蝶儿〗雷一振、雷一胜、雷一鸣同起霸。"
        },
        {
          "character": "雷一振、雷一胜、雷一鸣",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "雷一振",
          "type": "白",
          "text": "雷一振。"
        },
        {
          "character": "雷一胜",
          "type": "白",
          "text": "雷一胜。"
        },
        {
          "character": "雷一鸣",
          "type": "白",
          "text": "雷一鸣。"
        },
        {
          "character": "雷一振",
          "type": "白",
          "text": "父帅升帐，你我两厢伺候。"
        },
        {
          "character": "雷一胜、雷一鸣",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点。八龙套、四上手、四下手、黑马夫、白马夫、陈休、雷万春同上。雷万春上高台。"
        },
        {
          "character": "雷万春",
          "type": "念",
          "text": "威风凛凛上将台，职受金章拜御街。儿郎个个分左右，雄兵猛将两边排。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "老夫，雷万春。只因西辽打来战表，要与我主争斗江山。圣上挂我为帅，征战 西辽。 众家儿郎！"
        },
        {
          "character": "雷一振、雷一胜、雷一鸣",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "雷一振、雷一胜、雷一鸣",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "三关去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "郭相到。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手抬酒同上，郭章上。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "相爷，本帅有何得能，敢劳相爷长亭饯行？"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "岂敢！将酒摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭章斟酒，雷万春饮酒。"
        },
        {
          "character": "雷万春",
          "type": "西皮原板",
          "text": "我主爷坐江山风调雨顺， 全凭着文武臣扶保乾坤。 请相爷且宽心来把酒饮！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "雷万春",
          "type": "西皮原板",
          "text": "头又晕眼又花所为何情？"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "啊，元帅，为何这等模样？"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "相爷有所不知，霎时头晕眼花，不知是何缘故？"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "既然如此，元帅不去也罢。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "若不出兵，岂不是违背圣命？"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "圣上降罪，老夫与你担待。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "多谢相爷。 一振听令！"
        },
        {
          "character": "雷一振",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "把守头关。"
        },
        {
          "character": "雷一振",
          "type": "白",
          "text": "得令！带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引雷一振同下。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "一胜听令！"
        },
        {
          "character": "雷一胜",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "把守二关。"
        },
        {
          "character": "雷一胜",
          "type": "白",
          "text": "得令！带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引雷一胜同下。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "一鸣听令！"
        },
        {
          "character": "雷一鸣",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "把守三关。"
        },
        {
          "character": "雷一鸣",
          "type": "白",
          "text": "得令！带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引雷一鸣同下。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "元帅且请回府养息去罢。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "如此，告辞了。"
        },
        {
          "character": "雷万春",
          "type": "西皮摇板",
          "text": "叫人来搀我回府门， 但愿病恙早离身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套搀雷万春同下。"
        },
        {
          "character": "郭章",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "郭章",
          "type": "西皮摇板",
          "text": "老儿中了我的计， 不死也要脱层皮。"
        },
        {
          "character": "郭章",
          "type": "白",
          "text": "来！打道回府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引郭章同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四下手、金生里、银生里自下场门同上。八龙套、四下手、万花公主、羌洪同上。〖点绛唇〗。羌洪坐高"
        },
        {
          "character": null,
          "type": "text",
          "text": "台。）"
        },
        {
          "character": "羌洪",
          "type": "念",
          "text": "孤家兴兵谁敢挡？要夺唐室锦家邦。"
        },
        {
          "character": "万花公主",
          "type": "念",
          "text": "冲锋对垒无人挡，全凭法宝把人伤。"
        },
        {
          "character": "羌洪",
          "type": "白",
          "text": "孤家，西辽王羌洪是也。"
        },
        {
          "character": "万花公主",
          "type": "白",
          "text": "咱家，万花公主是也。"
        },
        {
          "character": "金生里、银生里",
          "type": "同白",
          "text": "臣，（金生里）（银生里），参见狼主。"
        },
        {
          "character": "羌洪",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "金生里、银生里",
          "type": "同白",
          "text": "喳。"
        },
        {
          "character": "羌洪",
          "type": "白",
