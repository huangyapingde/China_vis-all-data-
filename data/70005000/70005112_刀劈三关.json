          "character": "雷万春",
          "type": "白",
          "text": "带上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童押报子同上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "奸细带到！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "呔！何方奸细？擅敢前来窥探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "哎呀元帅！小人不是奸细，元帅不必多疑。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "两旁搜来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童搜报子。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "启元帅：身旁搜出一封书信。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "来，押下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童押报子下。"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "且住！原来奸贼勾通番邦，暗害与我。不免去到相府，与老贼辩理。 马童，带路郭府。"
        },
