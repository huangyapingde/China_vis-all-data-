        {
          "character": "雷万春",
          "type": "叫头",
          "text": "郭章啊！郭章！"
        },
        {
          "character": "雷万春",
          "type": "白",
          "text": "无有此事，还则罢了！若有此事，定不与你甘休！"
        },
        {
          "character": "马童",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "小人拿住番邦奸细。"
        },
