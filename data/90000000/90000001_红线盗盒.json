{
  "script_id": "90000001",
  "title": "红线盗盒",
  "alias": [],
  "source": "名家藏本、演出本",
  "characters": [
    {
      "name": "红线",
      "hangdang": "旦"
    }
  ],
  "plot": "魏博节度使田承嗣欲吞并潞州节度使薛嵩之地，薛嵩甚为忧虑。薛嵩侍儿红线有剑术，自告奋勇往田承嗣处\n探听，给予警告。值田承嗣睡卧，红线欲行刺，后改盗田承嗣金盒而返。田承嗣遣兵追之，又为红线所败。\n红线献盒于薛嵩，薛嵩乃修函附盒还与田承嗣。田承嗣大惊，知薛嵩部有强将，非敌手，乃与薛嵩修好。",
  "notes": "见唐杨巨源《红线传》，明梁伯龙《红线女》杂剧及《双红记》传奇。梅兰芳编演。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "【第三场：行路】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红线上。"
        },
        {
          "character": "红线",
          "type": "念",
          "text": "三尺青锋吐翠烟，等闲粉黛总无缘。一心自有匡时策，却笑须眉不敢前。"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "俺，红线。奉谪天曹，投身薛府。适闻田承嗣居心叵测，欲吞并潞洲，为此今 夜驾起祥云，观其动静。看月明风细，夜色清凉，须速走遭者！"
        },
        {
          "character": "红线",
          "type": "西皮导板",
          "text": "谯楼上打三更月明人静，"
        },
        {
          "character": "红线",
          "type": "西皮原板",
          "text": "按吴钩紧锦带独自思忖： 想当日，想当日天曹中焚香击磬， 谪红尘，谪红尘投薛府奴婢藏身。 适才间，适才间闻承嗣兴兵临近， 薛大人，薛大人终日里愁锁眉心。 差红线，差红线魏营中前去探听， 驾云来，驾云来转瞬间……"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "来此已是漳河，待俺飞渡过去。"
        },
        {
          "character": "红线",
          "type": "西皮流水板",
          "text": "飞渡了漳滨。 风飘飘云淡淡银河泻影， 野荒荒星皎皎万籁无声。 心羡那波浪中鱼龙睡稳， 娇身躯犯霜露哪顾劳辛。 但愿得两相安免开争竞， 通玉帛，息干戈，各守疆土，莫苦黎民。 远望着魏营中灯光不定，"
        },
        {
          "character": "红线",
          "type": "西皮散板",
          "text": "催祥云向前去莫要消停。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红线下。"
        },
        {
          "character": "红线",
          "type": "stage",
          "text": "【第十一场：舞剑】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、薛嵩同上。"
        },
        {
          "character": "薛嵩",
          "type": "引子",
          "text": "驰书魏博，观看他，动静如何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛嵩坐下，旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "敌营蒙恩赐，须报主人知。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "叩见主公！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "起来！送盒前去，田公有何言语？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "田节镇将盒留下，言道：回书专人送来。并赏小人黄金百两，彩缎百端。"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "外面伺候。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启禀主帅：魏博田大人来拜。"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "啊？他是怎么到此？吩咐摆队相迎！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "大人有令：摆队相迎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、田承嗣同上，薛嵩出迎。"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "啊，亲翁！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "亲翁！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同进门。"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "亲翁请坐！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "不知亲翁驾到，未曾远迎，面前恕罪！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "岂敢！小弟来的卤莽，亲翁海涵。"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "亲翁到此，有何见教？"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "唉！承嗣首级系在恩人。此番自当知过自新，不复再贻伊戚。所置外宅键儿， 本防他盗，并非异图。今并脱其甲裳，放归田亩，是以小弟特来谢罪。"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "区区小事，何足挂齿！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "取盒之人，当是天神下界，不知可允小弟一见否？"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "此乃小婢所为，何劳奖宠？"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "哦！乃丫鬟所为！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "更要相见！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "待我唤她前来。 红线进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "红线进帐！"
        },
        {
          "character": "红线",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红线上。"
        },
        {
          "character": "红线",
          "type": "念",
          "text": "一夜身经千里路，幸得骊龙项下珠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红线进门。"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "主公有何吩咐？"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "见过田大人。"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "与田大人叩头！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "罢了，罢了！前者进帐取盒，就是你么？"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "哎呀呀！真乃超凡出众！只是那夜床头取盒，路程千里之远，如此迢远，营门 有数重之深，不知你是怎样前去？怎样进帐？可得闻之否？"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "你可讲与大人一听。"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "遵命！那夜子时三刻，既达魏城。凡历数门，遂及寝所。观外宅儿止于房廊， 鼾声雷动；见军中士兵步于庭下，传叫风生。奴婢拨了左扉，直抵绣帐。见大 人鼓腹酣眠，头枕文犀枕，枕露七星剑。剑前仰开一金盒，内藏生辰八字。时 则蜡烛烟微，炉香烬萎，侍人四布，兵仗交罗。或头触屏风，垂头而睡；或手 持巾拂，抵足而眠。奴乃拔其簪珥，牵其衣裳，如病如痴，皆不能悟，遂持金 盒，御风而归。出魏城西门，将行二百里，见铜台高揭，漳水东流，晨鸡动夜， 斜月在林，好一派宵景也！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "如此说来，你辛苦了！"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "奴婢觉得来回只一刹那耳，又何辛苦之有？只是得罪大人，望乞原宥！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "岂敢，岂敢！多谢不杀之恩！"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "亲翁此话，她哪里受的？"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "精妙剑法，可赐一观否？"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "有何不可。如此，献丑了！"
        },
        {
          "character": "红线",
          "type": "西皮散板",
          "text": "忆从天上谪红尘， 游戏人间十六春。 苍生涂炭难怜悯， 略施小伎呈奇能。 且取双剑来舞定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红线舞剑。"
        },
        {
          "character": "红线",
          "type": "西皮散板",
          "text": "望求大人指示分明。"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "妙极，妙极！真乃神人也！"
        },
        {
          "character": "红线",
          "type": "白",
          "text": "大人夸奖了！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "啊亲家，你帐下有这样的无意剑侠，乃国家之幸也！悔不该当初屡动干戈，承 嗣悔之晚矣！今日你我不免两家和好，何怕外寇侵犯西河之岸？天下太平，免 动刀枪，乃黎民百姓安宁之福也！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "亲翁之言，正合我意，我早已吩咐下去宰猪杀羊，为两家和好与军民共欢！"
        },
        {
          "character": "田承嗣",
          "type": "白",
          "text": "如此，大人请！"
        },
        {
          "character": "薛嵩",
          "type": "白",
          "text": "请！军士们！痛饮几杯呀！"
        },
        {
          "character": "薛嵩",
          "type": "笑",
          "text": "哈哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}