{
  "script_id": "90000002",
  "title": "麻姑拜寿",
  "alias": [],
  "source": "名家藏本、演出本",
  "characters": [
    {
      "name": "麻姑",
      "hangdang": "旦"
    },
    {
      "name": "圣母",
      "hangdang": "老旦"
    },
    {
      "name": "吕洞宾",
      "hangdang": "老生"
    },
    {
      "name": "李铁拐",
      "hangdang": "净"
    }
  ],
  "plot": "三月三日西王母寿辰，设蟠桃会，上中八洞神仙齐至祝寿；百花、牡丹、芍药、海棠四仙子采花，特邀麻姑\n同往。麻姑乃在绛珠河畔以灵芝酿酒，献于王母，欢宴歌舞。",
  "notes": "取材于清《调元月》传奇。梅兰芳早年编演。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "圣母上。"
        },
        {
          "character": "圣母",
          "type": "二黄原板",
          "text": "喜滋滋移莲步用目观望， 看瑶池好华艳胜似天堂。 诸神仙齐来到瑶池庆赏， 因此上设寿宴齐集非常。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "圣母上高台。"
        },
        {
          "character": "圣母",
          "type": "念",
          "text": "海屋添寿祝圣诞，福星永乐画堂前。岁岁年年逢此日，蟠桃会上会君仙。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "君乃，华瑶池圣母也。上帝见我广并九寿，常度众生。时命诸仙，齐赴蟠桃， 为此准备筵席，候众仙降临。 侍女们伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四仙女同上。"
        },
        {
          "character": "四仙女",
          "type": "同念",
          "text": "画堂筵庆雀屏开，福禄荣华自天来。"
        },
        {
          "character": "四仙女",
          "type": "同白",
          "text": "圣母在上，小仙等拜寿。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "众仙子平身。"
        },
        {
          "character": "四仙女",
          "type": "同白",
          "text": "圣寿无疆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老同上。"
        },
        {
          "character": "吕洞宾",
          "type": "西皮摇板",
          "text": "银镯煌煌瑞彩罩，"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、张果老",
          "type": "同西皮摇板",
          "text": "年年此日捧蟠桃。"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、张果老",
          "type": "同白",
          "text": "圣母在上，我等拜寿。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "众位大仙不用拜了。"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同白",
          "text": "哪有不拜之礼？正是："
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同念",
          "text": "画堂今日寿筵开，"
        },
        {
          "character": "圣母",
          "type": "念",
          "text": "相邀众仙到此来。"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同念",
          "text": "殷勤祝寿瑶池界，"
        },
        {
          "character": "圣母",
          "type": "念",
          "text": "共祝长生赴瑶台。"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同白",
          "text": "圣寿无疆！"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "开筵，待我把盏。"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同白",
          "text": "摆下就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "众位大仙，仙子请！"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同白",
          "text": "圣母请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。麻姑上。"
        },
        {
          "character": "麻姑",
          "type": "念",
          "text": "手捧佳酿瑶池献，整来彩衣拜金阶。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "圣母在上，小仙麻姑拜寿。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "麻姑仙子平身。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "圣寿无疆！"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "手捧何物？"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "小仙特制的圣寿长生不老酒。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "何谓圣寿长生不老酒？"
        },
        {
          "character": "麻姑",
          "type": "念",
          "text": "此酒本是鲜花炼，灵芝仙草精益鲜。凡人若得饮此酒，可得长生永绵绵。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "如此身受你一杯。"
        },
        {
          "character": "李铁拐",
          "type": "白",
          "text": "啊圣母，麻姑仙子之长生不老酒，可能给我等饮一杯否？"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "那是理当奉敬，今日众仙驾临，乃是仙池之大幸也，现今园内蟠桃也熟，各敬 一枚，以为结缘之品。 侍女们，将蟠桃各敬一枚。 麻姑仙子，命你在众仙面前执壶敬酒一杯。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "遵法旨。"
        },
        {
          "character": "麻姑",
          "type": "西皮二六板",
          "text": "瑶池奉了圣母命， 回身取过酒一樽。 进前忙把仙姑敬， 金壶玉液仔细斟。 饮一杯来增福命， 饮一杯来延寿龄。 愿祝仙师万年庆， 愿祝仙子比那南极天星。 霎时琼浆都倾尽， 愿年年如此日不老长生。"
        },
        {
          "character": "吕洞宾",
          "type": "白",
          "text": "众位大仙，这里有编戏上寿词一首，请麻姑仙子跳舞一番如何？"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、张果老",
          "type": "同白",
          "text": "好，我等幸会。"
        },
        {
          "character": "麻姑",
          "type": "白",
          "text": "小仙当得奉命。"
        },
        {
          "character": "麻姑",
          "type": "山花子",
          "text": "寿筵开处风光好， 争看寿星荣耀。 羡麻姑玉女并超， 寿同王母年高。 寿香腾寿烛影高， 玉杯寿酒增寿考。 今盘寿果长寿桃， 愿福如东海得寿比南山。"
        },
        {
          "character": "麻姑",
          "type": "大和佛",
          "text": "青鹿御芝呈瑞草， 齐祝愿寿弥高。 画堂寿日多喧闹， 寿基巩固寿坚牢。 京寿绵绵乐寿滔滔， 展寿席人人欢笑。 齐庆寿诞中祝寿间妙。"
        },
        {
          "character": "麻姑",
          "type": "红绣鞋",
          "text": "寿炉宝篆香消香消， 寿桃结子堪描堪描。 斟寿酒寿杯交， 歌寿曲寿多娇。 齐祝寿比南山高。"
        },
        {
          "character": "麻姑",
          "type": "尾声",
          "text": "长生寿域宏开了， 寿烛辉煌彻夜烧。"
        },
        {
          "character": "圣母",
          "type": "白",
          "text": "众仙如此殷勤，乃我神之幸也，你等随我往凌宵宝殿谢恩去者。"
        },
        {
          "character": "何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同白",
          "text": "遵法旨。"
        },
        {
          "character": "圣母、何仙姑、韩湘子、曹国舅、蓝采和、汉钟离、李铁拐、吕洞宾、张果老",
          "type": "同合头",
          "text": "愿岁岁年年增寿考。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}