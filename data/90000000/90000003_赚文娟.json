{
  "script_id": "90000003",
  "title": "赚文娟",
  "alias": [],
  "source": "名家藏本、演出本",
  "characters": [
    {
      "name": "苏小妹",
      "hangdang": "旦"
    },
    {
      "name": "秦观",
      "hangdang": "小生"
    }
  ],
  "plot": "长沙名妓文娟慕秦观词名，寄词达意，为秦观妻苏小妹所见，戏代秦观和词送还。蔑片柳元卿知其事，说动\n乡绅任草包冒秦观之名，往访文娟。文娟生疑，面试其才，柳元卿、任草包露丑而逃。秦观被贬郴洲，路经\n长沙，访文娟，一见订情。苏小妹乔装至长沙，冒秦观名，亦访文娟，佯指秦观为假冒，留词而去。秦观复\n任，再访文娟，文娟拒而不见。秦观悔恨至京，苏小妹已接文娟来，道破其事，秦观纳文娟为妾。",
  "notes": "故事见清朝李玉《眉山秀》传奇。程砚秋编演。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦观、家院同上。"
        },
        {
          "character": "秦观",
          "type": "引子",
          "text": "淮海客家，正青春，锦样年华。"
        },
        {
          "character": "秦观",
          "type": "念",
          "text": "暗空万缕漾垂杨，尚有春寒到画堂。歌扇未阑馀酒力，满身花气日初长。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "下官姓秦名观字少游，高邮人也。官拜翰林子七，夫人苏氏名唤小妹，乃苏老 泉之女苏轼之妹，才华第一，与下官时常唱和。今当三月，百花盛开，命人预 备酒筵与夫人赏花饮酒。 左右，酒筵可曾齐备？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "齐备多时了。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "请夫人出堂。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏小妹、丫鬟同上。"
        },
        {
          "character": "苏小妹",
          "type": "引子",
          "text": "春光无限，看闺林，柳媚花妍。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "夫人来了，请坐。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "官人请坐。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "夫人，今当春景融和，百花开放，下官命人置酒花前与夫人痛饮几杯。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "妾身陪伴官人。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "酒筵摆上，夫人请酒。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "官人请。"
        },
        {
          "character": "秦观",
          "type": "西皮原板",
          "text": "看园林春色好百花俱放， 一双双粉蝴蝶上下飞扬。 举起了金锤酒心中欢畅， 劝夫人且痛饮玉液琼浆。"
        },
        {
          "character": "苏小妹",
          "type": "西皮原板",
          "text": "坐花前面对着风和日朗， 喜的是酒筵前蝶粉蜂黄。 满庭中又只见柔丝荡漾， 休得要辜负了锦样春阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "念",
          "text": "忽奉宫中诏，看花要赋诗。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启老爷：适才宫中传旨，万岁爷在上林赏花，宣召老爷速进宫去。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "晓得了。 夫人，下官与夫人畅饮，谁想宫中宣召，不敢延迟，下官要进宫去了。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "想宫中宣召，不可延迟，官人快去。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "左右，与我更衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦观更衣。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "夫人自饮几杯，下官失陪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦观下。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "官人请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏小妹下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苏小妹上。"
        },
        {
          "character": "苏小妹",
          "type": "西皮慢板",
          "text": "我官人原本是才名远震， 在朝中为侍从执掌经纶。 都只为行新法万民怨恨， 因此上去奏本上达天闻。 虽然是秉忠心凶吉不问， 怕只怕天颜怒要逐孤臣。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "奴家苏氏，配夫秦少游，琴瑟和谐，唱随甚乐，只因朝廷，设行新法，万民不 便，我夫要上奏章弹劾宰相。今早上朝，尚未回来，不知事体怎么样了，好叫 我放不下，等官人回来问个明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦观上。"
        },
        {
          "character": "秦观",
          "type": "西皮散板",
          "text": "为新法使平民四方怨恨， 我只得上一本去奏明君。 又谁知贬他方官移远郡， 从今后望长安万里君门。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "官人回来了，官人请坐，上本之事怎么样了？"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "上本之后，圣上震怒，道我毁谤贤相，罪在不赦，把我贬到郴洲监酒税去了。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "吓，官人贬他方去了……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏小妹哭。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "夫人不必愁烦，下官有志锄奸，无心恋位，虽然贬谪，实出天恩，只是钦限逼 迫不可久留，下官就要起程了。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "官人就要远别了！"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "此去郴洲千里之遥，长途辛苦，妾身实在放心不下。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "夫人不必担心，下官此去自能排解，不劳夫人挂心；只是家中之事，全丈夫人 照管，夫人自己保重才好。"
        },
        {
          "character": "苏小妹",
          "type": "白",
          "text": "妾身自当尽心，官人保重。"
        },
        {
          "character": "秦观",
          "type": "白",
          "text": "下官就此去也！"
        },
        {
          "character": "秦观",
          "type": "西皮摇板",
          "text": "辞别了闺中人登程趱行， 我此去经多少水驿山林。"
        },
        {
          "character": "苏小妹",
          "type": "西皮摇板",
          "text": "这一去落南荒山程路远， 见浮云西北返回望修门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦观下。"
        },
        {
          "character": "苏小妹",
          "type": "西皮摇板",
          "text": "只见官人投远郡， 不由奴家痛伤心。 水宿山行天样远， 不知何日转家门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏小妹下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}