{
  "script_id": "90000006",
  "title": "花园赠金",
  "alias": [],
  "source": "名家藏本、演出本",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "薛平贵",
      "hangdang": "小生"
    }
  ],
  "plot": "王允三女王宝钏游园时见门外有一乞丐，由怜而问，知是薛平贵，并嘉许他的才智。以银和米相赠，约于二\n月二在彩楼前等候。",
  "notes": "后即《彩楼配》，亦可连演。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引王宝钏同上。"
        },
        {
          "character": "王宝钏",
          "type": "引子",
          "text": "燕语莺啼，惊醒了，春梦迷离！"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "闺中独处整红妆，承欢膝下慰高堂。五色绒将彩球绣，二月二日选佳郎。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "奴家王宝钏。爹爹王允，官居朝堂首相；母亲陈氏，膝下无儿，所生我姊妹三 人：大姊金钏，许配苏龙；二姊银钏，配与魏虎。只有奴家尚待字闺中，这且 不言。只因那年母亲染病在床，是我伺汤药三载，母病全愈。圣上闻知见喜， 赐我五色绒线绣成彩球，定于二月二日在十字街前，高搭彩楼招赘。但愿打中 如意郎君，方为终身之幸。今当正月，大雪初晴，园中梅花盛开，正好前去赏 雪观花。 丫鬟，看衣伺候，引路花园！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是啦！"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "银光耀眼雪初晴， 新春天气正宜人。 几处楼台如画镜， 无边玉宇净无尘。 丫环带路花园进，"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "您可小心着点儿。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "无妨。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "踏雪寻梅迎芳芬。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐，你看满园的梅花开得多好啊！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "开的果然茂盛。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐，您请在亭中小坐，那株梅花花开的更好，我给您摘上一枝来。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我在亭中等你！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "肚中饥饿身寒冷， 头晕目眩难支撑。 霎时只觉站立不稳，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵倒。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐，这枝红梅开得多好啊！"
        },
        {
          "character": "王宝钏",
          "type": "黄钟·醉花荫",
          "text": "雪斗红梅花枝俏， 见喜鹊飞来喧闹。 又谁人领路识孤芳， 何处知音，毕竟人间难找。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊，丫鬟，你我闷坐凉亭，何不想个法儿消遣？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我去拿棋盘，陪你下棋可好？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不好！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "那就打千秋玩吧？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "也不好！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "也不好！嗳！要不然我就将后花园门儿打开，陪你观看野景好不好啊？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "相爷可在府中？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "不在府中。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此将花园门开了！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是啦！ 啊呀！我的妈呀！ 启禀小姐：后花园门口有个花郎倒卧。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有这等事，待我看来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "您快去看看。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊呀且住！果然是个花郎倒卧在此。 丫鬟快快将那花郎唤醒。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "遵命。 嗳……这一花郎你快醒醒，哎，我说花郎你倒是醒醒啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵醒。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "原来是位大姐，唤我何事？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "你这个人为什么倒卧在我们后花园门口哇？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "只因天气寒冷，腹中饥饿，两眼昏花，不料倒卧在此。多蒙大姐将我唤醒，我 这里当面谢过！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "慢着，慢着，你先谢过我们小姐吧！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哦，是是是，多谢小姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "罢了。 且住，看这花郎，面目清秀，十分英俊，因何落魄至此啊？ 丫鬟，将这花郎带进花园，我要周济与他。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是啦！那一花郎随我来！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "喔，参见小姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "罢了，这一花郎，你家住哪里？姓甚名谁？因何落到这般光景？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "卑人薛平贵，乃长安人氏。晓读诗书，略通武艺。只因父母早亡，闻得苏元帅 招兵将，为此，沿途乞讨，前去投军报国，怎奈天气寒冷，腹中饥饿，困倒在 此，啊！真正困煞人也！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "落魄之身当发奋， 有心立志去投军。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "听他言来自思忖， 他家贫却是有志的人。 抛球选婿事不稳， 我有意与他订下亲。 彩楼之事对他论，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀，"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "又恐丫鬟一旁听。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这一花郎你可曾用过饭么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "这个……惭愧。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "丫鬟，看这花郎饿得甚是可怜，速去取些银米过来！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "那一花郎，你方才言道父母双亡，但不知家中可有……"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有什么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "可有妻室否？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐说哪里话来，落在乞讨之中，哪有银钱娶妻室呢？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "奴有一言，不好启齿。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐有话请当面。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我实对你说了吧，我父亲为我终身大事，定于二月二日，在十字街前，高搭彩 楼，抛球招婿。不知你前来接彩？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多承小姐如此见爱，感恩非浅，怎奈落魄之人，怎配相府千金，还望小姐三思！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我既以身相许，你……你……又何必迟疑？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "想那抛球招婿，必是王孙公子，哪有花郎之分？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "无妨，到了那日你早些站在楼前，我自有道理。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "理当遵命！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "花郎啊！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "二月二日事有准， 请君听我说分明： 莫道姻缘君无份， 万事只怕有心的人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐，银米在此。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "付于花郎，叫他去罢。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "花郎，你把银米拿去，谢过小姐，你快走吧！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多谢小姐，平贵告辞了！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "辞别小姐出园门，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "唤那花郎转来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "花郎回来。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "小姐有话快言明。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "花郎啊！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "彩楼之事你须守信， 莫做薄情无义人。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "小姐不必细叮咛， 平贵岂是无义人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "回房去吧！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "心中暗把秦晋订， 愿与薛郎结良姻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、丫鬟同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}