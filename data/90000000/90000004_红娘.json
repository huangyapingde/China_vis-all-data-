{
  "script_id": "90000004",
  "title": "红娘",
  "alias": [],
  "source": "名家藏本、演出本",
  "characters": [
    {
      "name": "红娘",
      "hangdang": "旦"
    },
    {
      "name": "崔莺莺",
      "hangdang": "旦"
    },
    {
      "name": "张珙",
      "hangdang": "小生"
    }
  ],
  "plot": "崔夫人悔约，令张珙与崔莺莺改为兄妹相称。张珙求计于红娘，红娘使赋诗写意。张珙跳墙夜见莺莺，崔莺\n莺责之。张珙忧愤致病，红娘忽引崔莺莺至，二人订情。",
  "notes": "此为传柬、佳期两场。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "【第七场：传柬】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔莺莺上。"
        },
        {
          "character": "崔莺莺",
          "type": "西皮原板",
          "text": "无端的月不圆好事难成， 为什么老娘亲言而无信？ 虽然是亲生母决无歹心， 全不想女儿家怎样为人。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "奴家崔莺莺。只因爹爹亡故，同母亲扶柩回乡，路过河中府，就在这普救寺内 担搁。昨日在经堂超度爹爹，不想强徒孙飞虎要强抢于我，多亏了张相公搭救。 是我母亲有言在先：谁能解围，就将我的终身许配于他，事后母亲忽然反悔。 啊母亲啊母亲，你如此行事叫女儿如何为人？天已不早，待我梳妆。红娘去 了半天，为什么未见到来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘上。"
        },
        {
          "character": "红娘",
          "type": "念",
          "text": "为了抱不平，替人送书信。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "啊小姐！"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "你为何去了半天呀？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐，这两天我忙得很呢！"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "啊？你忙些什么？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "没有什么。啊小姐，你可记得老夫人请客的那一天？"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "记得便怎样？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "老夫人说：儿啊！"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "唉！怎样讲话？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "我是学老夫人说。老夫人说：儿啊，你上前斟上一杯酒。未了又说一声：儿呀！ 上前呼一声哥哥！小姐，你晓得那个哥哥有多么难受啊！"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "这样的胡说我就要打！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐，你可怜可怜哥哥吧！"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "起来替我梳妆。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "崔莺莺",
          "type": "二黄原板",
          "text": "我母亲为私心悔却婚姻， 全不想女儿家难以为人。 若不是那张生一封书信， 我一命为贞节早赴幽冥。 思起了终身事珠泪滚滚，"
        },
        {
          "character": "崔莺莺",
          "type": "二黄摇板",
          "text": "好似那云中月难见光明。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "啊红娘，你手拿何物？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "没有什么。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "哪个叫你拿来？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "就是“二十三岁未曾娶妻”的那个人叫我送来的，小姐请看。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "啊红娘，我乃是相国千金，虽然我母亲亏对于他，也不能拿这样的书信戏弄于 我，你对他言讲：倘若禀告老夫人定责不饶，还要打死你这小贱人！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "那么待我去禀告老夫人，打死这小奴才。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "红娘我饶了你，你也饶了他吧。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐“他”是谁啊？谁又是“他”啊？小姐你快些写回信吧。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "与我溶墨。你对张生言讲：我与他写信也不过是问候而已，下次再来书信禀告 老夫人，定要重责不饶！就是你也要责打！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐，想人家张先生乃是一片好心，你要是不愿意的话就罢了，你干嘛写这样 的信给他，这不是害了他张先生吧！这封信啊，我可不给您送去。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "小贱子好不知分晓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔莺莺丢信，下。"
        },
        {
          "character": "红娘",
          "type": "四平调",
          "text": "看小姐做出来许多破绽， 对红娘偏用着要巧语花言。 本来是千金体大家风范， 最可怜背人处红泪偷弹。 盼佳期数不清黄昏清旦， 还有个痴情种忘废寝餐。 非是我愿意儿传书递简， 有情人成眷属不羡神仙。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "张相公开门。"
        },
        {
          "character": "张珙",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙上。"
        },
        {
          "character": "张珙",
          "type": "西皮摇板",
          "text": "听叫门想必是红娘来临， 但愿得结鸾俦良缘早定。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘姐你来了，小姐怎样言讲？可有书信到来？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐看了那封书信就要将我责打，我苦苦地哀求才饶恕了我，叫你妈妈的用功 念书，下次再要将书信戏弄于她，禀告老夫人，打死你这小奴才！"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘姐你要救我一救啊！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "我救不了你。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "噫！这是小姐的书信，待我三跪九叩香案迎接。哈哈哈……"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "你打了半天的哈哈，怎么回事啊？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘姐，这是小姐做的一首好诗啊！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "什么好诗啊？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "待我念于你听："
        },
        {
          "character": "张珙",
          "type": "念",
          "text": "“待月西厢下，迎风户半开。佛墙花影动，疑是玉人来。”"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "啊好好好！这首诗做得真不错。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "啊红娘姐，你也明白么？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "文诌诌的，从头到尾我一句都不懂的，你讲给我听听吧。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "怎么你要我讲与你听？好！“待月西厢下”就是待月儿上升的时候。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "噢，就是月亮上天的时候。张先生，要是阴天没月亮呢？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "唉，此乃是一句比喻呀。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "哦，是比喻，那么你往下讲。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "“迎风户半开”就是门儿被风这么一吹么，开了半扇。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "噢，门儿被风这么一吹，开了半扇儿。张先生，那么它另外半扇怎么不开啊？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "这又是一句比喻呀。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "又是一句比喻，你往下讲。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "“佛墙花影动”就是要跳墙进去与你们小姐相会啊！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "怎么？我们小姐叫你跳墙相会吗？你说我们小姐多坏啊，表面上庄庄重重的， 私底下约人家花园相会。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "“疑是玉人来”哦哦！！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "张先生，谁是玉人啊？玉人又是谁呢？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "就是小生我嘛！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "啊哟，敢情你是个玉人啊，我们小姐不是叫你跳墙进去吗？要是把你这个玉人 摔碎了，可怎么好啊？啊，张先生，既然我们小姐约你今晚跳墙相会，那么你 就跳吧。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "好便好，只是花园院墙甚高，叫我怎么跳得过去啊？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "你这个人哪连狗都不如！"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "不要骂人哪！"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "你可晓得狗急跳墙，何况人乎？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘下。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "啊呀，这个丫头厉害得很哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙下。"
        },
        {
          "character": "张珙",
          "type": "stage",
          "text": "【第十一场：佳期】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘、崔莺莺同上。"
        },
        {
          "character": "崔莺莺",
          "type": "西皮摇板",
          "text": "那夜晚似不该绝人太甚， 效私奔羞得我小鹿撞心。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐别害羞，男大当婚女大当嫁，谁也免不了这回事的，待我叫他开门来。"
        },
        {
          "character": "张珙",
          "type": "内白",
          "text": "啊呀，妙啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙上。"
        },
        {
          "character": "张珙",
          "type": "西皮摇板",
          "text": "听叫门想必是小姐来临，"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "小姐来了，请啊！哈哈哈哈！"
        },
        {
          "character": "张珙",
          "type": "西皮摇板",
          "text": "请小姐莫负这良辰美景。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "啊，红娘姐，外面有人来了，请你与我看上一看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘出，张珙关门。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "张相公，张相公！"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘姐，这时候我也顾不得你了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙拉崔莺莺同下。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "张相公，张相公！ 他们也顾不得我了，想他们双双同入罗帏，竟将我红娘关在门外。 张相公，啊张…… 红娘啊红娘，你这算何苦啊！"
        },
        {
          "character": "红娘",
          "type": "反四平调",
          "text": "小姐小姐多风采， 君瑞君瑞你大雅才。 风流不用千金买， 月移花影玉人来。 今宵勾却了相思债， 无限的春风抱满怀。 花心拆，游蜂采， 柳腰摆，露滴牡丹开。 一个是半推半就惊又爱， 好一似襄王神女赴阳台。 不管我红娘在门儿外， 这冷露湿透了我的凤头鞋。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "什么我的鞋儿也湿啦，张相公，张相公，你的相思病好了九成了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "琴童上。"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "我的一成汗还没有出哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘逃下。"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "好啊！你们做的好事，我去问红娘借钱，她要是不答应，我就告诉欢郎，让老 夫人知道也好晓得我的厉害！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "琴童下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}