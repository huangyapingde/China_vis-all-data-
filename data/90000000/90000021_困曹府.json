{
  "script_id": "90000021",
  "title": "困曹府",
  "alias": [],
  "source": "名家藏本、演出本",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "曹彬",
      "hangdang": "小生"
    },
    {
      "name": "张氏",
      "hangdang": "旦"
    },
    {
      "name": "华佗",
      "hangdang": "末"
    }
  ],
  "plot": "赵匡胤奉郭威之命，往燕京刺杀刘王化，为崔龙所擒。曹彬之嫂张氏救之，赵匡胤乃得释。曹彬邀赵匡胤回\n家，赵匡胤夜间与之私语，讥张氏，张氏闻之羞愤自缢。是夜，赵匡胤梦中见华陀前来为其割瘤，治愈后向\n赵匡胤讨封。赵匡胤封之为神。张氏鬼魂亦来讨封，赵匡胤复封之为华山茶花圣母。醒来，见曹彬因嫂亡大\n哭。乃告以梦中之事，曹彬感戴不已。次日，赵匡胤乃假扮曹彬之兄逃走。",
  "notes": "此为贯大元藏本，系尹培玺钞本，经吴小如先生订正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "曹彬",
          "type": "内白",
          "text": "兄长请。"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "贤弟请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、曹彬同上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "逃出天罗地网，"
        },
        {
          "character": "曹彬",
          "type": "念",
          "text": "好似雀鸟腾飞。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长请坐。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有坐。多蒙贤弟搭救，我这里当面谢过。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "岂敢。小弟当报前恩。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "小弟备得有酒，为兄长压惊。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "来此就要叨扰。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长请。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟请。"
        },
        {
          "character": "曹彬",
          "type": "二黄摇板",
          "text": "受恩不报非君子， 忘恩负义是小人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬醉状睡。〖起初更鼓〗。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "他倒睡着了。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄三眼板",
          "text": "小豪杰坐书房心中暗想， 二相公心无事瞌睡一旁。 无奈何推吊窗观看月亮， 此乃是中秋月分外明光。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "叹爹娘和弟妹在家悬望， 盼玄郎功名就急早还乡。 酒金桥遇苗训对我来讲， 他道我后来有九五之望。 周文王坐江山全凭姜尚， 小唐王坐江山元霸逞强。 汉刘秀坐江山二十八将，二十八将， 俺玄郎坐江山妄想一场。 恨金鸡不报晓天还未亮， 谯楼上睡着了打更儿郎。 恨不得抛长枪刺落了天边月亮， 用金钩钩出了红日轮光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。张氏上。"
        },
        {
          "character": "张氏",
          "type": "二黄摇板",
          "text": "轻移莲步到书房， 且听恩人说端详。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "奴家张氏，赵恩人正在书房饮酒，不免去到窗外，听他讲些什么。正是："
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "要知心腹事，但听口中言。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎呀且住，适才在关前，被崔龙拿住，多亏张氏嫂嫂叫俺一声丈夫，真乃难得 啊难得。哎呀，讲什么难得，若是俺玄郎的妻子叫了别人一声丈夫，我就是这 一刀……"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎呀。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄散板",
          "text": "一句言语错出唇， 墙内说话墙外听。 不饮酒来假装醉， 酒醉的人儿话不清。"
        },
        {
          "character": "张氏",
          "type": "二黄摇板",
          "text": "听一言来吃一惊， 羞得脸上起红云。 腰间解下丝罗带， 不如一死丧残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏下。〖起三更鼓〗。华佗上。"
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "闷坐松林下，修道数百年。三国行医术，自称华佗仙。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "我乃华佗是也，只因赤须龙在曹府被困，特地前来讨一封号，来此已是。"
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "不用忧来不用愁，宝刀割去肉龙瘤。阳世之间无用处，抛在长江顺水流。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何方妖道在此摆来摆去？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "贫道华佗。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "前来则甚？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "修炼多少年代？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "数百余年了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "可算得一洞老神仙。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "谢主龙恩。正是："
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "不是真龙开金口，焉得蓬莱一洞仙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华佗下。〖起四更鼓〗。张氏上。"
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "人死如灯灭，犹如汤泼雪。若要还阳转，海底捞明月。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "奴乃张氏鬼魂是也，只因闻听赵公子之言，羞愧难当，回房自缢身死，方知他 日后有九五之尊，不免去至书房，向他讨一封号。来此已是，待我进去。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何处鬼魂在此摆来摆去？"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "奴乃张氏鬼魂是也。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "到此何事？"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "前日打从华山经过，缺一圣母，就封你以为茶花圣母，归位去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金童、玉女同上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "金童、玉女送她归位。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏、金童、玉女同下。〖起五更鼓〗。"
        },
        {
          "character": "曹小姐",
          "type": "内白",
          "text": "走哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹小姐上。"
        },
        {
          "character": "曹小姐",
          "type": "念",
          "text": "忙将大嫂事，报与二哥知。"
        },
        {
          "character": "曹小姐",
          "type": "白",
          "text": "二哥快快开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬醒，开门。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "贤妹何事？"
        },
        {
          "character": "曹小姐",
          "type": "白",
          "text": "嫂嫂悬梁自尽了。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "你且回房去吧。"
        },
        {
          "character": "曹小姐",
          "type": "哭",
          "text": "唉，嫂嫂哇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹小姐下。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长醒来。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄散板",
          "text": "茶花圣母归了位， 三国华佗受封回。 猛然睁开丹凤眼， 贤弟为何两泪垂？"
        },
        {
          "character": "曹彬",
          "type": "哭",
          "text": "唉，嫂嫂哇……"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟为何落泪？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "我家嫂嫂悬梁自尽了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有这等事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内呐喊声。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哪里人马呐喊？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "待小弟府门打探再来回报。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有劳贤弟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬下，上。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "兄长大事不好了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "今有崔龙带领人马，将府门围住。口口声声要拿兄长上殿。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟今乃什么日期？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "八月十四日。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "明日呢？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "中秋之日了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如此说来，俺玄郎也有出头之日了。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "想你这光棍之家，还有什么出头之日不成？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟呀。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄碰板",
          "text": "休道我光棍家根本无有， 请台座听玄郎细说从头："
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "想当年俺玄郎江湖上走， 柴大哥贩雨伞郑恩卖油。 我三人秦王庙焚香叩首， 胜似那一母生心意相投。 董家桥打五虎弟兄分手， 柴大哥上淮庆官封王侯。 好一个柴大哥不忘故友， 修书信接玄郎全家来投。 弟兄们闲无事在花厅饮酒， 鱼池内起怪风妖魔出头。 大哥道龙戏水常常则有， 俺玄郎一见是妖魔出头。 左拉弓右搭箭照怪射走， 又听得谯楼上鼓打三筹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡琴过门。"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "次日里柴大哥朝房待漏， 郭王爷一见俺火上浇油。 某一言未出口就要斩首， 多亏了柴大哥一本保留。 悔不该在金殿夸下海口， 不用兵不用将独下燕州。 在关前遇崔龙蒙你搭救， 多亏了贤弟你将我收留。 今夜晚在书房一觉醒后， 偶然间得二梦大不相投。 头一梦梦见了华佗老叟， 执宝刀照左臂割去肉瘤。 贤弟你若不信解衣看透，"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "曹彬",
          "type": "二黄原板",
          "text": "细端详果然是割去了肉瘤。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "请问兄长这第二梦？"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "第二梦梦尊嫂书房来走， 披着发相带愁她苦苦哀求。 我封她到华山茶花圣后， 赐金童和玉女送上瀛州。 劝贤弟在此间休要多守， 倒不如同家眷搬出燕州。 天牢内替愚兄代为问侯， 说玄郎成了功即刻回头。 叫贤弟看过了——"
        },
        {
          "character": "赵匡胤",
          "type": "二黄散板",
          "text": "铁链手杻， 此一番上金殿杀他个寸草不留。 辞别了曹贤弟就要分手， 这才是祸到临头来不自由，我去献肉瘤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、曹彬同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}