{
  "script_id": "90000005",
  "title": "梅龙镇",
  "alias": [
    "游龙戏凤；一名：下江南"
  ],
  "source": "名家藏本、演出本",
  "characters": [
    {
      "name": "正德帝",
      "hangdang": "老生，武生巾，风帽，内罩黄道袍，外穿蓝道袍，红彩裤，穿厚底，手执扇子"
    },
    {
      "name": "李凤姐",
      "hangdang": "旦，头梳抓髻，穿粉红裤袄，系饭袋和四喜帚，彩鞋，白袜子，手绢"
    }
  ],
  "plot": "正德帝私游大同，过李龙酒店，见李龙之妹李凤姐美，乃加调戏。后实告以皇帝身份，封李凤姐为妃。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "正德帝",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小毛锣，正德帝作军家打扮上。"
        },
        {
          "character": "正德帝",
          "type": "引子",
          "text": "离金阙暗藏珠宝，游天下察访民情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝归大座。"
        },
        {
          "character": "正德帝",
          "type": "念",
          "text": "大明一统锦山河，国家闲暇太平歌。孤王离了燕京地，闻得大同景致多。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "孤，大明天子明武宗在位，自孤登基以来风调雨顺、国泰民安。是孤来到梅龙 镇上，住在李龙店中。是他言道用茶用酒，响动木马，自有人来。今晚闲坐无 事，我不免试它一回便了！"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "有寡人离了燕京地， 梅龙镇上且散心。 将玉玺交与龙国太， 朝中大事托付了众卿。 孤忙将木马儿一声响， 唤出提茶送酒的人。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保！"
        },
        {
          "character": "李凤姐",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐托酒盘上。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "自幼儿生长在梅龙镇， 兄妹卖酒度光阴。 我哥哥临行时对我论： 他说道前堂有一位军人。 我这里捧香茶将他来敬，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "紧忙回转绣房门，啊……我弹一弹灰尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐的腰巾拖在地上，才拾起来。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀呀啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐从上场门下。"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "好花儿生在深山内， 美女出在这小地名。 孤忙将木马二声震，"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "后面来了卖酒的人。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保！酒保！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "无有酒保，倒有个酒大姐在此吆。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "啊呀呀！好大的口气呀！呃，也罢！以酒为名，叫她一声。啊！酒大姐。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "方才那位汉子他是何人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他是我家哥哥。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他叫李龙。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "喔！他叫李龙。你叫什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我么，我是无有名字的。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嗳！人生天地之间，哪有无有名字的道理呀？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "名字倒有，说出来只怕军爷你叫哇。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为君的不叫就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，军爷不叫？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不叫。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，我叫……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "叫什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我叫……噢，我姓李吆。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嗳！我原晓得你姓李呀。你叫什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我叫……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐贴近正德帝耳边，小声。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "李凤姐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嗬，好一个李凤姐吆！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "拿名字来还我！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "话出如风，怎能还你？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "方才说过不叫，怎么又叫起来了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的乃是顺口答应。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "下次不可！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "下次不叫。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷，唤我何事呀？ 正德帝　　李凤姐　　（白）　　　　　我这里有三等酒饭。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪三等？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "上中下三等。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这上等的何人所用？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "来往官员。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "中等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "买卖客商。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这下等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这下等的么……不说也罢。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为何不讲呀？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "说出来，怕军爷着恼哇。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的不恼就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷不恼？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不恼。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这下等的酒饭就是你们这些吃粮当军之人所用。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "啊呀，且住！吃粮当军之人有这些个苦处！也罢，此番回得朝去，我要犒赏他 们。 啊，酒大姐，你将这上等的酒饭摆上一席，为军的我用啊。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷要吃这上等的酒饭么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "打个哑谜，你可晓得？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的我最喜哑谜，快些讲来。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有道是，行船？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "船钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "住店？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "店钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这吃酒呢？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，少不得要酒后哇……"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啐！连酒钱都不会说，还说什么酒后哇。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "听你之言，敢莫是要钱哪？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我倒不要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪个要钱？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我哥哥回来，他向我要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好好好，既是要钱就好办的了。大姐，将帘门卷呐起！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "好一个乖巧李凤姐， 未曾饮酒将钱问。 龙袍袖内摸一把， 白晃晃取出一银。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "拿去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "放下。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为什么要放下？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你可晓得男女授受不亲哪？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "男女授受不亲。喔喔喔，放下，放在何处？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "放在桌儿上。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "桌儿是光的，银子是圆的，掉在地下那还了得！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "滚在地下有我来拣呐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的我怕呀。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你怕什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕闪了大姐你的腰哇！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "闪了我的腰，与你什么相干？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我心疼哪。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我自己都不心疼，要你来心疼做什么？放下！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦哦哦，放下就放呃下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝用扇遮银子。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀！军爷敢是舍不得？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的舍得。只怕大姐你舍不得。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啊呀，且住！看这军爷有些不老实，待我来哄他一哄。 军爷你进得店来，可曾看见一幅古画？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "古画？为君的我最喜古画，古画在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐将银子拿在手中。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷，银子在这里吆。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "倒被她诓了去了。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "我这里接过银一锭， 问声军爷几个人？"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "为军的一人一马骑，"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "一人用不了这许多银。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "银子多了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "人的饭食，马的草料。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，人的草料，马的饭食。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃！人的饭食，马的草料。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "还多。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "还多，那就送与大姐买花戴呀。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "多谢军爷。军爷请哪！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "请到哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "请到客堂。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的正要到妳的卧房走走哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎！客堂吆！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎！客堂吆！哈哈哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐，这是哪个的卧房？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这是我哥哥的卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎呀！肮脏得很吆。啊，大姐，这是哪个的卧房？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这是我的卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我正要到妳的卧房瞻仰瞻仰啊。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎！你可晓得男女有别哪？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎呀呀！这个丫头也晓得男女有别。有趣，有趣呀，哈哈哈。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "龙行虎步把客堂进，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐，你怎么将门关起来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "遇见你们这样之人，门户是不得不紧呐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这梅龙镇上好紧的门户呀！哈哈哈"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝从下场门下。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "回身儿带上两扇门，啊啊啊，啊，两扇门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐摆酒。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "我这里好酒来摆定， 忙将军爷请一声。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷请出来吃酒哇，哎，军爷请出来吃酒呀！哎呀呀，你看这个人倒也有趣方 才叫他进去，他不进去。如今叫他出来，他又不出来了。为了军爷一席酒，脏 了我一双手，待我打水净手吆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐洗手，正德帝暗上抱李凤姐，李凤姐挣脱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，这梅龙镇上好高的房子！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "房子，房子，我打你一盘子。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么打起为军的来了哇？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你这个人进得店来，上也瞧瞧，下也看看。难道我们一个女孩儿家有什么好看 的？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦，不是啊。大姐你生得标致，长得漂亮，为军的我爱看哪！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦？长得好看，军爷爱看？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "实实地爱看。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，你就请看。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "喂呀呀！她倒大方起来了。我倒要瞻仰瞻仰。 好！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "好嘛？再看看！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "再看看，我就再看看。啊呀呀！越看越好哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "再看看！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦吆，不看了，不看了。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "真的不看了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我看够了哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哼！我若不看你是我这店中的客官，我就要骂你！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "啊？你要骂我？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我不但要骂你，我还要打你！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这倒巧得很哪！为军的出世以来，还不曾挨过打。今日就请大姐一双玉手打上 几下，为军的我要尝上一尝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝伸手。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷让我打？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "让你打。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，我就……，哎呀呀！不打了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为何不打了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我怕军爷着恼。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的不恼就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷不恼？如此，我就打打打，呀啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐从上场门下。"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "这佳人性情真清呐爽， 恰似嫦娥下天凡。 将木马连声响，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐上。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "想是茶寒酒又凉。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保，酒保！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "来了，来了！敢是茶寒了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不寒。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "酒冷了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不冷。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "茶也不寒，酒也不凉，将我们桌儿敲敲打打，打坏了，是要你赔的！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "慢说是这一张桌儿，就是大姐你……"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我说的是这一张桌儿呀！为军的我是包的起，赔的着哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "说话要明白些。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "本来明白。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "唤我何事？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我来问你，这席酒是哪个摆的？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是我摆的。可好？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好却好。缺少两样物件。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哪两样？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "青楼女子霜罗敷，红粉佳人白嫦娥。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，白萝卜我们这里是不上酒席的。军爷要吃，待我取来。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，回来，回来！不是那样物件呐。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是什么东西？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我说的是那穿红挂绿的大姐"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷问的是那些姐儿们么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嗯，不错。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "先前倒有。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "被官府查禁了。慢说无有，就是有，这夜半三更，叫我们女孩儿家到哪里去寻？ 哪里去找？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "着啊！大姐，我们商量商量。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "商议什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "就烦大姐斟上一杯，如何？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们只管卖酒，不会斟酒。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "斟斟何妨啊？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不斟。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "当真不斟？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不斟。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好，酒我不吃了，拿银子来还我吧！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "待我取来。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，回来！你来看，这席酒被我吃残，银子被我拿去，你哥哥回来，你将何言 答对啊？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎呀！是啊，如今酒也被他吃残了，我哥哥回来我拿何言答对啊？有了，待我 来哄他一哄。啊，军爷，你们那里老鼠儿是什么颜色？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "自然是灰色的。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们这里是白的。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "白老鼠不曾见过。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎呀，它出来了！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐将酒斟好。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷，在这里吆。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这杯酒是哪个斟的？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是我斟的，可好哇？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这样斟法，十杯八杯何足道哉！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你要怎样的斟法呢？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我要大姐你的手斟上一杯酒，你的手送与我的手，我的手再送入我的口。吃了 下去，那才算得。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我手上有糖？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "无糖。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有蜜？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "无蜜。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "无糖，无蜜，为何要我来斟酒？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嘿嘿，为军的我喜的就是这个样儿。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，花钱的老爷就喜欢这个调调儿。我哇，就恼的这个调调儿。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你斟是不斟？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不斟。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好，拿银子来还我吧。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "待我取来。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，回来。你可晓得我这银子的来路？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "难道说是做强盗打抢来的不成？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不错，正是做响马打抢来的。不犯事便罢。倘若犯下事来，将你兄妹二人攀扯 在内，看你怎生得了！这银子我不要了，酒我也不吃了，我要走了哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷回来。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "何事啊？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们商议商议。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你我商议商议。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我的心与口商议。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "快去商议。我还等着吃酒呢。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎呀，且住！想他这银子乃是打劫来的。不犯事便罢。倘若犯事，将我兄弟攀 扯在内，这便如何是好？哥哥呀，哥哥，今日也卖酒，明日也卖酒这就是卖酒 的下场哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐斟酒。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "无奈何斟上了酒一杯， 尊声军爷饮杯巡。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "孤王我有意将她戏， 看她知呃情不知情。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝戏搔挠李凤姐手心。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "干你娘的心肝！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么骂起来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你这个人，吃酒便吃酒，怎么将我的手心搔了一把，是何道理？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦，想是为军的这几日未曾跑马射箭，指甲养的长了，碰着大姐，也是有的。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我的指甲也长了，怎么碰不着你呢？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "唉呀！大姐原来是个爱占小便宜的人呐。你来看，为军的生就是一双粗手，大 姐来着，任凭你就着上几下。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷让我来着，如此我就……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "着呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不着了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么不着了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我还未曾着你，你倒先翘起来了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好好好，放平些，放平些。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，我就着着着。"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "李凤姐",
          "type": "西皮流水板",
          "text": "月儿弯弯照天下， 问声军爷你住哪家？"
        },
        {
          "character": "正德帝",
          "type": "西皮流水板",
          "text": "大姐不必细盘查， 天底下就哇是我的家。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "住了！一个人不住在天底下，难道还住在天上不成？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我的住处与旁人不同呃。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怎样不同？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "北京城内有个大圈圈，大圈圈里面有个小圈圈，小圈圈里面有个黄圈圈。我就 住在那黄圈圈里面呐。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "好像我认得你呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你认得我是哪一个？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你就是我家哥哥……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "的大舅子呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "休得胡言！"
        },
        {
