{
  "script_id": "70402103",
  "title": "锁五龙",
  "alias": [
    "锁乌龙；一名：斩雄信"
  ],
  "source": "方荣翔剧本选",
  "characters": [
    {
      "name": "单雄信",
      "hangdang": "净"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "徐勣",
      "hangdang": "老生"
    },
    {
      "name": "罗成",
      "hangdang": "小生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    }
  ],
  "plot": "隋炀帝即位后，昏庸无道，致使群雄举义，干戈四起，天下大乱。瓦岗寨聚起三十六友，结拜造反。后因时\n势变迁，风流云散，大多数归顺唐王李渊。惟单雄信挟李渊杀兄之仇，投到洛阳王王世充麾下做了东床驸马。\n李世民奉命剿灭各路烟尘，战争中单雄信被擒。众结义兄弟晓以利害，劝其降唐，单雄信执意不肯，终被\n斩于尉迟恭刀下。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "催命鼓。"
        },
        {
          "character": "单雄信",
          "type": "内西皮导板",
          "text": "号令一声绑帐外，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手举刀同走上，单雄信上。"
        },
        {
          "character": "四刽子手",
          "type": "同白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信对两旁轻蔑扫一眼，抖动手上铁链。"
        },
        {
          "character": "单雄信",
          "type": "西皮原板",
          "text": "不由得豪杰笑开怀。 某单人独一骑我把唐营踹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手、单雄信同扯四门。"
        },
        {
          "character": "单雄信",
          "type": "西皮原板",
          "text": "只杀得儿郎叫苦悲哀。 遍野荒郊血成海， 尸骨堆山无处里葬埋。 小唐童被某胆吓坏，"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "某二次被擒也应该。 今生不能够把仇解， 二十年投胎某再来。⑴ （二刽子手同归左，二刽子手同站一排。刽子手搬椅至台口，单雄信坐。四龙套捧酒具同上。尉迟恭、罗成、 程咬金、徐勣、引李世民同上。）"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "将身来在营门外， 只见雄信绑法台。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套斟满酒，交李世民。李世民持杯。"
        },
        {
          "character": "李世民",
          "type": "西皮流水板",
          "text": "一斗酒来满满筛， 尊声将军听开怀： 你今饮了杯中酒， 愿你灵魂上天台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信蔑视李世民，李世民无奈，将酒交龙套。"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "一口怒气冲天外， 大骂唐童小奴才： 胞兄被你父箭射坏， 兵发洛阳为何来？ 今生不能食尔的肉， 你坐江山爷再来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信不理睬李世民。徐勣向前对李世民示意。"
        },
        {
          "character": "徐勣",
          "type": "西皮摇板",
          "text": "主公且待营门外， 为臣自有巧安排。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套拿酒杯交徐勣，徐勣接酒走向单雄信。龙套搬椅，李世民坐。"
        },
        {
          "character": "徐勣",
          "type": "西皮摇板",
          "text": "一斗酒儿满满筛， 尊声五弟听开怀： 贾家楼前曾结拜， 惟有你我同心怀。 你今饮了杯中酒， 但愿你灵魂上天台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信气愤，怒视，徐勣无奈，将酒杯交龙套。"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "休要提起来结拜， 提起结拜恼心怀。 你在那唐营为元帅， 俺在洛阳为将才。 叔宝、咬金被你拐， 点手又唤罗成来。 锦绣江山被你卖， 你是个人面兽投胎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣羞愧。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套拿酒杯交罗成，罗成持杯向前。"
        },
        {
          "character": "罗成",
          "type": "西皮流水板",
          "text": "一斗酒儿满满筛， 尊声五哥听开怀： 五哥饮了杯中酒， 还望你灵魂上天台。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "啊！ （罗成持杯向前敬酒，单雄信甩后扎，抬左腿踢飞罗成手中酒杯，把手铐上铁链向罗成猛砸，急走快步。罗 成激怒。程咬金按住罗成，单雄信用手指点。）"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "见罗成把我牙咬坏， 大骂无耻小奴才。 曾记得踏坏瓦岗寨， 曾记得一家大小洛阳来。 我为你造下了三贤府， 我为你花费许多财。 忘恩负义投唐寨， 花言巧语哄谁来！ 雄信一死名还在，"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "奴才呀！奴才！"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "怕的是乱箭镩身尸无处葬埋。 （单雄信跺脚。行弦。单雄信举左拳欲打罗成，罗成举右拳。程咬金分开，单雄信、罗成同往里对翻。单雄 信举左拳，罗成举右拳。程咬金分开，单雄信、罗成同往外对翻。程咬金劝。）"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "慢动手，瞧我啦。 五哥！"
        },
        {
          "character": "程咬金",
          "type": "西皮摇板",
          "text": "列位宾朋且站开， 咬金自有巧安排。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金对龙套示意，龙套拿酒杯交程咬金，程咬金持杯。"
        },
        {
          "character": "程咬金",
          "type": "西皮流水板",
          "text": "一斗酒儿满满筛， 尊声五哥听开怀： 五哥饮干杯中酒， 管叫你灵魂就上天台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "噢！上天台？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不错，上天台。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "好，酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金递酒杯。单雄信接过一饮而尽。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信将酒杯交与程咬金。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好海量！酒来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金接酒杯。"
        },
        {
          "character": "程咬金",
          "type": "西皮流水板",
          "text": "二斗酒儿满满筛， 尊声五哥听开怀： 五哥饮干杯中酒， 我保你灵魂就赴蓬莱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "噢！赴蓬莱？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不错，赴蓬莱。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "好，酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金递酒杯。单雄信接过一饮而尽。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信将酒杯交与程咬金。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好海量！看酒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金接酒杯。"
        },
        {
          "character": "程咬金",
          "type": "西皮流水板",
          "text": "三斗酒，满满筛， 尊声五哥听开怀： 贾家楼，曾结拜， 惟有你我同心怀。 好一个徐勣心肠坏， 罗成也是狗肺才。 来生变一个奇男子， 拿住他们一个一个用刀裁，你把我丢开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "这一句话儿真爽快，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信伸拇指。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "爽快吧！"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "叫贤弟把酒斟上来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "给您斟上啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金递酒杯。单雄信接过一饮而尽。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "干！"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "贾家楼，曾结拜，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不错，咱们贾家楼拜过把子。"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "惟有你我同心怀。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "就是咱们哥儿俩好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信环视。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "您看什么呢？"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "满营将官俱已在，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "都在这儿伺候着您哪！"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "不见叔宝栋梁材。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "您问谁呀？"
        },
        {
          "character": "单雄信",
          "type": "西皮摇板",
          "text": "问一声秦二哥今何在？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "五哥！"
        },
        {
          "character": "程咬金",
          "type": "西皮摇板",
          "text": "二哥押粮未归来。"
        },
        {
          "character": "单雄信",
          "type": "哭头",
          "text": "啊！好汉哥！"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "二哥押粮未回来。 等候二哥回营寨， 把我尸首好葬埋。 我今饮他三斗酒， 快叫那唐童就把刀开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金归原位。李世民站起。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "尉迟恭听令！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "将雄信拿去开刀！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "得令！ 来，击鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。李世民、众人同归下场门，单雄信归上场门，脚踏椅子笑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "尉迟恭",
          "type": "stage",
          "text": "—————————— ⑴此段还有一种唱法："
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "某二次被擒也应该。 他劝我降唐我不爱， 情愿一死赴阳台。 今生不能够把仇解， 二十年投胎某再来。"
        }
      ]
    }
  ]
}