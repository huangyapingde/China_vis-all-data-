      "name": "周处",
      "hangdang": "净"
    },
    {
      "name": "王浚",
      "hangdang": "老生"
    },
    {
      "name": "刘才",
      "hangdang": "丑"
    },
    {
      "name": "范老二",
      "hangdang": "丑"
    },
    {
      "name": "张百川",
      "hangdang": "丑"
    },
    {
      "name": "张利",
      "hangdang": "丑"
    },
    {
      "name": "田大娘",
      "hangdang": "老旦"
    }
  ],
  "plot": "晋代宜兴人周处，膂力过人，性情粗豪，酗酒之后，每多暴行，百姓患之，与当时为害地方的孽蛟、猛虎，\n并称“三害”。太守王浚初到任，知周处尚有可为，乃乔装寻访，与周处相遇于途中。王浚伪装不识，以蛟、\n虎为衬，痛数其罪。周处闻言震惊，痛悔前非。乃奋不顾身，射虎斩蛟，为民除害。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "周处",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纽丝。周处醉朦胧步伐踉跄上，抖扇子亮相。纽丝，凤点头。"
        },
        {
          "character": "周处",
          "type": "西皮散板",
          "text": "虎背熊腰系紫绦， 佯狂市井任逍遥。 有酒不知天大小， 任他肉眼看英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处用扇向外指胸前。五击头。向前移两步，进门。张利自下场门上。"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "周大爷，您来了！我算计着您就该来了！酒我给您都烫好了，您别站着了，您 请坐……您坐。 （五锤。周处不耐烦地用扇子抽一下衣襟，入座。张利端酒壶、酒杯，周处看，推在地下。一锤一锣。张利 拾起。）"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "我给您换大坛去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张利下。张利端酒坛子上，打去泥头。张利斟酒，周处拿起，闻，饮酒，品味，放下酒碗。张利斟酒。"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "周大爷我就剩下这一坛子酒啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处看张利，张利下。周处连饮三碗。"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "咳！想俺周处，市井佯狂，家财荡尽，无依为家，落得办事落魄，喜得打下了 各行常例，今俱已过限，不见送来，我不免吃个醉饱，寻闹他们一番便了！"
        },
        {
          "character": "周处",
          "type": "西皮散板",
          "text": "市井佯狂伤老大， 一任粗豪置年华。 有酒且醉我多潇洒， 哪顾荆臻道路差。 一坛美酒俱饮下，"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "酒保！"
        },
        {
          "character": "周处",
          "type": "西皮散板",
          "text": "快把美酒献与咱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张利上。"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "拿酒来……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处醉晃。"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "周大爷，我不是跟您说了吗，我就剩这一坛酒了！再也没有了！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "无有了？"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "我还敢冤您吗？"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "好！既然无有，将俺的常例银子拿来！"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "周大爷，罚了不打、打了不罚，您看我这小买卖，哪搁得住呀，周大爷！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "你不知道周大爷的厉害吗？"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "哎呀，周大爷！我就这一锭银子了，全给您，这回再要，我的命都没有了！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "无有了？"
        },
        {
          "character": "张利",
          "type": "白",
          "text": "我冤您哪，我不得好死！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "我再往窑上走走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处出门，张利下。周处走圆场，醉步到要门口欲呕吐。"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "这里的人都哪里去了？ 出来个人哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘才、范老二同上。"
        },
        {
          "character": "刘才",
          "type": "念",
          "text": "忽听语声高，"
        },
        {
          "character": "范老二",
          "type": "念",
          "text": "想是周处到。"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "老掌柜的，您听见没有，周处他又来了！"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "待我向前。 啊，周大爷您可好哇！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "嘿！哪个要你这文绉绉的酸礼！快拿俺的旧规矩来！"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "啊，周大爷，这几日天气不好，未曾开窑，生意冷淡，改日有了银钱，一定与 周大爷送去也就是了！"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "周处啊，你瞧见没有，你来了这么半天啦，甭说买主，就是连个打落的也没有 啊！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "啊！你敢拿官府欺压与咱不成！"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "难道你比官府还厉害吗？"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "你敢拿官府任意勒索。"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "啊，谁让人家是官的，你是私的哪！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "听你之言就罢了不成？"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "买卖不开张，那可没法子！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "好狗头！"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "哎，你怎么骂人呢，他骂人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范老二挽袖欲向前，刘才拦阻劝解。"
        },
        {
          "character": "周处",
          "type": "西皮散板",
          "text": "听一言来怒气发， 你敢拿官府将咱压。 若无银两来献纳， 顷刻将你的窑打塌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处左手指下场门，收回身怒视范老二。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "啊，周大爷，我们这数十余口，全仗窑儿度日，若是将窑儿打塌，我们何以为 生啊？"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "老掌柜，咱们这窑是灌了浆的，谅他也打不塌！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "啊！你道你周大爷打不塌这几座窑么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处指下场门。"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "嗯，我瞧不透你！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范老二指周处，刘才拦范老二求和。"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "好！你试试看哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处跺左脚，右手指范老二，周处、范老二、刘才转场。"
        },
        {
          "character": "周处",
          "type": "西皮散板",
          "text": "非是俺今日说大话， 任它泰山也倒塌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处用扇子自指，左手抓褶子大襟，向上甩，右手接住，抬左腿亮相，下。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "看那周处怒冲冲而去，倘若将窑打塌，我们何以为生！都是你惹了大祸！"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "不要紧，他打不塌！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二伙计同上。"
        },
        {
          "character": "二伙计",
          "type": "同白",
          "text": "掌柜的，周处将窑打塌一座！"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "周处果然将窑打塌，这便如何是好？"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "干脆抄家伙，咱们跟他拼了！"
        },
        {
          "character": "二伙计",
          "type": "同白",
          "text": "对，跟他拼了！走……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二伙计同下。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "哎呀，伙计们使不得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘才抓范老二，范老二推开，下。刘才摆双手下。周处幕后脱褶子，挽袖上。"
        },
        {
          "character": "周处",
          "type": "西皮散板",
          "text": "酒入愁肠力气大， 几座窑儿俱打塌。 挽袖挥拳往下打！ （〖急急风〗。周处回身向上场门，四小窑户手举棍棒同上，同朝周处打。周处毫不用力扒小窑户倒筒靴。 刘才、范老二自同上，范老二打周处，周处用左手拧住范老二的左膀，范老二转半身踉跄两步向前跪下。周 处挥拳将要打，刘才托住周处右膀，跪在周处前。四小窑户被击趴倒筒靴后倒下不起，举棍向前欲打，刘才 阻止。众人同亮相。凤点头。）"
        },
        {
          "character": "刘才",
          "type": "西皮散板",
          "text": "大爷息怒饶恕他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处举手仍欲打范老二，刘才急拦住。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "啊周大爷，看在我的份上饶恕他吧！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "你们还打不打了？"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "哎呀，再也不打了！"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "不打了，俺的常例银子呢？"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "大爷息怒，常例银子在此。"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "你若早交银子，何用你周大爷动手！"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "哎呦，膀子疼痛！"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "哦！是……"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "从今以后，这常例银子每前三日与俺送去，如若不然，管叫你那几座窑儿，尽 为齑粉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处甩开小窑户。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "哦，是……我们记下了。"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "取我的衣服来。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "周大爷的衣服在此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘才将衣扇与周处。"
        },
        {
          "character": "周处",
          "type": "白",
          "text": "俺要饮酒去了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处右手一把将衣夺过交左手，从左手接扇子。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "周大爷，您歇息歇息再走哇！走好，走好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖闪锤〗。周处醉步踉跄地走近范老二，范老二吓得后退。周处回身向刘才走去，刘才殷勤地拱手。"
        },
        {
          "character": "周处",
          "type": "西皮流水板",
          "text": "堪笑尔等双眼瞎， 错把金刚当菩萨。 你把那当官来看大， 大捧金银献与他。 某是私取尔不怕， 狗眼里面哪有咱。 你与我装聋来作哑， 不纳金银空磨牙。 一时之怒我把这窑来打， 顷刻间一座一座几座窑儿被某俱打塌。 从今后你等你们怕不怕？"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "我们怕了，周大爷慢着走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处抖扇亮相。〖长锤〗。范老二与周处推磨，范老二去上场门归刘才一边，周处出窑门。"
        },
        {
          "character": "周处",
          "type": "西皮流水板",
          "text": "限三天把银两你送到某家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周处指刘才，用扇指右方，周处用右手抖开扇子，左手提褶子搭在右胳膊上，蔑视地看刘才，傲慢地走下。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "是、是，记下了，大爷慢走。将我这陶窑打塌，这买卖也做不成了，哎呀这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘才拱手殷勤地送周处走下。刘才、范老二同进门，站成左右八字形，用手指后面。"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "干脆！老掌柜的，咱们告他去！"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "哎，那官府也奈何不得他呀！"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "听说新上任的龙骧将军王浚王大人能为黎民分忧解冤，上那去告他去。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "啊，告得下来么？"
        },
        {
          "character": "范老二",
          "type": "白",
          "text": "没错，咱们快去吧。"
        },
        {
          "character": "刘才",
          "type": "白",
          "text": "哎！只好如此呀！走……走吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "王浚",
          "type": "内白",
          "text": "回操！"
        },
        {
          "character": "四文堂",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖快长锤〗。四文堂、家院引王浚同上，亮相。"
        },
        {
          "character": "王浚",
          "type": "西皮摇板",
          "text": "操演归来精神爽， 儿郎个个逞刚强。 催马加鞭回府往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘才、张利、范老二持状纸自下场门同上。〖长锤〗。刘才、张利、范老二同跪王浚面前举状。"
        },
        {
          "character": "刘才、张利、范老二",
          "type": "同白",
          "text": "冤枉！"
        },
        {
          "character": "王浚",
          "type": "西皮摇板",
          "text": "拦马喊冤为哪桩？"
        },
        {
          "character": "家院",
          "type": "白",
