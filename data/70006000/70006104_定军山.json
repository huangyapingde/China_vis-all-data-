    }
  ],
  "plot": "张郃兵败惧罪，又攻打葭萌关。老将黄忠、严颜向诸葛亮讨令拒敌，合力杀退张郃；又乘胜攻占曹军屯粮之\n天荡山，杀死夏侯德。黄忠另引一军攻打曹军重镇定军山，定军山守将夏侯渊出战，各不相下；夏侯渊擒去\n牙将陈式，黄忠又擒住夏侯渊之侄夏侯尚，黄忠故意于走马换将之时，箭射夏侯尚，激怒夏侯渊来追，引至\n荒郊，用拖刀计斩夏侯渊。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照李少春说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。因原稿只含主角唱念的场次，故第五至六场、第八场、第十至\n十二场、第十八场从略。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引赵云、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "点绛唇",
          "text": "奉主之命，统领雄兵，扫荡烟尘，要把乾坤鼎足成三分。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上高台。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "高卧南阳岁月深，主公三请出卧龙。四面烽火烟尘尽，灭却魏吴方称心。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人，诸葛亮。闻报曹操派遣张郃攻打葭萌关，必须差一能将前去退敌。 赵云听令。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传令下去，可有能人去至阆中，速调三将军回营，大战张郃。"
        },
        {
          "character": "黄忠",
          "type": "内叫头",
          "text": "且慢哪！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "何人阻令？随令进帐！"
        },
        {
          "character": "黄忠",
          "type": "内白",
          "text": "黄忠来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "参见军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "黄将军少礼。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "谢军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军为何阻令？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "军师！闻得张郃小儿攻打葭萌关，何劳三将军？末将不才愿带领人马大战那张 郃。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想那张郃乃中原有名上将，老将军虽勇，惜已年迈，岂是那张郃对手？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "军师！"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "末将年迈勇，血气贯长虹。杀人如削土，跨马走西东。 两膀千斤力，能开铁胎弓。若论交锋事，还算老黄忠。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "也罢，帐下有一铁胎宝雕弓，你若拉得开，就命你前往。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令哪！"
        },
        {
          "character": "黄忠",
          "type": "西皮二六板",
          "text": "师爷说话言太差， 不由我黄忠怒气发。 一十三岁习弓马， 威名镇守在长沙。 自从归顺了皇叔爷的驾， 匹马单刀取过了吴夏。 斩关夺寨功劳大， 军师爷不信在功劳簿上查一查。 非是我黄忠夸大话，"
        },
        {
          "character": "黄忠",
          "type": "夹白",
          "text": "弓来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠取弓。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "铁胎弯弓手中拿。 满满搭上珠红扣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠拉弓，四军士同喝彩。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "帐下的儿郎把咱夸。 二次忙用这两膀的力，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠拉弓，四军士同喝彩。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "人有精神力有加。 三次开弓秋月样，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠拉弓，四军士同喝彩。黄忠收弓。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "再与师爷把话答。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "帐外听令。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云应。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传令下去，可有能人愿协助黄老将军，大战张郃？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。 令出，下面听者：可有能人，愿随黄老将军大战张郃？"
        },
        {
          "character": "严颜",
          "type": "内白",
          "text": "严颜愿往！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "随令进帐。"
        },
        {
          "character": "严颜",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜上。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "参见军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军少礼。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "谢军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军进帐，敢是愿协同黄老将军大战张郃？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "末将愿往！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军年迈，恐怕难敌那张郃？"
        },
        {
          "character": "严颜",
          "type": "叫头",
          "text": "师爷！"
        },
        {
          "character": "严颜",
          "type": "念",
          "text": "末将今年八十一，虽然年迈有余力。万马军中无人敌，斩将擒王何足奇？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这几日未曾上阵，不知你的枪法如何？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "若论枪法，在两军阵前刺上将咽喉，如探囊取物一般。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "当帐演来。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "严颜",
          "type": "西皮流水板",
          "text": "师爷休道老将差， 有几个老将听根芽： 赵国廉颇威名大， 齐国纪业也不差。 老虽老头上发， 胸中韬略似子牙。 虎头金枪耍一耍， 某比黄忠也不差！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，传黄老将军进帐。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "黄老将军进帐。"
        },
        {
          "character": "黄忠",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "黄老将军以为正帅。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "严老将军以为副帅，"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "听山人令下！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮流水板",
          "text": "一个西川威名大， 一个镇守在长沙。 二位老将齐上马， 得胜回来把功加。"
        },
        {
          "character": "黄忠、严颜",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "黄忠接令把帐下，"
        },
        {
          "character": "严颜",
          "type": "西皮摇板",
          "text": "不由严颜笑哈哈。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "一不用战鼓这咚咚的打，"
        },
        {
          "character": "严颜",
          "type": "西皮摇板",
          "text": "二不用旌旗把队押。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "事不宜迟把马跨，"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        },
        {
          "character": "严颜",
          "type": "西皮摇板",
          "text": "要把张郃一马踏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "军师，二位老将此去可否成功？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "定然成功，退帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引陈式同上。"
        },
        {
          "character": "陈式",
          "type": "念",
          "text": "辕门战鼓响，儿郎报端详。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "黄、严二位老将军到，"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。黄忠、严颜同上。"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "参见二位老将军，"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "罢了，一旁坐下，"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "可曾与那贼见过阵来？"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "见过一阵，大败而回。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "唗！无能之将，先败头阵，来，推出斩了。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "且慢！兵家胜败，古之常理。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "老将军莫非替他讲情？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "老将军开恩。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "谢过黄老将军，"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "多谢黄老将军。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "罢了。陈式听令，城楼之上，高扯红旗两面，上写“黄”、“严”二字，那贼 闻名丧胆！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "张郃讨战。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "黄忠",
          "type": "叫头",
          "text": "严老将军。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "黄老将军。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "红旗未挂，那贼就来讨战，你我抖搂精神，会他一会！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "去会他一会。"
        },
        {
          "character": "黄忠、严颜",
          "type": "同白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、严颜同上马，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引张郃同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "某、张郃。适才探马报道，黄忠、严颜兴兵前来，岂能容他猖狂。 众将官，杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士引黄忠、严颜同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "呔！来将通名。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "老夫黄忠。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "老夫严颜。"
        },
        {
          "character": "张郃",
          "type": "三笑",
          "text": "哈哈，哈哈，哪哈哈……"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "尔为何发笑？"
        },
        {
          "character": "张郃",
          "type": "叫头",
          "text": "黄忠、严颜哪！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "我道你二人是天神下界，原来是两个老匹夫，怎挡某家一战？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "一派胡言，放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、严颜、张郃同开打，张郃败下。黄忠、严颜同追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩浩、夏侯尚同上。"
        },
        {
          "character": "韩浩、夏侯尚",
          "type": "同白",
          "text": "俺！"
        },
        {
          "character": "韩浩",
          "type": "白",
          "text": "韩浩。"
        },
        {
          "character": "夏侯尚",
          "type": "白",
          "text": "夏侯尚。"
        },
        {
          "character": "韩浩",
          "type": "白",
          "text": "将军请了。"
        },
        {
          "character": "夏侯尚",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "韩浩",
          "type": "白",
          "text": "奉了魏主之命，攻打头阵，你我一同前往。"
        },
        {
          "character": "夏侯尚",
