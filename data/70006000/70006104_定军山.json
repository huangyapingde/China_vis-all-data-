          "character": null,
          "type": "stage",
          "text": "四上手同下。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "到明天午时三刻要成功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        }
      ]
    },
