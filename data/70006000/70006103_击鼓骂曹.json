{
  "script_id": "70006103",
  "title": "击鼓骂曹",
  "alias": [
    "群臣宴"
  ],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "祢衡",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "孔融荐处士祢衡于曹操，曹操不加礼，祢衡反唇诮骂。曹操故命祢衡在元旦大宴时为鼓吏以辱之，祢衡乃复\n击鼓骂曹，曹操又遣其往说刘表，借刘表之手以杀祢衡。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬吊嗓录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "引子",
          "text": "天宽地阔，论机谋，智广才多。"
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "口似悬河语似流，全凭舌战运计谋。男儿若得擎天手，自然谈笑觅封侯。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "卑人，姓祢名衡，字正平，乃平原孝义村人氏。幼读经论，深通战策。少游北 海，偶遇孔融，将我荐与曹府作幕。我想曹操，名为汉相，实乃汉贼，未必有 敬贤礼士之心。此番进得相府，须要见机而行，正是："
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "未逢真明主，有愧栋梁才！"
        },
        {
          "character": "祢衡",
          "type": "西皮快三眼",
          "text": "平生志气运未通， 似蛟龙困在浅水中。"
        },
        {
          "character": "祢衡",
          "type": "西皮原板",
          "text": "有朝一日春雷动， 得会风云上九重。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "战事纷纷刀兵闹， 昼夜思想计千条。 但愿狼烟一齐扫， 四海升平乐唐尧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "一封书信忙修好， 见了丞相把令交。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你修书，可曾修齐？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "书已修齐，但不知命何人前往？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我命孔融呼唤祢衡，因何不见到来？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔融上。"
        },
        {
          "character": "孔融",
          "type": "西皮摇板",
          "text": "祢衡先生我请到， 见了丞相说根苗。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "呼唤祢衡，可曾唤到？"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "现在帐下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唤他进来。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "遵命！ 有请祢先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "西皮流水板",
          "text": "相府门前杀气高， 层层密密摆枪刀。 画阁雕梁龙凤绕， 亚赛天子九龙朝。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "祢先生，这就是丞相。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "丞相在上，卑人礼到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "下站何人？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "卑人姓祢名衡字正平，乃平原孝义村人氏。"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "丞相，这就是祢先生。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗯！难道老夫不知他叫祢衡，进得相府，只行常礼，令人可恼！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "唔呵呀！人言曹操轻贤慢士，今日一见，果然话不虚传。 孔大夫你把我错荐了！"
        },
        {
          "character": "祢衡",
          "type": "西皮流水板",
          "text": "人言曹操多奸巧， 果然亚赛秦赵高。 欺君误国非正道， 全凭势力压当朝。 站立在阶前微微笑， 哪怕虎穴与笼牢。"
        },
        {
          "character": "祢衡",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "为何发笑？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "我笑只笑天地虽阔，并无一人。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫帐下，文能安邦，武能定国，何言无人？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "请问丞相，你帐下文有谁能，武有谁高？请道其详，卑某愿闻。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "听道！文有荀或、荀攸、郭嘉、程昱；武有许褚、张辽、李典、乐进；夏侯敦 可称无敌将军，我儿曹子孝盖世奇才。老夫兴兵以来，攻无不取，战无不胜， 何言无人？"
        },
        {
          "character": "祢衡",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你道你帐下都是英雄，依卑某看来，尽都是些个无用之辈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "听道！荀或、荀攸只可以吊丧问疾。郭嘉、程昱只可以看墓守坟。乐进、李典 只可以牧羊放马。许褚、张辽，哼，也只好击鼓鸣金。曹子孝可称要钱太守， 夏侯敦可称完体将军。其余者尽都是些个衣架饭囊酒桶肉袋、碌碌之辈，何足 道哉？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "出口狂言，有何德能？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "区区不才，幼读诗书，深通战策。天下之书，无书不读；三教九流之事，无事 不晓。上可以致君于尧舜，下可以德配于孔颜。我乃天下名士，岂与你这奸贼 同党？ 孔大夫，你把我错荐了！"
        },
        {
          "character": "祢衡",
          "type": "西皮流水板",
          "text": "平生志气与天高， 不愿金钱结富豪。 我本堂堂青史表， 岂与奸贼共同朝？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "张辽",
          "type": "西皮散板",
          "text": "祢衡说话真可恼， 辱骂丞相为哪条？ 三尺龙泉出了鞘，"
        },
        {
          "character": "孔融",
          "type": "西皮散板",
          "text": "将军息怒将他饶。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "来、来、来！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张将军，休要污了老夫的宝剑。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "哼！便宜了这厮。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "量你也不敢。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡，明日老夫大宴群臣，帐下缺少一名鼓吏，你可愿当否？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "孔融",
          "type": "白",
          "text": "祢先生，忍耐了吧！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "愿当鼓吏。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "明日来早便罢，倘若来迟，依军法从事。 张将军！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将他搀出帐去。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "出去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡冷笑。"
        },
        {
          "character": "祢衡",
          "type": "笑",
          "text": "嘿嘿嘿嘿！"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "丞相委用恩非小， 用为鼓吏怎敢辞劳。 出得帐来微微笑， 孔融作事也不高。 明知道曹贼多奸巧， 全凭势力压当朝。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "我越思越想心头恼， 安排巧计骂奸曹。 罢罢罢暂且忍下了， 明天自有我的巧妙高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        },
        {
          "character": "孔融",
          "type": "西皮摇板",
          "text": "祢衡先生心太傲， 险些一命赴阴曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孔融下。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "祢衡小儿真可恼， 丞相不杀为哪条？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "袖内机关他怎晓， 杀鸡何用宰牛刀？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "祢衡",
          "type": "内西皮导板",
          "text": "适才与贼一席话，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "西皮散板",
          "text": "气得我心中乱如麻。"
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "酒逢知己千杯少，话不投机半句多。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "适才进得相府，与曹操深施一礼，他坐在上面，是昂然不动，倒还罢了，反道 我的礼貌不周。明日大宴群臣，他将我用为鼓吏，分明是羞辱于我呀！等到明 天当着众位大人将奸贼辱骂一场，纵然将我斩首，也落得个青史名标。正是："
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "明知山有虎，偏向虎山行。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "昔日里韩信受跨下， 英雄落魄走天涯。 到后来登台把帅挂， 扶保汉室锦邦家。 明日里进帐把贼骂， 拚得一死染黄沙。 纵然将我头割下， 落一个骂贼的名儿扬天涯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四朝官同上。"
        },
        {
          "character": "朝官甲",
          "type": "念",
          "text": "日观战国策，"
        },
        {
          "character": "朝官乙",
          "type": "念",
          "text": "夜读国风诗。"
        },
        {
          "character": "朝官丙",
          "type": "念",
          "text": "要知今古事，"
        },
        {
          "character": "朝官丁",
          "type": "念",
          "text": "还诵五车书。"
        },
        {
          "character": "朝官甲",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "三朝官",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "朝官甲",
          "type": "白",
          "text": "丞相相邀我等，不知为了何事，你我一同前往。"
        },
        {
          "character": "三朝官",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "朝官甲",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "朝官甲",
          "type": "念",
          "text": "五凤楼前朝金阙，相府门前拜元戎。"
        },
        {
          "character": "朝官甲",
          "type": "白",
          "text": "来此已是。 门上哪位将军在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "啊，列位大人。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "张将军，丞相邀我等到此，烦劳通禀。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "候着。 有请丞相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "列位大人到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "奏乐相迎！"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相在上，我等大礼参拜。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫也有一拜。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相宠召我等，不知有何见谕？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "今日元旦佳节，老夫特摆盛宴，与列公畅饮几杯。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "到此就要叨扰。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将宴摆下！ 列位大人。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫帐下新收一名鼓吏。命他廊下擂鼓，你我畅饮几杯。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "我等愿闻。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传鼓吏进帐。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "鼓吏进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": "祢衡",
          "type": "西皮导板",
          "text": "谗臣当道谋汉朝，"
        },
        {
          "character": "祢衡",
          "type": "西皮原板",
          "text": "楚汉相争动枪刀。 高祖爷咸阳登大宝， 一统山河乐唐尧。 到如今出了个奸曹操， 上欺天子下压群僚。 我有心替主爷把贼扫， 手中缺少杀人的刀。 主席坐定——"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "奸曹操， 左右文武众群僚。 元旦节与贼个不祥兆， 假装疯魔骂奸曹。 我把这褴衫来脱掉，"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "破衣褴衫摆摆摇。 大摇大摆上中道，"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "呔！你这鼓吏，丞相大宴群臣，这样破衣褴衫成何体统？"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "帐下的儿郎闹吵吵。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "好笑啊。"
        },
        {
          "character": "二旗牌",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "你二人休要呵呵笑， 有辈古人听根苗： 昔日太公曾垂钓， 张良拾履在圮桥。 为人受得苦中苦， 脱却了褴衫换紫袍。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "你怎比得前朝的古人？"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "你二人把话讲差了， 休把虎子当狸猫。 有朝一日时运到， 拔剑要斩海底蛟。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "青天白日，说梦话。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "休道我白日梦颠倒， 倾刻就要上青霄。 我把破衣也脱掉， 赤身露体逞英豪。 耀武扬威往上跑，"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "呔！你这样赤身露体，丞相降罪哪个担代？"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "你丞相降罪我承招。 将身来在东廊道，"
        },
        {
          "character": "祢衡",
          "type": "西皮散板",
          "text": "看奸贼把我怎开销。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "鼓吏带到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命他擂鼓三通。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "命你擂鼓三通。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打鼓三通。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "列位大人，看鼓吏擂鼓，有如金声玉振一般，我等畅饮三杯，庆贺丞相。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "擂鼓三通响如雷， 文武百官饮三杯。 张辽一旁牙咬碎， 孔融带愧转回归。 老夫近前观鼓吏，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打〖夜深沉〗、〖节节高〗。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "赤体露身廊下擂。 老夫暂忍心头气， 再与祢衡说端的。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "曹操。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你为何叫老夫曹操？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你叫得我祢衡，我就叫得你曹操。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫也不计较于你，今天大宴群臣，你是这样赤身露体，成何体统？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "我赤身露体，露我父母之遗体，显得我是清洁君子。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你是清洁君子，哪个是混浊的小人？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你就是混浊小人！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗯！老夫乃当朝首相，何言混浊二字？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "听道！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你不识贤愚，眼浊也。不讷忠言，耳浊也。不读诗书，口浊也。常怀篡逆，心 浊也。我乃天下名士，将我用为鼓吏，有如藏仓毁孟子，阳货轻仲尼。曹操啊、 贼！真乃匹夫之辈也！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "昔日里文王访姜尚， 亲临渭水得栋梁。 臣坐君辇联辔往， 为国求贤理所当。 我本堂堂奇男子， 把我当作小儿郎。 枉在朝中为首相， 狗奸贼不知臭和香。"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "老夫兴兵谁敢挡， 赫赫威名天下扬。 论机谋亚赛姜吕望， 你是无知小儿郎。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "祢衡",
          "type": "西皮散板",
          "text": "曹操把话错来讲， 祢衡言来听端详： 鼓打一通天地响， 鼓打二通国安康。 鼓打三通灭奸党， 鼓打四通振朝纲。 鼓发一阵连声响， 管叫你狗奸贼死无下场。"
        },
        {
          "character": "四朝官",
          "type": "同西皮散板",
          "text": "下得位来把话讲， 丞相为何怒一旁？"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相为何怒坐一旁？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "适才与鼓吏争论儿句，故而闷坐在此。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相息怒，我等上前问来。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "你这鼓吏家在那里？姓甚名谁？慢慢讲来。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "列公啊！"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "未曾开言我的心头恨， 尊一声列位大人听详情。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "家住哪里？"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "家住在平原孝义村，"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "姓甚名谁！"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "姓祢名衡字表正平。"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "原来是称先生。"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "我胸中颇有安邦论， 曾与孔融当过了幕宾。 他把我荐与曹奸佞， 贼有眼不识宝和珍。 我宁作忠良门下客， 不愿你奸贼帐下的人。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "真乃舌辩之徒。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "贼道我舌辩徒， 舌辩之徒有张苏。 有朝大展昆仑手， 要把奸贼一笔勾。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "井底之蛙能起多大风浪。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "贼道我井底蛙， 井底之蛙也不差。 有朝一日风云驾， 要把奸贼一朝拿。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位大人，他骂老夫奸，老夫奸在哪里？"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "是呵！奸在哪里？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "列公啊！"
        },
        {
          "character": "祢衡",
          "type": "西皮散板",
          "text": "狗奸贼出巧言故意问道， 尊一声列公卿细听根苗： 他自幼儿举孝廉官卑职小， 他乃是夏侯子过继姓曹。 到如今做高官忘了宗考， 全不怕骂名儿万古留标。"
        },
        {
          "character": "张辽",
          "type": "西皮散板",
          "text": "听他言来心头恼， 辱骂丞相为哪条？ 三尺龙泉出了鞘，"
        },
        {
          "character": "四朝官",
          "type": "同西皮散板",
          "text": "将军息怒把他饶。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张将军，休要污了老夫的宝剑。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "便宜了你。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "哼！狗仗人势，甚么东西，量你也不敢哪！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡，老夫有书信一封，命你去往荆州，顺说刘表来降，保你官职不小。"
        },
        {
          "character": "祢衡",
          "type": "西皮散板",
          "text": "要往荆州不能够， 岂与奸贼作马牛。"
        },
        {
          "character": "四朝官",
          "type": "同西皮散板",
          "text": "丞相暂息雷霆怒， 顺说祢衡往荆州。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有劳列位大人。"
        },
        {
          "character": "朝官甲",
          "type": "白",
          "text": "祢先生，丞相有书信一封，命你去往荆州，顺说刘表来降。你若不去，将你斩 首，你家中还有妻儿老小，所靠何人？你要再思再想。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "祢衡",
          "type": "西皮二六板",
          "text": "列公下位齐来劝我， 犹如惊醒梦南柯。 自古道未曾责人先责己的过， 手摸胸膛我自揣摩。 罢罢罢暂息我的心头火，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "他骂老夫奸，老夫奸在哪里？"
        },
        {
          "character": "四朝官",
          "type": "同白",
          "text": "丞相是大大的忠臣？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "忠臣！"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "西皮快板",
          "text": "学一个陆贾与随何。 走上前忙告错， 顺说刘表再定夺。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "顺说刘表归降我， 老夫保你在朝歌。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "丞相宽心安闲坐， 披星戴月渡江河。 顺说的事儿若不妥， 愿死在他乡作鬼魔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}