{
  "script_id": "70006110",
  "title": "战太平",
  "alias": [],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "花云",
      "hangdang": "老生"
    },
    {
      "name": "花孙氏",
      "hangdang": "旦"
    },
    {
      "name": "陈友谅",
      "hangdang": "净"
    },
    {
      "name": "朱文逊",
      "hangdang": "小生"
    },
    {
      "name": "花安",
      "hangdang": "丑"
    },
    {
      "name": "花夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "花云辅佐朱元璋之侄朱文逊驻守太平；北汉陈友谅进袭，花云奋勇抵御，但因采石矶守将乏人，被陈部陈友\n杰暗袭，夺得矶头。太平城破，花云拟突围，朱文逊贪恋家眷，贻误时机，与花云同遭擒获。陈友谅劝降，\n朱文逊屈膝被杀，花云坚决不降，陈友谅命缚于高竿，以箭加以威胁。花云挣断绑绳，力杀多人，终因中箭\n伤重，自刎而死。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。因原稿只含主角唱念的场次，故第四至五场、第九场后半部分、\n第十至十一场从略。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引朱文逊同上。"
        },
        {
          "character": "朱文逊",
          "type": "引子",
          "text": "胡元数尽，炎汉重兴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊坐内场。"
        },
        {
          "character": "朱文逊",
          "type": "念",
          "text": "叔王龙驾坐南京，全凭文武保乾坤。奉旨领兵矶头镇，但愿中华保太平。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "小王，朱文逊。叔父朱元璋，称号吴王，南京即位，小王奉叔王之命，把守采 石矶头，坐镇太平。可恨陈友谅打来战表，夺取太平，城中兵寡将少，难以抵 挡，不免宣上花爱卿，商议用兵之计。 内侍！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "宣花云上殿。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "遵旨。 千岁有旨，花云上殿！"
        },
        {
          "character": "花云",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上。"
        },
        {
          "character": "花云",
          "type": "念",
          "text": "怀揣忠义胆，保主锦江山。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "臣花云见驾，主公千岁！"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "谢坐，宣臣上殿，有何军情议论？"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "今有反贼陈友谅，前来攻打采石矶头，夺取太平，卿家有何良策？"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "既是反贼陈友谅攻打采石矶头，主公带领人马埋伏闸子口，以弓箭当先。为臣 带领人马杀奔江心，哪怕此贼不灭？"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "此计甚好，照计而行。正是："
        },
        {
          "character": "朱文逊",
          "type": "念",
          "text": "江山本是将军镇，"
        },
        {
          "character": "花云",
          "type": "念",
          "text": "协力同心定太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云、朱文逊、四太监自两边分下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花夫人、花孙氏同上。"
        },
        {
          "character": "花夫人",
          "type": "念",
          "text": "夫受皇家禄，"
        },
        {
          "character": "花孙氏",
          "type": "念",
          "text": "妻沾雨露恩。"
        },
        {
          "character": "花云",
          "type": "内白",
          "text": "回府哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引花云同上，四文堂同下。花云进门。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "可恼！"
        },
        {
          "character": "花夫人、花孙氏",
          "type": "同白",
          "text": "啊老爷，今日回府，为何这等烦恼？"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "二位夫人有所不知，可恨反贼陈友谅，领兵夺取太平城，千岁命我回府披挂， 埋伏闸子口，只是采石矶头缺一能将，故而烦恼！"
        },
        {
          "character": "花夫人、花孙氏",
          "type": "同白",
          "text": "食王爵禄，当报皇恩，何言烦恼二字？就请老爷后堂披挂，待我等替老爷点动 人马，准备出战。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "有劳夫人，正是："
        },
        {
          "character": "花云",
          "type": "念",
          "text": "青龙背上屯军马，"
        },
        {
          "character": "花夫人、花孙氏",
          "type": "同念",
          "text": "白虎当头休扎营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        },
        {
          "character": "花夫人",
          "type": "白",
          "text": "众将走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "参见夫人。"
        },
        {
          "character": "花夫人",
          "type": "白",
          "text": "站立两厢，听我一令！"
        },
        {
          "character": "花夫人",
          "type": "二黄导板",
          "text": "我这里在二堂忙传将令，"
        },
        {
          "character": "花夫人",
          "type": "二黄原板",
          "text": "叫一声众将官细听分明： 陈友谅提兵将前来犯境， 千岁爷命老爷前去出征。 劝尔等一个个争行赌胜， 退后者犯军令插箭游营。 耳边厢又听得金甲声振，"
        },
        {
          "character": "花夫人",
          "type": "二黄散板",
          "text": "候老爷披挂讫即刻发兵。"
        },
        {
          "character": "花云",
          "type": "内二黄导板",
          "text": "头戴着紫金盔齐眉盖顶，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上。"
        },
        {
          "character": "花云",
          "type": "二黄散板",
          "text": "为大将临阵时哪顾得残生。 撩铠甲且把二堂进， 有劳夫人点雄兵。"
        },
        {
          "character": "花夫人",
          "type": "二黄散板",
          "text": "人来看过酒一樽， 旗开得胜早回程。"
        },
        {
          "character": "花云",
          "type": "二黄散板",
          "text": "接过夫人得胜饮， 背转身来祭神灵。 辞别夫人足踏蹬， 但愿此去扫荡烟尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云、四龙套同下。花夫人、花孙氏同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引陈友杰同上。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "俺，陈友杰。奉了兄王之命，攻打采石矶头。 众将官，杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士引花云同上，会阵。"
        },
        {
          "character": "花云",
          "type": "二黄散板",
          "text": "一见贼子怒气发， 不由老爷咬龈牙。 我主爷洪福齐天大， 把尔当作井底蛙。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "陈友杰",
          "type": "二黄散板",
          "text": "劝你马前归顺罢， 不然一命染黄沙。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "一派胡言，放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云、陈友杰同开打。陈友杰败下，花云追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈友杰、陈英豹同上。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "先行听令！"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "就说大元帅陈友杰，保定北汉王得了采石矶头。教那不怕死的花云，前来受死！"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "得令。 下面听者！今有大元帅陈友杰，保定北汉王得了采石矶头，那个不怕死的花云 前来受死！"
        },
        {
          "character": "花云",
          "type": "内白",
          "text": "花云来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云持枪上，与陈友杰、陈英豹交战，花云败下。陈友杰、陈英豹同追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花夫人、花孙氏同上。"
        },
        {
          "character": "花夫人",
          "type": "念",
          "text": "老爷去出兵，"
        },
        {
          "character": "花孙氏",
          "type": "念",
          "text": "未见转回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上，花安上。"
        },
        {
          "character": "花夫人、花孙氏",
          "type": "同白",
          "text": "老爷受惊了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊上。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "花安，你爹爹可曾回府？"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "现在府内。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "对你爹爹言讲，大炮一响，吓死皇老太太，贾氏夫人坠楼而死，叫你爹爹快快 出马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊下。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "花云",
          "type": "叫头",
          "text": "爹爹！"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "适才千岁言道：大炮一响，吓死皇老太太，贾氏夫人坠楼而死，叫爹爹快快出 马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊上。"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "花安，你爹爹可曾出马？"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "尚未出马。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "哦，是了。想必是你爹爹，有降顺北汉王之意，这有宝剑一口，叫你爹爹将小 王龙头割下、降顺北汉王去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊下。"
        },
        {
          "character": "花安",
          "type": "叫头",
          "text": "爹爹！"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "适才千岁言道，将千岁龙头割下，降顺北汉王去罢。"
        },
        {
          "character": "花云",
          "type": "西皮导板",
          "text": "号炮一响惊天地，"
        },
        {
          "character": "花云",
          "type": "西皮散板",
          "text": "就是雀鸟也难飞。 叫花安与父带坐骑， 舍不得妻儿两分离。 大夫人请上受一礼，夫人哪！ 下官言来听端的： 孙氏、姣儿托付你， 这是花家一脉息。 含悲忍泪跨坐骑， 落一个青史名标万古题。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        },
        {
          "character": "花夫人",
          "type": "西皮散板",
          "text": "花安随后去探信，"
        },
        {
          "character": "花孙氏",
          "type": "西皮散板",
          "text": "快到阵前看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花安下。花夫人、花孙氏同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊、花云自两边分上。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "哎呀卿家呀！那贼人马有如潮水一般，如何是好？"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "待为臣保定千岁，杀出重围，再作道理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云、朱文逊同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈友杰、四军士同上。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "绊马索伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上，与陈友杰起打。花云落马被擒。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "绑回去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈友杰、四军士押花云同下。花安上。"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "哎呀且住！看千岁与爹爹俱被贼人擒去，待我报与母亲知道便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花安走圆场，请花夫人、花孙氏同上。⑴"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第十二场",
      "utterances": [
        {
          "character": "花云",
          "type": "内西皮导板",
          "text": "叹英雄失智入罗网，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士押花云同上。"
        },
        {
          "character": "花云",
          "type": "西皮原板",
          "text": "大将难免阵头亡。 我主爷洪福齐天降， 刘伯温八卦也平常。 早知道采石矶被贼抢， 早就该差能将前来提防。 将身儿来在大街上，"
        },
        {
          "character": "花孙氏",
          "type": "内笑",
          "text": "哈哈哈哈，啊哈哈哈！"
        },
        {
          "character": "花云",
          "type": "西皮散板",
          "text": "那旁来了疯婆娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花孙氏上。"
        },
        {
          "character": "花孙氏",
          "type": "西皮快板",
          "text": "急急忙忙往前奔， 法场绑定一将军。 认得他是奴夫样， 不由奴家痛在心。 舍死忘生将他认，"
        },
        {
          "character": "花云",
          "type": "西皮散板",
          "text": "这一足踏在你地埃尘。 你是谁家疯婆女？"
        },
        {
          "character": "花云",
          "type": "西皮快板",
          "text": "怀中抱定小娇生。 明明认得孙氏女， 假装疯魔认夫君。 你若念在夫妻义， 去到金陵搬救兵； 你若不念夫妻义， 千万莫丢小娇生。 使个眼色快逃走，"
        },
        {
          "character": "花孙氏",
