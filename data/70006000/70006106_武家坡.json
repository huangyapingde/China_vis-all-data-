{
  "script_id": "70006106",
  "title": "武家坡",
  "alias": [],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "老生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    }
  ],
  "plot": "薛平贵归家，遇王宝钏于武家坡前，夫妻相别十八年，王宝钏已不识薛平贵。薛平贵假问路以试其心，王宝\n钏逃回窑，薛平贵赶至，直告己名及别后经历，夫妻相认。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "一马离了西凉界，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "不由人一阵阵泪洒胸怀。 青是山绿是水花花世界， 薛平贵好一似孤雁归来。 那王允在朝中官居太宰， 他把我贫苦人哪放在心怀。 恨魏虎是内亲将我谋害， 苦害我薛平贵所为何来？ 柳荫下拴战马武家坡外，"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "见了那众大嫂细问开怀。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "众位大嫂请了。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "请了，军爷敢是失迷路途？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "阳关大道，并非失迷路途，我乃找名问姓的。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "提起此人大大有名。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "但不知是那一家呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "王丞相之女，薛平贵之妻，王氏宝钏。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "军爷来的不巧。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "方才在此剜菜。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "回寒窑去了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "烦劳大嫂传话一声：就说她丈夫带来万金家书，叫她亲自前来接取。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "军爷请稍待。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "啊！王三姐。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "怎么？"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "你丈夫托人带来万金家书，叫你坡前接取。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "有劳了！"
        },
        {
          "character": "王宝钏",
          "type": "内西皮导板",
          "text": "多蒙邻居对我言，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢三眼",
          "text": "武家坡又来了王氏宝钏。 站立在坡前举目观看， 那一旁站定了一军官。 假意儿在此间把菜剜， 他那里问一声奴好回答一言。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "这大嫂传话——"
        },
        {
          "character": "薛平贵",
          "type": "西皮流水板",
          "text": "太也迟慢， 武家坡站得我两腿酸。 下得坡来用目看， 见一位大嫂把菜剜。 前影好像王三姐， 后影儿好似妻宝钏。 本当向前将妻唤， 错认了民妻礼不端。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂请来见礼！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "还礼！军爷敢是失迷路途么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "阳关大道，并非失迷路途，我乃找名问姓的。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "提起此人大大有名。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "但不知是哪一家呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "王丞相之女，薛平贵之妻，王氏宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷你与他家有亲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "无亲。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "带故？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "非故。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "既非亲故，你问他作甚呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我与他丈夫同营吃粮，托我带来万金家书，故而动问。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷可将书信放下，待我转交那王三姐就是。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我那薛大哥言道，书信要面交本人。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不见本人呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "原书带回。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷请少待。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀且住！想我夫妻分别一十八载，今日才有书信回来，本当上前接取，怎奈 衣衫褴褛。若不上前，书信又不能到手，这便怎么处？哦哦、我自有道理。 啊军爷，打个哑谜你可知晓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "略知一二。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有道是，这“远”？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "千里不能相见。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这“近”？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "莫非你是薛大嫂么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不敢，平贵之寒妻啊。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "来来来，重见一礼。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "方才见过礼了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有道是礼多人不怪啊！我也告便。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀且住！想我平贵离家一十八载，不知她的贞节如何？乘此四下无人，不免 调戏她一番。她若贞节，我便认下。她若失节，我便赶回西凉，也好见我那代 战公主。有理呀，呵呵，有理！"
        },
        {
          "character": "薛平贵",
          "type": "西皮流水板",
          "text": "洞宾曾把牡丹戏， 庄子也曾三戏妻。 秋胡戏过罗氏女， 薛平贵调戏自己的妻。 弓插袋内摸一把，"
        },
        {
          "character": "薛平贵",
          "type": "夹白",
          "text": "哎呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮流水板",
          "text": "我把大嫂的书信失。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你放在哪里？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "弓插袋内。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "敢是个不要紧的所在？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是要紧的所在。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你为何失落了啊？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一路之上，抽弓打雁，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "打雁作甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "打雁充饥啊。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "想是那雁儿吃了你的心肝不成？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊，大嫂，一封书信能值几何，为何开口便伤人哪？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有道是为人谋而不忠乎？与朋友交而不信乎？失落人家的信，岂不令人痛苦啊？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀呀，倒底是大家之女，开口便是文。啊，大嫂不要啼哭，书信上面的言语 么，我还记得几句。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我倒明白了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "明白何来？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "想是我丈夫带来安家银子，被你在中途路上花尽，你道是与不是？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我那薛大哥修书之时，我在一旁打点行李，偷看了几句，故而记得。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此说来，你倒是个有心之人了！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我若有心，也不能失落你的书信哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵调戏王宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "站远些！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "八月十五月光明，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了！军营之中连灯亮都无有么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "军营之中好苦哇，哪里来的灯亮呃？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "薛大哥在月下修书文。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "我问他好来？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "他倒好，"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "再问他安宁？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "倒也安宁。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "三餐茶饭？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "小军造，"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "衣衫破了？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "有人补缝。 薛大哥这几年运不通， 在行营之中受了苦刑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "受了苦刑，敢莫是挨了打了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是挨了打了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "但不知打了多少？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一捆四十。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀，苦命的夫哇！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊，大嫂不要啼哭，这苦哇还在后头呢！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "站远些！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "军营中失落了一骑马，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "但不知是官马，还是私马？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "军营之中，哪里来的私马，自然是官马呀。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "既是官马，岂不要他赔呀？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哪怕他不赔。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊呀呀，他哪里来的银钱赔马呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "自然有啊！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "为赔马借了我十两纹银。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你在军营之中，吃几份钱粮？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一份。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我那薛郎呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "也是一份哪。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你二人俱是一份钱粮，你哪里有银钱借与他赔马呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我那薛大哥先前倒是一把手好，一文钱也舍不得化，也不晓得交朋友。如今哪， 嘿嘿，学坏了。在外面交了些个无业的游民，每日吃喝嫖赌，无所不为。为 军的，实不怕大嫂你笑话，乃是个贫寒出身，积攒了几两银子，都借与他赔马 了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这就不对了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我那薛郎也是贫寒出身，从不晓得化费银钱的。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀呀，薛大哥呀，到今日我才晓得你也是个贫寒出身哪！哈哈哈哈！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "倒被他取笑了。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "本利算来二十两， 并不曾还我半毫分。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "就该问他要，"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "无有，也是枉然。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "打骂起来，也该问他要。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "打骂起来岂不伤了弟兄们的和气呀？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你腰挂何物？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "防身宝剑，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "杀了他，也该问他要。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三几两银子就要拿刀动剑，嘿嘿，不像话呀！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "难道说，就罢了不成？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有道是，善财难舍呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "那一日过营去把债讨， 他言说长安城有一个王氏宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了！王宝钏该你的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不该。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "欠你的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "也不欠哪。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不该不欠，你提她作甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我来问你，自古道，父债？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "子还。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "夫债呢？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "妻……"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "妻怎么样？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "妻，不管哪．"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你倒推得个干净，少不得这汗还要出在病人的身上呃！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "他无钱便把妻来卖， 把大嫂卖与了当军的人。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "当军人是哪个？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "喏，喏，喏就是我呀！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "婚书为证。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "拿来我看。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "慢来，慢来，大嫂乃是有气之人，婚书被你诓到手中，三把五把扯碎，为军的 岂不落了个人财两空呃？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "依你之见呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "去至前村，找一大户人家，请出三老四少，你我大家，同拆同观。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "此话当真？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "当真。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "果然？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哪个骗你不成么？"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "啊啊啊！狠心的强盗。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "她倒骂起来了。"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "手指着西凉高声骂， 无义的强盗骂几声。 我为你不把相府进， 我为你失了父女情。 既是儿夫把我卖， 谁是那三媒六证的人？"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "那苏龙、魏虎为媒证， 王丞相是我的主婚人。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "提起了旁人我不认， 苏龙、魏虎是内亲。 你我同把相府进， 三人对面说分明。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "他三人与我有仇恨， 咬定了牙关他是不认承。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "我父在朝为官宦， 府中金银堆如山。 本利算来该多少， 命人送到西凉川。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "西凉川四十单八站， 为军的要人我是不要钱。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "我进相府对父言， 将你带到官衙前。 打板子、上夹棍、丢南牢、坐监禁， 管叫你思前容易退后难。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "大嫂说话理不端， 为军哪怕到官前。 衙里衙外我打点， 管保大嫂就断与了咱。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "军爷作事欠思念， 欺人犹如欺了天。 西凉鞑子把你斩， 妻儿老小奴一般。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "好一个贞节王宝钏， 百般调戏也枉然。 腰间取出银一锭， 双手放在了地平川。 这银子三两三， 送与大嫂作养奁。 买绫罗作衣衫、打手饰置簪环， 作一对少年夫妻就过几年。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "这锭银子我不要， 与你娘做一个安葬钱。 买白布做白衫、买白纸糊白幡， 落一个孝子的名儿天下传。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "烈女不该出绣房， 因何来在大道旁。 为军起下不良意， 来来来、一马双跨奔西凉川。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "走，上马！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀……"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "一见军爷变了脸， 吓得宝钏心胆寒。 低下头来心暗转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵牵马。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "走，上马！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷，那旁有人来了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "在那里，唗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏撒土迷薛平贵眼。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "急忙回转寒窑前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        },
        {
          "character": "薛平贵",
          "type": "笑",
          "text": "哈哈……"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "好个贞节王宝钏， 果然为我受熬煎。 不骑马来步下赶， 夫妻相会寒窑前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "走啊！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "前面走的王宝钏，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "后面跟随平贵男。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "进得窑来将门掩，"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "将为丈夫关至在这窑外边。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "先前说是当军汉， 如今又说儿夫男。 说得明白重相见， 说不明来也枉然。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "妻呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "提起了当年泪不干，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "夫妻们在寒窑受尽了熬煎。 自从降了红鬃战， 唐王驾前去讨官。 官封我后军都督府， 你的父一旁把本参。 自从盘古立地天，"
        },
        {
          "character": "薛平贵",
          "type": "西皮流水板",
          "text": "哪有个岳父把婿参。 西凉国造了反， 为丈夫倒作了先行官。 两军阵前遇代战， 将我擒过了马雕鞍。 多蒙那老王施恩典， 反把公主配良缘。 西凉的老王把驾晏， 众文武保我坐银安。 那一日驾坐银安殿， 宾鸿大雁口吐人言。 手执金弓银弹打， 打下了半幅血罗衫。 打开罗衫从头看， 才知道寒窑受苦的王宝钏。 不分昼夜往回赶， 为的是回家夫妻团圆。 三姐不信从头算， 连来带去十八年。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "既是我夫回家转， 可有血书你付与我观。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "水流千遭归大海， 原物交还本人观。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "一见血书心好惨， 果然是我夫转回还。 开了窑门重相见，"
        },
        {
          "character": "王宝钏",
          "type": "夹白",
          "text": "唗！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "我丈夫哪有五绺髯？"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "少年子弟江湖老， 红粉佳人两鬓斑。 三姐不信菱花看， 你容颜不似彩楼前。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "寒窑哪有菱花照？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "水盆里面。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "水盆以内照容颜。"
        },
        {
          "character": "王宝钏",
          "type": "夹白",
          "text": "老了！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "啊……容颜变哪， 十八载老了王宝钏。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "快快开门，夫妻相见。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "既是我夫回来，必须要退后一步。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "退一步。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "再退后一步。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "再退一步。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "还要你退后一步。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀妻呀！后面无有路了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "后面若是有路，你……就不回来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "我把寒窑交与你，"
        },
        {
          "character": "王宝钏",
          "type": "夹白",
          "text": "唉！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "不如碰死在窑前。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "三姐不必寻短见， 为丈夫跪在窑外边。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "走向前来用手挽， 十八载做的什么官？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "进得窑来，不问我饥寒二字，就问我做的甚么官？难道你吃官穿官不成么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "是呀，你进得窑来，也不曾问我饥寒二字。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我与你留下安家度用。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "甚么安家度用？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "十担干柴、八斗老米。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "十担干柴、八斗老米，慢说是吃，就是数，也把它数完了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "就该去借。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哪里去借？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "相府去借。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "自你去后，我未曾进过相府。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好，有志气，走哇！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "相府算粮。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我家爹爹，他病了．"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "他得的是什么病？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "他得了见不得你的病。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我若得了唐室天下，他与我牵马坠蹬，我还嫌他老呢？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你要醒来说话。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "未曾睡着。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "句句都是梦话。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有道是龙行有宝。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有宝献宝。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "无宝呢？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "看你的现世包。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐观宝！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "在头上整整沿毡帽， 身上抖抖紫罗袍。 腰间取出番邦宝， 三姐拿去仔细瞧。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "用手接过番王宝， 果然金光照满窑。 走向前来忙跪倒， 君王面前讨封诰。"
        },
        {
          "character": "薛平贵",
