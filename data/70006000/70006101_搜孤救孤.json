{
  "script_id": "70006101",
  "title": "搜孤救孤",
  "alias": [],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "程婴",
      "hangdang": "老生"
    },
    {
      "name": "屠岸贾",
      "hangdang": "净"
    },
    {
      "name": "公孙杵臼",
      "hangdang": "老生"
    },
    {
      "name": "程妻",
      "hangdang": "旦"
    }
  ],
  "plot": "晋赵盾死后，屠岸贾诬其曾弑灵公，请景公杀死其子赵同、赵括、赵朔等。赵朔娶成公之女庄姬，庄姬将孤\n儿带入宫中躲藏，赵门客程婴暗将孤儿救回家中。屠岸贾再搜不得，下令十日内若不献出孤儿，即将国中与\n孤儿同庚婴儿杀死。程婴乃舍子，公孙杵臼舍身，合计救孤。",
  "notes": "晋赵盾死后，屠岸贾诬其曾弑灵公，请景公杀死其子赵同、赵括、赵朔等。赵朔娶成公之女庄姬，庄姬将孤\n儿带入宫中躲藏，赵门客程婴暗将孤儿救回家中。屠岸贾再搜不得，下令十日内若不献出孤儿，即将国中与\n孤儿同庚婴儿杀死。程婴乃舍子，公孙杵臼舍身，合计救孤。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "【第一场：定计】"
        },
        {
          "character": "公孙杵臼",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小锣打上〗。公孙杵臼上，至中场台口。"
        },
        {
          "character": "公孙杵臼",
          "type": "引子",
          "text": "赵屠结怨恨，不知何日得罢休？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "老汉，公孙杵臼，昔日曾为赵相的门客，可恨屠贼诬害赵家三百余口，只有庄 姬一人，逃进宫去。闻听在宫中产生孤儿，屠贼闻知，进宫搜孤，也不知搜出 无有？唉，天哪！但愿留得忠良之后，也好与赵家报仇雪恨哪！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄原板",
          "text": "赵屠二家有仇恨， 三百余口命赴幽冥。 眼见忠良无救应， 大事还有须问程婴。"
        },
        {
          "character": "程婴",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "屠贼做事心太狠， 三百余口赴幽冥。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "来此已是。 公孙兄在家么？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "是哪一位？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "哦，小弟来了。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "原来是程贤弟来了，请！请坐。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "有坐。唉！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "啊，贤弟，叹着何来？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "晋国之中，出了这样惊天动地的奇事，你还不知道么？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "又出了什么惊天动地的奇事？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "只因屠贼，诬杀赵家三百余口，只剩庄姬一人，逃回宫去，产生孤儿。屠贼进 宫搜孤，不曾搜出，标出赏格在外：十日之内，有人献出孤儿，赏赐千金。不 然，要将这晋国中的婴孩，只要与孤儿般长般大，俱要刀刀斩尽！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "此事愚兄早已知道，贤弟你的来意如何啊？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小弟特为此事前来，与兄商议救孤之策呀！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "哎呀，愚兄是忙中无计呀！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "怎么你也是忙中无计么？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "忙中无计呀！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小弟倒有一两全之计，此时若有一人，舍得一命，若有一人，舍得一子，就可 以救得孤儿的性命。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "贤弟你来看！愚兄偌大年纪，情愿舍命，但不知哪一个舍子呢？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小弟有一子，与孤儿般长般大，我意欲将孤儿掉换下来，藏在小弟家内，再将 我亲生之子，抱到兄处，待弟去到奸贼那里出首，就说你隐藏孤儿不报。屠贼 闻知，定要前来搜孤。哎呀，那时只恐你的性命难保哇！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "那时愚兄，见机而行。我那弟妹，可曾知晓？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "话虽如此，你那弟妹她还不知道哇。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "哎呀，只怕弟妹她不能应允吧？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "不妨，不妨。想你那弟媳，虽是女流，是颇通大义，想此事她、断乎不能不肯 吧！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "好，贤弟回家商议，愚兄随后就到。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "你我二人把计定， 救孤的事儿我担承。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "但愿救得忠良后， 满斗焚香谢神灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼下。"
        },
        {
          "character": "公孙杵臼",
          "type": "stage",
          "text": "【第二场：舍子】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程妻上。"
        },
        {
          "character": "程妻",
          "type": "念",
          "text": "仗义救孤生，妻随夫志行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "大事安排定，劝妻舍亲生。"
        },
        {
          "character": "程妻、程婴",
          "type": "同白",
          "text": "啊，（官人）（娘子）！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "啊，官人，那屠贼如此行为，难道就不怕报应了么？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "事到如今，还说什么苍天报应，屠贼进宫搜孤不曾搜出，又起了狠毒之心哪！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "但不知什么狠毒之心哪？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "屠贼一计不成，又生二计，标出赏格在外，十日之内，有人献出孤儿，赏赐千 金。不然，要将晋国中的婴孩，只要与孤儿般长般大，俱要刀刀斩尽！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "如此说来，那孤儿岂不是无有救了？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "我与公孙老爷定一计策，可以救得孤儿。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "但不知有何妙计？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "此时，若有一人舍命，若有一人舍子，可以搭救孤儿的性命。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "但不知哪个舍命？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "啊、娘子，那公孙老爷他情愿舍命哪！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "噢，这舍子呢？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "这舍子么，啊娘子，想我夫妻，曾受赵家的厚恩，焉能坐观成败。我意欲，将 你我琴声之子舍了，将孤儿调换下来，抚养成人，一来不绝忠良之后，二来也 好报仇，啊娘子，你看此计可好吗？"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "官人此言差矣，想你我夫妻，年将半百，只生此子，焉能救得孤儿？此事是万 万不能！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "唉，娘子啊！"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "娘子不必太烈性， 卑人言来你是听： 赵屠二家有仇恨， 三百余口命赴幽冥。 我与那公孙杵臼把计定， 他舍命来你我舍亲生。 舍子搭救忠良的后， 老天爷不绝我的后代根。 你今舍了亲生子， 来年必定降麒麟。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "官人！"
        },
        {
          "character": "程妻",
          "type": "二黄原板",
          "text": "官人说话理不顺， 奴家言来听分明： 你我只生一个子， 焉能舍子救孤身。"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "千言万语她不肯， 不舍姣儿难救孤身。 无奈何我只得双膝跪，"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "哀求娘子舍亲生。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "官人！"
        },
        {
          "character": "程妻",
          "type": "二黄散板",
          "text": "你要跪来只管跪， 叫我舍子万不能！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "人道妇人心肠狠， 狠毒不过你妇人的心。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "程妻",
          "type": "二黄散板",
          "text": "虎毒不食儿的肉， 你比虎狼狠十分。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "不如程婴死了罢，"
        },
        {
          "character": "程妻",
          "type": "二黄散板",
          "text": "或生或死一路行。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "手执钢刀我要你的命，"
        },
        {
          "character": "程妻",
          "type": "二黄散板",
          "text": "用手关上两扇门。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "哼，岂有此理呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程妻下。公孙杵臼上。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "我与程婴把计定， 未必他妻似我心。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "啊贤弟！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "唉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下意请公孙杵臼坐小边。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "哎呀，公孙兄！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴忽然醒悟，急忙起立让公孙杵臼坐大边。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "噢噢噢。 啊贤弟，弟妹可曾应允哪？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "这个贱人她不肯哪！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "啊？你先前言道，我那弟妹颇通大义，如今她为何不肯哪？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "啊，她、她、她、她，她不肯哪！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "请出来，待愚兄良言相劝。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "公孙兄稍候。 贱人与我走了出来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程妻上。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "公孙老爷来了，有话对你讲呃！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "晓得！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "公孙兄万福。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "弟妹少礼，请坐！"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "有坐，公孙兄到此何事？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "弟妹舍了亲生子，来年必定降麒麟。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "怎么又来了！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄原板",
          "text": "人有善恶天有灵， 莫把阴功当浮云。 舍子搭救忠良后， 赵家代代不忘你的恩。"
        },
        {
          "character": "程妻",
          "type": "二黄原板",
          "text": "公孙兄说话欠思论， 奴家言来你是听： 只为我家无二子， 岂肯舍子救孤身。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄摇板",
          "text": "老朽薄面情要准，"
        },
        {
          "character": "程妻",
          "type": "二黄摇板",
          "text": "你要尽义我不行。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "看起来你是个不贤的妇！"
        },
        {
          "character": "程妻",
          "type": "二黄散板",
          "text": "要我舍子万不能！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "手执钢刀项上刎，"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "贤弟息怒暂消停。 走向前来良言劝， 死了丈夫你靠何人？"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "多口！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "莫奈何我只得双膝跪，"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "哎……跪不得。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "你也跪下吧！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "哀求弟妹舍亲生。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "程妻",
          "type": "二黄散板",
          "text": "他二人哭得珠泪滚， 铁石人儿也泪淋。 公孙兄与夫且请起， 情愿舍子救孤身。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "弟妹舍得亲生子， 代代世世标美名。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "娘子啊！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "多谢娘子开了恩， 你母子快快两离分！"
        },
        {
          "character": "程妻",
          "type": "二黄散板",
          "text": "一句话儿错出唇， 娇儿送进枉死城。 且把娇儿怀抱定。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖快扫头〗。程婴抢子，程婴、程妻、公孙杵臼同下。"
        },
        {
          "character": "程妻",
          "type": "stage",
          "text": "【第三场：公堂·搜孤】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同上，屠岸贾上。"
        },
        {
          "character": "屠岸贾",
          "type": "念",
          "text": "要除心头恨，斩草要除根。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "老夫、屠岸贾。前番搜孤，并未搜出，因此出下赏格，十日之内，有人献出孤 儿，赏赐千金；若无人献孤，要将这晋国中的婴孩，与孤儿同庚者，一齐斩尽 杀绝。 这校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": "程婴",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上，击鼓。"
        },
        {
          "character": "校尉甲",
          "type": "白",
          "text": "有人击鼓。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "命击鼓人上堂。"
        },
        {
          "character": "校尉甲",
          "type": "白",
          "text": "击鼓人上堂！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "报，击鼓人告进。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "叩见大人！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "唗！上告自有日期，为何擅击堂鼓？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "大人前者搜孤，可曾搜出？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "未曾搜出。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "孤儿喏在！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "啊！现在何处？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "现在首阳山公孙杵臼的家中。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "去到首阳山将公孙杵臼，抓来见我。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二校尉同下。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你是怎么知道？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "是小人与公孙杵臼俱是赵家的门客，又有八拜之交。只因他隐藏孤儿不报，小 人劝他献出，况且大人还要赏赐于金，谁想这老儿执意的不肯，反来辱骂小人。 小人本当不来出首，怎奈大人有令在先，知情不举者罪加一等，为此特地前 来禀告大人。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "名叫程婴。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "程婴！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "起过一旁。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二龙套同上，公孙杵臼上。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "叩见大人！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "唗！胆大的老狗，隐藏孤儿不报，该当何罪？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "大人！小人隐藏孤儿不报，是何人得见？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你来看！"
        },
        {
          "character": "公孙杵臼",
          "type": "叫头",
          "text": "哎呀大人哪！"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "此人名叫程婴，与小人素日有仇，他乃是诬告小人。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "诬告小人。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄散板",
          "text": "老狗说话大不正， 知法犯法罪非轻。 隐藏孤儿你不报， 论王法尔就该问斩刑。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "好贼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼故指程婴。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "白虎大堂一声禀， 尊声大人听分明： 这是程婴他诬告我， 拿什么孤儿献大人？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "老狗！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄散板",
          "text": "老狗再三不招认， 不由老夫动无名。 人来与爷乱棍打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同打公孙杵臼。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "纵然打死我也不招承。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄散板",
          "text": "回头便把程婴叫， 老夫赐你鞭一根。 一边打来一边问， 看他招承不招承？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "程婴",
          "type": "二黄倒板",
          "text": "白虎大堂奉了命，"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "程婴！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你要与我着实的打！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "程婴",
          "type": "二黄垛板回龙",
          "text": "都只为、救孤儿、舍亲生、连累了年迈苍苍受苦刑、眼见得两离分。"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "我与他人定巧计， 到如今连累他受苦刑。 开言便把公孙兄问， 小弟言来你是听： 你若是再三的不肯招认， 大人的王法不容情。 手执皮鞭将你打，"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "你、你切莫要胡言攀扯我好人。"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "贼！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "指着程婴高声骂， 死在阴曹要勾尔的魂。"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "公孙杵臼不肯认， 大人首阳去搜寻。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "带了老狗，打道首阳山。"
        },
        {
          "character": "二校尉",
          "type": "同白",
          "text": "来到首阳山。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "两厢搜来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同搜，抱孤儿上。"
        },
        {
          "character": "屠岸贾",
          "type": "叫头",
          "text": "老狗！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你说孤儿不在，这夹壁墙内婴孩哪里来的？"
        },
        {
          "character": "公孙杵臼",
          "type": "白",
          "text": "奸贼！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "屠贼做事心太狠， 苦害赵家为何情？"
        },
        {
          "character": "公孙杵臼",
          "type": "夹白",
          "text": "罢！"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "拼着老命把孤儿抢，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾踢公孙杵臼。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄散板",
          "text": "一足踏你地埃尘。 人来与爷忙上捆，"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "飞蛾投火自烧身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二校尉、公孙杵臼同下。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人讨祭。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你为何祭他？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "我与公孙杵臼，旧有八拜之交，故而讨祭，以表当年结拜之情。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "好，容你一祭，去罢。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "谢大人！"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "虽然杯酒寻常饮， 叙叙当年故旧情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "打道法场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾、二校尉同下。"
        },
        {
          "character": "屠岸贾",
          "type": "stage",
          "text": "【第四场：法场·救孤】"
        },
        {
          "character": "公孙杵臼",
          "type": "内二黄导板",
          "text": "一片好心反成恨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼上。〖夺头〗。"
        },
        {
          "character": "公孙杵臼",
          "type": "回龙",
          "text": "都只为救孤儿年迈苍苍受苦刑。"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄原板",
          "text": "心中只把屠贼恨， 诬害赵家一满门。 含悲忍泪法场进，"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄散板",
          "text": "咬定牙要等时辰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "迈步儿来在法场中， 只见孤儿与公孙。"
        },
        {
          "character": "程婴",
          "type": "叫头",
          "text": "公孙兄，赵公子！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "你二人死在九泉之下，莫怨我程婴啊！"
        },
        {
          "character": "程婴",
          "type": "二黄碰板",
          "text": "躬身下拜礼恭敬， 眼望孤儿泪淋淋。 法场上看的人都来叫骂， 一个个骂的是我程婴，是一个无义的人。"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "贪享荣华受富贵， 断送了忠良爷的后代根。 这是我好意反成恶意， 满怀心腹事向谁云？"
        },
        {
          "character": "公孙杵臼",
          "type": "二黄原板",
          "text": "去了好言恶言骂， 开言大骂小程婴。 你不过贪图受富贵， 你不过求赏得千金。 我今一死不打紧， 叮咛抚孤要小心。"
        },
        {
          "character": "程婴",
          "type": "二黄原板",
          "text": "公孙兄说话须谨慎， 泄漏了机关大事难成。 先前抚孤是你我， 到如今知心又有谁人？ 你为忠良舍了性命， 可叹我程婴绝了后根。 无奈何烧纸把酒奠， 我那亲——"
        },
        {
          "character": "四校尉",
          "type": "内同白",
          "text": "哦！"
        },
        {
          "character": "程婴",
          "type": "哭",
          "text": "我、我的儿，"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "但愿你灵魂早超生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、屠岸贾同上。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "可曾祭奠？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "祭奠已毕。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "将老狗与孤儿一齐开刀！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙杵臼、四校尉同下。〖起鼓〗。四校尉同上。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "程婴，程婴，程婴！"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "啊、啊、啊大人！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你为何落泪？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人先前也曾言道，我与公孙杵臼，俱是赵家的门客，又有八拜之交，只因他 隐藏孤儿不报，是小人劝他献出，也免得连累旁人家许多的孩儿。谁想这老儿 执意的不肯，他如今落得身首异处，故而在此悲叹，不禁落泪。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "老夫有言在先，有人献出孤儿，赏赐千金。 来，与程婴看赏。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "且慢！小人不愿领赏。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小人有一子，与孤儿般长般大，今日小人将孤儿出首，恐日后旁人怀恨在心， 加害我父子的性命，恳求大人格外施恩，与小人作主。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你将此子，抱来见我。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "程婴",
          "type": "二黄滚板",
          "text": "背转来笑盈盈， 奸贼中了我的巧计行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "屠岸贾",
          "type": "二黄散板",
          "text": "老夫仇人俱杀尽， 这才是斩草除了根。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "二黄散板",
          "text": "怀抱孤儿法场进， 日后长大要杀仇人。"
        },
        {
          "character": "屠岸贾",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "屠岸贾",
          "type": "二黄摇板",
          "text": "此子生来有福分， 眉清目秀是贵人。 老夫膝下无有后，"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "儿啊，哈哈哈！"
        },
        {
          "character": "屠岸贾",
