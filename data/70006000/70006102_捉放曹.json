{
  "script_id": "70006102",
  "title": "捉放曹",
  "alias": [],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "陈宫",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "吕伯奢",
      "hangdang": "老生"
    },
    {
      "name": "店家",
      "hangdang": "丑"
    }
  ],
  "plot": "曹操谋刺董卓未成逃走，董卓下信捕拿，曹操逃至中牟县为关吏所获。县令陈宫敬曹操忠直，私行释放，弃\n官同逃，路遇曹操父执吕伯奢加以款待，曹操心疑，杀死吕伯奢及其全家。陈宫怨曹操不仁，乘夜弃曹操而\n去。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。自《行路》起，标记为“第五场”。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "自作自受自遭殃， 小鬼怎挡五阎王？ 宝剑一举全家丧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫上。"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "吓得我三魂七魄忙。"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "怒气不息向后闯，"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "陈宫向前扯衣裳。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公！你将他一家杀死，手执宝剑，又欲何往？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "取把火来，烧他的庄院。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "杀人放火岂是你我所为？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "不要你管，闪开了！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "使不得！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "取把火来烧他的庄，"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "杀人还要火焚房。"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "宝剑一举厨下往，"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "嘿嘿！"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "见一捆猪在厨房。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公！你将他一家错杀了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "分明是那老丈吩咐家下人等，杀猪宰羊款待你我，岂不是错杀了？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我却不信！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "你自己看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操看。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嘿嘿！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "孟德做事太莽撞， 错把一家好人伤。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公！你将他一家杀死，等那老丈沽酒回来，你拿何言答对？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这个……公台！你我三十六计，走为上策，不如寻找马匹逃走了吧！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "事到如今，也只好是一走。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "走啊。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "走啊。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "走。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "走。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "走啊！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "走、走、走！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "出得庄来把马上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下"
        },
        {
          "character": "陈宫",
          "type": "西皮快板",
          "text": "背转身来自思量， 只道他是个定国的安邦将， 却原来贼是人面一个兽心肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吕伯奢上。"
        },
        {
          "character": "吕伯奢",
          "type": "西皮摇板",
          "text": "老汉亲自沽佳酿， 眼跳心惊为那桩？ 将身来在庄头上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、陈宫同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "遇见了！"
        },
        {
          "character": "吕伯奢",
          "type": "西皮摇板",
          "text": "又见二公走慌忙。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "二公，这般时候，意欲何往？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "侄男避祸事小，连累伯父事大，告辞了。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "且慢！老汉也曾吩咐家下人等杀猪宰羊，款待二公。"
        },
        {
          "character": "陈宫",
          "type": "夹白",
          "text": "如何？"
        },
        {
          "character": "曹操",
          "type": "夹白",
          "text": "嘿！"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "怎么就要走去，如若不然，老汉就要强留了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "啊！老丈不必强留，回到家去自然明白。你我后会有期，我这里谢谢了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "辞别伯父把马跨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "陈宫心中似刀扎。"
        },
        {
          "character": "陈宫",
          "type": "夹白",
          "text": "老丈！"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "多蒙老丈你的美意大， 好意反成恶冤家。"
        },
        {
          "character": "吕伯奢",
          "type": "夹白",
          "text": "这从哪里说起？"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "急忙里难说你我的知心话， 你莫怨我陈宫你怨他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "吕伯奢",
          "type": "西皮摇板",
          "text": "孟德上马急喳喳， 陈宫为何泪如麻。 莫不是家下人说了错话， 言语不周得罪了他？ 叫人难解真和假？"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "吕伯奢",
          "type": "西皮摇板",
          "text": "回到家去问根芽？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕伯奢下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操、陈宫同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "勒住丝缰停住马，"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "他人不走事又差。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公，为何停马不走啊？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "忘了嘱咐那老狗几句言语。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "什么言语，你就放他一条老命去吧！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "休要你管。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "天地良心啊！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "伯父请转！"
        },
        {
          "character": "吕伯奢",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕伯奢上。"
        },
        {
          "character": "吕伯奢",
          "type": "西皮摇板",
          "text": "相逢未说知心话， 再与孟德把话答。"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "贤侄莫非有回转之意？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "回转之意倒有，伯父你看身后何人？"
        },
        {
          "character": "吕伯奢",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "陈宫哭得咽喉哑， 年迈老丈染黄沙。 一家大小丧剑下，"
        },
        {
          "character": "陈宫",
          "type": "哭",
          "text": "老丈！"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "啊哈哈！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "陈宫",
          "type": "西皮散板",
          "text": "再与孟德把话答。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公！你将他一家大小杀死，尚且追悔不及，出得庄来，又将老丈剑劈道旁， 是何理也？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "杀死老狗，以除后患。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "是你这样疑心杀人、岂不怕天下人咒骂于你？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这个！陈宫！俺曹操一生作事，宁负天下人，不叫天下人来负我！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "陈宫",
          "type": "西皮慢板",
          "text": "听他言吓得我心惊胆怕， 背转身自埋怨我自己作差。 我先前只望他宽洪量大， 却原来贼是个无义的冤家。 马行在夹道内我难以回马， 这才是花随水水不能恋花。 这时候我只得暂且忍耐在心下， 既同行共大事必须要劝解于他！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你的言多、语诈！"
        },
        {
          "character": "陈宫",
          "type": "西皮二六板",
          "text": "休道我言语多必有奸诈， 你本是大义人把事作差。 吕伯奢与你父相交不假， 为什么起疑心杀他的全家？ 一家人被你杀也就该罢， 出庄来杀老丈是何根芽？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公台！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "陈公台休埋怨一同上马，"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "跨雕鞍听孟德细说根芽： 吕伯奢与我父相交不假， 错把他当作了对头怨家。 既杀人哪怕他泰山倒下， 五阎君撞着俺也要杀他。"
        },
        {
          "character": "陈宫",
          "type": "西皮摇板",
          "text": "好言语劝不醒蠢牛木马， 把此贼好一比井底之蛙。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "紧加鞭催动了能行跨下， 黑暗暗雾沉沉有户人家。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "天色已晚，你我安歇了吧！"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "但凭于你。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "店家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "啊哈！"
        },
        {
          "character": "店家",
          "type": "念",
          "text": "高挂一盏灯，安歇四方人。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "二位客官敢是住店的吗？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可有上房？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "有上房。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将马带过。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "不卸鞍辔明日早行。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "二位客官用些什么？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明灯一盏。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "暖酒一壶。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是啦。 明灯一盏、暖酒一壶啊！ 二位还用些什么？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唤你再来，去吧。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公台请来用酒。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "鞍马劳顿、吞吃不下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哪里是鞍马劳顿吞吃不下，分明是见俺杀了吕伯奢的全家，你那心中有些不忿， 是与不是？"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "既与同行共图大事，说什么忿与不忿，只是你的疑心忒大了哇！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "俺曹操一生，就是疑心忒大！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "孟德遇事疑心大， 常在虎口去拔牙。 多饮几杯安歇罢， 昏昏沉沉倒卧下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操睡。〖起初更鼓〗。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公、孟德！ 他睡着了。唉！我陈宫好悔也！"
        },
        {
          "character": "陈宫",
          "type": "二黄慢板",
          "text": "一轮明月照窗下， 陈宫心中乱如麻。 悔不该心猿并意马， 悔不该随他人到吕家。 吕伯奢可算得义气大， 杀猪沽酒款待与他。 又谁知此贼的疑心太大， 拔出剑将他的满门杀。 一家人俱丧在宝剑之下， 年迈的老丈命染黄沙。 屈死的冤鬼魂休来怨咱， 自有那神灵儿天地鉴察。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "陈宫",
          "type": "二黄原板",
          "text": "听谯楼打罢了二更鼓下， 越思越想把事来做差。 悔不该把家属一旦撇下， 悔不该弃县令抛却了乌纱。 我只说贼是个宽洪量大， 汉室后来贼是个惹祸的根芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "陈宫",
          "type": "二黄原板",
          "text": "观此贼睡卧真潇洒， 安眠好似井底之蛙。 贼好比蛟龙未生鳞甲， 贼好比猛虎未曾长牙。 虎在笼中我不打， 我岂肯放虎归山又把人抓？"
        },
        {
          "character": "陈宫",
          "type": "二黄散板",
          "text": "持宝剑将贼的头割下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操翻身。"
        },
        {
          "character": "陈宫",
          "type": "二黄散板",
          "text": "险些儿把事又作差。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "哎呀且住！如今一剑将他杀死。岂不被天下人疑心我与董卓同党。将剑入库。 不免题诗一首，打动此贼。但不知以何为题？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "就以四更为题。"
        },
        {
          "character": "陈宫",
          "type": "念",
          "text": "鼓打四更月正浓，心猿意马归旧踪。误杀吕家人数口，方知曹……"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "明公、孟德。"
        },
        {
          "character": "陈宫",
          "type": "念",
          "text": "方知曹操是奸雄。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "陈宫题。天即明亮，不免寻找马匹逃走了吧！"
        },
        {
          "character": "陈宫",
          "type": "二黄散板",
          "text": "这是我把事来做差， 悔不该随贼奔天涯。 落花有意随流水， 流水无情空恋花。"
        },
        {
          "character": "陈宫",
          "type": "白",
          "text": "我好悔也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宫下。〖起五更鼓〗。"
        },
        {
          "character": "曹操",
          "type": "二黄散板",
          "text": "一梦阳台到故家， 不见陈宫事有差。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀且住！陈宫不见，桌案现有柬帖，待我看来！"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "鼓打四更月正浓，心猿意马归旧踪，误杀吕家人数口，方知曹操是奸雄。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "陈宫题。呀呸！陈宫题诗咒骂于我，日后若不杀他，誓不为人。 店家，银两放在桌案之上，俺去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。曹操打马下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}