{
  "script_id": "70006105",
  "title": "失街亭·空城计·斩马谡",
  "alias": [],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "司马懿",
      "hangdang": "净"
    },
    {
      "name": "马谡",
      "hangdang": "净"
    },
    {
      "name": "王平",
      "hangdang": "老生"
    }
  ],
  "plot": "诸葛亮闻魏又起用司马懿为帅，因街亭为汉中咽喉要地，拟派将驻守。马谡请令，诸葛亮再三叮嘱须靠山近\n水扎营，并令王平辅之。马谡刚愎自用，违令，又不听王平谏言，竟在山顶扎营，因而被魏将张郃所败，街\n亭失守。诸葛亮驻西城，得街亭失守之讯，又知司马懿乘胜来攻，所部精锐已俱被遣出，西城空虚；在危急\n中，定空城之计，令将城门大开，自坐城头，抚琴饮酒以待。司马懿兵至城下，见状大疑，又素知诸葛亮谨\n慎，不进而退；及至探明回军，诸葛亮已调来赵云，惊退司马懿。马谡与王平回营请罪，诸葛亮虽惜马谡之\n才，但以军法无私，挥泪斩之；并因己用人失当，上表自贬。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。因原稿只含主角唱念的场次，故《失街亭》第二至九场、《空\n城计》第三至四场从略。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同上，诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "羽扇纶巾，四轮车，快似风云。阴阳反掌定乾坤，保汉家，两代贤臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、王平、马岱、马谡同上。"
        },
        {
          "character": "赵云、王平、马岱、马谡",
          "type": "同白",
          "text": "参见丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军少礼！"
        },
        {
          "character": "赵云、王平、马岱、马谡",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "忆昔当年居卧龙，万里乾坤掌握中。扫尽狼烟复汉统，人曰男儿大英雄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫、复姓诸葛名亮、字孔明、道号卧龙。蒙先帝爷在白帝城托孤以来，要扫 荡中原、扭转汉室。闻得司马懿兵至祁山，必然夺取街亭。想街亭乃汉中咽喉 之地，必须派一能将，前去防守。 列位将军！"
        },
        {
          "character": "赵云、王平、马岱、马谡",
          "type": "同白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哪位将军愿带领人马，镇守街亭敢当此任？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相传下将令并无一人应声，待俺马谡进帐讨令。 启禀丞相：马谡愿往。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔！马将军愿往么？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "当报国恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那司马懿虽然年迈，用兵如神，将军不可轻敌。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！俺马谡跟随丞相以来，攻无不取，战无不胜。何况那小小的街亭？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "街亭虽小，干系甚重啊。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "愿当军令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军无戏言。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "愿立军状。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "当帐立来。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "马谡乎！ 丞相请看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "候令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "列位将军！哪位将军愿带领人马、协同马谡镇守街亭，当帐请令。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平愿往。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "王将军愿往么？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "当报国恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此番到了街亭，靠山近水安营扎寨。安营之后，画一图形，速报我知。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "赵老将军听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "镇守列柳城。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马岱听令！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "解押粮草，军中听用，不得迟误。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马谡进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "末将正在点动人马，丞相呼唤，有何军事密令？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今逢大敌，非比寻常，我有一言，将军听了！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮原板",
          "text": "两国交锋龙虎斗， 各为其主统貔貅。 管带三军要宽厚， 赏罚中公平莫要自由。 此一番领兵去镇守， 靠山近水把营收。"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "我主本是汉家后， 南征北战不停留。 辞别丞相出帐口， 好似顺水送轻舟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "先帝爷白帝城叮咛就， 汉诸葛扶幼主岂能无忧？ 但愿得此一去扫平贼寇， 免得我亲自去把贼收。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、诸葛亮同下。"
        },
        {
          "character": "诸葛亮",
          "type": "stage",
          "text": "《空城计》"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮偕二琴童同上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "兵扎祁山地，要擒司马懿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "人行千里路，马过万重山。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "门上哪位在？"
        },
        {
          "character": "琴童甲",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "献图人求见。"
        },
        {
          "character": "琴童甲",
          "type": "白",
          "text": "候着。 启禀丞相：献图人求见。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "琴童甲",
          "type": "白",
          "text": "丞相传你，随我进来。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。 参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "罢了，你奉何人所差？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "奉王将军所差，地理图呈上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "展开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮看图。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你去到列柳城，速将赵老将军调回营来，快去、快去。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊！好一个大胆的马谡哇！临行之时，怎样的嘱咐与你，叫你靠山近水安营扎 寨，怎么你偏偏在山上扎营？哎呀，只恐街亭难保。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！ 王平、马谡失守街亭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "如何？果然把街亭失守了。王平、马谡失守街亭，乃诸葛之罪也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！ 司马懿领兵，往西城而来。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔呼呀！那司马懿居然带兵夺取西城来了。咳！曾记得先帝爷在白帝城托孤之 时，说道马谡言过其实，终无大用。悔不听先皇之言，错差马谡，失守街亭， 如今我是悔之晚矣呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！ 司马懿大兵，离西城不远。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再、再、再、再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊！司马懿的大兵，来得好快呀！唔！人言司马，用兵如神，今日一见，令人 可敬、令人可服！哎呀且住！我将西城的兵将，俱已调遣在外。所剩下的都是 些个老弱残兵。司马懿兵临城下，难道叫我束手被擒？这、这、这束手？被擒！ 来，老军们进见。"
        },
        {
          "character": "琴童甲",
          "type": "白",
          "text": "老军们进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同上。"
        },
        {
          "character": "老军甲",
          "type": "念",
          "text": "司马兵到，"
        },
        {
          "character": "老军乙",
          "type": "念",
          "text": "心惊肉跳。"
        },
        {
          "character": "老军甲",
          "type": "念",
          "text": "见了丞相，"
        },
        {
          "character": "老军乙",
          "type": "念",
          "text": "急忙跪倒。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你们是西城的老军么？"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命尔等将四门大开，每门二十名打扫街道，那司马懿兵临城下，尔等不可惊慌 浮躁，违令者斩！"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "老军甲",
          "type": "念",
          "text": "丞相吩咐我，"
        },
        {
          "character": "老军乙",
          "type": "念",
          "text": "准死不能活。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "琴童甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带了瑶琴，城楼去者。 天哪，天！国家兴败，就在这空城一计了！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "我用兵数十年从来谨慎， 错用了小马谡无用之人。 无奈何定空城计我的心神不定， 望空中求先帝大显威灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、二琴童同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二老军同上，同打扫街道。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "有请丞相！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二琴童、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "恨马谡失街亭令人可恨， 这时候倒叫我难以调停。"
        },
        {
          "character": "老军甲",
          "type": "白",
          "text": "我说咱们丞相大概是老糊涂了吧？司马懿的大兵到此，不把四门紧闭，反将四 门大开，这不是越老越糊涂了吗？"
        },
        {
          "character": "老军乙",
          "type": "白",
          "text": "可说的是啊！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "问老军因何故纷纷议论？"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "非是小人纷纷议论，司马懿兵临城下，叫小人们胆惊害怕呀！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "国家事用不着尔等劳心。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "虽然说国家事用不着小人们劳心，可是这西城乃是通汉中咽喉要路，须得拿个 准主意才好啊！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "这西城地原本是咽喉路径， 我城内早埋伏有十万神兵。"
        },
        {
          "character": "老军甲",
          "type": "白",
          "text": "怪不得丞相不慌不忙的，原来城里头埋伏有十万神兵呢！伙计，你瞧瞧去。"
        },
        {
          "character": "老军乙",
          "type": "白",
          "text": "我去瞧瞧。 哎，伙计，这里三层外三层，我一个也没看见。"
        },
        {
          "character": "老军甲",
          "type": "白",
          "text": "你肉眼凡胎，怎么能看得见哪！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "叫老军扫街道、把宽心放稳，"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "咋。扫喽扫喽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、二琴童同上城。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "退司马保空城全仗此琴。"
        },
        {
          "character": "司马懿",
          "type": "内西皮导板",
          "text": "大队人马往西城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、司马懿、司马师、司马昭同上。"
        },
        {
          "character": "司马懿",
          "type": "夹白",
          "text": "啊！"
        },
        {
          "character": "司马懿",
          "type": "西皮散板",
          "text": "为何大开两扇门？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "且住！适才探马报道！西城乃是空城。老夫兴兵至此，为何四门大开？ 唔呼呀！想是诸葛亮又在那里弄鬼，不要中了他人之计。 众将官，听我一令！"
        },
        {
          "character": "司马懿",
          "type": "西皮流水板",
          "text": "坐在马上传将令， 大小儿郎听分明： 哪一个胆大把西城进， 定斩人头不容情。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮慢板",
          "text": "我本是卧龙岗散淡的人， 评阴阳如反掌保定乾坤。 先帝爷下南阳御驾三请， 算就了汉家的业鼎足三分。 官封到武乡侯执掌帅印， 东西战南北剿博古通今。 周文王访姜尚周室大振， 汉诸葛怎比得前辈的先生。 闲无事在敌楼我亮一亮琴音，"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮原板",
          "text": "我面前缺少个知音的人。"
        },
        {
          "character": "司马懿",
          "type": "西皮原板",
          "text": "有本督在马上观动静， 诸葛亮在城楼饮酒抚琴。 左右琴童人两个， 打扫街道俱都是那老弱残兵。 我本当传将令杀进城，"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "杀！"
        },
        {
          "character": "司马懿",
          "type": "夹白",
          "text": "杀不得！"
        },
        {
          "character": "司马懿",
          "type": "西皮流水板",
          "text": "又恐怕中了巧计行。 勒住丝缰把话论， 尊一声诸葛听分明： 你我在渭南会一阵， 棋逢对手一般平。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮二六板",
          "text": "我正在城楼观山景， 耳听得城外乱纷纷。 旌旗招展空翻影， 却原来是司马发来的兵。 我也曾差人去打听， 打听得司马领兵往西行。 一来是马谡无谋少才能， 二来是将帅不和失街亭。 你连夺我三城多侥幸， 贪而无厌又夺我的西城。 诸葛亮在敌楼把驾等， 等候你到此谈、谈、谈谈心。 西城的街道打扫净， 预备着司马好屯兵。 诸葛亮无有别的敬， 早备下羊羔美酒犒赏你的三军。 既到此就该把城进， 为甚么犹疑不定，进退两难为的是何情？ 我只有琴童人两个， 我是既无有埋伏又无有兵。 你不要胡思乱想心不定， 你就来、来、来，请上城来听我抚琴。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "司马懿",
          "type": "西皮散板",
          "text": "左思右想心不定， 城内必有埋伏兵。"
        },
        {
          "character": "司马昭、司马师",
          "type": "同白",
          "text": "爹爹！趁此机会杀进城去、活捉那孔明。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "呸！小小年纪知道什么？诸葛亮一生谨慎，从不弄险。我若杀进西城，岂不正 中其计？ 众将官！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "将前队改为后队，人马倒退四十里。 待我说破与他。 诸葛亮呃孔明！你实城也罢、空城也罢，老夫拿定主意不进城，请了！请了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、司马懿、司马师、司马昭同下。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "司马大兵倒退四十里呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下城。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "人言司马善用兵， 到此不敢进空城。 诸葛从来不弄险， 险中有险显才能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、赵云同上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "参见丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军回来了。适才司马带领人马夺取西城，被我空城之计将他惊走，他必然 复夺西城，老将军要速速的抵挡一阵。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。 带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、四上手同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "虎豹在山群兽远，蛟龙得水又复还。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "险哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "诸葛亮",
          "type": "stage",
          "text": "《斩马谡》"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "算就汉家三分鼎， 险些一且化灰尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！马谡、王平回营请罪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "击鼓升帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！赵老将军得胜回营。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "有请！ （探子下。赵云上。诸葛亮向赵云敬酒表示祝贺，赵云拟向诸葛亮讲话，诸葛亮阻止，并摇头请赵云离去， 赵云下。）"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带王平！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平上。"
        },
        {
          "character": "王平",
          "type": "西皮快板",
          "text": "忽听丞相传将令， 不由王平心内惊。 迈步且把宝帐进，"
        },
        {
          "character": "王平",
          "type": "西皮摇板",
          "text": "丞相台前请罪名。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "火上心头难消恨，"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "帐下跪的小王平。 我也曾吩咐你， 靠山近水扎大营。 大胆不听我的令， 失守街亭你的罪不轻。"
        },
        {
          "character": "王平",
          "type": "西皮快板",
          "text": "丞相不必怒气生， 王平言来听分明： 马谡不听王平论， 先有画图作证凭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "若不是画图来得紧， 定与马谡同罪名。 将王平责打四十棍，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二龙套押王平同下，二龙套同上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "再带马谡无用的人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "西皮快板",
          "text": "丞相宝帐令传下， 马谡心中乱如麻。 悔不该不听王平话， 不该山上把营扎。 自古军令无戏耍， 等候丞相将令发。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "见马谡跪帐下， 不由山人咬龈牙。 大胆不听我的话， 失守街亭你差不差？"
        },
        {
          "character": "马谡",
          "type": "西皮快板",
          "text": "马谡无谋作事差， 犯罪理当正军法。 当年跟随先帝驾， 还望丞相厚恩加。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "吩咐两旁的刀斧手， 快将马谡正军法。"
        },
        {
          "character": "马谡",
          "type": "西皮散板",
          "text": "丞相宝帐传令下， 赏罚公平果不差。 二次进帐忙跪下， 末将言来听根芽： 我今一死倒也罢， 家中还有白发的妈。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！马谡失守街亭，理当斩首，死而无怨。但家中尚有八旬老母，无人侍奉。 我死之后，望求丞相另眼看待。马谡纵死九泉，也感丞相的大恩大德。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "见马谡只哭得珠泪洒， 我心中好一似乱刀扎。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马谡！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "幼常！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "武乡侯！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎！只因你未曾出兵，当着满营的将官，先立下军令状。临行之时，何等的嘱 咐与你，叫你靠山近水安营扎寨，谁知你到了街亭，偏偏在山上扎营。如今失 守街亭，若不将你正法、我是何以服众？ 马谡！幼常！咳！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "哦！哦！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "斩！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "娘啊！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "招回来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡回场，向诸葛亮跪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马谡，你方才言道，家有八旬老母，无人奉养。你但放宽心，你死之后，将你 的兵马钱粮，拨与你母以为养老之费。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "多谢丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马谡！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "幼常！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "武乡侯！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "咳！将军哪！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "哦！哦！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "斩、斩、斩、斩！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "该斩哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "我哭、哭一声马将军， 我叫、叫一声马幼常。 未出兵先立军令状， 可叹你为国家刀下身亡。 马谡哇！参谋哇！啊……马幼常！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "丞相斩了马谡为何落泪？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军那里知道！先帝爷在白帝城托孤之时说道，马谡言过其实、终无大用。 是我不听先皇之言、错差马谡、失守三城，我哪里哭的是马谡！哭只哭先帝爷 托孤之言哪！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "也罢！就烦老将军拜本进京，奏明幼主，自贬武乡侯之职。歇兵三日，再与司 马决一死战。后帐摆宴，与老将军贺功！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、赵云同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}