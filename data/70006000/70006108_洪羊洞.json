{
  "script_id": "70006108",
  "title": "洪羊洞",
  "alias": [],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "杨继业",
      "hangdang": "老生"
    },
    {
      "name": "老军",
      "hangdang": "丑"
    },
    {
      "name": "八贤王",
      "hangdang": "老生"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "柴氏",
      "hangdang": "旦"
    }
  ],
  "plot": "杨延昭命孟良再往辽邦洪羊洞盗取杨继业骸骨，焦赞知而暗随至洞；孟良误以为敌将，用斧劈死。既而疑声\n音不类，细察为焦赞，哀悔不已，以遗骨付老兵程宣赍回，自刎洞前。杨延昭闻耗惊悼呕血，病势益重，与\n八贤王及母妻诀别而死。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。因原稿只含主角唱念的场次，故第二至六场、第八场从略。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄原板",
          "text": "为国家哪何曾半日闲空， 我也曾平服了塞北西东。 官封到节度使皇王恩重， 身不爽不由人瞌睡朦胧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、四鬼卒同上。"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "听谯楼打罢了三更时分， 进宋营见六郎细说分明。 叫鬼卒急忙忙大营来进， 又只见我的儿睦睡沉沉。 我这里将他的阴魂唤醒，"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "猛抬头只见故父令公。 曾记得在两狼父把命送， 哪有个人死后又能复逢。 我这里下位去身难转动，"
        },
        {
          "character": "杨继业",
          "type": "二黄回龙",
          "text": "我的儿休贪睡细听分明："
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "儿前番盗父骨尸骸回郡， 那都是萧天佐弄假成真。 父尸骸在北国洪羊洞内， 望乡台第三层那才是真。 父本当与我儿多谈多论， 怕的是天明亮难以回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、四鬼卒同下。家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "元帅醒来！"
        },
        {
          "character": "杨延昭",
          "type": "二黄导板",
          "text": "方才老元戎前来托梦，"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "醒来时不由人珠泪满胸。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "宣孟二爷进帐。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "孟二爷进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良上。"
        },
        {
          "character": "孟良",
          "type": "念",
          "text": "不听皇王诏宣，但听杨家令传。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟少礼，请坐。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "谢坐。唤末将进帐，有何军情？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟有所不知，昨晚三更，偶得一梦，只见我父托兆与我，言道前番盗骨，乃 是假的。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "真的呢？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "真骸骨现在北国洪羊洞，望乡台第三层，那才是真。我有意，命贤弟二下番营 前去盗骨，不知贤弟意下如何？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "末将好比元帅跨下之驹，扬鞭就走，停鞭即止，但听元帅传令。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "好，如此贤弟听令！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "我命贤弟下北番，"
        },
        {
          "character": "孟良",
          "type": "念",
          "text": "此去哪怕路途难。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "但愿盗得尸骨转，"
        },
        {
          "character": "孟良",
          "type": "念",
          "text": "凌烟阁上美名传。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "好，好一个凌烟阁上美名传，小心了！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、孟良同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "孟良盗骨无音信， 倒叫本帅挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院领老军同上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "随我来！ 少站一旁。 启禀元帅：小番求见。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 小番，元帅传你，小心了。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "是。 北国军卒告进。元帅在哪里？元帅在？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "嗯！胆大小番，见了本帅，为何不跪？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "去掉盒儿，方可下跪。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来，将盒儿去掉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院取盒交杨延昭看。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "令公骸骨，啊呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "见骸骨不由人泪双流， 如今才见亲骨肉。 家院供奉二堂后， 再与老军说从头。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "小人与元帅叩头。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "谢元帅。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "小人名叫程宣。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "程宣，你奉何人所差？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "奉孟二爷所差。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "有板斧为证。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "将板斧收下。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "程宣。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你孟二爷他往哪里去了？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "哦喝元帅！孟二爷前去盗骨，焦二爷暗地跟随，孟二爷一时失手，将焦二爷劈 死洪羊洞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唉呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "听罢言来泪双淋， 可叹你为杨家命丧番营。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "程宣，那孟二爷将焦二爷劈死，他因何不来见我啊？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "哦喝、元帅！孟二爷将焦二爷劈死，无有脸面来见元帅，他也自刎在洪羊洞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "自刎在洪羊洞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孟良！焦赞！啊呀！"
        },
        {
          "character": "家院、老军",
          "type": "同白",
          "text": "元帅醒来！"
        },
        {
          "character": "杨延昭",
          "type": "二黄导板",
          "text": "听说二将双双丧命，"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "失了我左右膀难以飞行。 叫老军到番营把尸骨搬运， 待本帅奏圣上超度灵魂。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军下。"
        },
        {
          "character": "杨延昭",
          "type": "二黄摇板",
          "text": "霎时间腹内痛心血上涌， 休得要惊动年迈的太君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、家院同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第九场",
      "utterances": [
        {
          "character": "杨延昭",
          "type": "内白",
          "text": "搀扶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保搀杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄慢板",
          "text": "叹杨家投宋主心血用尽， 真可叹焦、孟将命丧番营。 宗保儿搀为父软榻靠枕，"
        },
        {
          "character": "杨延昭",
          "type": "二黄原板",
          "text": "怕只怕熬不过尺寸光阴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监、御林军引八贤王同上。"
        },
        {
          "character": "八贤王",
          "type": "二黄摇板",
          "text": "来至在郡马府忙下金蹬，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监、御林军同下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "迎接千岁！"
        },
        {
          "character": "八贤王",
          "type": "二黄摇板",
          "text": "宗保免礼且平身。 问宗保你的父何处养病？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "现在病房。"
        },
        {
          "character": "八贤王",
          "type": "白",
          "text": "带路！"
        },
        {
          "character": "八贤王",
          "type": "二黄摇板",
          "text": "又只见御妹夫瞌睡沉沉。"
        },
        {
          "character": "八贤王",
          "type": "白",
          "text": "醒来！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "方才郊外闲游散闷， 遇见了一官长放雕翎。"
        },
        {
          "character": "八贤王",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "对着我前心放一箭， 险些丧了命残生。 猛然间睁开了昏花眼， 抬头只见放箭之人。 我与你一无仇来二无有怨恨， 你、你、你……为什么放雕翎射我前心？"
        },
        {
          "character": "八贤王",
          "type": "二黄摇板",
          "text": "听罢言来才知情， 他病体沉重神志不清。 我与你好亲眷无有仇恨， 休把孤当做了放箭之人。"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "听说贤爷驾到临， 宗保儿向前去请罪负荆。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "参见千岁！"
        },
        {
          "character": "八贤王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "八贤王",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "八贤王",
          "type": "白",
          "text": "啊，御妹夫，你此病从何而起？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唉！贤爷……呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄中三眼",
          "text": "自那日朝罢归安然睡定， 三更时梦见了年迈爹尊。 我前番命孟良骸骨搬请， 那乃是萧天佐以假成真。 真骸骨移在那洪羊洞， 望乡台第三层那才是真。 二次里命孟良番营来进， 又谁知焦克明他私自后跟。 老军报他二人在洪羊洞丧命， 失了我左右膀难以飞行。 为此事终日里忧成疾病， 因此上臣的病重加十分，千岁爷呀！"
        },
        {
          "character": "八贤王",
          "type": "二黄原板",
          "text": "御妹夫休得要珠泪淋淋， 哪有个人死后又能复生。 叫宗保到后堂急忙相请， 请出了儿祖母与儿娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八贤王下。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "有请祖母、娘亲！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君、柴氏同上。"
        },
        {
          "character": "佘太君",
          "type": "二黄散板",
          "text": "听说宗保一声请，"
        },
        {
          "character": "柴氏",
          "type": "二黄散板",
          "text": "急忙上前看分明。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "我儿醒来！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "我方才朦胧将养静， 耳边厢又听得有人声。 睁开了昏花眼难以扎挣， 抬头只见儿的老娘亲。 生下孩儿人七个， 到如今白发人反送了黑发人，儿的娘！好不伤情。"
        },
        {
          "character": "杨宗保",
          "type": "夹白",
          "text": "爹爹啊！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "宗保儿必须要服人的教训，"
        },
        {
          "character": "柴氏",
          "type": "夹白",
          "text": "喂呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "实难舍柴夫人夫妇之情。 宗保儿、柴夫人，将我搀定， 一家人跪埃尘叩谢圣恩。 恕为臣不能够社稷重整， 恕为臣再不能扶保乾坤。 霎时间腹内痛心血上涌， 我、我面前站定了有许多的鬼魂。 焦克明气昂昂，他心怀不、不、不忿， 那孟、孟、孟伯苍他那里拱手相迎。 这一旁站的是猛将岳胜， 抬头只见老严亲。 哭一声老爹爹黄泉路等，"
        },
        {
          "character": "佘太君",
          "type": "夹白",
          "text": "保重了！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "无常到万事休去见先人。"
        },
        {
          "character": null,
          "type": "stage",
