          "character": "张别古",
          "type": "白",
          "text": "启禀太爷：我这盆儿，它又说话了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "它又说些什么？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "它说赵大夫妻将他剥得赤身露体，太爷日后因有八公之位。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "嘿，三公之位。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不错，是三公之位。恐有冲撞，望求太爷赏下青衣一件，遮盖身体，方可进入。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，赏他青衣一件，"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "嘿，这位太爷可真好说话，啊，有啦，我也来朦一下。 回禀老爷的话，乌盆又说话了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "又说什么？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "它说想跟太爷借五百两银子。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "嗯！不像话。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "本来不像话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古出衙门对乌盆叫。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "乌盆！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "跟我进来。 太爷，乌盆来了，你趁热叫罢。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "左右听了，乌盆！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "乌盆！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有哇！"
        },
        {
          "character": "包拯",
          "type": "三笑",
          "text": "哈哈，哈哈，哈哈哈！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "那不成，你冤枉我了，那可不成。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，错打五板，赏他五钱银子。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哈哈，这倒不错，错打五板，给五钱银子。 回禀老爷，干脆您再多打五板，咱们凑一两吧！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "轰了下去。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "这回不行了，回家养伤去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "那一乌盆，家住哪里？姓字名谁？有何冤枉？朝上诉来！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "太爷容禀！"
        },
        {
          "character": "刘世昌",
          "type": "西皮流水板",
          "text": "未曾开言泪汪汪， 尊声太爷听端详： 家住南阳太平庄， 姓刘名安字世昌。 奉母之命把京上， 贩卖那绸缎转还乡。 赵大夫妻图财主仆把身丧， 望求太爷做主张。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "何人的见证？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "判爷的见证。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，将盆入库。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，拿我火签，去到东大洼，将赵大夫妻抓来见我。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二差役同下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "退堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、包拯同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}