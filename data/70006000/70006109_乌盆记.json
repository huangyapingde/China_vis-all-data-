    },
    {
      "name": "刘升",
      "hangdang": "丑"
    },
    {
      "name": "赵妻",
      "hangdang": "旦"
    },
    {
      "name": "钟馗",
      "hangdang": "净"
    }
  ],
  "plot": "南阳缎商刘世昌结账回家，行至定远县遇雨，借宿窑户赵大家。赵大见财起意，将其用酒毒死，后将其尸烧\n制乌盆。鞋工张别古向赵大索欠，得盆。刘世昌鬼魂诉冤。张别古代鸣冤。包拯雪冤，杖毙赵大。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。因原稿只含主角唱念的场次，故第三至四场从略。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "刘世昌",
          "type": "内白",
          "text": "刘升！"
        },
        {
          "character": "刘升",
          "type": "内白",
          "text": "有。"
        },
        {
          "character": "刘世昌",
          "type": "内白",
          "text": "带路！"
        },
        {
          "character": "刘升",
          "type": "内白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌上。"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "一路美景观不尽， 人投旅店鸟宿林。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "卑人，刘世昌，南阳人氏，贩卖绸缎为生。只因离家数载，思念双亲，因此清 算账目，回家探望。 刘升！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘升上。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "前面什么所在？"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "定远县所管。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "看天色不好，速速趱行！"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "刘世昌",
          "type": "西皮快三眼",
          "text": "叹人生世间名利牵，"
        },
        {
          "character": "刘世昌",
          "type": "西皮原板",
          "text": "抛父母别妻子离故园。 道旁美景懒得看， 披星戴月奔家园。 霎时一阵把天变，"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "下大雨啦！"
        },
        {
          "character": "刘世昌",
          "type": "西皮散板",
          "text": "狂风大雨遮满天。 刘升带路往前趱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。刘世昌、刘升同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "数板",
          "text": "自幼，自幼生来命运单，又烧瓦来又烧砖，吃喝嫖赌又偷懒，只落得身穿破衣 衫、破衣衫。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我，赵大。不幸父母双亡，夫妻二人，在这定远县东大洼烧窑度日。前两天老 下雨，看今日天气晴和，不免将老婆子唤出，将这些盆儿罐儿的拿出去晒晒， 也好作买卖。 我说老婆子哪里？"
        },
        {
          "character": "赵妻",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻上。"
        },
        {
          "character": "赵妻",
          "type": "念",
          "text": "奴家生来命运苦，嫁了个丈夫是窑户。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "当家的，叫我干什么呐？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "看今日天气晴和，叫你出来，咱们把这些盆儿罐儿的晒一晒，也好去卖呀？"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "好，咱们来抬。 吆，下雨啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "好，搬回去。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "又晴天啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "再搬出去。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "吆，又下雨啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "得啦，别挨骂啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、赵妻同下。刘世昌、刘升同上。"
        },
        {
          "character": "刘世昌",
          "type": "西皮散板",
          "text": "行了一程又一程， 浑身上下水淋淋。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "刘升，看前面有户人家，上前借宿。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "转来，好话多讲。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "我知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘升叩门。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "我说有人吗？走出一个来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "外面大惊小怪的，是谁啊？"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你是干什么的啊？"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "我们要到你家，睡宿觉，你看怎么样？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "有这么说话的吗？你出来，家里人也放心。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "这么说，有什么不对，我偏要这么说。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你这么说，我就要揍你！"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "我还要揍你哪。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "不会讲话的奴才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌向赵大。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "啊，兄台请了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "好说好说，兄台请了。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "我主仆二人，行至中途，天降大雨，前不着村，后不着店。望求兄台行个方便， 借宿一宵，明日早行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大向刘升。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "人家这才算会说话的哪。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "有一个就对得起你。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我说客官，你要借宿一宵，倒是没什么，只是地方狭小，恐怕……"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "但求一席之地。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "照你这么一说，我倒……好好，请进来吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大搬行李。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "吆，挺沉的。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "都是银子么。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你瞧，你们衣服都淋湿啦，快脱下来，我给你们烤烤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大向刘升。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小子你呢？"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "我呀，就这一套，免了吧！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "家里的，把这件衣服拿去烤一烤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻上。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "你管他呐。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你不懂，烤干了放在咱们柜里。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "哦，我明白了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻下。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "请问客官尊姓大名？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "在下刘世昌。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "哪儿人氏？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "南阳人氏。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "好地方，做什么买卖？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "贩卖绸缎为生。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "啊呀，大买卖！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "小买卖。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "大买卖，"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "小本钱。"
        },
        {
          "character": "刘世昌、赵大",
          "type": "同笑",
          "text": "啊，哈哈哈哈！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "请问兄台贵姓？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "在下姓赵，单名一个大字。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "原来是赵大哥，失敬了。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "不敢，不敢。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "作何生意？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "烧盆儿窑为生。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "大买卖。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小买卖。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "大买卖，"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小本钱。"
        },
        {
          "character": "刘世昌、赵大",
          "type": "同笑",
          "text": "啊，哈哈哈哈！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我说客官，你们还没有吃饭吧？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "前途用过。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "哪儿吃过啦，我还饿着肚子哪。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "出门在外，甭客气，我们这儿也没什么好吃的，有的是绿豆稀饭杂和菜。你等 会儿，我再烫壶酒，赶赶寒气。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有劳赵大哥，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大下位至台前，背躬。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "哎呀慢着，我看这位客官的行李，倒是挺沉的，八成儿银子不少。我想我烧窑 一辈子，也发不了财，倒不如把他们两个害啦，岂不发财了吗？让我跟老婆子 商议商议。 老婆子快来！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "来了来了，什么事啊？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "老婆子，咱们发财啦！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "怎么发法呢？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "刚才有两个人，前来借宿，乃是一主一仆。主人是个做绸缎生意的大客商。我 看他们的行李挺沉的，定有不少的银子。我想把他们害了，银子都归了咱们， 岂不是发了财啦吗？"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "吆，害人我可不会。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "别嚷别嚷啊。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "你说怎么害呢？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "他们还没吃饭，咱们给他安排点酒饭，在酒里头下点耗子药，他们吃了岂不就 完了吗？"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "好，就这么办。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小心了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻下，上。赵妻将酒饭递与赵大，下。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "酒到、饭到，来来来，我给你们斟上一杯。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "打搅了！"
        },
        {
          "character": "刘世昌",
          "type": "西皮原板",
          "text": "好一位赵大哥人慷慨， 霎时间酒饭有安排。 行至在中途大雨盖， 萍水相逢礼不该。 到明天自当多谢拜， 昏昏沉沉倒在土台。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "客官再饮几杯罢。 得，我看他二人俱已醉倒，待我将门倒扣，咱们明儿见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大下。"
        },
        {
          "character": "刘世昌",
          "type": "西皮导板",
          "text": "霎时一阵肝肠断，"
        },
        {
          "character": "刘世昌",
          "type": "西皮散板",
          "text": "刀绞柔肠为哪般？ 回头便把刘升唤，"
        },
        {
          "character": "刘世昌",
          "type": "夹白",
          "text": "刘升、刘升！"
        },
        {
          "character": "刘世昌",
          "type": "西皮散板",
          "text": "想是奴才丧黄泉。 是是是来明白了， 中了赵大的巧机关。 远望着南阳高声喊，爹娘啊！ 阴曹地府走一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌死。"
        },
        {
          "character": "刘升",
          "type": "西皮导板",
          "text": "适才酒醉将合眼，"
        },
        {
          "character": "刘升",
          "type": "夹白",
          "text": "好厉害的绿豆水饭啊！"
        },
        {
          "character": "刘升",
          "type": "西皮散板",
          "text": "我心中好似刀来穿。 是是是来明白了， 中了赵大的巧机关。 眼望着南阳高声叫，"
        },
        {
          "character": "刘升",
          "type": "哭头",
          "text": "我的妈妈呀！"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "我死了吧我。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘升死。赵大、赵妻同上。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "天亮啦，咱们去看看，有没有动静。大概许是死啦，待我开开门。 有得，两个人死了一对。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "这可怎么办呢？抬出去埋了吧！"
        },
        {
          "character": "赵大",
          "type": "白",
