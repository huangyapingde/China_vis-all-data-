{
  "script_id": "70006111",
  "title": "二进宫",
  "alias": [],
  "source": "孟小冬剧本选",
  "characters": [
    {
      "name": "杨波",
      "hangdang": "老生"
    },
    {
      "name": "徐彦昭",
      "hangdang": "净"
    },
    {
      "name": "李艳妃",
      "hangdang": "正旦"
    },
    {
      "name": "徐小姐",
      "hangdang": "贴旦"
    },
    {
      "name": "杨公子",
      "hangdang": "小生"
    }
  ],
  "plot": "李良谋篡，封锁昭阳院，使内外隔绝，李艳妃始悟其奸，独居悔叹。徐彦昭、杨波二次进宫进谏，李艳妃感\n悟，遂以国事相托，后杨波领兵，诛斩李良。",
  "notes": "这个剧本是在钱培荣手抄余派戏词（不含配角唱念）的基础上，由李炳莘对照孟小冬说戏录音进行校核，并\n请范石人对配角的唱念进行修订，最终订稿。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "李艳妃",
          "type": "内白",
          "text": "先皇啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫娥抱太子、徐小姐引李艳妃同上。"
        },
        {
          "character": "李艳妃",
          "type": "二黄慢板",
          "text": "自那日与徐、杨决裂以后， 独坐在寒宫院闷悠悠。 先皇爷晏了驾太子年幼， 太师爷一心心想篡龙楼。 他那里父女情全然无有， 尽把我孤儿寡母当作了马牛。 徐小姐把守在宫门口， 看一看不觉到八月中秋。"
        },
        {
          "character": "杨波",
          "type": "内白",
          "text": "千岁请！"
        },
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "大人请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨公子、杨波、徐彦昭同上。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄散板",
          "text": "探罢皇陵到昭阳，"
        },
        {
          "character": "杨波",
          "type": "二黄散板",
          "text": "宫门上锁贼李良。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄散板",
          "text": "铜锤付与大人掌，"
        },
        {
          "character": "杨波",
          "type": "二黄散板",
          "text": "锤击宫门禀皇娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨公子接锤。"
        },
        {
          "character": "杨公子",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "杨公子",
          "type": "二黄散板",
          "text": "我父把令往下降， 哪怕铁壁与铜墙。 铜锤一举只环响，"
        },
        {
          "character": "徐小姐",
          "type": "二黄散板",
          "text": "你是何人击宫墙？"
        },
        {
          "character": "徐彦昭、杨波",
          "type": "同白",
          "text": "我儿休要动手，此乃（四公子）（徐小姐），上前见礼。"
        },
        {
          "character": "杨公子",
          "type": "白",
          "text": "这厢有礼！"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "还礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨公子下。"
        },
        {
          "character": "徐彦昭",
          "type": "白",
          "text": "我儿启奏国太，徐、杨二家宫门求见。"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "是。 启奏国太：徐、杨二家宫门求见。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "宣他们进宫。"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "领旨。 国太有旨：徐、杨二家进宫。"
        },
        {
          "character": "徐彦昭、杨波",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "徐彦昭",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁。"
        },
        {
          "character": "徐彦昭",
          "type": "白",
          "text": "此番进宫，将保国之事，细说一番，"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "全仗千岁。"
        },
        {
          "character": "徐彦昭",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁请！"
        },
        {
          "character": "杨波",
          "type": "二黄慢板",
          "text": "千岁爷进寒宫休要慌忙， 站宫门听学生细说比方： 昔日里楚汉两争强， 鸿门设宴要害汉王。 张子房背宝剑把韩信来访， 九里山前摆下战场。 逼得个楚项羽乌江命丧， 到后来封韩信三齐王。 他朝中有一个萧何丞相， 后宫院有一位吕后娘娘。 君臣们设下了天罗地网， 三宣韩信斩首未央。 九月十三寒霜降， 为国的忠良不能久长。 千岁爷进寒宫学生不往，"
        },
        {
          "character": "徐彦昭",
          "type": "夹白",
          "text": "却是为何？"
        },
        {
          "character": "杨波",
          "type": "二黄慢板",
          "text": "怕的是辜负了十载寒窗、九载遨游、八月里科场、七篇的文章，落得个兵部侍 郎，无有下场。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "说甚么学韩信命丧未央， 站宫门听老夫改换比方： 先皇爷怎比得汉高皇上， 龙国太怎比得吕后娘娘。 李良贼怎比得萧何丞相， 大人怎比得三齐王。 这寒宫怎比得鸿门宴上， 有老夫比樊哙、怀抱铜锤、保驾身旁、料也无妨。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "我好比鱼儿闯过了千层罗网， 受了惊恐着了些慌忙。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "只要你忠心把国掌， 老夫保你满门无伤。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "千岁爷保学生满门无伤， 拚着一死闯进昭阳。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "前面走的是开国将，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "后面跟的兵部侍郎。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "站立在宫门朝内望，"
        },
        {
          "character": "李艳妃",
          "type": "夹哭",
          "text": "喂呀！"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "又只见龙国太，怀抱太子两泪汪汪、口口声声哭的是先王。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "龙国太哭的是江山难掌，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "摆一摆手儿切莫要声张。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "进宫去休把那君臣礼上，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "学一个文站东，"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "武列西，"
        },
        {
          "character": "杨波、徐彦昭",
          "type": "同二黄原板",
          "text": "各自分班站立在两厢。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "先皇呀！"
        },
        {
          "character": "李艳妃",
          "type": "二黄慢板",
          "text": "李艳妃坐昭阳自思自想， 想起了先皇爷好不惨伤。 耳边厢又听得朝靴响亮， 想必是徐、杨二家进了昭阳。 有几句话儿不好言讲， 我只得怀抱太子、两泪汪汪、口口声声、哭的是先皇。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "怀抱着幼主爷江山执掌，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "为什么，恨天怨地、颊带愁肠、所为哪桩？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "并非是哀家颊带愁肠， 都只为我朝中不得安康。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "我朝中有甚么祸从天降？"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "你就该请太师父女商量。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "太师爷心肠如同王莽， 他要夺我皇儿锦绣家邦。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "太师爷娘娘的父，他本是皇亲国丈，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "未必他一旦无情起下了篡位心肠，太师爷是一个忠良。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "你道他无有篡位的心肠， 封锁昭阳为的是哪桩？"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "臣七月十三，三本奏上，国太偏偏要让，"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "你言道大明朝有事无事，不用徐、杨二奸党，赶出朝廊自立为王。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "先前的话儿休要讲， 不看哀家看先皇。 徐皇兄保太子登龙位上， 我封你一字并肩王。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "老臣我年迈难把国掌， 要保国还要那兵部侍郎。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "徐皇兄年纪迈难把国掌， 转面来叫一声兵部侍郎。 你保太子登龙位上， 你的名儿万古扬。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "吓得臣低头不敢望， 战战兢兢启奏皇娘。 臣昨晚修下了辞王本章， 今日里进宫来辞别皇娘。 臣要学姜子牙钓鱼台上， 臣要学钟子期砍樵山岗。 臣要学尉迟恭耕种田上， 臣要学吕蒙正苦读文章。 春来百花齐开放， 夏至荷花满池塘； 秋来菊花金钱样， 冬至腊梅带雪霜。 望国太开龙恩将臣放， 臣要落个无忧无虑、无是无非、做什么兵部侍郎、赦臣还乡。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "他二人把话一样讲， 倒叫哀家无有主张。 没奈何怀抱太子跪至在昭阳，"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "吓坏了定国王，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "兵部侍郎。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "自从盘古立帝邦，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "君跪臣来臣怎敢当？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "非是哀家来跪你， 为的是我皇儿锦绣家邦。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "锦家邦来锦家邦，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "臣有一本启奏皇娘。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "昔日里有一个李文、李广，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "换刀杀妻保朝堂。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "李文北门带箭伤，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "伴驾山前又收李纲。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "收了一将损伤一将，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "一将倒比一将强。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "到后来保太子登龙位上，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "反把亚父斩首在庆阳。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "这都是前朝的忠臣良将，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "哪一个忠良又有下场？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "有下场来无下场， 细听哀家说比方： 昔日里有一个子龙将， 长坂坡前救过小王。 到后来保幼主登龙位上， 他的名儿万古扬。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "困龙思想长江浪，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "虎落平阳想奔山岗。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "事到头来想一想，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "谁是忠良哪个是奸党？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "忠良本是徐、杨将， 奸党乃是我父李良。 二卿不把国来掌， 哀家跪死在昭阳。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "铜锤一举皇请上，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "老杨波搀扶起定国王。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄原板",
          "text": "回头来奏一道太平表章， 老杨波搬来了众家儿郎。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "好呀！"
        },
        {
          "character": "李艳妃",
          "type": "二黄摇板",
          "text": "听说是杨波搬兵到， 不由哀家喜眉梢。 太子付与小姐抱，"
        },
        {
          "character": "徐小姐",
          "type": "二黄摇板",
          "text": "双手奉与老年高。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄摇板",
          "text": "用手接过大明后，"
        },
        {
          "character": "徐彦昭",
          "type": "夹白",
          "text": "大人！"
        },
        {
          "character": "徐彦昭",
          "type": "二黄摇板",
          "text": "你保幼主坐龙楼。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "用手接过龙一条， 二目圆睁把臣瞧。 乘此机会生计巧， 浑身上下似水浇，难以保朝。"
        },
        {
          "character": "徐彦昭",
          "type": "二黄摇板",
          "text": "大人不必生计巧， 你的心事某猜着。 莫不是保幼主你嫌官小？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "徐彦昭",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "徐彦昭、杨波",
          "type": "同笑",
          "text": "哈哈哈哈哈！"
        },
        {
          "character": "徐彦昭",
          "type": "二黄摇板",
          "text": "快与杨波加封号。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "杨波听封！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "李艳妃",
          "type": "二黄摇板",
          "text": "我封你七岁孩童戴纱帽， 九岁女儿进皇朝。 加封太子和太保， 子子孙孙爵禄高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李艳妃、徐小姐、宫娥同下。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "叩罢头来谢龙恩！"
        },
        {
          "character": "徐彦昭",
          "type": "二黄摇板",
          "text": "徐延昭代驾且平身。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "一文，"
        },
        {
