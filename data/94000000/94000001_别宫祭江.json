{
  "script_id": "94000001",
  "title": "别宫祭江",
  "alias": [],
  "source": "院团改编本、演出本",
  "characters": [
    {
      "name": "孙尚香",
      "hangdang": "正旦"
    },
    {
      "name": "吴国太",
      "hangdang": "老旦"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    }
  ],
  "plot": "孙尚香自荆州回到东吴以后，听说刘备伐东吴失败，死于白帝城，痛不欲生。当即进宫辞别母后吴国太，到\n江边遥祭丈夫，祭后投江而死。",
  "notes": "《别皇宫》（一名《别宫》）和《祭江》（一名《祭长江》）是两个剧情相连而又可以单独演出的剧目。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "引子",
          "text": "恹恹守损，怎能消，终日愁闷。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "别君常挂念，难忘夫妻恩。虽无千丈线，万里系人心。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "奴家孙尚香。只因兄王孙权，与周郎定下美人之计，将刘皇叔诓下东吴，谁知 弄假成真，母后作主，将我许配皇叔为偶，一同回转荆州；未到三载，又差周 善将我诓回。思想起来，好不愁闷人也！"
        },
        {
          "character": "孙尚香",
          "type": "二黄慢板",
          "text": "坐吴宫每日里长吁短叹， 思想起已往事好不惨然！ 遭不幸父王爷命丧一旦， 我兄长继父业执掌江南。 与周郎定巧计把皇叔来骗， 又谁知弄假成真反配凤鸾。 回荆州未三载诓我回转， 阿斗儿在中途被子龙追还。 恨只恨我兄长把事办错， 拆散我好夫妻人各一天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启郡主：大事不好啦。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "刘皇叔晏驾白帝城。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "刘皇叔晏驾白帝城啦。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香昏去。"
        },
        {
          "character": "孙尚香",
          "type": "西皮导板",
          "text": "听皇叔白帝城龙驾已晏，"
        },
        {
          "character": "孙尚香",
          "type": "三叫头",
          "text": "皇叔，夫主，喂呀夫哇……"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "好一似万把刀刺在心间。 可叹你为江山经百战，"
        },
        {
          "character": "孙尚香",
          "type": "哭头",
          "text": "皇叔哇！ 梦不想一旦间命赴黄泉！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且住！皇叔晏驾，我不免换了孝服，进宫辞别母后，去到江边一祭。 宫娥们，伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香换孝服。"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "宫娥女忙引路把母后去见，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监暗下。"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "长寿宫见母后细说一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引孙尚香同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "吴国太",
          "type": "内西皮导板",
          "text": "一日清闲一日安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监引吴国太同上。"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "光阴一去不回还！ 我儿孙权身荣显， 承父兄基业镇江南。 可恨那曹丕把位篡， 图谋汉室锦江山。 我婿刘备重兴汉，"
        },
        {
          "character": "吴国太",
          "type": "西皮快板",
          "text": "称孤道寡坐西川。 将身且坐皇宫院，"
        },
        {
          "character": "吴国太",
          "type": "摇板",
          "text": "等候尚香来问安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "叹夫君白帝城把驾晏， 去愁容忍悲泪问娘金安。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "尚香见驾，母后千岁。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "皇儿平身。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "谢母后。"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "啊？我儿今日进宫身穿素服，面带泪痕是何缘故？"
        },
        {
          "character": "孙尚香",
          "type": "叫头",
          "text": "母后哇！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "时才宫人报道，刘皇叔晏驾白帝城了……"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "哇！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哦！刘皇叔晏驾白帝城了？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "咳！可伤啊可伤呀！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "为此，女儿身穿孝服，要到江边一祭；特来辞别母后。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "去往江边祭奠，多有不便；不如就在宫中备下祭礼，祭奠一番也就是了。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "咳，母后哇！"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "母后说话理太偏， 细听女儿说根源： 回荆州未及三年满， 又差周善诓儿还。 到如今不容儿江边祭奠， 怎不叫儿珠泪涟！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "我的儿不必泪满面， 细听为娘把话言： 儿嫁那刘备娘心愿， 送儿到荆州有三年； 接儿回转差周善， 母女们分别才得团圆。 江边祭奠空祭奠， 一滴何曾到九泉？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后啊！"
        },
        {
          "character": "孙尚香",
          "type": "西皮快板",
          "text": "儿在东吴心在汉， 夫妻永别不团圆。 当年为讨荆州郡， 把儿定计就理不端。 说什么祭奠空祭奠， 一滴怎不能够到九泉！"
        },
        {
          "character": "吴国太",
          "type": "西皮快板",
          "text": "我的儿不必来埋怨， 提起往事也枉然。 夫妻好比同林鸟， 大限来时各一天。"
        },
        {
          "character": "孙尚香",
          "type": "西皮快板",
          "text": "昔日里有个孟姜女， 千里寻夫到城边。 哭倒了长城人称赞， 留得美名万古传。 夫死不容儿祭奠， 就不该当初配夫男！ 母后空把弥陀念， 往日贤来，如今反不贤。"
        },
        {
          "character": "吴国太",
          "type": "西皮快板",
          "text": "我儿说话失检点， 讲什么古来论的什么贤！ 为娘我坐在皇宫院， 看哪个大胆到江边！"
        },
        {
          "character": "孙尚香",
          "type": "西皮快板",
          "text": "儿今一心要祭奠！"
        },
        {
          "character": "吴国太",
          "type": "西皮快板",
          "text": "为娘我一定要阻拦！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "母后不容儿祭奠，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "不如碰死在娘前！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "我儿不必寻短见， 为娘同儿到江边。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "我儿定要江边祭奠，也不阻拦于你；待为娘同儿前去就是。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "这个……女儿怎敢劳动母后。有宫娥陪伴就是了……"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "哇！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "有宫娥陪伴，我放心不下。也罢，为娘赐你半副銮驾护送前往，儿要早去早回。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "如此，母后请上，女儿我拜别。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "啊？江边祭奠，去去就回，何言“拜别”二字？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后哇！"
        },
        {
          "character": "孙尚香",
          "type": "西皮二六板",
          "text": "虽然暂别皇宫院， 为人须要礼当先； 儿愿母后多健康， 儿原母后福寿全。 辞别母后出宫院，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女同下。"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "我母后不解巧机关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。"
        },
        {
          "character": "吴国太",
          "type": "西皮散板",
          "text": "我儿定要去祭奠， 满怀心事话难言。 尚香儿若有长和短，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监同下。"
        },
        {
          "character": "吴国太",
          "type": "西皮散板",
          "text": "暮景残年谁问安！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴国太下。"
        },
        {
          "character": "吴国太",
          "type": "stage",
          "text": "《祭江》"
        },
        {
          "character": "孙尚香",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四小太监、四宫女、二大太监、孙尚香、车夫同上。"
        },
        {
          "character": "孙尚香",
          "type": "二黄慢板",
          "text": "想当年截江事无限悔恨， 背夫主撇娇儿两地离分； 闻皇叔白帝城丧了性命， 到江边去祭奠好不伤情。⑴"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启禀郡主：来到江边。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "祭礼摆下！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "祭礼摆下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖哭皇天〗。二大太监同设香案，孙尚香焚香祭奠。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "两厢退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四小太监、四宫女、二大太监、车夫自两边分下。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "设祭长江岸，举目望西山。梦魂何日见，空教泪不干！"
        },
        {
          "character": "孙尚香",
          "type": "二黄导板",
          "text": "在江边摆祭礼悲声告禀，"
        },
        {
          "character": "孙尚香",
          "type": "叫头",
          "text": "皇叔，夫主，喂呀……"
        },
        {
          "character": "孙尚香",
          "type": "反回龙",
          "text": "尊一声汉皇叔在天之灵。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "好夫妻恶因缘衷情难尽， 半空中当鉴我一点诚心。 可叹你大英雄出世受困， 可叹你结桃园义功死生； 可叹你下南阳把诸葛搬请， 可叹你烧赤壁同破曹兵。⑵ 好容易得西川身立未稳， 偏遇到讨荆州二弟丧生； 未报仇战虢亭遇着陆逊， 失机谋被他人火烧连营。⑶ 辜负了兴汉室基业初定， 辜负了平生志万里鹏程。 看将来叹人生总是梦境， 倒不如殉一死以报亡魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖反哭皇天〗。孙尚香祭。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且住！想皇叔一死，我有何面目回转西川；留在东吴，兄长又岂能容我。也罢！ 不免拜别母后养育之恩，寻个自尽了吧……"
        },
        {
          "character": "孙尚香",
          "type": "反二黄散板",
          "text": "江水滔滔波浪滚， 尚香拜别养育恩。"
        },
        {
          "character": "孙尚香",
          "type": "哭头",
          "text": "叫声皇叔你且等……"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香投江，下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "孙尚香",
          "type": "stage",
          "text": "—————————— ⑴此段另有四句唱词可供参考："
        },
        {
          "character": "孙尚香",
          "type": "二黄慢板",
          "text": "曾记得当年来此郡， 浪打鸳鸯两离分； 从今不照菱花镜， 清风一去未亡人。 ⑵此段有的增唱两句："
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "可叹你占荆州周郎不急，周郎不忿，皇叔哇！ 可叹你入虎穴东吴招亲。 ⑶此段有的增唱两句："
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "辜负了五虎将九泉遗恨， 辜负了诸葛亮赤胆忠心。"
        }
      ]
    }
  ]
}