{
  "script_id": "70001205",
  "title": "义责王魁",
  "alias": [],
  "source": "周信芳剧本选",
  "characters": [
    {
      "name": "王中",
      "hangdang": "老生"
    },
    {
      "name": "王魁",
      "hangdang": "小生"
    },
    {
      "name": "张千",
      "hangdang": "丑"
    }
  ],
  "plot": "王魁与妓女敫桂英情笃义深，互盟誓愿。王魁入京高榜得中，入赘宰相之家，回书休弃敫桂英。老仆王中，\n见他忘恩负义，痛加斥责，脱下丝带，愤愤而去。",
  "notes": "本剧故事愿于《焚香记》，系根据上海市人民评弹团的演出本编写，初由吕仲执笔，在排练和演出中，周信\n芳同志对剧本做了较大的修改，对老仆王中的形象有所丰富。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王中喜形于色上。"
        },
        {
          "character": "王中",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "王中",
          "type": "二黄摇板",
          "text": "少主人登金榜高魁得中， 喜得我年迈人兴致冲冲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中仰对天空。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "老太爷！太夫人！今日我家公子金殿传胪，状元及第，老太爷，太夫人虽不及 亲眼得见，如今在九泉之下，也当含笑的了哇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中过分激动，喜极拭泪。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "嗳！我今天怎么快活得落下泪来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中拭泪。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "敫桂英，少夫人！我佩服你的眼力不差呀！"
        },
        {
          "character": "王中",
          "type": "二黄摇板",
          "text": "那敫桂英可算得眼力出众， 尘土内拾明珠选得乘龙。 此一番传捷报莱阳去送， 开笑颜喜心头快乐无穷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "锣声。"
        },
        {
          "character": "四青袍",
          "type": "内同白",
          "text": "状元公回府！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "人声喧哗，想是我家状元公回家了！ （〖吹打〗。王魁戴纱帽、插宫花、着红宫衣、骑马随四青袍同上。王魁下马入内，四青袍同下，小院子接 马下，王魁坐。）"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公，赴过琼林宴了？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "是啊，赴过琼林宴了。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "想这琼林宴上，三百多位新进土，哪一个比得上我家状元公的人品出众，文采 风流。真是状元公春风得意之时也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁骄傲地。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "唔！那是自然。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "状元公今日拜过宗师老大人了。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "拜过了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁高兴地。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "王中，你道宗师是谁？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "是哪一位？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "就是当朝首相韩均韩老大人"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公满腹经纶，又得师相提携，从此青云直上，指日可待。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁更加得意忘形。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "这还不算呐，还有一件天大的喜事落在我王魁的头上。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "什么天大的喜事呀？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁猛然惊觉地止住不说。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "哦！这这这，噢！少时对你言讲，我如今要写一封紧要的书信。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "是，待我浓墨。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "不用，我自己浓墨，你与我封三百两纹银来。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中背供。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "状元公一定是与少夫人写信报喜了。哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中下。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "哎呀！险些将相府许亲之事脱口而出，王中性情甚是固执，相府招亲之事还要 暂时隐瞒与他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中捧银上。"
        },
        {
          "character": "王中",
          "type": "二黄摇板",
          "text": "定是莱阳传书简， 不由王中暗喜欢。 三百两纹银将行装置办， 迎接那敫桂英夫妻团圆。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公，三百两纹银取来了。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "放在书案之上。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公，我知道相公你与哪个写信。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "你知道我与哪个写信哪？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "自然是与那莱阳城中贤德的敫氏夫人写信。她是早也盼，晚也盼，朝卜金钱， 夜卜灯花，朝朝暮暮，暮暮朝朝，只盼相公金榜题名，高科得中，今日这一纸 捷报到她手中，我那敫氏夫人呵！"
        },
        {
          "character": "王中",
          "type": "四平调",
          "text": "这一纸捷报送到手， 喜上眉梢乐在心头； 自念平生志气有， 不甘久困在青楼； 穷途偶将公子救， 慧眼识人咏好逑！ 可恨那鸨母龟儿齐诅咒， 姐妹们笑她错配鸾俦； 幸喜得王郎得中琼林宴上饮御酒， 敫桂英才得夙愿酬。 此一番扬眉吐气京城走， 但愿你夫妻双双白头到老永谐千秋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁对这些话不感兴趣。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "你说得太高兴了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁起立，王中将椅搬到桌旁。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "哦呵！是呵，老奴这样高兴的说了多时，把相公的正事都耽误了。相公快快写 信，待老奴去准备准备，正是："
        },
        {
          "character": "王中",
          "type": "念",
          "text": "一封喜信送裙钗，桂英夫人笑颜开。"
        },
        {
          "character": "王中",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中下。王魁离坐，两望门，掩门，重就坐。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "待我修书。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁提笔沉思。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "好难落笔也！"
        },
        {
          "character": "王魁",
          "type": "四平调",
          "text": "往日胸中海样宽， 走笔似飞千万言。 这一纸休书心意乱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "王魁",
          "type": "四平调",
          "text": "倒叫王魁难上难。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "想我与敫桂英，三载夫妻，恩情不薄，今日这一纸休书却不知从哪里写起！不 写也罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁搁笔。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "哎呀且住。方才我在相府允婚之时，并未提起已有妻室，日后若被韩相知晓， 我这功名富贵岂不要化为灰烟！为了自己前程，这封休书是非写不可。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁提笔。"
        },
        {
          "character": "王魁",
          "type": "念",
          "text": "当机不能立刻断，怎理民事作高官！"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "哎呀！写不得呀，写不得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁搁笔。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "我与桂英南浦分别，难舍难分，曾在海神面前双双盟誓，言道：“夫不另娶， 女不别嫁，若背此盟，必遭天谴。”想起日后遭报之惨，这封休书还是写不得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁略思片刻。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "哎！海神管波涛，哪管男女婚嫁之事。何况我王魁如今状元及第，天于门生， 自有百灵呵护，怕什么小小海神。真是多虑呀多虑。写！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁提笔。"
        },
        {
          "character": "王魁",
          "type": "四平调",
          "text": "状元头上三把火， 海神怎能奈我何！ 不愁应誓遭恶果， 只怕宦海起风波。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "哎，还是写不得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁掷笔。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "这一封休书接到敫桂英手中，她是一个烈性女子，岂不要自寻短见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁转念。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "王魁你好痴也，敫桂英也曾对我言讲：当年她父病死客中，她不学曹娥身背父 尸投江而亡，反而卖身葬父，堕落烟花，寄身青楼，苟安偷生，如今怎能为了 这些须小事，自寻短见！不会的呀，不会的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁最后决定主意。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "还是写！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁提笔写休书。"
        },
        {
          "character": "王魁",
          "type": "四平调",
          "text": "上写王魁多拜上， 拜上莱阳敫姑娘： 自悔缠绵花柳巷， 欢场失足少主张。 今日高中登金榜， 另娶淑女理应当。 奉上纹银三百两， 聊报一片好心肠。 流水年华莫虚晃， 盼卿早选好夫郎。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "王中哪里？走来。"
        },
        {
          "character": "王中",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中身背包裹兴冲冲上。"
        },
        {
          "character": "王中",
          "type": "二黄摇板",
          "text": "相公鱼书端正好， 去到莱阳走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中入内。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公，书信想必写完了？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "写完了。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "如此，请将书信、银两支付老奴，待老奴即刻起程，去住莱阳迎接夫人前来， 与状元公团聚。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中欲上前取书信。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "一件小事，何必你老人家亲自前往。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "啊，相公，迎接夫人，怎说小事。依老奴看来，此事非我去不可。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "此去莱阳数千余里，老人家年迈，只恐难受风霜之苦；况且这新状元府中，实 是少你不得。依我看来，还是另差别人为是。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "老奴为的是状元府中都是新人；此去莱阳人地生疏，再说夫人一路而来，有老 奴从旁照看，却要方便得多。还是让老奴前去。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "我另有打算，不必多言。快唤张千前来。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公，还是我去的好。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "不必多言，唤张千前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中知道难再求，出门。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "啊！我家相公往日言语柔和，今日为何这等模样？唔！中了状元了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中放包袱。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "好，张千走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千上。"
        },
        {
          "character": "张千",
          "type": "念",
          "text": "新到状元府，人生路不熟。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "老人家唤我何事？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "状元公唤你，小心去见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中引张千入内。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "张千叩见状元公。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "罢了。这有书信一封，纹银三百两，送往莱阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁看王中。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "要速去速回，不准片刻停留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千接银、信。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "小人遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁下。张千、王中同走出，二道幕闭。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "请问老人家，这封信上写敫桂英，好象早女人的名字，她倒底是哪一位呀？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "嘘！轻声些。她就是我家状元夫人。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "该死，该死！我可不知道她就是我家状元夫人。请您老人家恕罪。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "有道是：“不知者，不怪罪。”"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "是是是，下次小心。我说老人家，您可认识咱们状元夫人吗？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相处三载，怎么不认识呀！"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "噢！咱们状元老爷成亲有三年啦！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "提起这位状元夫人，她真贤德的很哪。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "噢！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "不但但容貌端庄，美若天仙，而且性情温和，举止安详，对待家人侍女从无疾 言厉色。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "生来就是一位状元夫人嘛。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "她与我家状元公乃是—对患难夫妻，山盟海誓，相亲相爱，此番迎接进京，真 是扬眉吐气；有了出头之日了哇！哈哈哈哈！"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "啊！老人家，怎么状元爷口中不曾对我提起迎接两字啊？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "嗳！他那书信里面有哇。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "噢！书信里面有。好，告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千转身欲走。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "小哥回来。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "什么事呀？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "小哥，你去过莱阳城无有？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千摇头。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千看信封。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "真个的，莱阳县里的鸣坷巷在哪儿呀？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "小哥，这一下你问着了。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "我知道您是个老在行嘛！在哪儿呐？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "进了莱阳东大关。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "噢，进了莱阳东大关。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "不到一里之遥，见—座高大牌坊。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "不到一里之遥，见一座高大牌坊。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "上写四个金宇。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "哪四个金字？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "写着：“威灵显赫”。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "“威灵显赫”——这不是一座城隍庙吗？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "本来就是城隍庙嘛！"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "咱们状元夫人就住在城隍庙里呀？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "哎！不是的有唷。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "不是呀！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "还末曾到呢。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "原来还没有到呐！那么再往前走。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "张千哥，再往前，就走错了。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "要往哪儿走？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "这要向左面拐。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "噢！要向左面拐。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "走进一条狭小的巷儿。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "走进一条狭小的巷儿。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "这才是鸣珂巷。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "这就到了鸣珂巷啦？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "正是。巷子里面第三家，是—座小小的门墙。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "—座小小的门墙。咱们状元夫人就住在这儿呀？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "对了。这门墙之上，挂着……挂着……挂着…… 哎呀且住！想我家叫敫氏夫人，如今还住在勾栏院中，说将出来，岂不使我家 状元老爷丢丑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中沉思有顷。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "哎！就是不说，他到了鸣珂巷也会知道。 小哥！事到如今，也就不得不对你实说了。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "没有外人，实说的好。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "但是必须依我一件。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "你要守口如瓶，才能直言相告。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "您放心，我对天盟誓！老人家你听着。 皇天在上，我张千在下，我若走漏了消息半点，叫我天雷轰顶；死无葬身之地。 老人家，你该放心了吧？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "哈哈！你还会盟誓呀！"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "我常常盟誓。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "张千哥，我对你讲，你道这小小门墙，却是什么所在？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "嗨！您不说，我怎么会知道呢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中两望。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "乃是一座勾栏曲院。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "啊！是妓院呀！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "嘘！轻声些。我家状元夫人原是名门之女，只因老父客中亡故，这才卖身葬父， 身入青楼，虽是飞絮沾泥，她却不接走马王孙。那日……那日……"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "那日怎样？嗨！您不放心，我再对天盟誓！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "不用不用！不妨长话短叙。那日遇见了我家相公，他二人心心相印。这才成为 夫妇。这时我家相公身染重病，好一位贤德的夫人，她是衣不解带，亲奉汤药， 后来，质钗环，典衣衫，打发相公上京赴试，且喜一举成名，金榜得中。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "如此说来还是夫人挣得来的。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "张千哥，此话怎讲？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "老人家；您想呀！没有夫人，状元老爷性命都不保，还会中状元吗？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "呵呵！小哥倒也说得是呀。这书信你要好好带着。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "这封万金家书，我得小心点带着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千将书信藏在怀内。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "张千哥，你进得门去；见了状元夫人，呈上捷报银两之后，你要对她拜上几拜。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "这样的好夫人，我要多拜她几拜。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "是呀，要多拜她几拜。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "拜罢之后？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "这时夫人看罢书信，必然欢天喜地随你即刻登程。你一路之上要好好的照应。 小哥，"
        },
        {
          "character": "王中",
          "type": "四平调",
          "text": "拜托你一路之上多谨慎， 早晚照顾要殷勤； 早些住店晚些登程， 行船过渡莫争行； 饥餐渴饮要洁净， 晓行露宿都要留心； 倘若是夫人将我问， 你就说王中身体健康好精神； 你就说状元起居要我照应， 不能够亲身来把夫人迎； 你就说我家相公日夜盼望将她等， 盼她早早到京城。"
        },
        {
          "character": "张千",
          "type": "二黄摇板",
          "text": "多谢院公来指引， 莱阳城内接夫人。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "老人家请放心吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千下。"
        },
        {
          "character": "王中",
          "type": "二黄摇板",
          "text": "好一个贤德敫桂英， 果然慧眼能识人。 张千此去报喜信，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内人声。吹节节高牌。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "王中",
          "type": "二黄摇板",
          "text": "不知何人到来临？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小院子引门官持全帖同上。"
        },
        {
          "character": "小院子",
          "type": "白",
          "text": "老人家！这是相府差来的门官，前来迎接新贵人。 这是我家管家王中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小院子下。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "奉了相爷之命，来此迎接新姑老爷。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "如今堂上无客，你家新姑老爷不住此处。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "老人家，你还不知道呀？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "不晓得。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你家状元公就是我家新姑老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中不信真有此事。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "你说什么？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你家状元公，就是我家新姑老爷。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "啊！你弄错了吧！"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "什么弄错。这里是不是王魁王状元府上？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中点头。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "这就不错了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中惊，强忍怒气。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "这、这、这，何人为媒？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "白行简白大人为媒。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "何日完婚？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "明天乃是黄道吉日，就在相府招赘。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "我家状元公，有了夫人了。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "对啊！状元公与相府小姐配成夫妇，自然是有了夫人了。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "我且问你，莫非相府千金甘居妾位？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "什么七位八位，我不懂你的话。如今相爷恐状元恐在此不便，特地命我前来， 迎接状元公进相府居住，吉日完婚，轿马都在门前等候。这有全帖—张，烦你 快去通报，我等就在外面伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官下。王中感到事出意外，十分激怒。"
        },
        {
          "character": "王中",
          "type": "西皮小导板",
          "text": "晴天霹雳一声震，"
        },
        {
          "character": "王中",
          "type": "西皮快板",
          "text": "浑身战抖两眼昏。 相公作事心太狠， 他做了忘恩负义的人！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "哎呀且住，我家相公才做了两天状元，他竟贪图眼前富贵，就立刻忘却莱阳患 难相救的敫挂英！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中忽有所悟。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "哎呀且住！方才张千去往莱阳下书，这封书信，既是迎接敫氏夫人前来，就不 该另娶相府千金，既是另娶相府千金，为何又迎接敫氏夫人？噢呵是了！怪不 得方才在书房之中，见他言语支吾，神色不正，我自愿去至莱阳一迎接，他又 偏偏要差张千前往。我想这封书信之中，必有变端。可怜我那敫氏夫人见了这 封书信，必然心如刀绞，肝肠寸断。待我去问他。"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "难道他真将良心变！ 一旦富贵忘饥寒。 到书房问一个水落石出现，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中走圆场。二道幕启。王魁上。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "老人家，为何这样慌张？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "笑话得很！方才相府差人前来，言道迎接他家新姑老爷，全帖—张，相公请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中呈帖上。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "来人还说些什么？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "来人言道：迎接新姑者爷到相府居住；黄道吉日在相府招赘。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "噢，原来如此！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁沉思。王中察看王魁神色。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公，新姑老爷是哪个？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "老人家，你可知道新姑老爷是哪个呀？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "是啊，老奴正请问状元公，这新姑老爷他是哪一个啊？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "方才在回府之时，也曾对你言道，有一件天大的喜事嘛！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "如此说来，这新姑老爷……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁赧然强笑。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "嘻嘻嘻嘻！这新姑老爷，就是我呀！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "噢！原来就是你！"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "你忘了敫桂英……雪地相救、亲奉汤药、钗环典尽，深夜伴读的……恩情三年。"
        },
        {
          "character": "王中",
          "type": "叫头",
          "text": "相公，你就大大的失了主意了。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "你家相公少年得志，金殿占魁，当朝首相极意垂青，才与我结为秦晋之好，从 此青云得路，提拔有人，真是享不尽的荣华，受不尽的富贵，怎说是失了主意 呢？，"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "你可记得，莱阳还有敫氏夫人，看你用何言答对，这相府千金，看你怎样安排！"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "我不是已经安排好了吗？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "难道说相府千金她甘居妾位不成！"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "堂堂相府千金，岂能甘居妾位！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "是啊！张千已去莱阳，迎接夫人到此，看你怎样发落？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "你说的是那敫桂英吗？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "是呀！"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "她是不会来的了。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "家书一封，纹银三百两，怎说不会来？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "哪里是家书，乃是一纸休书。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "一纸休书。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "相公，这一纸休书，白银三百两，送到莱阳，那敫氏夫人看了，只恐要逼出事 来啊！"
        },
        {
          "character": "王中",
          "type": "西皮流水板",
          "text": "一纸休书莱阳传， 铁石的人儿也心酸； 柔肠百折寸寸断， 这晴天霹雳要起祸端！ 速将张千唤回转， 收起覆水好团圆。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "待我将张千唤回，"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "慢来。张千去远，追赶不上了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中变色。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "如此，待老奴去见白大人。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "你去见白大人何事？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "来人言道；媒人乃是白行简。我去见了白大人，就说我家状元公是有了夫人的， 求他转告韩相，回绝这门亲事。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "白大人奉命与我作伐，乃是一片好意；我既允婚于前，岂能能失信于后！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "失信，失信！你既然不肯失信于韩相，又为什么偏偏要失信于恩高义厚、患难 相共的敫桂英？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一锣。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "你怎知道我的为难之处阿！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "唉！相公呀！"
        },
        {
          "character": "王中",
          "type": "反西皮二六板",
          "text": "贤主母她待你恩重如山， 性温柔人端庄说之不完； 曾记得风雪中垂危救挽， 莱阳城鸣珂巷留养三年。 你也曾得重病卧床辗转， 典衣衫质钗环汤药亲煎； 衣不宽带不解朝夕相伴，"
        },
        {
          "character": "王中",
          "type": "西皮流水板",
          "text": "朝求神晚焚香哀告苍天。 盼相公奋壮志磨穿铁砚， 常伴你苦攻书彻夜不眠。 似这等贤德女世上少见， 你何忍下绝情割断琴弦。 望相公三思想心回意转， 思前情想后果再谐凤鸾。"
        },
        {
          "character": "王魁",
          "type": "西皮散板",
          "text": "你不必絮叨叨言憨语谩， 此一时彼一时事过境迁，"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "过去之事，你还提它则甚！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "嗨嗨！过去之事，想想是有好处的。你不但失信于敫氏夫人！你可记得，在南 浦分别时节，在海神庙中的山盟海誓？你还失信于鬼神哪！"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "啊！海神庙里的话，你都听见了吗？"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "呵呵！庙外虽然海涛汹涌，庙内却是鸦雀无声，我在庙外收拾行囊，你们的话， 我句句听得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中提起海神庙，王魁不免内疚。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "王中！不要讲下去了。"
        },
        {
          "character": "王背",
          "type": "白",
          "text": "背信弃义，我怎能不讲？"
        },
        {
          "character": "王背",
          "type": "西皮散板",
          "text": "曾记得你在海神面前把誓盟， 你说道生生世世不离分。 她说……"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "她说什么？"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "她说青楼难久因， 鹏程得路莫负心。 你说……"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "我说什么？"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "你说为人岂能忘根本， 刻骨铭心感桂英； 王魁日后若失信， 剥却人皮入鬼门。 过往的神灵可作证， 我王中句句听得真。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "只恐这状元夫人，不是青楼妓女消受得起，依我看来，非是王魁负义，实乃桂 英命薄。"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "既是青楼薄命女， 不该当初配婚姻，"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "偶然逢场作戏。又非明媒正娶。况且相府婚事已成定局，此事有关我的前程， 你就不必再讲了。"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "千言万语劝不醒， 高官厚禄失掉了魂。 你一旦富贵把良心昧， 千秋万世留骂名。"
        },
        {
          "character": "王魁",
          "type": "西皮散板",
          "text": "不念你孤苦又伶仃， 将你赶逐出府门。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "老奴才，我要不是念你这样孤苦伶仃定然将你赶出门去。"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "王魁呀！王魁！只因当初太老爷待我不薄，才怜你父母双亡，穷途潦倒，无人 照看，这才患难相从直到如今。我随你也不知受了各少苦处，苦来苦去，苦到 今日才苦出你这一个状元。你可记得，三年前，落地出京的时节，你在中途路 上，身染重病，那时天降大雪，倒卧路旁，看看就要穷困而死。哪知道绝处逢 生，来了一位就是你讲的那个青楼妓女，好一个仁慈的敫桂英，将你救到院中， 亲奉汤药，延医疗治，百般卫护，你病体痊愈，起死回生，她见你品貌清秀， 文质彬彬彬彬，不顾鸨儿责骂，姐妹讪笑，与你结为夫妇，深闺伴读，彻夜 不眠，指望你出人头地，她也可扬眉吐气，谁知你，一旦得志，忘恩负义，你 还要口口声声妓女，奴才！你要想一想，你在雪地之中，要没有那个妓女，我 这个奴才，你早巳身葬沟渠，死于非命。你还能中状元吗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁欲言又无法回答，低声地。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "老奴才！"
        },
        {
          "character": "王中",
          "type": "白",
          "text": "你还骂我奴才！患难相从，扶你成人，要没有我这个奴才，早把你把你饿死了。 你虽然戴乌纱。插宫花，身穿锦袍，衣冠楚楚，一见高官，忘却根本。哪个 要你怜悯，我把你这名教败类，衣冠禽兽啊！"
        },
        {
          "character": "王中",
          "type": "西皮散扳",
          "text": "苍松翠柏不畏冷， 傲骨峻嶒比你强十分。 急忙解下丝鸾带，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中解带。"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "这奴才的衣服脱下身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中脱去衣帽。"
        },
        {
          "character": "王中",
          "type": "西皮散板",
          "text": "我虽然年迈有血性， 不似你卑鄙无耻下贱的心。 哪一个要你来怜悯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王周转圆场。王魁至下场门，连气带恐惧。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "大胆！放肆！赶了出去，赶了出去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王魁急下。王中气极狂笑。"
        },
        {
          "character": "王魁",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "王魁",
          "type": "西皮散板",
          "text": "沿门托钵我也要度几春。"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "王魁",
          "type": "念",
          "text": "可恨王魁不知羞，忘恩负义把富贵求；卑鄙无耻难挽救，"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "王魁，小奴才！"
        },
        {
          "character": "王魁",
          "type": "念",
          "text": "我且看你的下场头！"
        },
        {
          "character": "王魁",
          "type": "白",
          "text": "走了，走了，走了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王中下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}