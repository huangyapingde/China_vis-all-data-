        {
          "character": "关羽",
          "type": "白",
          "text": "响过三次。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第一次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "温酒斩华雄。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第二次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斩颜良，诛文丑。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这第三次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这三——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽笑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊啊啊！莫非要应在大夫身上了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃惊惧。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯，你言重了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "言重了，哈哈哈……"
        },
        {
          "character": "鲁肃",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、鲁肃同归座。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问君侯，这件事叫做什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "叫做：以德报德，以直报怨。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "好一个以德报德，以直报怨。我想君侯借物不还，谓之怨也。想君侯熟读春秋， 通晓兵书，匡扶社稷，济困扶危，谓之仁也。待玄德公如骨肉，视曹操如寇 仇，谓之义也。辞曹归汉，封金挂印，五关斩将，千里独行，谓之礼也。斩颜 良、诛文丑，谓之智也。想君侯仁、义、礼、智俱全。咳，嘿嘿，惜乎吓，惜 乎，却缺少一个信字。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯是不会失信于人的。但是令兄玄德公曾失信于鲁肃。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某大哥，乃仁德之君，岂能失信于你？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "昔日贤昆仲，兵败当阳，身无所归，那时孔明见与肃求见吾主，即日兴师，破 曹操于赤壁之间。东吴费有巨万之资，又折了大将黄盖。只因贤昆仲无尺寸之 地，故而暂借荆州，以为养军之地。那时玄德公言道，得了西川，交还荆州， 如今东西两川已得，玄德公愿将长沙、零陵、桂阳三郡交还东吴，惟君侯不允， 这信字安在？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊！今日请某饮宴，就是为了索取荆州么？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这酒是要饮，荆州也要还。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！大夫！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "我把你真心儿待， 恁将那筵席来设， 攀今弔古，分什么枝叶？ 俺跟前使不得之乎者也，诗云子曰。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "荆州原是吴地。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "但开言，只叫恁剜口绝舌！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孙刘结亲，原为两邦和好。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "恰又来！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "有意孙刘，目下反成吴越。"
        },
        {
          "character": "周仓",
          "type": "叫头",
          "text": "呔！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "荆州乃是汉家基业，岂能与你！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！我与大夫谈论国家大事，何用你来多口！站下。"
        },
        {
          "character": "鲁肃",
          "type": "叫头",
          "text": "君侯！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "我劝你写下退还文约，如若不然，我……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽出位，鲁肃出位。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你便怎么样？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "我，我，我……哎呀，我鲁肃为难呐！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鲁大夫！"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "青龙偃月不可挡，万马军中非寻常。筵前再提荆州事，子敬难免刀下亡。"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "凭着恁三寸不烂舌， 休恼俺三尺无情铁。 这刀饥餐了上将头， 渴饮了仇人血。 这的是龙在鞘中蛰， 虎向座间歇。 今日个故友重相见， 休教俺弟兄们相间别。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鲁子敬听者！"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "心下休惊怯，好日已西斜。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "吾当醉也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯！你不还荆州，你来看……这沿江一带，俱是我东吴人马，慢说你是一人， 就是一只猛虎，也难闯过江去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃抓杯，欲击杯为号。关羽抓鲁肃袍带。内喊声。吕蒙、四吴将同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你可有埋伏？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "无有埋伏？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你可有诈？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "无有诈。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鲁大夫！"
        },
        {
          "character": "关羽",
          "type": "揽筝琶",
          "text": "恰怎生闹吵吵三军列？ 有谁人把谁挡拦者？ 挡着俺啊，只教你剑下身亡，目前见血。 恁便有张仪口，蒯通舌，哪里去闪遮。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "无有诈。"
        },
        {
          "character": "关羽",
          "type": "揽筝琶",
          "text": "你且来来来， 好生送某到船上。和你慢慢地分别。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽抓鲁肃同下，众人同下。关羽抓鲁肃同上，众人同上。四蜀兵同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请大夫过船谢宴。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "我不过船了。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "谅你也不敢。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，受惊了。"
        },
        {
          "character": "关羽",
          "type": "煞尾",
          "text": "承款待，多称谢， 只这两句话儿， 恁可也牢牢记者， 百忙里你不得老兄心， 急切里夺不得汉家业。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽跳上船。周仓刀斩船缆。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "开船。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽率众人同下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "惭愧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃下。众人同随下。"
        }
      ]
    },
    {
