{
  "script_id": "70001204",
  "title": "单刀赴会",
  "alias": [],
  "source": "周信芳剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    },
    {
      "name": "关平",
      "hangdang": "武生"
    }
  ],
  "plot": "鲁肃设宴，以邀请关羽过江赴席为名，暗伏刀兵，欲加胁迫。关羽明知其中有诈，并不畏怯，仅携周仓一人，\n单刀赴会。筵间，鲁肃果然婉言索取荆州，关羽佯称酒醉，一手持刀，一手挟鲁肃退席。东吴伏兵不敢轻\n动，关羽安然扬帆回到荆州防地。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "发点。四飞虎、四军校、伊藉、马良、王甫、赵累、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "想当年弟在范阳、兄在楼桑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。关平、周仓同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "俺关某在蒲州解良，诸葛在南阳，英雄聚四方，结义桃园皇叔关张。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "曹操胁主占中原，孙氏东吴已敷传。天下三分成鼎足，大哥仁义坐西川。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室关羽。奉大哥之命，镇守荆州，东扼下游，北拒郧襄；闻得大哥领西 川，进位汉中，也曾奉表申贺，前者诸葛瑾入川催讨荆州，大哥愿将长沙三郡 交还东吴，俺想汉朝疆土，岂肯让人，被某拒绝，量孙权必不休，须要提防。 左右，伺候了。"
        },
        {
          "character": "伊藉、马良、王甫、赵累",
          "type": "同白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "龙虎台前出入，貔貅帐下传宣。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启禀君侯：今有东吴鲁子敬差人前来下书。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "下书人何在？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "现在辕门以外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文暗上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "搜检明白，叫他报门而进。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "喳、喳、喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓急搜黄文。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "呔，父王传你，你要打点了，你要——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓亮相。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "小心了，报门而进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文惧怕。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "报！东吴下书人黄文告进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军校同喝威，黄文战抖地跪见。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "下书人叩见君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那一下书人，奉何人所差？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "东吴鲁大夫所差。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "小将名叫大胆黄文。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大胆黄文！你的胆有多大？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "有巴斗大。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "剖开看来。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓举刀。黄文唬倒。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "哎吓，哎吓！不要剖开，我的胆儿只有芥菜子那样小。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哈哈哈哈。周将，命他将书呈上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "将书呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文呈书，周仓交关羽。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "待某拆开一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。关羽看信。两丝边。关羽考虑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "黄文！"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "本月十三日，某亲来赴会，修书不及，回话去罢！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "去吧！"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "是是是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文出门回头偷看。"
        },
        {
          "character": "黄文",
          "type": "念",
          "text": "出得门来看云长，蚕眉凤目髯飘荡。面如重枣—般同，青龙刀举谁能挡！"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "鲁子敬吓，鲁子敬，此番我倒替你担忧呢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文下。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "敢问父王。东吴来信，写些什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那鲁子敬相请为父，过江赴宴。必为讨荆州之事。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "父帅去是不去？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "他既相请，焉有不去之理。我若不去，岂不被东吴耻笑？"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "启禀父帅：皇伯将荆州九郡托与父帅掌管，倚若泰山，身临险地，倘席间有差， 如何是好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！孺子竟敢多言！为父驰骋在万马军中，尚且视同儿戏，东吴纵有奸谋，为 父又何惧哉！"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "两朝相隔汉阳江， 鲁子敬排宴不寻常。 哪里有倾杯葡萄酿， 分明是巴豆和砒霜。 玳筵前摆列的英雄将， 休想是画堂别样好风光。 他准备着天罗与地网，"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "他准备着杀人好战场。 既相请我当亲身往， 猛虎何惧犬和羊！"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "想那鲁子敬足智多谋，东吴兵多将广，只怕此去，落在他圈套之中。君侯不可 不防。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某自有安排。 周仓听令。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "准备大船一只，挑选关西大汉二十名，随某单刀赴会。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平听令。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "准备战船二十只，军卒三千名，埋伏陆口对岸江上，见红旗一摆，即来迎接为 父。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马良、伊藉镇守荆州，诸将各守汛地，严加防守。正是："
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "云长亲赴单刀会，磊落行藏万古传。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。众人同随下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。黄文、四文堂同上。"
        },
        {
          "character": "黄文",
          "type": "念",
          "text": "江边延上客，席上动刀兵。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "某，东吴大将黄文。奉了鲁都督之命，江边探望荆州船只。 众将官，江边去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引黄文同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周仓上，单起霸。"
        },
        {
          "character": "周仓",
          "type": "念",
          "text": "志气凌云贯九霄，周仓随驾显荚豪。今日江东去赴会，全仗青龙偃月刀。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "今日东吴鲁大夫请俺父帅赴宴，为此驾舟前往。一言未了，只见父帅来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵引关羽同上。〖吹打〗。船夫上，众人同登舟，关平送行，下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "可曾齐备？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吩咐开船。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "喳！ 呔，开船吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "船夫开船。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。吩咐风帆不用扯满，把船缓缓而行，某家好观看江景。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓。 嘚，水手们听者。"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "父帅有令，风帆不要扯满，把船缓缓而行。"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、周仓同亮像。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "波涛滚滚渡江东，独赴单刀孰与同。片帆瞬息西风力，要向东吴一逞雄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好—派江景也！"
        },
        {
          "character": "关羽",
          "type": "上字调新水令",
          "text": "大江东去浪千叠， 趁西风驾着这小舟一叶。 又不比九重龙凤阙， 早来探千丈虎狼穴。 大丈夫性烈，大丈夫性烈， 觑着那单刀会赛村社。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声。周仓出舱看。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "好水。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "前面是何处？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "前面乃是赤壁。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽出舱。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哦哈呀，看这边厢山连着水，那边厢水连着山，俺想二十年前隔江斗智，曹兵 八十三万人马屯在这赤壁之间，也是这般山水，到今日……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽亮像。"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "依旧的水涌山叠， 依旧的水涌山叠， 好一个年少周郎恁在何处也， 不觉的灰飞烟灭， 可怜黄盖暗伤嗟， 破曹樯橹却又早一时绝。 只这鏖兵江水犹然热， 好教俺心惨切。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "嗗，呀呀，好水吓，好水！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "这是二十年流不尽英雄血。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "船夫催舟，关羽率众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引鲁肃同上。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "水军当大任，为国秉忠诚。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文上。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "启都督：关羽船近临江边。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "传令摆队相迎。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四蜀兵同上，同斜门，四吴兵自下场门同上，同斜门。黄文、周仓同上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "君侯到。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "请少待。 有请鲁大夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "君侯驾到。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "待我登舟相迎。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "鲁都督来迎。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有请父帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上，船夫搭扶手，鲁肃下船相迎。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吓，君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
