        {
          "character": "关羽、鲁肃",
          "type": "同笑",
          "text": "啊，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽返席。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯马到成功，肃当敬一大杯。 （〖节节高〗。鲁肃奉酒。关羽接饮，入座。〖急急风〗。吕蒙率四吴将同上，见鲁肃举杯，欲入杀，鲁肃 急止。）"
        },
        {
          "character": "鲁肃",
