{
  "script_id": "70001103",
  "title": "投军别窑",
  "alias": [],
  "source": "周信芳剧本选",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    }
  ],
  "plot": "王宝钏是丞相王允第三个女儿，她奉旨“抛球选婿”，存心将彩球抛中花郎薛平贵。王允不愿招赘花郎为婿，\n意图悔婚；王宝钏则坚决反对父亲这种嫌贫爱富、不守信义的行为，于是毅然抛却荣华，离开相府，随着\n平贵去到寒窑，共度清贫的生活。薛平贵立志投军，降服了红鬃烈马，唐王封他为后军都督府，王允却故意\n将他改任为“马前先行”，并派他随军远征西凉；使这一对新婚不久的夫妇，不得不在相互依恋中忍痛分别。",
  "notes": "《投军别窑》是周信芳同志早年演出的代表作之一。数十年来，经不断丰富和提高，在舞台表演艺术上益趋\n精练。本剧在整理时仅对个别词句有所修订。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "引子",
          "text": "相府堂前三击掌，抛却荣华，甘守清贫。"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "恼恨爹爹太不仁，嫌贫爱富赖婚姻。宝钏誓死随平贵，愿在寒窑受苦辛。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我，王宝钏。爹爹王允，官居首相。只因二月二日在十字街前高搭彩楼，抛球 招婿，打中薛郎，可恨爹爹嫌贫爱富，是我与他三击掌，离却相府，夫妻二人 来到寒窑，苦度光阴。如今薛郎立志前去投军，但愿日后能得一官半职，也不 枉我受苦一场，啊啊啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏拭泪。"
        },
        {
          "character": "王宝钏",
          "type": "二黄慢板",
          "text": "王宝钏坐寒窑珠泪双掉， 老爹爹枉为官一品当朝： 嫌贫穷爱富贵信义不要， 狠心肠把骨肉情一旦丢抛。 愿薛郎此一去身得荣耀， 也不枉我宝钏受苦一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上，起霸。"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "头戴银盔一点红，身穿铠甲透玲珑；降了红鬃一烈马，扶保唐王立大功。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "俺，薛平贵。是我前去投军，降红鬃烈马，圣上见喜，封为后军督府。可恨王 允老贼，上得金殿，参奏一本，言道西凉下国，打来连环战表，要夺我主江山， 苏龙、魏虎以为正副帅，我后军督府改为马前的先锋。今乃黄道吉日，就要 登程。我不免回转寒窑，辞别三姐。天哪，天！恼煞某也！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "可恨王允太不仁，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上马。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "害我夫妻们两下离分！ 催马加鞭往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下马。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "叫声三姐快开窑门。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "忽听门外一声唤， 想必薛郎回窑前。 开开窑门用目看，"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐，为丈夫回来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵进窑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "来了堂堂将一员。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊，薛郎，你回来了！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你这身荣耀，莫非作了官了?"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "为丈夫降了红鬃烈马，圣上见喜，封为后军督府。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀呀，果然作了官了。待我谢天谢地。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐慢谢天地，其中有变哪。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎，此话活从何而起？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊呀三姐呀！可恨你父与魏虎奸贼，上得金殿，参奏一本，言道西凉下国，打 来战表，要夺我主江山，苏龙、魏虎以为正副帅，为丈夫后军督府改为了马前 的先锋，即日就要登程。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我就要走了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏晕倒。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐，三姐醒来！"
        },
        {
          "character": "王宝钏",
          "type": "西皮导板",
          "text": "听一言来珠泪洒！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐醒来！"
        },
        {
          "character": "王宝钏、薛平贵",
          "type": "同叫头",
          "text": "（薛郎）（宝钏）！（我夫）（我妻）！（喂呀）（嗳呀）！"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "好一似万把刀把我心扎！ 父好比秦赵高指鹿为马， 又好比汉萧何私造律法。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "贼好比秦赵高指鹿为马， 贼好比汉萧何私造律法。 为丈夫与你父冤仇结下， 害得我夫妻俩各奔天涯。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "手指相府，"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "高声骂， 爹爹作事理太差。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "夫妻们只哭得泪如雨下， 好鸳鸯遭棒打各奔天涯！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "三姐不必泪双流， 丈夫言来听从头： 干柴十担米八斗， 你在寒窑度春秋； 守得住来将我守， 三姐呀！守不住来将我丢。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "薛郎说话没来由， 为妻言来听从头： 干柴十担米八斗， 我在寒窑度春秋； 守不住来也要守， 纵死在寒窑也不回头。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "三姐说话世少有， 上得青史把美名留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "先行听令。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵出窑。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "元帅初点大卯，不要误了卯期。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "将军不下马，"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "各自奔前程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。薛平贵进窑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "方才何人到此？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "方才中军至此，言道元帅初点大卯，不要误了卯期。三姐你看，天色不早，我 要告辞了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎，你这就要走了吗？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "唉！我这就要走了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你有什么言语，嘱咐为妻几句。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我的心如刀割，也想不起什么言语来了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你……嘱咐为妻几句啊！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "罢！为丈夫此番从军，不知几时回来，寒窑之中，干柴十担，老米八斗，你苦 度春秋；倘若是柴米不够，你……回转相府去吧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎啊！我与我爹爹三击掌，纵然是饿死寒窑，我也是不……回去的啊！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好哇！好个三姐，虽是女流，却比男子刚强。为丈夫此番征战西凉，不知三年 五载，才得回来；你在这窑前、窑后、窑左、窑右，与人家缝缝连连度日，为 丈夫回来，一家一家登门叩谢。话已讲完，我告辞了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎，你当真要走了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我即刻就要走了。唉！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待为妻送你一程。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "外面的风大得很哪！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我一定要送。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不送也罢。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "一定要送啊！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如此有劳了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵欲走，回身为王宝钏拭泪。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊三姐，为丈夫征战西凉，就要回来了，你……不要哭啊！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎，你自己珍重，也不……要哭啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏为薛平贵拭泪。薛平贵出窑，头碰窑门，王宝钏为薛平贵抚痛。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不妨事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏同出窑。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "夫妻双双出窑门，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "叫人难舍又难分。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "但愿得此一去旗开得胜，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "自有那探马儿来报捷音。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "一路上必须要小心谨慎！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "你在那寒窑内切莫要挂心。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "送薛郎送至在三岔路口， 喂呀，薛郎啊！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐啊！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "刀绞肝肠泪淋淋。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "从空降下无情剑，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "斩断夫妻两离分。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "王宝钏难舍薛平贵。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "薛平贵难割结发情。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "流泪眼观流泪眼。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "断肠人送……"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "断肠人。"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "夫妻们只哭得珠泪滚滚…… 喂呀，我的夫啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "号炮三声。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "又听大炮响三声。 辞别三姐踏金蹬，"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "拉住薛郎不放开。 你要走来将我带！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "你苦苦拉我为何来？"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "此去不知三五载， 你叫为妻怎安排？"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "干柴十担米八斗， 你在寒窑度春秋。 辞别三姐跨马走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵推王宝钏倒地，拉马欲行，见状复回。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵扶王宝钏起，急上马。王宝钏急追，扯薛平贵衣襟。薛平贵拔剑割断衣襟，王宝钏晕倒。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐，你要保重了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。王宝钏苏醒起立，远望。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎！我夫！"
        },
        {
          "character": "王宝钏",
