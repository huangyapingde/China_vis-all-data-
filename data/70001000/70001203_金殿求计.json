{
  "script_id": "70001203",
  "title": "金殿求计",
  "alias": [],
  "source": "周信芳剧本选",
  "characters": [
    {
      "name": "乔玄",
      "hangdang": "老生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    }
  ],
  "plot": "刘备取得西川以后，三国鼎足之势已成。孙权乘机命新任都督鲁肃设法索还荆州；在金殿上，东吴元老乔玄\n分析了当时天下大势，他认为这样必使孙、刘两家失和，予曹操以可乘之机。孙权不采纳乔玄的建议。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引孙权上。"
        },
        {
          "character": "孙权",
          "type": "引子",
          "text": "中原大势三分鼎，霸主江东万代馨。"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "赤壁鏖兵余火残，孙刘联合拒曹瞒。楼桑大耳真无信，借占荆州久不还。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤孙权，只因赤壁鏖兵，我东吴费了兵马钱粮，刘备坐收渔人之利，占据荆州， 久借不还，今刘备取得西川曾命诸葛瑾前去索讨，刘备允许暂还三郡，可恨 关羽不允，今调鲁肃回朝，共同商议，还未到来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏千岁：鲁都督回朝。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "千岁有旨：鲁都督上殿。"
        },
        {
          "character": "鲁肃",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "刘备全无信，孔明弄巧心。荆州久不返，鲁肃作难人。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "臣鲁肃见驾，吴侯千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "谢座。宣臣回朝，莫非为了荆州之事？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "诸葛瑾入川，刘备允许暂还长沙、零陵，桂阳三郡，可恨关羽执意不还，反将 诸葛瑾羞辱一场。你道恼是不恼！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "那刘备作事无信义， 我鲁肃无才惹是非。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "当初刘备借荆州，可是你的保？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是鲁肃作的保。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "他不还荆州，你这保人又待怎样？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "鲁肃",
          "type": "西皮摇板",
          "text": "鲁肃作保要保到底，"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "荆州一日不还，你这保人就难脱关系。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "千岁吓！"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "为此事昼夜费心机。 今日定下了三条计， 他不还荆州定不依。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "但不知哪三条计？这一？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第一条计，就以庆贺刘备进位汉中王为由，修下书信一封，命人下到荆州，请 那关云长过江赴宴。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哦，请那关云长过江赴宴！你料他来是不来？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他若不来，便是惧怕我东吴，料那关云长性情高傲，他必然前来！酒席筵前， 还了荆州，万事全休——"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "若是不还？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "在衣壁之中，暗藏甲士，击杯为号，伏兵齐起，擒着关羽囚于江东。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "第二计呢？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "我将一应战船，尽行拘收，不放云长回去，拘囚日久，他自然悔惧，那时不怕 他不还。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "想云长英勇过人，他若恃武不还，你又待怎样？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "还有这第三条吓！"
        },
        {
          "character": "鲁肃",
          "type": "西皮摇板",
          "text": "关云长是刘备股肱臣宰， 他焉能作痴聋把手足情乖！ 那时节我君臣安坐而待， 管教他奉荆州双手送来。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "孙权",
          "type": "西皮摇板",
          "text": "三条计顿教我愁眉尽解， 讨荆州—任你妙计安排。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小太监上。"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "启奏千岁：乔国老有本启奏。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "乔国老，久不上朝，今日前来，定有大事，宣国老上殿。"
        },
        {
          "character": "小太监",
          "type": "白",
          "text": "千岁有旨：乔国老上殿！"
        },
        {
          "character": "乔玄",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乔玄上。"
        },
        {
          "character": "乔玄",
          "type": "西皮摇板",
          "text": "赤壁鏖兵曹兵败， 曹操不敢卷土来。 孙刘联合遭破坏， 只怕荆州是祸胎。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "老臣见驾，吴侯千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "国老不要多礼，请坐。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "国老请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃让上坐。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "鲁都督请坐。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "国老今日上殿，有何大事？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "诸葛瑾空手而回，调回鲁都督，莫非为讨荆州？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "刘备倒有还三郡之意；可恨关羽执意不允，令人可恼。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "屡讨荆州，一事无成，今番又恐画虎不成，反被耻笑。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "鲁都督定下三条妙计：这一，请他赴宴，当宴索讨。这二，他若不允，拘留江 东。这三，刘备闻知，必定献城赎将，荆州可得。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "这三计不成，必然引起争战，曹操虎视耽耽，必然乘机杀来，报赤壁之仇；不 如相安—时，再等时机。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "我意已决，不必多言。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "乔玄",
          "type": "西皮原板",
          "text": "汉高祖在咸阳登了大宝， 四百年至桓灵八方萧条。 董卓贼霸朝纲豺狼当道， 众诸侯兴义兵大战虎牢。 王司徒献连环董卓诛了， 曹孟德挟天子又霸汉朝。 刘皇叔居西川狼烟尽扫， 我东吴承父兄列土分茅； 这才是既得陇又望蜀道， 怕的是，螳螂捕蝉，黄雀在后，那曹操乘隙而攻，自取火烧。"
        },
        {
          "character": "孙权",
          "type": "西皮原板",
          "text": "汉光武灭王莽汉室暂保， 传至在桓灵帝瓦解冰消。 孤承受父兄业国安民好， 恨曹瞒领人马威赫我朝； 战赤壁费尽了兵马粮草， 刘玄德在夏口有何功劳？"
        },
        {
          "character": "乔玄",
          "type": "西皮原板",
          "text": "曾记得曹操打战表， 他要把东吴一笔销。 文班中准备写降表，"
        },
        {
          "character": "乔玄",
          "type": "西皮二六板",
          "text": "武将土不敢动枪刀。 我国中若不是周郎好， 江南九郡尽归曹。 老黄盖苦肉计献粮草， 庞士元连环计谋高； 若不亏南阳诸葛东风祭得妙， 这东吴焉有半分毫！ 孙刘若是失和好， 鹬蚌相争自把祸招。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "国老吓！"
        },
        {
          "character": "鲁肃",
          "type": "西皮流水板",
          "text": "国老把话讲差了， 鲁肃言来听根苗： 诸葛瑾曾把荆州讨， 那刘备允还三郡归我朝。 可恨那关羽性高傲， 寸土不还恨难消。 蜀中大将年纪老， 何惧他将老兵又骄。"
        },
        {
          "character": "乔玄",
          "type": "西皮流水板",
          "text": "休道蜀中兵将老， 现有五虎将英豪： 关云长谋略好， 全凭青龙偃月刀。 张翼德，情性躁， 大吼一声断了坝林桥； 赵子龙，胆量好， 曹兵一见魂魄消； 马孟起，似虎豹， 只杀得曹操割须弃了袍； 黄汉升八十不服老， 百步穿杨射得高； 五虎将、我不表， 还有那诸葛孔明他的志谋高。"
        },
        {
          "character": "孙权",
          "type": "西皮流水板",
          "text": "体道蜀中兵将好， 东吴也有将英豪： 丁奉、徐盛韬略好， 蒋钦、周泰志谋高； 甘宁、韩当赛虎豹， 陈老、潘璋似龙蛟。 一心要把荆州讨， 何惜—战动枪刀！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "国老！"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "昔借荆州我为保， 久惜不还我常把心操。 故此定下三杰计， 宴请关羽去相邀。 席前便把荆州讨， 管教他束手被擒无处逃。"
        },
        {
          "character": "乔玄",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "乔玄",
          "type": "西皮散板",
          "text": "休道你三条计真巧妙， 休道他三条计定难逃。 你头次曾把荆州讨， 未曾取得半分毫。 二次定下美人套， 以假成真在甘露寺把亲招； 美人计曾把郡主陪送掉， 陪了夫人又折兵这话柄被人笑嘲。 三次又把荆州讨， 中了孔明计笼牢； 损兵折将事非小， 可叹我小婿周瑜命丧巴丘赴阴曹。 前车之鉴你忘怀了， 看起来你智穷力竭把旧文章抄，大妙不妙，看来计不高。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "孙权",
          "type": "西皮散板",
          "text": "不提甘露寺还罢了， 提起此事怒眉梢。 周公瑾定下牢笼套， 金钩准备钓海螯。 被你泄露母后知晓， 以假成真无下梢； 今日又来多阻挠， 请太尉再休要谰言絮叨。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "下殿去罢！"
        },
        {
          "character": "乔玄",
          "type": "西皮散板",
          "text": "他君臣必要行此道， 好似沙中把金淘。 话不投机良言少，"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "乔玄",
          "type": "西皮散板",
          "text": "我不愿袖手旁观再去絮叨。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "国老，你为何去而复返？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "我总觉得三计不妙，这一封小简，焉能会来，纵然来了，焉能一席小宴，就退 回荆州，你要擒他，难道他就一无准备不成？何况那关羽他那样英雄、那样的 神威。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "他只要肯来，四方都是我国兵将，他纵然是一只猛虎，也飞不过江去，他还有 什么威风，还称什么英雄？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "你又来了！"
        },
        {
          "character": "乔玄",
          "type": "西皮小导板",
          "text": "他上阵风摆美髯飘又飘，"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "他胡子长得好，又有什么了不得？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "胡子，哈哈，我也有胡子吓！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "你呀！差得多。"
        },
        {
          "character": "乔玄",
          "type": "西皮流水板",
          "text": "雄纠纠一丈虎躯摇。 恰便似六丁六甲活神道， 敌人见了就魂消。 他诛文丑，逞粗躁， 他刺颜良，显英豪； 战虎牢曾把华雄斩了， 百万军中把上将首级轻轻的枭； 曹孟德灞桥饯行只落得一场谈笑， 青龙刀挑起了大红袍，赤兔马飞过了灞陵桥。 过五关斩将如同削草， 怎挡他千里追风驹，闪不过青龙偃月刀。 你讨荆州好有一比， 好比那水中捞月——"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "吴侯，鲁都督！"
        },
        {
          "character": "乔玄",
          "type": "西皮散板",
          "text": "月难捞。"
        },
        {
          "character": "孙权",
          "type": "西皮散板",
          "text": "你将云长夸大了， 孤家看来等鸿毛。 鲁都督安排三条计， 准备孙刘动枪刀。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权下，四太监随下。"
        },
        {
          "character": "乔玄",
          "type": "西皮散板",
          "text": "他君臣不听良言告， 唇破舌焦枉徒劳。 关云长恩怨分明又高又傲，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乔玄向鲁肃。"
        },
        {
          "character": "乔玄",
          "type": "西皮散板",
          "text": "怎肯一席将荆州交！ 莫道他武将粗鲁你文官狡，"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "我好怕呀！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "你怕什么？"
        },
