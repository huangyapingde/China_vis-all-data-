{
  "script_id": "03028002",
  "title": "小商河",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "杨再兴",
      "hangdang": "武生"
    },
    {
      "name": "兀术",
      "hangdang": "净"
    },
    {
      "name": "岳飞",
      "hangdang": "老生"
    }
  ],
  "plot": "岳飞破“五方阵”后，兀术举兵南侵。岳飞战将杨再兴奉命大战于小商河，连斩四番将。兀术不敌，埋兵小\n商河桥头，杨再兴被乱箭射死。岳云挺战，兀术败退朱仙镇。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖将军令〗。四文堂、四下手、雪里花东、雪里花西、雪里花南、雪里花北扎犄角引兀术同上。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "巴图鲁！催军！ （四文堂、四下手、雪里花东、雪里花西、雪里花南、雪里花北同允。〖出队子〗。四文堂、四下手、雪里 花东、雪里花西、雪里花南、雪里花北、兀术同走圆场，同挖开。）"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "孤，大金邦四太子、昌平王、扫宋大元帅，御讳完颜宗弼，皇号兀术。奉了父 王之命，统领倾国人马，夺取宋室天下。 众平章！"
        },
        {
          "character": "雪里花东、雪里花西、雪里花南、雪里花北",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "命尔等各带本辖人马，渡过小商河，攻打宋军，孤家随后接应！"
        },
        {
          "character": "雪里花东、雪里花西、雪里花南、雪里花北",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引雪里花东、雪里花西、雪里花南、雪里花北同下。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "巴图鲁！接应去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同允。〖合头〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引岳飞同上。"
        },
        {
          "character": "岳飞",
          "type": "唱",
          "text": "收服了杨再兴精明干练， 扫平那九龙山潭州安然。 统雄师剿太湖贼人丧胆， 火攻计释王佐义结金兰。 戚统制挟嫌隙暗施冷箭， 多亏了牛贤弟妙药仙丹。 今日里破阵式贼军溃散， 破了那洞庭湖再征北番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引杨再兴同上。"
        },
        {
          "character": "杨再兴",
          "type": "唱",
          "text": "率军卒洞庭湖一场鏖战， 刺杀那五虎将贼军胆寒。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将军少礼！请坐。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将军率兵破敌，如何成功？本帅愿闻。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "元帅容禀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将军勇敢直前，哪怕那厮不灭。功绩昭然，待本帅奏明圣上，定有褒奖。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "谢元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "适才探马报道：兀术又来南犯，兵经朱仙镇，直抵小商河。就命将军率领五千 人马，迅速应敌，阻其南下！"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "这才是一波未平，一波又起。那金寇虽然嚣张，俺也要深入北国，直捣黄龙。 纵然战死疆场，马革裹尸，为报元帅知遇之恩，又何憾哉！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将军如此忠勇，实堪钦佩。听吾一令！"
        },
        {
          "character": "岳飞",
          "type": "唱",
          "text": "率本部万千人急忙应战， 莫令那金兀术再逞凶顽。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "杨再兴",
          "type": "唱",
          "text": "奉将令敌金兵小商河岸， 此一去报知遇死也心甘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴下。牛皋、岳云同上。"
        },
        {
          "character": "岳云",
          "type": "唱",
          "text": "攻破了五方阵奇功一件，"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "进帐中见元帅细说根源。"
        },
        {
          "character": "岳云、牛皋",
          "type": "同白",
          "text": "参见（父）（元）帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "罢了。洞庭湖之事怎么样了？"
        },
        {
          "character": "岳云、牛皋",
          "type": "同白",
          "text": "（父）（元）帅容禀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "是你二人首功一件，奏明圣上，定有升赏。"
        },
        {
          "character": "岳云、牛皋",
          "type": "同白",
          "text": "多谢（父）（元）帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "岳云、牛皋听令！"
        },
        {
          "character": "岳云、牛皋",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "命你二人各率本部人马齐赴朱仙镇，渡过小商河，拒敌金兀术，接应杨再兴， 不得有误！"
        },
        {
          "character": "岳云、牛皋",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四上手引杨再兴同上。杨再兴起霸。"
        },
        {
          "character": "杨再兴",
          "type": "粉蝶儿",
          "text": "番奴狂妄，逞凶顽，番奴狂妄， 陷帝京，劫二圣，肆意嚣张。 天辐辏，暗助康王； 中兴主，泥马渡江！"
        },
        {
          "character": "杨再兴",
          "type": "念",
          "text": "报国丹心达太清，一时千载定声名。只惭世上无忠孝，不论人间有死生。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "俺、杨再兴。奉令渡过小商河拒敌金兵。 众将官，随俺迎敌者！"
        },
        {
          "character": "杨再兴",
          "type": "合头",
          "text": "恨金兵贪无厌兴师犯上， 此一番扫灭豺狼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同领圆场归上场一字，四下手引雪里花南自下场门同上，倒脱靴下。"
        },
        {
          "character": "雪里花南",
          "type": "白",
          "text": "呔！马前来将，慢催坐骑，雪里花南在此！"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "番奴休走！"
        },
        {
          "character": "杨再兴",
          "type": "石榴花",
          "text": "只凭俺匹马银枪， 只凭俺匹马银枪， 诛戮尽这番奴心方畅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴刺死雪里花南。雪里花东上，打。"
        },
        {
          "character": "杨再兴",
          "type": "石榴花",
          "text": "又只见那番儿齐涌似虎如狼， 何惧他奇勇也那猖狂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴刺死雪里花东。"
        },
        {
          "character": "杨再兴",
          "type": "石榴花",
          "text": "只见那烟尘弥漫， 只见那烟尘弥漫， 杀气腾腾摆开了战场， 雄赳赳纵马也那勒缰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪里花西、雪里花北同上，同打。"
        },
        {
          "character": "杨再兴",
          "type": "石榴花",
          "text": "管叫那小番儿， 管叫那小番儿， 匆忙俱都疆场丧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴刺死雪里花西、雪里花北。"
        },
        {
          "character": "杨再兴",
          "type": "石榴花",
          "text": "俺夺旗斩将姓名扬！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手引兀术同上。"
        },
        {
          "character": "兀术",
          "type": "黄龙滚",
          "text": "统雄师虎跃龙扬， 扫宋室如平草莽， 昌平王威震八方！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "四位平章落马！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "巴图鲁，杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引杨再兴同上，会阵。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "阵前来者，敢是兀术？"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "呔！那一小将慢逞刚强，通上名来！"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "听者！俺乃岳元帅麾下大将杨再兴是也。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "杨再兴，小奴才！"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "孤奉狼主之命，统兵南征，就是那岳飞早晚也须受缚，何况你这偏裨小将，怎 堪一战！"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "呸！满口胡言，看枪！ （杨再兴、兀术同架住。八文堂、四下手分钻烟筒下。起打。兀术败下。四文堂同上，过场，同下。杨再兴 下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手、兀术同败上。"
        },
        {
          "character": "兀术",
          "type": "黄龙滚",
          "text": "杨再兴俊逸豪强， 杨再兴俊逸豪强， 杀得俺魂飞魄丧！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "嘿！想孤自南征以来，未曾经此大败。那杨再兴十分骁勇，难以力敌。不免趁 此大雪纷飞，就在小商河桥上埋伏军卒，取他性命便了。 巴图鲁，埋伏去者！"
        },
        {
          "character": "兀术",
          "type": "合头",
          "text": "恰遇着天公作美鹅毛降， 雪地里正好埋藏。 可怜他英雄小将， 可怜他英雄小将， 也难逃箭似飞蝗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手引兀术同走圆场，同上高台，杨再兴上。"
        },
        {
          "character": "杨再兴",
          "type": "上小楼",
          "text": "怒冲冲抖丝缰， 凶狠狠精神旺。 霎那间踏破番营， 银枪起处现红光。 又只见大雪纷飞， 又只见大雪纷飞， 银装世界难分低昂， 急煎煎觅路走慌忙。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "乱箭齐发！"
        },
        {
          "character": "四文堂、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手同放箭。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨再兴",
          "type": "叠字令",
          "text": "闹吵吵梆声乱响， 冷飕飕箭如雨降， 匆忙忙展银枪， 扑啦啦难遮挡； 紧促促扯断丝缰， 颤巍巍血溅胸膛。 颤巍巍血溅胸膛， 撕断袍幅把创痕扎绑， 今日里为国捐躯姓字香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋引四上手同上，救杨再兴同下。岳云上，起打，兀术败下。四文堂自两边分上。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "兀术兵退朱仙镇！"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "众将官，将朱仙镇团团围住！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同走圆场，同跑下。岳云耍下场，下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、严成方、何元庆、张保、狄雷、岳飞同上。"
        },
        {
          "character": "岳飞",
          "type": "唱",
          "text": "这几日身不爽胸怀闷恹， 帅字旗无风动所为哪般？ 杨再兴小商河抗敌交战， 但愿得破金兵捷报临安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报：杨将军在小商河桥身中乱箭，失机落马！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "牛皋",
          "type": "内白",
          "text": "牛皋、岳云救杨将军回营！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "快快搭进帐来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、岳云引四上手扶杨再兴同上。岳飞起箭，杨再兴死。"
        },
        {
          "character": "岳飞",
          "type": "三叫头",
          "text": "再兴！贤弟！哎，贤弟呀！"
        },
        {
          "character": "岳飞",
          "type": "唱",
          "text": "痛惜良将肝肠断！"
        },
        {
          "character": "岳飞",
          "type": "三叫头",
          "text": "再兴！贤弟！贤弟呀！"
        },
        {
          "character": "岳飞",
          "type": "唱",
          "text": "呜咽悲啼血泪斑。 忆昔当年潭州战， 吾弟占据九龙山。 较量枪法互钦羡， 武艺相同伯仲间。 夜梦令祖神威显， 传授绝技记心间。 次晨运用撒手锏， 才得收服在马前。 王佐设摆金兰宴， 四下火起红彻天。 愚兄被困遭贼陷， 幸遇贤弟施救援。 兀术统兵来侵犯， 又差贤弟至阵前。 小商河桥中乱箭， 为国捐躯痛心间。 大料阴魂去不远， 定灭金囚复仇冤。"
        },
