    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": "孙膑",
          "type": "内唱",
          "text": "坐在营中心惊战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙燕扶孙膑同上。"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "神魂缥缈不安然。 胆战心惊精神乱， 我体似筛糠为哪般？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "儿啊！为叔神魂不定，坐卧不安，不知为了何事？"
