{
  "script_id": "03027001",
  "title": "五雷阵",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "孙膑",
      "hangdang": "老生"
    }
  ],
  "plot": "战国时，秦欲吞并六国，命王翦挂帅与燕孙膑战。王翦屡败于孙膑，乃约师兄毛逩设“五雷阵”摄孙膑魂于\n阵中，孙膑险被害。嗣由孙膑师弟毛遂盗来“九转还阳丹”，老君“太极图”，乃破阵救孙膑。并击败王翦、\n毛逩。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四秦将同上，同站门。王翦上。"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "得胜猫儿强似虎， 败阵凤凰不如鸡。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "俺、秦国大元帅王翦。不想中了孙膑诱兵之计，所带兵马伤了大半，为此今日 整顿军兵，随带法宝“打神钢鞭”，与他一决雌雄。 众将官，骂阵去者！"
        },
        {
          "character": "四龙套、四秦将",
          "type": "同白",
          "text": "噢！"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "可恨孙膑诱兵计， 杀得豪杰胆魂飞。 随带法宝把阵对， 不灭燕邦誓不回。 （四龙套、四秦将同领下，王翦下。连场。〖牌子〗。四上手、四燕将、蒯文通、袁达、孙燕、毛遂同上， 同站门。孙膑上，坐。）"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "两厢退下！"
        },
        {
          "character": "四上手、四燕将、袁达、蒯文通",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四燕将、袁达、蒯文通自两边分下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "师弟请坐！"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "昨日诱兵之计，多亏师弟相助成功。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥，想那王翦，昨日一败，必不甘心；又知你未受“转天箭”身亡，定要搬 取救兵，再报前仇。不定又要用什么暗器，你总要提防提防才是。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "师弟之言甚是。但那王翦乃一勇之夫，不足为虑。就是他转求他师海潮，赐些 法宝，临阵暗用，也不放在愚兄的心上。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥此言差矣！有道是：强中自有强中手。总要提防一二！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "师弟，想昨日一战，他已按兵不出，谅他有何能为？愚兄静坐营中，候他前来 讨战，愚兄要独自出兵，擒那王翦也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启真人：王翦骂阵。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "这厮果来骂阵，岂能容他猖狂！师弟，看守大营。唤众将前来！"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "遵命。 众将走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四燕将、袁达、蒯文通自两边分上。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "迎敌王翦去者！"
        },
        {
          "character": "四上手、四燕将、袁达、蒯文通",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同领下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四上手、四燕将、蒯文通、袁达、孙膑同上，同出城。四龙套、四秦将、王翦同上，同会阵。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "呔！杀不死的贼子，又来讨战。今日相逢，定与你一决雌雄。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "住了！孙伯陵，前者误中你的诡计，锐气未挫，谅你今日难逃某手！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "一派胡言！ 众将官，擒此逆贼！ （孙膑、王翦同起打。王翦、四龙套、四秦将同败下，孙膑、四上手、四燕将、蒯文通、袁达同追下。连场。 王翦上。）"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "且住！这厮人多势众，“打神钢鞭”伤他。 （孙膑、四上手、四燕将、蒯文通、袁达同追上，王翦用鞭打，孙膑、四上手、四燕将、蒯文通、袁达同过 场，同下。孙膑上，接打。）"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "招打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王翦祭鞭，孙膑收鞭。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "王翦，又用暗器！神鞭已到某手，尔还有何法宝？"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "骂声伯陵好大胆， 敢收你爷打神鞭！ 抖擞威风与他战， 定斩你头在阵前！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑、王翦同起打。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "看拐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑打王翦。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "唉呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王翦败下。四上手、四燕将、蒯文通、袁达同上。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "不必追赶，人马回营！"
        },
        {
          "character": "四上手、四燕将、蒯文通、袁达",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同拥下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "毛遂、孙燕同上。"
        },
        {
          "character": "孙燕",
          "type": "念",
          "text": "叔父去出兵，"
        },
        {
          "character": "毛遂",
          "type": "念",
          "text": "未知输和赢。 （〖水底鱼〗。孙膑、四上手、四燕将、蒯文通、袁达同上，同挖门。四上手、四燕将、蒯文通、袁达自两 边分下。孙膑坐。）"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "师弟请坐！"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "参见叔父！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥，与那王翦交战，胜负如何？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "师弟，那王翦匹夫之勇，被愚兄几合勇战，收来他的“打神钢鞭”，用双拐将 他打进关去了。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "这就是了。 孙燕，命你巡营了哨，不得有误！"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙燕下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "师弟，请至后账。正是："
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "谅他纵有擎天手，"
        },
        {
          "character": "毛遂",
          "type": "念",
          "text": "难逃燕邦道高人。"
        },
        {
          "character": "孙膑、毛遂",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑、毛遂同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金子陵上。"
        },
        {
          "character": "金子陵",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。王翦、四龙套、四秦将同上，同挖门。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "罢了啊罢了！"
        },
        {
          "character": "金子陵",
          "type": "白",
          "text": "师弟回营，胜负如何？"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "想你我弟兄，自下昆仑以来，扶保始皇天子，并吞六国，百战百胜。不料今日 被孙膑收去了俺的“打神钢鞭”，祭起沉香二拐，不是俺马走如飞，险遭不测。"
        },
        {
          "character": "金子陵",
          "type": "白",
          "text": "师弟，事已至此，只好点起信香，求告师傅便了。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "只好如此。 来，香案伺候！"
        },
        {
          "character": "金子陵",
          "type": "唱",
          "text": "那日别师下仙山，"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "统领貔貅扫狼烟。"
        },
        {
          "character": "金子陵",
          "type": "唱",
          "text": "到处全凭转天箭，"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "孙膑扭天下尘凡。"
        },
        {
          "character": "金子陵",
          "type": "唱",
          "text": "挡住弟子兵百万，"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "收去法宝打神鞭。"
        },
        {
          "character": "金子陵",
          "type": "唱",
          "text": "叩罢首来将身站，"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "速把免战挂高杆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同拥下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙燕上。"
        },
        {
          "character": "孙燕",
          "type": "唱",
          "text": "心中恼恨贼王翦！"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "俺、孙燕。可恨王翦，苦苦与我孙家作对，且喜叔父将他战败。命我巡营了哨， 就此去者！"
        },
        {
          "character": "孙燕",
          "type": "唱",
          "text": "害我全家丧黄泉。 祖父阴灵若惦念， 灭却王翦报仇冤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙燕下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二童儿引海潮真人同上。"
        },
        {
          "character": "海潮真人",
          "type": "引子",
          "text": "云山修道，每日里，快乐逍遥。"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "吾乃海潮真人是也。前命金子陵、王翦二人下山，扶助秦始皇并吞六国，不知 胜负如何？今日坐在洞中，好生烦闷。 童儿，开了洞门者！"
        },
        {
          "character": "二童儿",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "海潮真人",
          "type": "唱",
          "text": "每日洞中来修炼， 快乐清闲自安然。 站立洞外用目看，"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "海潮真人",
          "type": "唱",
          "text": "忽然一阵信香烟。"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "哎呀且住！霎时一阵信香，原来王翦被孙膑战败，特来求救。我自有道理。 童儿，唤你大师兄进见。"
        },
        {
          "character": "童儿甲",
          "type": "白",
          "text": "大师兄进见。"
        },
        {
          "character": "毛逩",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛逩上。"
        },
        {
          "character": "毛逩",
          "type": "念",
          "text": "立志修身奉师严，专心悟道炼金丹。"
        },
        {
          "character": "毛逩",
          "type": "白",
          "text": "参见师傅！"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "罢了。坐下。"
        },
        {
          "character": "毛逩",
          "type": "白",
          "text": "谢坐！唤弟子出来，有何调教？"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "只因你师弟王翦，被孙膑战败，为师命你前去相助。"
        },
        {
          "character": "毛逩",
          "type": "白",
          "text": "弟子遵命！只是身旁无有法宝，恐怕难以成功。"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "不妨！为师赐你“混元金钟”、“五雷神匣”，必定成功。"
        },
        {
          "character": "毛逩",
          "type": "白",
          "text": "想那孙膑，惯用“五雷”，岂不是班门弄斧？"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "那孙膑用的乃是“阳”五雷，为师乃是“阴”五雷，有道是：阴能益阳。只是 一件——"
        },
        {
          "character": "毛逩",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "若遇青龙，不可交战。"
        },
        {
          "character": "毛逩",
          "type": "白",
          "text": "但不知青龙是谁？"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "孙龙之子，名唤孙燕。"
        },
        {
          "character": "毛逩",
          "type": "白",
          "text": "弟子记下了。"
        },
        {
          "character": "海潮真人",
          "type": "白",
          "text": "听为师吩咐！"
        },
        {
          "character": "海潮真人",
          "type": "唱",
          "text": "若遇青龙不可战， 灭却伯陵早回山。"
        },
        {
          "character": "毛逩",
          "type": "唱",
          "text": "师傅且把心放宽， 全凭法宝到凡间。 辞别师傅把衣换，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛逩换衣。"
        },
        {
          "character": "毛逩",
          "type": "唱",
          "text": "灭却孙膑即回山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛逩下。"
        },
        {
          "character": "海潮真人",
          "type": "唱",
          "text": "一见毛逩下高山， 孙膑绝命在眼前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "海潮真人下，二童儿同随下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、王翦同上。"
