        {
          "character": "孙膑",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "妖道设下巧机关， 把为叔的魂魄押阵前。 纵有神通难施展， 要报冤仇难上难。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "儿呀！那贼摆下“五雷”大阵，将为叔魂魄押在阵中了。"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "叔父就该用“杏黄旗”破之。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "毛逩摆的乃是“阴”五雷，俱是些肮脏之物，那“杏黄旗”如何破得？"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "叔父不去打阵，又怕他何来？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "我头上鲜花，已被妖道押在阵中，纵然不去，也休想活命。"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "叔父，倘有差迟，家中祖母娘亲，侄儿如何侍奉？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "提起娘亲我心乱，"
        },
        {
          "character": "孙膑",
          "type": "三叫头",
          "text": "母亲！老娘！母亲哪！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "寸断肝肠珠泪琏。 深恨毛逩骂王翦， 我与你结下山海冤。 儿不死总是爷的患， 且到阵中走一番。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "准备下杏黄旗、峨嵋剑， 再备为叔的引魂幡。 扳角青牛备鞍韂，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑下。孙燕备马。孙膑上，起霸。"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "八卦仙衣扣连环。 可叹我一家人被风来吹散，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙燕哭。"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "小孙燕在一旁珠泪不干。 实指望扶儿登宝殿， 恢复燕国锦江山。 为叔的苦征恶战三年整， 到如今事事不周全。 看酒来与为叔活活祭奠， 这杯酒送我到鬼门关。 看过了沉香拐亲把礼见， 此一番全仗你会战军前。 悲切切上青牛肝肠痛断， 可叹我入仙山悟道参禅。 到今日未报父仇怨， 无有结果好收缘！"
        },
        {
          "character": "孙膑",
          "type": "三叫头",
          "text": "孙燕！我儿！哎儿呀！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑下。孙燕哭。"
        },
        {
          "character": "孙燕",
          "type": "三叫头",
          "text": "叔父！三叔！叔父呀！"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙燕下。"
        }
      ]
