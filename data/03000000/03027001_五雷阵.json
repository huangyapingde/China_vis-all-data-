          "character": "毛遂",
          "type": "白",
          "text": "俺、毛遂。前者随定孙三哥同破王翦，那贼大败。营中无事，暂回连阴洞打坐。 今日为何心血来潮？必有缘故。正是："
        },
        {
          "character": "毛遂",
          "type": "念",
          "text": "一生无别事，专为他人忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白猿上。"
        },
        {
          "character": "白猿",
          "type": "白",
          "text": "来此已是连阴洞，待我进去。 啊，师兄在洞里吗？"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "白猿贤弟来了，请坐！"
        },
        {
          "character": "白猿",
          "type": "白",
          "text": "啊师兄，你好安然自在呀！"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "贤弟何出此言？"
        },
        {
          "character": "白猿",
          "type": "白",
          "text": "你可知孙师兄之事吗？"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "前者愚兄随定伯陵大战王翦，秦兵已退，营中无事，我才回连阴洞打坐。怎见 得我安然自在？"
        },
        {
          "character": "白猿",
          "type": "白",
          "text": "亏你与孙师兄还在一处！那海潮真人又差毛逩下山，摆下“五雷大阵”，将伯 陵押在阵中了。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "白猿",
          "type": "白",
          "text": "压在阵中了。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "可恼啊可恼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "既然如此，你我一同前去搭救！"
        },
        {
          "character": "白猿",
          "type": "白",
          "text": "你可到阵前与三哥送信，叫他暂且忍耐，我还要去搬请同道师友，共破此阵。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "你我弟兄分头而行。"
        },
        {
          "character": "白猿",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "毛遂",
          "type": "唱",
          "text": "可叹三哥陷了阵，"
        },
        {
          "character": "白猿",
          "type": "唱",
          "text": "各自分头走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂、白猿同下。"
        }
      ]
