{
  "script_id": "03057007",
  "title": "晴雯补裘",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "晴雯",
      "hangdang": "旦"
    },
    {
      "name": "贾宝玉",
      "hangdang": "小生"
    },
    {
      "name": "麝月",
      "hangdang": "旦"
    }
  ],
  "plot": "贾宝玉衣贾母所赠之“孔雀裘”赴宴，不慎被火星燎损，惧贾母责罪，归告晴雯，晴雯带病为之补缀，连夜\n而成。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "晴雯上。"
        },
        {
          "character": "晴雯",
          "type": "引",
          "text": "命薄如云，只赢得，青衫一领。"
        },
        {
          "character": "晴雯",
          "type": "念",
          "text": "荏苒年华十五余，飘萍断梗一身孤。怡红院里春如海，夜夜添香伴读书。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "奴家、晴雯。幼失怙恃，辗转流离。自入贾府为婢，多蒙老太太十分爱惜，赏 与贾二爷使唤。哪知这位贾二爷，性格温存，有多般怜惜于我。我想人非草木， 谁能无情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯起身。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "只是想奴乃是命薄之人，受他——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯左右看。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "这般看待，是叫人怎生消受得起哟！"
        },
        {
          "character": "晴雯",
          "type": "西皮原板",
          "text": "可怜我似落红随风飘荡， 怎禁得宝二爷怜玉惜香。 未跳出烦恼坑又入情网， 倒教我相思债怎样去偿。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "天色已晚，为何不见二爷回来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月执红灯引贾宝玉同上。"
        },
        {
          "character": "贾宝玉",
          "type": "西皮原板",
          "text": "花姐姐回家去叫人眷念， 在院中好一似度日如年。 无聊赖到潇湘闲游一遍， 不觉得黄昏后月挂霜天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉立，向麝月。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "你看前面莫非是花——"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "花什么？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "唔，原来是晴雯姐姐。我方才说的是我眼儿花了。哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯低头不语，麝月引贾宝玉同进院，贾宝玉转向晴雯。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "天气这般寒冷，姐姐为何呆立风前？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯不语。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "倘若被风吹病了，岂不又要我担心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯转身看贾宝玉。起风。晴雯打寒噤，转身随贾宝玉进院。贾宝玉坐塌上，晴雯烤火。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "适才老太太吩咐，只因袭人姐姐回家去啦，特派你我二人小心伺候二爷。天时 不早，二爷明天还要到舅太爷府中拜寿，早些安歇吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉点头，麝月铺床，晴雯坐炉旁烤火，麝月喘向晴雯。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "你倒真会享福，看我这儿铺床叠被，忙得气都喘不过来，难道你连这窗帘儿、 镜袱子都不能将它放下来吗？"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "好妹妹，我方才被那阵狂风吹得心如刀刺，现坐熏笼之旁，才觉得好些，妹妹 你偏劳了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月作势。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "哼！你是金枝玉叶，难道我就是土牛木马不成吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月转身不动，晴雯忽然起立，贾宝玉急上前阻止。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "晴雯姐姐，今夜冒了风寒，可到后房安歇去吧。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "二爷身旁无人侍奉。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "我身旁么？有麝月姐姐在此。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯向麝月。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "还是要辛苦妹妹你了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月不睬，晴雯快步自上场门下。起更。贾宝玉、麝月各作眠。帐中。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "袭人呀，花姐姐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯睡装短衣持烛急上，作冷。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "麝月妹妹，麝月妹妹！"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "什么事，这么大惊小怪的？"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "二爷适才呼唤，你可曾听见？"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "他唤袭人，与你我有什么相干？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月睡，晴雯持烛呆立。贾宝玉掀帐。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "夜静更深，你怎么来到这里？照你这样打扮，怕不要冻出病来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉摸晴雯额。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "如何，果然发起热了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月起奉茶。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "麝月姐姐，快些扶晴雯姐姐到后房里去，待我去唤人煮药。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯急阻。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "二爷呀！"
        },
        {
          "character": "晴雯",
          "type": "西皮快板",
          "text": "二爷不必高声嚷， 些小地感冒谅无妨。 夜静更深你将人唤， 别人必笑我太轻狂。 回转身来"
        },
        {
          "character": "晴雯",
          "type": "西皮散板",
          "text": "向后往， 切莫要怜我病自把神伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯扶麝月同下。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "咳，这是哪里说起哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "贾母",
          "type": "内西皮导板",
          "text": "白发婆婆享天年，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸳鸯引贾母同上。"
        },
        {
          "character": "贾母",
          "type": "西皮原板",
          "text": "华封紫诰乐陶然。 松柏长春随人转， 芝兰并茂绕膝前。 福寿堂好似大罗殿， 不羡荣华不羡仙。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "老身、史氏。自进贾门以来，数十余载。幸喜儿孙繁茂，长幼康宁，倒也了却 我心头之愿。 鸳鸯！"
        },
        {
          "character": "鸳鸯",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "你看天色破晓，可将堂门打开。"
        },
        {
          "character": "鸳鸯",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸳鸯开门。贾宝玉上。"
        },
        {
          "character": "贾宝玉",
          "type": "念",
          "text": "夜寒愁似絮，天曙同笼霜。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "老祖宗在上，孙儿这厢有礼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉请安。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "罢了。啊宝玉，你今天为何打扮得这般华茂？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "启禀老祖宗：舅父今天寿诞，孙儿要前去拜寿，特来请命。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "哈哈哈！不是孙儿提起，老身倒忘怀了。如此，孙儿你快些前去！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉转身欲行。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "回来！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "老祖宗有何吩咐？"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "天气寒冷，你看外面可曾下雪？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉外看。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "北风甚紧，天色阴沉，恐怕午后是要下雪的。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "鸳鸯！"
        },
        {
          "character": "鸳鸯",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "你把那件雀金丝的宝裘取来，给了宝玉吧！"
        },
        {
          "character": "鸳鸯",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸳鸯取裘递贾宝玉。贾宝玉与贾母叩头。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "多谢老祖宗！"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "宝玉须要小心，这是俄罗斯国拿孔雀羽毛织成的，我孙穿衣惜衣，不要糟蹋了。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "孙儿不敢。"
        },
        {
          "character": "贾母",
          "type": "白",
          "text": "宝玉你要早去早回。正是："
        },
        {
          "character": "贾母",
          "type": "念",
          "text": "箕裘付与孙儿辈，我自含饴乐余年。"
        },
        {
          "character": "贾母",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸳鸯扶贾母下。贾宝玉向鸳鸯招手。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐，你看我穿这件宝衣，是好看不好看呢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸳鸯不答，下。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "呀，鸳鸯姐姐她到底不肯理我，咳，这也是我自寻烦恼噢！"
        },
        {
          "character": "贾宝玉",
          "type": "唱",
          "text": "昨宵愁病今朝恨， 人说我狂我说情。 万事茫茫皆梦境， 最难消受美人心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "麝月揽晴雯同上。"
        },
        {
          "character": "晴雯",
          "type": "二黄慢板",
          "text": "昨夜里西北风颠狂一阵， 吹得我神颠倒心冷如冰。 恼风姨忒无情把人蹂躏， 岂不惜薄命女孤苦伶仃。 眼生花心如醉身立不稳， 病恹恹魂渺渺寒梦沉沉。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "姐姐，你这样的泪眼愁眉，到底是什么病啊？"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "妹妹我头昏脑晕，骨软心寒，难受得紧！"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "现有西洋头痛膏在此，待我与你贴上如何？"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "有劳妹妹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月为晴雯贴膏。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "姐姐，可怜你病的乱头蓬发，似鬼一般，如今贴了这对金钱膏倒觉得俏皮不少。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "嗳，我病到这个样儿，你还拿我耍笑么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯泣。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "姐姐休得如此，这是妹妹的不是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月赔礼。贾宝玉提笼急上。"
        },
        {
          "character": "贾宝玉",
          "type": "二黄摇板",
          "text": "适才筵前太不慎， 单单烧坏雀衣襟。 乘兴而来扫兴归， 衣破怎见老夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉跺脚。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "这叫我怎样才好哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉抬头看。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "来此已是晴雯卧室。她昨夜冒了风寒，不知好了无有？待我进去看看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉进门，晴雯、麝月同迎。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐今日病体如何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月代答。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "比昨夜又加重啦。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "嗳，这才是祸不单行。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "二爷，还有什么意外之事？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐哪里知道。我今晨到舅太爷家拜寿，老太太怕我受冷，给我这件雀毛金裘， 临行之时，是再四地嘱咐，叫我加意小心。哪知我一时大意，将毛裘烧坏， 四处寻人织补，都不能担此重任。姐姐你想，倘被老太太晓得，教我怎样回答 呢！"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "是怎样宝贵的东西，待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉脱裘，晴雯看，笑。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "原来是孔雀金线织成的，照它这样线纹织补，又有什么为难！"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "我早已知道，晴雯姐姐一看，就会织补。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯索针，贾宝玉阻止。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "这个如何使得，姐姐的身体要紧。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "嗳，为了你的事，就是拼死也要去做的。 麝月妹妹，你把针线拿来便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月取针线递晴雯。晴雯倚榻揉眼，贾宝玉执烛旁立。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "这又是我害了姐姐。"
        },
        {
          "character": "晴雯",
          "type": "二黄原板",
          "text": "猛抬头不觉得眼花缭乱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯揉眼。"
        },
        {
          "character": "晴雯",
          "type": "stage",
          "text": "晴雯　　　（）　　　　　　织织手为什么骨软如绵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯身飘。"
        },
        {
          "character": "晴雯",
          "type": "二黄原板",
          "text": "莫奈何强挣扎穿针引线，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯补衣。"
        },
        {
          "character": "晴雯",
          "type": "二黄原板",
          "text": "这都是补我的前世孽缘。 梳翠羽管教它光生正面， 绾金线好待我浸织不偏。 执并剪分清了经纬不乱， 度花针仔细把里面来缠。 撑竹弓补花样光彩燦燦， 用熨斗熨新纹线绣斑斓。 一行行一点点花遭泪溅， 一丝丝一缕缕线把愁牵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯晕倒。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐，你太劳神了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉倒茶。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "吃一口热茶，休息一会吧。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "夜静更深，你还是去睡吧！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐在此带病补裘，教我怎能去睡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯咳嗽。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "待我来与你捶背。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯推。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你真淘气哟！"
        },
        {
          "character": "晴雯",
          "type": "二黄原板",
          "text": "见此情不由我心中暗叹， 尊一声二爷听我言： 我今补裘你莫管， 夜深何必来胡缠。 倘若闲人来看见， 他必说晴雯长、晴雯短、情长情短、暗地里有了牵连。 柔声软语低声劝，"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "二爷呀！"
        },
        {
          "character": "晴雯",
          "type": "二黄散板",
          "text": "你快些去睡奴心安。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "二爷，你快些睡去，待我静心补完也就安睡了。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "看你这样劳神，叫我哪里放心得下。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "啊，二爷平常说的是怜，讲的是爱。到了今日，我的一句话儿都不肯听从，还 说什么怜我、爱我！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯泣。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "哎呀，她倒哭起来了，待我藏躲起来。姐姐不必烦恼，我去睡就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉躲入帐后。晴雯拭泪。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "麝妹，你看他去睡了无有？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月看。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "真去睡啦。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "请你与我牵起线来！"
        },
        {
          "character": "晴雯",
          "type": "二黄散板",
          "text": "长夜灯昏风似剪， 强打精神把针拈。 补裘了却心头愿， 不觉得心中似油煎。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯吐血，晕倒。麝月急扶晴雯，惊。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "姐姐！哎呀，怎么吐出鲜血来啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉急上。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐是怎么样了？"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "都是你叫她补裘，现在她口吐鲜血，人已经晕了过去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉扶晴雯，呼唤。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐醒来，姐姐醒来！"
        },
        {
          "character": "晴雯",
          "type": "二黄导板",
          "text": "霎时间气上涌神魂飘散，"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月学贾宝玉。"
        },
        {
          "character": "麝月",
          "type": "白",
          "text": "好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麝月笑。晴雯醒，见贾宝玉站在前面，楞。"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "又只见冤孽种站立面前。"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "你又来了！"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "可怜我负韶华心高气短， 可怜我如飞絮傍水和烟。 可怜我十五载春愁秋怨， 可怜我一夜夜骨碎心寒。 猛然见旧衣襟血花点点，"
        },
        {
          "character": "晴雯",
          "type": "白",
          "text": "我的天哪！"
        },
        {
          "character": "晴雯",
          "type": "二黄摇板",
          "text": "怕只怕衣能补人寿难延。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐，我们扶你养息去吧。"
        },
        {
          "character": "晴雯",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}