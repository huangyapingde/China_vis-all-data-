          "text": "自古道：父职子袭。况州牧乃是朝廷特简之职，备焉能接领？"
        },
        {
          "character": "陶谦",
          "type": "白",
          "text": "只要使君应许，我陶谦自当表奏朝廷。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "此事碍难遵命。"
