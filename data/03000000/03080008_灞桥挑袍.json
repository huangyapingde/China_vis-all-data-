{
  "script_id": "03080008",
  "title": "灞桥挑袍",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "程昱",
      "hangdang": "老生"
    }
  ],
  "plot": "关羽得知刘备去向后，走辞曹操，曹操避而不见。关羽乃挂印封金，留柬告辞，保甘、糜二夫人出许都。曹\n操率众将赶至灞陵桥送行，关羽横刀立马以待。曹操赠锦袍，关羽恐中计，于马上以刀挑袍，扬长而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四马童、大马童引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "身在曹营心在汉，思念桃园泪涟涟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某、汉寿亭侯关。昨闻大哥现在河北袁绍军中，是我挂印封金，去往曹营走辞。 可恨奸曹，将免见牌高挂辕门，不容某相见。某特修书一封，不免遣人送至 曹营，就此保定二位皇嫂，闯出许昌便了。 来！"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这有书信一封，送至曹丞相营中，不得有误！"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童甲下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小校！"
        },
        {
          "character": "三马童",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "车辆可曾齐备？"
        },
        {
          "character": "三马童",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有请二位皇嫂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同上。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同念",
          "text": "思想皇叔泪珠抛，终日如同坐监牢。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二叔唤我等何事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小弟两次去见曹操，无奈他高挂免见牌，不容我见。是弟封金挂印，修书一封， 送往曹营，意欲不辞而别，特请二嫂登车。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "倘若途中有人拦阻，如何是好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二位皇嫂但放宽心。只有小弟这青龙刀，管叫他难逃公道！"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "全凭二叔。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "众小校，趱行者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二车夫同暗上。"
        },
        {
          "character": "三马童",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "守城官上。"
        },
        {
          "character": "守城官",
          "type": "念",
          "text": "奉了丞相命，把守许昌门。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "下官、许昌守城官是也。奉了丞相将令把守城门，就此上关去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下场门设城。守城官上城。〖风入松〗。四马童、甘夫人、糜夫人、二车夫同上，大马童引关羽同上。"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "呔，开关！"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "何人叫关？"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "关将军保定二位皇嫂过关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守城官下城。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "参见二将军！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "二将军今欲何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "出关另有公干。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "拿来！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "要什么？"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "丞相的令箭。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "无有。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "公文？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "也无有。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "一无令箭，二无公文，想要出关，万万不能！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊！你敢拦阻某的去路？休走看剑！"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "哎！慢着慢着！放您出去不就结了吗！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哼！谅尔也不敢。 小校，催车！"
        },
        {
          "character": "四马童",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四马童、甘夫人、糜夫人、二车夫、大马童、关羽同下。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "哎呦我的妈呀！可吓着了我啦！不免报与丞相知道便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守城官下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖快长锤〗。四红龙套、乐进、于禁、夏侯惇、许褚、曹仁、曹洪、张辽、徐晃、郭嘉、程昱引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "燮理阴阳，统雄兵，坐镇许昌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "今有关将军书信一封，丞相请看。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌呈书，曹操看书。〖牌子〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唔呼呀，关羽封金挂印，去心已定，真乃义人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守城官上。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "启丞相：今有关将军保定二位夫人，怒气不息，闯出城去，小人等拦挡不住， 特来禀报丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "与尔无干，再探！"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守城官下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唉！不料此人竟自去了！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "啊丞相，看关羽趾高气扬，性情狂妄，不辞丞相，竟自修书前来，真乃胆大狂 妄！丞相何不将他赶回杀之？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那关羽英雄出众，仗义轻财，不忘故主，吾甚敬之爱之。 张辽听令！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你速速赶去，见了关羽，叫他少待一时，老夫还要亲自送他一程，以表旧日 之情。快去快去！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位将军！"
        },
        {
          "character": "乐进、于禁、夏侯惇、许褚、曹仁、曹洪、徐晃",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "带了美酒、锦袍、黄金千两，随向老夫追赶关羽去者！"
        },
        {
          "character": "乐进、于禁、夏侯惇、许褚、曹仁、曹洪、徐晃",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乐进、于禁。夏侯惇、许褚、曹仁、曹洪、徐晃、曹操同上马。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "适才间众军校报连番， 许昌城走了关美髯。 人来带马速追赶， 见了关羽说根源。"
        },
        {
          "character": "曹操",
          "type": "四红龙套、乐进、于禁。夏侯惇、许褚、曹仁、曹洪、徐晃、曹操同下。",
          "text": ""
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "关羽如此的不辞而别，丞相还要与他送行；我有意在酒内暗下毒药，将关羽害 死，以除后患。你意如何？"
        },
        {
          "character": "郭嘉",
          "type": "白",
          "text": "此计甚好。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "照计而行便了。"
        },
        {
          "character": "郭嘉",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱、郭嘉同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "关羽",
          "type": "内西皮导板",
          "text": "写柬辞曹出许昌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、甘夫人、糜夫人、二车夫、大马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "挂印信、封黄金、来去明白、冠冕堂皇。 曹孟德他待我恩深义广， 暗用那牢笼计打动我关云长。 他爱我是一个英雄能将， 我看他到如今枉费心肠。 此一番到河北去寻兄长， 青龙刀赤兔马保定皇娘。 叫人来你与爷催车仗，"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "见一人骑战马急走慌忙。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住！远远望见后面曹兵赶来。 小校！"
        },
        {
          "character": "四马童",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "保护二位主母车辆，过得桥去，只管往大路上紧行，我等随后！"
        },
        {
          "character": "四马童",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、甘夫人、糜夫人、二车夫同下。大马童拉马，关羽上桥。张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "二将军请了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "原来是文远贤弟。你此番前来，莫非是丞相要你追关某回转不成？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "非也！丞相言道：请二将军少待片时，丞相要亲自送二将军一程。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "纵然丞相带来铁甲雄兵，关某也要决一死战！"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "张辽把话对我讲， 倒叫关某暗思量。 叫人来快把长桥上， 等候曹军作商量。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "将军请勿多疑，丞相来也！"
        },
        {
          "character": "曹操",
          "type": "内西皮导板",
          "text": "人马纷纷出城濠！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、乐进、于禁、夏侯惇、许褚、曹仁、曹洪、徐晃、郭嘉、程昱、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "不料关羽竟脱逃。 我念他英雄盖世武艺好， 义气凌云贯九霄。 在许昌我与他相交好， 赠他的上马金、下马银、美女、战马和锦袍。 都只为刘备投了贼袁绍， 他不忘桃园故旧交。 不远千里把兄找， 可算得世间一英豪。 人来与爷前引道， 见一人勒马立长桥。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军，你为何去心忒急？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相容禀：某本解良一武夫，自幼投侍刘皇叔，桃园结义，誓同生死，皇天后 土，共鉴此衷。前在下邳，曾约三事，均蒙丞相恩准。昨日闻得故主刘玄德现 在河北袁绍军中，是某一闻此言，寸心如割，追念前盟，恨不得插翅飞去。有 道是：大丈夫义不负心，忠不顾死。新恩虽厚，旧义难忘。倘有未尽之恩，容 俟异日图报。昨日封金挂印，缴还丞相，还望丞相无忘昔日之言为幸也！"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "勒马提刀把话讲， 尊一声丞相听端详： 自从下邳来归降， 盟丞相带我见君王。 官封我汉寿亭侯皇恩浩荡， 蒙丞相赐我锦袍、战马、美女、琼浆。 白马坡前无能将， 某也曾诛文丑斩却颜良。 非是我关某忒狂妄， 桃园恩情时时挂在心肠。 望丞相开恩将某放， 知恩报德不敢忘。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "听罢言来心欢畅， 忠义英雄世无双。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫欲与将军朝夕相聚，共扶汉室；不料将军去心已定，老夫亦不敢强留。现 备黄金千两，与将军以作路途之费。 来！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将黄金献上！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且慢，久蒙丞相厚恩，感激不尽。某尚有川资，就将黄金分赏丞相之将士可也。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军真妙人也！既不收此黄金，现有锦袍一袭，聊以作别，望将军收纳！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "人言将军义气高， 千秋万古美名标。 千两黄金他不要， 轻财仗义大英豪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "人来看过一斗酒， 双手送与二君侯。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "丞相赐酒当叨扰，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱斟酒，大马童用青龙刀接酒，关羽执酒杯看。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "莫非酒内设笼牢？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住！某在曹营，屡建奇功，全仗某这把青龙刀，丞相恩赐美酒，不免祭了俺 的刀吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽将酒洒刀上。火彩。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "青龙刀头火光冒， 不由关某怒冲霄。 曹操不该生计巧， 要害某家赴阴曹。 任你奸来任你巧， 谅尔难逃青龙刀！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "何人设此牢笼套？ 回营查明定不饶！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军，既是黄金不收，现有锦袍一件，赠与二将军以作纪念。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "多谢了！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "丞相待某恩谊好， 黄金不受赐锦袍。 扳鞍下马把话表， 曹营中将士杀气高。 李典、乐进把驾保， 又有那许褚和张辽。 曹孟德行事多奸巧， 恐怕中了计笼牢。 手执着青龙刀把袍挑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽挑袍，下桥。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "催马加鞭下长桥。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "曹丞相，某在营中，多有厚待，上马献金，下马献银，三日一小宴，五日一大 宴，赤兔马，大红袍，足见多情。异日相逢，定当厚报，关某去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、大马童同下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "一见关羽他去了， 好叫老夫心内焦。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "关羽已去，老夫少却一员战将，真真可惜。 来，带马回营！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
