{
  "script_id": "03065001",
  "title": "绝粮返境",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "马腾",
      "hangdang": "生"
    },
    {
      "name": "韩遂",
      "hangdang": "生"
    }
  ],
  "plot": "李傕、郭汜犯长安，掌朝政；西凉太守马腾、并州刺史韩遂引兵勤王，杀奔长安。李傕、郭汜闭关不战，并\n斩与马腾、韩遂约为内应之马宇等三家，号令辕门。马腾、韩遂军粮尽，援粮又被劫于陈仓，因拔寨回军。\n李傕、郭汜令张济、樊稠追杀，西凉军大败回境。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马超、庞德同上，双起霸。"
        },
        {
          "character": "马超",
          "type": "念",
          "text": "威镇西凉胆气高，"
        },
        {
          "character": "庞德",
          "type": "念",
          "text": "白马银枪逞英豪。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "将军请了！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "今日父帅升帐，你我两厢伺候！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四西凉兵引马腾、韩遂同上，同归帐，同坐。"
        },
        {
          "character": "马超、庞德",
          "type": "同白",
          "text": "参见（父帅）（元帅）！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "少礼。两厢伺候！"
        },
        {
          "character": "马超、庞德",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "马腾",
          "type": "念",
          "text": "指望靖难力勤王，数万雄师离西凉。"
        },
        {
          "character": "韩遂",
          "type": "念",
          "text": "贼兵据守高山上，大军不利内应亡。"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "累次攻战师无向， 堪恨空劳枉逞强！ 此际心中怀惆怅， 再想良谋保朝堂。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "贤弟，你我自起勤王之兵，屯于山口，结内应于三家，统大兵于外镇。不想机 关泄露，三户被诛。今有小校来报，那李傕、郭汜二贼，反将三人首级，高悬 营前，以壮其威。本欲率兵进攻，怎奈军粮不敷，好生愁闷人也！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "吾已遣将催粮去了，不日即到，以应军用。我与仁兄，分兵两路，夺入山谷， 过了此川，李、郭二贼，不难擒也。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "粮饷被贼抢，敌势太猖狂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子进门。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报子告进！启二位主帅：并州解来军粮，行至陈仓道口，尽被敌军抢去，奔入 深谷去了。"
        },
        {
          "character": "马腾、韩遂",
          "type": "同白",
          "text": "知道了。再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "哎呀，敌人久老吾师，又将军粮劫去，事在燃眉，须当早作计较。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "为今之计，不如暂且退兵。待等秋凉，再起兵讨之，未为晚也。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "此言甚合吾意。可传令诸将，预备今夜拔营。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "说得有理。此皆天数当然，等待养成锐气，再整军马，共灭叛逆便了。 众将官，就此拔营，回转西凉去者！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二纛旗同上，众人同上马。"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "秉正丹心除逆党，"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "怎奈他兵暗隐藏！"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "免战牌高挂营门上，"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "空劳我军受风霜。"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "粮饷不济收兵往，"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "再整雄师灭强梁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、四大铠、张济、樊稠同上。"
        },
        {
          "character": "张济",
          "type": "唱",
          "text": "运筹帷幄意精详，"
        },
        {
          "character": "樊稠",
          "type": "唱",
          "text": "樊笼困鸟怎翱翔。"
        },
        {
          "character": "张济",
          "type": "白",
          "text": "贤弟，那马腾、韩遂，必因军粮不接，夜间弃营遁去。俺与将军兵分两路，打 从山谷绕出，以劫其军。两下相继而战，料马腾、韩遂，难出我计矣！"
        },
        {
          "character": "樊稠",
          "type": "白",
          "text": "兵贵神速。 众将官，就此抄路截杀者！"
        },
        {
          "character": "四军士、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "张济",
          "type": "唱",
          "text": "分路剿杀休轻放，"
        },
        {
          "character": "樊稠",
          "type": "唱",
          "text": "整顿威风战西羌。"
        },
        {
          "character": "张济",
          "type": "唱",
          "text": "莫教遁去留余障！"
        },
        {
          "character": "樊稠",
          "type": "唱",
          "text": "兵速如风声势扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四西凉兵、马腾、韩遂同上，二纛旗随上。"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "各整行装收兵将，"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "衔枚息鼓避锋芒。"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "众将官，前面已近大山口。急急趱行，恐有伏兵，截杀不便！"
        },
        {
          "character": "四西凉兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "四军士、四大铠",
          "type": "内同白",
          "text": "杀！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "呀，你听喊杀之声渐近。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "吾已令庞德、马超断后。我与贤弟前行便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、四大铠引张济、樊稠同上，会阵。四军士、四大铠、樊稠、四西凉兵、韩遂自两边分下。"
        },
        {
          "character": "张济",
          "type": "白",
          "text": "马腾哪里走！快快住马，与你比试三合！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "逆贼，你不思奋力王家，反助贼为虐；俺奉天讨逆，还不下马受缚！"
        },
        {
          "character": "张济",
          "type": "白",
          "text": "一派胡言，放马过来！ （马腾、张济同起打。马腾下，张济追下。韩遂上，樊稠追上，打韩遂败下，樊稠追下。马腾上，张济追上， 马超上，接战，马腾下。马超打张济败下，马超追下。樊稠追韩遂同上，庞德上，接战，韩遂下。庞德打 四大铠同上，围战。四西凉兵、马超、庞德同上，救出马腾、韩遂，同下。）"
        },
        {
          "character": "樊稠下，庞德追下。四军士、四大铠、四西凉兵同上，攢下。张济、樊稠追马腾、韩遂同上，打，四军士、张济、樊稠",
          "type": "同白",
          "text": "马腾、韩遂已败，穷寇莫追。就此回军！"
        },
        {
          "character": "四军士、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "张济",
          "type": "唱",
          "text": "今番对垒军威壮， 一战成功败西凉。"
        },
        {
          "character": "樊稠",
          "type": "唱",
          "text": "得胜回军凯歌唱， 英名大振保边疆。"
        },
        {
          "character": "张济、樊稠",
          "type": "同白",
          "text": "众将官，收兵者！"
        },
        {
          "character": "四军士、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}