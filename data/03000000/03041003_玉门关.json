{
  "script_id": "03041003",
  "title": "玉门关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "班超",
      "hangdang": "小生"
    },
    {
      "name": "鄯善王",
      "hangdang": "老生"
    },
    {
      "name": "匈奴王",
      "hangdang": "净"
    }
  ],
  "plot": "汉朝，班超出使鄯善国，驻玉门关。匈奴威胁鄯善叛汉，并于深夜刺班超。为班超识破，计斩匈奴王，鄯善\n仍附汉朝。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郭熙上，起霸。"
        },
        {
          "character": "郭熙",
          "type": "念",
          "text": "威风凛凛绕将台，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李义上，起霸。"
        },
        {
          "character": "李义",
          "type": "念",
          "text": "儿郎三军闹垓垓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲍勇上，起霸。"
        },
        {
          "character": "鲍勇",
          "type": "念",
          "text": "统领人马征北塞，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "任尚上，起霸。"
        },
        {
          "character": "任尚",
          "type": "念",
          "text": "方显男儿将英才。"
        },
        {
          "character": "郭熙、李义、鲍勇、任尚",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "郭熙",
          "type": "白",
          "text": "郭熙。"
        },
        {
          "character": "李义",
          "type": "白",
          "text": "李义。"
        },
        {
          "character": "鲍勇",
          "type": "白",
          "text": "鲍勇。"
        },
        {
          "character": "任尚",
          "type": "白",
          "text": "任尚。"
        },
        {
          "character": "郭熙",
          "type": "白",
          "text": "列位将军请了！"
        },
        {
          "character": "鲍勇、李义、任尚",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "郭熙",
          "type": "白",
          "text": "我等随定班司马征战北国。今日起兵，一同在此伺候。"
        },
        {
          "character": "鲍勇、李义、任尚",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、大纛引班超同上。"
        },
        {
          "character": "班超",
          "type": "引子",
          "text": "志气凌云，玉门关，寻取功名！"
        },
        {
          "character": "郭熙、李义、鲍勇、任尚",
          "type": "同白",
          "text": "参见司马！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "郭熙、李义、鲍勇、任尚",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "列位将军，想俺班超，有何德能，蒙大将军保荐，迎接我等进关，镇守西凉一 带等处，顺说鄯善国归降。此番前去，全仗列位将军之力！"
        },
        {
          "character": "郭熙、李义、鲍勇、任尚",
          "type": "同白",
          "text": "司马威名，去往北国，何愁那厮不降？"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "只要列位将军并力同心，何愁他国不降。今乃黄道吉日，吩咐人马趱行！"
        },
        {
          "character": "郭熙、李义、鲍勇、任尚",
          "type": "同白",
          "text": "得令。 众将官！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "郭熙、李义、鲍勇、任尚",
          "type": "同白",
          "text": "人马趱行！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": "班超",
          "type": "西皮导板",
          "text": "离长安上坐骑暗暗思想，"
        },
        {
          "character": "班超",
          "type": "西皮慢板",
          "text": "叹不尽功名事古今贤良。 奉王命镇西凉统领兵将， 要催那众蛮王俱归汉邦。 玉门关虽然是黄沙鼓浪， 却也有渔樵人放牛牧羊。 看将来西番地终非草莽， 但愿得顺说那鄯善归降。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四番将引匈奴王同上。"
        },
        {
          "character": "匈奴王",
          "type": "念",
          "text": "长就黑脸黑发，生成巨齿獠牙。每日操练人马，要夺汉室邦家。"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "某、匈奴王是也。威镇北国，自立为王。帐下蛮兵数万，战将千员，意欲夺取 汉室江山。适才闻报，今有班超等三十六人，统领人马，已出玉门关。不知为 了何事。不免去往鄯善国，一问老大王便知明白。 嘚，众蛮兵！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "人马往鄯善国去者！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引鄯善王同上。"
        },
        {
          "character": "鄯善王",
          "type": "引子",
          "text": "执掌番邦，领羌兵，威镇西凉。"
        },
        {
          "character": "鄯善王",
          "type": "念",
          "text": "光武重兴闭玉门，西羌各国我为尊。匈奴联合非吾愿，愿息干戈享太平。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "孤、鄯善国王安广。自从光武重兴，深闭玉门，两不相犯。今闻大汉王命班超 来到我国，不日即到。也曾命人打探，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀老大王：班超人马已到。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！有请班将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。四龙套、四上手、郭熙、鲍勇、李义、任尚、大纛引班超同上。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "啊老大王！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "啊司马！请！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "不知司马驾到，有失远迎，望乞恕罪！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "俺奉天子之命，特来安抚西羌。请贤君自量！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "自从大汉重兴，深闭玉门，两无相犯。司马此来，所为何事？"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "天国不久就要扫尽北国。先命我等前来晓谕贤君，及早进贡天朝，生灵免受涂 炭。请自参详！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "孤王本欲归顺天朝，怎奈匈奴王不肯。司马请在馆驿安歇，待孤请他到来，一 同商议归顺便了。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "如此告辞了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "班超、大纛、郭熙、鲍勇、李义、任尚、四上手、四龙套同下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启大王：匈奴王到。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。四下手引匈奴王同上。"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "啊老大王！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "大王请！"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "告坐。请问老大王，那班超等来到北国，为了何事？"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "前来安抚西羌，命我等归顺天朝。"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "这厮往哪里去了？"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "现在馆驿安歇，等候降表。"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "待某前去将他杀死，以除后患。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "啊大王，想那班超同来之将，俱是气宇轩昂，必有谋略。大王不可前去！"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "休长他人志气，灭却自己威风！ 众蛮兵！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "匈奴王",
          "type": "白",
          "text": "人马悄悄去往馆驿，刺杀班超去者！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、匈奴王同下。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "看匈奴王此去，定然有失。 羌兵们！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "带马接应去者！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄯善王、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、郭熙、鲍勇、李义、任尚、大纛引班超同上。"
        },
        {
          "character": "班超",
          "type": "念",
          "text": "投笔从戎羡虎头，庭训谈笑觅封侯。玉门关外三千里，图进功名冠九州。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "列位将军请坐！"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "告坐！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "列位将军，我等奉命来到鄯善国，且喜国王见信，情愿进贡归降，叫我等在这 馆驿安歇。为何供应全无？"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "老大王既言归降，何愁供应？桌上有宴，大家同饮。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "如此大家同饮！"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。〖起初更鼓〗。郭熙、鲍勇、李义、任尚同睡。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "啊列位将军！俱已睡着了！"
        },
        {
          "character": "班超",
          "type": "二黄慢板",
          "text": "听树梢风悠悠人烟肃静， 对此景不由人诸事在心。 受皇恩出玉门离乡别井， 只见那天边月三星照临。 汉高皇坐江山全凭韩信， 吕太后掌朝纲害却功臣， 听谗言使奸计忠良丧命， 只有那张子房告职归林。 数百年害平帝王莽乱政， 天不绝汉江山光武重兴。 云台观剐王莽奸人丧命， 俺班超必须要报效朝廷。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "且住！俺今在此自叹，倘被贼兵暗算，如何是好？呃！大丈夫行事，何惧小谋？ 不免打睡片时，到了天明，再作道理！"
        },
        {
          "character": "班超",
          "type": "唱",
          "text": "到如今心有事神魂不定， 怀抱剑无良策且待天明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、匈奴王同上，过场，同下。四文堂、鄯善王同上。"
        },
        {
          "character": "鄯善王",
          "type": "唱",
          "text": "班司马虽年幼英雄气象， 怕的是匈奴王必遭祸殃。"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "孤、安广。只为匈奴王领兵去往馆驿行刺班超，恐他难以成功，为此带领羌兵 暗地接应。 羌兵们！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "鄯善王",
          "type": "白",
          "text": "就此赶上前去！"
        },
        {
          "character": "鄯善王",
          "type": "唱",
          "text": "众儿郎且谨慎休要卤莽， 必须要听消息紧随孤王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、鄯善王同下。虎形上。郭熙、鲍勇、李义、任尚同醒，同惊。"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "啊！哎呀！司马醒来！"
        },
        {
          "character": "班超",
          "type": "唱",
          "text": "睡梦间只听得有人唤醒，"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "司马醒来！"
        },
        {
          "character": "班超",
          "type": "唱",
          "text": "莫不是那番奴兵将夜行？"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "列位将军，为何这等惊慌？"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "我等在此打睡，忽然有猛虎出现，将我等惊醒。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "虎在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形下。郭熙、鲍勇、李义、任尚同望。"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "啊，猛虎不见了。"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "这又奇了。啊列位将军！"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "司马！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "想那猛虎出没，定有贼人暗算。有道是：不入虎穴，焉得虎子？我等在馆外埋 伏，若有动静，杀他个片甲不存！"
        },
        {
          "character": "郭熙、鲍勇、李义、任尚",
          "type": "同白",
          "text": "言之有理。大家埋伏去者！"
        },
        {
          "character": "班超",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "班超",
          "type": "唱",
