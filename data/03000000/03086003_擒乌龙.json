{
  "script_id": "03086003",
  "title": "擒乌龙",
  "alias": [
    "闯唐营"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "单雄信",
      "hangdang": "净"
    }
  ],
  "plot": "李世民攻洛阳，洛阳王王世充累败，驸马单雄信遣子单金安往红桃山搬兵，途遇唐营埋伏，被杀。单雄信归\n告公主，公主自刎。单雄信闯唐营报仇，被尉迟恭擒获。李世民劝降，不从，绑赴法场，徐勣、程咬金等请\n往法场生祭。",
  "notes": "此剧下接《锁五龙》场。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、王世充同上。"
        },
        {
          "character": "王世充",
          "type": "西皮散板",
          "text": "可恨唐童行毒手， 派人刺死刘武周。 只恐这洛阳难保守， 不由心内暗躇踌。 将身坐在宝帐口， 等候诸侯把计筹。"
        },
        {
          "character": "王世充",
          "type": "白",
          "text": "孤，王世充。可恨唐童攻打洛阳，是孤独力难支，约请窦建德、孟海公、朱灿、 高谈圣到此相助，不料都打了败仗。今又有琉球国鳌鱼大太子带兵前来助战， 但不知胜负如何？ 来，伺候了！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "窦建德、孟海公、朱灿、高谈圣",
          "type": "内同白",
          "text": "众诸侯到！"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "众位诸侯到。"
        },
        {
          "character": "王世充",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦建德、孟海公、朱灿、高谈圣同上。"
        },
        {
          "character": "窦建德、孟海公、朱灿、高谈圣",
          "type": "同白",
          "text": "盟主！"
        },
        {
          "character": "王世充",
          "type": "白",
          "text": "列位王兄！请坐！"
        },
        {
          "character": "窦建德、孟海公、朱灿、高谈圣",
          "type": "同白",
          "text": "谢坐！啊盟主，我等自到此出兵以来，屡次损兵折将，不能取胜，如何是好？"
        },
        {
          "character": "王世充",
          "type": "白",
          "text": "列位王兄不必忧心。今有琉球国鳌鱼太子，前来助战，他倒有万夫不当之勇。 孤已派驸马单雄信陪同鳌鱼太子到唐营讨战去了。"
        },
        {
          "character": "窦建德",
          "type": "白",
          "text": "虽然鳌鱼太子到此，只是唐室将官一个个智勇双全，只怕鳌鱼太子也难以取胜。"
        },
        {
          "character": "王世充",
          "type": "白",
          "text": "王兄啊！"
        },
        {
          "character": "王世充",
          "type": "唱",
          "text": "王兄不必眉头皱， 孤王言来听根由： 鳌鱼太子世少有， 必然得胜可无忧。 坐在宝帐来等候，"
        },
        {
          "character": "单雄信",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、单雄信同上。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "鳌鱼太子丧荒丘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信下马，进门。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "列位王侯，大事不好了！"
        },
        {
          "character": "王世充、窦建德、孟海公、朱灿、高谈圣",
          "type": "同白",
          "text": "何事惊慌？"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "那鳌鱼太子被唐将暗算，命丧阵前！"
        },
        {
          "character": "王世充",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王世充",
          "type": "唱",
          "text": "鳌鱼太子遭毒手， 倒叫孤王心内忧。 倘若洛阳难保守， 从此江山一旦休。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "主公啊！主公不必心忧，臣已派单金安去往红桃山搬兵，待等红桃山人马一到， 便可无忧矣。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀驸马：单金安公子前去搬兵，在中途中了唐营埋伏，被杀身死。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "公子被杀身死。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "金安！我儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信昏倒。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "驸马醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王世充、窦建德、孟海公、朱灿、高谈圣同起围看。"
        },
        {
          "character": "单雄信",
          "type": "西皮导板",
          "text": "听说吾儿遭毒手！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信醒。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "不由英雄泪双流。 差吾儿搬兵去求救， 不想在中途路上一命休。 讲什么争论什么斗？ 连累了吾儿丧荒丘。 杀兄旧恨难忍受， 又谁知旧仇未报又结新仇。 咬牙切齿骂唐寇， 扫灭了唐营报冤仇。"
        },
        {
          "character": "王世充、窦建德、孟海公、朱灿、高谈圣",
          "type": "同白",
          "text": "驸马呀！"
        },
        {
          "character": "王世充、窦建德、孟海公、朱灿、高谈圣",
          "type": "唱",
          "text": "唐营人马多雄厚， 你好似飞蛾把火投。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "说什么飞蛾把火投？ 雄信言来听从头： 纵然死在战场口， 落一个芳名万古留。 大丈夫视死如归名不朽， 誓到唐营报冤仇。 辞别王侯就跨走兽——"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信上马。四文堂同下。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "不杀唐童誓不休！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信下。"
        },
        {
          "character": "王世充、窦建德、孟海公、朱灿、高谈圣",
          "type": "同唱",
          "text": "驸马壮志冲牛斗， 但愿他得胜早回头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、大太监引公主同上。"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "我兄王与唐营交战不利， 众诸侯连日里败阵失机。 驸马爷为国家筹思无计， 只见他这几日愁锁双眉。 派我儿红桃山搬兵前去， 倒叫我在宫中胆吊心提。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引单雄信同上。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "来在宫门下坐骑， 心中悲痛皱双眉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信下马，四文堂同下。单雄信进门。"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "见了公主忙施礼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信施礼，坐，拭泪。"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "驸马因何泪悲啼？"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "驸马进得宫来，泪流不止，不知为了何事？"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "公主，大事不好了！"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "我儿金安，在中途被唐将杀死了！"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "公主",
          "type": "西皮导板",
          "text": "听说我儿命归西！"
        },
        {
          "character": "公主",
          "type": "三叫头",
          "text": "金安！我儿！唉，儿呀……"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "怎不叫娘泪悲啼。 面对驸马开言语， 必须设法斩仇敌！"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "公主且免心惨悽， 本宫言来听端的： 楂树岗，结冤起， 箭射我胞兄命归西。 鳌鱼太子中奸计， 我儿为国也捐躯。 国仇家恨重叠起， 血海深仇怎能依？ 雄信单人又独骑， 要把唐营踏为泥！"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "虽然报仇要仔细， 单人独骑怎对敌？"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "生死二字不介意， 抛下了公主我心惨悽。"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "倘若此去失了利， 我与你九泉之下做夫妻。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "公主可称明大义， 本宫心中免怀疑。 我今进宫无别意， 要学那霸王别虞姬。"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "驸马不必多疑虑，"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "情愿一死美名题。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信拔剑掷地。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "三尺龙泉扔在地， 或死或生任凭你。"
        },
        {
          "character": "公主",
          "type": "唱",
          "text": "上前忙把剑拾起， 顷刻之间两分离。 我今一死全大义，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公主自刎。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "驸马，公主自刎啦！"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "哇呀呀……"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "霎时她鲜血满宫衣。 全节一死有志气， 巾帼真足愧须眉。 吩咐宫人盛殓起，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监、四宫女搭公主同下。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "军士们！"
        },
        {
          "character": "四文堂",
          "type": "内同白",
          "text": "有！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同上。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "抬槊带马！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "单人独骑要闯重围。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单雄信、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、秦琼、尉迟恭、黑夫人、白夫人、罗成、程咬金、徐勣、李世民同上。"
        },
        {
          "character": "李世民",
          "type": "西皮摇板",
          "text": "虽然连日打胜仗， 不知何时破洛阳。 迈步来在宝帐上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民坐。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "再与军师做商量。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "啊军师，这几日虽然杀了洛阳数将，斩了鳌鱼太子，只是那单金安一死，那单 雄信必然前来报仇。军师有何妙计，可擒那单雄信？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼作势。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "主公，常言道：兵来将挡。只是军中缺粮，必须派一能将，前去催押粮草，方 保无虑。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "既然如此，就请军师传令，派将前去催粮就是。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "秦琼听令！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "命你前去各处催押粮草，不得有误！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀二主、军师：那单雄信单人独骑杀奔我营来了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "军师，那单雄信果然报仇来了，如何是好？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "山人早已料定。 罗成听令！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "命你把守前营，与单雄信交战，只许败不许胜，将他引进营来！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "黑、白二夫人听令！"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "命你二人把守左右二营！"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑夫人、白夫人同下。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "程咬金听令！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "命你把守后营！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "尉迟恭保驾！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "得令！"
