{
  "script_id": "03096003",
  "title": "华容道",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "赤壁之战，曹操惨败。诸葛亮命关羽预伏于华容小道，擒拿曹操。曹操遇关羽，以旧情动之；关羽不忍，放\n曹操逃走。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四月华旗、四马童、关平、周仓、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "正气冲霄汉，文光射斗牛。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "头戴金冠凤翅飘，凤眼蚕眉逞英豪。忠义扶定汉室主，上阵全凭偃月刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某、汉室关。与军师赌头争印，捉拿奸曹。 周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纛旗手暗上。"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "背地里笑诸葛用兵不到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上马。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "在大营他那里藐视吾曹。 自幼儿读春秋韬略颇晓， 因不平斩熊虎怒诛势豪。 为避祸离乡井故土别了， 走樊阳才结拜生死故交。 初起手破黄巾——"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "立功不小， 酒未寒斩华雄初试宝刀。 过五关斩六将力保皇嫂， 古城边斩蔡阳匹马单刀。 将人马埋伏在——"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "华容小道， 今日里一定要捉拿奸曹。"
        },
        {
          "character": "四马童、关平、周仓",
          "type": "同白",
          "text": "来此华容小道。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大路安下烟墩，小路设下埋伏。曹操到此，禀爷知道。"
        },
        {
          "character": "四马童、关平、周仓",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "场设高台，四月华旗、四马童、关平、周仓同站一字。关羽暗下。"
        },
        {
          "character": "曹操",
          "type": "内西皮导板",
          "text": "曹孟德在马上长吁短叹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张辽、许褚、曹洪、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "手捶胸眼流泪口怨苍天。 在中原领人马八十三万， 实指望扫东吴踏平江南。 又谁知小周郎谋略广远， 还有那诸葛亮诡计多端。 黄公覆他把那苦肉计献， 蒋子翼引庞统来献连环。 我只说数九天东风少见， 又谁知诸葛亮力能回天。 烧得我众兵将头焦肉烂， 只剩下十八骑好不惨然。 正行间勒战马——"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "用目观看，"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "许褚",
          "type": "西皮散板",
          "text": "丞相发笑为哪般？"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "笑只笑周郎见识浅， 孔明袖内少机关。 此处若有人和马， 只恐性命难保全。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喊声〗。"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "一言未尽人呐喊， 旌旗招展心胆寒！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "许褚，看看是什么人的旗号？"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚看。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "乃是“关”字旗号。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待我谢天谢地。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "事到如今，还谢的什么天地？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那关云长曾许我三不死，难道今日一死也不饶么？"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "我等杀不得了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "不用你们杀了。就在此地歇息歇息。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张辽、许褚、曹洪同席地坐。"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "听说来了关美髯， 不由孟德喜心间。 走上前来把礼见， 问声君侯驾可安？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操打躬。"
        },
        {
          "character": "关平、周仓",
          "type": "同白",
          "text": "曹操到！"
        },
        {
          "character": "关羽",
          "type": "内西皮导板",
          "text": "耳旁厢又听得人嘶马闹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。关平、周仓、关羽同上高台，同亮相。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "展蚕眉睁凤眼仔细观瞧。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "君侯，别来无恙啊？哈哈哈……"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "狭路上莫不是冤家来到，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "故友相逢，怎说冤家二字？言重了哇！哈哈哈……"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "奉军令谁认你旧日故交！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "君侯哇！"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "曹孟德在马上满脸赔笑， 尊一声二君侯细听根苗： 在赤壁中火攻败兵来到， 望君侯开大恩放我回朝。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "三国中论奸雄算你曹操， 一派的假殷勤袖内藏刀。 俺今日用兵时何必发笑？ 奉军令捉拿你怎肯相饶！"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "我中了小周郎苦肉计巧， 只烧得众兵丁皮开肉焦。 只剩下十八骑败兵来到， 二君侯若不信仔细观瞧。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "查看曹操还有多少人马？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓下高台。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "你们站起来！一五，一十，一、二、三。 一十八骑残兵败将。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓上高台。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师呀，军师！你既能算，却不能料。慢说一十八骑残兵败将，就是一十八只 猛虎，何足道哉！"
        },
        {
          "character": "关羽",
          "type": "西皮快二六板",
          "text": "我看他好一似鳌鱼吞钓， 惊弓鸟插双翅也难飞逃。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "说什么我好似鳌鱼吞钓， 说什么惊弓鸟也难飞逃。 想当初待君侯恩高义好， 上马金下马银美酒红袍。 官封你汉寿亭侯爵禄不少， 你本是大义人怎忘故交？"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "你虽然待我的恩高义好， 我也曾答报了汗马功劳。 斩颜良诛文丑立功报效， 将印信悬高梁封金辞曹。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "我也曾命张辽文凭送到， 临行时我又送美酒红袍。"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "休提起送文凭令人可恼， 诛孔秀，刺孟、韩，王植被枭。 过黄河斩秦琪文凭才到， 谢丞相假人情哪在心梢！"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "在许昌曾许我云阳答报， 你本是大义人岂忘故交！"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "非是我忘却了云阳答报， 皆因你这奸曹罪恶难饶。 在许田射鹿时把君欺藐， 挟天子令诸侯势压群僚。 逼死了董贵妃其罪非小， 害董承斩马腾欲谋汉朝。 恨不得拿住你剥皮楦草。 上前来试一试偃月钢刀。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "曹孟德在马上苦苦哀告，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "君侯哇！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "你何不留美名在那万古标。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "往日杀人不眨眼， 铁打心肠软如棉。 背地只把军师怨， 左思右想难上难。 关某岂做无义汉， 宁斩我头挂高杆。 摆开一字长蛇阵， 释放曹操回中原。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "许褚，看看什么阵势？"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚看。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "此乃一字长蛇阵。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "想是关羽有意放你我逃走。走了罢！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "好个仁义关美髯， 释放曹操回中原。 苍天若助三分愿， 再领人马报仇冤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、四龙套、张辽、许褚、曹洪同下。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "曹操逃走！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "回营交令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平、周仓、关羽同下高台。"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "悔当初错许他云阳答报， 到今日顺人情又犯律条。 叫小校你与爷辕门通报， 就说是关二爷释放奸曹。 七星剑把头来割掉， 一腔热血染战袍。 盖世英雄身丧了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上马。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "汗马功劳一旦抛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}