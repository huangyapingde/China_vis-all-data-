{
  "script_id": "03108007",
  "title": "疯僧扫秦",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "疯僧",
      "hangdang": "丑"
    },
    {
      "name": "秦桧",
      "hangdang": "净"
    }
  ],
  "plot": "秦桧设计害死岳飞后，日夜惊悸不安，乃至灵隐寺斋醮，以为忏悔。寺内疯僧，与之谈话时，疯僧指桑骂槐，\n尽揭其隐，且以笤帚扫之。秦桧狼狈出寺而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "僧人上。"
        },
        {
          "character": "僧人",
          "type": "念",
          "text": "扫地恐伤蝼蚁命，爱惜飞蛾纱罩灯。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "贫僧，灵隐寺住持便是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引秦桧同上。"
        },
        {
          "character": "秦桧",
          "type": "出队子",
          "text": "三公之位， 一举登科占大魁。 只因连宵噩梦非， 使我心中多疑惧， 灵隐寺修斋，虔诚忏侮！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "小僧迎接相爷！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "罢了！经典可曾诵完？"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "诵完了。请相爷大殿拈香！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "引导！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、秦桧、僧人同走圆场，同进殿。四小僧自两边分上。泰桧拈香。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "第一柱香：愿风调雨顺，国泰民安；第二柱香：愿秦桧夫妇，百年谐老；这第 三柱香：愿……"
        },
        {
          "character": "四小僧",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四小僧同下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "哎呀佛爷呀！愿岳家父子早登仙界！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖朝天子〗。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "请相爷各处随喜！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "引导！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "僧人引秦桧同走圆场，随喜。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这是什么所在？"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "香积厨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "倒也洁净。壁上有诗，待我看来："
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "缚虎容易纵虎难，无言终日倚栏杆。男儿两眼凄惶泪，流入襟怀透胆寒。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好奇怪！这诗是我与夫人在东窗之下作的，何人书写在此？ 和尚，这诗是何人写的？"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "是个远方和尚写的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "如今可在？"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "就在寺中。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唤他前来！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "是。启相爷：此僧有些疯颠，恐言语冒犯相爷，不当稳便。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "老夫不计较于他。快快唤来！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "僧人唤。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "师兄哪里？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "谁唤我？"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "秦丞相唤你！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺忙哩！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "忙什么？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "烧火忙。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "敝下烟头子，快来！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺又忙哩！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "又忙什么？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "念佛忙。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "念的什么佛？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "我念的佛，普天之下，世人多不省的。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "你念来我听。"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "南无阿弥陀佛！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "唉，这三岁孩童都会念的。你快来！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧上。"
        },
        {
          "character": "疯僧",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "疯僧",
          "type": "唱",
          "text": "波罗蜜，波罗蜜， 一口沙糖一口蜜。 河里洗澡睡在寺里， 黄牛儿可不羞煞你！ 你好痴！ 攒金银，打首饰，与汝妻。 自己死后六块板儿一领席。 这便是，啊哈，落得的！ 南无大慈大悲、救苦救难、广大灵感观世音菩萨！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "师父！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "看你垢面疯痴，怎么了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳，师父！"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "休笑俺垢面疯痴， 恁可也参不透我的本来主意。 我笑那世人痴， 不解我的禅机。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "看你鬓发蓬松！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "休笑俺发蓬松，"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "挂着这甚么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "挂着破袋儿。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "袋内什么东西？"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "这里面倒包、包藏着天地。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "手中拿的是什么？"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "我拿着这吹火筒， 却离了这香积—— 他哪知我是地藏王化身哩！ 今日个泄天机， 故来临凡世。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "你经忏也不看些！"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "我不会看经忏， 在恁那法堂中， 我只理会打扫的勤劳， 在恁那山寺里。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "你看你今日涂，明日涂，涂出事来了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "涂出什么事来？"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "秦丞相唤你！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "可是那奸臣秦桧？"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "唔！秦丞相。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我正要去见他！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "随我来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "僧人进殿。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "疯僧唤到！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唤过来！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "是。 丞相唤你！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "僧人引疯僧同进殿。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊！我道怎么样一个疯僧，原来是个腌臜和尚。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我道怎么样一个丞相，原来是个奸臣秦桧。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！你怎么道我的名讳？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你的名，我不道，谁道？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你认得我是谁？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你么！"
        },
        {
          "character": "疯僧",
          "type": "醉东风",
          "text": "恁是个上瞒天子下欺臣。 我单道着你，你！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好个腌臜和尚！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "醉东风",
          "text": "休笑俺污秽， 我这肚皮中倒干净似你！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我来问你的缘由。"
        },
        {
          "character": "疯僧",
          "type": "醉东风",
          "text": "恁来问我的缘由， 我对伊家说破， 看他怎生得将俺来支对？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我且问你：这壁上的诗，可是你写的？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是你做的，是我写的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何“胆”字恁小？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我的胆小出了家；你的胆大，就弄出事来哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！你可知我的来意？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我怎么不知！"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "恁主意，我先知， 则恁那梦境恶， 故来到，来到俺这山寺里。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我拜当阳求忏悔。"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "恁来这里拜俺的当阳，求忏悔， 恁则待要灭罪消释！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "南无观世音菩萨！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "那里是念彼观音力！"
        },
        {
          "character": "疯僧",
          "type": "石榴花",
          "text": "太师着俺说个因依， 俺与恁便仔细话个真实。 恁可也悔当初错听恁大贤妻， 她也曾屡屡的引诱你， 你都也依随。 恁那东窗下， 不解我这西来意。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦桧惊。"
        },
        {
          "character": "疯僧",
          "type": "石榴花",
          "text": "只见他葫芦提， 无语将俺支对。 那谗言谮语， 恁便将心昧。 恁可以杀害忠良， 使万民心灰！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "恁待要结媾金邦哩， 也只是肥家； 唉！哪里肯为国！ 恁如今事要前思， 免劳、免劳后悔！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "悔什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "秦桧，你下阶来！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "看上面是什么？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是天。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "可有来！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "却不道湛湛青天不可欺！ 如今人都理会的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊哈哈哈…… 左右，与我拿下！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "恁在这里吓鬼瞒神哩， 恁做的事，事做的来藏头露尾。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你手中拿的什么东西？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是扫帚。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "要它何用？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "昔日边上扫烟尘，今日殿上扫奸臣。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔，那个呢？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是火筒。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "又要它何用？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "要它私通番邦！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "何不放下来？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "放不得。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "放下来他就要弄权哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我是君子人。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "红绣鞋",
          "text": "君子人只怕当权倚势， 俺待说着呵， 害得他一家儿恰便似烟灭灰飞！ 恁待要节外生枝， 可便落什么便宜？ 俺为甚不在恁那厨房中放， 常则在我这手中持？ 啊呀，火筒儿啊！ 这其间引狼烟倾了他的社稷！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，你平日可有功？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有功的多被你杀了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "功课。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "在袋里。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦桧向僧人。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "取来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧递。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "拿去！"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "功课有了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "僧人递秦桧。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何绉了？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "在蜡丸内取出，怎么不绉？"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "久闻丞相理乾坤，占断朝纲第一人。都领群臣朝北阙，堂中埋没老元勋。 闭门杀害忠良将，塞上欺君枉万民。贤相一心归正道，路上行人口似……"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！怎么诗不全？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "若遇施全，你就该死了！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "左右，若遇施全，与我拿下！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "还有。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "横看去。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "诗怎么横着看？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你的事怎么横行呢？"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "“久占都堂，闭塞贤路”。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唗！你敢侮弄我朝中的宰相么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "嘚，秦桧！"
        },
        {
          "character": "疯僧",
          "type": "十二月",
          "text": "卖弄恁那朝中的宰相职， 恁可以懊恼我这阇黎。 俺这里心似镜明无垢鄙， 他那里口是心非腹内虚。 休笑俺疯魔和尚会嘴， 俺可也干净似堂食。"
        },
        {
          "character": "疯僧",
          "type": "尧民歌",
          "text": "呀，这的是坐而不觉， 立而才知饥。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "讲了半日，想是他肚饥了。 和尚，赏他一分斋。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "僧人递疯僧馒头。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "相爷赏你一分斋。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我不吃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧倾斋。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "倾坏了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "再赏他一分。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "相爷又赏你一分。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我又不吃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧倾斋。"
        },
        {
          "character": "僧人",
          "type": "白",
          "text": "又倾了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！你不吃也就罢了，为何连坏了我两个？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "呔，秦桧！我坏了两个，你就发恼，你害了他三个哩！"
        },
        {
          "character": "疯僧",
          "type": "尧民歌",
          "text": "馒头白面做来的， 坏了恁那两个有谁得知？ 恁便屈杀了他三人待推着谁？ 痴也么痴， 难藏着诡计。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这是什么？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这是馒头。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这不是馒头。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "敢是馋馅？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "也不是馋馅。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "喏！"
        },
        {
          "character": "疯僧",
          "type": "尧民歌",
          "text": "这的是岳家肚皮中腌臜气！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这里不好讲话，随我到冷泉亭上。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "冷泉亭不好，倒是风波亭上好行事哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，我看你伶牙俐齿，有甚本事？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我会呼风唤雨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "风雨在天上，如何唤得来？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "唤得来还要退回去。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "如此，我要一阵大风。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有有有！ 如来佛助弟子一阵大风！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内风声〗。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大风！收了，收了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "收收收！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我要一阵大雨。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有有有！ 东海龙君助贫僧一阵大雨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内雨声〗。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大雨！收了，收了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "收收收！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！我想这风雨在天上，如何来想能骤？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "连发十二道金牌召来的，怎么不骤！"
        },
        {
          "character": "秦桧",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "疯僧",
          "type": "快活三",
          "text": "风来时，雨便起， 云过处，电光辉， 把他拿住风来握住雨， 不淋漓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内风声〗。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大风啊！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这不是风。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是朱仙镇上那些黎民的怨气！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内雨声〗。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大雨啊！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这也不是雨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "又是什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "喏！"
        },
        {
          "character": "疯僧",
          "type": "快活三",
          "text": "这的是屈杀了岳家父子天垂泪！"
        },
        {
          "character": "疯僧",
          "type": "朗天子",
          "text": "太师爷，俺与恁便说知， 说着恁那就里， 恁用的擎天手把人欺。 恁可也悔当初屈杀了他三人， 可也无着无对。 到如今后悔迟， 他在阴司下便等你， 在阎王殿前去告你。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "告我什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他告你私造下十座牢房。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "哪十座？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "雷、霆、施、号、令，星、斗、唤、文、章。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "他在哪一号？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他在章字号等你哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊呀，佛爷，佛爷呀！"
        },
        {
          "character": "疯僧",
          "type": "朗天子",
          "text": "这的是恁自造下落得这佞臣例。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，如今要免六道轮回之苦，可免得过么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你随我出了家，削了发，就可免了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我要出家，怕没有高僧剃度；况灵隐寺小，怎藏得我下？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "灵隐寺虽小，佛力最大哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "方才这八句诗如何讲？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "方才这八句诗……"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "做一个哑谜儿与恁猜。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "横头上八个字？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "横头上八个字！"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "做一张闷弓儿在恁那心上射。 有一日东窗事犯， 才知我的西来意。 那时节搥着胸，跌着脚，"
        },
        {
          "character": "疯僧",
          "type": "夹白",
          "text": "嘚，秦桧！"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "恁可也慢慢的悔！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "俺去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊呀！倒被这疯僧一番言语，说得毛骨悚然，回去与夫人商议拿他便了！ 来，打道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "疯僧一席话，使我魂魄飞！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}