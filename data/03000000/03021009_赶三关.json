{
  "script_id": "03021009",
  "title": "赶三关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "老生"
    },
    {
      "name": "代战公主",
      "hangdang": "旦"
    },
    {
      "name": "莫洪",
      "hangdang": "丑"
    },
    {
      "name": "马达",
      "hangdang": "丑"
    },
    {
      "name": "江海",
      "hangdang": "丑"
    }
  ],
  "plot": "薛平贵继位后，一日有鸿雁代王宝钏赍血书飞至。薛平贵得书，顿忆前情，乃灌醉代战公主私逃回国。代战\n公主醒而追之，连赶三关。追及，薛平贵哭诉衷曲，代战公主怜而允诺，并驻兵国境，以备接应。",
  "notes": "为全部《王宝钏》之第九折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖西皮小开门〗。四太监、大太监引薛平贵同上。"
        },
        {
          "character": "薛平贵",
          "type": "引子",
          "text": "驾坐西凉，众文武，扶保孤王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵坐。"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "离长安一十八载，思宝钏常挂心怀。恨魏虎将孤谋害，这冤仇何日解开？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "孤，薛平贵。恼恨魏虎，用酒将孤灌醉，绑在马上，放至西凉，致被公主擒住。 多蒙老王不斩，反将公主匹配。只因老王晏驾，满朝文武，扶孤登基。今当 设列早朝。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雁仙暗上，站在大边椅上。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "闪放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 闪放龙门哪！"
        },
        {
          "character": "雁仙",
          "type": "白",
          "text": "平贵无道！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启大王：空中有一大雁，口吐人言，道大王无道！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "待孤看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵离座，看。"
        },
        {
          "character": "雁仙",
          "type": "白",
          "text": "平贵无道！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "唔呼呀！看这大雁，口吐人言，道孤无道，定是不祥之兆。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "看弓弹伺候！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "自从盘古立地天， 哪有宾鸿吐人言？ 内侍看过弓和弹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵接弓。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "对准宾鸿撒了弦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵打雁，归座。雁仙掷血书，下。大太监拾血书。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启大王：大雁不见。现有血书在此。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呈上来，待孤观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵接书，看。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵昏迷。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "大王醒来！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "见血书不由人泪流满面，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "大王醒来！"
        },
        {
          "character": "薛平贵",
          "type": "三叫头",
          "text": "三姐，宝钏，妻呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "点点珠泪洒胸前。 内侍传旨把班散，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同下。薛平贵离座。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "待孤王从头仔细观。 上写宝钏修书柬： “拜上儿夫平贵男： 妻为你懒把父母见， 妻为你寒窑受熬煎。 你若念在夫妻义，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "不分昼夜返长安。 你若不念夫妻义， 稳坐西凉莫回还。 早来三天还相见， 迟来三日不团圆！” 看罢血书肝肠断，"
        },
        {
          "character": "薛平贵",
          "type": "哭头",
          "text": "王三姐！妻宝钏哪！啊、啊、啊……我的妻呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "想回长安难上难。 低下头来心暗算，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西皮行弦。薛平贵想。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "猛然一计在心间。 撩袍端带上银安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵归座。大太监暗上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "快宣公主到银安把王来参！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 代战公主上殿哪！"
        },
        {
          "character": "代战公主",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主上。"
        },
        {
          "character": "代战公主",
          "type": "西皮二六板",
          "text": "适才校场把兵演， 忽听大王把咱宣。 大摇大摆——"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "上银安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主上殿。"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "参王驾来问王安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖西皮小开门〗。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "妾妃见驾。大王千岁！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主坐。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "啊大王，将咱家宣上殿来，有何国事议论哪？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "孤王备下酒宴，与公主痛饮。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "咱家奉陪。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "夫妻对坐饮琼浆， 哪知有血书在孤的袖内藏。 虽然西凉孤执掌， 怕的是南朝动刀枪。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "代战公主",
          "type": "西皮原板",
          "text": "劝大王你且把愁眉展放， 咱家言来听端详： 哪怕那南朝兵将广， 咱一人能挡百万儿郎？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "公主虽然韬略广， 你一人怎能挡百万儿郎？"
        },
        {
          "character": "代战公主",
          "type": "西皮原板",
          "text": "内侍臣看酒大杯上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西皮过门。大太监斟酒。"
        },
        {
          "character": "代战公主",
          "type": "西皮原板",
          "text": "多饮几杯解愁肠。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "公主！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "公主进酒王心爽， 孤王言来听端详。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "大王，为何停杯不饮哪？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "非是孤王停杯不饮。孤到西凉以来，一十八载，多蒙公主照看。今日我要把敬 三大杯。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "哎哟！咱家的酒量，可比不得从前啦。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "从前能饮多少？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "从前能饮一百杯。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "如今哪，只能饮五十双杯啦。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "还是一样啊。看酒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖西皮小开门〗。代战公主饮酒醉。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "唔……"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "公主酒醉。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你也醉了！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "公主醉倒银安殿， 中了平贵巧机关。 内侍与孤把衣换，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵换衣。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "番邦令箭带身边。 内侍带过红鬃战！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "闪却公主泪如泉。 桌案现有笔和砚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵修书。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "字字行行写根源： “春夏秋冬四季天， 孤王亲自去阅边。 公主若念夫妻义， 带领人马赶三关。 公主不念夫妻义， 西凉国改做女儿川。” 内侍带马休迟慢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上马。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "公主若问？"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "公主醒来对她言：王去阅边哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "公主醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西皮过门。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "忽听内侍一声唤！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主看。"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "不见大王为哪般？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "内侍，大王上哪儿去啦？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "阅边去了。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "留下什么没有哇？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "留下书信一封。公主请看。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "待咱家看来。"
        },
        {
          "character": "代战公主",
          "type": "西皮流水板",
          "text": "“春夏秋冬四季天， 孤王亲自去阅边。 公主若念夫妻义， 带领人马赶三关。 公主不念夫妻义， 西凉国改做女儿川。” 看罢书信心暗算，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西皮行弦。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "噢，噢，是了！"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "想是私自回长安。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "内侍过来！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "吩咐马达、江海校场听点！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主、大太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同上。"
        },
        {
          "character": "马达",
          "type": "念",
          "text": "家住在北国，"
        },
        {
          "character": "江海",
          "type": "念",
          "text": "说话不利落。"
        },
        {
          "character": "马达",
          "type": "念",
          "text": "喜吃牛羊肉，"
        },
        {
          "character": "江海",
          "type": "念",
          "text": "爱骑大骆驼。"
        },
        {
          "character": "马达",
          "type": "白",
          "text": "马达。"
        },
        {
          "character": "江海",
          "type": "白",
          "text": "江海。"
        },
        {
          "character": "马达",
          "type": "白",
          "text": "请啦！"
        },
        {
          "character": "江海",
          "type": "白",
          "text": "请啦。"
        },
        {
          "character": "马达",
          "type": "白",
          "text": "公主发兵，两厢伺候！"
        },
        {
          "character": "江海",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套引代战公主同上。"
        },
        {
          "character": "代战公主",
          "type": "念",
          "text": "带领兵和将，追赶无义郎。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "马达、江海，人马可齐？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "吩咐兵发三关哪！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "兵发三关哪！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "呕！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主上马。代战公主、马达、江海、四红龙套同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小番上。"
        },
        {
          "character": "小番",
          "type": "念",
          "text": "奉了公主命，把守在头关。"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "就此上关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番上城。薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "开关！"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "哪儿去？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "奉了公主将令，出关另有公干。"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "可有令箭？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "果然是公主令箭。 来呀，把城给他举起来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番下城开关。薛平贵出关下。代战公主、马达、江海、四红龙套同上。"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "参见公主！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "罢啦。可曾看见大王过去？"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "他刚顺这儿钻过去。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "没用的东西。给我打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番下。代战公主、马达、江海、四红龙套同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小番上。"
        },
        {
          "character": "小番",
          "type": "念",
          "text": "把了头关把二关，我的孙子把三关。"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "说得有理。就此上关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番上城。薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "开关！"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "呦！又是你？ 来，把城再给他举起来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番下城开关。薛平贵过关下。代战公主、马达、江海、四红龙套同上。"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "参见公主！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "罢啦。可曾见着大王过去？"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "他又钻过去啦！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "打他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番下。代战公主、马达、江海、四红龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、莫洪同上，莫洪起霸。"
        },
        {
          "character": "莫洪",
          "type": "念",
          "text": "白盔白甲白旗号，白脸白须白眉毛。白吃白喝白挑眼，白打白闹白扯臊。 姓莫名洪字君兆，把守三关防贼盗。红日当空天不早，带过骆驼上城道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同下，莫洪上城。薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "且住！来此界牌三关，乃是我国地界。看城上好像莫老将军模样。待我冒叫一 声。 啊，莫老将军请了！"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "这是谁呀，这么提名道姓的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "先行平贵。"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "打鬼，打鬼！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "何言打鬼？"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "人都说你死在西凉啦，怎么跑到我这儿显魂来啦？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "此乃仇人咒骂于我。"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "有何为证哪？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "红鬃烈马为证。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鼓响。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "老将军，后面追兵甚紧，你我开城再叙。"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "谅你一个人，也反不了哪儿去。 来，把城给他举起来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开城。薛平贵进关。代战公主、马达、江海、四红龙套同上。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "来此界牌三关。 马达、江海！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "前去叫关！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "回来！来此乃是他国地界，说话要和气点儿！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同对莫洪。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "哎，我说老头儿！"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "老头儿？我又不玩火球儿！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "怎么啦？"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "怎么啦？问你呀！瞧你们俩人，长得这样儿！一人来高，顶着个肉球儿，上头 七八个小窟窿儿！叼着个血饼儿，一嘴碎骨头儿！人不人，鬼不鬼，也配长着 两条仙鹤腿！像你们这样的，也配跟我说话？换个好脑袋的过来！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "碰啦！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "待咱家向前。 我说城上的老将军请啦！"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "哎哟，怎么着，我的小老太太儿？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "可曾见着我国大王过去？"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "倒没看见你国大王。我国先行平贵，刚打这儿钻过去。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "你国先行，到了我国，就是我国大王。烦劳老将军，叫他城楼答话！"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "丫头哇，我把你这个黄毛丫头！我国先行平贵，在我国吃得是精精壮壮、肥肥 胖胖，到了你国一十八载，你每天跟他“朝于斯、夕于斯”，“蚕吐丝”，才 把他闹得这样面黄肌瘦，皮里抽肉。好不容易盼他回得朝来，你又赶到三关还 跟老汉我这样“巧笑倩兮，美目盼兮”。我劝你急速退兵便罢。如若不然，城 上现有钩镰枪，把你搭上城来，扒你个赤条精光！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "怎么着？"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "我看看你有几个脚趾头。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "这老东西，胡说八道。 马达、江海！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同允。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "攻城！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "呕！"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "慢着，慢着！拿您一个好人，干吗跟我嘎杂子一般见识？您将人马暂退一箭之 地。我把先行平贵叫上城来，你们俩人爱怎么唱怎么唱。您瞧好不好？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "老将军，须要言而有信！"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "岂肯失信于汝乎？"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "马达、江海，人马暂退！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "呕！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主、马达、江海、四红龙套自上场门同下。"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "先行，平贵！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "老将军，胜负如何？"
        },
        {
          "character": "莫洪",
          "type": "白",
          "text": "好嘛，你带着家眷来的？好厉害！叫你城楼答话。你去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫洪下。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "莫老将军对我言， 公主带兵到关前。 放心不下敌楼看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上城。马达、江海同暗上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "旌旗遮着半边天。 马达、江海一声唤： 快宣公主到城边，"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "王有话言。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "有请公主！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、代战公主同上。"
        },
        {
          "character": "代战公主",
          "type": "西皮流水板",
          "text": "马达、江海一声唤， 催马来到三关前。 坐在雕鞍用目看， 城楼站定无义男。 按着军令将他问： 为何私自转长安？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "公主！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "那一日驾坐银安殿， 宾鸿大雁吐人言。 手执金弓和弹打， 打下了半幅血罗衫。 打开罗衫从头看， 想起了寒窑受苦王宝钏。 非是我独自离宫院， 为的是前妻王宝钏。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "我说你张口王宝钏，闭口王宝钏，到底儿王宝钏是你什么人哪？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "她是孤的前妻呀！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "怎么着，你还有前妻哪吗？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "你可害苦了我啦！"
        },
        {
          "character": "代战公主",
          "type": "西皮导板",
          "text": "代战女坐雕鞍泪满面，"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "不由我一阵阵心内酸。 你有前妻王三姐， 早该对咱说根源。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "孤本当对你说实言， 公主不放也枉然。"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "你那里休得巧言辩， 想回长安难上难！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "一见公主变了脸， 不由孤王心内酸。 远望寒窑高声唤， 王三姐呀！ 夫妻们要相逢难上加难。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "一见大王泪满面， 倒叫咱家心不安。 低下头来心暗算， 忽然一计上心间。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "大王，并不是咱家不放你回去，皆因你国奸多忠少，咱家放心不下。这儿有金 铃鸽儿一只，你带在身旁。若有人谋害于你，你将鸽儿放回，咱家也好发兵搭 救于你。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多谢公主！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "多谢公主开恩典， 马达、江海听我言： 人马休回西凉转， 就在此地扎营盘。 交与公主鈚箭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵交箭取鸽。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "寒窑内看一看妻宝钏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。"
        },
        {
          "character": "代战公主",
          "type": "西皮快板",
          "text": "一见大王回长安， 马达、江海听我言： 人马休回西凉转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、马达、江海同下。"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "且待发兵反长安！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}