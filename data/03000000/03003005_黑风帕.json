          "character": "张兰英",
          "type": "白",
          "text": "你二人为何这等模样？"
        },
        {
          "character": "张保、达婆",
          "type": "同白",
          "text": "城下来了一个黑汉，将我二人杀得大败。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "就该使起黑风擒他。"
        },
        {
          "character": "张保、达婆",
          "type": "同白",
          "text": "他的黑风，比我二人还高三尺。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "待为娘前去会他，你二人退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张保、达婆同下。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "番儿带路上关！"
        },
        {
          "character": "张兰英",
          "type": "唱",
          "text": "番儿带路把关进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张兰英上城。"
        },
        {
          "character": "张兰英",
          "type": "唱",
          "text": "看看来的是何人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同下。高旺上。"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "战了一合又一合，"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "呃！"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "城楼上换了一个老达婆。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "唗，开关！"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "哪道而来？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "来道而来。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "哪道而去？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "去道而去。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "姓甚名谁？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "姓马名夫字钢鞭，绰号甩手甩手。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "莫非你姓高？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "达婆说话真奇巧， 怎知老夫我姓高？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "我越杀越高。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "有高必有旺，莫非你叫高旺？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "咦！"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "达婆会看麻衣相， 怎知老爷叫高旺？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "夫啊！"
        },
        {
          "character": "张兰英",
          "type": "唱",
          "text": "老爷不必心不定， 我是你妻张兰英。"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "既是我妻张兰英， 有何宝物做证凭？"
        },
        {
          "character": "张兰英",
          "type": "唱",
          "text": "用手取出黑风帕， 老爷拿去看分明。"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "一见此宝果是真， 不由高旺喜在心。 夫人你把城开定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高旺进城。"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "夫妻们相逢在牧虎城。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "适在城楼，为何不将妾身认下？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "离别日久，不敢相认。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "这也难怪。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "适才头关上有一娃娃，他是何人？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "乃是你我的儿子。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "好，叫他前来。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "是。张保哪里！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张保上。"
        },
        {
          "character": "张保",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "爹爹来了，上前见过。"
        },
        {
          "character": "张保",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "罢了。他叫什么名字？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "他叫张保。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "夫人把话讲错了， 高旺的儿子怎么叫张保？这个名儿起错了！"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "随他娘舅之姓。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "不好，我要与他改过。儿啊，往上跪。"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "张保改名高洪保， 老道腾生下一个小道腾。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "什么老道腾生一个小道腾？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "为丈夫会使黑风，你我的儿子也会使黑风，岂不是老道腾生下一个小道腾？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "取笑了。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "儿啊，拿为父钢鞭，去到松林，迎接杨姑母进关来。"
        },
        {
          "character": "张保",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张保下。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "夫人，二关之上，有一个小达婆，她是何人？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "是你我儿媳。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "是你我的什么？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "儿媳。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "你是她的什么？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "我是她的婆婆，"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "那么我哪？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "你是她的公公啊。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "嘿！哎呦！哎呦！好孱头的公公呕！"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "夫人有所不知情， 为丈夫言来听分明： 我二人关前来会阵，"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "你打了她？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "不曾。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "你骂了她？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "也不曾。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "不打不骂，你便怎样？"
        },
        {
          "character": "高旺",
          "type": "唱",
          "text": "呦呦！呦呦！哎哎哎哎哟！妈妈娘唉，你好糊塗呦！ 为丈夫年迈苍苍起了一个幼年的心。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "取笑了。待我唤她前来。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "不要唤她。"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "儿媳哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "达婆上。"
        },
        {
          "character": "达婆",
          "type": "白",
          "text": "婆婆何事？"
        },
        {
          "character": "张兰英",
          "type": "白",
          "text": "你公公来了，上前见过。"
        },
        {
          "character": "达婆",
          "type": "白",
          "text": "公公在哪里，公公在哪里？"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "哞儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "达婆下。"
        },
        {
          "character": "张保",
          "type": "内白",
          "text": "杨姑母到。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张保、杨八妹同上。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "夫人见过杨贤妹，此乃你张氏嫂嫂。后堂摆宴，与贤妹接风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}