        },
        {
          "character": "高来",
          "type": "白",
          "text": "有请爷爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高旺上。"
        },
        {
          "character": "高旺",
          "type": "白",
          "text": "高来！你爷爷此去，将家中之事，付与你一人掌管。你爷爷得胜回来，与你带 一个花丢丢的婆娘。"
        },
