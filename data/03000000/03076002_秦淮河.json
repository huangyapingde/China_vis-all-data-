{
  "script_id": "03076002",
  "title": "秦淮河",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张顺",
      "hangdang": "净"
    },
    {
      "name": "张旺",
      "hangdang": "丑"
    },
    {
      "name": "安道全",
      "hangdang": "小生"
    },
    {
      "name": "李香兰",
      "hangdang": "花旦"
    },
    {
      "name": "鸨儿",
      "hangdang": "彩旦"
    },
    {
      "name": "王八",
      "hangdang": "丑"
    }
  ],
  "plot": "宋江患瘩背，遣张顺请神医安道全。张顺过江，误饮药酒，被水寇张旺推落江心。张顺通水性，酒醒上岸。\n时安道全正在秦淮河热恋名妓李香兰，张顺往请，亦被留院。张旺杀死孙武，陡然大富，亦来秦淮河嫖妓，\n与安道全殴斗。张顺杀死张旺，复斩李香兰。安道全被迫，同上梁山。",
  "notes": "此剧第二场《劫江》系李燕生藏本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "张顺",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺上。"
        },
        {
          "character": "张顺",
          "type": "唱",
          "text": "水泊梁山义气正， 替天行道宋公明。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "俺，浪里白条张顺。只因宋大哥身患瘩背，是俺奉了先生之命，去请神医安道 全，与大哥调治病症。就此走走也！"
        },
        {
          "character": "张顺",
          "type": "唱",
          "text": "今奉将令不敢停， 急请名医到山中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张旺、孙武同上。"
        },
        {
          "character": "张旺",
          "type": "唱",
          "text": "大雪不住纷纷下，"
        },
        {
          "character": "孙武",
          "type": "唱",
          "text": "并无买卖做生涯。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "在下，劫江鬼张旺。"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "我，泥里鳅孙武。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "兄弟请啦！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "请啦！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "你我做这船上的生意，这两天儿也没有买卖，看今天满江大雪，又算吹啦！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "你别说这个，咱们这个买卖，不在一天，就在一时。咱们把船摇在江边儿上， 等着孤行客来啦，做他一号儿两号儿的，你看怎么样？"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "如此，掌稳了舵！"
        },
        {
          "character": "张旺",
          "type": "唱",
          "text": "将身来在江边下， 等候孤客把他杀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。张顺上。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "且住！天降大雪，又无船只，怎样过去？"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "打鱼哟！"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "船家，将船摆过来！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "打鱼的船，不渡人哪！"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "将我渡过河去，多把银钱与你。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "多给钱也不渡啊！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "呃！多给钱，咱们就干。您上船！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺上船。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "您瞧瞧，身上这雪都溻湿啦。您脱下来，我们给您烤干了再穿，好不好？"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "真格的，您要是有金银财宝，可拿出来，恐怕失落啦！"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "无有啊！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "没有，您背上背的是什么？"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "银子。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "还是呀！您拿下来吧，反正是您的，还能不给您吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺解银交张旺。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "反正是您的。我收起来啦。您坐着，坐着。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "您贵姓啊？"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "我姓张。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "哎哟！咱们五百年前是一家子。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "你也姓张！这位贵姓？"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "这位是孙爷。"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "好说您哪！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "真格的，您瞧这个江景儿，跟这个雪景儿，嘿，多得劲儿呀！唉，就是缺点儿 酒！"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "着哇！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "我那儿有酒哇。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "你有，还不拿出来。人家给钱哪！拿来，拿来！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "我拿去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙武取酒。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "喝着，喝着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张旺饮一杯。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "好，打搅了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺、张旺、孙武同饮酒。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "哎，怎么没有啦？哎，这里头怎么这么一点儿呀？多来点儿吧！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "这就不少啦！"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "你再去灌些酒来，多把银钱。"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "好，我再灌点儿去。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "哎，你把那好酒灌上点儿，人家多给钱！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "我知道啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙武下，拿酒上。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "喝着，喝着。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "叨扰了！"
        },
        {
          "character": "张顺",
          "type": "唱",
          "text": "大雪不分南北道， 青山绿水难画描。 此酒本是杜康造， 学一个刘伶醉酕醄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺醉。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "得！成啦。你看是刀切卷子，还是下馄饨？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "送上门来的买卖，下馄饨得啦！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "得，下馄饨吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张旺对张顺。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "起来，起来，出来凉快凉快。下去呗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺落水，下。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "成啦。怎么分哪？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "分什么呀，全是我的！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "怎么全是你的呀？咱俩人做的买卖！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "分也成，一九提。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "什么叫一九提呀！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "我要九成，你要一成。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "你要那么多，我就是这么一点儿吗？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "那么二八吧！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "什么又叫二八哪？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "我八，你二。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "你老在大头上站着。不论怎么样也得分我一半呀！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "三七！四六！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "分我一半吧！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "那都是我的啦！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "嘿！咱们俩人做的买卖，怎么能都是你一个人的哪？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "买卖是我让的，酒是我存的。不成，全是我的。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "兄弟，往后可还有哪。你这么一来，不就绝了交情了吗？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "什么交情，锅里不煮交情。银子是白的，眼珠子是黑的！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "全是你的啦？得啦，水过地皮湿，那件衣裳哪？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "衣裳是酒钱。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "嗬！您这个酒值多少钱哪？"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "没价儿！"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "怎么都是你的啦？一点儿也没我的？你瞧那边儿又来了一号儿！"
        },
        {
          "character": "孙武",
          "type": "白",
          "text": "在哪儿哪？"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "你瞧啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张旺杀死孙武，踢孙武下江，孙武下。"
        },
        {
          "character": "张旺",
          "type": "白",
          "text": "我让你不！我让你要！都是我的啦！把银子拿好啦。正是："
        },
        {
          "character": "张旺",
          "type": "念",
          "text": "鳌鱼脱却金钩钓，摇头摆尾再不来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张旺下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安道全上。"
        },
        {
          "character": "安道全",
          "type": "引子",
          "text": "流落烟花，好叫我，心乱如麻！"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "卑人，安道全。幼习岐黄，术如扁鹊，医人无数，四远皆知。是我在秦淮河下 勾栏院中，宿了妓女李香兰。我二人十分相爱。我将一份家产，尽行花费。可 恨王八鸨儿终日要钱，我是毫无打算。却好吏部王大老爷请我治病，病好之后， 许我一千两纹银。早晚下来，也免得与他们怄气。"
        },
        {
          "character": "李香兰",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "话言未了，大姐出来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安道全佯睡。李香兰上。"
        },
        {
          "character": "李香兰",
          "type": "唱",
          "text": "身落在烟花巷朝夕欢畅， 白日里陪伴客夜会新郎。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "哎，你倒是醒醒啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安道全醒。"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "大姐出来了？"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "我早就出来啦。"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "卑人有礼！"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "哎！我看你这个样儿，又可怜，又可嫌。你真是活给花钱的老爷们丢脸泄气呀！"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "你安大爷花钱买乐，怎言“丢脸泄气”？你此话不通，要吃些砂仁、豆蔻、藕 节汤，通通气才好。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "你看别人房中，划拳行令，弹唱歌舞。你瞧咱们屋里，冷清清的，慢说是个人， 就是灶王爷也都有点儿停食着凉啦！"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "怎么，灶王爷病了？待我与他开个药方。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "灶王爷病啦，开什么方儿哪？"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "天门冬、麦门冬、鲜姜三片，沏上一碗红糖水，盖上棉被，发上一身汗，也就 好了。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "我这儿没叫你背药方子。我问你，有银子，有钱，快点儿拿出来，别叫我跟着 你受热啦！"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "你又不曾吃了朱砂，说些什么傻话！"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "我问你：我妈买我为什么？"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "买你为诺。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "什么叫“诺”呀？"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "就是药啊！"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "为什么“药”哇？"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "为的是十香暖脐膏，连生种子丹，人马平安散，外有一颗抱龙丸。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "我告诉你：这是勾栏院，不是太医院，没请尊驾您哪上这儿开药方子来。"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "请我，马钱四吊八。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "门脉哪？"
        },
        {
          "character": "安道全",
          "type": "白",
          "text": "六百。概不多取。"
        },
        {
          "character": "李香兰",
          "type": "白",
          "text": "说真格的，要是有钱，早早地拿出来。要是没钱，您哪，再到别处去讨讨高招 儿去吧！"
