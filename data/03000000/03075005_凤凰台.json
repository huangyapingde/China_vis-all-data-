{
  "script_id": "03075005",
  "title": "凤凰台",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "孙策",
      "hangdang": "武生"
    },
    {
      "name": "大乔",
      "hangdang": "旦"
    }
  ],
  "plot": "孙策被刘繇所逼，携程普等投袁术。袁术轻视之。孙策愁叹。朱治献计：假名救吴景，借兵赴江东，暗图大\n业。孙策喜，留玉玺为质，引兵东去。乔玄女大乔布散家财，在凤凰台募兵防乱。孙策往借粮，与之交锋。\n大乔擒孙策委以终身。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引袁术同上。"
        },
        {
          "character": "袁术",
          "type": "引子",
          "text": "四世三公，镇东南，名高望众。"
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "一战虎牢定帝都，风云万里卷三吴。英雄事业英雄做，董卓原来不丈夫。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "某、寿春太守袁术。自虎牢关战吕布之后，退兵此地，养精蓄锐，以图霸业。 正是："
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "人事盖棺方论定，莫把成败识英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱治、吕范同上。"
        },
        {
          "character": "朱治",
          "type": "念",
          "text": "孙策今来干父蛊，"
        },
        {
          "character": "吕范",
          "type": "念",
          "text": "统军不成请长缨。"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "佐史、（朱治）（吕范）参见！"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "今有长沙太守孙坚之子孙策，带领旧将程普等前来相投，辕门求见。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "哦，孙坚之子孙策前来相投？"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "看他多大年纪？"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "不过十余岁，却是豪迈人。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "如此，传他进见。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "有请孙公子！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策上。"
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "气吐虹霓三万丈，胸怀忠孝五尺身。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "太守在上，小侄孙策参见！"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "孙郎少礼。何处而来？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "小侄自父丧之后，退居江南，在丹阳太守母舅吴景处安居。今兵微将寡，被扬 州刺史刘繇所逼，小侄无所依靠，特此带领旧将程普等来投麾下，以效驱策。 未知明公肯收留否？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁术面露轻慢。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "嗯！观尔形象魁梧，英气勃发，将来或堪大用。我且拜你以为怀义校尉，帐下 差遣委用。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "谢明公！ 咳！"
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "早知贤豪皆虚誉，何必英雄奔矮檐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策下。"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "明公看此公子如何？"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "此乃少年英雄。若老夫有子如孙策，死后何恨！"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "明公既以英雄评之，为何不甚为礼？"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "我与孙坚同辈，故倨傲待之，以灭其少年英气，待日后自当重用。"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "原来如此。请明公退帐！"
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "曾问洗足骄英布，"
        },
        {
          "character": "朱治、吕范",
          "type": "同念",
          "text": "何可婴儿视项王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "孙策",
          "type": "内二黄导板",
          "text": "听号角韵悠扬夜静声悄，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "又只见初升月斜挂树梢。 可叹我怀宝剑失了计较。 投袁术他好似泥塑木雕。"
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "欲睡唯多愁，夜看山衔斗。搔首问青天，心事可知否？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "唉，天哪，天！我孙策好错也！因甚误投此地，以致袁术待我如同小儿一般！ 想父亲在日，何等英雄！生我不才，如此沦落，追思往事，好不伤心人也！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "天地间古今事令人难料， 也不知埋没了多少英豪。 周室衰五霸强七雄攘扰， 风云起怎不叫追思汉高。 三尺剑过硭砀灭秦除暴， 鸿门宴险中了范增笼牢。 好一个张子房烧绝栈道， 萧何相荐韩信平步云霄。 九里山逼霸王自刎江道， 方显得男儿汉盖世功劳。 到如今这三杰何处去了？ 空留下英雄恨泪湿征袍！"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "且住！昔日董卓烧洛阳之时，我父曾于建章殿月下为国挥泪；今我误投袁术帐 前，在这月下为家伤情。泪虽一般，心怀各别。正是："
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "我有一片心，诉与天边月。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "苍天哪，苍天！人之伤感，此为甚也！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "对明月怀往事神情飘渺， 想父亲创功业胆落魂消。 事未竟大厦倾将星落早， 遗留我无用才不能续貂。 哭不尽功名事羞夸年少， 哭不尽众诸侯横行乱朝。 空悬着三尺剑两行泪吊， 孙伯符做不得玉阙班超。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱治暗上，听。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "朱治",
          "type": "唱",
          "text": "年少郎自痛哭真正可笑， 莫不是在月下怀想风骚？"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "啊伯符，何故对月痛哭？尊翁在日，也曾用我朱治之谋。你有什么不决之事， 何不问我决之？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "朱先生请坐！"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "请问公子，何故如此？请道其详。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "咳，先生，策所哭者，恨不能继先父之志耳！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "哭先父破黄巾威风曷浩！"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "哭孙策失祖业水流花落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策哭。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "孙郎英雄，令人可敬。何不告求袁术，借兵往江东，假名救吴景，就便暗图大 事。何必在此困于人下？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "是呀，承先生开我愚蒙也！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "深感谢金石言承蒙指教， 借雄兵向江东起凤胜蛟。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "孙郎！"
        },
        {
          "character": "朱治",
          "type": "唱",
          "text": "照此行方能够鳌鱼脱钩， 到长江戏风雨何等逍遥！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕范暗上，听。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "吕范",
          "type": "唱",
          "text": "他二人意欲往南山变豹， 我这里附骥尾同上云霄。"
        },
        {
          "character": "吕范",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "二公之言，为吾听见了！"
        },
        {
          "character": "孙策、朱治",
          "type": "同白",
          "text": "原来是吕范先生！"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "吾手下现有精壮百人，愿助伯符一臂之力。但恐袁术不肯借兵，如之奈何？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "吾有先父留下传国玉玺，送与袁术为质，必然应允。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "着啊！公子将无用之物，换有用之兵，袁术若得此宝为质，必肯借兵。天已明 了，一同相求便了。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "有劳二公了！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "得二公是天赐机缘合巧， 谅必能成大事裂土分茅。"
        },
        {
          "character": "朱治",
          "type": "唱",
          "text": "扶公子我二人义同管、鲍，"
        },
        {
          "character": "吕范",
          "type": "唱",
          "text": "愿求得功名事凌阁名标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策、朱治、吕范同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引袁术同上。"
        },
        {
          "character": "袁术",
          "type": "唱",
          "text": "自昨日退帐后仔细思想， 虎牢关忌孙坚转瞬时光。 不意他有此子十分异相， 宛若是灭秦的西楚霸王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "求借兵占江东假意惆怅，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱治、吕范同上。"
        },
        {
          "character": "朱治、吕范",
          "type": "同唱",
          "text": "附和他创基业龙如长江。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "啊明公，孙策有事相求！"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "啊孙郎，进帐何事？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "小侄父仇不能得报，今母舅吴景，又被扬州刺史刘繇所逼。策之老母、幼弟俱 在曲阿地方，必将被害。敢借雄兵数千，渡江救难。特此拜求明公，伏乞见尤。"
        },
        {
          "character": "袁术",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "话虽如此，但你年幼，如何领得大兵？这断断不可！"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "哎呀明公啊！自古道：有志者事竟成。明公不信，策有先父留下玉玺一颗，权 为质当，求乞收存。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策递。"
        },
        {
          "character": "袁术",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "果然汉家传国玉玺。孙郎，非吾要你玉玺，今且权留在此，请起说话。吾今借 与你精兵三千，良马五百匹，渡江平定之后，可速速回来。你职位卑微，难掌 大权。我拜你为折冲校尉、殄寇将军，就同朱治、吕范一同前去，不得有误！"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "多谢明公！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "拜谢了明公恩提兵调将， 权在手可算得男儿自强。 有劳了二先生一同前往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策下。"
        },
        {
          "character": "朱治、吕范",
          "type": "同唱",
          "text": "笑袁术他不及年少孙郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱治、吕范同下。"
        },
        {
          "character": "袁术",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "袁术",
          "type": "唱",
          "text": "好容易传国玺归于我掌， 炎汉家锦社稷事有可商。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "某久想此玺，不料今日到了吾手，称帝之兆，有几分委托了！"
        },
        {
          "character": "袁术",
          "type": "唱",
          "text": "我且去暗自里整顿粮饷， 趁机会学王莽又有何妨？"
        },
        {
          "character": "袁术",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁术、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程普、黄盖、蒋钦、韩当同上，同起霸。"
        },
        {
          "character": "程普",
          "type": "念",
          "text": "一剑横空几度秋，"
        },
        {
          "character": "黄盖",
          "type": "念",
          "text": "少年义气肝胆投。"
        },
        {
          "character": "蒋钦",
          "type": "念",
          "text": "将军征战开疆土，"
        },
        {
          "character": "韩当",
          "type": "念",
          "text": "志在江南八十州。"
        },
        {
          "character": "程普、黄盖、蒋钦、韩当",
          "type": "同白",
          "text": "俺、（程普）（黄盖）（蒋钦）（韩当）。"
        },
        {
          "character": "程普",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "黄盖、蒋钦、韩当",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "程普",
          "type": "白",
          "text": "我等昔日相随孙坚太守，不想太守被荆州刘表射死。今公子借得袁术兵马，前 往江南，暗图功业，你我前去伺候。"
        },
        {
          "character": "黄盖、蒋钦、韩当",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "程普、黄盖、蒋钦、韩当",
          "type": "同白",
          "text": "看旗幡招展，公子来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂、朱治、吕范、孙策同上。"
        },
        {
          "character": "程普、黄盖、蒋钦、韩当",
          "type": "同白",
          "text": "公子借兵一事如何？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "托列公之福，幸得袁术借兵，看来大事可成也！"
        },
        {
