{
  "script_id": "03021007",
  "title": "探寒窑",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "王夫人",
      "hangdang": "老旦"
    }
  ],
  "plot": "薛平贵出征后，王宝钏苦守寒窑；王允屡逼其改嫁，王宝钏坚决不从，贫病交加。母来探望，见女凄苦，劝\n其返家，王宝钏将母诓出，紧闭窑门，誓死不回。",
  "notes": "为全部《王宝钏》之第七折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引王夫人同上。"
        },
        {
          "character": "王夫人",
          "type": "引子",
          "text": "鹤发皓首，两鬓如霜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人坐。"
        },
        {
          "character": "王夫人",
          "type": "念",
          "text": "夫为相国伴皇家，妻沾雨露享荣华。早晚只把三女叹，怎得周全锦上花？"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "老身，陈氏。配夫王允。膝下无儿，所生三女。长女金钏，许配苏龙。次女银 钏，许配魏虎。三女宝钏，许配平贵。我那宝钏女儿性情高傲，独居寒窑，老 身百般相劝，执意不肯回府。今早也曾命家院去到寒窑，探望三女近来光景如 何，还未见回来。 丫鬟！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "念",
          "text": "有事来通报，无事不乱言。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "参见老夫人！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "罢了。命你去到寒窑打听三姑娘，怎么样了？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘在寒窑身染重病。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘在寒窑身染重病。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "哎，儿呀！"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "听得家院禀一声， 烈性的三女病缠身。 眼望寒窑珠泪——"
        },
        {
          "character": "王夫人",
          "type": "哭头",
          "text": "滚， 我的儿呀！"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "怎不叫娘痛伤心？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "老夫人不必啼哭。何不多带钱米，去到寒窑探望三姑娘？"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "家院、丫鬟！"
        },
        {
          "character": "家院、丫鬟",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "多带钱米，随我探望你家三姑娘。吩咐车辆伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人离座。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "车辆走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫暗上。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人哭。"
        },
        {
          "character": "王夫人",
          "type": "西皮三眼板",
          "text": "为娇儿把我的心机用尽， 想当年大不该在彩楼招亲。 为宝钏与相爷时常争论， 为娇儿失却了夫妻之情。 叫家院你与我前把路引， 到寒窑母女们细说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人、车夫、家院、丫鬟同走圆场。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "来到寒窑！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "前去叫门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人下车。车夫暗下。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘开门来！"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "忽听窑外有人声， 想是四邻探奴身。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘开门来。老夫人来了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "老娘亲到寒窑前来做甚？ 思往事似钢刀刺在我心。 薛郎夫去西凉无有音讯， 这般的光景怎见娘亲？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏开窑门，出窑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "我儿！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "老娘！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "宝钏！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人哭。"
        },
        {
          "character": "王夫人",
          "type": "西皮导板",
          "text": "见娇儿不由娘两泪淋，"
        },
        {
          "character": "王宝钏",
          "type": "三叫头",
          "text": "老娘，母亲，娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "王夫人",
          "type": "三叫头",
          "text": "宝钏，我儿，儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人哭。"
        },
        {
          "character": "王夫人",
          "type": "西皮流水板",
          "text": "手拉娇儿说分明： 儿在那相府多由性， 闷来花园散散心。 自从你把寒窑进， 面黄肌瘦无精神。 千般苦处儿受尽， 叫娘心疼不心疼！"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "老娘亲不必痛伤心， 女儿言来听分明： 大姐、二姐有福分， 许配达官做夫人。 唯有宝钏的命运苦， 彩球单打平贵身。 倘若世人都为宦， 谁是那耕田种地的人？"
        },
        {
          "character": "王夫人",
          "type": "西皮流水板",
          "text": "我心中只把相国恨， 一样的女儿两样的心。 回头我对宝钏论， 为娘言来听分明： 今日母女重相会， 好似枯木又逢春。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲在上，待女儿大礼参拜。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "我儿不要拜了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿久离膝下，少奉甘旨，望母亲恕女儿不孝之罪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏跪拜。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "我儿起来！ 家院、丫鬟，见过你家三姑娘！"
        },
        {
          "character": "家院、丫鬟参",
          "type": "同白",
          "text": "见三姑娘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院、丫鬟同行礼。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "罢了。母亲不在相府，来到寒窑做甚？"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "家院回府报道，我儿身染重病。此病从何而起？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲有所不知。只因魏虎回朝，打从寒窑经过。是他言道，我夫平贵命丧西凉。 爹爹又差人前来，劝女儿改嫁。儿听此言，痛哭不止，因此身得重病。今日 母亲到此，女儿这病么，就好了一半了。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "我把你这老天杀的！为何常常来逼女儿改嫁？此番回去，我定要与他吵闹一场。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊母亲，不要为了女儿之事，伤了你二老的和气。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "儿呀，看在我儿分上，不与你父吵闹就是。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "多谢母亲！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "儿呀，为娘要进得窑去，看看我儿的光景如何。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "寒窑窄小，不去也罢！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "啊，我儿住得了，难道为娘就进去不得么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此，待女儿打扫打扫。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "不要打扫，与为娘带路。儿呀！"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "画阁雕梁儿不住， 破瓦寒窑怎把身存？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、王夫人同进窑。家院、丫鬟同随进。家院端饭碗与王夫人看。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "珍馐美味儿不用， 粗茶淡饭怎把饥充？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "我儿！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "老娘！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "宝钏！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "喂呀，母亲哪！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "我哭哇，哭一声宝钏儿呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "我叫，叫一声老娘亲！"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "想当初在相府何等光景， 到如今叫为娘好不心疼！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "只当孩儿丧了命， 母亲莫要挂在心。"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "我儿随娘相府进， 享尽荣华不愁贫。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "儿与爹爹三击掌， 饿死寒窑也不进相府的门。"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "王宝钏！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "老娘亲！"
        },
        {
          "character": "王宝钏、王夫人",
          "type": "同西皮摇板",
          "text": "啊、啊、啊……我的（娘哪）（儿呀）！"
        },
        {
          "character": "王宝钏",
          "type": "西皮导板",
          "text": "老娘亲请上容儿禀："
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "母女们在寒窑叙一叙苦情。 都只为老娘亲身染重病， 女儿我后花园去把香焚。 许愿降香三年整， 后宫娘娘得知情。 恩赐五彩花绒线， 绣成彩球定终身。 实指望打中宦门后， 谁知单打花郎身。 夫妻二人相府进， 爹爹一见怒气生。 前门赶走——"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "薛平贵， 又将女儿赶出了后门。 夫妻二人无投奔， 破瓦寒窑把身存。 红沙涧内妖魔现， 红鬃烈马乱伤人。 平贵擒了红鬃马， 唐王驾前报功勋。 西凉贼子造了反， 平贵做了马前先行。 一去不觉十七载， 儿似孤雁失了群！ 母亲回府对父论， 莫把女儿挂在心。"
        },
        {
          "character": "王夫人",
          "type": "西皮快板",
          "text": "我儿不必心烦闷， 为娘言来听分明： 休与你父来争论， 不要记挂平贵身。 儿随为娘相府进， 随娘坐来伴娘行。 倘若你父把话论， 为娘舍死把命拼。 倘若为娘百年后， 儿就是披麻戴孝的人。"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "老娘亲不必泪淋淋， 女儿言来听分明： 倘若老娘百年后， 儿是披麻戴孝的人。 倘若爹爹身亡故， 女儿不去哭半声。 非是女儿不孝敬， 他那里不把儿当人。 宝钏心志早已定， 至死不回这相府的门。"
        },
        {
          "character": "王夫人",
          "type": "西皮摇板",
          "text": "立志守节拿得稳， 皇天不负受苦的人。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "家院、丫鬟，将带来的银米交与你家三姑娘。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "且慢！相府之物，女儿一概不要。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "你如不要，岂不辜负为娘一片好心？儿呀，收下了吧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "多谢母亲！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "这便才是。 家院、丫鬟，你们暂且回去。老身今日在此陪伴你家三姑娘一宵，明日回府。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊母亲，寒窑如此肮脏，母亲怎能住得？"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "我儿住得，难道为娘就住不得么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "且住！母亲不回相府，这便如何是好？我自有道理。 啊母亲，女儿情愿跟随母亲回转相府去了。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "这便才是。 家院，吩咐车辆走上。 我儿开了窑门！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
