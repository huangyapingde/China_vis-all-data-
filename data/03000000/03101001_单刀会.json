{
  "script_id": "03101001",
  "title": "单刀会",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    },
    {
      "name": "关平",
      "hangdang": "小生"
    }
  ],
  "plot": "鲁肃急索荆州，特命人请关羽过江赴宴，以便劫持。关羽仅携周仓单刀赴会，筵席间历述战功，鲁肃乘隙讨\n还荆州。关羽佯醉，并持刀亲执鲁肃同至江边。东吴诸将，以计不成，未敢轻动。经关平接应，关羽得安然\n返回荆州。",
  "notes": "故事出自关汉卿的《关大王独赴单刀会》的杂剧及《三国演义》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四耀武旗、关羽同上，周仓持刀、关平抱印同上，两边亮象。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "凤目蚕眉须苍白，秉烛达旦天下仰；展雄威，声震邻邦。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "赤面长髯武艺强，兵机战策腹中藏。青龙赤兔无人挡，扰倾雄兵镇荆襄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某、汉寿亭侯关。奉了军师之命，镇守荆州一带。可恨孙权，每每着人前来讨 取，是俺再三不与，那厮必定不肯罢休，且自由他。 周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东吴卒上。"
        },
        {
          "character": "东吴卒",
          "type": "念",
          "text": "离了东吴地，来此是荆州。"
        },
        {
          "character": "东吴卒",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "东吴卒",
          "type": "白",
          "text": "东吴下书人求见。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "你且稍等。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓向关羽。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "启君侯：东吴下书人求见。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "传！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓向下书人。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "传你进去，你要小心了。"
        },
        {
          "character": "东吴卒",
          "type": "白",
          "text": "是。 叩见关将军！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你奉何人所差？"
        },
        {
          "character": "东吴卒",
          "type": "白",
          "text": "奉鲁大夫所差。有书信呈上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹牌子〗。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你对鲁大夫言讲，修书不及，照书行事。"
        },
        {
          "character": "东吴卒",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东吴卒下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "原来鲁肃请某过江饮宴。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "鲁肃约请父帅饮宴，断无好意，父帅不可前去。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某若不去，岂不被东吴耻笑？"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "虽然如此，父帅岂可以万金之躯，轻入虎狼之地？倘有差池，怎能对得皇伯！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想为父出兵多年，纵横天下，岂惧东吴小辈！"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "父帅一定要去，必须多带人马。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "只用大船一只，挑选关西大汉数名，在船中服役，周仓一人跟随，船上插红旗 一面；再备白旗一面，暗藏船中。吾儿准备战船二十只，领精兵一千名，在江 心伺候。倘若东吴有诈，那时将白旗摆动，吾儿带兵急速接应，料无妨碍。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平，你随为父出兵多年，尚不深悉用兵之道。站立一旁，听为父训教。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "孩儿恭听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "为将帅者，必须要上晓天文，深明地理，熟读兵书，通达战策。统兵出战，更 须足智多谋；治兵当以纪律为先，临阵务从精细入手。统率将士，体恤人心， 宽以济猛，猛以济宽。有功则赏，有过者罚。交锋之际，量自己之强弱，察敌 阵之虚实。又道是知己知彼，百战百胜，乘其未至，攻其不备。运筹帷幄之中， 决胜千里之外。诈败不可紧追；得胜不可妄进。安营扎寨，靠山近水。深林 防埋伏；苇塘防火攻。此乃战无不胜，攻无不取，所谓行军之要诀也！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "用兵之道须谨慎， 临阵交锋要小心。 随机应变休妄进， 得胜成功莫逞能。 因地制宜安营寨， 靠山近水好屯军。 偷营劫寨心拿稳， 旗开得胜把功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四水手同上，船靠岸。周仓上，摆式、亮架、舞刀。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有请君侯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四耀武旗、关羽同上，同登船。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "上得船来，好一派江景也！ 周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "解缆开船。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "喳！ 众水手！"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "解缆开船。"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "关羽",
          "type": "二黄导板",
          "text": "上船来只觉得神清气爽！"
        },
        {
          "character": "关羽",
          "type": "二黄原板",
          "text": "推楼窗展凤眼细看端详。 大战船千百只江岸倚傍， 小战船密匝匝好似蜂房。 微风起淡云收天晴日朗， 碧澄澄波浪稳水接天光。 耳边厢又听得人声喧嚷， 又只见东吴兵排列两厢。 叫周仓将大船——"
        },
        {
          "character": "关羽",
          "type": "二黄散板",
          "text": "依靠岸上， 来到了东吴地天各一方。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "水手的！"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "将船靠岸。"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、鲁肃同上。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "安排酒宴请关羽，为讨荆州费心机！"
        },
        {
          "character": "探子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "关羽到。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "来，摆队相迎。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。鲁肃、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "甘宁、周仓自两边分上，同比式子。四龙套、鲁肃同上，关羽上。鲁肃迎，众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、甘宁、鲁肃、周仓、关羽同上。关羽、鲁肃同入座。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯驾到，肃未曾远迎，望祈恕罪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某家久未致候，大夫海涵！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫招宴，足见故人情义。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "摆宴！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖细吹打〗。鲁肃送酒入坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯请！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "久闻君侯海量，今日定要尽醉方休。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "叨扰了！"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "今日里与大夫共饮琼浆， 在筵前听关某诉一诉衷肠： 想当年破黄巾东除西荡， 战吕布诛文丑刀斩颜良。 数十载动干戈未离马上， 奉主命统雄兵坐镇荆襄。 与大夫对饮在临江亭上， 蒙厚意备酒宴甚是叨光。"
        },
        {
          "character": "鲁肃",
          "type": "西皮原板",
          "text": "君侯说话太谦让， 鲁肃言来细端详： 盖世功劳人钦仰， 灭黄巾破吕布天下名扬。 叫人来看大杯把酒献上， 蒙大驾临东吴日月增光。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯辱临，定要畅饮一回。想当年君侯辞曹以后，过五关、斩六将，单骑千里 之事，可能说与肃一听否？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫不嫌絮烦，听某道来！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯请讲。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "关羽",
          "type": "吹腔慢板",
          "text": "想当年在曹营多安享， 为寻兄长出许昌。 挂印封金阳关上， 沿途关口动刀枪。 孔秀、孟坦刀下丧， 韩福、王植马前亡。 有普净泄机关得脱罗网， 三尺剑劈卞喜他命丧佛堂。 黄河渡那秦琪又来阻挡， 青龙刀斩鼠辈命丧无常。 古城之下摆战场， 擂鼓三通斩蔡阳。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯武艺无敌，其乃天神降世也！"
        },
        {
          "character": "鲁肃",
          "type": "吹腔慢板",
          "text": "似这等神威勇无人能挡， 博得美名天下扬。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊君侯，肃有一言，不知当讲不当讲？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有何金言，但讲不妨！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "想当年皇叔借去我国荆州，屯军养马。那时也曾言道，日后得了西川，即将荆 州还我东吴。前次诸葛瑾先生由西川归来，奉皇叔之命，领取荆州，君侯却再 三不与，不知是何道理？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鲁大夫，今日饮宴，乃是朋友之情，军国大事，何须提起！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这！还要君侯裁夺！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小锣〗，〖作刀鸣声〗。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊！君侯这是什么响亮！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "乃是某宝刀的啸声！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是君侯的刀啸？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "但不知这刀，几年一啸？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "自桃园结义以来，某家即有此刀，数十馀年，直到今日它只啸了三次。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "但不知刀啸主何吉凶？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "也不过是杀人而已。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "何以见得？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "第一次刀啸，应在斩颜良、诛文丑；第二次刀啸应在过五关斩六将；今日这第 三次刀啸么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽视鲁肃佯笑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "只恐怕要应在大夫你的身上了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃吓倒，四龙套同扶起。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓，刀来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽持酒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀哇，青龙刀！想你随某出兵多年，也不知斩了多少上将。今日鲁大夫设宴相 邀，在临江亭上散酒，你也来饮上一杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽泼酒。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "青龙偃月白光凝， 能征惯战血染红！"
        },
        {
          "character": "鲁肃",
