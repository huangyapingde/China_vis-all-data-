        {
          "character": "关羽",
          "type": "白",
          "text": "好酒！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "常言三杯和万事， 一醉便能解千愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽佯醉。"
