{
  "script_id": "03013007",
  "title": "高平关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "高行周",
      "hangdang": "净"
    },
    {
      "name": "高怀德",
      "hangdang": "小生"
    },
    {
      "name": "高怀亮",
      "hangdang": "小生"
    }
  ],
  "plot": "五代时，高行周据守高平关。时赵匡胤在郭彦威部下，欲杀高行周以邀功。赵匡胤到关后，高行周察知其意，\n并预料赵匡胤必成大业，乃将印信交付其子高怀德执掌，并托赵匡胤得志后，优遇高怀德弟兄。赵匡胤许\n以己妹配高怀德，高行周乃自刎。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四开门刀、中军、高行周同上。"
        },
        {
          "character": "高行周",
          "type": "点绛唇",
          "text": "坐镇高平，统率三军，旌旗整，保主乾坤，令出山摇震。"
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "威风凛凛坐虎堂，五龙二虎逼彦章。鸡爪山前曾交战，刘主官封东鲁王。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "老夫高行周。刘华王驾前为臣。奉命镇守高平关一带等处。只因昨晚仰观天象， 见赤须龙压着了白虎大堂。是我屈指一算，赤须龙乃是河东赵匡胤；白虎之 象乃是老夫本命星。他今前来，行刺于我。本当不助他成功，又恐五雷击顶。 为此，今日升坐虎堂。正是："
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "大国愁来小国愁，干戈不知几时休。算来宝剑项上刎，盖世忠良不到头。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "众将进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。 众将进帐！"
        },
        {
          "character": "四将",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "元帅一十三载未升白虎大堂。今日升坐虎堂，宣我等进帐，有何军情议论？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "众位将军哪里知道。只因老夫年迈，难以执掌高平大事。老夫有意，将印信付 与尔等，不知意下如何？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "我等才疏学浅，还有二位少爷。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "真乃仁德之将。帐外候令！"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同下。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "二位少爷进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。 二位少爷进帐！"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀亮同上。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "参见爹爹！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿是怀德？"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "儿是怀德。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿是怀亮？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "儿是怀亮。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "嗐，儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周哭。"
        },
        {
          "character": "高行周",
          "type": "西皮导板",
          "text": "擂鼓三通坐虎堂，"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "怀德！"
        },
        {
          "character": "高怀德",
          "type": "叫头",
          "text": "爹爹。"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "怀亮！"
        },
        {
          "character": "高怀亮",
          "type": "叫头",
          "text": "我父。"
        },
        {
          "character": "高行周",
          "type": "叫头",
          "text": "嗐，儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周哭。"
        },
        {
          "character": "高行周",
          "type": "西皮原板",
          "text": "怀德、怀亮细听端详： 为父我昨夜晚仰观天象， 赤须龙压着了白虎大堂。 儿道那赤须龙是哪一个？"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "他是哪个？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "他就是河东的赵……"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "赵什么？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "一个“赵”字出了口， 两个冤家着了慌。 我这里将赵字丢开罢， 怀德、怀亮坐两旁。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "啊爹爹，十数余载，未曾升坐白虎大堂；今日升坐虎堂，不知为的哪路军情？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿等哪里知道。只因为父年迈，难以执掌高平大事。为父有意，将印信付与儿 等。不知意下如何？"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "孩儿年小。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "孩儿年幼。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "哽，讲什么年小年幼，可记得为父一十三岁，大战勾家滩之事。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "儿等不知。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿等不知，听为父慢慢道来！"
        },
        {
          "character": "高行周",
          "type": "西皮原板",
          "text": "忆昔黄巢反大唐， 将唐主赶在西岐美良。 程敬思前去搬兵将， 沙陀国搬来了李晋王。 飞虎山收下了李存孝， 灭却了黄巢兴大唐。 为父书房念文章，"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "探马不住报端详。 王彦章打胜仗， 儿祖父中了那回马枪。 为父闻言冲冲怒， 直到阵前去会彦章。 他把为父太小量， 我二人分个谁胜哪个强。 为父就用铜锤打， 那贼就把铁鞭扬。 铜锤打铁鞭扬， 打得那贼带了伤。 五龙二虎逼贼丧， 才得官封东鲁王。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "看印拜过！"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德拜。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮拜，哭。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "怀德执掌高平印， 怀亮一旁放悲声。 手掌手背俱是肉， 一样的孩儿两看承。 怀亮看过上方剑， 儿带三千鹞子兵。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿啊，明日午时三刻上关之期，见一红脸大汉。他若进关，枪头朝里；他若出 关，枪头朝外。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "却是为何？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "这个……儿啊！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "昔日里楚汉两争强， 鸿门设宴害高皇。 霸王不听范增语， 后来自刎在乌江。 父说此话儿参想，"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "孩儿不解。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "枉读诗书和文章。 弟兄双双把关上， 无令休到白虎堂。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "怀德执掌高平印，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "怀亮马前做先行。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "人来带过马能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德下。"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "去到关前看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮下。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "怀德、怀亮把关上， 父子们再相逢梦一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周、四龙套、四开门刀、中军同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四将、高怀德、高怀亮同上。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "关内奉了爹爹命，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "来到关前看分明。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "人马扎在鹞子岭，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "看是何人到来临。"
        },
        {
          "character": "赵匡胤",
          "type": "内西皮导板",
          "text": "戴月披星离怀庆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "不分昼夜奔高平。 在西门遇崔龙将我拿问， 多亏了曹二弟合家满门。 二次里又遇见老将杨滚， 那老儿虽年迈武艺皆能。 铜锤下不伤俺玄郎性命， 郭王爷赐宝刀二下高平。 有豪杰催青鬃忙往前进，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "又只见鹞子岭扎下大营。 上写着东鲁王让了帅印， 有怀德和怀亮执掌高平。 不杀老儿回怀庆，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "监牢内还有我二老双亲。 明知道山有虎伤人性命， 俺玄郎大着胆偏把虎擒。 头上的檐毡帽齐眉遮定， 学关公斩蔡阳夜奔古城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "我看此人好面善，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "好像河东赵玄郎。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "怀德提枪忙赶上，"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "爹爹将令谁敢挡。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "人来带路回宝帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德下。"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "见了爹爹说端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮、四龙套、四将同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高行周上。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "昨夜晚一梦大不祥， 梦见我主刘华王。 手挽手儿悲声放， 二人同见五殿阎王。 今早打开古书看， 午时三刻一命亡。 将身儿坐至在白虎堂上， 等、等、等、等候河东赵玄郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "豪杰打马上高关， 玉石栏杆把马拴。 手搭凉棚用目看， 白虎堂坐定将魁元。 手使宝刀朝上砍，"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "是何人大胆敢欺天！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "侄儿河东赵。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "敢是匡胤？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "上得关来，为何拔刀出鞘？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "侄儿上得关来，心中骇怕，故而拔刀出鞘。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "将刀入鞘。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "那旁有座，儿且坐下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿一双爹娘可好？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "二爹娘安康。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿在江湖可好？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "侄儿有何德能，敢劳伯父动问。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "伯父不来问你，你把你伯父、伯母，就忘怀了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "侄儿上得关来，被伯父占先了。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "好个“占先”二字！ 哎呀且住。人言匡胤，有九五之尊，老夫习就麻衣神相，待我相他一相。他若 有九五之尊，助他成功；他若无有九五之尊，玄郎啊玄郎，想出高平，万万的 不能。 玄郎！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "伯父！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "将檐毡帽挽起！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "高行周",
          "type": "西皮原板",
          "text": "东鲁王坐虎堂细观匡胤， 观一观河东创业之人。 卧蚕眉丹凤眼丰额隆准， 耳垂肩手过膝九五之尊。 问玄郎上关来有何议论？"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "伯父台前问安宁。"
        },
        {
          "character": "高行周",
          "type": "西皮原板",
          "text": "问什么安来问什么宁，"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "为伯父心中明如灯。 刺杀刘王就该走， 不该二次到高平。 高平关怎比得燕京地， 老夫怎比刘华君。 左有天奇与天庆， 右有刘安和刘民。 四员虎将威风凛， 还有那怀德、怀亮杀人星。 虽然老夫年高迈， 还有三千鹞子兵。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "这老儿他倒能隔山照影， 就知道俺玄郎今要杀人。 不杀老儿回怀庆，"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "回去拜上儿的爹娘。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "想起爹娘书信在身。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿为何去而复转？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "非是侄儿去而复转，二爹娘有书信到来，伯父请看。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "上写着拜上多拜上， 拜上高平老仁兄。 玄郎到此无别事， 借你的人头作证凭。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "呀呀，呸！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "世上万物皆可借， 要借人头不近情！ 问玄郎杀伯父因为何故？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "监牢内搭救我二老双亲。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "儿有儿的父和母， 怀德、怀亮靠何人？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "伯父助我把功成， 怀德、怀亮我看承。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "我的儿本是将门后， 何劳赵家你看承？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "我有一妹赵美蓉， 许给怀德配为婚。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "说此话儿就该双手剁！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "伯父说话欠聪明。 天凭日月轮流转， 人凭双膀定乾坤。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "走关西来闯关东， 这两句话儿解不通。 你若解开其中意， 老夫助你把功成； 若解不开其中意， 想出高平万不能。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "走关西来闯关东， 这句话儿解不通。 豪杰低头暗思想， 想是伯父要合同。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "侄儿上得关来，未带文房四宝。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "虎堂现有。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请伯父离了虎位。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "正要离位。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "还早。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "赵玄郎上关来魂飞天外，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮原板",
          "text": "上高平好一似鬼使神差。 姓高人与赵家无有仇害， 苦苦的要杀他所为何来。 对伯父施一礼公位来踩， 上公案我只得提笔写来。 头辈爷赵高祖富足员外， 二辈爷赵怀度颇有家财， 我的父赵洪恩名扬四海， 我的母曾受过皇王封来。 生下俺赵玄郎面带古怪， 兄匡胤、弟光美、美蓉裙钗。 姓高人与赵家结亲四海， 但愿得他夫妻们到老和谐。 写合同不把这画押来带， 老伯父拿去看自刎头来。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "小奴才你不必作鬼作怪， 些小的逃脱计我父解开。 有三媒和六证人头现在； 无三媒要人头转世投胎。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "这老儿虽年迈聪明还在， 赵玄郎肺腑情被他解开。 提笔再写柴子耀， 石守能、石守信人称将才。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "张光远、郭彦威名扬四海。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "不好！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "还有个苗先生八卦安排。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "这不要那不要把我难坏， 老伯父要何人自己讲来！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "董家桥打五虎几人结拜， 谁是兄谁是弟一一讲来！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "董家桥打五虎三人结拜， 还有个郑子明未曾写来。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "问玄郎此人在不在？"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "在西门与怀德见过阵来。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "他二人打一仗谁胜谁败？"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "不分胜不分败转回营来。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "罢，罢，罢！写郑恩老夫心爱。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "提笔再写郑英才。 昔日打马金桥界， 偶遇先生把卦排。 将我八字案上摆， 算我将来坐龙台。 有九台无九台， 高家代代伴金阶。 七岁孩儿纱帽戴， 九岁女儿簪凤钗。 一对合同忙修好， 老伯父拿去看自刎头来。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "这合同好一似阴阳地界， 一张纸换下了我的头来。 叫玄郎你与我眼色来迈， 袖儿内藏合同他怎解开。 叫玄郎你与我把路来带！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "伯父要往哪道而去？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "去到上房，见过儿的伯母。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "想伯父与伯母乃是恩爱夫妻，倘若见面，难以割舍。伯父你舍了吧！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "舍了吧！"
        },
        {
          "character": "高行周",
          "type": "哭头",
          "text": "啊，啊，啊，我的妻呀！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "夫妻们再相逢转世投胎。 叫玄郎你与我下关路带！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "伯父又往哪里去？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "去到关前，见过你两个兄弟。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "两个兄弟一个个如狼似虎，倘若见面，岂肯与侄儿干休。伯父你舍了吧！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "舍了吧！"
        },
        {
          "character": "高行周",
          "type": "哭头",
          "text": "啊，啊，啊，我的儿啊！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "父子们再相逢梦里阳台。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "玄郎上得关来，全凭何物？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "骑下马，掌中刀。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "借刀一用。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刀不离身。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "锤换刀。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刀换锤。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "开刀先杀赵匡胤，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "想是伯父变了心。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "非是伯父变了心， 怕你后来忘了恩。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "伯父助儿把功成， 怀德讨饭我担承。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "起过了！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "真龙天子开金口， 我儿讨饭他收留。 罢罢罢来休休休， 学一个乌江自刎头。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "玄郎，那旁有人来了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周自刎。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "一见伯父尸不倒， 想是伯父讨封号。 有朝一日登大宝， 封你白马大英豪。 宝刀一举人头掉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周死，下。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "郭王台前报功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}