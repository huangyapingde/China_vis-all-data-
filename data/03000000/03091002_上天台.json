{
  "script_id": "03091002",
  "title": "上天台",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘秀",
      "hangdang": "老生"
    },
    {
      "name": "姚期",
      "hangdang": "净"
    },
    {
      "name": "姚刚",
      "hangdang": "净"
    },
    {
      "name": "郭荣",
      "hangdang": "净"
    }
  ],
  "plot": "东汉刘秀时，姚期之子姚刚打死太师郭荣。姚期绑子上殿。刘秀念姚家父子颇具功勋，只将姚刚发配。姚期\n欲辞官，亦经慰留。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姚刚上。"
        },
        {
          "character": "姚刚",
          "type": "引子",
          "text": "金殿喜气扬，父子保朝纲。"
        },
        {
          "character": "姚刚",
          "type": "念",
          "text": "征战南蛮有三秋，金殿之上占鳌头。南蛮救父功劳有，终得官封猛烈侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "某、姚刚，字霸陵。父子扶保汉王。是我南蛮救父回朝，圣上见喜，金殿封官； 可恨郭荣老贼，一旁启奏，道我年幼，封不得官职。多亏邓禹先生保奏，圣 上封我猛烈侯之职。因此夸官三日，跨马游街。 家院，吩咐外厢开道！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 外厢开道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍自两边分上，伞夫上。姚刚上马。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "念",
          "text": "有事忙通报，无事不乱传。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请太师爷！"
        },
        {
          "character": "郭荣",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭荣上。"
        },
        {
          "character": "郭荣",
          "type": "念",
          "text": "有事在心头，终日眉头皱。"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "今有姚刚，跨马游街，鸣锣过府。"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "好个大胆姚刚小畜生，竟敢鸣锣。 家院，带路府门！"
        },
        {
          "character": "郭荣",
          "type": "唱",
          "text": "家院与爷把路引， 见了姚刚问分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、郭荣同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上，同站门。家院、姚刚同上。"
        },
        {
          "character": "姚刚",
          "type": "唱",
          "text": "金瓜钺斧朝天镫， 红罗罩定姚霸陵。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "家院，前道为何不行？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "来此郭太师府门，府前有三尺禁地，文官下轿，武将离鞍。请爷绕道而行！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "起过。 且住！俺在金殿封官，那郭荣启奏，道我年幼，封不得官职。那时俺怀恨在心， 正要寻这老贼。 家院，吩咐鸣锣，闯道而过！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 人役们！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "鸣锣过府！开道！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "院子、郭荣同上。"
        },
        {
          "character": "郭荣",
          "type": "唱",
          "text": "家院带路出府门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、郭荣同出门。"
        },
        {
          "character": "郭荣",
          "type": "唱",
          "text": "只见姚刚到来临。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、家院、姚刚同上，上场门站一字。"
        },
        {
          "character": "姚刚",
          "type": "唱",
          "text": "坐立雕鞍来观定， 又见老贼坐府门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚刚下马。"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "老太师请了！"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "老太师怒气不息，为着谁来？"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "就为你来！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "为俺何来？"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "我且问你：圣上赐我三尺禁地，文官下轿，武将离鞍，你为何私自鸣锣，闯府 而过，是何道理？"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "我且问你：你在朝凭文？"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "不凭文。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "这论武？"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "也不论武。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "在朝为官，凭着何来？"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "谁不知我女在西宫陪王伴驾！喏喏喏，我乃当朝老太师！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "郭荣当",
          "type": "白",
          "text": "朝老太师！"
        },
        {
          "character": "姚刚",
          "type": "三笑",
          "text": "啊哈！啊哈！哇呀呀呀……"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "你为何发笑？"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "我道你三弓两箭，挣来的乌纱紫袍，原来是裙边带的官儿，尔有些不洁净！"
        },
        {
          "character": "郭荣",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "郭荣",
          "type": "唱",
          "text": "听一言来动无名， 大骂姚刚小畜生。 老夫上殿奏一本， 管教你黑头挂午门！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "老贼！"
        },
        {
          "character": "姚刚",
          "type": "唱",
          "text": "听罢言来心头恼， 二目圆睁似火烧。 三尺龙泉出了鞘， 叫你老贼赴阴曹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚刚杀死郭荣，院子逃下。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "杀死了！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "带马回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郭妃上。"
        },
        {
          "character": "郭妃",
          "type": "念",
          "text": "闷坐西宫院，每日伴驾眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启娘娘：大事不好了！"
        },
        {
          "character": "郭妃",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "今有姚刚，将太师爷剑劈府门而死！"
        },
        {
          "character": "郭妃",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "郭妃",
          "type": "唱",
          "text": "听说爹爹丧了命， 怎不叫我痛伤情！ 内侍摆驾上龙庭， 万岁驾前奏分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监、郭妃同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姚期上。"
        },
        {
          "character": "姚期",
          "type": "念",
          "text": "父子功劳重，满门受皇恩。"
        },
        {
          "character": "姚刚",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院、姚刚同上。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "罢了。坐下！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "告坐。可恼哇，可恼！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "儿呀，你为何怒气不息？"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "爹爹有所不知，今日孩儿奉旨跨马游街，那郭荣老贼拦住马头，百般笑骂，是 孩儿怒气之下，将郭荣老贼杀死了！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "好，尔近前来，为父有话对你言讲！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期打姚刚。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "好奴才！"
        },
        {
          "character": "姚期",
          "type": "唱",
          "text": "奴才做事真胆大， 全然不知犯王法！ 叫人来将他忙绑下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠自两边分上，同绑姚刚。"
        },
        {
          "character": "姚期",
          "type": "唱",
          "text": "上殿奏本将尔杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "刘秀",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同上，同站门，刘秀上。"
        },
        {
          "character": "刘秀",
          "type": "二黄慢三眼",
          "text": "金钟响玉磬鸣王出龙庭， 汉光武登大宝五谷丰登。 文凭着邓先生阴阳有准， 武仗着姚皇兄扫荡烟尘。 云台观剐王莽江山重整， 到如今文共武才乐安宁。 内侍臣摆御驾九龙口进，"
        },
        {
          "character": "郭妃",
          "type": "内哭",
          "text": "喂呀……"
        },
        {
          "character": "刘秀",
          "type": "二黄慢三眼",
          "text": "猛听得金殿外大放悲声！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、郭妃同上。"
        },
        {
          "character": "郭妃",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "郭妃",
          "type": "唱",
          "text": "急忙来把龙庭进， 万岁驾前奏分明！"
        },
        {
          "character": "郭妃",
          "type": "白",
          "text": "万岁作主呀……"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "梓童为何这等模样？"
        },
        {
          "character": "郭妃",
          "type": "白",
          "text": "启奏万岁：今有姚刚，将我父剑劈府门，望万岁作主呀……"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "梓童，你且回宫，寡人自有发落！"
        },
        {
          "character": "郭妃",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "郭妃",
          "type": "唱",
          "text": "谢罢万岁下龙庭， 管叫姚刚命难存。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、郭妃同下。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "内侍，传孤旨意，宣伴驾王带子上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！ 万岁有旨：伴驾王带子上殿哪！"
        },
        {
          "character": "姚期",
          "type": "内白",
          "text": "遵旨！"
        },
        {
          "character": "姚期",
          "type": "二黄导板",
          "text": "安静府绑姚刚怒气大发，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期、姚刚同上。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "奴才呀，奴才！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "骂一声小姚刚胆大冤家。 明知道郭荣贼势力浩大， 为什么闯府门将他来杀！ 他女儿在西宫陪王伴驾， 满朝中文武臣谁不怕他！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "姚刚",
          "type": "二黄摇板",
          "text": "儿奉旨征南蛮功劳甚大， 圣天子龙心喜帽插金花。 那时节老奸贼一旁搭话， 是孩儿心儿内有些恨他。 儿奉旨游御街拦住叫骂， 因此上拔宝剑将他来杀！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "小奴才犯王法胆比天大， 杀了人还说是不犯王法。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "儿是好汉？"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "是好汉！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "是好汉随为父朝王见驾，"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期、姚刚同走小圆场，同上殿。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "跪下！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "见万岁一桩桩一件件、谁是谁非——"
        },
        {
          "character": "姚期",
          "type": "哭头",
          "text": "姚刚，我的儿呀！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "儿启奏皇家！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "臣、姚期见驾，愿吾皇万岁！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "姚皇兄，你可知罪？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "臣知罪，不知罪犯何条？"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "你三子姚刚，将郭太师剑劈府门，你还说无罪！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "郭太师他也有一行大罪！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "他有何罪？当殿奏来！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "他私立禁地，文官下轿、武将离鞍。万岁可曾降旨？"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "寡人未曾降旨！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "私立禁地，犹如占主江山，斩首无亏！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "好个斩首无亏！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "绑坏了！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "老皇兄，殿角下绑的何人？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "罪子姚刚！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "不要绑坏了孤的小爱卿！ 内侍，快快松绑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监与姚刚松绑。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "谢万岁不斩之恩！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "非是寡人不斩于你，寡人有言在先：姚不反汉，汉不斩姚。孤赐你三千人马， 发往河北宛子成，保定殿下刘庄。你不必回府，你父子就在午门一别，下殿去 吧！"
        },
        {
          "character": "姚刚、姚期",
          "type": "同白",
          "text": "谢万岁！"
        },
        {
          "character": "姚刚",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "万岁赦却姚霸陵， 好似枯木又逢春。 手拉娇儿下龙庭， 为父言来儿是听： 去到河北改情性， 休要提刀乱杀人！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "儿来看！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "为父年迈苍苍白发如银，"
        },
        {
          "character": "姚期",
          "type": "哭头",
          "text": "姚刚，我的儿呀！"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "好一似瓦上霜风前之灯！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "姚刚",
          "type": "二黄摇板",
          "text": "爹流泪来儿悲伤， 点点珠泪洒胸膛。 在朝为官有什么好， 一卯不到定有伤。 不如写下辞王表， 回到家中乐安康。 午门辞父泪汪汪， 安静府难辞老萱堂。"
        },
        {
          "character": "姚刚",
          "type": "叫头",
          "text": "爹爹！"
        },
        {
          "character": "姚期",
          "type": "叫头",
          "text": "吾儿！"
        },
        {
          "character": "姚刚",
          "type": "叫头",
          "text": "天伦！"
        },
        {
          "character": "姚期",
          "type": "叫头",
          "text": "姚刚！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "哎呀娘啊！罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚刚下。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "姚刚，霸陵！啊啊啊……我的儿呀……"
        },
        {
          "character": "姚期",
          "type": "二黄摇板",
          "text": "午门外去了姚霸陵， 好似钢刀刺在心。 撩袍端带上龙庭， 告辞还乡为庶民。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "臣、姚期二次见驾，愿吾皇万岁！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "老皇兄为何去而复转？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "老臣年迈，要告职归林！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "老皇兄要告辞还乡，寡人怎能舍得！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "万岁舍不得老臣，老臣也舍不得万岁。要臣在朝奉君，依臣一件！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "万岁戒酒百日！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "只要皇兄在朝，慢说戒酒百日，就是周年半载，又待何妨！"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "吾主有道明君。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "内侍，搀扶起老皇兄！"
        },
        {
          "character": "刘秀",
          "type": "二黄三眼板",
          "text": "劝皇兄休得要告职还乡， 卿本是擎天柱架海金梁。 孤江山多亏卿东征西挡， 王封你享清福永乐安康。 都只为小爱卿情性倔强， 连累了老皇兄心下着忙。 为王的不久就把旨来降， 赦回了小姚刚转回故乡。"
        },
        {
          "character": "姚期",
          "type": "二黄原板",
          "text": "万岁爷待老臣恩深海洋， 老姚期粉身碎骨也是应当。 非是臣在金殿告职还乡， 怕的是郭娘娘暗害忠良。"
        },
        {
          "character": "刘秀",
          "type": "二黄原板",
          "text": "孤离了龙书案——"
        },
        {
          "character": "刘秀",
          "type": "二黄三眼板",
          "text": "把话来讲， 为王的实难舍开国忠良。 孤想起逃难时卿家庄上， 孤单单独一人奔走南阳。 邓先生算八卦带孤私访， 君与臣扮举子扰乱科场。 采鸾殿高得中岑彭小将， 气走了湖阳城马武子章。 鬼神庄老伯母一命身丧， 三年孝改三月、三月孝改三日、三日孝改三时、三时孝改三刻、三刻孝改三分、 三年三月三日三时三刻三分来扶孤王。 白水村初起首灭了王莽， 收二十单八将龙凤呈祥。 可恨那牛邈贼兵马雄壮， 一心心要夺孤锦绣家邦。 老皇兄奉孤旨征剿贼党， 年老迈白发苍苍围困战场。 多亏了小爱卿提兵调将， 杀番贼救父回盖世无双。 孤见他有功臣加官封赏， 职封他猛烈侯绕道还乡。 赐銮驾游御街君欢臣畅， 又谁知郭太师年迈颠狂。 大不该剑劈在府门命丧， 郭娘娘奏一本要斩姚刚。 孤本当赦却了爱卿小将， 怕的是郭娘娘心怀不良。 因此上发至在河北一往， 赐三千人和马保定刘庄。 孤念你东挡西除、南征北剿、昼夜杀砍、马不停蹄、到如今耳聋眼花、年迈苍 苍， 孤念你征南蛮受尽风霜。 孤念你有三子两子身丧， 孤念你白发苍苍只剩得一子姚刚。 孤念你扫烟尘能擒上将， 孤念你秉忠心扶汉兴邦。 剑劈了郭太师但把心放， 千斤担有孤王一人承当。 随孤王进宫去定惊赔罪你须把好言奏上， 为王的戒酒百日、不听谗言、岂斩你开国忠良。 姚皇兄、放宽心、大着胆， 一步一步步步随定孤王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、刘秀同下。"
        },
        {
          "character": "姚期",
          "type": "二黄原板",
          "text": "我主爷走南阳一十二载， 赴科场与邓禹八卦安排。 白水村邓先生兴兵挂帅， 灭王莽扶我主才坐龙台。 小姚刚犯王法满门有害， 发河北去充军才放心怀。 哪里是臣与君把酒来戒， 皆因是老姚期幼年间、东挡西除、南征北剿、功劳浩大、买动了帝王心怀、我 还怕着何来！"
        },
        {
          "character": "姚期",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}