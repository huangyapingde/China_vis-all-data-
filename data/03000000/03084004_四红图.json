{
  "script_id": "03084004",
  "title": "四红图",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "刘化王",
      "hangdang": "丑"
    }
  ],
  "plot": "赵匡胤谋刺刘化王事败，刘化王命杨滚、崔龙画影图形四门缉拿。赵匡胤果为崔龙所获。适有曹仁自外来归，\n以其貌与赵匡胤似，亦为杨捉。崔龙、杨滚上殿争功。刘化王因真假难辨，遂命曹仁之弟曹义家中勘问。\n赵匡胤迫于情，全盘实供。曹氏深感之，反助赵匡胤，杀死刘化王。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠引杨滚同上。"
        },
        {
          "character": "杨滚",
          "type": "点绛唇",
          "text": "掌理朝纲，镇压封疆，雄心壮，何惧强梁？威名俱传讲。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "白发如霜心性刚，帐下三军似虎狼。文韬武略怀智量，恩赐爵位火山王。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "老夫，杨滚。扶保刘王，官居极品，位列朝班。今早主公传下旨意，道赵匡胤 私下燕京，行刺我主。老夫奉旨，把守禁城东门，张挂图形，捉拿刺客赵匡胤。 嘚！众军校，打道上关！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。杨滚、四龙套、四大铠同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹仁上。"
        },
        {
          "character": "曹仁",
          "type": "唱",
          "text": "经营贸易他乡奔， 心怀慈亲转家门。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "俺，曹仁。先父去世，老母在堂。兄弟曹义，在朝居官。俺平生喜走江湖，今 从三江贸易得利而归，回家探母。看天色尚早，前面已是燕京东门，不免打马 归家便了！"
        },
        {
          "character": "曹仁",
          "type": "唱",
          "text": "离别家乡日已深， 千里迢迢少信音。 归家喜得团圆庆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠同上。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "曹仁",
          "type": "唱",
          "text": "因何城边有官兵？"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "因何关前有许多官兵在此？待俺下马过去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹仁下马。杨滚上，看图形、曹仁。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "来，与我拿下了！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠同拿曹仁。杨滚、曹仁、四龙套、四大铠同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手同上，同站门。高怀德、高怀亮同上。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "奉命昼夜守禁门，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "捉拿刺客要小心。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "高怀德。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "高怀亮。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "贤弟请了！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "你我兄弟，奉旨把守南北二门。今闻伯父崔龙在西门拿住刺客赵匡胤，不知是 真是假？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "你我一同入朝，看个明白，也好放心。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "言之有理。一同前往！"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "若是奸人来拿定，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "免却终日费辛勤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引刘化王同上。"
        },
        {
          "character": "刘化王",
          "type": "引子",
          "text": "四时吉庆，每日里，欢乐无穷。"
        },
        {
          "character": "刘化王",
          "type": "念",
          "text": "为君要有道，自然乐逍遥。不论文共武，孤全管得着。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "孤，刘化王。承父大业，坐守燕京。近闻钦天监奏道：仰观天象，赤须火龙压 住孤的星相，故有刺客赵匡胤私下燕京，要摘孤的龙头。已命众卿画影图形， 守住禁门，捉拿刺客赵匡胤。这般时候，未见交旨。 内侍，展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！展放龙门哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔龙上。"
        },
        {
          "character": "崔龙",
          "type": "念",
          "text": "擒得奸细到，定然爵位高。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "臣，崔龙见驾，大王千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "谢坐。恭喜大王！贺喜大王！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "孤王喜从何来哪？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "臣在西门，仗主洪福，拿住刺客赵匡胤，前来交旨。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "怎么着，赵匡胤被你拿住啦？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘化王",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": "杨滚",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚上。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "捉住贼奸细，国运与天齐。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "臣，杨滚见驾，大王千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "老千岁平身。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "赐座！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "谢大王！臣在东门，仗主洪福，拿得刺客赵匡胤，前来交旨。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "啊！你在东门拿住一个赵匡胤？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "崔爱卿，你在西门拿住一个刺客赵匡胤？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "怪呀！只有一个赵匡胤，你们二位，倒是谁拿住的？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "臣在东门照画图拿来，现在殿角以下，有军校看守。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "臣在西门照画图拿来，现在午门候旨。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "你拿住一个？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "是，臣拿住一个。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "你么，也拿住一个？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "是臣拿住一个。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "好！拿住刺客，功劳非小。都带上殿来，孤王观看。"
        },
        {
          "character": "杨滚、崔龙",
          "type": "同白",
          "text": "领旨！ 下面听者！大王有旨：将刺客赵匡胤押上殿来！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠押赵匡胤、曹仁自两边分上。"
        },
        {
          "character": "杨滚、崔龙",
          "type": "同白",
          "text": "刺客当面！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "赵匡胤！赵匡胤！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、曹仁互指。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "闹吧，可倒好，两个全是哑巴。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "刺客，大王唤你，因何不应？"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "呔！俺是草民曹仁，哪个是刺客赵匡胤哪？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "刺客，大王唤你，因何不应？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呔！俺是草民曹仁，哪个是刺客赵匡胤哪？"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "咳！这不糟了吗？二位辛苦劳驾，听见没有？两个都不是。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "启奏大王：臣闻曹义有一兄长，名唤曹仁，难道也有两个不成？"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "是呀！"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "大王，臣将他二人带回衙去，五刑拷打，定有赵匡胤在内。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "也好。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "且慢！何必如此？大王就在金殿亲审，定知真假。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "咳！你们二位真是老糊涂啦。曹义的哥哥名叫曹仁。就把曹义宣来，叫他认认， 就明白啦，费这么大事干什么？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "大王所见不差。臣领旨。 大王有宣：宣曹义上殿！"
        },
        {
          "character": "曹义",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹义上。"
        },
        {
          "character": "曹义",
          "type": "念",
          "text": "丹书将臣诏，忙上九龙朝。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "臣，曹义见驾，大王千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "千千岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "他们是这么回事：杨老千岁在东门拿来了一个刺客赵匡胤，崔大人在西门也拿 来了一个刺客赵匡胤。方才孤家审问，两个都道是曹仁，闹不清楚。宣卿上殿， 想那曹仁是你胞兄，自然你总认得明白。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "今在何处？待臣看来。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "将他们带上殿来！"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "啊！你是兄长曹仁？"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "正是愚兄。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "你是兄长曹仁？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "正是愚兄。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "哪个是令兄啊？"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "这二人俱都一样，真是真假难分。 启奏大王：臣认不出真假。容臣将他二人带回家去，有老少人等，认明回奏。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "这是打哪儿说起，连你也闹不清楚啦？也罢！就命卿带回家去，审明回奏。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "曹义",
          "type": "唱",
          "text": "大王驾前领圣命， 丹墀吩咐众校军。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "御林军！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "曹义",
          "type": "唱",
          "text": "两个刺客来押定！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠押赵匡胤、曹仁同下。"
        },
        {
          "character": "曹义",
          "type": "唱",
          "text": "倒叫世人解不明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹义下。"
        },
        {
          "character": "杨滚",
          "type": "唱",
          "text": "曹府去把二人问， 少时皂白自分清。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚下。"
        },
        {
          "character": "崔龙",
          "type": "唱",
          "text": "辨不出曹仁与赵匡胤， 空费勤劳一片心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔龙下。"
        },
        {
          "character": "刘化王",
          "type": "唱",
          "text": "青天白日如梦境， 两个赵匡胤都叫曹仁。 亲弟亲兄认不准，"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同下。"
        },
        {
          "character": "刘化王",
          "type": "唱",
          "text": "孤王怎能放下心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘化王下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
