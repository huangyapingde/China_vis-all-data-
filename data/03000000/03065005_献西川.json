{
  "script_id": "03065005",
  "title": "献西川",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张松",
      "hangdang": "老生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "庞统",
      "hangdang": "净"
    }
  ],
  "plot": "张松赴许都说曹被逐后，路过荆州。诸葛亮闻知，急遣赵云、关羽迎请张松，更使刘备厚加礼遇。张松感而\n献西川地图于刘备。",
  "notes": "此戏故事紧接《反难杨修》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞、赵云同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "凤眼蚕眉义气豪，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "上阵全凭丈八矛。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "长坂威风谁不晓？"
        },
        {
          "character": "关羽、张飞",
          "type": "同念",
          "text": "桃园结义美名标。"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "姓关名羽子云长。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "姓张名飞字翼德。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "姓赵名云字子龙。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟、四弟请了！"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "今有张松去至中原，要结好于曹操。怎奈他出言冲撞，被乱棍打出。如今他回 转西川，打从荆州经过，不免前去迎接于他，借便打探西川消息。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥说哪里话来！想那张松，生来身躯矮小，诡计多端。此番打此经过，想是 私探俺荆州消息，待俺老张将他擒来，你看如何？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "三将军，想你我桃园兄弟，向以仁义待人，此事万万不可用武。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "四弟此言甚是。你我一同请示大哥便了。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "有请大哥！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "有请主公！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、八马童、诸葛亮、庞统、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "为国忧民，"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "定阴阳，"
        },
        {
          "character": "庞统",
          "type": "引子",
          "text": "旋转乾坤。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "屯军养马在荆州，"
        },
        {
          "character": "诸葛亮、庞统",
          "type": "同引子",
          "text": "救汉室，"
        },
        {
          "character": "刘备、诸葛亮、庞统",
          "type": "同引子",
          "text": "协力同心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、诸葛亮、庞统同坐。"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "参见（大哥）（主公）、两位先生！"
        },
        {
          "character": "刘备、诸葛亮、庞统",
          "type": "同白",
          "text": "少礼！两厢伺候！"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "忆昔结义在桃园，乌牛白马祭苍天。协力同心扶汉室，不知何日灭曹瞒？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤、刘备。坐守荆州，一心匡扶汉室。因此屯兵养马，以待良机。曾闻西川张 松，往说曹操，使兵取汉中，未知如何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "启禀大哥：今有西川张松，被曹操乱棍打出。听他要从荆州经过，大哥何不将 他接来，借此可探听川中之事？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那张松本欲献西川图于曹操，不料曹操因他傲慢，将他乱棍打出，主公正好趁 此机会，向他索取西川地理图。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥！想那张松既然从此经过，待俺老张前去，不用兵将，只要一条麻绳，将 他捆来，何愁西川地图不得？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "张将军，此非用武之事，且莫鲁莽。 赵四将军听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领二十名兵丁，去至二十里堡，准备馆驿，扫清街道，迎接张松进城。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二将军听令！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领五百名军士，严整队伍，在十里长亭，迎接张松入城。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人随同主公在城外等候，迎他入城，酒宴款待，哪怕西川图不得！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "就此带马！"
        },
        {
          "character": "八马童",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "曹孟德作事大有错， 棒打张松却为何？ 但愿西川图归我，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八马童同带马，庞统、诸葛亮、刘备同上马。庞统、诸葛亮同下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "这件事怎瞒得南阳诸葛？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四马童引赵云同上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺、赵云，奉了军师之命，在二十里堡，准备馆驿，清扫街道，等候张松，就 此前往！"
        },
        {
          "character": "四马童",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、赵云同走圆场，二童儿引张松同上。"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "不分昼夜奔荆襄， 一路之上马蹄忙。 勒住丝缰用目望， 见一武将站道旁。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "迎接张先生！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "请问将军是何人也？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺乃常山赵子龙。奉了我主之命，迎接张先生到馆驿暂歇，少时一同进城。"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "我道是谁，原来是子龙将军。久仰得很！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "想张松乃西川一末吏，怎敢劳动将军前来迎接，请将军先行，松随后即至也！"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "将军威名天下震， 长坂坡前立功勋。 七进七出威风凛， 杀退曹操百万兵！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "我与大夫把路引， 快请台驾来进城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、赵云同下。"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "童儿与我把马顺， 见了皇叔叙衷情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二童儿、张松同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、二马童、关羽自下场门同上，同列队立候。二童儿引张松自上场门同上。"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "来在道旁用目望， 见一虎将面带红光。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "迎接张先生！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "请问将军是何人也？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺乃关羽。闻得大夫远路而来，奉了大哥之命，恭迎大夫进城。"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "久闻大名，如雷贯耳！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "今日幸得相逢，可谓欣幸之致也！"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "手挽手，把话讲， 今日得见关云长。 丹凤眼，蚕眉长， 五绺长髯飘飘在胸膛。 过五关，斩六将， 在古城弟兄相会擂鼓斩过蔡阳。 果算是当世英雄将， 你前来相迎我怎敢当！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "深施一礼把马上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上马。四校尉、二马童、关羽同下。"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "当世豪杰关云长。 童儿带马朝前往， 荆州城会一会刘、关、张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二童儿、张松同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张飞、庞统、诸葛亮、刘备自下场门同迎上，同立候于城侧。二童儿、张松同上，张松下马。"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "皇叔！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大夫！请！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "还是皇叔请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你我挽手而行。啊？"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "刘备、张松",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同进城，同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、二旗牌、张飞、庞统、诸葛亮、刘备、张松同上，张飞、庞统、诸葛亮、刘备、张松同入座。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大夫远道而来，风尘跋涉。备未能远路相迎，尚乞恕罪！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "松乃西川末吏，有何德能，敢劳皇叔亲迎于城外？当面请罪！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "岂敢。 来，看宴伺候！"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大夫请！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "皇叔请！"
        },
        {
          "character": "刘备、诸葛亮、庞统、张飞",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。张飞、庞统、诸葛亮、刘备、张松同入席。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待我与大夫把盏。"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "这就不敢！啊此位是？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这就是诸葛先生。"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "啊！敢是隐居隆中、躬耕南阳、自比管乐的诸葛先生？今日一见，果然名不虚 传。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "大夫夸奖了！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "这位是？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这就是庞士元庞先生。 来来来，见过大夫！"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "啊！凤雏先生，前在江东，献连环之计，烧退曹兵百万，真乃奇人也！"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "足智多谋庞士元， 曾在东吴献连环。 烧退曹兵有百万， 可算当今一奇男！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "啊皇叔，人言卧龙、凤雏乃当今贤士，若得其一，即成大事。今皇叔俱都聘请 前来，眼前定成霸业也。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊哈大夫！想你姓张，俺也姓张，五百年前是一家。你今到此，别无可敬，来！ 来！来！待俺老张敬你三大杯。 来！"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大杯伺候！"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌甲换大杯斟酒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊大夫请！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "三将军请！"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "忆昔大战在当阳， 大吼一声断桥梁。 喝退曹兵百万将， 落得美名天下扬。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "夸奖了！"
        },
        {
          "character": "张飞",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞敬酒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大夫再饮几杯。"
        },
        {
