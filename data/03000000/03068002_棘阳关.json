        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "众将官，棘阳关去者！"
        },
        {
          "character": "贾复、杜茂、王霸、吴汉、姚期",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。场设城门。县官暗上。"
        },
        {
          "character": "贾复、杜茂、王霸、吴汉、姚期",
          "type": "同白",
          "text": "开城！"
        },
        {
          "character": "县官",
          "type": "白",
          "text": "什么人叫城？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "太夫人向前答话。"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "遵命。 棘阳县听者！如今我母子已降刘主，现有棘阳印信，速速开城！"
        },
        {
          "character": "县官",
          "type": "白",
          "text": "众将官，开城！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "县官下。开城。四龙套、姚期、刘秀、邓禹、岑母、贾复、杜茂、王霸、吴汉同进城。"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "君臣且把棘阳上，"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "我儿到来劝他降。"
        },
        {
          "character": "岑彭",
          "type": "内西皮导板",
          "text": "这一阵杀得我魂飞魄荡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。岑彭上。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "口吐鲜血冒红光。 人马扎在棘阳上， 我与马武动刀枪。 杀得众将魂魄丧， 卸甲丢盔败疆场。 勒住丝缰用目望， 大骂贼子夺棘阳。 老母因何遭罗网？ 一一从头说端详。"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "我儿带兵在疆场， 不幸为娘遭祸殃。 因此才把城献上， 劝儿快快早归降。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "听罢言来魂魄丧， 无故连累白发娘。 孩儿忠心保王莽， 岂肯背主降刘王？"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "我儿说话不思量， 王莽谋篡汉家邦。 如今城破家又散， 我儿不降也要降！"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "母亲把话错来讲， 忠孝二字付汪洋。 情愿战死沙场上， 留下美名万古杨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武上，马武、岑彭同开打，马武擒岑彭，进城，下。众人同下。"
        },
        {
          "character": "岑彭",
          "type": "stage",
          "text": "【十三场】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、姚期、刘秀、邓禹、岑母、贾复、杜茂、王霸、吴汉同上，同挖门。马武上。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "报！岑彭拿到。"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "将岑彭绑上帐来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武下。〖急急风〗。马武绑岑彭同上。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "绳捆索绑将岑彭， 不由豪杰怒气生。 迈步且把宝帐进， 看他把我怎样行！"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "一见岑彭被生擒，"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "再与奴才说分明。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "唗！胆大岑彭！见了我主，因何不跪？"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "俺乃堂堂男子，岂肯跪你！"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "儿啊，事到如今，城破家亡，就改归顺刘主的才是。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "母亲！儿幼年曾受我父教训：为臣要忠，为子要孝。母亲既陷孩儿于不忠，孩 儿也不能全孝于母亲。如今孩儿心如铁石，母亲不必多讲，孩儿有死而已！"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "儿啊！非是为娘陷儿于不忠。自古道：良禽择木而栖，贤臣择主而事。想那王 莽，为臣不忠，以小犯上，篡了汉室江山，神人共怒。有道是：乱臣贼子，人 人得而诛之。那王莽既不忠于汉室，我儿又何必忠于王莽？如今汉室中兴，刘 主有道，我儿就应天顺人，弃暗投明，日后落一个青史名标。为娘虽然不能受 享荣华，死后也免得骂名千载。如今吾儿执意不降，为娘也无颜立于人世。也 罢！为娘一头碰死，也好见那去世的先人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑母欲碰壁。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "母亲不必如此，孩儿情愿归降。"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "这便才是。 啊贵人！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "伯母！"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "吾儿他归顺了。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "待我亲自松绑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘秀与岑彭松绑。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "多谢贵人！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "岑将军归顺小王，伯母真乃教子有方。"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "贵人夸奖了"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "汉刘主他本是亲支近脉， 不由得老身笑开怀。 我儿今日来降汉， 从今后必须要齐心努力扶保龙台。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "贵人休把我来怪， 岑彭降迟大不该。"
        },
        {
          "character": "刘秀",
          "type": "唱",
          "text": "岑将军真心来归顺， 忠孝二字美名排。"
        },
        {
          "character": "马武",
          "type": "唱",
          "text": "适才间马武莽撞得罪了你， 我上前施一礼、赔上一个不是、打我几下也应该。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "适才间在阵前哪一个把你来怪？"
        },
        {
          "character": "刘秀",
          "type": "唱",
          "text": "有道是各为其主莫挂心怀。"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "来来来我的儿见一见军师邓元帅。"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "也是我才疏学浅无有将才。"
        },
        {
          "character": "刘秀",
          "type": "唱",
          "text": "姚皇兄你把家中的事儿说个大概，"
        },
        {
          "character": "姚期",
          "type": "唱",
          "text": "奉母命打柴度日、三次聘请、老母尽忠一死就命赴阳台。"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "最可叹姚母如今命不在， 儿要是比姚期除非是转世又投胎。"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "中军帐，"
        },
        {
          "character": "马武、姚期",
          "type": "同唱",
          "text": "把宴排，"
        },
        {
          "character": "岑母、岑彭",
          "type": "同唱",
          "text": "休要款待，"
        },
        {
          "character": "刘秀",
          "type": "唱",
          "text": "大放开怀。"
        },
        {
          "character": "姚期",
          "type": "唱",
          "text": "来来来！"
        },
        {
          "character": "马武",
          "type": "唱",
          "text": "我的老太太！"
        },
        {
          "character": "刘秀、邓禹",
          "type": "同唱",
          "text": "请请请！"
        },
        {
          "character": "马武、姚期",
          "type": "同唱",
          "text": "走走走！"
        },
        {
          "character": "刘秀、邓禹、姚期、马武、岑母、岑彭",
          "type": "同唱",
          "text": "大家一同把宴排，细说开怀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}