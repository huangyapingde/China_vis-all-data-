{
  "script_id": "03068002",
  "title": "棘阳关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "岑彭",
      "hangdang": "武生"
    },
    {
      "name": "岑母",
      "hangdang": "老旦"
    },
    {
      "name": "马武",
      "hangdang": "净"
    },
    {
      "name": "刘秀",
      "hangdang": "小生"
    },
    {
      "name": "邓禹",
      "hangdang": "老生"
    }
  ],
  "plot": "刘秀进兵棘阳关，守将岑彭不降。邓禹用计接去岑母。岑母以死相劝，岑彭终归汉。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾复、王霸、杜茂、吴汉同上，同起霸。〖点绛唇〗。"
        },
        {
          "character": "贾复",
          "type": "白",
          "text": "贾复。"
        },
        {
          "character": "王霸",
          "type": "白",
          "text": "王霸。"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "杜茂。"
        },
        {
          "character": "吴汉",
          "type": "白",
          "text": "吴汉。"
        },
        {
          "character": "贾复",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "王霸、杜茂、吴汉",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "贾复",
          "type": "白",
          "text": "幼主升帐，两厢伺候！"
        },
        {
          "character": "王霸、杜茂、吴汉",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、四上手引姚期、邓禹、刘秀同上。"
        },
        {
          "character": "刘秀",
          "type": "念",
          "text": "只为复国走南阳，"
        },
        {
          "character": "邓禹",
          "type": "念",
          "text": "保主重整锦家邦。"
        },
        {
          "character": "姚期",
          "type": "念",
          "text": "可叹老母命早丧，"
        },
        {
          "character": "刘秀、邓禹、姚期",
          "type": "同念",
          "text": "扫灭王莽称心肠！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "先生，想我汉家被莽贼谋篡，药酒毒死先皇，小王逃出咸阳。多亏先生、姚皇 兄与众位将官扶保小王，重整汉室。马皇兄攻打洮城，不知胜负如何，叫小王 放心不下。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "主公兴兵以来，攻无不取，战无不胜。量那小小洮城，何难收复？且听探马一 报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！马将军得胜回城。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "贾复、王霸、杜茂、吴汉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": "贾复、王霸、杜茂、吴汉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套、四大刀手引马武同上，大纛旗随上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（场设城门。〖吹打〗。刘秀、邓禹、姚期、贾复、王霸、杜茂、吴汉、四龙套、四上手同出城，马武、四"
        },
        {
          "character": null,
          "type": "text",
          "text": "龙套、四大刀手、大纛旗同上，同进城，同下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（刘秀、邓禹、姚期、贾复、王霸、杜茂、吴汉、四龙套、四上手同上，马武、四龙套、四大刀手、大纛旗"
        },
        {
          "character": null,
          "type": "text",
          "text": "同上，同挖门。）"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "臣、马武。奉军师将令夺取洮城，托我主洪福，唾手而得。现有洮城印信，请 军师观看。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "此乃马将军之功。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "马皇兄听封：今将洮城印信归你执掌，封你为骠骑将军，世袭洮城牧。 左右摆宴，与马皇兄贺功。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "谢主隆恩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。刘秀、邓禹、姚期、马武、贾复、王霸、杜茂、吴汉同饮酒。探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！启禀军师：今有岑彭带领人马，城外叫骂，口口声声要与洮城报仇。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "贾复、王霸听令！"
        },
        {
          "character": "贾复、王霸",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "大战岑彭，不得有误！"
        },
        {
          "character": "贾复、王霸",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾复、王霸同下。三冲头。乱锤。贾复、王霸同上。"
        },
        {
          "character": "贾复、王霸",
          "type": "同白",
          "text": "大败而归。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "杜茂、吴汉听令！"
        },
        {
          "character": "杜茂、吴汉",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "大战岑彭，不得有误！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜茂、吴汉同下。三冲头。乱锤。杜茂、吴汉同上。"
        },
        {
          "character": "杜茂、吴汉",
          "type": "同白",
          "text": "大败而归。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "众位将军！"
        },
        {
          "character": "姚期、马武、贾复、王霸、杜茂、吴汉",
          "type": "同白",
          "text": "军师！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "那岑彭小儿十分骁勇。那位将军出城会他一阵，以慰圣心？"
        },
        {
          "character": "马武、姚期",
          "type": "同白",
          "text": "末将愿往。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "为何拦阻？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "马将军鞍马劳乏，多受辛苦。此事待我姚期走走。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "为主江山，何言劳乏！倘若你不能取胜，岂不被他人耻笑？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "马将军！你休要不自量。想当年在武科场，那王莽中了岑彭，不中于你，你心 中不忿，要与岑彭比武。不想你将马缰挣断，被岑彭打下马来。因此气走咸阳。 此番你再要出兵，岂不是白白送死？此事非俺姚期不可！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你怎么讲？"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "非俺姚期不可！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "哇呀呀……"
        },
        {
          "character": "马武",
          "type": "唱",
          "text": "听他言来怒满膛， 活活气死马子张。 我若不擒岑彭将， 情愿战死在疆场。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "你不能！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你不能！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "二将不必来争斗， 为国勤劳解忧愁。 斩将擒王功劳有， 凌烟阁上把名留。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "二位将军不必争论，同到敌楼一观！"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "同到敌楼来观斗，"
        },
        {
          "character": "刘秀",
          "type": "唱",
          "text": "众将保驾量无忧。"
        },
        {
          "character": "马武",
          "type": "唱",
          "text": "我今定斩贼人首！"
        },
        {
          "character": "姚期",
          "type": "唱",
          "text": "败将何必强出头？"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "军家胜败古常有，"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘秀、邓禹、姚期、马武、贾复、王霸、杜茂、吴汉同上马，同上城，同下马。"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "又只见旌旗遮日、杀气连天鬼神愁。"
        },
        {
          "character": "岑彭",
          "type": "内西皮导板",
          "text": "旌旗招展空翻影！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、周彬、周奎、岑彭同上，大纛旗随上。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "马到疆场似风云。 帐下儿郎威风凛， 刀枪剑戟鬼神惊。 号炮一响似雷震， 大骂刘秀你快出城！"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "人喊马嘶战场进， 岑彭小儿似天神。 王莽本是贼奸佞， 心怀谋逆害先君。 将军若是承天运， 扶保我主再整乾坤。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "听罢言来怒满腔， 抬头只见马子张。 曾记当年武科场， 枪挑马下脸无光。 尔若自称英雄将， 下得城来摆战场。 沽名钓誉无能将，"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "贪生怕死！"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "你就免到疆场。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "岑彭我儿休要猖狂，俺马老子来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开城。马武领四上手同出城。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "马武看枪！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "岑彭，我的儿啊！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "马武！想当年武科场中，被我挑下马来，抱头鼠窜而逃。今日兵困棘阳关，难 道你就不惜性命吗！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "岑彭，我的儿呀！想当年武科场，那王莽中了你的相貌，不中俺马武的奇才。 是俺与你比武，俺的马缰扯断，你将俺马武摔下马来。那王莽道俺是无能之辈， 事到如今，冤仇未报，恶气未消。今日相逢，岂能饶你！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "满口胡言！放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武、岑彭同起打，打快枪，架住，岑彭、四龙套、四下手、周彬、周奎、马武、四上手同下。"
        },
        {
          "character": "邓禹",
          "type": "唱",
          "text": "本帅敌楼来观阵， 只见两家动刀兵。 一个银枪威风凛， 一个猛勇似天神。 本帅急忙传将令， 姚期将军听分明： 急忙出城来助阵， 帮助马武把功成。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期下。岑彭、四龙套、四下手、周彬、周奎、马武、姚期、四上手同上，同打，架住。内鸣金声。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "敢是怯战？"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "我家元帅鸣金收兵，明日再战。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "明日来者？"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "君子。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "不来？"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "岂肯失信于你！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "收兵去吧！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "众将官，收兵！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "马武",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武、姚期、四上手同进城。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "回营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘秀、邓禹、贾复、王霸、杜茂、吴汉同下"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四龙套同挖门。县官上，迎接。"
        },
        {
          "character": "县官",
          "type": "白",
          "text": "太守，胜负如何？"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "两军阵前，未分胜败。他家鸣金收兵，明日再战。命你带领三军，饱餐战饭， 三更时分，听我号令。城外扎营去吧！"
        },
        {
          "character": "县官",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "县官下。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "我不免去到后堂，问候老母金安。正是："
        },
        {
          "character": "岑彭",
          "type": "念",
          "text": "欲逞男儿刚强志，终日常怀社稷忧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟搀岑母同上。"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "想当年老王爷把江山来创， 斩白蛇灭秦楚登基咸阳。 至孝平出了个奸贼王莽， 毒药酒酖先皇命丧无常。 汉家后起义师招兵聚将， 但愿得汉室兴早灭奸王。 我的儿保奸贼痴心妄想， 愿我儿归汉家落一个万古名扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭上。"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "在疆场与刘贼打了一仗， 但愿得扫狼烟扶保家邦。 将身儿我且把二堂来上， 见萱堂施一礼儿问安康。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "母亲在上，孩儿拜揖！"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "吾儿少礼，一旁坐下。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "儿谢坐！"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "我儿今日出兵，与何人交战？"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "母亲有所不知，今有刘秀命邓禹为帅，带领马武、姚期与孩儿交战。两家不分 胜负，天色已晚，鸣金收兵。明日定要扫灭此贼！"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "儿啊，想当年高祖先皇受尽千辛万苦，闯荡山河，不想被莽贼谋篡。幸有刘贵 人重整汉室，自南阳起义，攻无不取，战无不胜，可见汉室气数未尽。想我儿 身为大将，就该应天顺人。有道是：知时务者方为俊杰。依为娘相劝，趁此机 会弃暗投明，扶保汉室，日后不失封侯之位。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "母亲说哪里话来！儿幼年蒙我父教训：为臣要忠，为子要孝。想孩儿既扶保莽 主，生为莽臣，死为莽鬼。有道是：食君之禄，当报王恩。若叫孩儿降汉，除 非是日从西起！"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "儿呀，我有一言，你且听了！"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "叫岑彭我的儿听娘教训， 有为娘一件件细说分明。 你的父汉司马官居极品， 儿就该答报那汉室恩情。 王莽贼谋篡位天下怨恨， 为臣者怎能够心怀异志、叛主杀君、留下了千载骂名！"
        },
        {
          "character": "岑彭",
          "type": "唱",
          "text": "老娘亲说此话全不思忖， 孩儿言来细听详情： 儿的父为司马执掌帅印， 为什么一旦间削职为民？ 幼年间儿的父将我教训， 食君禄必须要答报王恩。"
        },
        {
          "character": "岑母",
          "type": "唱",
          "text": "听他言来心自忖， 奴才果然铁打心。 千言万语劝不醒， 再想良策弃暗投明。"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "儿啊，为娘再三相劝，我儿执意不听。如今为娘不愿在城内居住，去到城外寻 一个僻静所在安身。今晚准备车辆将为娘护送出城，我儿的战事，为娘是不闻 不问，任凭吾儿所为。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "母亲既然要出城避静，孩儿也不敢阻拦，谨遵母命。请母亲后面收拾收拾。"
        },
        {
          "character": "岑母",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "岑母",
          "type": "念",
          "text": "忠言逆耳成何用！"
        },
        {
          "character": "岑彭",
          "type": "念",
          "text": "男儿立志报王恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟搀岑母同下。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "众将走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、周彬、周奎同上。"
        },
        {
          "character": "周彬、周奎",
          "type": "白",
          "text": "参见元帅，有何将令？"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "今晚三更时分，本帅护送老母出城。命你等一更饱食战饭；二更人马齐备；三 更齐跨雕鞍，绕敌营而走，前去接应，不得有误！"
        },
        {
          "character": "周彬、周奎",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "岑彭",
          "type": "念",
          "text": "令出山摇动，"
        },
        {
          "character": "周彬、周奎",
          "type": "同念",
          "text": "言发鬼神惊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
