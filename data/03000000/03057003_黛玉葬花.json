{
  "script_id": "03057003",
  "title": "黛玉葬花",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "林黛玉",
      "hangdang": "旦"
    },
    {
      "name": "贾宝玉",
      "hangdang": "小生"
    }
  ],
  "plot": "薛宝钗夜访贾宝玉，林黛玉旋至，扣环，丫鬟拒之。林黛玉疑贾宝玉薄己，次日荷锄至园中，见落花，愈伤\n身世，乃赋诗葬花。贾宝玉至，表明心迹，言归于好。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉上。"
        },
        {
          "character": "贾宝玉",
          "type": "西皮摇板",
          "text": "无可奈何花落去， 最难消受美人怜。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "小生、贾宝玉。适才去到“潇湘馆”看望林妹妹。那紫鹃丫头与我倒茶。是我 言道：“好丫头，我若得与你多情小姐同鸳帐，怎舍得叫你叠被铺床。”一句 戏言不大要紧，谁知林妹妹恼了我了。她虽然恼我，必定心许，我好侥幸也！"
        },
        {
          "character": "贾宝玉",
          "type": "西皮摇板",
          "text": "醉香莫被风吹醒， 寻梦归来自掩门。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "开门来！"
        },
        {
          "character": "晴雯",
          "type": "内白",
          "text": "是谁呀？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "连我的声音都听不出来了？"
        },
        {
          "character": "晴雯",
          "type": "内白",
          "text": "噢，宝二爷回来啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晴雯上，开门，贾宝玉进门，晴雯关门。"
        },
        {
          "character": "薛宝钗",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛宝钗上。"
        },
        {
          "character": "薛宝钗",
          "type": "西皮二六板",
          "text": "庭皋向晚日昏黄， 阵阵东风拂柳塘。 落花无主春骀宕， 新来燕子借画梁。 含情迤逦穿花障， 小步茅尘绣鞋香。 行过了小桥"
        },
        {
          "character": "薛宝钗",
          "type": "西皮散板",
          "text": "抬头望， 怡红院落在哪厢？"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "奴、薛宝钗。春倦无聊，因此要看看宝兄弟，借些诗词消遣。来此已是“怡红 院”，待我来扣门。 啊，开门来！"
        },
        {
          "character": "贾宝玉",
          "type": "念",
          "text": "隔帘花影动，疑是玉人来。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "门外是哪个？"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "连我的声音都听不出来了么？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "原来是宝姐姐来了，待我亲自开门。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉开门。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "姐姐请进！"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛宝钗进门，贾宝玉关门。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "啊，姐姐光降，不胜荣幸之至。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "这几日林妹妹可曾来过呀？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "不曾来，想必是又恼了我了。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "见着她的时候，赔个礼儿也就是了。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "是啊，赔个礼儿也就完了。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "兄弟，可有什么新诗新词，借来消遣。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "现有一绝妙好词在此，姐姐请看。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "一同看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛宝钗、贾宝玉同看诗，薛宝钗唱一段昆曲。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "外面风大，将窗儿关上了吧！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "关上了吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉关窗，贾宝玉、薛宝钗同下。"
        },
        {
          "character": "林黛玉",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉上。"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "欲把幽情诉明月， 不辞风露立花阴。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "来此已是“怡红院”，但不知宝哥哥他在里面作些什么？待我扣门。 啊，开门来！"
        },
        {
          "character": "晴雯",
          "type": "内白",
          "text": "又是谁呀？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "开门来，是我。"
        },
        {
          "character": "晴雯",
          "type": "内白",
          "text": "今晚上宝二爷吩咐啦，无论谁来，都不开门，有话明儿个再说吧！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "哎呀且住！平日到此，宝哥哥总是以礼相待，今日为何如此？这是什么缘故？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "幕内笑声。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "听这笑声，分明是宝姐姐在内。啊，原来她在里面，竟将我这般看待，这才是 我寄人篱下的苦处噢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉哭。"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "妒煞蛾眉天不管， 满城风絮正愁人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉哭。紫鹃上。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘，晚上风大，露气又重，一个人在这儿伤心，刚吃完了药，倘若是再着了 凉，那还了得吗！请您回去吧！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "怎么，回去么？"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "是，回去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "幕内笑声。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "哎，回去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃引林黛玉同下。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "天时不早，我要回去了。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "待我掌灯相送。"
        },
        {
          "character": "薛宝钗",
          "type": "白",
          "text": "不敢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛宝钗、贾宝玉同出门。"
        },
        {
          "character": "薛宝钗",
          "type": "唱",
          "text": "新词有味情无尽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛宝钗下。"
        },
        {
          "character": "贾宝玉",
          "type": "唱",
          "text": "红烛新擎送美人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉上。"
        },
        {
          "character": "林黛玉",
          "type": "引子",
          "text": "春去无痕，莽天涯，怎不消魂？"
        },
        {
          "character": "林黛玉",
          "type": "念",
          "text": "长安三月踏春阳，处处春阳总断肠。红瘦绿肥人寂寞，杜鹃声里吊余芳。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "奴、林黛玉。幼失怙恃，多蒙外祖母史太君抚养，寄居在荣国贾府之中。诸姑 伯姐妹都是另眼相看，只有表哥宝玉，也不知他情之真假？昨晚偶过“怡红院”， 他竟是闭门不理。咳，想我林黛玉呵！"
        },
        {
          "character": "林黛玉",
          "type": "西皮慢板",
          "text": "春光好都付与工愁善病， 辜负了艳阳天美景良辰。 奴好比失群雁天边只影， 奴好比萍和梗湖内飘零。 花如烟柳如雾"
        },
        {
          "character": "林黛玉",
          "type": "西皮散板",
          "text": "落红成阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉弹琴。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "林黛玉",
          "type": "西皮散板",
          "text": "这焦桐却为何弹不成声？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉看书。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "偏偏翻到这里来了，“良辰美景奈何天，赏心乐事谁家院？”这不是杜丽娘伤 春之词么，怎么她也是这样的情怀呀？"
        },
        {
          "character": "林黛玉",
          "type": "西皮散板",
          "text": "这几日闷恹恹春将人困， 却教我对何人去诉衷情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉哭。紫鹃上。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "我们姑娘又在这儿哭哪。 哎，姑娘，今儿个乃是饯花盛会，各房的姑娘、奶奶都在亭子上送春，等候姑 娘前去联诗饮酒哪。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "送春么？"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "春到哪里去了，怎么不叫它回来？"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "春去无言，叫我哪儿去找哪？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "怎么，春去无言？"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "哎，紫鹃，安顿花锄，我要葬花去了。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "外面春风似剪，姑娘不去也罢！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "你看，花谢花飞，一片片沾泥随水，世间薄命的人儿还不是与落花一样么？快 去拿来！"
        },
        {
          "character": "紫鹃",
          "type": "西皮散板",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃下。"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "扫香帚贮红囊花锄一柄，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃拿花锄上，交林黛玉。"
        },
        {
          "character": "林黛玉",
          "type": "西皮散板",
          "text": "去到那沁芳桥葬玉埋春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉下。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "想我们姑娘与宝二爷，从小就在一块儿长大，彼此十分相爱。他们的年纪一天 大似一天，相爱也一天盛似一天，这烦恼也就一天多似一天。据我看来，既是 相爱，就该彼此原谅才是，每天牵愁惹恨，是何苦来哪！正是："
        },
        {
          "character": "紫鹃",
          "type": "念",
          "text": "两情只要能常久，何必朝朝暮暮愁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉上。"
        },
        {
          "character": "贾宝玉",
          "type": "西皮摇板",
          "text": "昨夜晚怨东风无端蹂躏， 满园春吹遍了一片愁云。 林妹妹她本是惜花如命， 因何故这时候不到园林？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "小生、贾宝玉。今日到此，一来是赴饯花盛会，二来得罪了林妹妹，等她到来， 赔个礼儿便了！"
        },
        {
          "character": "贾宝玉",
          "type": "西皮摇板",
          "text": "我这里扫残红独穿花径， 早来到埋香处流水孤坟。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "你看梨花飘雪，柳絮飞棉。倘若俺林妹妹看见，一定是格外伤感。待俺将落花 扫起，等她到来，也晓得我一片痴心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉扫花。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "远望一个女子，隐约行过花丛，想必是林妹妹来了。俺不免闪在一旁，听她说 些什么？正是："
        },
        {
          "character": "贾宝玉",
          "type": "念",
          "text": "隔林听燕语，掬水奠花魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "林黛玉",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉上。"
        },
        {
          "character": "林黛玉",
          "type": "二黄摇板",
          "text": "碧云天芳草地蜂愁蝶怨， 乱莺声啼不住似水流年。 绕疏篱穿曲径遮遮掩掩， 冷清清一坯土谁荐寒泉？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉暗上。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "来此已是葬花之所。这香冢之旁是哪个有心人替我扫了一堆花瓣，莫非就是那 宝——咳，像他那样负心之人，哪里有这样细腻的心情啊！"
        },
        {
          "character": "林黛玉",
          "type": "反二黄原板",
          "text": "林黛玉把花锄无限凄怆， 繁华散花事尽难怨东皇。 可怜你莽天涯随风飘荡， 一年间消受得几日风光。 说什么护花枝金铃为障， 说什么渡花魂宝筏成航。 侬葬花人道我情魔万丈， 到后来侬与花一样下场。 可怜奴赋招魂泪和花葬， 从今后春渺渺地老天荒。 侬今葬花人笑痴， 他年葬侬知是谁呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉哭。贾宝玉哭。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "人家都道我是个痴子，听那边厢又有啼哭之声，难道还有个痴子不成么？待我 看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉回头看。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "我道是谁，原来是那狠心短命的——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉走。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "妹妹不要走。说完一句话，大家撩开手，好是不好？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "宝二爷，有什么吩咐？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "话是有一句，不知道当讲不当讲？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉欲走。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "咳，既有今日，何必当初！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "这句话倒要问问你，今日怎么样？当初又是怎么样？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "当初我与妹妹是怎样的好法：一同起坐，一同吃饭，一同玩耍；我有爱吃的东 西知道妹妹你也爱吃，就留下来，等着妹妹一同吃；有丫头、老妈子们想不到 的事情，我样样都替她们想到，为的是怕妹妹你生气，谁知你人大心大，偏偏 爱与那外四路的什么凤姐姐、宝姐姐要好，拿我放在一旁，三日不理，四日不 睬，我就是死了，也是个屈死的鬼，任凭有高僧高道超渡，妹妹你要是不说明 这个缘故，我也是不能超生的呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉、林黛玉对哭、对看。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "你不要在这里骗我，还是请回去把那门关上吧！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "啊，妹妹，这是哪里说起，我一点也不明白呀？"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "昨晚我偶过“怡红院”，你为什么闭门不理？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "妹妹，实在无有此事。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "还说无有此事，人家站在门外，连腿都站酸了！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "妹妹要是不信，我就跪下来赌咒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉跪。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "皇天在上，我宝玉若有半句虚言，罚我掉在水里，变个大大的乌龟。等妹妹百 年之后，与你驮一辈子的石碑，妹妹相信了吧？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉笑。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "或是丫鬟、老妈子不好，不起来开门也是有的。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "丫鬟、老妈子不好，待我回去重重地责罚她们。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "是要责罚责罚才是。今日得罪了我不要紧，倘若得罪了什么宝姑娘，那就闹大 了！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "她又提起宝姐姐来了！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "这香冢之旁一堆花瓣，是你扫来的么？"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "咳，看将起来，还是他才有这样的心情啊！"
        },
        {
          "character": "林黛玉",
          "type": "西皮摇板",
          "text": "你我问春春不管， 伤心断肠有谁怜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉、贾宝玉同哭。紫鹃上。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "啊，宝二爷也在这哪？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾宝玉、林黛玉忙拭泪。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "紫鹃姐姐！"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘，老太太等您吃饭哪！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "将花锄带了回去！"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃下。"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "贾宝玉",
          "type": "念",
          "text": "流水落花春去也，"
        },
        {
          "character": "林黛玉",
          "type": "念",
          "text": "独留青冢向黄昏。"
        },
        {
          "character": "紫鹃",
          "type": "内白",
          "text": "姑娘来吧！"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "噢，来了！ 宝哥哥你也来呀！"
        },
        {
          "character": "贾宝玉",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉、贾宝玉同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}