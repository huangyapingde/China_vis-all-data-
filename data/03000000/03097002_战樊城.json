{
  "script_id": "03097002",
  "title": "战樊城",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "伍尚",
      "hangdang": "老生"
    },
    {
      "name": "费无极",
      "hangdang": "净"
    },
    {
      "name": "伍奢",
      "hangdang": "老生"
    },
    {
      "name": "鄢将师",
      "hangdang": "丑"
    },
    {
      "name": "武城黑",
      "hangdang": "武净"
    },
    {
      "name": "家将",
      "hangdang": "小生"
    }
  ],
  "plot": "楚平王听信费无极谗言，囚伍奢，并命其修书召子伍尚、伍员进京，一并杀之。时伍尚、伍员镇守樊城，见\n书后，伍员心疑，劝伍尚勿受命。伍尚不听，至京见父，被执，与父同时遇害。楚平王又命武城黑带兵至樊\n城，捉拿伍员，伍员不敌，弃城逃。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、伍员同上。"
        },
        {
          "character": "伍尚",
          "type": "念",
          "text": "边外狼烟尽，"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "共享太平春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、伍员同坐。院子暗上。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长自到樊城以来，为何终日愁闷？"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟，你我弟兄镇守樊城，不知爹娘可安泰否？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "吉人自有天相，兄长何必挂怀！"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "来，伺候了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师上。"
        },
        {
          "character": "鄢将师",
          "type": "念",
          "text": "离了京都地，来此是樊城。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "门上哪位在？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "烦劳通禀：京都下书人求见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "候着。 启禀二位老爷：京都差来下书人求见。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "书先进，人落后。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "来人呢？书先进，人落后。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "书信在此。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师暗下。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "书信呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、伍员同看书。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "“伍尚、伍员开拆”。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟请看。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长请看。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "你我同拆同观。 爹娘在上，恕孩儿不孝之罪。"
        },
        {
          "character": "伍尚",
          "type": "西皮原板",
          "text": "未曾拆书泪淋淋， 纸上相逢父子情。 平王思念临潼会， 伍尚、伍员早回京。 外加走字多劳顿， 骏马十匹莫留停。 看罢书信心喜甚，"
        },
        {
          "character": "伍员",
          "type": "西皮散板",
          "text": "伍员心中暗沉吟。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟请看。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "“外加走字，骏马十匹”，兄长可解？"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "愚兄不解。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "此乃“逃走”二字。唤下书人，一问便知明白。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "来，唤下书人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师暗上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "下书人，老爷传你，小心了。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "是。 下书人与二位老爷叩头。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "罢了。起来。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "多谢二位老爷。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "下书人，你叫什么名字？"
        },
        {
          "character": "鄢将",
          "type": "白",
          "text": "师小人名叫鄢将师。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "我且问你：你是新进相府，还是久在相府？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "新进相府。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "太老爷？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "安泰。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "太夫人？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "福寿康宁。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "书信何人所交？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "内封外发。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "调我弟兄进京，所为何事？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "讲。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "无非是加官受爵。"
        },
        {
          "character": "伍员",
          "type": "笑",
          "text": "呵呵呵……"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "外厢伺候！"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师下。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟，听下书人之言，书信是真的了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "有道是：将在外君命有所不受。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟呀！"
        },
        {
          "character": "伍尚",
          "type": "西皮原板",
          "text": "贤弟休要太烈性， 有辈古人向弟云： 文王被囚遭陷阱， 伯邑考粉身救父身。 这都是前辈古人等， 留下了美名万古存。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长！"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "兄长说话欠思忖， 休把今人比古人。 文王被囚天注定， 伯邑考丧身命里生成。 既是平王——"
        },
        {
          "character": "伍员",
          "type": "西皮二六板",
          "text": "加官赠， 就该有圣旨到樊城。 若是爹娘修书信， 为何有“逃走”二字在书后明？ 怕的是失足落陷阱， 插翅不能远飞腾。 小弟愿把樊城镇， 宁做个不忠不孝的人。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "千言万语他不听， 一心镇守在樊城。 长子必须遵父命， 是好是歹走一程。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟，听你之言，是不进京的了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "凶多吉少，不去的为妙。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "也罢。待愚兄一人进京就是。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长一人进京，小弟放心不下，命家将跟随侍奉。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "但凭贤弟。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "传家将走上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "家将走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "念",
          "text": "俺本英雄好汉，侍奉帅府门前。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "叩见二位老爷。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "呼唤小人，有何吩咐？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "大老爷进京，命你跟随，倘有不测，速报我知。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "但不知几时起程？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "即刻起程。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "备马伺候。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "看衣更换。"
        },
        {
          "character": "伍尚",
          "type": "西皮原板",
          "text": "在头上取下了乌纱帽， 紫袍朝衣且离身。 叫家将备马府门等， 等候了你老爷就要登程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将下。"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "一封书信到樊城， 拆散了弟兄们两离分。 家院看过酒一樽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师、家将同暗上。"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "弟与兄长——"
        },
        {
          "character": "伍员",
          "type": "西皮二六板",
          "text": "来饯行。 登山涉水多劳顿， 披星戴月转家门。 非是小弟不从命， 怎奈有“逃走”二字书后明。 兄长饮干杯中酒， 一路平安早到京。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "接过了贤弟酒一樽， 背转身来谢神灵。 倘若是家门遭不幸， 你就是伍家报仇人。 辞别贤弟足踏镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚上马。鄢将师、家将同下。"
        },
        {
          "character": "伍尚",
          "type": "西皮散板",
          "text": "披星戴月奔都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚下。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "兄长上马两泪淋， 叫人难舍又难分。 流泪眼观流泪眼， 断肠人送断肠人。 倘若家门遭不幸， 杀上天子午朝门。 吉凶二字难料定， 闷坐樊城等信音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、伍员同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师、家将、伍尚同上。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "爹娘书信到来临， 心急哪顾路不平。 无心观看道路景， 催马加鞭奔帝京。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、鄢将师、家将同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、费无极同上。"
        },
        {
          "character": "费无极",
          "type": "念",
          "text": "眉头一皱计千条，舌尖杀人不用刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师上。"
        },
        {
          "character": "鄢将师",
          "type": "念",
          "text": "离了樊城地，报与相爷知。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "叩见相爷。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "谢相爷。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "伍尚、伍员可曾诓到？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "伍尚进京，伍员未到。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "伍尚往哪里去了？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "监中探父去了。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "你且回避。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师下。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "且住，我想伍尚私自监中探父，我不免上殿参他一本。 打道上朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费无极、四校尉同走圆场，同挖门。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "臣，费无极见驾，愿大王千岁！"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "今有伍尚，私自进京，监中探父。请旨定夺。"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "就命卿家将他父子斩首金阶，领旨下殿。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "领旨！ 校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "打道金阶。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费无极、四校尉同走圆场。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "来在金阶。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "将伍奢、伍尚父子绑了上来！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同下，绑伍奢、伍尚同上。"
        },
        {
          "character": "伍奢",
          "type": "西皮快板",
          "text": "见伍尚把我的牙咬坏， 骂声无知小奴才。 弟兄镇守樊城界， 为什么私自转回来？"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "老爹尊错把孩儿怪， 书信一到怎敢不来！ 父子们犯了何条罪， 为何捆绑在金阶？"
        },
        {
          "character": "伍奢",
          "type": "西皮快板",
          "text": "平王无道纲常坏， 父纳子妻理不该。 为父谏奏反遭害， 勒逼修书叫你来。 儿头上枉把乌纱戴， “逃走”二字解不开。"
