{
  "script_id": "03096002",
  "title": "舌战群儒",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "周瑜",
      "hangdang": "小生"
    }
  ],
  "plot": "曹操得荆、襄后，乘势下江东，攻孙权。东吴文官主降，武将主战，孙权不能决。鲁肃到江夏请来诸葛亮。\n诸葛亮以说词驳倒张昭等文官，并列举敌我形势，劝孙权抗曹。孙权意决，乃联合刘备，共拒曹兵。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、孙权同上。"
        },
        {
          "character": "孙权",
          "type": "引子",
          "text": "南面称孤，镇江东，霸业鸿图。"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "父兄征战有数年，开基创业在江南。曹操统领兵百万，要与孤家起争端。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤、孙权。承父兄之基业，坐镇江南，领守九州八十一郡。今有曹操得了荆、 襄各郡，带兵百万，直下江南，有吞并东吴之意。昨日与群臣商议，文官要降， 武将主战，倒叫孤家犹豫不决。也曾修书去到柴桑口宣召周瑜，等他到来， 再做商议。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "江夏请卧龙，同来见主公。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "参见主公！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "大夫少礼。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "谢主公！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "今有曹操遣使送来檄文，孤与众卿商议，文官要降，武将主战，不知大夫意下 如何？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "众人俱可降曹，惟主公万万不可。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "若肃等降曹，自然加官授爵，封妻荫子；若主公降曹，位不过封侯，马不过一 骑，从者不过数人。若想南面称孤，只怕不能了。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "众人之言大失孤望。大夫之言，正合孤意。只是那曹操灭了袁绍，冀州兵马皆 为所得，近日又得荆、襄之众，其势甚大，恐难对敌。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "主公休要多虑。肃至江夏请来诸葛孔明，主公与他相见，定知曹操虚实。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "莫非就是那卧龙先生么？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是此人。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "现在何处？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "现在驿馆。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "今日天色已晚，明日聚众文武于帐下，教他先看我江东之英俊，然后孤再与他 相见便了。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "遵命！正是："
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "欲图定国事，须问智谋人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃下。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "待明日见了诸葛孔明，看他是怎样议论。 退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权、四太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、中军、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "点绛唇",
          "text": "幼习兵机，智谋无敌；逞雄威，制胜出奇，名震东吴地。"
        },
        {
          "character": "周瑜",
          "type": "念",
          "text": "甘罗十二智谋高，少年拜将姓名标。男儿须抱凌云志，治国安邦立功劳。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "某、姓周名瑜字公瑾。吴侯驾前为臣，镇守柴桑一带等处。昨日吴侯有书信到 来，命我回朝议事。 众将官，兵发南徐去者！"
        },
        {
          "character": "四大铠、四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张昭、虞翻、步骘、薛综、陆绩、严畯同上。"
        },
        {
          "character": "张昭、虞翻",
          "type": "同念",
          "text": "衣冠济济珮玱玱，"
        },
        {
          "character": "步骘、薛综",
          "type": "同念",
          "text": "朝臣待漏五更忙。"
        },
        {
          "character": "陆绩、严畯",
          "type": "同念",
          "text": "九天阊阖开宫殿，"
        },
        {
          "character": "张昭、虞翻、步骘、薛综、陆绩、严畯",
          "type": "同念",
          "text": "万里山河定帝邦。"
        },
        {
          "character": "张昭、虞翻、步骘、薛综、陆绩、严畯",
          "type": "同白",
          "text": "下官——"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "张昭。"
        },
        {
          "character": "虞翻",
          "type": "白",
          "text": "虞翻。"
        },
        {
          "character": "步骘",
          "type": "白",
          "text": "步骘。"
        },
        {
          "character": "薛综",
          "type": "白",
          "text": "薛综。"
        },
        {
          "character": "陆绩",
          "type": "白",
          "text": "陆绩。"
        },
        {
          "character": "严畯",
          "type": "白",
          "text": "严畯。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "众位大人请了！"
        },
        {
          "character": "虞翻、步骘、薛综、陆绩、严畯",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "今有诸葛孔明，过江来见主公，定是前来游说。今日曹操欲伐刘备，那孔明欲 借我东吴之兵，以敌曹操。幸勿使吴侯中了他的诡计。待他到来，我等与他辩 论一番。"
        },
        {
          "character": "虞翻、步骘、薛综、陆绩、严畯",
          "type": "同白",
          "text": "就依大人。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "诸葛先生到。"
        },
        {
          "character": "张昭、虞翻、步骘、薛综、陆绩、严畯",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃引诸葛亮同上，张昭、虞翻、步骘、薛综、陆绩、严畯同迎。鲁肃暗下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊，众位大夫请了！"
        },
        {
          "character": "张昭、虞翻、步骘、薛综、陆绩、严畯",
          "type": "同白",
          "text": "先生请了！请坐！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "张昭、虞翻、步骘、薛综、陆绩、严畯",
          "type": "同白",
          "text": "先生驾到，我等未曾远迎，当面恕罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "久闻先生隐居南阳，高卧隆中，自比管仲、乐毅，不胜钦敬之至。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此亮平生小可之比耳，何劳大夫挂齿！"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "那刘豫州三顾茅庐，聘请先生，言听计从，就该席卷荆、襄，今日荆、襄州郡 尽属曹操，不知是何主见？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想我主刘豫州自出世以来，以仁德为本，信义当先，若取汉上之地，易如反掌。 怎奈荆襄王刘表也是汉室之胄，我主不忍取同宗之基业，故力辞不受。那刘 琮小儿听信蔡瑁等谗言，将荆、襄各郡尽献于曹操，使曹操得以猖獗。今我主 屯兵江夏，别有良图，非君等所知也。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "先生自比管仲、乐毅，想当年管仲相桓公，霸诸侯，一匡天下；乐毅下齐邦七 十二城，名震当时，皆天下之奇才。今刘豫州聘请先生下山，必能兴利除害， 抑强扶弱。刘豫州未得先生之前，尚且占据城池，纵横宇内；既得先生之后， 则曹兵一出，抛戈弃甲，望风而逃，弃新野，走樊城，败当阳，奔夏口，竟无 容身之地。若有管仲、乐毅，必不至如此。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "万里鹏飞，群鸟难及；鸿鹄之志，燕雀难知。譬如人身染重病，必先用粥糜调 养，复用药剂医治，待其脏腑充盈，形骸平复，然后再用肉食以补之，猛药以 投之，则病根除矣。若不待气脉和缓，既投以猛药厚味，病人断无生理。我主 刘豫州，自汝南兵败之后，暂依刘表，兵不过千人，将则只有关、张、赵云等， 此正如病势尫羸已极之时。想那新野之地，乃是山僻小县，生民既少，粮草 无多；城郭未修，军马未练；器械不足，辎重不备，而能博望烧屯，白河决水， 使曹仁、夏侯惇辈心胆俱裂，弃甲而逃。当日管、乐用兵，未必过此。况军 家胜败，乃古之常理。昔日汉高祖皇帝与项羽争雄，屡战屡败，到后来垓下一 战成功，岂非韩信之良谋乎？"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "我主行事多义信， 打从新野赴江陵。 难民倒有数十万， 我主不忍两离分。 旷野荒郊哭声震， 一日只行数十程。 因此当阳败了阵， 曹操得胜逞其能。 自古兵家无常胜， 征战全在主谋人。"
        },
        {
          "character": "虞翻",
          "type": "白",
          "text": "今曹公带兵百万，勇将千员，蜂拥而来，夺取江夏，不知先生当用何计？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "曹操收袁绍蚁聚之兵，刘表乌合之众，虽有数百万，何足惧哉？"
        },
        {
          "character": "虞翻",
          "type": "白",
          "text": "你主刘豫州兵败当阳，逃奔夏口，几无容身之地。今将求救于人，尚言不惧曹 兵，可谓大言欺人也！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我主当阳之败，乃因携带数十万难民，扶老携幼，号泣相随，我主不忍舍而去 之，一日只行数十里，身旁只有数千仁义之兵，岂能敌曹操百万残暴之众！今 日你东吴兵有数万，将有百员，且据长江之险。你等竟欲使你主屈膝降曹，贻 笑天下，以此比之，我主则真不惧曹操矣！"
        },
        {
          "character": "步骘",
          "type": "白",
          "text": "孔明，你今日过江，莫非要学那苏秦、张仪之辈，游说我东吴么？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你道苏秦、张仪为舌辩游说之辈。岂知那苏、张也是豪杰英雄。苏秦六国封相， 张仪两次相秦，皆有匡扶人国之谋，并非畏强凌弱、避刀怕剑之流。你等只 信曹操诡妄之言，万分畏惧，贪生怕死，劝主投降，还敢笑苏秦、张仪，真真 不知羞耻！"
        },
        {
          "character": "薛综",
          "type": "白",
          "text": "啊孔明，你道曹操是何等样人？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "曹操名为汉相，实为汉贼，人人皆知，何必问耶？"
        },
        {
          "character": "薛综",
          "type": "白",
          "text": "你此言差矣！汉室衰微，气运已尽。曹公应天之运，天下归心。你主不知时务， 强欲相争，如同以卵投石，以薪救火！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "薛敬文，你怎么竟说出无父无君之言来了！那曹操祖宗累食汉朝爵禄，理应忠 心为国，报效朝廷。哪知他心怀叛逆，常怀篡汉之心，天下之人无不痛恨。你 今竟以天命归之，真无父无君之人也。幸勿多言！"
        },
        {
          "character": "陆绩",
          "type": "白",
          "text": "想那曹操，虽然挟天子以令诸侯，他本是开国丞相曹参之后。刘豫州虽说是中 山靖王之后，却不可考；他织席卖履，人人皆知，似难与曹操抗衡。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你莫非是昔日在袁术座前怀橘遗亲之陆郎乎？请安坐，听山人讲来：那曹操既 为相国曹参之后，世为汉臣，为何霸持朝政，上期天子、下压群臣？不但无君， 亦且蔑祖；不但是汉室之乱臣，真乃曹氏门中之贼子。我主刘豫州，堂堂帝 室之胄，当今天子也曾按谱稽查，当殿赐爵，怎道无可稽查！汉室高皇帝以亭 长出身而有天下，则织席卖履何足耻哉！"
        },
        {
          "character": "严畯",
          "type": "白",
          "text": "听你之言，可谓强词夺理，但不知你所治是何经典？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "引经据典乃腐儒之论。昔日伊尹耕于莘野，太公钓于渭水之滨，陈平、张良之 流，耿弇、邓禹之辈，经文纬武，治国安邦，图画凌烟，名标青史，并不曾闻 治何经典。岂似尔等下士书生，徒守笔砚，专尚虚文，并无实学，终日戏墨弄 文而已！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "自古功臣扶社稷， 经纶抱负定出奇。 功勋卓著立战绩， 岂似你书生见识低！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "唱",
          "text": "诸君不必纷纷论， 先生快见我主君。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "江东文臣将我问， 一个个俱怀降曹心。 舌战群儒他等无有话论， 管叫他认识我南阳孔明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、诸葛亮同下。"
        },
        {
          "character": "张昭",
          "type": "唱",
          "text": "人言孔明才学广， 今日一见果然强。 自比管、乐无虚谎，"
        },
        {
          "character": "张昭、虞翻、步骘、薛综、陆绩、严畯",
          "type": "同唱",
          "text": "倒叫我等脸无光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张昭、虞翻、步骘、薛综、陆绩、严畯同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、孙权同上。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "曹操带兵下江东， 倒叫孤王挂心中。 将身且坐银安殿， 单等相会卧龙公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孔明先生到。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有请诸葛先生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吴侯！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "先生！请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告坐。我主刘豫州问候吴侯金安。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "岂敢！久闻鲁子敬言道：先生躬耕南阳，抱膝隆中，有安邦定国之才。今幸相 会，特地领教。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不才无学，有辱尊问。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "先生曾在新野辅佐刘豫州，与曹兵交战，必知曹营军情虚实。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想那新野城池狭小，粮食不足；我主刘豫州兵微将寡，寡不敌众，岂能与曹操 相持！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "曹操此番前来，不知兵将有多少？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马步水军约有百万。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "百万兵将，恐是诈词。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "非诈也。想那曹操据青、兖、幽、冀之兵，已有二三十万；平了袁绍，又有五 六十万；今又得荆、襄之兵二三十万；中原新招之兵三四十万。如此计算，已 有一百五十余万。亮方才言百万者，恐惊吓江东将士耳！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "但不知他帐下战将有多少？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他帐下足智多谋之士，能征惯战之将，至少也有一二千人。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "今曹操平定荆、襄，但不知他尚有远图否？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "看他沿江下寨，准备船只，教练水军，不是要取江东，他要取何处？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "他既有并吞我江东之意，战与不战，愿先生与孤决之。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮有一言，恐吴侯不肯听从。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "愿闻高论。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吴侯要自己裁处：若以吴越之众，可与中原抗衡，不如早与之绝。如其不能， 莫如从众谋士之言，投降可也！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "那刘豫州为何不降曹操？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想昔日田横乃齐之壮士，犹能守义不辱；况刘豫州乃帝室之胄，英才盖世，百 姓仰慕，事之不成，乃天命也。岂能屈膝于人下哉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权怒。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孔明大言，欺我忒甚！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎呀先生哪！你何出此言哪？幸我主宽宏大量，不肯面责于你。未免藐视我主 太甚矣！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你主也忒不能容物了。我视曹兵如拾草芥，你主不问，我故而不言。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "如此，待我去请主公。 有请主公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权上。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那孔明言道：他有破曹之计。适才肃曾责备于他，他倒说主公不能容物。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "既然如此，待孤再去相见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权见。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "先生，适才有犯尊颜，幸勿见怪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮出言冒昧，尚祈恕罪。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "岂敢！想那曹操生平所惧者，惟吕布、刘表、袁术、袁绍、玄德与孤。今日数 雄皆灭，惟玄德与孤尚在，孤岂肯以江东之地受制于人！但恐玄德新败之后， 不能与孤同抗此难耳！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吴侯哇！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "说什么兵败新野城， 细听山人说分明： 我主仁德威名震， 关云长、张翼德勇敌万人。 还有那赵子龙无人敢近， 哪怕那曹兵百万人。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我主帐下关、张、赵云，皆能勇敌万人；现有精兵两万，刘琦坐镇江夏也有万 人。曹操虽有百万之众，远道而来，疲乏已极；青州之兵，不习水战；荆州之 兵，虽然归曹，也非本心。今日若与我同心破曹，曹败之后，势必北还，则荆、 吴势强，鼎足形成矣!"
        },
        {
          "character": "孙权",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "先生之言，顿开茅塞，孤意已定，择日兴兵，共灭曹操！"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "听一言来喜在心， 同心协力破曹军。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "先生暂请馆驿歇息。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告退。正是："
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "全凭三寸不烂舌，激动江东孙仲谋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "鲁大夫，等待公瑾到了南徐，命他与孔明相见，商议破曹之计。退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}