{
  "script_id": "03009003",
  "title": "千秋岭",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "罗成",
      "hangdang": "武生"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "徐茂公",
      "hangdang": "老生"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    }
  ],
  "plot": "唐初，李世民部将多为瓦岗盟友，唯尉迟恭一人非秦琼等旧交，颇受歧视。时王世充据洛阳，李世民率部战\n争，相持于千秋岭。王世充部将罗成，为瓦岗盟友之一，勇猛善战；徐茂公激使尉迟恭出战，被罗成战败，\n众将嘲笑不已。嗣徐茂公召罗成来降，李世民倍加礼遇。尉迟恭不服，为争座与众将失和。愤而欲去。李世\n民屈膝排解，方言归于好。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗成上，起霸。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "束发金冠显少年，气吐虹霓贯九天。银枪摆动龙戏水，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "战马驰驱似火烟。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "俺、罗成。今在洛阳王世充帐下为将。闻听唐童兴兵前来，岂肯容他猖狂。 呔！众将官！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同带马，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、尉迟恭同上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "披棱锏盖世无双，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼归大边。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "水磨鞭保定唐王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼归小边。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "某、护国公秦琼。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "鄂国公敬德。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "二主升帐，两厢伺候！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引徐茂公、李世民同上。〖点绛唇〗。"
        },
        {
          "character": "尉迟恭、秦琼、徐茂公",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "众卿少礼。"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "奉了父王旨，征战洛阳城。虽然我为主，全仗众公卿。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王李世民。奉了父王之命，征战洛阳王世充，可恨他战又不战，降又不降。 也曾命探马前去打探，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "罗成讨战。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "罗成讨战，当命何将出马？"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "命马三保带领本部人马，攻打头阵。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生传令。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "得令。 下面听者！二主有令：命马三保带领本部人马攻打头阵！"
        },
        {
          "character": "马三保",
          "type": "内白",
          "text": "啊！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "主公，请至后帐，且听好音便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马三保、四龙套同上。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "某、马三保。奉命攻打头阵。 众将官，杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成、四下手同上，会阵。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "马三保，你乃久败之将，擅敢起兵到此！"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "一派胡言。放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起打。马三保败下，罗成追下。四文堂、尉迟恭、秦琼、徐茂公、李世民自两边分上。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "马三保败阵！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生，马三保败阵，当命何将出马？"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "待臣思忖回话。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "呜呼呀！看此黑贼耀武扬威，我不免在二主面前搬动是非，教他出马打一败阵， 也好灭灭他的火性。 臣启主公：罗成骁勇，我营将士，无人对敌，将营盘暂退四十里，打本进京， 奏与老王，遣来能将大战罗成！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生传令！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "得令。 令出……"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "尉迟恭为何阻令？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "先生啊！你道那罗成天上少有，地下难寻，眼前若有二主将令，某要生擒罗成 进帐。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "你若擒得住罗成，山人愿将军师大印，付你执掌。你呢？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "我若擒不住罗成，愿输项上人头。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "空口无凭，敢与山人击掌？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "击掌？请啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "尉迟恭听令！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "命你带领本部人马，大战罗成！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "皇兄须要小心。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "二主！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "二主不必太小量， 强中自有强中强。 辞别二主出宝帐，"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "大战罗成！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你不能得胜！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你是怎么知道？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "我与他乃是姑表之亲。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你们俱是一党！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "战鼓咚咚下教场！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "一见尉迟出唐营， 回头埋怨徐先生： 明知罗成多骁勇， 不该命他去出征。 先生传令某出马，"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "你也不能得胜！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "不得胜落一个两太平。"
        },
        {
          "character": "徐茂公",
          "type": "唱",
          "text": "二哥有所不知情， 小弟言来听分明： 自从黑贼进唐营， 屡屡欺压弟兄们。 教他出兵打败阵， 看他逞能不逞能！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "好个仁义徐先生， 把我弟兄看得清。 辞别二主出唐营， 且听探马报分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "带过御马跨金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民上马。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "去到阵前看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、尉迟恭同上。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "跨下一骑乌骓马， 打将钢鞭手中拿。 三军与爷催战马， 大小将官听根芽： 别的将官休出战， 单要罗成小娃娃。"
        },
        {
          "character": "四下手",
          "type": "内同白",
          "text": "唐将骂阵！"
        },
        {
          "character": "罗成",
          "type": "内唱",
          "text": "正在后帐习兵法，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引罗成同上。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "听得唐将叫骂咱。 三军带过爷的马， 管教敌将染黄沙！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "少爷罗成！"
        },
        {
          "character": "尉迟恭",
          "type": "三笑",
          "text": "啊哈！啊哈！啊哈哈哈……"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "黑贼为何发笑？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "罗成啊，我道你，天上少有，地下难寻；原来是黄毛孺子，怎受得某家一战？ 三军的，报与二主，上某家大大头功。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "黑贼到此，一战未交，为何上尔大大头功？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃，漫说交战，提起你老爷昔年威风，吓破尔的苦胆！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你要讲啊！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你要听啊！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "勒住马头慢交战， 细听老爷表家园： 家住山西麻衣县， 聚杰村内有家园。 日抢三关夺八寨， 杀得唐将心胆寒。 漫说与爷来交战， 提起威风吓尔还。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "忽听黑贼表家园， 吓得少爷心胆寒。 不战黑贼走了罢！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "敢是怯战？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "细听少爷表家园： 俺七岁气吹檐前瓦， 八九学艺在燕山； 十岁姑表枪换锏， 十一岁结拜在济南； 十二山东放响马， 十三岁威名天下传； 十四夜打登州府， 十五扬州夺状元； 十六景阳曾打虎， 十七染病在山前； 少爷今年十八岁，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "十八岁该死了！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "杀得唐将丧黄泉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、罗成同起打，同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引徐茂公、李世民同上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "君臣打马出唐营，"
        },
        {
          "character": "徐茂公",
          "type": "唱",
          "text": "观看两家动刀兵。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "下得马来高坡上，"
        },
        {
          "character": "徐茂公",
          "type": "唱",
          "text": "看是谁胜哪家赢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、罗成同上，同打下。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "尉迟好比南山豹，"
        },
        {
          "character": "徐茂公",
          "type": "唱",
          "text": "罗成好比浪里蛟。"
        },
        {
          "character": "尉迟恭",
          "type": "内唱",
          "text": "越杀越勇罗士信，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "杀得某家少精神。 只杀得襆头戴不稳， 乌骓马倒退不前行。 背地只把二主怨， 回头埋怨徐先生： 明知罗成多骁勇， 不该命某来出兵。 慈悲大士救八难， 缘何不救某难中人！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "不顾生死把他战！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "倒被娃娃笑一声。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃！"
        },
