{
  "script_id": "03074002",
  "title": "焚棉山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "介子推",
      "hangdang": "老生"
    }
  ],
  "plot": "晋文公重耳即位，大封功臣，独忘介子推。邻人解张劝介子推上朝请功，介子推不听，奉母隐居棉山。重耳\n用计烧棉山，介子推母子坚隐不出，均被烧死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "狐毛、狐偃、颠颉、魏犨同上。〖点绛唇〗。"
        },
        {
          "character": "狐毛",
          "type": "白",
          "text": "老夫，狐毛。"
        },
        {
          "character": "狐偃",
          "type": "白",
          "text": "下官，狐偃。"
        },
        {
          "character": "颠颉",
          "type": "白",
          "text": "某，颠颉。"
        },
        {
          "character": "魏犨",
          "type": "白",
          "text": "某，魏犨。"
        },
        {
          "character": "狐毛",
          "type": "白",
          "text": "从位大人请了！"
        },
        {
          "character": "狐偃、颠颉、魏犨",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "狐毛",
          "type": "白",
          "text": "吾主周游列国一十九载，今日回朝复位。我等分班人伺候！"
        },
        {
          "character": "狐偃、颠颉、魏犨",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引重耳同上。"
        },
        {
          "character": "重耳",
          "type": "引子",
          "text": "重开新气象，恢复旧家邦。"
        },
        {
          "character": "狐毛、狐偃、颠颉、魏犨",
          "type": "同白",
          "text": "臣等见驾，吾主千岁！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "狐毛、狐偃、颠颉、魏犨",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "重耳",
          "type": "念",
          "text": "贱妃奸计害好人，逼得孤王难存身；堪叹流浪十九载，受尽万苦与千辛。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "寡人，晋君重耳。只因父王听信谗言，毒害大臣。多蒙众卿保定寡人，周游列 国一十九载。今日回朝复位。 众卿！"
        },
        {
          "character": "狐毛、狐偃、颠颉、魏犨",
          "type": "同白",
          "text": "臣！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "多蒙卿等保寡人回朝复位。站立两厢，听寡人封赠！"
        },
        {
          "character": "狐毛、狐偃、颠颉、魏犨",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "内侍，取功劳簿过来！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "父王啊！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "父王无道坐朝纲， 听信谗言害忠良。 各地飘流无定向， 今日才得坐朝堂。 狐毛封为左丞相，"
        },
        {
          "character": "狐毛",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "狐偃封为右侍郎。"
        },
        {
          "character": "狐偃",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "颠颉封为镇殿将，"
        },
        {
          "character": "颠颉",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "魏犨替孤掌朝纲。"
        },
        {
          "character": "魏犨",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "一道旨意往下降， 晓谕文武听端详： 有功快把功献上， 功劳未叙怨朕思量。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "众位公卿有功者甚多，寡人一时难记。有榜文一道，悬挂午门，有功者三日陈 奏。"
        },
        {
          "character": "狐毛、狐偃、颠颉、魏犨",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "朝事已毕，退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "解张上。"
        },
        {
          "character": "解张",
          "type": "念",
          "text": "桃花岁岁皆相似，人面年年大不同。"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "老汉，解张。今有晋文公，周游列国一十九载，回朝复位，犒赏功臣。介子推 功劳甚多，不免前去报信于他。正是："
        },
        {
          "character": "解张",
          "type": "念",
          "text": "乡邻做官，大家喜欢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "解张下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推上。"
        },
        {
          "character": "介子推",
          "type": "引子",
          "text": "弃官离朝，名利抛，侍奉年高。"
        },
        {
          "character": "介子推",
          "type": "念",
          "text": "见机逃出是非地，落得清闲自在身；冷眼看破君王意，功成身退奉娘亲。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "卑人，介子推。晋献公驾前为臣，官居谏议大夫。只因吾主听信谗言，毒害大 臣。是我与狐毛、狐偃、颠颉、魏犨等，保定重耳逃出罗网，周游列国一十九 载。归来共渡黄河，是俺看破其意，弃职归家。正是："
        },
        {
          "character": "介子推",
          "type": "念",
          "text": "奉君何足乐，还是孝当先。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "介子推坐草堂自思自想， 想起了当年事令人惨伤。 晋献公他信那谗言毁谤， 害亲生斩忠良扰乱朝纲。 众贤臣保重耳逃出罗网， 日同行夜同眠好不凄凉。 我也曾在荒郊觅食求浆， 我也曾割股肉奉献君王。 过黄河一个个争功讨赏， 因此上怀戒心弃职还乡。 想起来这些事心神沮丧， 斩断了名利锁侍奉高堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "解张上。"
        },
        {
          "character": "解张",
          "type": "唱",
          "text": "晋公子登龙位百官封赠， 相劝那介子推前去面君。"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "来此已是，介兄在家么？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "是哪位？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推出门。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "原来是解兄，请进！"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "这厢有礼！"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "还礼！"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "请坐！解兄到此何事？"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "今有重耳公子回朝犒赏功臣。你乃有功之臣，何不前去请功受赏？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "解兄这些言语，依我看来，尽都是荒谬之言。"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "何为荒谬之言？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "既是晋文公回朝犒赏功臣，就该有旨前来，宣我入朝。今无旨意到此，岂不是 荒谬之言？"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "介兄啊！"
        },
        {
          "character": "解张",
          "type": "唱",
          "text": "昔日有个姜吕望， 八十二岁遇文王。 他也曾保主江山创， 他也曾领兵去伐商。 既是重耳加封赏， 就该前去见君王。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "解兄不必说比方， 小弟言来听端详： 讲什么兴周姜吕望！ 说什么武王伐纣王！ 我不为官身闲荡， 散淡逍遥奉高堂。"
        },
        {
          "character": "解张",
          "type": "唱",
          "text": "介兄不必性刚强， 你本盖世一忠良。 周游列国随驾往， 割股忠心天下扬。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "解兄不必如此讲， 非是为弟秉性刚。 一十九载远飘荡， 鞍前马后随君王。 重耳为君无度量， 弃旧迎新理不当。 既是有功该受赏， 因何把我丢一旁？ 冷眼看破君行状， 不做高官又何妨！ 蟒袍玉带我不想， 侍奉萱堂在故乡。"
        },
        {
          "character": "解张",
          "type": "唱",
          "text": "介兄不去请功赏， 老汉白来跑一场。 施罢一礼出草堂，"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "少送了！"
        },
        {
          "character": "解张",
          "type": "唱",
          "text": "休怪老汉言语狂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "解张下。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "好一个邻舍老解张， 絮絮叨叨讲比方。 他劝我请功去受赏， 哪知我不肯拜君王。 闷恹恹坐在草堂上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介母上。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "母子二人苦度时光。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "孩儿拜揖！"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "罢了，坐下！"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "谢母亲！"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "儿呀，方才何人到此？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "邻舍解张到此。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "到此何事？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "是他言道，今有重耳回朝犒赏功臣，叫孩儿前去请功受赏。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "既有此事，我儿就该前去。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "母亲，他既犒赏功臣，就该有旨召我入朝。今无圣旨到来，岂不是把孩儿看成 朽木一般了么？"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "他今复位坐朝堂， 犒赏功臣举栋梁。 我昔年有功他全忘。 落一个清闲自在行孝郎。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "我儿说话欠思量， 且听为娘说端详： 既是重耳论功赏， 我儿前去又何妨？"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "四四方方一堵墙， 许多能人里边藏。 昔日有个商纣王， 听信谗言斩忠良。 比干谏奏反遭丧， 箕子、微子一命亡。 自古常言道得好： 伴君犹如伴虎狼。 一旦不称君王意， 大祸临头无下场！"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "我的儿不愿去请功受赏， 母子们坐草堂再作商量。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "我儿不愿去请功受赏，也罢，我母子就该隐居起来才是。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "母亲，此处有一棉山，高山峻岭，倒好安身。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "待为娘收拾包裹衣服。就此前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介母下。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "好个贤德老母！"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "老母贤德世无双， 可算当世大贤良。 虽然年迈六旬上， 一片慈心达上苍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介母上。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "母子们双双跪草堂， 拜别祖先泪汪汪。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "用手拨开名利网， 翻身跳出是非墙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "狐毛、狐偃、颠颉、魏犨、四太监引重耳同上。"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "忆昔当年受奔忙， 多亏众卿保孤王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "唱",
          "text": "突然来个老解张， 忙上金殿奏君王。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏大王：今有一人名叫解张，他来报道，介子推有功甚多，未加封赠，现已 逃往棉山去了。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "此人现在哪里？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "午门外候旨。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "宣他上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨！ 大王有旨，解张上殿！"
        },
        {
          "character": "解张",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "解张上。"
        },
        {
          "character": "解张",
          "type": "念",
          "text": "子推上山岗，前来报君王。"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "草民，解张见驾，愿大王千岁！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "介子推今在何处？"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "他母子不愿为官，逃往棉山去了。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "哎呀卿家呀！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "听罢言来心惨伤， 汗马功劳一旦忘。 内侍与孤把旨降， 速往棉山访贤良。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "封解张为大夫之职！"
        },
        {
          "character": "解张",
          "type": "白",
          "text": "谢主隆恩！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "内侍，传孤旨意，命众将全身披挂，随孤棉山一行！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "重耳",
          "type": "念",
          "text": "孤王棉山访臣佐，"
        },
        {
          "character": "狐毛、狐偃、颠颉、魏犨",
          "type": "同念",
          "text": "不忘当年股肉割。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同上。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "母子双双到山洼，"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "不贪富贵与荣华。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "母亲，来此已是棉山。"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "高山峻岭，叫为娘怎样上去？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "老娘啊！"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "棉山小路远无涯， 四壁巍峨景物佳。 云环峻岭雁难下， 涧下清泉照眼花。 猿猴吱吱鹿戏耍， 喜鹊依枝叫喳喳。 手攀藤条山洼下， 古树林下可为家。"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "此处可好安身？"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "正好安身，只是难以度日！"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "母亲不必担惊怕， 草衣木食度年华。 无是无非多潇洒， 胜似蓬莱第一家。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "人儿说的哪里话， 为娘哪能顾其他？ 母子且把松林下，"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "功劳二字付尘沙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨同上，双起霸。"
        },
        {
          "character": "颠颉",
          "type": "念",
          "text": "沙场血战气如虹，"
        },
        {
          "character": "魏犨",
          "type": "念",
          "text": "万马营中抖威风。"
        },
        {
          "character": "颠颉",
          "type": "念",
          "text": "一心要作忠良将，"
        },
        {
          "character": "魏犨",
          "type": "念",
          "text": "保定晋王立大功。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "某，（颠颉）（魏犨）。 主公到棉山访求贤良，在此伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四太监、大太监引重耳同上。"
        },
        {
          "character": "重耳",
          "type": "引子",
          "text": "孤王到校场，棉山访贤良。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "臣等见驾，愿主千岁！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "兵发棉山！"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "领旨！众将官，兵发棉山！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推上。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "春草青青隐翠溪， 老母叮咛结草依。 山高也有长流水， 喜鹊吱吱绕树飞。 我好比箕子绝人迹， 我好比姜尚隐钓溪。 我好比白鹤鸡群立， 我好比凤凰觅枝栖。 一霎时遍地风沙起， 乌鸦不住往空飞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "人马呐喊耳边里， 叫人心中费猜疑。 站立山头用目觑——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引颠颉、魏犨同上，过场，同下。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "刀枪剑戟摆得齐。 见几个抱定双环戟， 见几个怀抱打将锤， 见几个用的刀和斧， 见几个兵刃不出奇。 莫不是哪国烟尘起？ 莫不是重耳把兵提？ 莫不是要进棉山里？ 莫不是来访介子推？ 看罢一回心火起！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引颠颉、魏犨同上，过场，同下。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "一口热气往上提。 我也曾对天盟过誓， 永不回朝挂紫衣。 任他搜来任他洗， 稳坐棉山永不离！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四太监、大太监引重耳同上。"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "这是为王大不幸， 为何忘了割股臣？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨同上。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "臣等交令。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "可曾得见？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "不曾得见。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "哎呀卿家呀！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "听一言来泪汪汪， 棉山隐藏一忠良。 回言再对二卿讲： 再往棉山走一场。"
        },
        {
          "character": "颠颉",
          "type": "唱",
          "text": "我主旨意往下降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉下。"
        },
        {
          "character": "魏犨",
          "type": "唱",
          "text": "二次入山访贤良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏犨下。"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "非是孤王把他请， 只为当年割股情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推上。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "四下人马齐围困， 想是重耳到山林。 回头便把母亲请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介母上。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "我儿为何着了惊？"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "棉山人马乱纷纷， 想是重耳到来临。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "既是重耳把你请， 我儿就该去见君。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "母亲说话不思忖， 想儿下山万不能！"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "还往哪里安身？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "随儿来！"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "搀定老娘东山进， 隐姓埋名不见君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引颠颉同上。"
        },
        {
          "character": "颠颉",
          "type": "唱",
          "text": "自从盘古到如今， 哪见棉山动刀兵？ 人马扎在东山岭， 棉山里面访贤臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母上。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "搀定老娘西山进， 西山里面且安身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引魏犨同上。"
        },
        {
          "character": "魏犨",
          "type": "唱",
          "text": "三皇五帝到如今， 哪见此处乱纷纷？ 兵将扎在西山岭， 观看子推哪里存？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四太监、大太监引重耳同上。"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "东山寻至西山尽， 不见子推何处存？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颠颉、魏犨同上。"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "臣等交令。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "可曾得见？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "不曾得见。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "寻访不见，如何是好？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "主公传下旨意，将棉山四下放火！"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "岂不将他母子伤坏？"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "想介子推乃是一孝子；见火一起，必然同他老母来见主公。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "好。吩咐众将放火！"
        },
        {
          "character": "颠颉、魏犨",
          "type": "同白",
          "text": "众将官，四下放火！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "火彩。介子推上。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "只见四下火光起， 想是重耳苦相逼。 回头再把老娘请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介母上。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "我儿为何心着急？"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "母亲请看，四下起火，如何是好？"
        },
        {
          "character": "介母",
          "type": "白",
          "text": "罢了，儿呀！"
        },
        {
          "character": "介子推",
          "type": "白",
          "text": "母亲啊！"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "母亲不必胆怕惊， 儿有一言听分明： 恁把棉山火烧尽， 情愿一死不回程。"
        },
        {
          "character": "介母",
          "type": "唱",
          "text": "棉山好比酆都城， 要想活命万不能。"
        },
        {
          "character": "介子推",
          "type": "唱",
          "text": "搀定老娘东山进， 四下火光难存身。 带定老母西山岭， 火光一起怕煞人。 搀定老娘上山岭， 霎时骨肉化灰尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "介子推、介母同死。重耳、四龙套、四太监、大太监、颠颉、魏犨同上。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "哎呀卿家呀！"
        },
        {
          "character": "重耳",
          "type": "唱",
          "text": "这是孤王送你命， 连累你母命归阴。"
        },
        {
          "character": "重耳",
          "type": "白",
          "text": "众卿，介子推已死，孤赐他金井玉葬。从今后，“棉山”改为“介山”。每年 清明节前一日，家家寒食，不动烟火，以表哀思！人马回朝！"
        },
        {
          "character": "颠颉、魏犨、四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}