          "text": "打出事来父承当。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "金阶上闷坏了赵匡胤，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑子明上。"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "北平府来了郑子明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑子明打窦瑶。窦瑶逃下，四校尉、四下手、窦龙、窦虎同随下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟那老贼跑了！"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、郑子明同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、四下手、窦龙、窦虎引窦瑶同上。"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "想老夫奉旨游街，被二千岁打得这般光景，难道老夫罢了不成？ 来！打道上朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、郑子明同上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟，老贼哪里去了？"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "上殿奏本去了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你我一同上殿启奏。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "请啊！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "弟兄双双齐顶本，"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "那窦瑶错打定盘星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、郑子明同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四武士手、四太监引柴世荣同上。"
        },
        {
          "character": "柴世荣",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋！"
        },
        {
          "character": "柴世荣",
          "type": "念",
          "text": "平顶金冠放紫霞，九州万户第一家。弟兄同把南唐下，才得一统锦中华。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "寡人柴世荣在位。自登基以来，风调雨顺，国泰民安，乃寡人之洪福也。只因 南唐窦瑶，进来一女，寡人见喜，封在西宫伴驾。也曾命窦瑶游街三日，挑选 王府，未见回宫。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "展放龙门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦瑶上。"
        },
        {
          "character": "窦瑶",
          "type": "念",
          "text": "恼恨匡胤、郑子明，不该御街打皇亲！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "臣窦瑶见驾，愿吾皇万岁！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "平身。命你游街三日，为何这等模样？"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "老臣奉了万岁旨意，游街三日，被二千岁将臣打得这般光景。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "内侍，宣南宋王上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "宣南宋王上殿哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、郑子明同上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "听得万岁一声宣，"
        },
        {
          "character": "郑子明",
          "type": "念",
          "text": "弟兄双双到君前。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟，大哥宣召，上殿启奏。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "二哥小心了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑子明下。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "撩袍且把龙廷上， 白玉阶前见君王。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "赵匡胤见驾，愿吾皇万岁！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "你可知罪？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "但不知罪犯哪条？"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "南宋王御街之上，擅打大臣，即如欺君。不忠不孝之臣，要你何用！ 武士手！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士手同允。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "推出午门去斩！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "金殿上昏迷了柴主君， 无故出旨斩忠臣。 含悲忍泪下龙廷， 把话说与三弟听。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑子明上。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "二哥，这是为何？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟，圣上见愚兄打了窦瑶，就要将我问斩。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "二哥不要惊慌。 刀斧手过来，将二千岁交付尔等，俺老郑上殿保本，无旨不许擅动，倘有差池， 要尔等的狗命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士手押赵匡胤同下。"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "站立午门高声叫， 文臣武将听根苗： 有人将俺二哥保， 老郑保他坐九朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀亮同上。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "迈步如飞午门到，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "千岁惊慌为哪条？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "为何这等模样？"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "二位贤弟有所不知。二千岁打了窦瑶老贼，圣上就要将二千岁问斩。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "千岁不要惊慌，待俺弟兄二人上殿保奏。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "小心了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑子明下。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "撩袍端带上龙廷，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "白玉阶前臣见君。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "二千岁身犯何罪，押在午门问斩？"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "他在御街擅打大臣，打臣即如欺君，理应问斩！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "裙边带来的官儿打死无罪。"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "臣启万岁：他二人哪里是在此保奏，分明是扰乱我主朝政，这等臣子理应问斩！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "唗！你二人哪里是在此保奏，分明扰乱孤的朝政。 武士手！将他二人推出问斩！"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "唗！"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "动不动传旨将臣斩，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "怒恼豪杰站金銮。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "弟兄双双下金殿，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "情愿为民不做官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀亮同下。"
        },
        {
          "character": "柴世荣",
          "type": "唱",
          "text": "他高家与我有仇恨， 又在金殿乱胡行。 寡人出下一道本， 捉拿高家一满门。"
        },
        {
          "character": "窦瑶",
          "type": "唱",
          "text": "金殿之上领圣命，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦瑶下殿。郑子明上。"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "适才官儿报一声。 将身来在午门等， 我看老贼哪里行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦瑶过，郑子明打窦瑶。窦瑶回殿内，郑子明站殿外。"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "启万岁：为臣领了圣旨，捉拿高家满门，偶遇三千岁，将臣打得这等光景。望 万岁作主！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "下殿，寡人自有主张！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "窦瑶",
          "type": "唱",
          "text": "看看窦瑶运不通， 偏偏遇见郑子明。 一言未发把眼睛瞪， 这一边打了个乌眼青。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦瑶下。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "宣北平王上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "北平王上殿！"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "忽听万岁传旨召， 心中恼恨老窦瑶。 他女生来容颜好， 献与当今惹祸苗。 贪淫好色君无道， 他把那手足弟兄一旦抛。 此一番上殿把本保， 不准人情我打窦瑶。 他纵然将我的头割掉， 拼着我命不要，我把银牙咬；打窦瑶，如削草，我定要斩草除根恨方消！ 低头不语把我金殿到， 看他把我怎开消。"
        },
        {
          "character": "柴世荣",
          "type": "唱",
          "text": "寡人明知故意问， 下面来的哪部臣？"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "骂声昏王行不正， 不认得北平王郑子明！"
        },
        {
          "character": "柴世荣",
          "type": "唱",
          "text": "寡人有道天心顺， 你怒气不息为何情？"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "咱二哥犯了何条罪？"
        },
        {
          "character": "柴世荣",
          "type": "唱",
          "text": "他不该金阶打大臣。"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "打了窦瑶有什么罪？"
        },
        {
          "character": "柴世荣",
          "type": "唱",
          "text": "打臣即如欺了君。"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "劝你早早赦了好， 老郑是你对头人！"
        },
        {
          "character": "柴世荣",
          "type": "唱",
          "text": "怀德、怀亮实可恨， 你无义来他无情。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "郑三弟！"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "柴大哥！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "郑子明！"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "柴子耀！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "黑村夫！"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "我把你个卖雨伞的！"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "你可知君要臣死，臣若不死为不忠；父要子亡，子若不亡即为不孝！"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "可不知君不正臣投外邦；父不正子奔他乡。你还是赦与不赦？"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "要寡人赦，万万的不能。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "得罪了！"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "郑子明开言怒满膛， 枣阳槊一举我打昏王。"
        },
        {
          "character": "柴世荣",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柴世荣领四太监同下。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "且住。昏王退入后宫去了，这便怎么处？哦，有了。老郑去到法场看看监斩官 是谁，来一个打一个。我就是这个主意，我就是这个主意。"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "君王无道臣不正， 看看监斩是何人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑子明下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苗光义上。"
        },
        {
          "character": "苗光义",
          "type": "唱",
          "text": "八卦阴阳如反掌， 赤须火龙命遭殃。 迈步来在金殿上，"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "万岁驾转后宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "苗光义",
          "type": "唱",
          "text": "见了公公说端详。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "公公，老夫这里有道本章，烦劳公公启奏！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "待咱家与你转奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监向内。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "苗先生有本，保定二千岁无事！"
        },
        {
          "character": "太监甲",
          "type": "内白",
          "text": "万岁酒醉，娘娘将他本章压下了！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "苗先生万岁酒醉，娘娘将你本章压下了。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "呕！娘娘将我的本章压下了。待老夫修成二道本章启奏！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "你快快写！"
        },
        {
          "character": "苗光义",
          "type": "唱",
          "text": "匡胤本是忠勇将， 单人独马朝刘王。 高平关上找首级， 才得保主作帝王。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "公公启奏！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监向内。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "苗先生有二道本章保奏！"
        },
        {
          "character": "太监甲",
          "type": "内白",
          "text": "将二道本章压下了！"
        },
