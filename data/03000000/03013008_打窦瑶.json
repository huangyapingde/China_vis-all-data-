        {
          "character": "苗光义",
          "type": "白",
          "text": "这三道本章教我从何处而写？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "先生，他们当初在哪里结拜，就从哪里写起！"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "着啊！"
        },
        {
          "character": "苗光义",
          "type": "唱",
          "text": "他弟兄结拜黄土岗， 三人庙内一柱香。 许定一在三人在， 许了一死三人亡。 今日不赦赵匡胤， 怕的江山不久长。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "三道本章启奏！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "三道本章再若不准，拼了老命撞死宫门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "圣旨下：有南宋王御街打臣即如欺君，理应斩首，念先生保奏，发在河南归德 府为民。郑恩欺压朝廷，理应正法，念先生保奏，发在桃源口为民。叩头谢恩 哪！"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "万万岁！"
        },
