{
  "script_id": "03013008",
  "title": "打窦瑶",
  "alias": [
    "斩红袍"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "郑子明",
      "hangdang": "净"
    },
    {
      "name": "柴世荣",
      "hangdang": "老生"
    },
    {
      "name": "苗光义",
      "hangdang": "老生"
    }
  ],
  "plot": "五代时，南唐窦瑶投后周，以女献周主柴世荣。柴世荣纳为西宫，赐窦瑶平章公爵，命其夸官游街三日；造\n府不及，任其挑选王公府第暂居。事为二千岁赵匡胤得知，甚为愤慨，并约集功臣相议，欲除窦瑶。适窦瑶\n鸣锣经过赵府，干犯禁条。赵匡胤出府责窦瑶非礼，窦瑶出言不逊，赵匡胤怒打窦瑶。周主命将赵匡胤处斩。\n功臣高怀德弟兄保本未准，愤而辞官。周主反命窦瑶抄高全家赴斩。北平王郑子明闻讯赶至，阻打窦瑶，\n并以械逼周主赦赵匡胤。周主避入后宫不出。郑子明急赴法场护赵匡胤。时，苗光义以死力保，周主见众叛\n亲离，始允赦赵匡胤。赵匡胤、郑子明从此衔恨离朝。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大纛、二旗牌、郑子明、苗光义、高怀德、高怀亮同上。"
        },
        {
          "character": "郑子明",
          "type": "念",
          "text": "雌雄眼能观天下，"
        },
        {
          "character": "苗光义",
          "type": "念",
          "text": "断阴阳分毫无差。"
        },
        {
          "character": "高怀德",
          "type": "念",
          "text": "白龙马足踏金蹬，"
        },
        {
          "character": "高怀亮",
          "type": "念",
          "text": "梅花枪保定邦家。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "本爵、北平王郑子明。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "老夫、护国军师苗光义。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "本爵、万里侯高怀德。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "本帅、还乡侯高怀亮。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "苗光义、高怀德、高怀亮",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "二哥有帖相邀，不知所为何事？"
        },
        {
          "character": "苗光义、高怀德、高怀亮",
          "type": "同白",
          "text": "你我大家同到南宋府，便知明白。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "来呀！打道南宋府。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、门官引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "引子",
          "text": "玉兔霞光，保定大哥锦家邦。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "忆昔当年创帝邦，天牢苦坏二高堂。刺杀刘皇保柴主，官封一字南宋王。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "本爵、赵匡胤。在柴主驾前为臣。只因南唐窦瑶进来一女，名曰文姬。圣上见 喜，将她封为西宫伴驾。封窦瑶为平章公。造府不及，命他游街三日。不论哪 家王府，任他挑选，暂住几月。想本爵怎容此事，也曾邀请众位王侯，议论此 事，灭却此贼，以振朝纲。 门官！"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众家王爷到此，即来通报。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "郑子明、苗光义、高怀德、高怀亮",
          "type": "内同白",
          "text": "众位王爷到！"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "众位王爷到！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。郑子明、苗光义、高怀德、高怀亮同上。〖吹打〗。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众位王爷驾到，未曾远迎，面前恕罪。"
        },
        {
          "character": "郑子明、苗光义、高怀德、高怀亮",
          "type": "同白",
          "text": "岂敢。我等来得鲁莽，二千岁海涵。"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "相邀我等到此，所为何事？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众家王爷有所不知。只因南唐窦瑶老贼，进来一女，名曰文姬。圣上见喜，将 她封为西宫伴驾。封窦瑶老贼以为平章公。造府不及，命他游街三日。不论哪 家王府，任他挑选，暂住几月。想本爵怎能容得！相邀众位王爷到此议论此事， 灭却老贼，以振朝纲。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "哈！这个狗娘养的有这等事情！"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "列位王爷！想那窦瑶老贼，若占老夫的府第……"
        },
        {
          "character": "苗光义",
          "type": "唱",
          "text": "忆自学法在仙山， 陈抟老祖把道传。 闲来山前观虎斗， 闷来山后听鸟喧。 无是无非全不管， 落个自在与清闲。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "大家忠心无二念， 文臣武将保江山。 来朝一本奏金殿， 辞官不做回家园。"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "抖抖精神枪一杆， 一马杀进寿州关。 灭却老贼除后患， 那时仍回火塘前。"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "郑子明闻言心欢畅， 想起了当年事一桩。 弟兄们结拜把香上， 胜似一母共同娘。 直许下一在三在有福共享， 一死三亡同无常，也落个青史名标万古流芳！ 同心协力把基业创， 东挡西杀马蹄忙。 咱大哥柴世荣帝王模样； 咱二哥赵匡胤威震八方。 走关东，关西闯， 谁人不知赵玄郎！ 拳打五虎把命丧， 董家桥前摆战场。 鞭坠董龙、董虎丧， 扶保俺大哥锦绣家邦。 到如今出了个窦瑶狗奸党， 依某想：他比赵高，似王莽，赛杨广，他就败坏纲常。勾引了俺大哥把江山大 事付汪洋！ 越说越恼气上撞， 尊一声列公细听端详： 你们只管把宽心放， 看某今日闹一场！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "列位说话有胆量， 大胆的老贼太猖狂。 我若灭却狗奸党， 大家同心保朝堂！"
        },
        {
          "character": "苗光义",
          "type": "白",
          "text": "列位王爷，你我大家上殿保奏便了！"
        },
        {
          "character": "赵匡胤、郑子明、高怀德、高怀亮",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "苗光义",
          "type": "唱",
          "text": "辞别千岁出府往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苗光义下。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "同心协力奏君王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德下。"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "吉凶二字人难量，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮下。"
        },
        {
          "character": "郑子明",
          "type": "唱",
          "text": "老郑心中有主张。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "回营我对官儿讲，"
        },
        {
          "character": "郑子明",
          "type": "白",
          "text": "官儿！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "那窦瑶到此报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、郑子明同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、四下手、窦龙、窦虎引窦瑶同上。"
        },
        {
          "character": "窦瑶",
          "type": "引子",
          "text": "赤面雄心，须发银，秉忠心，扶保圣君。"
        },
        {
          "character": "窦瑶",
          "type": "念",
          "text": "我本河北一窦瑶，须发美髯似银条。吾女西宫伴王驾，父子三人归天朝。"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "老夫窦瑶。乃南唐人氏。所生二子：长子窦龙；次子窦虎。吾女文姬，进献当 今。柴王见喜，封为西宫伴驾。将老夫封为平章公，命老夫游街三日。造府不 及，不拘哪家王府，任老夫挑选，暂住几月。 二孩儿！"
        },
        {
          "character": "窦龙、窦虎",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "吩咐外厢开道！"
        },
        {
          "character": "窦龙、窦虎",
          "type": "同白",
          "text": "外厢开道！"
        },
        {
          "character": "窦瑶",
          "type": "唱",
          "text": "这也是圣天子龙恩有道， 挑王府命老夫游街三朝。 皆因是我女儿颇有才貌， 封西宫伴王驾随侍龙朝。 从今后我就是当今国老， 哪一个敢不尊一品当朝！ 顺吾者不过是升官荣耀， 逆吾者奏一本项上加刀。 教人来你与我前行开道， 来至在南宋府用目观瞧。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "来此南宋府！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "住轿。来此南宋府，倒还清净，待老夫进去暂住几月，有何不可？哎呀且住。 内有皇太在内，倒有些不便。 来，开道过府！"
        },
        {
          "character": "窦瑶",
          "type": "唱",
          "text": "人来鸣锣忙开道， 炫赫过府乐逍遥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "门官上。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "这窦瑶老贼，这是什么地方，竟敢鸣锣开道！千岁知道，我吃罪不起。不免报 与千岁知道。 有请千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "独坐书斋心烦闷， 恼恨奸贼太不情。 开言来便把门官问， 想是老贼到来临。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "窦瑶老贼，府前经过，不曾下马，鸣锣过府。您瞧可恼不可恼？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "看金锏伺候！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "胆大老贼不自省， 是他自己惹祸根。 人来带路府门等，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤走圆场。门官下。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "我看老贼哪里行？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、四下手、窦龙、窦虎引窦瑶同上。"
        },
        {
          "character": "窦瑶",
          "type": "唱",
          "text": "金瓜钺斧朝天蹬， 黄罗伞罩定御皇亲。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "来此府门。"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "住轿。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "坐在金阶用目瞧，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "那边厢来了老窦瑶。 眉横一字须白了， 看来是一个老儿曹。 虽然他白发苍苍年纪老， 亚赛过秦国老赵高。 倚仗他女容颜好， 西宫伴驾乱当朝。 他好比三国奸曹操， 上欺天子下压群僚。 越思越想心头恼， 定除奸贼去祸苗。 回言便把官儿叫， 本爵言来你听着： 报与三千岁得知晓， 你就说千岁爷要打窦瑶。"
        },
        {
          "character": "窦瑶",
          "type": "唱",
          "text": "站立金阶心惊跳， 那旁坐定赵英豪。 老夫一见事不好， 今日必定要糟糕！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "二千岁请了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "怒气不息，为着谁来？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "就为你来！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "为老夫何来？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "我且问你，圣上钦赐本爵三尺禁地，九根挡柱；文官下轿，武将离鞍。你是甚 等样人，敢鸣锣过府？"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "还是老王亲封，还是见功敕赐？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "乃是我主见功敕赐！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "既是我主见功敕赐，老夫不才，官封平章公，所以行走得。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你待怎么讲？"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "行走得。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "听一言来怒气生， 骂声大胆狗奸臣！ 我只当你三弓两箭挣， 裙边带的狗皇亲。 暗用胭粉乱朝政， 搅乱我朝不安宁。 狼心狗肺非人品， 天下的国贼头一名。 披毛带掌非人类， 摇摇摆摆算不得人。 站立府门骂奸佞， 我朝哪有你这样人！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "哎呀骂得狠。 哎呀二千岁！老夫开口二千岁，闭口也是二千岁。你骂得老夫，难道老夫就骂 不得你！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "谅你也不敢！"
        },
        {
          "character": "窦瑶",
          "type": "白",
          "text": "哈哈，我得罪了！"
        },
        {
          "character": "窦瑶",
          "type": "唱",
          "text": "不才皇亲一国丈， 出言就把老夫伤！ 窦龙、窦虎齐动手！"
        },
        {
          "character": "窦龙、窦虎",
          "type": "同白",
          "text": "打出事来呢？"
        },
