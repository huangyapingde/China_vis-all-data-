{
  "script_id": "03041005",
  "title": "战山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "罗成",
      "hangdang": "小生"
    }
  ],
  "plot": "隋末，杨林败于罗成，秦琼大笑。杨林恼羞成怒，遂问秦琼以“惊驾”罪。经李渊保奏，得免。秦琼、杨林\n遂赌：秦琼若胜罗成，杨林输玉带；罗成若胜秦琼，秦琼献己头。秦琼、罗成原为姑表兄弟，罗成之锏法，\n俱系秦琼授；秦琼之枪法，虽由罗成教，然隐匿不全。故秦琼实则无以胜罗成。及见阵，秦琼以赌头实告。\n罗成念戚谊，让秦琼一阵，而瓦岗兄弟均笑罗成不胜秦琼。罗成愧极，二次下山，要与秦琼决一死战。秦琼\n痛哭流涕，责以往事。罗成终被感动，佯败而归。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗成上，起霸。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "少小英雄志凌云，万马军中显奇能。上阵跨下白龙马，全凭——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成走圆场，四下手自两边分上。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "梅花枪一根！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "俺、罗成。在西魏王李密驾前为臣。前日奉了徐三哥将令，与杨林老儿交战， 被俺打了一锏，打得那厮望风而逃。今日又奉将令，前去骂阵。 众喽兵！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "站立两厢，听我号令！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "有豪杰在山岗忙传将令， 叫一声众喽兵细听详情： 此一番战隋营人人奋勇， 若退后将尔等插箭游营。 叫儿郎你与我忙下山岭， 不杀那杨林贼誓不回营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "解粮打赌把印争， 会会表弟小罗成。 秦琼打马往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "罗成打马随后跟。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "黄骠马坐定秦叔宝，"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "白龙马坐定小罗成。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "秦琼马上呼表弟，"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "罗成马上呼表兄。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "啊，我道是谁，原来是二哥！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "我道是谁，原来是贤弟！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "啊二哥，为何军中打扮？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟不知，愚兄在隋营吃了一份粮饷。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "如此恕小弟少来恭贺！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "岂敢！啊贤弟，可与杨林交过战来？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "与杨林交过一战，被小弟一锏，打得他望风而逃。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哈哈哈！这隋营中都道贤弟是一员虎将。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "二哥夸奖了！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "是愚兄在辕门外大笑了一声。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "啊！敢是笑着小弟？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "这！哈哈哈……焉敢笑着贤弟？笑只笑杨林不知进退。那时杨林恼羞成怒，将 愚兄问了个“惊驾”之罪。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "多亏何人保奏？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "多亏唐国公李千岁保奏，才得活命。我与杨林以人头与蟒袍相赌，前来会战贤 弟。兄若不胜，愿输项上人头。啊贤弟，此阵你还是让也不让？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "这！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "二哥说哪里话来？你我姑表弟兄，漫说一阵，就是三阵两阵，又待何妨。只是 让阵便让阵，你我许久未会，这枪头无眼！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟，这锏下无情！"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "若要人不知，"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "除非己不为。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "二哥好比汉关公，"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "贤弟好比赵子龙。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "过五关曾斩六员将，"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "长坂坡前救主公。 叫贤弟让开马能行，"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "这一锏看在姑表情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        },
        {
          "character": "秦琼",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "好一个情义小罗成， 假败一阵让我赢。 两军阵前得了胜， 蟒袍玉带赌得成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "广武山前败了阵， 催马回到泰山营。 豪杰打马把山岗上，"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "罗成败阵，叫我等好笑哇，啊哈哈哈……"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "又听得众家弟兄发笑声。 道我不胜秦叔宝， 羞得豪杰满脸红。 一恼二次下山岭， 不胜秦琼不回营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "头戴金盔凤翅缨， 手拿劈棱锏二根。 催马来在广武岭， 瓦岗英雄听详情： 别的儿郎休出马， 单要英雄小罗成。 我这里十骂九不应， 个个低头不作声。 豪杰打马下山岭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "又见表弟怒气冲。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "啊！他二次下山，为何这般模样？哦哦是了，他乃年幼之人，待我说几句好话， 打发他回去。 啊表弟，你又来了？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "我来了。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟既已让阵，又来作甚？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哪个？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "奉了徐三哥将令，请二哥上山赴宴。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "愚兄有言在先，得了蟒袍玉带，再上山去看望众家弟兄。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "啊，你是去也不去？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "愚兄不去，你便怎样？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你若不去，小弟就要无礼了！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "啊，难道愚兄惧你不成？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "我还怕你不成！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "我还惧你不成！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "我还怕你不成！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "贤弟不必逞刚强， 刚强怎比楚霸王？ 霸王逞强乌江丧， 韩信强来丧未央。 贤弟今日把阵让， 愚兄知恩永不忘。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "二哥不必皱双眉！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "愚兄岂是怕人的？"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "罗门花枪忙施起，"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "劈棱双锏世间稀。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "按住花枪用锏打！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "凤凰点头躲不及。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "表弟好锏法！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "二哥也不差！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你这锏法何人教导你的？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "二哥教导我的。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "住了！愚兄教你在两军阵前，打那王子令公。怎么今日在广武山前，连师傅都 打起来了？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "二哥，有道是有智不施不如无。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呕，好个“有智不施不如无”！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "今日定要与你见个胜败！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "奴才！你可记得“传花过锏”之事？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "年深日久，倒也忘怀了。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "提起“传花过锏”之事，叫我好恨！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "敢是恨着于我？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哼！你且听了！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你且讲来！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你且听道！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你且讲来！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "提起传花过锏恨， 不由豪杰恼在心。 愚兄路过黄沙岭， 打死张琪去投军。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "只因愚兄时运不济，将店家打死，发配幽州，以为军犯。幽州乃是你父罗艺镇 守，出有晓谕在外，凡是天下囚犯到此，先打一百梢连棍，高搭坛台，丢下台 去不死，再抬上堂来问话。那时愚兄去得正巧，乃是姑母生日，你父接旨去了， 我在丹墀哭了一声“太平郎好命苦！”谁想惊动后堂姑母，将我带至后堂， 细问情由，姑侄相会。你父接旨回来，问道：中军，方才丹墀那一囚犯哪里去 了？中军言道：乃是太夫人带往后堂去了。姑夫连忙走到后堂，姑母说出情由， 一家骨肉重逢。你这奴才在郊外打猎回来，见了愚兄，理也不理，扬长就走。 彼时愚兄问道：这员小将他是何人？姑夫、姑母言道：乃是你表弟罗成。然 后你父问道：秦琼，你在家所用是何兵器？那时愚兄言道：小侄久走江湖，习 学一对劈棱双锏。姑夫言道：好！你弟兄二人，就在后花园中传花过锏。我将 秦门金锏，都教导与你；谁想你这奴才，将罗门花枪，不曾全教与我。不想到 了霜降之时，众将操演已毕，姑夫就传下一令：众将不要散去，看二位少爷比 试。你这奴才，将我秦门金锏，耍了一回，犹如那花朵一般。我将你罗门花枪， 耍了一回，枪枪有空——漫说伤人，连自身都是难保。那时姑夫问道：秦琼， 此枪何人所教？愚兄说道：乃是表弟罗成所教。那时你父问道：罗成！你这 奴才，教枪为何不全？你这奴才言道：为大将者，须留几枪防身。你可记得， 姑夫那时骂你的言语？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "记之不清。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你且听道！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你且讲来！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你且听道！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "骂你短命小罗成， 长寿百岁是秦琼。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你这奴才，气性高大，将画杆戟抛在尘埃，扬长就走。有道是：父母有爱子之 心。那时姑夫传下一令：众将，我左有罗成，右有秦琼，有你们不多，无你们 不少。这一句话不值紧要；谁想打冷众将之心，到了三更时分，众将鼓噪闹起。 姑夫、姑母走出大营一看，只气得口吐鲜血而亡了！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "众将三更来鼓噪， 你一双爹娘把命抛。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你这奴才，见你爹娘一死，手拿白银枪，只知杀进，不知杀出。那时愚兄手拿 双锏，杀了个双进双出，又一马双跨——"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "一马双跨搭救你， 带你到雄信家中去安身。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "愚兄将你救出营来，带到雄信家中安身，难道你都忘了么！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呃呀！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "再不要提起单雄信， 提起雄信怒气生。 日间教我放响马， 晚来把我当苦工。 恨不得一枪刺死你， 想我让阵万不能！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "听一言来怒气生， 不由秦琼恨在心。 背地里骂声单雄信， 把罗成当作雇工人。 眼前若有雄信在， 打一锏来问一声。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "凭你说得天花坠， 想俺让阵梦不成！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "豁喇喇刷开劈棱锏， 要与奴才定输赢！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呔！你敢是怯战？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "啊贤弟，你可知军中号令？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "为大将者，岂有不知！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "这一卯不到？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "一捆四十。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "二卯不到？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "两捆八十。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "三卯不到？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "住了！身为大将，哪有“三卯不到”之理？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "奴才！三卯不到，定要取你项上人头！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "不必多言！今日定要与你决一死战！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "啊，难道愚兄怕你不成？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "难道小弟怕你不成？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "越杀越勇罗士信， 秦琼越战少精神。 不战奴才走了罢！"
        },
        {
          "character": "罗成",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "只听得奴才发笑声。 恨不得使锏打死你， 罗门只有这条根。 秦琼死了还有后， 打死奴才绝了根。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "我罗成情愿绝了后， 想我让阵万不能！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "好话说了千千万， 他那里只当耳边风。 为朋友我卖过黄骠马， 为朋友夜宿古庙中； 为朋友受尽千般苦， 为朋友搭救程咬金； 为朋友受了多少气， 为朋友抛别老娘亲。 眼望历城双流泪， 看他知情不知情？"
        },
        {
          "character": "秦琼",
          "type": "哭头",
          "text": "高堂母啊！贾氏妻呀！怀玉我的儿呀！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "父子相逢万不能。 那徐三哥倒有结拜义， 罗成全无姑表情。 回言便把贤弟叫， 拿我的首级去献杨林。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "拿去拿去！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "听一言来两泪淋， 铁石人儿也动情。 徐三哥倒有结拜义， 难道罗成就无姑表情？ 低下头来暗思忖，"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "有了！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "猛然一计兜上心。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "啊二哥，你来看，众家英雄多在山岗掠阵，我与二哥假战三合，待俺咬破指尖， 口吐鲜血，助你成功便了！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "噢！贤弟此阵让了愚兄？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "让便让，日后不要忘了此情！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "怎敢忘却此情！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "如此放马过来！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "豁喇喇撒开马能行，"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "这一枪念在姑表亲。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成咬指吐血。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "广武山前得了胜， 欢欢喜喜见杨林。"
        },
        {
          "character": "秦琼",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
