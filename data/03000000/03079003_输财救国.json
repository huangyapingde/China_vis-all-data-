{
  "script_id": "03079003",
  "title": "输财救国",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "卜式",
      "hangdang": "老生"
    }
  ],
  "plot": "汉武帝时，匈奴犯境。河南卜式输家财之半以充军饷；并捐钱二十万赈济灾民。河南百姓，大受感动，群起\n而御侮。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、四太监、大太监引刘彻同上。"
        },
        {
          "character": "刘彻",
          "type": "引子",
          "text": "宾服四夷，振天威，重整帝基。"
        },
        {
          "character": "刘彻",
          "type": "念",
          "text": "云里帝城双凤闕，雨中春树万人家。要把匈奴齐扫尽，奠定金瓯报中华。"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "孤、大汉皇帝刘彻。自登基以来，承先世文景之治，倒也安享太平。怎耐北贼 匈奴屡犯边境，必须大举扫荡，早息狼烟。前有河南民人卜式，上书前来，愿 输家财之半，以助边庭征战之用。后又捐钱二十万，赈济河南离乱百姓。似这 等爱国男儿，真是十分难得。也曾命使臣驰往宣召，未见回报。正是："
        },
        {
          "character": "刘彻",
          "type": "念",
          "text": "苍天助炎汉，指日靖边庭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "使臣上。"
        },
        {
          "character": "使臣",
          "type": "念",
          "text": "宣召卜式到，上殿把旨交。"
        },
        {
          "character": "使臣",
          "type": "白",
          "text": "叩见万岁！"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "使臣",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "命你宣召卜式，怎么了？"
        },
        {
          "character": "使臣",
          "type": "白",
          "text": "卜式已经召来，现在午门候旨。"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "宣他上殿！"
        },
        {
          "character": "使臣",
          "type": "白",
          "text": "万岁有旨：卜式上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "使臣下。"
        },
        {
          "character": "卜式",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卜式上。"
        },
        {
          "character": "卜式",
          "type": "念",
          "text": "布衣躬畜牧，今日上丹墀。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "臣，河南小民卜式，叩见天颜！"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "闻尔输家财助边，真乃爱国之士。但不知尔可愿为官？"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "小臣出身畜牧，未习吏事，不愿为官。"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "你既不愿为官，想是你家有何冤仇，不妨奏与孤王，替你昭雪就是。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "小臣素来好施，与人无争，并无什么冤仇。"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "但不知你捐输巨款，有何需求？"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "臣并无什么需求。只因万岁征讨匈奴，依小臣看来，凡我大汉臣民，贤能者应 守边死节，厚富者应尽力输财。只要全国上下，有此决心，何愁匈奴不灭？"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "言之有理。待孤晓谕天下，矜式万民。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "小臣怎敢！"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "好！尔既出身畜牧，就命尔在上林替孤牧羊。封尔为中郎，长享爵禄。下殿去 吧！"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "卜式",
          "type": "二黄摇板",
          "text": "叩谢万岁下龙廷， 去做上苑牧羊的人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卜式下。"
        },
        {
          "character": "刘彻",
          "type": "二黄摇板",
          "text": "拂龙袖王退班后宫来进， 但愿得灭匈奴早庆升平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "卜式赶羊群上。"
        },
        {
          "character": "卜式",
          "type": "二黄三眼板",
          "text": "我炎汉承天运江山一统， 恨匈奴寇边庭窥伺华中。 自幼儿习畜牧兼事耕种， 为输财救边患才得荣封。 虽然在御驾前蒙恩深重， 依旧是布衣草履、上苑牧羊、沐雨栉风。 洒不尽忧时泪哀心隐痛， 只要那匈奴灭哪怕贫穷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引刘彻同上。"
        },
        {
          "character": "刘彻",
          "type": "二黄摇板",
          "text": "旌旗日暖龙蛇动， 宫殿风微燕雀高。 内待臣摆驾上林到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘彻观羊群，卜式跪。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "臣、卜式接驾，吾皇万岁！"
        },
        {
          "character": "刘彻",
          "type": "二黄摇板",
          "text": "卜爱卿牧群羊备尽辛劳。"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "卜卿，自你到上林以来，羊群日见肥壮，卿家真乃畜牧之能人也！"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "臣启万岁：世间万事，同为一理。若以臣牧羊之道，治理百姓，使其善者蕃殖， 不善者斥去，勿使害群，此乃治国之本。况臣出身畜牧，羊群肥壮，何足挂 齿！"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "言之极是。卿家经世大才，岂可久事畜牧？孤有意封卿为缑氏令，卿意如何？"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "小臣不愿为官，愿在上苑，随侍圣驾。"
        },
        {
          "character": "刘彻",
          "type": "白",
          "text": "不必推辞，明日候旨上任去吧！"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "刘彻",
          "type": "二黄摇板",
          "text": "大材岂可小材用，"
        },
        {
          "character": "卜式",
          "type": "二黄摇板",
          "text": "感恩何以报九重？"
        },
        {
          "character": "刘彻",
          "type": "二黄摇板",
          "text": "御香缥缈龙蛇动，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、刘彻同下。"
        },
        {
          "character": "卜式",
          "type": "二黄摇板",
          "text": "竭忠保国显英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卜式下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "父老甲、父老乙、父老丙、父老丁同上。"
        },
        {
          "character": "父老甲",
          "type": "念",
          "text": "宁为太平犬，"
        },
        {
          "character": "父老乙",
          "type": "念",
          "text": "不作离乱民。"
        },
        {
          "character": "父老丙",
          "type": "念",
          "text": "但愿匈奴灭，"
        },
        {
          "character": "父老丁",
          "type": "念",
          "text": "早日享太平。"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "父老乙、父老丙、父老丁",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "想那匈奴连年为患，河南地方屡遭兵灾，仓库空虚。前年我们这里卜式先生捐 资赈济，我们才得活命。如今边患未灭，像卜先生这样的好人，不知道到哪里 去了？"
        },
        {
          "character": "父老丁",
          "type": "白",
          "text": "你还不知道哪？他老人家赈济我们，花了不少钱哪！前三年北边吃紧的时候， 他老人家上书给皇上，愿意拿他的一半家财，捐助国家，扩充军备，去打外国 人。皇上早就把他老人家聘请去啦，由上林牧羊起，就有了很好的成绩，一直 升官，真是连升三级。如今唤做了齐王太傅，那儿的百姓谁不拥护他老人家？ 你怎么一点不知道呢？真是老糊涂了不是？"
        },
        {
          "character": "父老乙",
          "type": "白",
          "text": "想我乡里不靖，生计困难。何不去到临淄，投奔卜太傅，一来谢谢他老人家再 造之恩；二来投效乡里，寻个进身之计。不知列位意下如何？"
        },
        {
          "character": "父老丁",
          "type": "白",
          "text": "好极啦！反正咱们在家里待着，也没有好日子过，要是有机会的话，咱们也可 以上前线去杀敌人，岂不也是一个英雄，名垂千古吗？"
        },
        {
          "character": "父老甲、父老丙",
          "type": "同白",
          "text": "如此甚好。我们就此一同前往，请哪！"
        },
        {
          "character": "父老甲",
          "type": "二黄摇板",
          "text": "卜先生待我等恩德高厚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "父老甲下。"
        },
        {
          "character": "父老乙",
          "type": "二黄摇板",
          "text": "千里迢迢把齐投。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "父老乙下。"
        },
        {
          "character": "父老丙",
          "type": "二黄摇板",
          "text": "誓扫狼烟平贼寇，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "父老丙下。"
        },
        {
          "character": "父老丁",
          "type": "二黄摇板",
          "text": "大刀砍尽敌人的头！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "父老丁下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "卜式",
          "type": "内二黄导板",
          "text": "听谯楼打初更人声悄悄，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卜式上。"
        },
        {
          "character": "卜式",
          "type": "回龙",
          "text": "为国家秉忠心昼夜辛劳。"
        },
        {
          "character": "卜式",
          "type": "二黄原板",
          "text": "想当初输家财致身荣耀， 由上林迁缑氏又长成皋。 忧国事恨匈奴边患未了， 无有功勋报答圣朝。 到如今吕嘉贼南越反了， 自愧书生未习弓刀。 思来想去难抒怀抱，"
        },
        {
          "character": "卜式",
          "type": "二黄散板",
          "text": "惜微躯贪利禄不算英豪！"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "下官，卜式。乃河南人氏，官拜齐王太傅。只恨匈奴之患未平，南越吕嘉又反， 自愧书生不习戎马，刀兵扰攘，不知何日方得太平？下官身受国恩，岂能袖 手旁观，看水舟流？这！这！这！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乱锤。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "啊呵有了！我不免上一本章，率领我子，及齐国善射习船之士，请缨杀贼，以 救国家。嗯，我就是这个主意！我就是这个主意啊！"
        },
        {
          "character": "卜式",
          "type": "二黄摇板",
          "text": "男儿报国凭忠勇， 死到沙场是善终。 我这里修本章泪如泉涌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卜式修本。"
        },
        {
          "character": "卜式",
          "type": "二黄碰板",
          "text": "臣卜式冒死启奏九重： 主有忧臣之辱负罪深重， 何况那匈奴未灭南越又反屡起边烽！ 臣待罪在齐国有负禄奉， 一心要平贼寇建立微功。 率臣子及全齐水兵乡勇， 陆地干戈水上弓。 望万岁准臣本大兵兴动， 固边疆定山河誓死从戎。 修罢了本章曙光动，"
        },
        {
          "character": "卜式",
          "type": "二黄摇板",
          "text": "但愿得纶音降早奏膺功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卜式下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "父老甲、父老乙、父老丙、父老丁同上。"
        },
        {
          "character": "父老甲",
          "type": "二黄摇板",
          "text": "一日离家一日深，"
        },
        {
          "character": "父老乙",
          "type": "二黄摇板",
          "text": "好似孤雁宿寒林。"
        },
        {
          "character": "父老丙",
          "type": "二黄摇板",
          "text": "披星戴月来齐境，"
        },
        {
          "character": "父老丁",
          "type": "二黄摇板",
          "text": "不觉来到太傅门。"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "啊列位，看前面已是太傅府，我们少时进见，不可鲁莽。"
        },
        {
          "character": "父老乙、父老丙、父老丁",
          "type": "同白",
          "text": "那个自然。大家小心就是。"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "门上哪位在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "劳烦通禀太傅：就说河南乡人们求见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "少待一时。"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请家爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卜式上。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "河南父老们求见。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "快去请他们进来！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。 太傅有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗下。父老甲、父老乙、父老丙、父老丁同进见，同跪。"
        },
        {
          "character": "父老甲、父老乙、父老丙、父老丁",
          "type": "同白",
          "text": "小人们与太傅叩头！"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "岂敢！列位少礼，请坐！"
        },
        {
          "character": "父老甲、父老乙、父老丙、父老丁",
          "type": "同白",
          "text": "太傅在此，哪有小人们的座位？"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "远道而来，又是同乡父老，哪有不坐之理！"
        },
        {
          "character": "父老甲、父老乙、父老丙、父老丁",
          "type": "同白",
          "text": "我等告坐。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "今年秋收可好，乡里可靖？"
        },
        {
          "character": "父老甲、父老乙、父老丙、父老丁",
          "type": "同白",
          "text": "年成倒也不差。只是地方不甚平靖。乡人们都好，问候太傅金安。"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "有劳他们！列位远道到此，必有所为？"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "我等身受厚恩，无以为报；何况匈奴未平，故乡不靖。我们一来是看望太傅， 报答再造之恩；二来是投效府前，寻个进身之计。如有需要小人们之处，虽赴 汤蹈火，万死不辞！"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "列位哪里话来！下官前者输财助边，散钱施赈，无非是尽我爱护国家乡党之心， 何有功德可言？试问国亡之后，纵有万贯家财，焉能享有？古人云：“皮之 不存，毛将安附？”现在正是国家多事之秋，列位身许下官，不如以身许国。 必须要全国上下，智者尽其能，勇者尽其力，富者输其财，协力同心，共御外 侮，何愁匈奴不灭，海宇不平也！"
        },
        {
          "character": "卜式",
          "type": "二黄摇板",
          "text": "劝列位休提起恩德二字， 应效忠为国家万死不辞。 富输财穷输力同心一致， 定能够平贼寇宾服四夷。"
        },
        {
          "character": "父老甲",
          "type": "白",
          "text": "太傅金石之言，我等敢不遵命！"
        },
        {
          "character": "父老丁",
          "type": "白",
          "text": "啊太傅！听了你这一番话，真不愧救国的名言！小人不才，也忍不住热血奔腾， 恨不得马上就去打冲锋，杀敌人去。可惜我是个穷小子，要是有钱的话，一 定要全拿出来，贡献给我们的国家。闻听人言，太傅上了一道本章，请缨讨贼， 我愿意在太傅指挥之下，做一名士卒。不知尊意如何？"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "好倒好，只是万岁旨意下来，暂时不欲我齐国出兵。列位有此热忱，下官十分 钦敬，来日方长，自有效力之处。只要人人不惜性命，不爱金钱，为国忘家， 誓死御侮，将来大汉河山，必能永保，廓清海宇，得享太平。备得有酒，与列 位洗尘。正是："
        },
        {
          "character": "卜式",
          "type": "念",
          "text": "国破家亡无限恨，"
        },
        {
          "character": "父老甲、父老乙、父老丙、父老丁",
          "type": "同念",
          "text": "毁家纾难胜古人！"
        },
        {
          "character": "卜式",
          "type": "念",
          "text": "但愿匈奴齐扫尽，"
        },
        {
          "character": "父老甲、父老乙、父老丙、父老丁",
          "type": "同念",
          "text": "全仗男儿爱国心！"
        },
        {
          "character": "卜式",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}