{
  "script_id": "03013002",
  "title": "查关",
  "alias": [
    "尤家关"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "尤春风",
      "hangdang": "旦"
    },
    {
      "name": "苏利燕",
      "hangdang": "丑"
    },
    {
      "name": "刘唐建",
      "hangdang": "小生"
    }
  ],
  "plot": "汉元帝太子刘唐建出征战败，回朝求援。行至尤家关，天晚闭城，不能通过，遂在关前歇睡。守关尤都督之\n女尤春风携从人查关，见刘唐建人品非凡，乃窃取刘唐建之枪马，唤入盘查。刘唐建隐语瞒哄，被尤春风识\n破，两相爱悦，约订终身。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建上。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "休赶，休赶！"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "我今奉旨出朝堂， 七星台前摆战场。 一人一骑难交战， 勒马回头望故乡。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "小王刘唐建。奉父王旨意，七星台前，摆下战场，被那贼杀得大败，俺回朝搬 动人马。前面已是尤家关。催马趱行者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尤春风、丑丫头同上。"
        },
        {
          "character": "尤春风",
          "type": "念",
          "text": "头打三股辫，两耳坠金环。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "咱家尤春风。奉了都督之命，把守尤家关。每逢三六九日，查关之期。 来呀！"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "传苏利燕！"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "传苏利燕！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕上。"
        },
        {
          "character": "苏利燕",
          "type": "数板",
          "text": "上河流水淅漓漓漓漓！下河流水哗啦啦啦啦！二人盖着个破被窝。动也不敢动， 拉也不敢拉。动一动淅漓漓漓漓！拉一拉哗啦啦啦啦！只得由他，只得由他。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我苏利燕。正在后面除草，忽听姑娘呼唤，进去瞧瞧去。 报！苏利燕告进。姑娘在上，苏利燕请安。⑴"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "罢啦。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "您叫我出来，有何屁放？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "嗳，有何话讲！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "哦，有何话讲。您叫出我来有什么事？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "叫你出来，咱们今儿个该查关去了。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "昨儿查了，怎么今儿个又查？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你昨儿吃饭，今儿还吃不吃？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "饭不吃饿的慌。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "饭是一顿一顿的吃，关是一天一天的查。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "饭是一天一天的吃，关是一顿一顿的查。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你说倒了！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "甭管倒不倒啦，咱们查关去！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "查关去！"
        },
        {
          "character": "尤春风",
          "type": "西皮导板",
          "text": "尤春风尊奉了都督之命，"
        },
        {
          "character": "尤春风",
          "type": "唱",
          "text": "昼夜里巡查不消停。 苏利燕你带路忙往前进！"
        },
        {
          "character": "苏利燕",
          "type": "唱",
          "text": "苏利燕不怠慢手打灯笼。⑵"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤春风、苏利燕、丑丫头同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建上。"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "扬鞭催马往前进， 举目抬头看分明。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "来在什么所在，待我下马看来。哎呀，前面关门封锁，不免打一盹睡便了。正 是："
        },
        {
          "character": "刘唐建",
          "type": "念",
          "text": "一觉放开心地稳，酣睡沉沉到阳台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建睡。尤春风、苏利燕、丑丫头同上。"
        },
        {
          "character": "尤春风",
          "type": "唱",
          "text": "急急走来急急行。"
        },
        {
          "character": "苏利燕",
          "type": "唱",
          "text": "苏利燕上前回禀一声。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "到了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "查关去！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "是啦。 查来啦。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哪查的？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "关里头。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "关里头是咱们人，查他干甚么？你给我关外头查去。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我不敢去，关外有老头子！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你小伙子，为什么怕老头子？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "什么老头子，就是老虎！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你腰里带着什么？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "是刀。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "它给你一口，你给它一刀。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "它一口把我咬死了，我哪儿拔刀去！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你好好查去，姑娘有赏。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "您赏给我什么？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我把她赏给你罢。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我不要她。她比我还寒伧哪。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我赏你两钱儿。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "怎么着赏钱？好！查关去了。 了不得啦，关外有亮子！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "姑娘看看。⑶ 苏利燕，你远瞧！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "是火。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "近瞧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕看刘唐建。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "了不得啦！有个小长虫，打嘴出来了，又进鼻子里去啦，呦！又打耳朵里出来 啦，又进了眼睛啦！哎呀，不出来了。 姑娘，有个小蛮子睡觉，有个长虫，出来进去直钻。一会他就死了！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "那是蛇钻七窍，真龙天子。苏利燕，你瞧瞧小蛮子，好一匹马，⑷盗去！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "盗马去喽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕牵马。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "盗来了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "好马，好颜色！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "好颜色。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么颜色？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我瞧不出来。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "拴在槽上。你瞧小蛮子，好一杆矛子。盗去。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕取矛。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "盗来了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "放下。苏利燕，你把他唤醒了，问他家住哪里，姓字名谁。说得明白，还他枪 马，放他过关。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "小蛮子醒来！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你拿过我的套马杆子来吧！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "俺的枪马呢？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "盗进关去啦。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "快快还俺枪马！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "要你枪马不难。你爷爷是谁？我是谁。你爸爸是谁？我是谁。你儿子是谁？"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "你是谁。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我不是谁。"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "开言便把户长叫。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你为什么骂我混账？"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "称呼你一户之长。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你叫我阿哥！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "阿哥听了！"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "去掉户长阿哥称。 家住赤手脱空县， 谎家庄上有门庭。 我父名叫谎员外， 我母吃斋又动荤。 你若问我名和姓， 云端说话屋里听。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "问来了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "照着他那样，回给我听。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "嗻！"
        },
        {
          "character": "苏利燕",
          "type": "唱",
          "text": "开言便把户长叫。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我打你！你怎么骂我混账？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "这是称呼呢。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你往常称呼我什么？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "姑娘。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "还是姑娘！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "苏利燕",
          "type": "唱",
          "text": "去掉户长把姑娘称。 他住在赤手脱空县， 谎家庄上有门庭。 他父名叫谎员外， 他母吃斋又动荤。 若问此人名和姓， 云端说话屋里听。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你让他赚了！你想这一只手，怎么能托起一个县城来！哪有家门？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "谎家庄。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "有姓唐姓王的，哪有姓谎的！我告诉你，瞒得了你，瞒不了姑娘。姑娘住在两 国交界，看过天下地理图，能通六国番语。他说了真名真姓便罢，如若不然， 你拔出刀来……"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "杀了他？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你吓唬吓唬他。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "小蛮子，你瞒得了我，瞒不了我们姑娘。说了真名真姓便罢，如若不然，我拔 出刀来……"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我吓唬吓唬你。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "家住大国长安地， 紫禁城内有门庭。 我父本是汉元帝， 我母名叫赛昭君。 你若问我名和姓， 刘唐建就是我的名。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "问来了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "什么地方？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你是什么地方来着？"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "大国长安地。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "地。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "大国长安地吧？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "不错。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "哪有家门？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "仔泥坑。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "紫禁城吧。他爸爸叫什么？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "旱烟袋。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "汉元帝。他母亲呢？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "赛勾葱。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "嗐！赛昭君。他叫什么？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "流糖馅。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "去你的吧！刘唐建。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你都知道，没事让我费这么半天事！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你说话不明，叫小蛮子自己进来，我要亲自问话哪。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "是啦。 小蛮子，我们姑娘叫你进去，要亲自问话。"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "我不进去。里面黑洞洞的！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "那是帐篷，到里头就亮了。走。 姑娘，我给拉进来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕拉自己进。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你拉着谁哪？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我，拉着我呢！ 我说你进去不进去？"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "我不进去。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我杀了你！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建进。"
        },
        {
          "character": "尤春风",
          "type": "南梆子导板",
          "text": "俏仙子离却了瀛洲阆苑，"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "关城了。噌！"
        },
        {
          "character": "尤春风",
          "type": "南梆子",
          "text": "似牛郎渡银河不用舟船。 用手儿搀住了小将手腕， 我和你牛皮帐把话来谈。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "苏利燕，装烟去！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "嗳。 小蛮子，你会拉弓不会？"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "不会。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我交给你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕教作拉弓式。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我给你摆好了，不许你动，动一动，要你的命！ 装烟去了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "小主呀！"
        },
        {
          "character": "尤春风",
          "type": "唱",
          "text": "谁家的罗裙不沾地？ 哪个猫儿不吃荤？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "烟来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建作开弓式、触苏利燕。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你怎么左右开呀？ 姑娘抽烟。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "赏给小蛮子抽吧！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "小蛮子抽烟！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "我不会。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "苏利燕，倒茶去！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "嗻。 小蛮子，你这儿来，给我当帽架。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕以帽置刘唐建手上。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "倒茶去了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "小主呀！"
        },
        {
          "character": "尤春风",
          "type": "唱",
          "text": "你在南朝我在番， 千里姻缘一线牵。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "茶来了。 你拿我的帽子来吧。 姑娘喝茶。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "赏给小蛮子喝！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "是。 小蛮子喝茶！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "喝不服。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "他喝不服。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "赏给你喝。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "谢谢姑娘。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "在这儿喝！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我也喝不服。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "遛马去！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "遛了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "饮去！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "饮了。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我把你个杂种！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕向刘唐建。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我把你个杂种！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你为什么骂他？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "因为什么他老瞅你？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我打你！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我打他！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘唐建扯尤春风。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "哎唷！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他挨着我你生气？ 小蛮子，你还挨着！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "别让他挨着他身上有疥。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你滚下去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕下。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "小主呀！"
        },
        {
          "character": "尤春风",
          "type": "唱",
          "text": "走上前来忙跪定， 尊声千岁把我封。"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "有日小王登龙位， 封你昭阳掌正宫。"
        },
        {
          "character": "尤春风",
          "type": "唱",
          "text": "叩头忙把龙恩谢， 四起八拜谢龙恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏利燕上。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "看见了！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "看见什么？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你给小蛮子跪着来着！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "姑娘多咱跪过人！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你瞧还有土哪！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你瞧哪儿有土，一个家雀两脑袋！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "哪儿哪？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤春风拍土。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "飞了！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "你告诉我便罢，如若不然，我告诉老都督去！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你瞧他是谁，他是幼主！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "大煮才熟得了哪。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他是皇帝！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "皇历？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他封了我啦！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "他疯了，拿鸡罩扣上。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "他封我一宫！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "告诉他，也封我一宫。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你们爷们家，不能封宫。封你一个官！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "凭他。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "小主，封他个官吧！"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "叫他听封。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "苏利燕听封！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "苏利燕",
          "type": "唱",
          "text": "双膝跪在尘埃地， 万岁封我哪部卿？"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "小王有日登龙位， 封你这么大这么大大把总。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我打你！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你为什么打他？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "他骂我杂种！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "我问问去。 幼主爷，你怎么骂他是杂种？"
        },
        {
          "character": "刘唐建",
          "type": "白",
          "text": "封他是把总。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "封你把总，不是杂种。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "怎么好哪？"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "请罪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤春风对刘唐建。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "说你的！"
        },
        {
          "character": "刘唐建",
          "type": "唱",
          "text": "有日小王登龙位， 封你这么大这么大大把总。"
        },
        {
          "character": "苏利燕",
          "type": "唱",
          "text": "叩罢头龙恩谢， 四起八拜谢龙恩。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "哦……"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你干什么哪？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "站班。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "还没登基呢！"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "这还反不了啊！"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "别闹啦。后帐摆宴，与幼主接风！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。刘唐建、尤春风、苏利燕同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "尤春风",
          "type": "stage",
          "text": "—————————— ⑴ 原本是："
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "报！苏利燕告进。 姑娘在上，苏利燕摩尼姑。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你这是怎么说话？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "我说的是蒙古话。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你往常见了姑娘怎么说话？"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "往常见了姑娘，请安。"
        },
        {
          "character": "尤春风",
          "type": "白",
          "text": "你还是请安。"
        },
        {
          "character": "苏利燕",
          "type": "白",
          "text": "请姑娘安。 ⑵ 原本唱词后有：牙布登、牙布登、牙布、牙布。 ⑶ 原本是：姑娘乌及乌及。 ⑷ 原本是：好一匹么喇利。"
        }
      ]
    }
  ]
}