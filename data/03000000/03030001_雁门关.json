        },
        {
          "character": "韩昌",
          "type": "唱",
          "text": "大宋兵强将又广， 雁门关前摆战场。 铁甲将军难抵挡， 尸山血海马蹄忙。 中国京剧戏考 《雁门关》【头本】 6"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "闻言暗自珠泪降， 老母带兵到番邦。 延顺埋名不敢讲，"
        },
        {
          "character": "杨延顺",
          "type": "白",
