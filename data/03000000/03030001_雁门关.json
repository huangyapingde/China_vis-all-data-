        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "你们玩儿去吧！"
        },
        {
          "character": "香郎、香姐",
          "type": "同白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二达婆引香姐、香郎同下。"
