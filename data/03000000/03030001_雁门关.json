        {
          "character": "杨延顺",
          "type": "白",
          "text": "是是是！儿臣告退！正是："
        },
        {
          "character": "杨延顺",
          "type": "念",
          "text": "异国飘零空弹泪，慈亲在望我心悲。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎，母亲哪！"
