        {
          "character": "青莲公主",
          "type": "白",
          "text": "把你的脑袋留下！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "一言止住杨延顺！"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "二达婆",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "吩咐把关的，有人出关，须见太后的令箭，方可放出；若是无有太后的令箭， 不准他出关。快去！"
        },
        {
          "character": "二达婆",
          "type": "同白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二达婆同下。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "点点珠泪箭穿心！ 中国京剧戏考 《雁门关》【头本】 8"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "你就说实话吧！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "家住磁州火塘寨， 父子九人保宋君。 金沙滩前遭围困， 一家大半丧残生； 我大哥长枪丧了命， 我二哥短剑赴幽冥； 我三哥马踏如泥粉， 四郎、八郎失落番营； 我父李陵碑下死， 昊天塔内葬天伦。"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "你别哭了！你那儿哭，我这儿心里头也怪难受的。哎！我问你，那杨家的寡妇 是谁呀？"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "都是我的嫂嫂。"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "别的我都不问，在南朝你有元配没有啊？"
