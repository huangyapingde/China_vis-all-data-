        {
          "character": null,
          "type": "stage",
          "text": "韩昌上。"
        },
        {
          "character": "韩昌",
          "type": "唱",
          "text": "失机败阵折兵将， 含羞带愧回朝廊。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "韩昌见驾，太后千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
