          "character": "青莲公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "青莲公主",
          "type": "唱",
          "text": "你无恩来你无义， 青莲不领夫妻情！ 中国京剧戏考 《雁门关》【头本】 9"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "青莲公主",
          "type": "唱",
          "text": "不如杀死姣生子， 作个断嗣绝后根！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青莲公主下。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎呀！待我赶上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延顺急下。"
        }
      ]
    },
    {
