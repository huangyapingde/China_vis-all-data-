  "plot": "宋、辽不和，连年争战，宋将杨延昭与辽将韩昌大战于雁门关，未分胜负。宋仁宗命佘太君领兵助战。十二\n年前，佘太君之子杨延辉与杨延顺均被辽兵擒去，杨延辉改名木易光，配碧莲公主；杨延顺改名王司徒，配\n青莲公主，均有子女。闻佘太君率兵至，二人均欲过营探母。杨延顺求助于青莲公主，经青莲公主诓令箭，\n遂得混过雁门关。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孟金榜、蔡秀英、杨八姐、杨九妹同上，同起霸。"
        },
        {
          "character": "孟金榜",
          "type": "念",
          "text": "幼学兵书志量高，"
        },
        {
          "character": "蔡秀英",
          "type": "念",
          "text": "赤胆忠心保宋朝。"
        },
        {
          "character": "杨八姐",
          "type": "念",
          "text": "六韬三略能征战，"
        },
        {
          "character": "杨九妹",
          "type": "念",
          "text": "谁识闺中女英豪！"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "孟金榜。"
        },
        {
          "character": "蔡秀英",
          "type": "白",
          "text": "蔡秀英。"
        },
        {
          "character": "杨八姐",
          "type": "白",
          "text": "杨春景。"
        },
        {
          "character": "杨九妹",
          "type": "白",
          "text": "杨春花。"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "诸位妹妹请了！"
        },
        {
          "character": "蔡秀英、杨八姐、杨九妹",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "圣上命太君挂帅，命我等以为左右先行。太君升帐，你我两厢伺候。请！"
        },
        {
          "character": "蔡秀英、杨八姐、杨九妹",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟金榜、蔡秀英、杨八姐、杨九妹分站两边。四宋兵引佘太君同上。"
        },
        {
          "character": "佘太君",
          "type": "引子",
          "text": "年老白发，受皇恩，乐享荣华。"
        },
        {
          "character": "佘太君",
          "type": "念",
          "text": "杨家为国秉忠心，南征北战动刀兵。我今拜将封侯印，定把萧邦一扫平。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "老身，佘氏太君。先夫杨继业，宋室为臣。只因潘洪诳驾幽州，使我众家孩儿 半丧于金沙滩！昨日宗保回朝搬兵，圣上命老身挂帅，调选雄兵十万，征剿北 番。 众将！ 中国京剧戏考 《雁门关》【头本】 2"
        },
        {
          "character": "孟金榜、蔡秀英、杨八姐、杨九妹",
          "type": "同白",
          "text": "太君！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "孟金榜、蔡秀英、杨八姐、杨九妹",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "此番出兵，非同小可，去到雁门关，必须把萧银宗一鼓而擒。今当黄道吉日， 孟金榜、蔡秀英听令！"
        },
        {
          "character": "孟金榜、蔡秀英",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "传令下去：兵发雁门关！"
        },
        {
          "character": "孟金榜、蔡秀英",
          "type": "同白",
          "text": "得令。 太君有令：兵发雁门关！"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套引杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "引子",
          "text": "钦奉君命征北番，大军被阻雁门关。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "春明甲胄云飞彩，秋月扬辉紫雾开。扫尽烟尘平北塞，不枉英雄称将才。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "本帅，杨延昭。大宋为臣，官拜天下都招讨兵马大元帅。奉旨征剿北番。可恨 韩昌带领人马抗拒，在雁门关前屡次交战，难以成功。我也曾命宗保回朝搬兵 助战，未见交令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "心急懒观山河景，将军走马踏番营。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "爹爹在上，孩儿交令。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "命你回朝搬兵，怎么样了？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "孩儿奉命回朝搬兵，圣上命祖母挂帅，统领大兵十万扫荡北番，大兵将近雁门 关。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "既是太君领兵前来，吩咐摆队迎接！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "摆队出关，迎接太君去者！"
        },
        {
          "character": "四白龙套",
          "type": "同白",
          "text": "啊！ （四白龙套、杨延昭、杨宗保同下。四宋兵、孟金榜、蔡秀英、杨八姐、杨九妹引佘太君同上，过场，同下。 杨延昭、杨宗保、四白龙套同上，同出城迎接。佘太君、四宋兵、孟金榜、蔡秀英、杨八姐、杨九妹同上。 杨延昭参拜。）"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "众位将军下面歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟金榜、蔡秀英、杨八姐、杨九妹自两边分下。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊母亲，朝中多少大臣，为何要母亲挂帅征剿？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿啊！我杨家投宋以来，忠心报国，反被奸贼潘洪所害，你父命丧两狼山，骸 骨不能归宋；最苦者你兄死弟丧，手足分离。为娘白头出战，皆为你父子忠心， 但愿留名万古！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "老母慈命，孩儿敢不尽忠报国。备得酒筵，与母亲、众将接风。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "为娘奉旨扫北，必须观看番营的阵势，也好点兵抵敌。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "是。孩儿保定母亲上关观看。 众将官！"
        },
        {
          "character": "四白龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "带路上关！"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "萧、宋不和常交仗， 各为其主动刀枪。 奸贼潘洪诓驾往， 中国京剧戏考 《雁门关》【头本】 3 请主五台去烧香。 惊动番兵如铁网， 层层围困大宋王。 临阵脱逃贼潘相， 暗通战表到番邦。 圣主被困沙滩上， 犹如陈蔡绝兵粮。 御召回朝搬兵将， 独踏番营儿五郎。 父子九人幽州闯， 可叹杨家为国亡！ 七郎军营带箭丧， 你父碰死在两狼。 我儿回朝告御状， 除奸诛佞报君王。 太平一统好景象， 不料银宗又逞强。 众将带路把关上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四宋兵、杨延昭、佘太君同上城。"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "北国旌旗遮日光。 中央戊己扎营帐， 胡儿人壮马又强。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿呀，看番贼营盘，南靠雁门关，北靠高山，倘若出战，是怎样交锋？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿领兵杀出雁门关，不料那胡儿倚山为势，孩儿屡战不胜。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿呀，为帅者要见机而作。昔日田单火牛破燕兵，诸葛火烧藤甲，皆是“火攻” 之计。儿不学孙武子，焉能扫灭北番？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "即请母亲升帐，孩儿听命便了。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "且听为娘传令，少时命你嫂、妹出马，定能一战成功。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "带路回营！"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "调兵遣将升宝帐， 仗主洪福平番邦。 建功勤王有升赏， 班师奏凯回汴梁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "报子",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "探听惊天动地事，披星戴月马蹄忙。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "俺，北国能行探子是也。奉了韩驸马将令，打探军情。探得南朝发来一些女将， 已到雁门关。此事不敢隐瞒，不免报与韩驸马知道便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孟金榜、蔡秀英同上，双起霸。"
        },
        {
          "character": "孟金榜",
          "type": "念",
          "text": "纬武经文将帅门，怀藏珠玑沐皇恩。"
        },
        {
          "character": "蔡秀英",
          "type": "念",
          "text": "临阵接战威风凛，谁识闺中女钗裙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵自两边分上。"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "妹妹！"
        },
        {
          "character": "蔡秀英",
          "type": "白",
          "text": "嫂嫂！ 中国京剧戏考 《雁门关》【头本】 4"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "你我奉旨平番，正好打听你四哥和八弟的下落。贤妹请来传令！"
        },
        {
          "character": "蔡秀英",
          "type": "白",
          "text": "自然是嫂嫂传令！"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "你我一同传令。 众将官！"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "杀进番营去者！"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将引韩昌同上。"
        },
        {
          "character": "韩昌",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，军威浩，地动山摇，要把大宋扫！"
        },
        {
          "character": "韩昌",
          "type": "念",
          "text": "走马射猎逞威风，万马军中任纵横。扫灭宋室归一统，方显男儿盖世雄。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "本督，韩昌。北国为臣，蒙圣恩招为驸马。奉了太后旨意，夺取宋室天下。杨 延昭带兵来到雁门关，也曾与他见过数阵，他也难以取胜。我命探子前去打听 消息，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！驸马在上，探子参！"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "将军情一一报来！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "驸马容禀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "赏你羊羔美酒，再去打探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "且住！探子报道：杨家女将兴兵前来，必有一番恶战。 巴图鲁！"
        },
        {
          "character": "四番兵、四番将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "杀上前去！"
        },
        {
          "character": "四番兵、四番将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将引韩昌同走圆场。四女兵引孟金榜、蔡秀英同上。会阵。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "呔！宋营女将通名受死！"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "俺乃宋营女将孟金榜。"
        },
        {
          "character": "蔡秀英",
          "type": "白",
          "text": "蔡秀英。"
        },
        {
          "character": "孟金榜、蔡秀英",
          "type": "同白",
          "text": "番贼留名？"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "听者：俺乃北国驸马韩昌！"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "无名小辈，看枪！ （韩昌、孟金榜、蔡秀英同起打。韩昌败下。孟金榜、蔡秀英同追下。韩昌上，孟金榜、蔡秀英、四女兵同 追上，韩昌败下。）"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "番兵大败。"
        },
        {
          "character": "孟金榜",
          "type": "白",
