        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "延顺跌跪在埃尘， 祝告空中过往神。 雁门探母不回转， 死在千军万马营！"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "驸马请起！"
