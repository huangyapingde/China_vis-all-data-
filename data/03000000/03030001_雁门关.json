        {
          "character": null,
          "type": "stage",
          "text": "四番兵同下。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "适才韩昌兵败回来，言道我母亲带领众家嫂嫂与我妻蔡秀英来到雁门关。咳！ 我有心与公主商议，过营探母，不知她意下如何？今日不免将我真名实姓对她 实说。咳，思想老母好不伤感人也！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "韩昌兵败报军情， 雁门关前大交兵。 头阵败了六兄长， 老母奉旨往北征。 本当过营去探问， 纵有双翅难飞腾。 宫中哭坏杨延顺！"
        },
        {
          "character": "杨延顺",
          "type": "哭头",
          "text": "儿的娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四达婆、香郎、香姐引青莲公主同上。"
        },
        {
          "character": "青莲公主",
          "type": "唱",
          "text": "来了金枝玉叶人， 银安殿前施一礼， 驸马因何放悲声？"
        },
        {
          "character": "杨延顺",
          "type": "白",
