          "character": "杨延顺",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "赐座！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "谢座。"
