{
  "script_id": "03106003",
  "title": "窃兵符",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "廉颇",
      "hangdang": "净"
    },
    {
      "name": "赵胜",
      "hangdang": "老生"
    },
    {
      "name": "赵胜妻",
      "hangdang": "旦"
    }
  ],
  "plot": "秦王以王龁为将，进攻赵都邯郸。赵王惧，再用廉颇，守邯郸，御秦军。赵相平原君赵胜，又差人驰书至魏，\n求信陵君无忌援赵。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引王龁同上。"
        },
        {
          "character": "王龁",
          "type": "北粉蝶儿",
          "text": "野旷营髙战场开， 阵云笼罩。 飐西风旌旆飘飘， 领雄兵， 调虎将， 声威赫耀。"
        },
        {
          "character": "王龁",
          "type": "念",
          "text": "卓哉鲁仲连，品高人人羡。不帝我强秦，兵威稍稍敛。"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "某，秦邦大将王龁。前同武安君白起，长平一战，坑杀赵兵四十余万。正欲攻 下邯郸，有魏国新垣衍前来赵邦，请尊我主为帝，其心意在解围。不想被鲁仲 连一番言语阻止。我主甚慕仲连髙风，又惮廉颇、李牧英勇，故而暂退汾水驻 扎，令某仍屯邯郸，探其动静。如今探得廉颇患病，不能领兵，也曾密报大王， 请令发兵攻打。想早晚将有君旨来也！"
        },
        {
          "character": "蒙骜",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": "军士甲",
          "type": "白",
          "text": "圣旨下！"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "大开营门！"
        },
        {
          "character": "军士甲",
          "type": "白",
          "text": "大开营门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。四大铠引郑安平、司马梗、蒙骜持令牌同上。"
        },
        {
          "character": "蒙骜",
          "type": "白",
          "text": "大王旨下！"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "蒙骜",
          "type": "白",
          "text": "“昨据王龁密报，邯郸情形可攻，特着蒙骜领军十万，郑安平、司马梗作为 左右副将，同心协力，定要打破邯郸，毋负重托。”"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。王龁接令牌。"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "蒙骜",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "郑安平、司马梗",
          "type": "同白",
          "text": "末将等参见！"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "二位请坐！"
        },
        {
          "character": "郑安平、司马梗",
          "type": "同白",
          "text": "谢坐！"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "大王安泰？"
        },
        {
          "character": "蒙骜",
          "type": "白",
          "text": "我主驾安。大王言道，既已探得廉颇染病，李牧远在代州，平原君赵胜不谙兵 事，虽有食客三千，不过是说客之流，何能济得大事。为此特命某来，同心攻 打邯郫，早传捷报，以副大王圣怀。"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "君见与臣相同。此际进兵，全仗诸位将军之力。 中国京剧戏考 《窃兵符》【三本】 2"
        },
        {
          "character": "蒙骜、郑安平、司马梗",
          "type": "同白",
          "text": "还是仰仗大将军。"
        },
        {
          "character": "王龁",
          "type": "白",
          "text": "岂敢！ 来，今晚四更饱餐，五鼓整齐队伍，不待天明，攻打邯郸。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "王龁",
          "type": "忆秦娥",
          "text": "旗仗髙挑齐遥威， 破邯郸红旗捷报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵胜上。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "赵胜",
          "type": "忆秦娥",
          "text": "满目惨凄凄， 无宁日，无宁日！ 内乱将作，外援不至。"
        },
        {
          "character": "赵胜",
          "type": "念",
          "text": "高台百丈尽头颅，何止区区万骨枯。矢石无情缘斗胜，可怜降卒有何辜！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "某，平原君赵胜。唉！不意大王误用赵括去代廉颇为将。岂知赵括自恃一己之 能，将廉颇军政约束，尽行更改，与秦一战即败。他死在秦军之手，不足为惜， 可怜我军四十余万，尽被白起杀害。只杀得血流淙淙，杨谷之水，皆变为赤， 秦垒之间，头积成山，只存少年二百四十人放还。搅得我国，子哭其父，父 哭其子，兄哭其弟，弟哭其兄，祖哭孙，妻哭夫……沿街满市，号哭不止。正 尔疮痍将痊，岂知秦贼又来攻我城池。正是："
        },
        {
          "character": "赵胜",
          "type": "念",
          "text": "安危关社稷，生死尚难知！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引赵胜妻同上。"
        },
        {
          "character": "赵胜妻",
          "type": "忆秦娥",
          "text": "日夜心萦系， 为何无消息，无消息！"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "啊相公！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "夫人！"
        },
        {
          "character": "赵胜妻",
          "type": "忆秦娥",
          "text": "你毕竟怎生划计，解此危势？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "哎！我此际心绪如麻，形如木偶，还能划得何计，怎解此危？"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "妾闻，上智不处危以饶幸。中智，能因危以为功。下愚，安于危，以自亡。危 亡之至，在人所为，不可不察也！今番你我处此危城之中，义无所立，节无所 成，莫非要作那下愚之类乎？且相公堂前，尝养三千食客，其中岂无文韬武略 之人？若能得一长策，收那中智之功，此则转祸为福，岂不是好？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "明镜所以照形，鉴往所以知今。前者，我去说楚，欲得食客文武全备者二十人 同往，岂知三千余人之内，文者不能武，武者不能文，选来选去，只选得一十 九人。若无毛遂自荐，几被楚王笑话。今此累卵之势，再想得一文武长策之士， 只怕不得能够了！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "十数年养士名播扬于世， 食客数比孟尝难分髙低。 实指望仗他等分劳代力， 哪知晓全无个出色男儿。 孟尝君出函关仗鸡鸣犬吠， 我平原说楚王实亏毛遂。 那田文复齐相得冯驩之计， 我赵胜困邯郸有谁扶持？ 想魏国与赵邦势若唇齿， 何况是结婚姻亲戚之谊。 前致书既已蒙遣将晋鄙， 恰缘何屯其兵不来解围？ 且令弟信陵君向称侠义， 中国京剧戏考 《窃兵符》【三本】 3 能济困能扶危谁人不知。 尝闻他也养着三千珠履， 难道说与我客一般无奇？ 眼见得赵将成西山落日， 望救解好似那涸辙之鱼。 他袖手或因我不足相庇， 独不怜亲骨肉甘让秦欺！"
        },
        {
          "character": "赵胜妻",
          "type": "唱",
          "text": "君所言固然是层层有理， 大厦成几曾见一木独支。 可笑者三千客安居坐食， 临危难全无有解难之机。 论毛遂虽说得楚王适意， 讲其才终不能制胜出奇。 其余的想都是因人成事， 赚得个衣食足谁管是非？ 论贤名人皆晓我弟无忌， 为护鸠尚能使恶鹞头低。 这时节不见他拯救消息， 袖手观亲骨肉甘被人欺？ 莫不是我兄王畏秦如虎， 莫不是那晋鄙老而无为？ 思想起为今计别无可取， 请君去剀切切作下尺书。 料此际投书者无人敢去， 妾情愿舍微命亲去一回。 若能够到家乡见兄见弟， 他不发兵来救赵我不来见伊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵胜起立。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！你、你、你要亲赴魏邦求救么？"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "然也！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "喂哟！那秦贼的人马好生厉害呀！"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "夫人！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "不闻他兵儿将儿都带着那雄雄赳赳的虎狼气， 不闻他车儿马儿四下里喧喧腾腾地在八面驱驰。 我这里老儿少儿有谁个轰轰烈烈地保护着你？ 我这里男儿女儿选不出个将将就就的人儿跟随。 眼见他旗儿旌儿布得飘飘荡荡遮天盖地， 眼见他枪儿刀儿摆得来森森严严鬼惧神疑。 似你这貌儿材儿明是个怯怯虚虚的懦弱身体， 他见了你如饿虎见羔羊啖啖噬噬一口吞之。 兀的不顿使我心儿肝儿为着你，惨惨凄凄哭不出血泪， 兀的不顿使我魂儿魄儿怕不是恍恍惚惚在九霄外飞。 劝夫人忙把那情儿意儿你与我安安稳稳万不可提起， 莫教我失群雁东儿西儿盼不到恩恩爱爱偕老的娇妻。"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "赵胜妻",
          "type": "唱",
          "text": "一任他豺儿狼儿排成着狰狰狞狞的攒羊之势， 一任他鬼儿魅儿布成个昏昏沉沉的迷魂幛围。 我不用旗儿伞儿簇拥着前前后后多人护卫， 我只须侍儿马儿相随去平平坦坦直往魏国去。 怕什么他戟儿剑儿结得来层层叠叠如铁桶相似， 怕什么人儿马儿裹就个密密扎扎的金锁重围。 你道我手儿足儿似乎像窄窄纤纤无甚气力， 中国京剧戏考 《窃兵符》【三本】 4 哪知我胆儿量儿更比那粗粗大大的虎将还威。 到临敌精儿神儿你看我抖抖擞擞直冲他队里， 杀得他兵儿将儿一个个跌跌滚滚一霎时尸横血滴。 劝君家休将那心儿意儿为着我愁愁蹙蹙不能成事， 准看俺不待慢鱼儿雁儿早报取平平安安退贼的捷书。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "听你言得来这般容易！"
        },
        {
          "character": "赵胜妻",
          "type": "唱",
          "text": "不容易又何必向君妄提。"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "倘此行若逢贼万一有失，"
        },
        {
          "character": "赵胜妻",
          "type": "唱",
          "text": "即效个忠良将血染沙泥。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "此一句吓得我心如刀刺，"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "哎呀！夫人哪！你若果然如此──"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "可不就生喳喳鸳鸯分飞？ 劝贤妻把此事万勿提起，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵胜妻",
          "type": "唱",
          "text": "恰缘何一霎时人喊马嘶？"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "侍儿！"
        },
        {
          "character": "赵胜妻",
          "type": "唱",
          "text": "忙引导一同到二堂上去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引赵胜妻欲下，李同内击鼓。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "击堂鼓莫非是军情紧急！"
        },
        {
          "character": "赵胜妻",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "赵胜妻",
          "type": "唱",
          "text": "到宅门尔与我立传示谕， 甚紧急教他来当面禀知。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。 何人击鼓？相爷、夫人立等二堂回话。"
        },
        {
          "character": "李同",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李同上。"
        },
        {
          "character": "李同",
          "type": "唱",
          "text": "贼兵攻城势甚急， 守城儿郎怨声啼。 为此击鼓来面启，"
        },
        {
          "character": "李同",
          "type": "白",
          "text": "相爷、夫人！"
        },
        {
          "character": "李同",
          "type": "唱",
          "text": "快快设计保城池。"
        },
        {
          "character": "赵胜、赵胜妻",
          "type": "同白",
          "text": "何事紧急，便来击鼓？"
        },
        {
          "character": "李同",
          "type": "白",
          "text": "哎呀，相爷、夫人哪！那秦贼今番前来攻城，好生厉害！"
        },
        {
          "character": "赵胜、赵胜妻",
          "type": "同白",
          "text": "怎见得？"
        },
        {
          "character": "李同",
          "type": "白",
          "text": "相爷、夫人容禀："
        },
        {
          "character": "李同",
          "type": "念",
          "text": "王龁、蒙骜督将，司马、安平副之。这回更比前番勇，人马却似加倍。 乱箭尤如飞蝗，到处全搭云梯。纷纷爬城若蝼蚁，哪怕滚木擂石。"
        },
        {
          "character": "赵胜、赵胜妻",
          "type": "同白",
          "text": "我处守城的可都努力？防堵得住否？"
        },
        {
          "character": "李同",
          "type": "白",
          "text": "咳咳咳！"
        },
        {
          "character": "李同",
          "type": "念",
          "text": "我军长平败后，几个痊愈疮痍，昼夜防守带着饥，试问谁人有力？ 一闻贼兵来到，个个搓手悲啼。"
        },
        {
          "character": "李同",
          "type": "白",
          "text": "相国！"
        },
        {
          "character": "李同",
          "type": "念",
          "text": "若不早作良谋计，将成瓦解之势！"
        },
        {
          "character": "赵胜、赵胜妻",
          "type": "同白",
          "text": "哎呀！这便如何是好？"
        },
        {
          "character": "李同",
          "type": "白",
          "text": "李同有言，冒陈相国。 中国京剧戏考 《窃兵符》【三本】 5"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "有话起来讲。"
        },
        {
          "character": "李同",
          "type": "白",
          "text": "喳！臣观将士昼夜巡城固守，人人皆有饥色，百姓望救不来，纷纷皆有出降之 意。"
        },
        {
          "character": "赵胜、赵胜妻",
          "type": "同白",
