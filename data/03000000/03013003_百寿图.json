{
  "script_id": "03013003",
  "title": "百寿图",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "管辂",
      "hangdang": "老生"
    },
    {
      "name": "南斗星",
      "hangdang": "老生"
    },
    {
      "name": "北斗星",
      "hangdang": "净"
    },
    {
      "name": "赵颜",
      "hangdang": "小生"
    }
  ],
  "plot": "平原农家子赵颜，年十九岁。某日，行径相士管辂卦棚。管辂相其气色，断定三日后夭亡。赵颜之父母闻知，\n哀求救死之术。管辂授意赵颜持鹿脯、美酒往终南山，向二老人献酒求寿。赵颜如言而去，果见二老人在\n松下对弈，乃献上酒食。二老人系南斗、北斗二星君。饮酒后，问知来意，许将寿数改为九十九岁，赵颜叩\n谢而归。",
  "notes": "故事源出于《三国演义》。\n这个剧本经陈少武先生帮助校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "管辂上。"
        },
        {
          "character": "管辂",
          "type": "引子",
          "text": "慧眼能识仙鬼，判断祸福无差。"
        },
        {
          "character": "管辂",
          "type": "念",
          "text": "天上星辰日月，人间山水物华。争长论短空嗟呀，还是父母为大。"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "贫道，姓管名辂字公明，乃平原县人氏。自幼生就一双慧眼，能知过去未来之 事。在这十字街前，摆了一座卦棚，无非指引世人。看今日天气晴和，不免卦 棚走走。"
        },
        {
          "character": "管辂",
          "type": "二黄慢板",
          "text": "叹光阴似箭穿过目烟云， 见世间有草木尽已发青。 观前面山岗上一派美景， 又看见这山下花开缤纷。 花开时比人生越开越盛， 花瓣落比人老迟暮光阴。 有等人贪酒色昏迷不醒， 有等人为妻妾家业凋零。 有等人为财产伤了性命， 有等人为小事大祸临身。 有家产必须要安守本分， 切不可以势力欺压贫人。 行一步且把这卦棚来进， 等候了繁华世痴迷之人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜上。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "在家中遵奉了双亲严命， 手牵着青牛儿去把田耕。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "小生，赵颜。奉了双亲之命，下田耕种。就此走走。"
        },
        {
          "character": "赵颜",
          "type": "西皮导板",
          "text": "世间人必须要耕种为本，"
        },
        {
          "character": "赵颜",
          "type": "西皮原板",
          "text": "官出民民出土土内生金。 来至在十字路用目观定， 卦棚内坐定了算命的先生。 放下犁拴上牛卦棚来进， 看一看他手托哪部古文。"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "坐至在卦棚内心中烦闷， 观前朝和后汉累代圣君。 有纣王宠妲己天心不顺， 黄飞虎反五关去投国君。 且不论前朝事用不观定， 猛抬头见小哥大吃一惊。"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "可叹呐，可叹！"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "啊，先生叹者何来？"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "请问小哥，家住哪里，姓字名谁？身背犁杖，要向何往？"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "小子赵颜，奉了双亲之命，下田耕种。"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "我劝你休要耕种；急速回家，好酒好肉饱餐三天。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "先生何出此言？"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "我看你气色不正，三日后你定夭寿而亡。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "啊，先生，我行路有影，痰嗽有声，怎见得我三日后必死？"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "小哥呀！"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "休道你行有影痰嗽有声， 岂不知天有那不测风云？"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "管先生说此话我却不信， 哪有个平白的死了好人？"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "小哥！"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "劝小哥听此话休要不信， 待贫道下位去观看无行。 耳属金金不能生水半寸， 眉属木木生火枝叶凋零。 口属水水已干犹如枯井， 眼属火火无光不能生金， 鼻属土土入陷死气已真， 三日后你必定命丧残生。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "听他言不由我心神不定， 背转身我这里自己思忖。 急忙忙向前去先生来问， 三日后我不死有何为凭？"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "三日后你不死只管议论， 如不然我和你去到公厅。 再不然将我的卦棚拆损， 任你羞任你辱任你施行。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "听他言吓得我心意不定， 想必是三日后要见阎君。 转过身牵着牛急往家奔， 见双亲把此话细说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜下。"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "可叹他年少人大数已尽， 这也是五阎君造定死生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "管辂下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵范、赵母同上。"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "一家人全凭着耕种为本， 小娇儿下田去未见回程。"
        },
        {
          "character": "赵颜",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜上。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "放下犁拴上牛家门来进， 见双亲泪汪汪跪在埃尘。"
        },
        {
          "character": "赵颜",
          "type": "哭",
          "text": "喂呀，爷娘啊！"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "儿啊，为何啼哭？"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "爷娘有所不知，孩儿下田耕种，行至十字街前，有一算命先生，与儿看了一相。 他道孩儿三日后夭寿而亡啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜哭。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "不好了！"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "听说是三日后我儿丧命，"
        },
        {
          "character": "赵母",
          "type": "唱",
          "text": "只恐怕绝了我赵氏后根。"
        },
        {
          "character": "赵母",
          "type": "白",
          "text": "儿呀！那算命先生现在何处？"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "现在十字街前。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "待我二老前去哀告先生；倘有活命，也未可知。儿呀，带路！"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "叫妈妈你那里将门带定， 卦棚里去哀告算命的先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "管辂上。"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "将身儿来至在卦棚坐定， 算人间生和死不差毫分。"
        },
        {
          "character": "赵范、赵母",
          "type": "内同白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵范、赵母、赵颜同上。"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "小娇儿你与我把路来领， 见先生泪汪汪跪在埃尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵范、赵母同跪。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "哎呀，先生呐！"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "管公明坐卦棚用目观定， 见二老泪汪汪跪在埃尘。"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "赵颜。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "这二老是你什么人？"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "二老双亲。"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "年迈之人，快快请起。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "多谢先生！"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "你二老到此何事？"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "先生啊！"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "小老儿名赵范六十三岁，"
        },
        {
          "character": "赵母",
          "type": "唱",
          "text": "我二老年半百有此娇生。"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "先生道我娇儿三日丧命，"
        },
        {
          "character": "赵母",
          "type": "唱",
          "text": "望先生发慈悲搭救娇生。"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "我不是阴曹府轮回宫殿， 我不是阴曹府掌簿判官。 我不是观世音救苦救难， 我不是西天佛法力无边。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "哎呀，先生呐！"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "我哭哭一声管先生，"
        },
        {
          "character": "赵母",
          "type": "唱",
          "text": "我叫叫一声管辂仙。"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "为娇儿我二老朝山拜顶，"
        },
        {
          "character": "赵母",
          "type": "唱",
          "text": "为娇儿我二老把香来焚。"
        },
        {
          "character": "赵范",
          "type": "哭头",
          "text": "管先生！"
        },
        {
          "character": "赵母",
          "type": "哭头",
          "text": "仙长爷！"
        },
        {
          "character": "赵范、赵母",
          "type": "同哭头",
          "text": "啊！"
        },
        {
          "character": "赵范、赵母",
          "type": "同唱",
          "text": "望先生发慈悲搭救娇生。"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "见二老只哭得我心好惨， 不由人一阵阵心内痛酸。 这时候怎救得残生命转，"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "哦，有了！"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "又只见南北斗移奔高山。"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "二老请起。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "多谢先生！"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "赵颜有了救了。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "救在哪里？"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "回到家去，准备鹿脯，去至终南山，有二……"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "先生，二什么？"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "有二位仙长在那里着棋，你将这鹿脯美酒，暗暗献上。他饮了你的酒，必要与 你添寿。"
        },
        {
          "character": "赵范、赵母",
          "type": "同白",
          "text": "请问先生，那二位仙长怎样打扮？"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "你们听了！"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "有一个穿白的斯文体相， 有一个穿红的气宇轩昂。 你将这鹿脯酒暗暗献上， 饮了酒必与你添寿绵长。"
        },
        {
          "character": "赵范",
          "type": "白",
          "text": "多谢先生。"
        },
        {
          "character": "赵范",
          "type": "唱",
          "text": "辞别了管先生忙往家奔，"
        },
        {
          "character": "赵母",
          "type": "唱",
          "text": "准备下鹿脯酒送到山林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵范、赵母同下。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "辞别了管先生忙回家门，"
        },
        {
          "character": "管辂",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "问先生唤回我所为何情？"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "你把这鹿脯酒暗暗献上， 必须要隐身形跌跪一旁。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "仙长爷你不必仔细叮咛， 我赵颜纵一死不忘大恩。 此一番到南山把酒来敬， 见仙长求增寿小心殷勤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜下。"
        },
        {
          "character": "管辂",
          "type": "唱",
          "text": "这也是小赵颜不该命丧， 他二老前世里积下善良。 哀告那南北斗将寿添上， 到后来子孙多瓜瓞绵长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "管辂下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "南斗星、北斗星",
          "type": "内同白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南斗星、北斗星同上。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "观天地和日月乾坤浩荡，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "天连水水连天渺渺茫茫。"
        },
        {
          "character": "南斗星、北斗星",
          "type": "同白",
          "text": "吾乃（南）（北）斗星君是也。"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "星君请了。"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "你我奉了玉帝敕旨，巡查人间善恶。来此地已是南瞻部洲，今日闲暇无事，将 历代君王之事，细表一番。"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "自盘古分天地乾坤始创，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "先太极分两仪八卦阴阳。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "按金木水火土五行方向，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "先君臣后父子三纲五常。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "尧传舜舜传禹江山揖让，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "夏桀暴商纣淫自取灭亡。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "秦始皇归一统山河执掌，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "他不该焚诗书兴建阿房。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "楚项羽他倒有帝王之相，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "他不该杀义帝强霸为王。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "把前朝君王事暂且慢讲， 有一辈忠良臣细说端详： 淮阴侯小韩信功高智广， 为什么未央宫一命身亡？"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "休道那小韩信功高智广， 他不该活埋母九里山旁。 他不该问道路把樵哥斩丧， 他不该逼高祖拜他为王。 他不该困霸王乌江命丧， 因此上未央宫一命身亡。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "成萧何败萧何萧何该丧， 为什么那老儿寿命延长？"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "休道那汉萧何该当命丧， 他本是忠良将寿命延长。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "叹不尽前朝的忠臣良将，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "松林内摆棋盘散闷一场。"
        },
        {
          "character": "赵颜",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜上。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "手捧着鹿脯酒终南山上， 又只见二仙长分坐两厢。 我这里将鹿脯暗暗献上， 吞着气躲着身跌跪一旁。"
        },
        {
          "character": "南斗星、北斗星",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "在石台摆棋盘一帅一将，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "红棋先黑棋后各占一方。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "走一步当头炮千军难挡，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "还一个连环马士相奔忙。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "又只见鹿脯酒从空而降，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "想必是天赐我美味清香。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "我和你棋不胜共饮佳酿，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "飞来物饮几杯又有何妨。"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "你我再下一盘。"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "战胜了好一似汉高皇上，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "战败了好一似西楚霸王。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "求寿哇！"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "耳边厢又听得有人喧嚷，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "猛抬头见小子跌跪道旁。"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "那一小子，家住哪里，姓字名谁，到此何事？慢慢讲来。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "二位仙长容禀！"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "家住在城厢外绿柳村上， 我的名叫赵颜耕种田庄。 都只为在卦棚先生看相， 他道我三日后一命身亡。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "听小子说此话倒也清亮，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "仙家事是何人泄漏阴阳？"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "啊，星君，你我在此着棋，凡人怎能知晓？"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "星君有所不知，只因凡间有一个管辂，生来一双慧眼，能知人间过去未来之事， 定是此人引他前来，也未可知。"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "星君何不将他阳寿查上一查。"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "待我查来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "查得山西平原郡绿柳村赵范之子，名唤赵颜，前生作恶多端，今投赵门为子。 注定大汉建安一十二年，寿活一十九岁，夭寿而亡。 赵颜，你今年多大了？"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "一十九岁。"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "哈哈，完了哇，完了！"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "叫小子抬头看生死簿上， 这上面造定了字字行行。 十九岁你就该把命夭丧， 这时候并无有解救良方。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "听他言吓得我魂魄飘荡， 不由我小赵颜无有主张。 望仙长发慈悲将寿添上， 可怜我家还有二老爷娘。"
        },
        {
          "character": "南斗星、北斗星",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "小赵颜只哭得泪如雨降， 可怜他家还有二老爷娘。"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "啊，星君！你看赵颜哭得可怜，何不将他阳寿与他添上。"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "星君说哪里话来。你我奉了玉帝敕旨，巡查人间善恶。私添阳寿，玉帝闻知， 吃罪不起。"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "上苍也有好生之德。何况你我……"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "这是你好吃酒！"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "你也好贪杯！"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "彼此？"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "一样！"
        },
        {
          "character": "南斗星、北斗星",
          "type": "同笑",
          "text": "啊，哈哈哈哈！"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "如此说来，这阳寿添得的？"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "添得的！"
        },
        {
          "character": "北斗星",
          "type": "白",
          "text": "赵颜，你命活一十九岁，将这“一”字改为“九”字。寿活九十九岁，也就够 了。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "啊，仙长，将那一岁添上，岂不是百岁老人？"
        },
        {
          "character": "南斗星、北斗星",
          "type": "同白",
          "text": "哎！贪心不足。听我等道来！"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "我本是南斗星从天而降，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "我本是北斗星降下天堂。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "我掌生他掌死分亳不爽，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "查人间生和死善恶昭彰。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "我赐你子孙多富贵永享，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "我赐你财源盛金玉满堂。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "我赐你椿萱茂代代兴旺，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "我赐你一家人无有灾殃。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "我赐你百寿图悬挂堂上，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "我赐你九十九大寿延长。"
        },
        {
          "character": "南斗星",
          "type": "唱",
          "text": "在人间休得要胡言乱讲，"
        },
        {
          "character": "北斗星",
          "type": "唱",
          "text": "泄露了仙家事五雷身亡。"
        },
        {
          "character": "南斗星、北斗星",
          "type": "同白",
          "text": "去吧！"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "辞别了二仙长忙下山岗，"
        },
        {
          "character": "南斗星、北斗星",
          "type": "同白",
          "text": "转来。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "星君爷唤回我所为哪桩？"
        },
        {
          "character": "南斗星",
          "type": "白",
          "text": "回去见了管辂，叫他从今以后，不要胡言乱语；再若胡言乱语，难免五雷击顶。 那旁有人来了。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "在哪里？在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "北斗星、南斗星同下。"
        },
        {
          "character": "赵颜",
          "type": "白",
          "text": "哎！二位仙长不见，待我望空一拜。"
        },
        {
          "character": "赵颜",
          "type": "唱",
          "text": "手捧着百寿图忙下山岗， 回家去见爷娘细说端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵颜下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}