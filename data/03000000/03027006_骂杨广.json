          "text": "下官、宇文化及。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "老夫、靠山王杨林。"
        },
        {
          "character": "杨素",
          "type": "白",
          "text": "众位大人请了！"
        },
        {
          "character": "宇文化及、韩擒虎、杨林",
