          "text": "文武定太平！"
        },
        {
          "character": "杨素",
          "type": "白",
          "text": "老夫、越国公杨素。"
        },
        {
          "character": "韩擒虎",
          "type": "白",
          "text": "老夫、韩擒虎。"
