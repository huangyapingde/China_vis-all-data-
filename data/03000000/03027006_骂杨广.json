    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四旗牌、院子引伍建章同上。"
        },
        {
          "character": "伍建章",
          "type": "二黄原板",
          "text": "叹文帝为国家忧成疾病， 国运败出逆子扰乱乾坤。 大太子虽居长懦弱成性， 二太子一心要霸占龙庭。 满朝中文武臣无人持正， 一个个俱都是佞党奸臣。 我的儿伍云召颇有才论， 怎奈他奉圣命南阳关前统率雄兵。 为国家把我的心血用尽， 为国家昼夜里哪得安宁！ 昨夜晚得一梦吉凶未定， 乌鸦啼喜鹊噪所为何情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍保上。"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "来此府门，里面哪位在？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "伍保求见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "候着！ 启相爷：伍保求见。"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "唤他进来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相爷唤你，小心了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "是。 相爷在上，伍保叩头！"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "罢了，起来。"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "谢相爷！"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "伍保，你不在南阳关伺候少老爷，回来何事？"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "小人奉了少老爷之命，前来报喜。有少老爷书信呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍保呈书。"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "呈上来，待我拆书一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "原来吾儿云召得了一子，待我谢天谢地！"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "小人与相爷叩喜！"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "罢了。下面用饭。"
        },
        {
          "character": "伍保",
          "type": "白",
          "text": "谢相爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍保下。院子急上。"
        },
        {
          "character": "院子",
          "type": "念",
          "text": "忙将塌天事，报与相爷知。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启禀相爷：大事不好了！"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "今有杨广气死老王，逼死皇后，杀死陈妃，弟篡兄位了。"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "弟篡兄位了。"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "万岁！老王！哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍建章气椅。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "老夫人快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍夫人上。"
        },
        {
          "character": "伍夫人",
          "type": "白",
          "text": "啊，相国怎么样了？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相爷气绝了。"
        },
        {
          "character": "伍夫人",
          "type": "白",
          "text": "相爷醒来！"
        },
        {
          "character": "伍建章",
          "type": "唱",
          "text": "听说是文帝爷龙归海境，"
        },
        {
          "character": "伍建章",
          "type": "三叫头",
          "text": "万岁！我主！哎万岁呀！"
        },
        {
          "character": "伍建章",
          "type": "唱",
          "text": "好似狼牙箭穿心。 杨广奸贼行不正， 杀父夺权乱龙庭。"
        },
        {
          "character": "伍夫人",
          "type": "白",
          "text": "相国，为了何事这样气恼？"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "哎呀夫人哪！只因老王晏驾，杨广弟篡兄位。我想满朝奸佞，定然扶保杨广登 基。伍氏代代忠良，岂能附合奸佞？若不随驾而去，还有何颜生在世上！"
        },
        {
          "character": "伍夫人",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "伍夫人",
          "type": "二黄摇板",
          "text": "听说万岁丧了命， 眼见江山不太平。"
        },
        {
          "character": "伍夫人",
          "type": "白",
          "text": "啊老相国，想那杨广乱伦灭礼，弟篡兄位，自有满朝文武议论。相国且免悲痛 气恼，保重身体要紧。"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "也罢！我不免身穿孝服，上得殿去，痛骂奸贼，纵然一死，也好见老王于地下 也。"
        },
        {
          "character": "伍夫人",
          "type": "白",
          "text": "相爷保重才是，"
        },
        {
          "character": "伍建章",
          "type": "白",
          "text": "我就是这个主意，哎！我就是这个主意呀！"
        },
        {
          "character": "伍建章",
          "type": "唱",
          "text": "梦不想出了这逆贼杨广， 灭天伦夺兄位败坏纲常。 我只得穿孝服披麻执杖， 我情愿骂贼死去见先王。"
        },
        {
          "character": "伍建章",
          "type": "三叫头",
          "text": "万岁！我主！哎万岁呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
