        {
          "character": "四将军",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "四将军",
          "type": "同唱",
          "text": "听罢言来怒气生， 不由豪杰冒火星。 去到校场点人马， 要与太宰把冤伸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将军同下。兵丁上。"
        },
        {
          "character": "兵丁",
          "type": "白",
          "text": "启夫人：众将反上金殿去了。"
