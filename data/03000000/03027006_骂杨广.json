          "character": "伍夫人",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "伍夫人",
          "type": "唱",
          "text": "伍保说话不忠良， 竟作贼子反朝堂。 人来与我上了绑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍保逃下。"
        },
        {
          "character": "伍夫人",
          "type": "唱",
          "text": "儿郎个个珠泪汪！ 我只得捆绑金殿上，"
        },
        {
          "character": "四将军",
          "type": "同唱",
          "text": "全忠名儿天下扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
