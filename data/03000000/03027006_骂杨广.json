          "character": "伍夫人",
          "type": "唱",
          "text": "伍氏代代忠良将， 岂作谋反叛逆臣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将军同上。"
        },
        {
          "character": "四将军",
          "type": "同唱",
          "text": "旌旗铠甲多齐整， 拿住昏王方称心。"
