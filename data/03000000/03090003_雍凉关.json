          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：圣驾到！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "老夫到此，还不曾训练人马，圣驾到此为了何事？嗯，老夫正要叫他看看行兵 之威！ 众位将军！"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "元帅！"
        },
        {
          "character": "司马懿",
