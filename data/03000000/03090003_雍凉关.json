        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
