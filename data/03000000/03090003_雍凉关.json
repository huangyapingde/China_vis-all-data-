{
  "script_id": "03090003",
  "title": "雍凉关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "司马懿",
      "hangdang": "净"
    },
    {
      "name": "马谡",
      "hangdang": "净"
    },
    {
      "name": "曹睿",
      "hangdang": "小生"
    },
    {
      "name": "贾诩",
      "hangdang": "末"
    }
  ],
  "plot": "魏主曹睿命司马懿镇守雍、凉等处，预防诸葛亮进攻。诸葛亮心忧之，马谡献计：伪造告示，到处张贴；并\n散布流言，扬言司马懿有谋反之意。曹睿果心疑，削司马懿兵权。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾诩上。"
        },
        {
          "character": "贾诩",
          "type": "念",
          "text": "老王晏驾龙归沧，全凭智谋保家邦。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "下官，贾诩。大魏为臣，官居大夫之职。闻得孔明七擒孟获，必有吞我许都之 意。少时万岁登殿，把本启奏。看香烟缭绕，圣驾临朝，金殿伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。四太监、大太监、曹睿同上。"
        },
        {
          "character": "曹睿",
          "type": "引子",
          "text": "笙歌笛奏，万民欢，王坐龙庭。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "臣，贾诩见驾，吾皇万岁！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "曹睿",
          "type": "念",
          "text": "先王昔日领大兵，南征北剿费辛勤。四路烟尘俱扫尽，只有吴、蜀尚未平。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "寡人，曹睿。承先王之基业，风调雨顺，国泰民安。适才闻报，孔明七擒孟获， 平服南蛮，必有侵犯许都之意。 贾卿，有何妙计？"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "臣启万岁：想司马懿随老王出兵多年，深知孔明韬略，命他带领十万人马坐镇 雍凉，训练兵将，孔明纵有百万雄兵，不敢正视许都。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "替孤传旨，宣司马懿上殿！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "领旨。 万岁有旨：司马懿上殿！"
        },
        {
          "character": "司马懿",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿上。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "炎汉三分鼎，大魏有能人。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "臣，司马懿见驾，吾皇万岁！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿向贾诩拱手。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "啊大夫！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "啊大将军！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "宣臣上殿，有何国事议论？"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "卿家有所不知，孔明七擒孟获，平服南蛮，必有吞我许都之意，宣卿上殿商议， 怎样抵御孔明。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "万岁宣诏能人，带领人马，去往雍凉关训练兵将，谅那孔明不敢正视许都。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "卿家足智多谋，又随老王出兵多年，深知孔明之韬略，寡人意欲命卿带领十万 人马，雍凉训练，不知卿家可愿担此任否？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "臣恐才薄，不能胜任。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "卿家不必推辞。 贾卿，取印过来！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "曹睿",
          "type": "唱",
          "text": "卿家本是栋梁臣， 文韬武略胸中存。 金殿之上领孤命， 旗开得胜早回京。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "司马懿",
          "type": "西皮摇板",
          "text": "接过皇家元帅印，"
        },
        {
          "character": "司马懿",
          "type": "西皮二六板",
          "text": "扬扬得意自思忖： 跟随老王去出兵， 灭却了袁术、刘景升。 斩杀袁绍、吕布丧了命， 张绣骁勇也无能。 某家今日挂帅印， 我就是诸葛对头人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿下。"
        },
        {
          "character": "曹睿",
          "type": "唱",
          "text": "仲达接印下殿往，"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、曹睿自两边分下。"
        },
        {
          "character": "贾诩",
          "type": "唱",
          "text": "下得殿来自参详。 司马虽然智谋广， 要胜孔明恐怕是妄想一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾诩下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、关兴、张苞、魏延、马岱、马谡、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "我只道扶汉家易如反掌， 又谁知天命在难测难量。 曹孟德占天时兵多将广， 孙仲谋得地利独霸东方。 刘皇叔讲人和万民瞻仰， 汉江山分三国各自逞强。 我今日统人马中原扫荡， 秉忠心怀赤胆报答先王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启丞相：今有曹睿挂司马懿为帅，带领十万人马，在雍凉训练。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎呀且住，司马懿果然挂帅，此番出兵，只恐枉费辛劳！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相不必愁烦，末将有计献上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有何高见？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "司马懿用兵好胜，曹睿素怀疑忌，待末将去至各州府县粘贴告示，散布流言， 言道司马懿破蜀之后，还有收复许都之意。曹睿一闻此言，定要将司马懿斩首。 丞相伐魏，便可长驱大进了！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此计甚妙，急则有功，缓则无益，速速而行！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "辞别丞相出宝帐， 各州府县把榜文张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "马幼常文武才颇有志量， 借曹睿杀司马不用刀枪。 但愿得此计成灭却贼党， 汉江山成一统源远流长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张郃、郭淮同上，同起霸。高览、田密同上，同起霸。曹休、万起、李虎、张雄同上，同起霸。"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同点绛唇",
          "text": "杀气冲霄，人如虎豹，狼烟扫，各逞英豪，同心把魏保。"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张郃。"
        },
        {
          "character": "郭淮",
          "type": "白",
          "text": "郭淮。"
        },
        {
          "character": "高览",
          "type": "白",
          "text": "高览。"
        },
        {
          "character": "田密",
          "type": "白",
          "text": "田密。"
        },
        {
          "character": "曹休",
          "type": "白",
          "text": "曹休。"
        },
        {
          "character": "万起",
          "type": "白",
          "text": "万起。"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "李虎。"
        },
        {
          "character": "张雄",
          "type": "白",
          "text": "张雄。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "列位将军请了！"
        },
        {
          "character": "郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "今有圣上，挂司马懿为帅，前往雍凉训练。元帅升帐，你我两厢伺候！"
        },
        {
          "character": "郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠、中军捧印引司马懿同上，大纛旗、伞夫同随上。"
        },
        {
          "character": "司马懿",
          "type": "引子",
          "text": "志气凌云英雄论，要学孙武显才能。十万貔貅雍凉镇，虎视西蜀阻孔明。"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "队伍齐整出禁门，要学孙武显奇能。我今挂了元帅印，就是神鬼也担惊。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本帅，司马懿。今有孔明七擒孟获，有进犯许都之意，圣上命我为帅，带领十 万大兵去至雍凉训练，今日兴兵起程。 众位将军！"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "元帅！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "老夫今日兴兵，非比寻常，你等要队伍齐整，甲胄鲜明，刀枪耀目，弓箭随身。 交锋之期，努力前进，功成之日，凌烟标名，也不枉大丈夫一世英名也！"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "元帅威名远震，法令森严，末将等愿效犬马之劳。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "众位将军忒以过奖。人马可齐？"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "兵发雍凉！"
        },
        {
          "character": "张郃、郭淮、高览、田密、曹休、万起、李虎、张雄",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。四下手引马谡同上。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "来此已是魏邦地界。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "将告示四门粘贴！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同粘贴告示。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "粘贴已毕。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "命你等扮作魏兵模样，逢州府县粘贴告示，还要散布流言，道那司马懿破蜀之 后，有收复许都之意。记下了！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "司马懿呀，司马懿！"
        },
        {
          "character": "马谡",
          "type": "念",
          "text": "能人反被能人害，能人背后有能人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、马谡同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾诩上。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "贾诩",
          "type": "西皮摇板",
          "text": "长安百姓乱纷纷，"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "下官，贾诩。适才有人来报，逢州府县粘贴告示，说道司马懿破蜀之后，有收 复许都之意，待我速速奏与万岁知道便了！"
        },
        {
          "character": "贾诩",
          "type": "西皮摇板",
          "text": "何故今日起反心？ 撞动景阳万岁请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、曹睿同上。"
        },
        {
          "character": "曹睿",
          "type": "西皮摇板",
          "text": "景阳钟为何这样鸣！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "万岁，大事不好了！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "司马懿带兵往雍凉去后，逢州府县粘贴告示，说道平蜀之后，收复许都！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "这个！寡人将他召回，料然无事。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "万岁，岂不知“将在外，君命有所不受”？此时召回，恐其生乱！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "臣有一计在此。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "卿家有何妙计？"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "万岁去往雍凉，那司马懿必然前来接驾，就在马前拿获便了！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "寡人明日起行。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "迟者恐要误事！"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "内侍，传旨后宫娘娘，命太师代掌朝政，寡人起驾雍凉，即日就回。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "吩咐御林军走上！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "御林军走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同上。"
        },
        {
          "character": "曹睿",
          "type": "白",
          "text": "起驾雍凉！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "起驾雍凉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "诸葛亮",
          "type": "内二黄导板",
          "text": "习玄机学兵法孙武一样，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌执灯同上，关兴、张苞抱枪引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "回龙",
          "text": "视天机晓地理八卦阴阳。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "先帝爷越檀溪凶险波浪， 水镜庄遇高贤诉说衷肠。 魏、蜀、吴三分鼎江山分掌， 必须要智谋人扶保家邦。 徐元直荐山人徐母命丧， 蒙先帝三顾我出了龙岗。 头一功博望坡敌军胆丧， 借东风烧曹兵弃了荆襄。 孙仲谋霸江东寸土不让， 我三气周公瑾搬尸柴桑。 伐东吴白帝城龙归海藏， 我曾受托孤恩辅保朝纲。 奉王命征孟获七擒七放， 奏凯歌班师回祭渡泸江。 到如今伐中原意外之想， 司马懿挂了帅枉费心肠。 观天星看一看魏国气象，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌、关兴、张苞、诸葛亮同上高台。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "倘若是有凶险须要提防。 东北方一将星黑暗不亮， 一定是司马懿将星无光。 但愿得马参谋——"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "行计妥当，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌、关兴、张苞、诸葛亮同下高台。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "那时节统雄兵扫灭强梁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠、张郃、郭淮、高览、田密、曹休、万起、李虎、张雄、中军、司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "西皮流水板",
          "text": "三国纷纷刀兵振， 多少能将赴幽冥。 五虎将倒有那四人丧了命， 只剩下年迈苍苍老赵云。 余下之辈何足论， 生擒阿斗捉孔明。"
        },
