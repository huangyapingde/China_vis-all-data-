{
  "script_id": "03044004",
  "title": "火烧百凉楼",
  "alias": [
    "乱石山"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "常遇春",
      "hangdang": "武生"
    },
    {
      "name": "沐英",
      "hangdang": "副净"
    },
    {
      "name": "吴祯",
      "hangdang": "老生"
    },
    {
      "name": "徐达",
      "hangdang": "老生"
    },
    {
      "name": "刘福通",
      "hangdang": "净"
    }
  ],
  "plot": "朱元龙脱身百凉楼，幸常遇春接应，朱元龙得出险。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "沐英上。"
        },
        {
          "character": "沐英",
          "type": "西皮摇板",
          "text": "隐仙洞遵奉了师尊之命， 乱石山救义父锤打妖兵。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "俺，沐英。曾拜隐仙洞铁冠仙师门下为徒。遵奉师命，去至乱石山北山口，救 我义父朱千岁性命。用那蒋忠的凿金锤，迎战妖王刘福通，破他兵将，救驾解 围，在义父驾前为臣，保他成其大事。师尊命俺端午日赶到，今已五月初四， 急急趱行者！"
        },
        {
          "character": "沐英",
          "type": "唱",
          "text": "急趱路奔颍州救驾要紧， 明日里端阳节大战山林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "沐英下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、四红巾兵、四将同上，同站门。刘福通上。"
        },
        {
          "character": "刘福通",
          "type": "西皮摇板",
          "text": "元龙中孤诓军计， 兴隆大会兵将齐。 百凉高楼火光起， 纵有武艺也难施。 将身且坐宝帐里， 再听兵将报详细。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四兵丁、方国珍、左君弼、周伯颜、陈友定同上。"
        },
        {
          "character": "方国珍、周伯颜、左君弼、陈友定",
          "type": "同西皮摇板",
          "text": "大汉蒋忠好武艺， 锤下八将命归西。"
        },
        {
          "character": "方国珍",
          "type": "白",
          "text": "启会首：朱元龙、吴祯君臣逃下百凉楼，那马夫乃是蒋忠假扮．武艺高强，越 杀越勇，两柄金锤打死八员大将。老将吴祯银枪刺死无数兵将，剑斩白毛大帅。 特来报知。"
        },
        {
          "character": "刘福通",
          "type": "白",
          "text": "可恼啊可恼！"
        },
        {
          "character": "刘福通",
          "type": "西皮摇板",
          "text": "听说蒋忠艺骁勇， 老儿吴祯敢逞能。 统领全军齐奋勇， 生擒活捉朱元龙。"
        },
        {
          "character": "刘福通",
          "type": "白",
          "text": "众位王兄各施威勇，随孤捉拿朱元龙君臣去者！ 中国京剧戏考 《火烧百凉楼》【二本】 2"
        },
        {
          "character": "方国珍、周伯颜、左君弼、陈友定",
          "type": "同白",
          "text": "起兵前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "朱元龙上。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "杀败了！"
        },
        {
          "character": "朱元龙",
          "type": "唱",
          "text": "逃出了百凉楼君臣万幸， 道路迷分不出南北西东。 老将军与蒋忠俱无踪影，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴祯上。"
        },
        {
          "character": "吴祯",
          "type": "唱",
          "text": "西山口战死了大将蒋忠。"
        },
        {
          "character": "吴祯",
          "type": "白",
          "text": "参见主公！"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "老将军辛苦了！"
        },
        {
          "character": "吴祯",
          "type": "白",
          "text": "老臣效命疆场，理应尽忠。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "上将军蒋忠往哪里去了？"
        },
        {
          "character": "吴祯",
          "type": "白",
          "text": "主公啊！适才在阵前西山口内，蒋忠锤打八寇丧命；不想左腿被刺两枪，人马 落在陷坑之内，命丧沙场。老臣杀出道路，特来寻找主公。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元龙气椅。"
        },
        {
          "character": "吴祯",
          "type": "白",
          "text": "主公醒来！"
        },
        {
          "character": "朱元龙",
          "type": "唱",
          "text": "闻言叫孤心酸痛， 可惜蒋忠猛英雄。 神魂散乱血上涌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "沐英上。"
        },
        {
          "character": "沐英",
          "type": "唱",
          "text": "沐英救驾见主公。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "孩儿沐英参见义父千岁！"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "儿呀，你我父子数载未见，因何道家打扮，从哪里而来？"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "孩儿在隐仙洞蒙师尊铁冠仙长传授武艺，练就双锤。师尊命俺来到乱石山救驾 解围，蒋忠双锤归孩儿使用，大破妖兵。"
        },
        {
          "character": "吴祯",
          "type": "白",
          "text": "此乃主公洪福齐天。蒋忠虽然丧命，殿下到此，妖王可擒矣！"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "但愿如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四红龙套、四红巾兵、四将、刘福通同上，过场，同下。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "哎呀儿呀，看刘福通带领人马追杀前来，如何是好？"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "老将军保驾，树林安身。待我会他一阵。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "须要小心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元龙、吴祯同下。四红龙套、四红巾兵、四将、刘福通同上，同归小边，沐英归大边，会阵。"
        },
        {
          "character": "刘福通",
          "type": "白",
          "text": "呔！黄毛小道，乳食婴孩，竟敢来救朱元龙？通尔的名来！"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "呸！妖贼听者！俺乃铁冠仙长门徒、朱千岁义子、黄金刚沐英。尔叫何名？"
        },
        {
          "character": "刘福通",
          "type": "白",
          "text": "听者！孤乃颍州王、红巾会首刘福通。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "刘福通，你竟敢设计害俺义父千岁？看锤！ （沐英起打。刘福通、四红龙套、四红巾兵、四将同败下。方国珍、周伯颜、左君弼、陈友定同上，与沐英 打五梅花，方国珍、周伯颜、左君弼、陈友定同败下。刘福通上，漫头，起打，刘福通败下，沐英追下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "常遇春",
          "type": "内白",
          "text": "黑虎军！"
        },
        {
          "character": "四上手、四黑虎军",
          "type": "内同白",
          "text": "有！"
        },
        {
          "character": "常遇春",
          "type": "内白",
          "text": "催队趱行！ 中国京剧戏考 《火烧百凉楼》【二本】 3"
        },
        {
          "character": "四上手、四黑虎军",
          "type": "内同白",
          "text": "啊！ （四上手、四黑虎军、贾平、王威同上，同站斜一字。常遇春上，亮相。四上手、四黑虎军、贾平、王威同 走圆场，同挖门。）"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "俺，淮南百胜将军、紫太岁常遇春。在西吴王朱千岁驾前为臣。只因颍州妖王 刘福通，在千佛乱石山修造百凉楼，设立兴隆大会，邀请各路王爷带兵帮助， 要害千岁龙驾。奉了军师刘伯温之令，去往乱石山解围救驾，为此点齐黑虎军， 准备与妖王会战。看前面离千岁御营不远。 黑虎军！"
        },
        {
          "character": "四上手、四黑虎军",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "御营去者！"
        },
        {
          "character": "四上手、四黑虎军",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春趟马。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、胡大海、郭英、赵盛庸、范永年同上，同站门。徐达上，大纛随上。"
        },
        {
          "character": "徐达",
          "type": "西皮二六板",
          "text": "千岁去赴兴隆会， 吴祯、蒋忠保驾随。 带兵攻打山石垒， 山口难攻无计为。 已命汤和攻山北， 未见探马报信回。 将身且坐宝帐内， 候听探马报是非。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启元帅：常将军来到御营。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "有请六将军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请六将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四黑虎军、贾平、王威、常遇春同上，同站一字。徐达出迎。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "常六将军！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "元帅！"
        },
        {
          "character": "徐达、常遇春",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "众位将军！"
        },
        {
          "character": "胡大海、郭英、赵盛庸、范永年",
          "type": "同白",
          "text": "六将军！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "元帅请！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "六将军请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同进门。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "元帅请上，待末将常遇春大礼参拜！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "六将军少礼。请坐！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "不知六将军驾到，本帅未曾远迎，将军恕罪！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "岂敢！俺常遇春来得卤莽，元帅海涵！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "岂敢！请问六将军从何处而来？"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "元帅有所不知，只因京都武科场事毕，俺归家务农三载，偶遇护国军师刘道长， 是他言道：我主千岁在滁州被困，脱脱攻打甚急。是俺点齐黑虎军，奔往滁 州与李文忠将军合兵一处，与脱脱对敌，被俺几合勇战，将那老儿人马杀败， 中国京剧戏考 《火烧百凉楼》【二本】 4 退进木门岭山谷去了。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "将军真乃虎威，可算首功一件。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "些许小事，何劳元帅称赞。请问元帅，我主千岁带领多少兵将去赴兴隆大会？"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "将军也知主公赴会之事？"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "末将奉护国军师之命，去往乱石山解围救驾。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "若问千岁赴会之事，你且听了："
        },
        {
          "character": "徐达",
          "type": "西皮快板",
          "text": "主公寅刻把山入， 带领操军一马夫。 吴祯、蒋忠把驾护， 君臣三人事恍惚。 攻山两次遭埋伏， 伤了百余兵与卒。"
        },
        {
          "character": "常遇春",
          "type": "西皮摇板",
          "text": "闻言怒气冲肺腑， 大骂妖王狗佞徒。 统领兵将列队伍， 东征西挡做武夫。 任他的乱石山埋伏坚固， 常遇春铁枪钢鞭誓把妖除！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "元帅，末将愿统领黑虎军，攻开南山山口。请元帅带兵随后入山救驾。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "有劳将军！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "嘚！黑虎军！"
        },
        {
          "character": "四黑虎军",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "与爷带马！"
        },
        {
          "character": "四黑虎军",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四黑虎军、贾平、王威、常遇春同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "胡大海、郭英、赵盛庸、范永年",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "随本帅进山接驾！"
        },
        {
          "character": "胡大海、郭英、赵盛庸、范永年",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "蓝靛瑞",
          "type": "内西皮导板",
          "text": "巧安排铁冲车护守山口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四蓝龙套、四藤牌手、四下手推车、英雄推木车同上，站门。蓝靛瑞搭红绸巾上。"
        },
        {
          "character": "蓝靛瑞",
          "type": "白",
          "text": "俺，颍州王麾下铁枪大都督蓝靛瑞。我主邀请各路王爷齐集乱石山，要将朱元 龙害死。那朱元龙竟敢带领操军、马夫二人，大胆前来赴会。百凉楼火攻齐备， 各处埋伏安排妥当，命俺带领健将押定铁冲车在南山口埋伏，截杀朱元龙。 众兵卒！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "蓝靛瑞",
          "type": "白",
          "text": "南山口去者！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
