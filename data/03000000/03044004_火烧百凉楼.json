          "text": "四文堂、四大铠引徐达同上，大纛随上。"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "启元帅：圣驾在此。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "你等退后，待本帅见驾请罪。 臣，徐达见驾，主公千岁！臣徐达无能保护，使主公受惊，死罪呀死罪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达免冠。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "此乃小王一时大意，遭此毒计，元帅何罪之有？待小王与元帅将帅冠戴起。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "折煞为臣！"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "老将军辛苦了！"
        },
        {
          "character": "吴祯",
          "type": "白",
          "text": "老朽无能保驾，主公受此惊险，上将军蒋忠命丧沙场，皆老朽之过。元帅台前 请罪！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "若非老将军保驾，宝剑斩贼，主公难出百凉楼。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "元帅言得极是。 沐英，见过元帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元龙向徐达。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "这是孤的义子沐英。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "小殿下！"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "元帅不可如此称道！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "理当如是。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "众位将军往哪里去了？"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "在沙场与贼交战。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "元帅怎样进兵山口？"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "主公容奏：常六将军奉了刘军师之令，带兵到此救驾。滁州路解之围，将臣师 脱脱丞相人马杀退，败进木门岭山内。又带领黑虎军，一声喝开山口，枪挑五 辆铁刀冲车，将蓝靛瑞刺死。为臣才得带兵进山救驾。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "六弟可称忠勇盖世。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "六将军真乃神威也！ 中国京剧戏考 《火烧百凉楼》【二本】 9"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭英、胡大海、赵盛庸、范永年同上。"
        },
        {
          "character": "郭英、胡大海、赵盛庸、范永年",
          "type": "同白",
          "text": "参见主公！臣等救驾来迟，主公驾前请罪！"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "众位将军平身。"
        },
        {
          "character": "郭英、胡大海、赵盛庸、范永年",
          "type": "同白",
          "text": "谢主公！"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "六将军往哪里去了？"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "启主公：六弟遇春同三弟汤和赶奔颍州捉拿刘福通家眷和奸贼孙德崖去了。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "刘福通呢？"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "启主公：刘福通被常遇春枪挑落马，汤和将四王杀败，各自逃回驻地去了。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "众位将军辛苦了！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "臣等理应尽忠。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "孤赐上将军蒋忠黄罗帐裹体，回至滁州再行治丧。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "谢主公！启千岁：刘福通疆场丧命，四路王子各回驻地，此处妖兵全军尽没， 请驾回转滁州。"
        },
        {
          "character": "朱元龙",
          "type": "白",
          "text": "驾返滁州再行升赏。起驾，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
