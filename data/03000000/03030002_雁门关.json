    },
    {
      "name": "孟金榜",
      "hangdang": "旦"
    },
    {
      "name": "蔡秀英",
      "hangdang": "旦"
    },
    {
      "name": "孟良",
      "hangdang": "净"
    },
    {
      "name": "焦赞",
      "hangdang": "净"
    },
    {
      "name": "韩昌",
      "hangdang": "净"
    }
  ],
  "plot": "杨延顺过营探母，因分别已久，佘太君与蔡秀英均不敢相认，后经查验朱砂痣，方知无误。母子夫妻团聚，\n细诉离情，奈因时限将至，乃忍痛作别。孟良欲借用杨延顺令箭，混进关卡，杀辽军于措手不及。杨延顺恐\n公主受累，初不肯从，后经晓谕大义，终将令箭交出。杨延昭趁机混进雁门关。韩昌因无萧太后令箭，不得\n发兵往救，辽军大败，退守黑水河。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵、四火把、四车夫同上，同站门。岳胜上。"
        },
        {
          "character": "岳胜",
          "type": "念",
          "text": "剑气冲霄贯日红，将军走马建奇功。剿除胡儿扶大宋，不枉百战将英雄。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "俺，岳胜，随同元帅扫北，难以取胜。闻听太君领兵来到雁门关，因此催粮黑 夜急行。 众将官！"
        },
        {
          "character": "四宋兵、四火把、四车夫",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "粮草解往雁门关去者！"
        },
        {
          "character": "四宋兵、四火把、四车夫",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵执火把引萧天佐、萧天佑同上。"
        },
        {
          "character": "萧天佐",
          "type": "念",
          "text": "平地风狂摧细柳，"
        },
        {
          "character": "萧天佑",
          "type": "念",
          "text": "塞北天寒尚如秋。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "萧天佐。"
        },
        {
          "character": "萧天佑",
          "type": "白",
          "text": "萧天佑。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "只因韩驸马与杨家交兵，大败而回。明日太后亲自出兵，你我点齐人马，去到 校场伺候。 巴图鲁！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "校场去者！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、萧天佐、萧天佑同走圆场。"
        },
        {
          "character": "四番兵",
          "type": "stage",
          "text": "中国京剧戏考 《雁门关》【二本】 2"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "四番兵",
          "type": "白",
          "text": "南朝粮草离此不远。"
        },
        {
          "character": "萧天佐、萧天佑",
          "type": "同白",
          "text": "劫他粮草！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵、四火把、四车夫、岳胜同上。"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "番兵断路！"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "粮草退后。 众将官，杀！"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。萧天佐、萧天佑、四番兵同败下。岳胜领四宋兵同追下。萧天佐、萧天佑、四番兵同上。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "且住！宋将骁勇，粮草难以夺取。 巴图鲁！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "人马撤回校场！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "杨延昭",
          "type": "内唱",
          "text": "更鼓响银箭催月明星现，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵引杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "为宋室征杀砍哪得消闲！ 实指望扫北国得胜回转， 番营中兵将广倒海排山。 两军阵我与他交过数战， 我营中众兵将难胜北番。 多蒙那圣天子爱将恩典， 命老母领人马来到边关。 幸喜得败番兵遂我心愿， 奉母命巡营哨军威森严。 众将官披星月小心查点，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上城。四宋兵同随上城。"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "紧提防众番寇暗地行奸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵、四火把、四车夫、岳胜同上。"
        },
        {
          "character": "岳胜",
          "type": "唱",
          "text": "押军粮如急风归心似箭， 催战马紧加鞭来到关前。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "开关！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "关下何人？"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "岳胜押解粮草回营。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "岳胜将军回来了。 守关军士快快开关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵同开关。岳胜、四宋兵、四火把、四车夫同进关。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "参见元帅！粮草催齐。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "将粮草押送回营！"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳胜、四宋兵、四火把、四车夫同下。"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "今不是汉武侯西城弄险， 番邦将如仲达枉起狼烟。 为国家运粮草星夜回转， 杨延昭查奸细理所当然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、四宋兵同下。"
        },
        {
          "character": "杨延昭",
          "type": "stage",
          "text": "中国京剧戏考 《雁门关》【二本】 3"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵、四女兵同上，同站门。佘太君上。"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "奉王旨领人马南北征战， 西王母降瑶池白发老年。 中军帐灯光照光辉灿烂， 且等候巡营将禀报帐前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈林、柴干、郎千、朗万、孟金榜、杨八姐、杨九妹同上。"
        },
        {
          "character": "陈林",
          "type": "白",
          "text": "启禀太君：末将等拿住奸细，现有萧银宗金批令箭在此。太君请看！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "待我看来。呜呼呀！果然是萧银宗的令箭。吩咐众将，弓上弦、刀出鞘，将奸 细押上帐来！"
        },
        {
          "character": "陈林",
          "type": "白",
          "text": "下面听者！太君有令：弓上弦、刀出鞘，将奸细押上帐来！"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵押番兵甲、杨延顺同上。"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "奸细带到。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "将小番带下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵同允，带番兵甲下。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "将奸细带上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君看。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "果然番邦奸细，推出斩首！"
        },
        {
          "character": "孟金榜、杨八姐、杨九妹",
          "type": "同白",
          "text": "且慢！此人不是小番打扮，何不将他叫醒，问问北国情形。他若不说，再斩不 迟。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "快快将他唤醒！"
        },
        {
          "character": "孟金榜、杨八姐、杨九妹",
          "type": "同白",
          "text": "番将醒来！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "昏沉沉只听得人声叫喊， 心恍惚如梦中意马心猿。 放开了英雄胆睁开双眼， 好一似孽镜台鬼魂诉冤。 跪宝帐实不敢抬头仰面， 听老母传将令再把话言。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "奸细听了！"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "问奸细你奉了何人差遣， 黑夜里到宋营所为哪般？ 说真情饶尔命放尔回转， 若隐瞒管叫尔命丧黄泉。"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "我非是小胡儿奉命打探， 想老母诓令箭黑夜出关。 离膝下十二载未见娘面， 我本是杨延顺不孝儿男。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "胡说！"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "杨延顺岂是这胡儿打扮？ 他弟兄闯幽州至今未还。 我兴兵胜吕望能知暗算， 早知道贼今晚偷探营盘。 中军帐岂容尔巧言善辩，"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "众将官！ 中国京剧戏考 《雁门关》【二本】 4"
        },
        {
          "character": "陈林、柴干、郎千、朗万",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "绑辕门将他斩决不容宽！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": "杨延顺",
          "type": "唱",
          "text": "儿好心探母亲反遭大难， 容禀明再斩首死也心甘。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "你且讲来！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎呀母亲哪！暂息雷霆之怒，不要误杀孩儿。儿离膝下一十二载，母亲年迈， 老眼昏花，不能相认；众位嫂嫂、二位贤妹，难得也不认得了么？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "你是北国胡儿，谁来认你？"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "啊！我妻蔡秀英，为何不在此处？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "胡说！蔡秀英是我的媳妇，老身命她巡营去了，你在哪里访得这个名字，前来 蒙哄于我？"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "母亲将她唤进营来，她若不认孩儿，再死也是无怨的了。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "暂容你多活一时。 春景、春花，传你蔡氏嫂嫂进帐！"
        },
        {
          "character": "杨八姐、杨九妹",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨八姐、杨九妹同下。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "陈林、柴干、郎千、朗万听令！"
        },
        {
          "character": "陈林、柴干、郎千、朗万",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "命你等巡营瞭哨，若遇番兵哨探，速来通报。"
        },
        {
          "character": "陈林、柴干、郎千、朗万",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈林、柴干、郎千、郎万同下。杨八姐、杨九妹引蔡秀英同上。"
        },
        {
          "character": "蔡秀英",
          "type": "唱",
          "text": "二贤妹报一信心中难解， 到前帐问婆婆便知明白。 见小番跪帐前低头细揣，"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎呀母亲，这就是我妻蔡秀英！ 哎，难得见的妻呀！"
        },
        {
          "character": "蔡秀英",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "哎！她也不认我了！"
        },
        {
          "character": "蔡秀英",
          "type": "唱",
          "text": "番邦人叫的我羞惭满腮。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "啊媳妇，这番将可是八郎么？"
        },
        {
          "character": "蔡秀英",
          "type": "白",
          "text": "啊呀母亲哪！延顺左腿有朱砂大痣一个，何不吩咐众将看个明白：若是无有， 即刻将他斩首！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "大痣是有的。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "来！将他的左腿验来！"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "脱了靴袜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵同验。"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "左腿有大痣一个！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君看。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿是八郎？"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "杨延顺",
          "type": "白",
          "text": "娘啊！"
        },
        {
          "character": "佘太君",
          "type": "唱",
