{
  "script_id": "03107003",
  "title": "阳平关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "黄忠",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    }
  ],
  "plot": "曹操闻夏侯渊被黄忠斩杀，切齿痛恨，亲率大军至阳平关，移屯米仓山粮草于北山，誓为夏侯渊报仇。诸葛\n亮闻讯，欲遣将劫断曹军粮草辎重，以挫其锐。黄忠请令前往。赵云恐黄忠连战劳乏，欲代其行。黄忠不服\n年老力衰，坚请出征，诸葛亮许之，并命赵云哨探胜败，俟机往助。黄忠率军烧毁曹军粮草后，被困垓心，\n幸赵云来援，杀退曹兵，始得突围回营。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、许褚、焦炳、曹洪、王平、慕容烈同上。"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同点绛唇",
          "text": "细柳营开，丽日光霭，军威迈，文武全才，吴、蜀敢眦睚？"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "俺！徐晃。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "许褚。"
        },
        {
          "character": "焦炳",
          "type": "白",
          "text": "焦炳。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "曹洪。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平。"
        },
        {
          "character": "慕容烈",
          "type": "白",
          "text": "慕容烈。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "我主魏王，闻得西蜀刘备直犯汉中，为此亲率大兵，来决雌雄。前有手书，命 夏侯渊拒敌，尚未见捷音回报，好生忆念也！"
        },
        {
          "character": "许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "且待主公升帐，你我请求前往相援便了。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "有理。请！"
        },
        {
          "character": "许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "双手独擎天，奇勋早已建；虚名扶汉祚，时势魏将迁。"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "参见主公！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位将军少礼！"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "三召入虎帐，九列冠朝缨。今朝僭銮舆，不日九五登。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孤，魏王曹操。假意举义于陈留，召请诸侯，扫灭董卓。明以伊尹之作用，暗 如后羿之图谋，视天子如木偶，藐群雄如草芥，虎视天下，位加九锡。诸侯皆 已顺服，唯孙、刘尚未剪除，因此亲率大兵，着夏侯渊开兵试武，此时未闻捷 报，好生犹疑也！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "主公既虑夏侯渊无音，何不另选别将代替？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "且自消停，容孤思之！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "地下鼓角鸣，天上落将星。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报子告进！参见千岁！定军山失守，夏侯将军被黄忠立斩于马下！"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "啊？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那老儿怎样斩得夏侯将军？速速讲来！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "容禀！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "起来讲！"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "夏侯自得军令便欲提兵，张郃苦谏不纳听。出兵冲敌阵，独领队伍逞胜。 对山息兵歇战，我军辱骂纷纷。门旗闪出老寿星，叱咤人头瓜滚！"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "报子",
          "type": "园林好",
          "text": "真个是天崩地陨，鬼神惊，我军无剩。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "主公看仔细！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "西皮导板",
          "text": "听报来痛得孤口呆目瞪，"
        },
        {
          "character": "曹操",
          "type": "叫头",
          "text": "渊弟，妙才！"
        },
        {
          "character": "曹操",
          "type": "哭",
          "text": "唉！贤弟呀……"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "又何殊失却孤股肱之人！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "孤今朝始信那管辂神签， 果黄猪遭虎口己亥之征。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "丞相为何发笑？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "当年管辂有言：“三八纵横，黄猪遇虎；定军之南，伤折一股。”这三八纵横 者，乃建安二十四年也；黄猪遇虎，亥猪寅虎，乃己亥正月也；定军之南，乃 定军山之南也；今闻此凶报，顿悟管辂之言不谬。唉！管辂呀，管辂！你何其 神也！渊弟，妙才！何其苦也！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "望定西蜀咬牙恨， 手指着大耳骂几声！ 孤一怒叫你成齑粉， 看是谁强哪个能！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "主公不必悲伤。何不亲率大兵，夺转定军山，拿住刘备，以消夏侯将军之恨。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "着哇！就命你为先锋，诸将副之，即日拔寨，速往定军山进发。"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖八声甘州〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张郃、杜袭同上。"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "定军山一战魂胆惊，"
        },
        {
          "character": "杜袭",
          "type": "唱",
          "text": "可惜大将一命倾！"
        },
        {
          "character": "张郃、杜袭",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张郃。"
        },
        {
          "character": "杜袭",
          "type": "白",
          "text": "杜袭。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "将军，你我奉了魏王之命，把守定军山，怎奈夏侯渊刚愎自恃，不肯听谏，以 致身死沙场，定军山失陷。前着飞骑请兵，今日魏王将到，你我迎上前去。"
        },
        {
          "character": "杜袭",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "急速前去迎大军，"
        },
        {
          "character": "杜袭",
          "type": "唱",
          "text": "协力破敌西蜀平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、徐晃、许褚、焦炳、曹洪、王平、慕容烈、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "豪雄威镇仪仗新，浩浩荡荡鬼神惊。"
        },
        {
          "character": "张郃、杜袭",
          "type": "同白",
          "text": "迎接魏王。死罪呀，死罪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、杜袭同跪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此系前定之数，与尔等何干。起来！"
        },
        {
          "character": "张郃、杜袭",
          "type": "同白",
          "text": "谢主公！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孤家此来，实为夏侯将军报仇雪恨，今定军山既失，可将米仓山粮草，屯积汉 水北山角下，稍事喘息，然后看其虚实而动，听孤吩咐！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "孤王马上传将令， 叫一声左右众将军： 孤自起兵陈留郡， 为的是董卓目无君。 我东挡西除亲临阵， 南战北剿自劳形。 尔等奋勇往前进， 任他有翅难也难腾。 今晚且自各安顿，"
        },
        {
          "character": "徐晃、许褚、焦炳、曹洪、王平、慕容烈、张郃、杜袭",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、徐晃、许褚、焦炳、曹洪、王平、慕容烈、张郃、杜袭自两边分下。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "择选黄道再开兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、诸葛亮、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "非孤劳形，都只为汉祚将倾，怎敢辞，疆场辛勤。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "鼎足三分，谋一统，从权秉政。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、刘封、孟达、张著同上。"
        },
        {
          "character": "赵云、刘封、孟达、张著",
          "type": "同引子",
          "text": "唯欲取宇宙安宁。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请坐！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "扬眉掀髯笑颜开，幸得将军斩贼来。今朝且饮功臣宴，"
        },
        {
          "character": "赵云、刘封、孟达、张著",
          "type": "同念",
          "text": "他日齐唱凯歌回。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "幸赖先生妙算，汉升智勇，贼将授首，定军山已得，为此大帐摆宴，庆贺功臣。 黄老将军可曾来到？"
        },
        {
          "character": "赵云、刘封、孟达、张著",
          "type": "同白",
          "text": "想必来也。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "黄老将军得胜回营。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吩咐摆队相迎！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "摆队相迎！ （报子下。〖牌子〗。四文堂、赵云、刘封、孟达、张著、诸葛亮、刘备同下。四龙套同上，马童捧夏侯渊 人头引黄忠同上。）"
        },
        {
          "character": "黄忠",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、马童、黄忠同下。四文堂、赵云、刘封、孟达、张著、诸葛亮、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊！老将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下马。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "老将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备递酒。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "折杀老臣了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠跪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "理当。 （刘备扶起黄忠，四文堂、四龙套、马童、赵云、刘封、孟达、张著、诸葛亮、刘备、黄忠同下。四文堂、 马童、赵云、刘封、孟达、张著、诸葛亮、刘备、黄忠同上，同归座。）"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "老臣赖主公洪福，斩夏侯渊首级来献！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童献头。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "将军莫大之功也。首级号令辕门！"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童捧头下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "加封将军征西大将军之职。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "谢主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "看酒与老将军贺功！"
        },
        {
          "character": "四文堂",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同摆宴。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待孤把盏。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "哎呀，折杀老臣！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "当得的。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "断断不敢！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我儿代敬。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
