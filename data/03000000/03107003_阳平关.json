        {
          "character": "黄忠",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "张著赶来必有因。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张著上。"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "老将军！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "啊！敢是军师疑我不能成功，着你赶我回去么？"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "非也。军师谅将军此去必然成功，但恐独力难支，故使某来听候驱策。"
        },
        {
          "character": "黄忠",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "军师可谓知我也！"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "话虽如此，只是曹兵甚众，将军若仗力敌，决难成功，必得奇计，方能劫得他 的粮草。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "我斩夏侯渊，张郃已经丧胆；再者，他连日运粮，必然疲倦。我若今晚三更， 饱餐战饭，四更时分，悄至北山，放火烧他粮草，张郃必然前来扑救，此时一 鼓擒之，岂不为妙？"
        },
