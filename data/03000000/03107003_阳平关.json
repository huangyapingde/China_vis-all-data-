          "character": "张著",
          "type": "白",
          "text": "老将军真妙计也！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "将军既来助我，急速办理去者！"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "兵不厌诈从来论， 也学那诸葛火烧博望兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
