        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "子龙暗暗作后应， 准备精卒候时辰， 黄忠午时无消息， 急速救援莫消停。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令！"
        },
