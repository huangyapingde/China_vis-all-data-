    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "黄忠",
          "type": "内西皮导板",
          "text": "我非人前夸老硬，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、四龙套、马童同上。"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "自有韬略定乾坤。 赵国廉颇八十正， 尚食斗米肉十斤。 我年未过七十五， 怎说老朽便无能。 任他兵来如潮水， 哪怕将来似风云。 杀他个血流人头滚， 杀得他尸横马难行。 洋洋得意往前进，"
        },
        {
          "character": "张著",
          "type": "内白",
          "text": "老将军慢走！"
