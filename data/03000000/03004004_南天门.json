{
  "script_id": "03004004",
  "title": "南天门",
  "alias": [
    "走雪山"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "曹福",
      "hangdang": "老生"
    },
    {
      "name": "曹玉莲",
      "hangdang": "旦"
    },
    {
      "name": "店家甲",
      "hangdang": "老生"
    },
    {
      "name": "店家乙",
      "hangdang": "丑"
    },
    {
      "name": "驴夫",
      "hangdang": "丑"
    }
  ],
  "plot": "曹福保护曹玉莲逃出官庄堡后，山川跋涉，备历艰苦。行至广花山，时值隆冬，大雪纷飞。曹福解衣与曹玉\n莲御寒，因致冻死。适大同总镇蔡同善遣人来迎，曹玉莲得救，始抵大同。",
  "notes": "这个剧本是陈德霖先生生前演出本，经安舒元先生协助校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "曹玉莲",
          "type": "内唱",
          "text": "急急忙忙走得慌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹玉莲、曹福同上。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "点点珠泪洒胸膛。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "鱼儿闯过千层网，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "虎口内逃出了两只羊。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小姐，且喜你我主仆，逃出虎口。老奴搀扶你慢慢行走。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "搀扶了！"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "恼恨那魏忠贤奸贼佞党，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "我朝中出谗臣搅乱家邦。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "天启爷坐早朝东方未亮，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "狗奸贼上金殿不等天光。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "我的父修下了辞王表本，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "不容奏将老爷绑赴法场。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "多亏了程伯父把本奏上，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "丢了官罢了职谪贬回乡。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "耳边厢又听得人声喧嚷，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "刘司羽带人马暗地埋藏。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "夜晚间宿至在官庄堡上，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "官庄堡围了个铁壁铜墙。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "遭不幸我的父剑下命丧。 老爹爹……"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "太老爷呀……"
        },
        {
          "character": "曹玉莲、曹福",
          "type": "同唱",
          "text": "呵，呵，呵……"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "太老爷呀！ 可怜我太老爷一命身亡。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "我的母跳花井把命来丧， 老娘亲……"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "太夫人哪！"
        },
        {
          "character": "曹玉莲、曹福",
          "type": "同唱",
          "text": "呵，呵，呵……"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "我的娘啊！"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "实可叹太夫人花井埋藏。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "多亏了老曹福能言会讲，"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "也是你小姑娘福大命长。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "这一时走得我腿酸足胀， 腹儿内无有食饥饿难当。 将身儿坐至在土台之上， 思想起二爹娘好不惨伤。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小姐为何不走？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "腹内饥饿难以行走。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "这个……老奴身旁分文无有，如何是好？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "我这里有金耳环一对，拿去换些银钱使用。 转来！问这里，可有大米饭食无有？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "老奴遵命。 啊掌柜的哪里？"
        },
        {
          "character": "店家乙",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家乙上。"
        },
        {
          "character": "店家乙",
          "type": "念",
          "text": "说我富来不算富，开了七十二座典当铺。"
        },
        {
          "character": "店家乙",
          "type": "白",
          "text": "老头儿做什么？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "我这里有金耳环一对，换些银钱使用。"
        },
        {
          "character": "店家乙",
          "type": "白",
          "text": "拿来我看。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "店家乙",
          "type": "白",
          "text": "我问你，金子是什么颜色？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "金子是黄的。"
        },
        {
          "character": "店家乙",
          "type": "白",
          "text": "你们那里金子是黄的；我们这是绿的。去你的罢，别拿风磨铜，在这搅我了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家乙下。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "哎！这人不在时中，金子都变成铜了！那厢去换。 啊，掌柜的有么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家甲上。"
        },
        {
          "character": "店家甲",
          "type": "念",
          "text": "买卖兴隆通四海，财源茂盛达三江。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "老头儿当什么？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "我这里有金耳环一对，换些银钱使用。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "拿来我看。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "好赤金。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "掌柜的眼力不差。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "要换多少。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "按市价合来。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "伙计们，金耳环一对按市价合来！"
        },
        {
          "character": "伙计",
          "type": "内白",
          "text": "耳环三钱重，金子十四换。三得三，三四一两二；银子四两，下找铜钱二百。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "老头儿，耳环三钱重，金子十四换。三得三，三四一两二；银子四两，下找铜 钱二百。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "掌柜的，可有大米饭食无有？"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "无有大米饭食，有面食馍馍。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "面食亦可。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "等着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家甲下，拿上。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "面食馍馍拿去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家甲下。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "少刻奉还。 啊小姐，金耳环一对，三钱重，他们这里金子十四换。三得三，三四一两二， 银子四两，下找铜钱二百，小姐收下。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "待我收下。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "此处无有大米饭，现有面食馍馍小姐请用。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "拿来我用。 哎呀爹娘啊！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小姐为何不用？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "思想爹娘，吞吃不下。曹福，你拿去吧！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "是…… 太老爷、太夫人哪！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "曹福，为何不用？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "老奴思想太老爷、太夫人，也是吞吃不下。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "这也难怪。将碗送还！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "回来！问这里可有脚程无有。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "是。 啊掌柜的，面食未用，要多少钱文？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家甲上。"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "面食未用，钱不要了。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "到处都有好人。借问一声，此处可有脚程无有？"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "脚程那厢去问。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": "店家甲",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家甲下。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "脚程哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驴夫上。"
        },
        {
          "character": "驴夫",
          "type": "念",
          "text": "忽听唤脚程，两腿跑如风。脚程是我，我是脚程。"
        },
        {
          "character": "驴夫",
          "type": "白",
          "text": "啊老头儿，敢是雇脚程的？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "驴夫",
          "type": "白",
          "text": "雇几头？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "两头。"
        },
        {
          "character": "驴夫",
          "type": "白",
          "text": "上哪里去？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "往大同而去。"
        },
        {
          "character": "驴夫",
          "type": "白",
          "text": "但不知走大路，走小路？"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "走大路怎说，小路怎讲？"
        },
        {
          "character": "驴夫",
          "type": "白",
          "text": "走大路远三天，小路近三天。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "如此说，自然走近不走远。"
        },
        {
          "character": "驴夫",
          "type": "白",
          "text": "走小路路过四十里广花山，惯出狼虫虎豹，吃了你这个老头子，算不了什么； 吃了我的驴，乃是一件大事。我不去了。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小哥，我多把钱文与你。"
        },
        {
          "character": "驴夫",
          "type": "白",
          "text": "留着你的钱，买棺材钉子罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驴夫下。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "呀呀呸！好一个不会讲话的奴才，吃了我的人，倒是小事；吃了他的牲口，倒 是大事。待我瞒过小姐，从小路而走。 啊小姐，此处离大同不远，无有脚程，老奴搀扶你慢慢行走！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "曹福，搀扶了！"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "三家店前把饭用， 心猿意马归旧踪。 适才中途问路径， 主仆双双奔大同。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹玉莲下。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "恨贼子把我的牙咬坏， 埋怨老爷太无才。 忠良反被奸贼害， 害得我一家大小好不悲哀。 拿住了奸贼千刀宰， 挖尔的心肝方趁称我的心怀。"
        },
        {
          "character": "曹玉莲",
          "type": "内白",
          "text": "曹福，来呀！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "嗯，来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹福下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四家将同上。"
        },
        {
          "character": "四家将",
          "type": "同唱",
          "text": "大同领了大人命， 迎接小姐转回程。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "你我奉了大人之命，迎接小姐。一同趲行！"
        },
        {
          "character": "家将乙",
          "type": "白",
          "text": "慢着，我问你们，咱们迎接小姐，是走大路，走小路？"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "走大路怎样，走小路怎样？"
        },
        {
          "character": "家将乙",
          "type": "白",
          "text": "走大路远三天，走小路近三天。"
        },
        {
          "character": "三家将",
          "type": "白",
          "text": "自然走近不走远。"
        },
        {
          "character": "家将乙",
          "type": "白",
          "text": "走小路路过四十里广花山，山中惯出狼虫虎豹，吃了你们这年青的小伙儿，不 要紧；吃了我这老头子，你们赔得起吗？"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "腰里带着什么呢？"
        },
        {
          "character": "家将乙",
          "type": "白",
          "text": "刀。"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "着啊，有刀怕什么？走啊！"
        },
        {
          "character": "家将甲",
          "type": "唱",
          "text": "打罢春来又交秋，"
        },
        {
          "character": "家将乙",
          "type": "唱",
          "text": "夕阳西下水东流。"
        },
        {
          "character": "家将丙",
          "type": "唱",
          "text": "扬鞭打马朝前走，"
        },
        {
          "character": "家将丁",
          "type": "唱",
          "text": "野花闲草遍地愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家将同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹玉莲、曹福同上。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "我的父过府把寿拜， 贼将珠宝往上抬。 邀买忠良心一块， 谋取万岁九龙台。 这旁有一大石块， 坐在上面不起来。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小姐为何又不行走？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "两足疼痛，难以行走。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "小姑娘啼哭坐土台， 珠泪滚滚洒下来。 自幼未出闺门外， 鞋弓袜小步难挨。 思父想娘俱不在， 头上取下金钗来。 缠足带忙松解， 轻轻刺破红绣花鞋，好把路挨。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "老哥哥你把脸朝外， 头上取下金钗来。 缠足带忙松解， 轻轻刺破红绣花鞋。 老哥哥与我把路带， 一步一步往前挨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下雪。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "霎时天气变得快， 大雪鹅毛洒下来。 荒郊俱被雪来盖， 处处楼阁似银台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹福冻颤。曹玉莲坐。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小姐为何又不行走？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "身上寒冷，难以行走。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "小姑娘啼哭坐道边， 点点珠泪洒胸前。 难道你冷我不冷， 哪个多穿几件棉？ 不辞小姐走了罢！"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "曹玉姐上前忙遮拦。 你要走你把奴来带， 老哥哥！"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "小姑娘只哭的我心痛酸。 无奈何脱下了衣一件，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹福脱衣与曹玉莲穿。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "我与小姑娘来遮寒。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "难道我冷你不冷， 老哥哥就是铁打的人。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "男儿头上有三把火，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹福掷帽。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "我比你小姑娘胜强十分。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "此一去到大同将奴送下， 那时节管教你受享荣华。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "送姑娘到大同与公子配下， 我不过吃一碗闲饭闲茶。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "老哥哥百年后身归泉下， 曹玉姐愿与你带孝披麻。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "我死后四块板将我埋下， 胜似你与老奴带孝披麻。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "你救我活命还恩比天大， 你与我生身父半点不差。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "小姑娘说的是一派疯话， 说什么生身父半点不差。 奴欺主就应该千刀万剐， 怕的是五阎君差鬼来拿。 搀扶小姐走了罢，"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "见一座独木桥把我吓煞！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小姐，前面有一独木小桥，待老奴将小桥垫稳，搀扶你过去！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "要小心了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹福垫桥、过桥。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "过小桥不由人心中害怕， 树枝儿刮乱了青丝头发。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "似这样寒冷天难以招架， 四下里风不顺飘落雪花。"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "老哥哥行走不方便， 怕的是老性命不能保全。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "你说我行走不方便， 紧走几步小姐观。 三步当作两步走， 两步当作一步颠。 正走中间抬头看， 不觉来在广花山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹福僵尸。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "曹福醒来！"
        },
        {
          "character": "曹福",
          "type": "西皮导板",
          "text": "耳边厢又听得有人呼唤！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "曹福！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "啊，小姐呀！"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "尊一声小姑娘细听我言： 实指望保小姐脱离此难； 又谁知行至在中途路上不能周全。 但愿得早到那大同地面， 似这等数九寒天大雪纷飞闪得你真是可怜。 我的小姑娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金母、八仙同上。"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "说话之间彩云现， 猛抬头又只见八洞神仙。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "无有啊！"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "汉钟离手摇着阴阳宝扇， 吕洞宾二龙剑背在后肩， 李铁拐手拿着月牙大铲， 张果老捧渔鼓驴上摇肩， 曹国舅手拿着阴阳二板， 蓝采和抱横笛站在云端， 何仙姑执莲花可喜可羡， 韩湘子在一旁手提花篮， 王母娘娘在莲台坐， 左金童右玉女手持宝旛。 东南角上观一眼，"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "来了甚么？"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "又来了白发苍苍一老仙。 手拿鲜花哈哈笑， 他笑我曹福不周全。 他也笑来我也笑，"
        },
        {
          "character": "曹福",
          "type": "三笑",
          "text": "哈哈，哈哈，啊，哈哈……"
        },
        {
          "character": "曹福",
          "type": "唱",
          "text": "一霎时无常到命赴阴间。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上，抓曹福衣。曹玉莲下。虎行扔衣下。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "将他唤醒！"
        },
        {
          "character": "八仙",
          "type": "同白",
          "text": "曹福醒来！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "参见圣母。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "念其是一义仆，封你南天门都土地。 众位大仙，送他归位去者！"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "圣寿无疆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金母、八仙、曹福同下。〖牌子〗。虎行引曹玉莲同上。虎行下。八仙引曹福同上，同过南天门。"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "小姐，此处离大同不远，自有人前来接你。老奴不能远送了。 且住。想我曹福身登仙界，乃是一桩喜事，须要大笑三声。"
        },
        {
          "character": "曹福",
          "type": "三笑",
          "text": "哈哈，哈哈，啊……"
        },
        {
          "character": "曹福",
          "type": "白",
          "text": "哎，小姐啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹福下。四家将同上。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "你我迎接小姐，大雪漫天，走到哪里是一站！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹玉莲哭。"
        },
        {
          "character": "四家将",
          "type": "白",
          "text": "哪里有人哭？这边有一女子。 啊，那一女子是人哪，是鬼？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "列位容禀！"
        },
        {
          "character": "曹玉莲",
          "type": "唱",
          "text": "未曾开言泪涟涟， 尊声列位听我言： 我父本是曹天官， 被贼陷害丧黄泉。 我与曹福来逃难， 天寒冻死广花山。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "原来是小姐。我们这里见礼了！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "罢了。你们是哪里来的？"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "我们是大同来的，迎接小姐上任。曹福哪里去了？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "曹福冻死雪地。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "可惜一个义仆，冻死雪地。我们刨个坑，把他埋了吧。这边有一棵树，题首诗、 留个记号。"
        },
        {
          "character": "家将甲",
          "type": "念",
          "text": "曹福死的苦，"
        },
        {
          "character": "家将乙",
          "type": "念",
          "text": "冻死广花府。"
        },
        {
          "character": "家将丙",
          "type": "念",
          "text": "明年春三月，"
        },
        {
          "character": "家将丁",
          "type": "念",
          "text": "搬尸转故土。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "得了，请小姐趱路吧！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "身上寒冷，难以行走。"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "穿我的。"
        },
        {
          "character": "家将乙",
          "type": "白",
          "text": "得了，你们年轻的，没有我这老头禁冻，穿我的吧。"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "小姐趱路啊！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "两足疼痛难以行走。"
        },
        {
          "character": "三家将",
          "type": "同白",
          "text": "骑我的马。"
        },
        {
          "character": "家将乙",
          "type": "白",
          "text": "等等儿吧，一不作二不休，衣衫穿了我的，马也骑我的就结了。请小姐上马。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "带马！曹福，掌家，喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}