{
  "script_id": "03009002",
  "title": "耒阳县",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "庞统",
      "hangdang": "净"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "庞统为当世奇才，鲁肃荐之于吴侯孙权。孙权见其貌陋，不加礼遇。鲁肃再为修书荐于刘备，刘备委充耒阳\n县爷。庞统到任，终日醉卧，积案不理。张飞怒来责问，庞统乃升堂理事；不到半日，积案审清。张飞惊服，\n回报刘备。刘备面谢轻慢之罪，庞统始取出荐书，刘备益加敬重而以中郎将任之。",
  "notes": "《耒阳县》故事源出《三国演义》。\n这个剧本经苏连汉先生协助校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "引子",
          "text": "三国争汉鼎，何日定太平。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "下官鲁肃。吴侯驾前为臣，官拜水军都督之职。只因公瑾弃世，吴侯思慕贤良， 待吴侯升殿，不免将庞统荐上，若得重用，东吴之幸也。看香烟缭绕，吴侯 临朝来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引孙权同上。"
        },
        {
          "character": "孙权",
          "type": "引子",
          "text": "碧眼紫髯，怀宇宙，威镇江南。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "鲁肃见驾，吴侯千岁！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "胸怀韬略志谋远，碧眼紫须貌不凡。南面称孤承父业，声震刘、曹坐江南。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤，孙仲谋。承父兄基业，威镇江南九州八十一郡，国库丰盈。可叹公瑾弃世， 荆州未还。 此时缺少良才，子敬计将安出？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "臣荐一人，吴侯若能重用，东吴幸甚也。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "何人？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "前在曹营献连环计的庞士元。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "莫非是庞统乎？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "此人何在？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "现在馆驿。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "宣他上殿，孤面试其才。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "领旨。 下面听者：吴侯有旨，庞士元上殿。"
        },
        {
          "character": "庞统",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞统上。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "忽听得吴侯来召宣， 午门外来了我庞士元。 曾记得曹操带领兵百万， 势如山倒下江南。 东吴的文臣皆丧胆， 武将不敢跨雕鞍。 黄盖他把苦肉献， 我庞统暗地巧献连环。 诸葛亮祭东风在那七星台上面， 曹孟德一时间他中了我的巧机关。 在赤壁江中一场战， 冲锋破阵火烧战船。 只杀得曹瞒嚇破胆， 丢盔卸甲败回中原。 今日里鲁子敬把我举荐， 怕的是孙仲谋与我也无有缘。 大摇大摆我就上金殿， 山呼吴侯把驾参。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "臣庞统见驾，吴侯千岁！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "先生平身。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "谢吴侯！"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "奇容怪状真难看， 满脸五岳又朝天。 身体矮小皮骨贱， 怎在东吴为将贤。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "子敬道你才学高远，不知你平生治何经典？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "问答经典，乃腐儒所为耳。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "你与公瑾比论如何？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "用兵之道神鬼莫测，臣与公瑾大不相同。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、孙权同下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生请在馆驿，待某再见吴侯。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "大夫不必费心了。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "依先生若何？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "东吴非我立身之处；闻得曹操现在洛阳练兵，某有意授之。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生满腹才能投顺曹操，岂不是美玉投于淤泥之中矣！"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "依大夫之见如何？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "如今刘备新定荆楚，仁义过天，先生何不投之，前程也可进步。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "只怕与仲谋一样，岂非往返徒劳。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不妨。待我修书一封，必不怠慢。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "有劳大夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃修书。〖牌子〗。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生请看。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "有劳大夫！"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "大夫待某恩非浅， 修书荐某入桃园。 躬身施礼跨走战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二道童同上，带马，同下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "要相逢除非天赐缘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、庞统自两边分下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、二旗牌、张飞、孙乾、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "芦花荡内一场战， 周郎小儿丧黄泉。 先生过江未回转， 盼得孤穹两眼穿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二道童引庞统同上。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "勒住丝缰用目看， 特与皇叔来问安。"
        },
        {
          "character": "二道童",
          "type": "同白",
          "text": "门上有人么？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "你们哪里来的？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "通禀皇叔：庞士元有帖参拜。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "候着。 启奏主公：庞士元有帖参拜。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呈上来。 庞统字士元，道号凤雏。啊哈哈……当年司马徽言道，伏龙、凤雏得一可安天 下，莫非就是此人！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待小弟相迎先生。 先生在哪里？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "啊，将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞比相。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "哎！皇叔在上，贫道顿首。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请坐。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生光临，有何见教？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "闻得皇叔仁义过天，特来效力。未知皇叔可能留用否？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备初定荆楚，民心未定。离此百里有一耒阳县，请先生权充县事，日后有功升 迁。未知可能屈驾否？"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "辞别皇叔跨走战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二道童带马，同下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "将计就计把身安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞统下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥，弟观庞统，面貌丑陋，身体矮小，必无韬略。大哥不审明白，放他耒阳 县宰；倘有差错，岂不是祸国殃民！待小弟将他赶回，另派别人才是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟不可性急，愚兄自有道理。 孙乾过来！"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "命你暗地打探庞统行事如何。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "事虽如此，小弟放心不下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待等诸葛先生回来自有定夺。退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二班头、书吏捧印同上。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "众位请了。"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "新官到任，一同出城迎接去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "庞统",
          "type": "内西皮导板",
          "text": "时运不济招人怨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二道童引庞统骑马同上。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "庞凤雏坐马上心怨苍天。 可恨孙权瞎了眼， 他不该藐视我庞士元。 多蒙大夫将我荐， 不想孙权、刘备俱一般。 可笑刘备见识浅， 他命我耒阳为县官。 正行之间用目看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二班头、书吏同上。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "迎接太爷！"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "只见衙役与三班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下，同上，挖门。庞统接印，众百姓拿状同上。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "冤枉！"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "启太爷：众百姓告状。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "将状子一概收下。传话出去，过了百日前来听审。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞统下。"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "众百姓过了百日前来听审。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、二旗牌、张飞引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "凤雏初把孤穹见， 放他耒阳把民安。 孤命孙乾暗打探， 如何这时不见还！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾上。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "启奏主公：庞士元每日饮酒安睡，不理民词，衙内状纸堆积如山。主公速速定 夺！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥，我说庞统一派吹嘘，不能重用。待小弟将他抓来杀之，与民除害。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟不可造次，须要见机而行。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "知道了！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "妖道做事真大胆， 好久不理百姓冤。 怒气不息跨走战， 斩他首级谢民冤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孙乾快快赶上，教他忍耐为是。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "道童甲捧酒盘、道童乙捧酒壶引庞统同上。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "到任至今未审案， 终日酒醉乐安然。 童儿快把酒斟满， 多饮几杯可自闲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。旗牌、孙乾、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "白虎堂前下走战， 不见衙役与三班。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "衙役，衙役，衙役！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "班头上。"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "干什么鸡毛子喊叫的，待我看看。 可了不得啦，快快报与太爷知道。 太爷醒来！"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "时才梦睡将合眼， 耳旁听得有人言。 强睁二目来观看，"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "太爷不好啦！"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "你等慌张为哪般？"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "太爷大事不好啦！"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "三千岁到啦！"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "喔，张飞来了？"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "有什么大惊小怪的！今在哪里？"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "闪开！翼德张，你还了得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞统归正坐。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "怒气不息为着谁来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "是你来到荆襄寸功未见，我大哥放你耒阳县宰，你就该治国安民才是正理。谁 教你好酒贪杯，醉卧仙乡，不理民词，状积如山？想你这样误国殃民的匹夫， 留你何用！呸，我打死你王八日的！"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "三将军，主公教你不可造次。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你休管！"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "我道为了何事，原来为此。翼德你与我站班，我来审断你看看。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我原要你断我看。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "差役过来，吩咐三班衙役站班伺候！"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "太爷升堂啦！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "高声些，起鼓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四青袍、二差人同上。孙乾归上场门，张飞归下场门。庞统内坐。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "将原、被告一齐带上堂来！"
        },
        {
          "character": "班头",
          "type": "白",
          "text": "原、被告上堂回话！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同上。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "与老爷叩头。"
        },
        {
          "character": "庞统",
          "type": "白",
          "text": "你等站立两旁，听本县判断。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "三班衙役两边站，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哇呀！"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "张翼德在一旁怒发冲冠。 右手写来左手判， 连写带判再把状观。 头一状告的王清善， 欠我银子十两三。 此银借去一年限， 至今本利未归还。 本县与你来判断， 一月之内交银还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百姓甲下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "看罢头状我把二状看， 状告墙内误抛砖。 本县打他四十板， 管押一月放他还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百姓乙下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "看罢二状再把三状看， 停妻再娶理不端。 本县与你来判断， 先正后偏同归还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百姓丙下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "看罢三状我把四状看， 四状告的胡春山。 霸占田土招民怨， 无奈前来叩青天。 公堂打他二百板， 充军千里永不还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百姓丁下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "看罢四状余状不必看， 众位父老听我言： 非是本县不判断， 些小之事何足烦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "回头再把翼德唤， 你看我连写带判把状观，听我判断可断得周全？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好先生哪！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "他耳听口问连判断， 丝毫无差果非凡。 右手写来左手判， 他比那孔明还在先。 二次上堂把礼见，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生哪！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "尊声先生听我言： 俺张飞胸中见识浅， 望求先生海量宽。 躬身施礼跨走战。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同带马，同下。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "禀明大哥请你还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "站立大堂一声唤， 书吏进前听我言： 这颗印信你代管，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书吏接印。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "每日勤劳莫偷闲。 长随带过千里战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二道童带马，同下。"
        },
        {
          "character": "庞统",
          "type": "唱",
          "text": "此一去我必定官上加官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞统下。"
        }
      ]
    },
    {
