{
  "script_id": "03019004",
  "title": "取金陵",
  "alias": [
    "凤吉公主"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "凤吉公主",
      "hangdang": "武旦"
    },
    {
      "name": "徐达",
      "hangdang": "老生"
    },
    {
      "name": "赤福寿",
      "hangdang": "净"
    }
  ],
  "plot": "元末，朱元璋率红巾军反元，攻取金陵城。元驸马赤福寿与元将曹良臣镇守金陵。红巾元帅徐达用诱兵之计，\n陷曹良臣于重围，迫使投降。然赤福寿骁勇难制，时有游侠伍福，素与红巾群雄友善，闻两军相持不下，\n来助红军，于阵前迫赤福寿归降，赤福寿竟自刎。赤福寿妻凤吉公主领兵为夫报仇，力战红巾众将，后厮杀\n力尽自刎阵前。红巾军遂取金陵。",
  "notes": "《取金陵》故事出于《明英烈》。\n此本为阎岚秋（九阵风）先生生前演出本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "汤和、邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海同上，同起霸。〖点绛唇〗。"
        },
        {
          "character": "汤和、邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "汤和",
          "type": "白",
          "text": "汤和。"
        },
        {
          "character": "邓玉",
          "type": "白",
          "text": "邓玉。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "常遇春。"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "胡大海。"
        },
        {
          "character": "廖永忠",
          "type": "白",
          "text": "廖永忠。"
        },
        {
          "character": "俞通海",
          "type": "白",
          "text": "俞通海。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "郭英。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "沐英。"
        },
        {
          "character": "汤和",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "汤和",
          "type": "白",
          "text": "元帅意欲夺取金陵。元帅升帐，你我两厢伺候。请！"
        },
        {
          "character": "邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点。四文堂、四大刀手、李善长、徐达、朱元璋同上。"
        },
        {
          "character": "朱元璋",
          "type": "引子",
          "text": "旭日当空，乘云车，驾驭六龙。"
        },
        {
          "character": "汤和、邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海",
          "type": "同白",
          "text": "参见主公！"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "汤和、邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海",
          "type": "同白",
          "text": "谢主公！"
        },
        {
          "character": "朱元璋",
          "type": "念",
          "text": "仪宇初开展洪蒙，光华并丽万国同。"
        },
        {
          "character": "李善长",
          "type": "念",
          "text": "大地山河开锦绣，"
        },
        {
          "character": "徐达",
          "type": "念",
          "text": "指日尧纪宇宙中。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "孤、朱元璋。"
        },
        {
          "character": "李善长",
          "type": "白",
          "text": "山人、李善长。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "本帅、徐达。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "自汴梁起义以来，得娘舅郭广卿之权，占得疆士。只是建都之地，不能得破。 先生、元帅何计破之？"
        },
        {
          "character": "李善长",
          "type": "白",
          "text": "启奏主公：臣昨晚仰观天象，见元主当灭，我主当兴。就该率众过江，夺取金 陵，方为上策。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "孤想金陵乃是赤福寿、曹良臣把守，此二人万夫难敌，只怕难以得破。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "臣想金陵乃建都之地，东西南北，四路相通，虎踞之所。若得金陵，实为上策。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "全仗元帅虎威，先生妙算。怎样安排他们？"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "臣自有安排。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "但不知几日发兵？"
        },
        {
          "character": "李善长",
          "type": "白",
          "text": "今乃黄道吉日，正好兴兵。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "请元帅传令！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "臣领旨。 众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "兵发金陵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "探子",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "日间藏草内，黑夜走荒郊。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "我探子是也。奉了都督将令，打探敌情。今有徐达统领大兵，夺取金陵。不免 报与都督知道便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、中军引曹良臣、赤福寿同上。"
        },
        {
          "character": "赤福寿",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，威风好，地动山摇，要把红巾扫！"
        },
        {
          "character": "赤福寿",
          "type": "念",
          "text": "杀气连天透九霄，气吐虹霓万丈高。"
        },
        {
          "character": "曹良臣",
          "type": "念",
          "text": "威镇金陵谁敢犯，丹心一片保皇朝。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "某、大都督赤福寿。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "本帅、曹良臣。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "顺帝驾前为臣。奉旨镇守金陵一带等处。今有红巾贼党，前来夺取金陵。俺也 曾命探马前去打探，未见回报。"
        },
        {
          "character": "探子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "都督在上，探子叩头。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "打探哪路军情，一一讲来！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "都督容禀："
        },
        {
          "character": "探子",
          "type": "念",
          "text": "小人奉将令，昼夜不消停。红巾领人马，要夺金陵城。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "那贼兵势如何？"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "好不威严也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "赏你银牌一面，再去打探！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "曹将军，有何妙计？"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "今有红巾贼寇，兴兵前来。自古道：兵行千里，不战自倦。今晚末将带兵前去 偷营，都督大兵随后接应，哪怕大功不成！"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "命你带领人马，攻打头阵，本督大兵随后。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "都督传令一声吼， 扫灭红巾统貔貅。 三军带马出帐口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同下。"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "不灭红巾不回头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹良臣下。"
        },
        {
          "character": "赤福寿",
          "type": "唱",
          "text": "良臣可算擎天手， 侠义英雄美名留。 三军与爷退帐口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同下。"
        },
        {
          "character": "赤福寿",
          "type": "唱",
          "text": "请出公主定良谋。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请公主！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。二丫鬟、凤吉公主同上。"
        },
        {
          "character": "凤吉公主",
          "type": "唱",
          "text": "环佩声响出兰房， 夫受爵禄镇朝纲。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "公主！"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "可恼哇可恼！"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "驸马退帐，因何这等烦恼？"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "今有红巾贼党前来夺取金陵，你道恼是不恼？"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "驸马不必烦恼，就该发动人马出城抵挡才是。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "本督出城，恐怕城池无人照管。"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "驸马只管领兵出战，待为妻巡查城池，料然无事。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "全仗公主。"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "赤福寿",
          "type": "念",
          "text": "扫灭红巾清宇宙，"
        },
        {
          "character": "凤吉公主",
          "type": "念",
          "text": "斩将擘旗子为功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赤福寿、凤吉公主、二丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四文堂、四大刀手、汤和、邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海、李善长、徐达、朱元"
        },
        {
          "character": null,
          "type": "text",
          "text": "璋同上。）"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "汤和、邓玉、常遇春、胡大海、廖永忠、郭英、沐英、俞通海",
          "type": "同白",
          "text": "来此金陵。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "元帅传孤将令，吩咐众将，择一平阳之地，安营下寨。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "我兵至此，不见敌人，其中必有埋伏。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "全仗元帅调遣。就请发令！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "领旨。 汤和、邓玉听命！"
        },
        {
          "character": "汤和、邓玉",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你二人埋伏前营左方，闻得号令之声，一齐冲杀不得有误！"
        },
        {
          "character": "汤和、邓玉",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "常遇春、胡大海听命！"
        },
        {
          "character": "常遇春、胡大海",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你二人埋伏后营右方，闻得号炮之声，一齐冲杀不得有误！"
        },
        {
          "character": "常遇春、胡大海",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "廖永忠、俞通海、郭英、沐英听令！"
        },
        {
          "character": "廖永忠、俞通海、郭英、沐英",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你四人埋伏左右营，敌人到此、一齐冲杀不得有误！"
        },
        {
          "character": "廖永忠、俞通海、郭英、沐英",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "此地命老军四十名。立空营二座，只许败，不许胜，以为诱兵之计。大队人马 去往红罗山去者！ （朱元璋、徐达、李善长、四文堂、四大刀手同下，汤和、邓玉、常遇春、胡大海、廖永忠、郭英、沐英、 俞通海自两边边分下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "曹良臣",
          "type": "内唱",
          "text": "旌旗招展绕星斗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手引曹良臣同上。"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "金枪一举鬼神愁。 三军催马朝前走， 只见前面一营头。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "来至贼营。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "随爷杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹良臣冲。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "空营一座！"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "只望偷营功立就， 谁知中贼巧计谋。 三军随某绕营走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤和、邓玉同上。"
        },
        {
          "character": "汤和、邓玉",
          "type": "同唱",
          "text": "快快下马把降投。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤和、邓玉、曹良臣同打。汤和、邓玉同败下，曹良臣追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、赤福寿同上，连场，赤福寿耍下场下。四上手、曹良臣同上。"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "适才遇见红巾寇， 不由怒火起心头。 三军催马踹营走， 因何又有一营头？"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "又是一营。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "随爷杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同杀。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "又是空营。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "今晚只望擒贼首， 连踹两个空营头。 三军与爷寻路走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春、胡大海同上。"
        },
        {
          "character": "常遇春、胡大海",
          "type": "同唱",
          "text": "归降我主美名留。 （常遇春、胡大海、曹良臣同打。常遇春、胡大海同败下。廖永忠，俞通海、郭英、沐英同上，开打。廖永 忠，俞通海、郭英、沐英同败下。曹良臣追下。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "徐达",
          "type": "内唱",
          "text": "奉天承运立地基，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、徐达同上。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "常随御驾扫东西。 我主洪福掌社稷， 夺取金陵保华夷。 三军与爷战鼓起， 收伏良臣掌兵机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "俞通海、曹良臣双冲上，漫头。接廖永忠、郭英、沐英。"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "四面俱是红巾寇，"
        },
        {
          "character": "俞通海、廖永忠、郭英、沐英",
          "type": "同白",
          "text": "归降！"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "口口声声叫我投。 左撞右挡无路走——"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "俞通海、廖永忠、郭英、沐英",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "勒马停蹄战鼓收。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "曹将军！"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "我主当兴，你主当灭。听本帅相劝，归顺我主，不失封侯之位。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "答话者何人？"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "本帅徐达。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "唔呼呀！闻得徐达用兵如神，此乃是天教俺归降也！"
        },
        {
          "character": "曹良臣",
          "type": "唱",
          "text": "闻得徐达智谋有， 提兵调将似武侯。 甩蹬离鞍下走兽， 含羞带愧把他投。"
        },
        {
          "character": "俞通海、廖永忠、郭英、沐英",
          "type": "同白",
          "text": "曹将军归降！"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "众将搀起擎天手， 躬身施礼恐不周。 将军英名如山斗， 不封王位定封侯。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "归降来迟，死罪呀死罪！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "弃暗投明，何罪之有？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "何处人马？"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "赤福寿的人马，元帅要提防一二。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "无能之辈。 众将官！"
        },
        {
          "character": "俞通海、廖永忠、郭英、沐英",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "迎上前去！ （徐达、曹良臣、四文堂、俞通海、廖永忠、沐英、徐达同下。留常遇春，赤福寿上。汤和、邓玉，沐英同 上，同开打，常遇春、汤和、邓玉、沐英同败下，赤福寿耍下场下。）"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": "凤吉公主",
          "type": "内唱",
          "text": "古今来英雄女多少脂粉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵引凤吉公主同上。"
        },
        {
          "character": "凤吉公主",
          "type": "唱",
          "text": "巾帼中效丈夫能有几人？ 我今日领女兵巡查要紧， 怕的是贼人马暗地入城。"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "我、凤吉公主，夫君领兵出战，因此亲领女兵，巡查城池。 众女兵！"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "凤台门去者！"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "凤吉公主",
          "type": "唱",
          "text": "但愿得灭贼党干戈宁靖， 也免得众黎民颠沛飘零。 众女兵前引路凤台门进， 卷旌旗掩灯火休要高声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂引朱元璋同上。"
        },
        {
          "character": "朱元璋",
          "type": "唱",
          "text": "窥金陵昼夜间坐卧不定， 因此上为王的亲观其形。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "妙哇！"
        },
        {
          "character": "朱元璋",
          "type": "念",
          "text": "来在金陵城，云雾照山岭。两旁垂杨柳，亚似锦锈春。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "好一座城池也！"
        },
        {
          "character": "朱元璋",
          "type": "唱",
          "text": "似龙蟠如虎踞金汤牢稳， 得胜地多王气南面为君。"
        },
        {
          "character": "女兵甲",
          "type": "白",
          "text": "奸细窥探！"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "弓箭伺候！"
        },
        {
          "character": "凤吉公主",
          "type": "唱",
          "text": "一定是贼营中奸细探信， 一支箭放下去叫他命倾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "凤吉公主放箭。四红文堂、朱元璋同下。"
        },
        {
          "character": "女兵甲",
          "type": "白",
          "text": "奸细带箭而逃！"
        },
        {
          "character": "凤吉公主",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "凤吉公主",
          "type": "唱",
          "text": "见贼人带箭逃料无活命， 准备下滚木石筑下窝棚。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍福上。"
        },
        {
          "character": "伍福",
          "type": "唱",
          "text": "任侠好义江湖走， 袖箭一出神鬼愁。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "俺、合肥伍福。只因我在武科场与众家兄弟离别数载，闻听新主朱元璋创基立 业，应天顺人，如今夺取金陵。赤福寿拥有大兵。朱元璋不敢前进。为此，星 夜而来，劝那赤福寿归降，以安社稷。看前面已是大营，就此催马！"
        },
        {
          "character": "伍福",
          "type": "唱",
          "text": "下山师傅曾嘱咐， 大元其主依云州。 加鞭催马朝前走， 见了主公说从头。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "来此已是大营，门上哪位在？"
        },
        {
          "character": "常遇春",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春上。"
        },
        {
          "character": "常遇春",
          "type": "念",
          "text": "皂缨枪扫荡天下，乌骓马纵横中华。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "伍大哥！"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "你我哪里一别，直至如今？"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "武科场一别，直至如今。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "到此何事？"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "烦劳通禀，说俺伍福求见主公。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "候着。 有请主公！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达、朱元璋同上。"
        },
        {
          "character": "朱元璋",
          "type": "念",
          "text": "雄士夜宿同营伍，气概森严斗转移。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "合肥伍福求见。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "伍福来了，说孤有请！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "伍大哥请进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春下。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "草民伍福，参见主公！"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "将军少礼。见过元帅！"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "将军少礼。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "将军自武科场分别。时常怀念。今日相会，乃三生有幸也。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "草民有何德能，敢劳主公美言称赞！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "将军到此何事？"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "闻得主公创基立业，应天顺人，夺取金陵。赤福寿拥有大兵，我军不能前进。 为此星夜赶来，劝那赤福寿归降，以安社稷。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "赤福寿英勇非常，难以收伏。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "某今此去，量那赤福寿，难以逃脱。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "用些何物？"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "只用飞虎旗一对，管保成功。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "有劳将军！后营备宴，与将军接风。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "多谢主公！"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "朱元璋",
          "type": "念",
          "text": "知君怀抱英雄志，"
        },
        {
          "character": "伍福",
          "type": "念",
          "text": "扬风吼树像龙回。"
        },
        {
          "character": "朱元璋、伍福",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元璋、伍福、徐达同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": "赤福寿",
          "type": "内唱",
          "text": "战马不住连声吼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂引赤福寿同上。"
        },
        {
          "character": "赤福寿",
          "type": "唱",
          "text": "杀气腾腾神鬼愁。 三军列队出阵口， 红巾贼寇听从头： 盖世英雄赤福寿， 哪一个大胆敢出头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二飞虎旗同上，伍福暗上。"
        },
        {
          "character": "赤福寿",
          "type": "唱",
          "text": "飞虎旗在营门守， 不由某家心内忧。 此旗就是伍福有， 他若来时我命休！"
        },
        {
          "character": "伍福",
          "type": "唱",
          "text": "三军列开旗门抖，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍福上。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二飞虎旗同下。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "合肥伍福。哎呀……"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "贤弟请转！"
        },
        {
          "character": "伍福",
          "type": "唱",
          "text": "叙叙当年旧根由。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "伍大哥！恕小弟甲胄在身，不能全礼。请了！"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "啊，你我弟兄离别数载，今日相逢，就该下马才是。怎么还是这样跨马提刀， 想是要与俺见个高下？来来来！倒要试试你的手段。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "伍大哥息怒，待小弟下马。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "伍大哥，小弟这厢有礼！"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "愚兄还礼。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "伍大哥敢是与朱蛮助战来了？"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "非也。想你主大元顺帝，贪恋酒色，不理朝政；新主元璋创基立业，应天顺人， 夺取金陵，以为建都之所，为此星夜而来，在新主元璋面前夸下海口，来劝 贤弟归降，啊贤弟，你若归顺我主，不失封侯之位。请自三思！"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "伍大哥此言差矣！"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "何差？"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "有道是：天无二日，国无二主，俺只知大元顺帝，不知什么朱蛮。想俺多蒙顺 帝之恩，食王爵禄，当报君恩。粉身碎骨，理所当然。岂能背主投降？似这不 忠之言，你要谨慎哪谨慎。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "啊，听你之言，岂不辜负愚兄一片保主荐才之心么？"
        },
        {
          "character": "伍福",
          "type": "唱",
          "text": "昔日吴汉保刘秀， 换刀杀妻美名留。 若要归降卸甲胄， 日久必当封王侯。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赤福寿",
          "type": "唱",
          "text": "某家兴兵有数秋， 不想今日遇对头。 只恐金陵不能守， 再与大哥说从头。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "伍大哥，待小弟回去与公主商议，将金陵城池让与朱蛮就是。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "伍福",
          "type": "唱",
          "text": "你的诡计休出口， 要想回城错用谋。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "贤弟，你休弄诡计瞒哄于我。你这话只好瞒哄那三岁孩童。想那凤吉公主与你 乃是恩爱夫妻，你此番进城，对她言讲，焉能放你出城。若想归降，就在此地 卸甲脱袍；如若不然，愚兄就要动手了！"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "哇呀！"
        },
        {
          "character": "赤福寿",
          "type": "唱",
          "text": "伍福劝我卸甲胄， 恩爱夫妻难聚头。 眼望金陵三叩首，"
        },
        {
          "character": "赤福寿",
          "type": "哭头",
          "text": "公主哇！"
        },
        {
          "character": "赤福寿",
          "type": "唱",
          "text": "为主尽忠一命休。"
        },
        {
          "character": "赤福寿",
          "type": "白",
          "text": "伍大哥，那旁有人来了！"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赤福寿自刎，四红文堂同上，扶赤福寿同下。"
        },
        {
          "character": "伍福",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "伍福",
          "type": "唱",
          "text": "可叹英雄志不苟， 忠烈慷慨美名留。 元朝勇将实少有！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍福下。"
        }
      ]
