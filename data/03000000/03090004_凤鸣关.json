{
  "script_id": "03090004",
  "title": "凤鸣关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵云",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "诸葛亮领兵攻取凤鸣关。赵云请令，诸葛亮恐赵云年迈有失，不令出战，赵云坚决欲行，出兵后，果斩韩德\n父子五人落马。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、四白龙套、邓芝同上，同站门。诸葛亮上。〖点绛唇〗。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "天为阳来地为阴，九宫八卦腹内存。我今奉了幼主命，一战成功取凤鸣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人，诸葛亮。奉了幼主之命，夺取凤鸣。 邓芝听令！"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传令下去：命王平、廖化、阎晏、马忠以为四路总先锋。余下之将，随营调遣。 大队人马，兵发凤鸣！"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "得令。 下面听者！丞相有令：王平、廖化、阎晏、马忠以为四路总先锋。余下之将， 随营调遣。大队人马，兵发凤鸣！"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "且慢！"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "何人阻令？"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "赵云。"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "随令进帐！"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "黄公三略安天下，吕望六韬定乾坤。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "报，赵云告进！参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军少礼。请坐。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军无令进帐则甚？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "丞相今日登台点将，满营将官均有差遣。把俺赵云一字不提，是何道理？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想老将军年迈，又是先帝托孤的老臣。倘若阵前有失，山人担待不起！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "丞相！末将老只老头上发、颔下须，难道胸中的才略也老了不成？有道是："
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "虎老雄心在，年迈力刚强！"
        },
        {
          "character": "赵云",
          "type": "西皮二六板",
          "text": "丞相说话蔑视人， 细听俺赵云表一表功勋： 忆昔磐河来归顺， 杀退了袁绍救过了公孙。 长坂坡曾救幼主的命， 七进七出显奇能。 只杀得张郃无处奔， 卸甲丢盔败回了曹营。 大功劳一时说不尽， 小功劳我记也记不清。 丞相爷若是不肯信， 你在那功劳簿上查分明。 快与俺赵云一支令， 俺要学那黄忠取定军！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "老将军不必表功勋， 山人心中明如灯。 你今年已七十整， 怕你难学黄汉升！"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "丞相不与我先锋印， 兵发中原去不成！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "山人奉了幼主命， 哪个胆大阻令行！"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "丞相说话忒无情， 不如碰死在辕门。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮快板",
          "text": "一句话儿错出唇， 险些逼坏老将军。 邓芝看过先锋印， 双手付与老将军。 三千人马你带定， 鞍前马后你要小心。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "双手接过先锋印，"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "背转身来自思忖： 此去若是不得胜， 笑坏南阳诸葛孔明。 “机谋”二字心拿稳，"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上马。"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "凤鸣关前见机行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、赵云同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "邓芝听令！"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "邓芝近前听一令， 暗中保护老将军。"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "邓芝",
          "type": "西皮散板",
          "text": "帐中领了丞相命， 保护老将把功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓芝下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "满营三军俱差尽， 一战成功取凤鸣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "兵发凤鸣！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上，诸葛亮上车。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "赵云",
          "type": "内西皮导板",
          "text": "三国纷纷刀兵动，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套引赵云同上。"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "诸侯各自逞英雄。 曹操中原把权弄， 孙权霸业在江东。 我主爷，应运生， 要把群雄一扫空。 丞相道我老无用， 怎不叫人怒气冲。 三军与爷往前拥，"
        },
        {
          "character": "四白龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同下。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "此去一仗定成功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、魏延、马岱、张苞、关兴引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "前导为何不行？"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "来在沔阳界。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "启丞相：来此沔阳地界。我兄马超坟墓在此，末将要讨祭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫也有一祭。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "亡兄当受不起！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "一殿为臣，这有何妨！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "谢丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏延听令！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "打听魏邦何人挂帅，速报我知！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，祭礼伺候！"
        },
        {
          "character": "二红龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二红龙套同捧祭礼，众人同走圆场。诸葛亮、马岱同祭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将军哪！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "见坟台不见马将军， 怎不叫人痛在心！ 为国忠良丧了命，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将军哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "见了丞相说分明。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "启禀丞相：魏邦夏侯楙挂帅，韩德父子以为前部先锋。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军此去必然成功。 众将官！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、韩瑛、韩瑶、韩琼、韩琪、韩德同上。"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "某，韩德。赵云老儿兴兵前来，岂肯容他猖狂。 众儿郎！"
        },
        {
          "character": "韩瑛、韩瑶、韩琼、韩琪",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": "韩瑛、韩瑶、韩琼、韩琪",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、邓芝同上。"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "来将何名？"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "俺乃赵老将军麾下前部先锋，邓芝是也！"
        },
        {
          "character": "韩德",
          "type": "白",
          "text": "无名小辈。看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩德、邓芝同起打。邓芝败下，韩德追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、赵云同上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "老夫兴兵谁不怕？ 赫赫威名震天涯。 我命邓芝去出马， 等他回来问根芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓芝上。"
        },
        {
          "character": "邓芝",
          "type": "西皮摇板",
          "text": "来在营门下战马， 见了老将把话答。"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "参见将军！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "命你魏营把仗打， 快快从头说根芽。"
        },
        {
          "character": "邓芝",
          "type": "西皮摇板",
          "text": "韩德父子威名大， 要与老将动杀法！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "听一言来怒气发， 不由老夫咬钢牙。 人来带过枪和马， 去到战场将贼杀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、韩瑛、四白龙套、赵云自两边分上，会阵。赵云杀死韩瑛。邓芝上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "邓芝，你看我老也不老？"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "将军不老！"
        },
        {
          "character": "赵云",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "听罢言来呵呵笑， 丞相台前报功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、邓芝、四白龙套同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、韩瑶、四白龙套、赵云自两边分上，会阵。赵云杀死韩瑶。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "杀了一个又一个， 越来越勇越快活。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、四白龙套同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩琼上。"
        },
        {
          "character": "韩琼",
          "type": "西皮摇板",
          "text": "二位兄长把命丧， 不由豪杰怒满膛。 开弓便把雕翎放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上，接箭。韩琼下。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "老夫接箭不慌也不忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。韩琼上。"
        },
        {
          "character": "韩琼",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "韩琼",
          "type": "西皮摇板",
          "text": "赵云武艺果然强， 手接雕翎不慌忙。 二次开弓把箭放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩琼下。赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "接过雕翎第二条。 尔说尔的武艺好， 放箭哪有接箭高。 认扣填弦箭放了， （韩琼上，中箭，下。韩琪上，与赵云起打。韩琪败下，赵云追下。韩琪败上，赵云追上，同起打。赵云用 剑杀死韩琪。）"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "宝剑一举儿命丧， 无知匹夫敢逞强。 眼前若有诸葛亮， 管叫他含羞带愧脸无光。"
