{
  "script_id": "03007004",
  "title": "甘宁百骑劫魏营",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "甘宁",
      "hangdang": "武生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "孙权攻合肥，曹操率部驰援。孙权乘曹兵初到，欲先发制人。部将凌统与甘宁争功，凌统出战失败。甘宁请\n率壮士百骑夜袭曹营。孙权赐以牛酒；甘宁遍饷士卒，晓以大义，士气振奋。遂亲率进袭，大败曹兵。",
  "notes": "故事出于《三国演义》。\n这个剧本是杨小楼先生生前的演出本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张郃上，起霸。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "红日照缨盔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪上，起霸。"
        },
        {
          "character": "曹洪",
          "type": "念",
          "text": "英雄胆气横。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊上，起霸。"
        },
        {
          "character": "夏侯渊",
          "type": "念",
          "text": "久战疆场上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐晃上，起霸。"
        },
        {
          "character": "徐晃",
          "type": "念",
          "text": "塞外逞英雄。"
        },
        {
          "character": "张郃、曹洪、夏侯渊、徐晃",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张郃。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "曹洪。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "徐晃。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "曹洪、夏侯渊、徐晃",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "丞相升帐，两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四文堂、四大铠、四上手、刘晔引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "志满定乾坤，挟天子，执掌权衡，扫荡张鲁取阳平，率雄狮，奏凯回兵。"
        },
        {
          "character": "张郃、曹洪、夏侯渊、徐晃",
          "type": "同白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列公少礼！"
        },
        {
          "character": "张郃、曹洪、夏侯渊、徐晃",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "栉风沐雨已有年，扫荡群雄寰宇间。仗天威福遂人愿，转戈跃马整归鞭。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫、曹操。奉了圣上之命，统领雄兵，扫荡张鲁；日前夺了阳平关，且喜东 川已得。正是："
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "虽则驱鲁得重地，心患蛟龙起江南。"
        },
        {
          "character": "薛悌",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛悌上。"
        },
        {
          "character": "薛悌",
          "type": "念",
          "text": "心怀报国志，来见霸业人。"
        },
        {
          "character": "薛悌",
          "type": "白",
          "text": "报！薛悌告进！ 参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "罢了。闻听孙权兵抵宛城，直取合肥，张辽将军如何迎敌，速报我知。"
        },
        {
          "character": "薛悌",
          "type": "白",
          "text": "丞相容禀：只因孙权攻破宛城，朱光将军阵亡；张辽将军因失宛城，又恐合肥 有失，统兵死守。孙权带兵前来，被张辽将军一战，败往濡须口去了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哦！孙权夺了宛城，如今又败往濡须口么？"
        },
        {
          "character": "薛悌",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可惜朱光阵亡；老夫回朝，奏知天子，多请厚赠。"
        },
        {
          "character": "薛悌",
          "type": "白",
          "text": "闻知丞相取了东川，张将军差小将前来，请问可攻西川否？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫犹豫未决。 啊！先生有何妙计，怎样进兵？"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "启丞相：今蜀中稍变，已有防备；莫如撤兵去救合肥，以定江南。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生之言，正合吾意。 夏侯渊听令！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你镇守定军山隘口等处，不得违误！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "徐晃听令！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你镇守蒙头山口，不得有误！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "其馀将士，随定老夫，去救合肥。听吾号令！"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "中军宝帐把将委， 列位将军听指挥。 镇守汛地须防备， 忠心报国守军规。 统领雄兵救合肥， 要杀那东吴将片甲无归。 众家儿郎你们休违背， 灭东吴碧眼儿奏凯回归。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、刘晔、薛悌、张郃、曹洪领曹操同下。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "啊，徐将军！你我各守汛地，须要小心！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "言之有理。"
        },
        {
          "character": "夏侯渊、徐晃",
          "type": "同白",
          "text": "众儿郎！分兵把手去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同应，四上手领夏侯渊、徐晃同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四马夫、四龙套、李典、乐进引张辽同上。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "职任藩篱镇雄关，"
        },
        {
          "character": "李典、乐进",
          "type": "同念",
          "text": "未息干戈起凶蛮。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "李典、乐进",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "腹内藏经史，胸中隐甲兵。"
        },
        {
          "character": "李典",
          "type": "念",
          "text": "三千莽儿汉，"
        },
        {
          "character": "乐进",
          "type": "念",
          "text": "同镇合肥城。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "张辽。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "李典。"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "乐进。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "二位将军！我等奉命镇守合肥，不想朱光失去宛城；吴兵乘势攻打合肥。逍遥 津前一战，若非二位之勇力，我兵马焉能全胜也。"
        },
        {
          "character": "李典、乐进",
          "type": "同白",
          "text": "此乃将军虎威，末将等何能之有？只是失去宛城，朱光阵亡，我等如何去见丞 相？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "我想丞相宽洪大量，必不降罪。闻听丞相已得东川，曾命薛悌前去请教丞相收 服西川之事。待他回来，便之分晓。"
        },
        {
          "character": "李典、乐进",
          "type": "同白",
          "text": "将军所见不差。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "军士们！伺候了！"
        },
        {
          "character": "薛悌",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛悌上。"
        },
        {
          "character": "薛悌",
          "type": "念",
          "text": "云掩旌旗暗，风吹刁斗寒。"
        },
        {
          "character": "薛悌",
          "type": "白",
          "text": "末将参见。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "薛悌",
          "type": "白",
          "text": "启将军：丞相大兵，援救合肥已经到了。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相已到，吩咐摆队相迎！"
        },
        {
          "character": "李典、乐进、四龙套、四马夫、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四下手、四马夫、四龙套、李典、乐进引张辽同上。四文堂、四大铠、刘晔、薛悌、张郃、曹洪领曹操同"
        },
        {
          "character": null,
          "type": "text",
          "text": "上。）"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "末将等迎接丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大营伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四下手、四马夫、四龙套、李典、乐进、张辽、四文堂、四大铠、刘晔、薛悌、张郃、曹洪、曹操同上，"
        },
        {
          "character": null,
          "type": "text",
          "text": "同挖门归座。）"
        },
        {
          "character": "张辽、李典、乐进、薛悌",
          "type": "同白",
          "text": "末将等参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列公少礼！"
        },
        {
          "character": "张辽、李典、乐进、薛悌",
          "type": "同白",
          "text": "谢丞相！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相领兵远来，受尽风霜之苦！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "为国勤劳，此乃老夫分内之事。列公军威严整，使敌人不敢妄越雷池，老夫好 生钦佩。"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "皆赖丞相虎威！只是朱光阵亡，失去宛城，末将等请罪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、李典、乐进同跪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那孙权闻老夫兵入汉中，不得首尾相顾，他乘势而取，公等何罪之有！"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "谢丞相！闻听丞相已得东川，何不乘势夺取西蜀？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公等言得极是，岂不知既已得陇，又何必望蜀！老夫此来，援救合肥。今士卒 远途跋涉，暂且安营，探听吴兵消息，再作计较。军帐摆宴，与众将军同饮！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "甘宁上，起霸。"
        },
        {
          "character": "甘宁",
          "type": "念",
          "text": "吴郡甘兴霸，长江锦幔舟。酬君重知己，报友化仇雠。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "俺甘宁。随定主公，四路征战，屡建奇功。前者攻取宛城，众将奋勇，为国捐 躯。那凌统在逍遥津小师桥救主有功；因此某心怀壮志，要作一惊天动地之事， 教他见识见识。为此全身披挂，去至主公台前讨令。正是："
        },
        {
          "character": "甘宁",
          "type": "念",
          "text": "胸怀大志如沧海，要显甘宁虎将才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘宁下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、徐盛、董袭、程普、张昭引孙权同上。"
        },
        {
          "character": "孙权",
          "type": "西皮散板",
          "text": "逍遥津前摆战道， 张辽可算一英豪。 马跳桥头兵败了， 军回濡须重整袍。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤，姓孙名权，字仲谋。日前夺了宛城、直取合肥，被张辽一战，兵败濡须口； 多亏凌统相救，为此重整船只，以待水路进兵。也曾差人回朝搬取人马，一 去许久，未曾到来。 内侍！伺候了！"
        },
        {
          "character": "凌统",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "凌统上。"
        },
        {
          "character": "凌统",
          "type": "西皮摇板",
          "text": "曹操统领大兵到， 见了主公奏根苗。"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "凌统参见主公千岁！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "千千岁！启奏主公：适才探马报道，曹操自汉中统领大兵，救护合肥。请旨定 夺！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "啊，先生！那曹操领兵前来，先生妙计安在？"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "臣启主公：那曹操远路而来，兵将正在疲乏之际，我兵先挫其锐气，那曹操必 败矣！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "所见不差。不知何人敢当此任？"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "凌统愿往！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "将军愿去？只是救兵未到，不知要用多少兵将，前去破敌？"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "末将只用三千人马，可以破曹矣！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "好！就命你挑选精兵三千，前去破曹，不得违误！"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "甘宁",
          "type": "内白",
          "text": "且慢哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘宁上"
        },
        {
          "character": "甘宁",
          "type": "念",
