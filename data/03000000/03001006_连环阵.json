{
  "script_id": "03001006",
  "title": "连环阵",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "养由基",
      "hangdang": "武生"
    }
  ],
  "plot": "楚庄王兵迫晋国，晋成公派魏锜反攻，箭射楚庄王，楚军被阻。楚庄王召养由基来援，击杀魏锜。晋国荀林\n父会集郑、陈等四国援兵，布下连环阵，养由基率军冲破，生擒五将。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、公子侧、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "昨日两阵来厮杀， 魏锜韬略实可夸。 忽然提起雕翎发， 孤王险些丧黄沙。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤，楚庄王。与魏锜交战，不曾防备，被魏锜射了一箭，幸亏众将救孤进关。 晋兵昼夜攻城，孤王膀臂疼痛不止。想报这一箭之仇，奈无能将，真闷人也！"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "大王龙心暂安，待臣回朝搬养由基前来，不但报一箭之仇，管保一战成功。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "好，就命你星夜回朝搬养由基到来。听孤一令！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤在荥阳休记挂， 搬取良将救孤家。 星夜回朝莫迟压， 免得为王眼盼花。"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "大王且把愁放下， 披星戴月为邦家。 辞别大王忙带马， 不避山川走天涯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "为王兴兵洪福大， 并吞六国坐中华。 且把免战高悬挂， 待等良将保皇家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "养由基上。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "喜鹊门前叫喳喳， 昨晚府中报灯花； 未知吉凶念王驾， 闷坐府中自咨嗟。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "俺，养由基。只因大王亲征陈晋，命俺同苏大夫代理朝事；每日操演士卒，以 备捷报。今早忽然鹊噪，必有军情到来。俺且将军务训练一回，提防边邦起衅。 正是："
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "常将军务练，自有御敌时。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小军自两边暗分上。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "忆昔当年习弓马， 赤胆忠心保邦家。 功名事业非戏耍， 岂可轻浮戴乌纱。 庄王隆宠恩待咱， 秉理国政人尽夸。 晚来忽然灯花炸， 今早喜鹊闹喳喳。 看来必有圣旨下， 权坐内厅仔细察。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧上。"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "九重敕命来传话， 不远千里将相家。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "啊，将军！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "原来是公子侧将军，不辞千里，必有所为。请坐！"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "有座。末将同大王征伐陈、晋，已取荥阳关。那晋国魏锜，暗放一箭射中大王 左膊。如今免战高悬，特召将军同到荥阳救驾回朝。急速启行！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "哎呀，有这等事！ 军校，报知苏大夫说，大王有旨相召，我同公子侧将军往荥阳关救驾。朝中大 小兵将，按期操演，不可懈怠。带马！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "大王亲征心记挂， 我在朝内演兵法。 你我同把雕鞍跨，"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "岂顾山行路嵯岈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "魏锜武艺果然大， 射得孤王心胆麻。 虽将免战高悬挂， 盼望良将把贼拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧、养由基同上。"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "君王有难臣惊怕，"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "闻得凶信走天涯。"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "宝帐檐前参王驾，"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "救驾来迟请开发。"
        },
        {
          "character": "楚庄王",
          "type": "笑",
          "text": "啊，哈哈哈！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤自统兵相争杀， 犹如狂风打残花。 先蔑弟兄死马下， 撞遇魏锜作冤家。 一箭射来孤落马， 多亏众卿救孤家。 那贼围城兵势大， 须定良谋杀退他。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "大王啊！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "免战不必高悬挂， 些许卤夫不惧他。 且上城楼看臣杀， 抖擞精神动兵法。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "着啊！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "爱卿机谋无虚话， 兵书良策胜子牙。 路途劳顿歇鞍马，"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "来朝一战生擒拿。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "大王洪福比天大， 小小兵机何足夸。 多少英雄不惧怕，"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "魏锜可算井底蛙！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "三军后帐宴摆下， 君臣议论锦上花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "干牌子。四蓝文堂、四蓝大铠、赵旃、赵同、魏锜同上。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "某，晋国大司马魏锜是也。奉命抵敌楚兵，只杀得他君臣望风而逃。庄王被某 射了一箭，未知生死，他只是闭关不战。 众将官，尔等须要抖擞精神，夺转此关，方显男儿志气也！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "楚将出关骂战！"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "哎呀，楚兵被某杀得闭关不出，忽然前来骂战，必有诡诈。 众将官！尔等悄悄饱餐战饭，人不可卸甲，马不可离鞍；待他再来骂战，左右 抄队一拥而出，管教他片甲不回。各归队伍，听某吩咐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "养由基",
          "type": "内西皮导板",
          "text": "抖擞精神全披挂，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基上，起霸。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "杀气腾腾勇倍加。 跨马出关把阵踏，"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "魏锜拱手会某家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏锜冲上。"
        },
        {
          "character": "魏锜",
          "type": "唱",
          "text": "庄王兴兵有奸诈，"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "魏锜",
          "type": "唱",
          "text": "屡战不曾遇着他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏锜打。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "两军对垒，未会一面。通名受死！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "听者！某乃庄王驾前左车将军养由基是也。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "魏锜",
          "type": "唱",
          "text": "列国久已闻名大， 百步穿杨第一家。 某家几次把阵打， 向前且把大话夸。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "娃娃！"
        },
        {
          "character": "魏锜",
          "type": "唱",
          "text": "快快自把头刎下， 免得尸横万马踏。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "魏锜休要说大话， 狭路相逢遇冤家。 按住丝缰带回马！"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "无名之卒，去吧！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "你要来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基下。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "魏锜",
          "type": "唱",
          "text": "生死二字何惧他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏锜下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、公子侧、潘尪、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤被箭伤害了怕， 两膊疼痛难挣扎。 搬来由基今出马， 他的神箭也不差。 众军随孤站山漥， 帮助小将一鼓拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵旃、赵同同上。"
        },
        {
          "character": "赵旃",
          "type": "唱",
          "text": "司马威风果然大，"
        },
        {
          "character": "赵同",
          "type": "唱",
          "text": "指日奏凯回邦家。"
        },
        {
          "character": "赵旃",
          "type": "白",
          "text": "嗐！"
        },
        {
          "character": "赵旃",
          "type": "唱",
          "text": "由基声名也不假，"
        },
        {
          "character": "赵同",
          "type": "唱",
          "text": "你我性命送与他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧、潘尪同追上，杀赵旃、赵同同死下。楚庄王领四红文堂、公子侧、潘尪同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "养由基上。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "这厮惯会说大话， 不由豪杰活笑煞。 假意败走城关下，"
        },
        {
          "character": "魏锜",
          "type": "内白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏锜上。"
        },
        {
          "character": "魏锜",
          "type": "唱",
          "text": "擒你报功保晋家。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "娃娃，敢是怯战？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "非是俺怯战，闻听你箭法高强，俺今日要与你比试比试。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "娃娃，你我临阵交锋，一刀一枪，方算英雄。不许暗算。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "既然不许暗算，我主膀臂可是你射的？"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "你问的可是庄王吗？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "可惜呀，可惜！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "可惜什么？"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "可惜一箭未曾将他射死！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "一来我主洪福大，二来尔的武艺差。你既言道，不许暗算，身后为何有人放箭？"
        },
        {
          "character": "魏锜",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏锜转身。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基射死魏锜。四红文堂、公子侧、潘尪引楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哈哈哈，好将！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "这是魏锜老奸滑， 箭射孤王就是他。 将贼首级高杆挂， 晓谕各国畏怯咱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、晋成公同上。"
        },
        {
          "character": "晋成公",
          "type": "唱",
          "text": "楚、晋屡次争强弱， 一来一往动干戈。 荥阳境地已攻夺， 先氏兄弟丧山坡。 魏锜英勇多谋略， 未知出兵势如何？ 损兵折将孤王错， 闷坐宝帐自揣摩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "荀林父上。"
        },
        {
          "character": "荀林父",
          "type": "唱",
          "text": "适才闻报胆吓破， 我兵遭惨两泪落。"
        },
        {
          "character": "荀林父",
          "type": "白",
          "text": "荀林父见驾，大王千岁！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "荀林父",
          "type": "白",
          "text": "千千岁！"
        },
        {
