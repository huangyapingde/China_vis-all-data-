      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "代战公主",
      "hangdang": "旦"
    },
    {
      "name": "王允",
      "hangdang": "老生"
    },
    {
      "name": "苏龙",
      "hangdang": "老生"
    },
    {
      "name": "魏虎",
      "hangdang": "净"
    },
    {
      "name": "王夫人",
      "hangdang": "老旦"
    },
    {
      "name": "马达",
      "hangdang": "丑"
    },
    {
      "name": "江海",
      "hangdang": "丑"
    }
  ],
  "plot": "薛平贵得代战公主之助，攻破长安，拿下王允、魏虎，自立为帝。分封王宝钏、代战公主及苏龙。斩魏虎，\n欲杀王允。经王宝钏苦劝，始赦免。又迎请王母，共庆团圆。",
  "notes": "为全部《王宝钏》之第十三折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部\n均不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。\n本集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "龙凤阁内把衣换，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、马达、江海、薛平贵同上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "薛平贵也有今日天。 马达、江海把旨传， 你就说孤王驾坐在长安。 龙行虎步上金殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵坐。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "朝房内宣苏龙来把驾参。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "领旨。 苏龙上殿哪！"
        },
        {
          "character": "苏龙",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙上。"
        },
        {
          "character": "苏龙",
          "type": "西皮散板",
          "text": "撩袍端带上金殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙上殿。"
        },
        {
          "character": "苏龙",
          "type": "西皮散板",
          "text": "参王驾来问王安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙跪。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "孤王金殿把旨传， 加升三级在朝班。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙起。"
        },
        {
          "character": "苏龙",
          "type": "西皮散板",
          "text": "辞别万岁下金殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙下殿。"
        },
        {
          "character": "苏龙",
          "type": "西皮散板",
          "text": "加升三级在朝班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙下。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "忙将王允押上殿，"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同下，押王允同上。王允跪。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "王允当面！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "不由孤王怒冲冠。 先前定计将孤害， 今日也要报仇冤。 马达、江海推出斩， 斩他的人头挂高竿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同允，押王允同下。四宫女、王宝钏同跑上，站大边。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海内同允。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "听说万岁将父斩， 吓得宝钏心胆寒。 急急忙忙——"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "上金殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏跪。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "要斩我父为哪般？"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "先前定计将孤害， 仇报仇来冤报冤！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "我父犯罪律当斩， 我母待你恩如山。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "定斩不赦！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "万岁不赦我父转，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "不如碰死在金銮！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏碰头，二宫女同拦阻。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "御妻不必行短见， 午门赦回王相官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下殿。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "解下桩来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海内同允，押王允同上。"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "千层浪里翻身转， 百尺高竿得命还。 站在殿角用目看， 那旁站定王宝钏。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "唉，要叫娘娘千岁！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "她是我的女儿呀？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "金殿之上，不论亲戚。"
        },
        {
          "character": "王允",
          "type": "哭头",
          "text": "娘娘千岁，宝钏我的儿呀！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "好，又找补上啦！"
        },
        {
          "character": "王允",
          "type": "西皮散板",
          "text": "适才万岁将父斩， 何人救父活命还？"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "适才万岁将父斩， 女儿救父命回还。"
        },
        {
          "character": "王允",
          "type": "西皮散板",
          "text": "我儿救得父回转， 可算节孝两双全。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "讲什么节孝两双全？ 女儿言来听根源： 大姐许配苏元帅， 二姐许配魏左参。 唯有女儿命运苦， 彩球单打平贵男。 先前道他是花郎汉， 到如今端端正正、正正端端，驾坐在金銮。 来、来、来，随女儿上金殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允、王宝钏同上殿，王允跪。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "不斩我父还要封官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏坐。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "殿角赐你金交椅， 朝事齐毕再封官。"
        },
        {
          "character": "王允",
          "type": "西皮散板",
          "text": "万岁休把老臣怨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允起。"
        },
        {
          "character": "王允",
          "type": "西皮散板",
          "text": "俱是魏虎起祸端。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允下。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "忙将魏虎押上殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海同允，同下，押魏虎同上。魏虎跪。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "一见奸贼怒冲冠。 马达、江海将他斩！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "妾妃还要问一番。 内侍摆下金交椅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏坐小边。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "骂一声魏虎狗肺男。 先前怎样将我害， 一一从头说根源！"
        },
        {
          "character": "魏虎",
          "type": "西皮流水板",
          "text": "有魏虎，泪如梭， 娘娘千岁听我说： 你今若是饶了我， 从今吃素我念弥陀。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "马达、江海推出斩， 将他人头挂高竿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马达、江海押魏虎同下。王宝钏坐。马达、江海同上。"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "斩首已毕。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "马达、江海将旨传， 代战公主把驾参！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "领旨。 万岁有旨：代战公主上殿哪！"
        },
        {
          "character": "代战公主",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主上。"
        },
        {
          "character": "代战公主",
          "type": "西皮二六板",
          "text": "来在他国用目看， 他国我国不一般。 大摇大摆上金殿， 上面坐定女婵娟。 马达、江海一声唤！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "马达、江海！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "公主。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "万岁驾前，哪儿来这么一位眼光娘娘啊？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "那就是王宝钏，王娘娘。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "噢！她就是王宝钏，王娘娘啊？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "对啦。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "咱们娘儿们，得上去见个礼儿呀！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "得见个礼儿。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "见个礼儿吧！"
        },
        {
          "character": "代战公主",
          "type": "西皮流水板",
          "text": "上面坐的王宝钏。 走上前来——"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "把礼见，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西皮行弦。代战公主行礼。王宝钏离座抬胳臂。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "马达、江海呀！"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "公主。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "咱家给她见礼，她怎么要飞呀？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "不是要飞。咱们国行礼，是番邦大礼。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "他们国哪？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "他们国行礼，是麻绳上水——紧上加紧！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "那不成了捣碓儿了吗？"
        },
        {
          "character": "马达、江海",
          "type": "同白",
          "text": "不捣碓儿，不给月饼吃。"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "咱们娘儿仨捣捣碓儿吧！"
        },
        {
          "character": "代战公主",
          "type": "西皮流水板",
          "text": "他国我国不一般。 走向前来把礼见， 娘娘千岁！"
        },
        {
          "character": "代战公主",
          "type": "白",
          "text": "你们瞧着！"
        },
        {
          "character": "代战公主",
          "type": "西皮流水板",
          "text": "驾可安？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "代战公主跪，王宝钏离座。"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "王宝钏低头用目看， 代战女打扮似天仙。 怪不得儿夫他不回转， 被她缠恋一十八年。 宝钏若是男儿汉， 我也到她国住几年。 我本当不把礼来见， 她道我王氏宝钏礼不端。 走向前来用手搀，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏搀代战公主起。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "贤妹呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "尊一声贤妹听我言： 儿夫西凉你照看， 多蒙你照看他一十八年。"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "姐姐说话礼太谦， 小妹言来听根源： 说什么儿夫我照看， 可怜你受苦一十八年。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "姐妹双双上金殿，"
        },
        {
          "character": "王宝钏、代战公主",
          "type": "同西皮散板",
          "text": "参王驾来问王安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、代战公主同跪。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "孤王金殿用目看， 二梓童打扮似天仙。 宝钏封在昭阳院， 代战西宫掌兵权。 孤赐你二人龙凤剑， 三人同掌锦江山。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "叩头忙谢隆恩典，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、代战公主同起。"
        },
        {
          "character": "代战公主",
          "type": "西皮散板",
          "text": "你为正来咱为偏。"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "讲什么正来说什么偏， 姐妹二人俱一般。 二人同掌昭阳院，"
        },
        {
