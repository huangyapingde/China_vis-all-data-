{
  "script_id": "03059003",
  "title": "持轮战",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "卢俊义",
      "hangdang": "老生"
    },
    {
      "name": "宋江",
      "hangdang": "老生"
    }
  ],
  "plot": "宋江得卢俊义，攻打曾头市擒史文恭后，欲践晁盖遗言，推位让山于卢俊义。李逵等不服，宋江乃与卢俊义\n分头打东平、东昌二府，约以先胜者为寨首。卢俊义遇猛将张清，战不胜。值宋江得胜回，前往接应，张清\n飞石打众将，卢俊义持车轮大战，并力擒张清。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨雄、黄信同上，双起霸。"
        },
        {
          "character": "杨雄",
          "type": "念",
          "text": "封帅印英名震九州！"
        },
        {
          "character": "黄信",
          "type": "念",
          "text": "镇三山金枪威有。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关胜、呼延灼同上，双起霸。"
        },
        {
          "character": "关胜",
          "type": "念",
          "text": "凭刀法鬼哭神忧，"
        },
        {
          "character": "呼延灼",
          "type": "念",
          "text": "双鞭勇谁敢争斗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱仝、花荣同上，双起霸。"
        },
        {
          "character": "朱仝",
          "type": "念",
          "text": "美髯公屡显威风，"
        },
        {
          "character": "花荣",
          "type": "念",
          "text": "论神箭绝妙无穷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦明、徐宁同上，双起霸。"
        },
        {
          "character": "秦明",
          "type": "念",
          "text": "梁山泊豪杰聚众，"
        },
        {
          "character": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同念",
          "text": "似手足一母同生。"
        },
        {
          "character": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "杨雄",
          "type": "白",
          "text": "病关索杨雄。"
        },
        {
          "character": "黄信",
          "type": "白",
          "text": "镇三山黄信。"
        },
        {
          "character": "关胜",
          "type": "白",
          "text": "大刀关胜。"
        },
        {
          "character": "呼延灼",
          "type": "白",
          "text": "双鞭呼延灼。"
        },
        {
          "character": "朱仝",
          "type": "白",
          "text": "美髯公朱仝。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "小李广花荣。"
        },
        {
          "character": "秦明",
          "type": "白",
          "text": "霹雳火秦明。"
        },
        {
          "character": "徐宁",
          "type": "白",
          "text": "金枪手徐宁。"
        },
        {
          "character": "杨雄",
          "type": "白",
          "text": "众家哥弟请了！"
        },
        {
          "character": "黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "杨雄",
          "type": "白",
          "text": "前者，晁天王被史文恭一箭射死，大名府聘请“玉麒麟”上山，要报一箭之仇； 卢俊义、林冲统领众家哥弟前往曾头市捉拿史文恭。想林冲、俊义、文恭三 人同堂学艺，今番伤了幼年同堂之情，此事令人酸鼻。"
        },
        {
          "character": "黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同白",
          "text": "各为其主，说不得幼时同堂学艺之情。大哥排山，不知有何军情？"
        },
        {
          "character": "杨雄",
          "type": "白",
          "text": "我等两厢伺候！"
        },
        {
          "character": "黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "时迁、白胜、阮小二、阮小五、阮小七同上。"
        },
        {
          "character": "时迁、白胜、阮小二、阮小五、阮小七",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "白胜",
          "type": "白",
          "text": "白日鼠白胜。"
        },
        {
          "character": "时迁",
          "type": "白",
          "text": "鼓上蚤时迁。"
        },
        {
          "character": "阮小二",
          "type": "白",
          "text": "立地太岁阮小二。"
        },
        {
          "character": "阮小五",
          "type": "白",
          "text": "短命二郎阮小五。"
        },
        {
          "character": "阮小七",
          "type": "白",
          "text": "活阎罗阮小七。"
        },
        {
          "character": "白胜",
          "type": "白",
          "text": "诸位哥弟请了！卢员外擒住史文恭，命我五人报与宋大哥知道，就此前往。请！"
        },
        {
          "character": "时迁、阮小二、阮小五、阮小七",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大发点〗。杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁同上，排山，众人分站两边。"
        },
        {
          "character": "宋江",
          "type": "内西皮导板",
          "text": "忠义堂钟鼓响点兵聚将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙胜、吴用、宋江同上。"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "单单地不见了架海金梁。 可叹那晁天王中箭身丧， 齐奋勇擒文恭大报冤枉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙胜、吴用、宋江同归正座。"
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "曾头市前摆战场，可叹大哥一命亡。"
        },
        {
          "character": "吴用、公孙胜",
          "type": "同念",
          "text": "一箭之仇若不报，"
        },
        {
          "character": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同念",
          "text": "旗倒火焚忠义堂。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众家头领！"
        },
        {
          "character": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同白",
          "text": "大哥！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "只因晁天王被史文恭一箭射死，众家弟兄共起义愤，要报一箭之仇。卢俊义、 林冲带领燕青、李逵、武松、白胜、时迁、张顺、阮氏弟兄前去攻打曾头市， 要生擒史文恭，活祭晁大哥的灵堂。未知天意可遂人愿？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白胜、时迁、阮小二、阮小五、阮小七同上。"
        },
        {
          "character": "白胜、时迁、阮小二、阮小五、阮小七",
          "type": "同白",
          "text": "参见大哥！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "见过众家哥弟！"
        },
        {
          "character": "白胜、时迁、阮小二、阮小五、阮小七",
          "type": "同白",
          "text": "众家哥弟！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你五人回山，有何军情？"
        },
        {
          "character": "白胜、时迁、阮小二、阮小五、阮小七",
          "type": "同白",
          "text": "史文恭被擒，离山寨不远。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "好！众家哥弟，排队迎接卢员外去者！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "武松、林冲、张顺、燕青、李逵、史文恭同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "卢俊义",
          "type": "内西皮导板",
          "text": "堪叹英雄遭罗网，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八喽兵、八英雄、卢俊义同上。"
        },
        {
          "character": "卢俊义",
          "type": "唱",
          "text": "一世英名付汪洋。 箭射晁盖一命丧， 冤冤相报把命偿。"
        },
        {
          "character": "卢俊义",
          "type": "念",
          "text": "吾本富户一宦门，武艺超群韬略精。仗义疏财人钦敬，江湖人称玉麒麟。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "俺、卢俊义。奉宋江大哥之命，顺说史文恭。是俺苦口相劝于他，文恭执意不 听，如今被擒，量他性命难保。想俺与文恭同堂学艺，眼见他落此下场，唉， 回想幼年之时，与林冲、文恭练武习文，在一处玩耍，数年光景，只落得失义 绝交，思想起来，好不伤心也！"
        },
        {
          "character": "卢俊义",
          "type": "唱",
          "text": "卢俊义在中途自思自想， 习枪法学武艺三人同堂。 林冲弟为教头英名远望， 险些儿高俅贼害他身亡。 蒙柴进修书信又赠银两， 将林冲荐至在水泊山岗。 史文恭曾头市自把祸闯， 段景住连环马各逞豪强。 晁天王中雕翎一命身丧， 忠义堂众弟兄要报冤枉。 设巧计诱我降把水泊来上， 曾头市擒文恭贻笑万方。 说什么大丈夫义气为上， 讲什么丑名美名万载扬！ 心忙似箭我就加鞭抖丝缰， 自愧我大英雄无有主张！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁、公孙胜、吴用、宋江同上，同迎接，武松、林冲、"
        },
        {
          "character": null,
          "type": "text",
          "text": "张顺、燕青、李逵、卢俊义同上，过场，同下。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁、林冲、卢俊义、公孙胜、吴用、宋江同上。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "小弟奉令生擒史文恭，拜恳大哥谅情一二。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "是呀，望大哥天恩宽容。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同白",
          "text": "大哥，众家哥弟有言在先，不报一箭之仇，砍倒杏黄旗，火焚忠义堂。今日擒 来史文恭，仇人到山，就该将他绑至灵堂，剖腹剜心，祭奠晁天王。大哥此时， 这个、那个，是何道理？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卢俊义、林冲相对暗哭，叹气不语。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "好。打扫灵堂，大家祭奠晁天王。正是："
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "文恭做事理不当，"
        },
        {
          "character": "吴用、公孙胜",
          "type": "同念",
          "text": "不该箭射晁天王。"
        },
        {
          "character": "卢俊义、林冲",
          "type": "同念",
          "text": "各为其主难论讲，"
        },
        {
          "character": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁",
          "type": "同念",
          "text": "冤仇相报祭灵堂！ （杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁、公孙胜、吴用、宋江同下。卢俊义、林冲对哭， 同下。）"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二喽兵同上，同打扫灵堂。"
        },
        {
          "character": "二喽兵",
          "type": "同白",
          "text": "有请大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁、李逵、林冲、卢俊义、公孙胜、吴用、宋江同上。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "将史文恭绑上来！"
        },
        {
          "character": "二喽兵",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二喽兵绑史文恭同上。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "李逵听令！将史文恭剖腹剜心！"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "得令。走！ （二喽兵押史文恭同下，李逵随下。起鼓。卢俊义、林冲同哭，杨雄、黄信、关胜、呼延灼、朱仝、花荣、 秦明、徐宁同作出气。二喽兵、李逵托盘子同上，供灵牌前，杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦 明、徐宁、公孙胜、吴用、宋江同上祭。）"
        },
        {
          "character": "宋江",
          "type": "三叫头",
          "text": "晁天王！晁大哥！唉，大哥呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同哭。"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "见灵堂心酸痛悲声大振，"
        },
        {
          "character": "宋江",
          "type": "叫头",
          "text": "晁天王，唉，大哥呀！"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "盖世英雄赴幽冥。 擒仇人祭奠你报仇雪恨， 望大哥佑水泊大显威灵。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众家哥弟，连日辛苦，各自归寨，休息去吧！"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "传一令众弟兄各归各寨，"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同扯斜门。"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "今日里雪怨恨大快人心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八车夫、旗牌、李胜、张勇同上。"
        },
        {
          "character": "李胜、张勇",
          "type": "同白",
          "text": "俺、东昌府张将军麾下，中军官、（李胜）（张勇）。"
        },
        {
          "character": "李胜",
          "type": "白",
          "text": "奉了主帅之命，催运粮草。粮草催齐，回城交令。 呔，军士们，催军！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四喽兵、杨雄、黄信、关胜、呼延灼、朱仝、花荣、秦明、徐宁、林冲、李逵、武松、刘唐、鲁智深、公"
        },
        {
          "character": null,
          "type": "text",
          "text": "孙胜、吴用、宋江同上。）"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "擒文恭报箭仇已了心愿， 想起了晁天王临终遗言。 卢俊义智勇全韬略不浅， 与哥弟共商议推位让山。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众家哥弟！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "大哥！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "先前晁天王留有遗言：若有人捉得史文恭者，便为梁山水泊之主。今日卢员外 擒得仇人上山，祭献晁兄，报仇雪恨，正当为尊。来，有请卢员外！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有请卢员外！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卢俊义上。"
        },
        {
          "character": "卢俊义",
          "type": "念",
          "text": "同堂学艺情意丢，学了孙庞斗智谋。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "参见大哥，有何将令？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "员外请坐，有话叙谈。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "谢坐！大哥有何金言？当面赐教。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "晁天王留有遗言：有人捉得史文恭，当推为主。就请员外以为山寨首领。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "小弟德薄才疏，怎敢承当此位？若得居末，尚自过分。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "非宋某多谦，某有三件不如员外之处。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "愿闻哪三件？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "第一件，宋江身材黑矮，貌拙才疏；员外堂堂一表，凛凛一躯，有贵人之相。 第二件，宋江出身小吏，犯罪在逃，蒙众位兄弟不弃，暂居尊位；员外生于富 贵之家，素有豪杰之誉，又非众人所能得及。第三件，宋江文不能安邦，武不 能服众，双手无缚鸡之力，身无寸箭之功；员外力敌万人，通今博古，众人越 发无能得及。员外有如此才德，正当为山寨之主。宋江主张已定，休得推托。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "哎呀大哥呀，休再多谈。卢某宁死，实难从命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卢俊义跪。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "员外请起！"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "员外再三不从，还是大哥为尊，卢员外为次，人皆听服。兄长若是再三推让， 恐冷了众人之心。大哥不必再推了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴用使眼看众人。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "大哥，俺李逵在江州舍身拼命，跟将你来。众人都敬让你一步。你这样让来让 去，好不耐烦，我便杀将起来，各自散他娘的吧！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "大哥，想你手下许多军官，都是受过朝廷诰命，也只是敬让大哥为尊，今日如 何肯从别人？"
        },
        {
          "character": "刘唐",
          "type": "白",
          "text": "大哥，我们起初七个上山，那时便有让大哥为尊之意。今日却让后来之人，于 理不合。"
        },
        {
          "character": "鲁智深",
          "type": "白",
          "text": "众家哥弟，大哥若还推让别人，我们大伙各自散了吧！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "好啊，我们各自散了吧！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "且慢，众家哥弟休得如此，俺宋江有一拙见，且看看天意如何，方可定准。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "大哥请讲！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你等皆负晁天王遗言，不服卢员外为尊。如今山寨钱粮缺少，梁山泊东有两个 州府，却有钱粮。一处东平府，一处东昌府。我们自来不曾搅扰那里百姓，今 去向他借粮，定然不肯。如今写下两个阄帖，我和卢员外各拈一处。如先打破 城池者，便为梁山泊主，众位哥弟以为如何？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "我等皆服。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "文房、香案伺候！"
        },
        {
          "character": "喽兵甲",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "喽兵甲摆文房、香案。宋江写字条，焚香。众人各行礼，宋江、卢俊义各拿条对众人看条。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "东平府。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "东昌府。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "香案撤下！"
        },
        {
          "character": "喽兵甲",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "卢员外听令！"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "命你统领吴用、公孙胜、关胜、呼延灼、朱仝、雷横、索超、杨志、单廷圭、 魏定国、宣赞、郝思文、燕青、杨林、欧鹏、凌振、马麟、邓飞、施恩、樊瑞、 项充、李衮、时迁、白胜大小头领三十员，马步军兵一万；水军头领三员： 李俊、童威、童猛引水军驾船接应，攻取东昌府。"
        },
        {
          "character": "卢俊义",
          "type": "白",
          "text": "得令。带马！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卢俊义、吴用、公孙胜同下。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "林冲、花荣、刘唐、史进、徐宁、燕顺、吕方、郭盛、韩滔、彭玘、孔明、孔 亮、解珍、解宝、王英、扈三娘、张青、孙二娘、孙新、孙立、顾大嫂、石勇、 郁保四、王定六、段景住大小头领二十五员，马步军兵一万；水军头领三员： 阮小二、阮小五、阮小七领水军驾船接应，随我起兵前往东平府，带马！"
        },
        {
          "character": "众人",
          "type": "同白",
