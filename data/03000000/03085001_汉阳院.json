        {
          "character": "众百姓",
          "type": "同白",
          "text": "快快放我们进去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同啼哭。四龙套、文聘、蔡瑁、张允同上城楼。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "我主既降曹公，岂能容你进城？快快另投别处，免得后悔，去吧！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！我把你这卖国贼，想那刘琮与俺大哥乃是叔侄之情。快快开城！如若不然， 可知老张的厉害！"
        },
        {
          "character": "蔡瑁、张允",
          "type": "同白",
          "text": "众将官，放箭！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！ （四龙套同放箭。四龙套、四上手、众百姓、糜竺、糜芳、孙乾、简雍、赵云、张飞、甘夫人、糜夫人、二 车夫、刘备同下。四龙套、文聘、蔡瑁、张允同下。）"
        },
        {
          "character": "魏延",
          "type": "内白",
          "text": "军士们，快快开城！"
