        {
          "character": "四龙套",
          "type": "内同白",
          "text": "魏延造反！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "城门开。魏延急出，文聘追出。"
        },
        {
          "character": "文聘",
          "type": "白",
          "text": "魏延，无名小军，安敢造反？俺文聘来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延、文聘同起打，魏延败下，文聘追下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、众百姓、糜竺、糜芳、孙乾、简雍、赵云、张飞、甘夫人、糜夫人、二车夫、刘备同上。"
