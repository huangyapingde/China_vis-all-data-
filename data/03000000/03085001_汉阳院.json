{
  "script_id": "03085001",
  "title": "汉阳院",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "徐庶",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "刘备迁新野百姓于樊城，曹操欲举兵讨之；但为争取民心，先命徐庶说降。徐庶见刘备，尽陈曹操诡计，且\n与诸葛亮密议后事。刘备命关羽急往江夏，向刘琦求兵，自携百姓渡江逃难。及至刘琮处，因蔡瑁进谗，闭\n门不纳。刘备路过刘表坟墓，哭诉心事后，投奔江陵。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "执掌乾坤，破孙、刘，虎斗龙争。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "我本盖世一英雄，曾破黄巾立奇功。赏罚不能由献帝，汉室已在掌握中。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫、曹操。汉室为臣。自扫灭吕布，献帝见喜，封吾丞相之职。可恨桃园弟 兄，居住汉阳，实乃心腹大患，今又得诸葛辅助，如困龙得水，一日得志，不 可制也。我意欲填塞白河，令大军分作八路，一齐去取樊城。不免唤刘晔进帐 商议。 来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传刘晔进帐！"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "刘晔进帐！"
        },
        {
          "character": "刘晔",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘晔上。"
        },
        {
          "character": "刘晔",
          "type": "念",
          "text": "满腹藏经纶，幸遇知音人。"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "免礼。"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "唤某进帐，有何军情议论？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我想刘备实乃心腹大患，意欲分军八路，去取樊城，你看如何？"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "我想丞相初至襄阳，必须收取民心。今刘备尽迁新野百姓入于樊城，我兵径进， 两县将为齑粉矣。不如先使人招降刘备，备即不降，亦可见我爱民之心；若 其来降，则荆州之地不战而定也。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此言甚善。谁人可以为使？"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "徐庶与刘备甚厚，现在军中，何不命他一往！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "他去恐不复来。"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "他若不来，贻笑于人矣。丞相勿疑。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "既如此，就命他前去。速传徐庶进帐！"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "丞相有令，徐庶进帐！"
        },
        {
          "character": "徐庶",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "老母虽然丧泉下，心中难忘刘主恩。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生免礼。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢丞相！唤庶进帐，有何差遣？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可恨刘备火烧新野，将百姓迁入樊城。我本欲分兵八路，踏破樊城，奈怜众百 姓之命。公可往说刘备，若肯来降，免罪赐爵；若再执迷，军民共戮，玉石俱 焚。吾知公忠义，故使一往，愿勿相负！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操递书与徐庶。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "丞相吩咐，敢不效命，我就此去也！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "正好就此将刘报， 暗递消息放他逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "今遣说客汉阳道， 且候回音再作计较。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌引徐庶同上。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "心儿里恨曹操做事有错， 挟天子压诸侯行事太恶。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "山人、徐庶，字元直。昔日在刘皇叔驾前为臣，一旦辞刘归曹。曹操乃奸诈之 徒，设下“调虎离山”之计，要害桃园弟兄。想刘皇叔待我情同骨肉，尚未答 报。今奉曹操之命，一来下书；二来于皇叔送信，放他君臣逃走，脱离此难便 了！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "设下了牢笼计瞒哄诸葛， 汉阳院送信息教他逃脱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶、二旗牌同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、糜竺、糜芳、简雍、诸葛亮、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "心中悲痛叹刘表， 劣子无能降奸曹。 我兵微薄将又少， 不能讨逆扶汉朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾上。"
        },
        {
          "character": "孙乾",
          "type": "唱",
          "text": "适才军士来禀报， 元直到此事蹊跷。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "启禀主公；徐先生到。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哪个徐先生？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想必是徐元直到了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤可以见他么？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他前在主公帐下，焉有不见之理！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "如此快快有请！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且慢！他今到此，不是下书，定是说降。待山人退在屏风后面，听他讲些什么， 也好作一准备。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生且退！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人告退。正是："
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "九曲黄河深可测，唯有人心最难猜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有请徐先生！"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "有请徐先生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "明来下书信，暗中露真情。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣、徐庶见驾，主公千岁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请起。请坐！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "伯母驾安？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣母不幸，亡故曹营。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "山遥路远，未能吊祭伯母，实为抱歉！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣未来报丧，恕臣之罪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生驾临，有何见论？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣奉曹丞相之命，前来下书。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "下的何书？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "书信在此，主公请看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶呈书。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤王看书，无人奉陪先生。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣独坐一时，又待何妨！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤王有罪了！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "与卿分别有数载， 今日相逢天降来。 孤王看书你休怪， 一封书信亲手开。 上写曹操顿首拜， 大事当前好夺裁。 东吴孙权争地界， 约定赤壁把兵排。 曹、刘两家合一块， 得了江东四六开。 看罢书信疑难解， 有劳先生远路来。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公，书内是什么情由？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "曹、刘两家兵马合在一处，得了东吴，共分疆土。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公意下何如？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮暗上，咳嗽。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "何人咳嗽？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "乃是诸葛先生。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请来相见！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请先生进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮进门。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "徐先生在此，上前相见。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊师兄！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "恭喜主公，今得卧龙先生扶佐，如鱼得水，指日汉室可兴，真乃天下之幸也！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我得卧龙辅助，皆赖先生举荐之力也。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "此乃主公洪福。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "师兄不在曹营，到此有何见教？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "那曹操使徐庶前来招降主公，实乃假买民心，请主公裁处。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生既肯光临，有何良策，何妨教我，定当听从。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊师兄，不要忘了旧日之情，须替主公筹划良策，使我君臣转祸为福。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "那曹操言道，欲踏平樊城，因怜百姓之命，故此命庶前来说降使君。如肯来降， 免罪赐爵；再若执迷，军民共戮，玉石俱焚。今曹操兵分八路，填白河而进， 樊城恐不可守。宜速作行计，不可久停。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊师兄，你言曹操分兵八路，填白河而进。我兵虽寡，现有关、张、赵云，勇 冠三军，万夫难挡。前弟略施小计，火烧新野，杀得曹仁闻风丧胆，何惧曹操 八路分兵？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "你可知曹操现有多少人马？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "八十三万。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "得了荆襄九郡，又有多少人马？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二十八万。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "合在一处，共有多少人马？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "一百一十一万。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "好哇！你保主公，兵不满千人，将不足十员；那曹操人马遮天盖地而来，关、 张英勇，亦难御敌也。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "人生祸福实难料， 可叹奔波枉徒劳。 安居未稳曹兵到，"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "众百姓哪！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "怎忍弃民自奔逃！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公啊！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "与民休戚今古少，"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "仁德之主似唐尧。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公请退，臣弟兄二人自有料理。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "但凭先生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。诸葛亮背供。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人早已料定，我君臣有此大难，不料应在目前。有了，待我将计就计，在他 面前领教便了。 小弟有礼！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟施礼为何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "听师兄之言，我君臣大难将临，望兄指一条明路。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟，你上知天文，下通地理，胸藏韬略，难道还无有计策么？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "岂不知忙中无计。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "我这里有锦囊一封，你去看来！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔呼呀！未来之事，他早已安排。有了。 啊师兄，这锦囊上面，情由深奥，参测不透，还要在师兄面前领教。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟听了！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "弟兄们同坐汉阳营， 细看锦囊就里情。 汉业至今四百零，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我保刘主尚未得地，怎么就知四百有零？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "非也！自高祖斩蛇以来，相传至献帝，可有四百馀载？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不错！有四百馀载。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "却又来！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "建安登极属三雄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哪三雄？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "奸雄曹操，英雄孙权，枭雄刘——"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "噤声！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、徐庶同两望。"
        },
        {
          "character": "徐庶、诸葛亮",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "三国不和刀兵动， 荆襄王有子与无同。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "荆襄王现有二子，长子刘琦，次子刘琮，怎说无有？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "只因蔡后不贤，废长立幼，文武不服，百姓皆怨恨，他将荆襄九郡献与曹操。 曹操不仁，将他母子贬于青州，又差于禁在途中将他母子谋害，有子不能承受 父业，岂不是无子么？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "看起来，尽是丧家之犬也！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "走虎飞去龙逃奔，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这走虎逃龙是什么人？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "走虎就是关公。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他乃有名之将，倘若败阵，岂不失了二将军一世威名？还要避过此阵才好。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "江夏刘琦那里有二十五万铁甲雄兵，遣他前去借兵，以避此难。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这逃龙是谁？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "附耳上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶与诸葛亮耳语。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "记下了！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "长坂坡前救真龙。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "真龙敢是皇叔？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "非也。玄德不过创业之主，后出阿斗，有四十二年天下，那才是你的真主。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我定要保皇叔一统天下。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟不可扭天行事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "师兄啊！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "皇叔三顾把我请， 知遇之恩常挂心。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "自古天数早造定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "刀兵滚滚何日宁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，军务之事可曾说明？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "一一听从。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公，还是弃了百姓，速去为妙。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "数万百姓，从新野相随至此，不忍弃之。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "庶回复曹操之后，大兵即至。若不速去，悔之晚矣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "师兄放心，我主必然听从。师兄回至曹营，须要暗护我主，以表旧日之情。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "若遇机会，必然暗助。庶要告辞了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "依我之见，先生不要回去，就在此地同诸葛先生共扶孤王，必然稳如磐石矣。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "本当效犬马之劳，只是今若不还，惹人笑我。今老母已丧，抱恨终天，身虽在 彼，誓不为设一谋。公有卧龙辅佐，何愁大事不成？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生执意要去，亦不敢强留。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你我弟兄，日后哪里相逢？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "在南屏山相会便了！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "诸公速行方为妙， 曹兵到来恐难逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "徐庶不忘旧日好， 先生从速运奇谋。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "启主公：江夏大公子刘琦那里有二十五万铁甲雄兵，可命二千岁前去搬兵。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "家眷何人保护？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "家眷付与四将军保护，料无差错。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，二将军进帐！"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "二将军进帐！"
        },
        {
          "character": "关羽",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "山崩地裂乾坤乱， 遍起刀兵民难安。 丹心一点重扶汉， 何日才过太平年。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "参见大哥！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "免礼。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唤进帐来，有何军情议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生有差。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生有何差遣？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今曹操统领大兵八十三万，分八路而进，前来攻取。我军单薄，孤城难守。命 二将军去至江夏公子刘琦那里搬兵，不得有误！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关某前去搬兵，何人保护家眷？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有三将军、四将军保护，料然无事。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好！关某在哪里接驾？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "在汉津接驾。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好，某就此去也！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "辞别大哥跨走战， 去到江夏把兵搬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，请三将军、四将军进帐！"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "请三将军、四将军进帐！"
        },
        {
          "character": "张飞、赵云",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、赵云同上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "人似金刚马似龙，"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "文要精来武要通。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "同破黄巾威名振，"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "忠义常山赵子龙。"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "参见（大哥）（主公）！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "将我等唤进帐来，有何议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生有差。"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "先生有何差遣？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今曹操统领八十三万人马而来。此孤城难守，就命四将军保护主公家眷，须要 小心。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "末将受主公知遇之恩，保护家眷，万死不辞！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "赵云，你保护家眷，敢说无虑么？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "三将军，你好小量人也！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "常言忠义能尽命， 何惧曹贼百万兵？"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "你保家眷难凭信， 怕你能说不能行！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "翼德且莫闲争论， 赵云岂是空言人！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "启主公：可速弃城而走，先取江陵为家，不可迟误！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，奈百姓相随许久，安忍弃之而去？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公，既然难舍，何不遍告他们，有愿随行者同去；不愿随行者听便。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好，正合我意。 简雍，速速晓谕百姓，曹兵将至，孤城不能久守。百姓愿随行者，一同过江； 不愿随行者，听其自便。"
        },
        {
          "character": "简雍",
          "type": "白",
          "text": "遵命！ 众百姓听者：今曹兵将至，孤城难守。主公有令：愿随行者一同过江；不愿随 行者，听其自便！"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "我等虽死，愿随使君。"
        },
        {
          "character": "简雍",
          "type": "白",
          "text": "好，待我与你们转禀。 启主公：众百姓不惜性命，情愿相随。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好！叫他们各自收拾，听候起行。"
        },
        {
          "character": "简雍",
          "type": "白",
          "text": "遵命！ 众百姓听者：主公命你们各自收拾，听候启行！"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "哦！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣启主公：二将军去至江夏搬兵，臣恐大公子刘琦不能速速救应，必须臣亲身 一往，复催兵将，方不误事。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哪里是复催兵将，分明是你见曹兵势大，心中害怕，是与不是？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "自古“兵贵神速”，救应岂可迟误？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "刘琦感念先生昔日之教，就烦先生亲走一遭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人就此去也！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "主公速行莫迟延， 亮到江夏催救援。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请二位主母！"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "有请二位主母！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同上。"
        },
        {
          "character": "甘夫人",
          "type": "唱",
          "text": "日夜忧思心不定，"
        },
        {
          "character": "糜夫人",
          "type": "唱",
          "text": "曹操屡害我夫君。"
        },
        {
          "character": "甘夫人",
          "type": "唱",
          "text": "一县之主未坐稳，"
        },
        {
          "character": "糜夫人",
          "type": "唱",
          "text": "奔波何日得安宁！"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "唤我等出来何事？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "今有曹操兴兵前来，此城不能久守，故唤你们出来，一同逃走。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不必啼哭。看衣更换！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备换衣。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你督催百姓，一同赶路！"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾下。二车夫同暗上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "曹操大兵要临境， 孤城岂能久留存？ 急速渡江早逃奔——"
