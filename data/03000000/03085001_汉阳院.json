        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "刘备却还有意，怎奈孔明阻挠，不肯投降。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生后面歇息。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢丞相！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "刘备既不肯归降，必然弃城而走。待我传令点动大军，四处捉拿桃园弟兄便了！ 正是："
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "点动大军阻去路，谅他插翅也难逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四船夫引孙乾同上。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "俺、孙乾。奉了主公之命，预备船只，渡民过江，在此伺候。 （四龙套、四上手、众百姓、糜竺、糜芳、简雍、赵云、张飞、甘夫人、糜夫人、二车夫、刘备同上，依次 上船，众百姓同随后上船，只乘半数，众百姓同哭啼，糜竺、糜芳、简雍、甘夫人、糜夫人、刘备同哭泣。）"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "船已满载，百姓后来者不能渡了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同大哭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉！为我一人，使百姓遭此大难，我何生哉？不如投江一死，以报百姓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备欲投江，赵云截拦。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公若寻此短见，岂不使众百姓失望？保重身体，亦不失主公爱民之心也。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "是呀，千万保重才是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吩咐速速渡百姓们过江！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "速速过江！"
        },
        {
          "character": "四龙套、四上手、四船夫",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、魏延、文聘、蔡瑁、张允、刘琮同上。"
        },
        {
          "character": "刘琮",
          "type": "唱",
          "text": "天下荒荒刀兵动， 万般无奈降曹公。 刘备渡江余心恐， 怕他前来寻刘琮。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有刘备带领数万百姓，行至东门，请主公答话。"
        },
        {
          "character": "刘琮",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "刘琮",
          "type": "白",
          "text": "哎呀众位将军！刘备带领数万百姓，请我城楼答话。如何是好？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "主公不必为难，刘皇叔与先王俱是同宗弟兄，必须开城迎接，焉有据而不纳之 理？"
        },
        {
          "character": "文聘",
          "type": "白",
          "text": "魏延，你乃无名小辈，帐前议事，你敢多言！"
        },
        {
          "character": "蔡瑁、张允",
          "type": "同白",
          "text": "着哇！帐前议事，哪有你开口的地方？ 主公不必为难，既降曹公，若放刘备入城，被曹丞相闻之，定然加罪。不如紧 闭城门，遍插旌旗，他若攻城，乱箭射下，何愁刘备不走！"
        },
        {
          "character": "刘琮",
          "type": "白",
          "text": "此言甚善。照此行事便了！"
        },
        {
          "character": "蔡瑁、张允",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘琮下。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "众将官，城楼去者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、文聘、蔡瑁、张允同下。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "且住！想那刘皇叔乃仁德之主，今日到此，主公不念同宗之情，竟信卖国贼子 之言，拒而不纳。俺不免暗暗杀了守门将士，放下吊桥，教刘皇叔引兵入城， 共杀卖国之贼便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（场设城门。四龙套、四上手、众百姓、糜竺、糜芳、孙乾、简雍、赵云、张飞、甘夫人、糜夫人、二车夫、"
        },
        {
          "character": null,
          "type": "text",
          "text": "刘备同上。）"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来至城下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待我向前。 城上将官听者！烦劳转达刘琮贤侄，我今到此，欲救百姓之命，别无他意。可 快开城，休得疑虑！"
