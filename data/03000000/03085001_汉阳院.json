        {
          "character": "张飞、赵云、简雍、糜竺、糜芳",
          "type": "同白",
          "text": "江陵乃荆州要地，不如催趱百姓，先取江陵，乃为上策。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "如此正合我意。投奔江陵去者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
