{
  "script_id": "03021010",
  "title": "武家坡",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "老生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    }
  ],
  "plot": "薛平贵归家，遇王宝钏于武家坡前，夫妻相别十八年，王宝钏已不识薛平贵。薛平贵假问路以试其心，王宝\n钏逃回窑。薛平贵赶至，直告己名及别后经历，夫妻相认。",
  "notes": "为全部《王宝钏》之第十折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "一马离了西凉界，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上，扯四门。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "不由人一阵阵泪洒胸怀。 青是山绿是水花花世界， 薛平贵好一似孤雁归来。 老王允在朝中官居太宰， 他把我贫穷人哪放在心怀！ 恨魏虎起妒心将我谋害， 苦苦地要害我所为何来？ 柳林下拴战马——"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "武家坡外，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下马。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "见了那众大嫂细问开怀。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "列位大嫂请了！"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "请了！军爷敢是失迷路途么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "并非失迷路途。我乃找名问姓的。"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "王丞相之女，薛平贵之妻，王氏宝钏。"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "军爷来得不凑巧！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "怎么不凑巧？"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "适才在此剜菜。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "回转寒窑去了！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "烦劳大嫂，与我通报一声，就说有人与她带来万金家书，叫她前来接取。"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "请少站！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "啊王三姐！"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "做什么？"
        },
        {
          "character": "邻人",
          "type": "内白",
          "text": "有人与你带来万金家书，叫你前去接取。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "有劳了！"
        },
        {
          "character": "王宝钏",
          "type": "内西皮导板",
          "text": "多蒙邻居对我言，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢三眼板",
          "text": "武家坡又来了王氏宝钏。 站立在坡前用目看， 那一旁站定了一位军官。 假意儿在此间把菜剜， 他那里问一声我好回答一言。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "这大嫂传话——"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "太迟慢！ 武家坡等得我好不耐烦。 下得坡来用目看， 见一位大嫂把菜剜。 看前影看也看不见， 后影好似妻宝钏。 本当向前把妻唤，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵欲行又止。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "错认民妻礼不端。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂请了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "请了！军爷敢是失迷路途么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "阳关大道，哪有失迷路途之理？我乃找名问姓的。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "提起此人，大大有名！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "但不知是哪一家呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "王丞相之女，薛平贵之妻，王氏宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "噢！王宝钏？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷与她有亲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "非亲。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有故？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "非故。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "非亲非故，问她做甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂有所不知。我与她丈夫同军吃粮，托我带来万金家书，故而动问。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "王宝钏回转寒窑去了。军爷将书信交付与我，我与她带去就是。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我那薛大哥言道，书信要面交本人。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "若不见本人呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "原书带回！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷请少站。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀且住！想我儿夫离家一十八载，今日才有书信回来。本当上前接取，怎奈 这衣衫褴褛，这便怎么处？我自有道理。 啊军爷，我与你打个哑谜，你可晓得？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "略知一二。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这远？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "远在天边，不能相见。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这近？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "莫非你就是薛大嫂？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不敢，平贵之寒妻哟！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "来、来、来，重见一礼。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "方才见过礼了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有道是：“礼多人不怪呀！”"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "好个“礼多人不怪”。拿书信来呀！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "告便！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀且住！想我平贵，离家一十八载。今日夫妻相会，并不相认，这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵想。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我自有道理。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "洞宾曾把牡丹戏， 庄子先生三戏妻。 秋胡戏过罗氏女， 薛平贵调戏我自己妻。 弓插袋内——"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "把书取，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵取书信。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "我把大嫂的书信失。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "书信呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "失落了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "放在何处？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "弓插袋内。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "敢是不要紧的所在？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是要紧的所在。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "既是要紧的所在，因何失落了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一路之上，抽弓打雁。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "打雁做甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "打雁充饥。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "难道那雁儿吃了你的心肝不成？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊大嫂，一封书信，能值几何，为何开口伤人？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你岂不知：“为人谋而不忠乎？与朋友交而不信乎？”失落人家的书信，怎不 叫人心痛啊？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊大嫂，不必啼哭。那书信上的言语，我还记得几句。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此说来，我倒明白了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "明白何来？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "想我夫带来书信，内有安家银两。一路之上，被你花费。你道是与不是？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不是的。那日薛大哥修书之时，我在一旁打点行李，偷看了几句，故而记得。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此说来，你倒是个有心的人了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我若有心，还不失落你的书信呢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵调戏王宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "站远些！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "八月十五月光明，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了！军营之中，连个灯亮都无有么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "军营之中，哪有许多的灯火！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "全凭何物？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "皓月当空！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "薛大哥在月下修书文。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "我问他好来？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "他倒好。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "再问他安宁？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "倒也安宁。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "三餐茶饭？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "小军造。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "衣衫破了？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "自有人缝。 薛大哥这几年运不通， 他在那西凉国受了苦情。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了！受苦敢是挨了打了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是挨了打呀！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "但不知打了多少？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一捆四十。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "喂呀！我那苦命的夫哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂不必啼哭。这苦嘛，还在后头呢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵调戏王宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "站远些！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "军营中失了一骑马，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "是官马，还是私马？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "军营之中，哪里来的私马？自然是官马。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "官马岂不要他赔？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哪怕他不赔！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哪里来的银钱，与他赔马？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "自然有哇！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "为赔马借了我十两银。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了！我且问你：你在营中吃几份钱粮？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一份。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我那薛郎呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "也是一份。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你二人俱是一样，你哪里来的银钱借与他用？"
        },
        {
          "character": "薛平贵",
          "type": "白",
