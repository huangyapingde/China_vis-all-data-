        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "当真不封？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "当真不封！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "果然不封？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "果然不封！"
