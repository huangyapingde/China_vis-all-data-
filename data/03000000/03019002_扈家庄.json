{
  "script_id": "03019002",
  "title": "扈家庄",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "扈三娘",
      "hangdang": "刀马旦"
    }
  ],
  "plot": "梁山泊时迁攻打祝、扈二庄被擒，宋江率众往救之。先命石秀与吴用扮作樵夫与道人，混入庄内为内应。扈\n家庄扈三娘闻梁山泊大军至，率领庄丁出战，宋江派王英打前锋，王英被擒，梁山众英雄与扈三娘拼战，始\n擒扈三娘。",
  "notes": "此本为阎岚秋（九阵风）先生生前演出本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "石秀、杨林、杨雄、秦明、花荣、李逵、黄信、王英同上。"
        },
        {
          "character": "石秀",
          "type": "白",
          "text": "众家兄弟请了！"
        },
        {
          "character": "杨林、杨雄、秦明、花荣、李逵、黄信、王英",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "石秀",
          "type": "白",
          "text": "今日大哥攻打三庄，少时就要排山，你我两厢伺候！"
        },
        {
          "character": "杨林、杨雄、秦明、花荣、李逵、黄信、王英",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、吴用、公孙胜、宋江同上。"
        },
        {
          "character": "宋江",
          "type": "点绛唇",
          "text": "水泊英雄，替天行道，义气好，胸藏略韬，要把三庄扫！"
        },
        {
          "character": "石秀、杨林、杨雄、秦明、花荣、李逵、黄信、王英",
          "type": "同白",
          "text": "参见大哥！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众家兄弟免礼。"
        },
        {
          "character": "石秀、杨林、杨雄、秦明、花荣、李逵、黄信、王英",
          "type": "同白",
          "text": "谢大哥！"
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "威风凛凛坐梁山，盖世英雄非等闲。除暴安良本夙愿，不与奸佞共一天。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "俺，及时雨宋江。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "智多星吴用。"
        },
        {
          "character": "公孙胜",
          "type": "白",
          "text": "入云龙公孙胜。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "前者攻打祝、扈二庄，那贼累次抗拒义兵，至堪痛恨。闻得时迁被擒，不知生 死，为此点动大兵，前去攻打二庄，搭救时迁上山。 先生，请来传令！"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "遵命。 石秀听令！"
        },
        {
          "character": "石秀",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你扮作樵夫模样，探听祝家庄不得有误！"
        },
        {
          "character": "石秀",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "石秀下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "杨林听令！"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你扮作募化道人模样，暗地保护石秀，不得有误！"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨林下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "杨雄听令！"
        },
        {
          "character": "杨雄",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你解压粮草，不得有误！"
        },
        {
          "character": "杨雄",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨雄下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "王英听令！"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你攻打扈家庄，不得有误！"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "但愿此去旗开得胜，"
        },
        {
          "character": "秦明、花荣、李逵、黄信",
          "type": "同白",
          "text": "马到成功！"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众将官，攻打扈家庄去者！"
        },
        {
          "character": "秦明、花荣、李逵、黄信",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "李逵",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵上。"
        },
        {
          "character": "李逵",
          "type": "唱",
          "text": "豪杰生来多任性， 诚心扶保宋公明。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "俺，黑旋风李逵。只因宋大哥带领人马下山，攻打扈家庄。众家弟兄分路攻打 去了，就不差俺李二。啊呵有了！俺只好私自下山，倘遇机会，俺就杀他个落 花流水。看天色尚早，就此走遭也！"
        },
        {
          "character": "李逵",
          "type": "唱",
          "text": "不遵将令下山林， 俺李逵一人独自行。 生来不怕天和地， 单单只怕宋公明。 非他武艺强似我， 义气买动咱的心。 因此私自下山岭， 暗地帮助把功成。 迈开大步向前进， 方显胸中有才能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、秦明、花荣、黄信、宋江同上。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "秦明、花荣、黄信",
          "type": "同白",
          "text": "来到扈家庄。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "人马列开！ 哎呀，且住！看此庄深沟高垒，甚是严密。树木层层，好一村庄也。 众将官，扎下营盘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘上，起霸。"
        },
        {
          "character": "扈三娘",
          "type": "醉花阴",
          "text": "披挂整齐， 凤翅飞耀。 旌旗灿烂也那云霞蔽， 凭着俺这雄威， 百忙里炮似轰雷。 猛冲入数重围， 也顾不得临阵前万敌施威。 紧加鞭龙驹云催， 管叫他血染战袍回。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "奴家，一丈青扈三娘。正在花园游玩，忽听庄丁来报，梁山宋江，带领一干毛 贼前来骚扰我庄，为此全身披挂提防御敌。贼子啊贼子！这才是太岁头上动土。 呔，众女兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵、四下手、大旗同上。"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "随你姑娘出庄观阵者！"
        },
        {
          "character": "扈三娘",
          "type": "喜迁莺",
          "text": "俺只见旌旗蔽日，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英上，上高台。"
        },
        {
          "character": "王英",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英下。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "扈三娘",
          "type": "喜迁莺",
          "text": "猛听得鼍鼓声雷， 跷也么蹊， 堪笑他熊落谷里， 凭怎生双翅飞出重围。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "王英讨战！"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "众女兵，带马！"
        },
        {
          "character": "扈三娘",
          "type": "喜迁莺",
          "text": "我提画戟管叫他人头落地， 啊，怎能知俺勇冠无敌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、王英同上，王英起霸。"
        },
        {
          "character": "王英",
          "type": "念",
          "text": "自幼身量矮小，胸中韬略颇高。上阵不用战马，纵跳强似飞雕。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "俺，矮脚虎王英。奉了大哥将令，攻打扈家庄。闻得一丈青生得天姿国色，真 是闭月羞花之貌。俺若擒住此女，也好做一个老婆，啊哈哈哈……好不快乐人 也！ 众将官，今日出兵必须要人人奋勇、个个当先。就此前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英、四上手同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四女兵、四下手、大旗、扈三娘同上。"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "哎呀！ 又只见阵势飘缈绕旌旗， 这战场等闲看觑， 不许他拔寨归山里， 俺可也气吐虹霓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、王英同上，同会阵。四女兵、四下手、大旗、四上手同下。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "好一个娇婆娘！"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "好一个矮汉子！"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "呔！扈三娘，闻得你武艺高强，今日见了你王爷，敢么是怯战？"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "住了！看你身体不满三尺，敢与你姑娘交战？"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "一丈青，你休嫌我身量矮小，有道是：泰山高遮不住太阳，秤砣小能压千斤。 我若战你不过，情愿与你做……"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "做一个女婿。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "呸，贼子！"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "我笑，笑着他毛贼无见识， 怎知俺枪法无敌？ 觑着他汗淋淋，忙躲避， 俺这里，何曾用力， 俺也可只手扫平你， 一霎时将贼擒提。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘下。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "咦啊，想我战她不过，怎么她倒败了？啊呵是了！想是她心中有了我了，待俺 紧紧地赶上。 呔！扈三娘休走，王爷赶来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘上。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "且住！王英来的厉害。 众女兵走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵、四下手同上。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "绊马索伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英上，被擒。"
        },
        {
          "character": "四女兵、四下手",
          "type": "同白",
          "text": "王英被擒。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "贼子！"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "这才是狭路相逢难回避。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "来，将王英吊在高竿之上！"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "咦，这才是狭路相逢难回避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押王英同下，报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "前面便是宋江营盘！"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子应，下。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "众女兵，踹宋江营盘者！"
        },
        {
          "character": "扈三娘",
          "type": "水仙子",
          "text": "恨、恨、恨小毛贼， 恨、恨、恨小毛贼， 怎、怎、怎、怎逃俺虎穴龙潭地！ 他、他、他、他那里珠泪惨凄， 俺、俺、俺、俺生擒把贼悬提， 似、似、似、似大鹏展翅飞不起。 有、有、有、有神通难逃画戟， 杀、杀、杀、杀得他无路奔，血染马蹄。 斩、斩、斩、斩尽了残兵败将， 管、管、管、管叫他片甲不存死如泥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘引四女兵同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李逵上。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "听人喊马嘶，待某登高一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、秦明、花荣、黄信、宋江同上，过场，同下。四下手、四女兵同上，过场，同下。扈三娘上。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "好一个黑汉子！"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "好一个娇婆娘！"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "呔！这一黑汉，为何挡住奴家的去路？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "你李逵爷爷在此。这一斧，劈你两半！"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘、李逵同开打，扈三娘、李逵同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李逵、扈三娘同上，对打。扈三娘挑李逵。四下手、四女兵同上，过场，同下。扈三娘下。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "且住！只望私自下山擒那扈三娘；不想被她一枪刺倒尘埃，好不晦气也！"
        },
        {
