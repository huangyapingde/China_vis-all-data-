{
  "script_id": "03021005",
  "title": "平贵别窑",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "小生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    }
  ],
  "plot": "薛平贵婚后，因降服红鬃烈马，受封为后军督府；王允参奏，降为先行，使隶于次婿魏虎麾下，且遣其远征\n西凉。薛平贵归家，忍痛与王宝钏分别。",
  "notes": "为全部《王宝钏》之第五折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "引子",
          "text": "闷坐寒窑，终日里，愁锁眉梢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏坐。"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "离了相府住寒窑，思想老母泪滔滔！嫌贫爱富世间少，父母恩情一旦抛。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "奴家，王宝钏。爹爹王允，官居首相。膝下无儿，生我姐妹三人。前者母亲身 染重病，我每日在床前侍奉汤药，不离左右。且喜母亲病体痊愈。后宫娘娘见 喜，亲赐五色绒线，绣成彩球，高搭彩楼，抛球招赘。彩球打中薛郎。爹爹嫌 贫爱富，叫我退去这门亲事。是我执意不允，与爹爹三击掌，怒出相府，来在 寒窑，与薛郎苦度光阴。薛郎投军去了。独坐寒窑，思念母亲，好不忧闷人也。"
        },
        {
          "character": "王宝钏",
          "type": "二黄慢三眼板",
          "text": "王宝钏坐寒窑伤心泪掉， 老爹爹枉做了一品当朝。 嫌贫穷爱富贵世间稀少， 他把那父女情一旦皆抛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏离座。"
        },
        {
          "character": "王宝钏",
          "type": "二黄慢三眼板",
          "text": "薛平贵虽贫穷志气不小， 凭武艺去投军报效皇朝。 走向前我把这窑门闭了， 等薛郎回窑转细问根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "龙虎台前出入，貔貅帐内传宣。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "俺，苏元帅帐下中军官是也。奉了元帅将令，去到寒窑，催促薛平贵速速回营 听点。天时不早，马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上，起霸。"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "头戴金盔风翅飘，身穿铠甲放光豪。红沙涧内降妖马，扶保唐王立功劳。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "俺，薛平贵。是我前去投军，降了红鬃烈马。圣上见喜，封俺后军督府。只因 西凉夏国，打来连环战表，要夺我主江山。圣上挂苏龙、魏虎以为正副元帅。 可恨王允老贼，上殿参奏一本，将俺后军督府，改为马前先锋。今乃黄道吉期， 即日就要出兵。因此全身披挂，去到寒窑，辞别三姐。王允哪，老贼！平贵 得地，若不杀你，非为人也！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "心中只把王允恨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵作备马身段，上马，扯四门。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "薛平贵马上暗思忖： 西凉国打来了连环本， 他要夺我主锦乾坤。 我心中只把老贼恨， 害得我夫妻两离分。 催马加鞭——"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "朝前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵走圆场，下马。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "叫声三姐快开窑门。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐开门来！"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "忽听门外有人唤， 想必薛郎转回还。 开开窑门用目看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏开门。西皮行弦。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵进窑，两旁看。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "哪里来的荣耀还？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊薛郎，你哪里来的这身荣耀哇？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐哪里知道。为夫前去投军，降了红鬃烈马。圣上见喜，封俺后军督府。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此说来，你做了官了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待我谢天谢地。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "慢谢天地，其中有变！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "此话从何说起？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "只因西凉夏国，打来连环战表，要夺我主江山，圣上挂苏龙、魏虎以为正副元 帅，可恨你父，上殿参奏一本，将俺后军督府，改为马前先行。今乃黄道吉期， 即日就要出兵。因此回得窑来，辞别三姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "辞别三姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏急死。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐醒来！"
        },
        {
          "character": "王宝钏",
          "type": "西皮导板",
          "text": "听一言吓得我心惊胆怕，"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐醒来！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "不由人一阵阵珠泪如麻。 父好比秦赵高指鹿为马， 又好比汉萧何私造律法。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "说什么秦赵高指鹿为马， 讲什么汉萧何私造律法。 为丈夫与你父冤仇结下， 害得我夫妻们各奔天涯！"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "手指相府——"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "高声骂！ 苦苦害我理忒差。 眼看着好鸳鸯——"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "如同浪打， 狠心的爹爹呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "害得我夫妻们远隔天涯。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "三姐不必泪双流， 丈夫言来听从头： 干柴十担米八斗， 你在寒窑度春秋。 守得住来把我——"
        },
        {
          "character": "薛平贵",
          "type": "哭头",
          "text": "守， 三姐呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "守不住来你把我丢！"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "薛郎说话无来由， 倒叫为妻心内忧。 干柴十担米八斗， 奴在寒窑度春秋。 守不住来也要守， 纵死寒窑我也不回头！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "三姐说话志量有， 落下美名万古留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "薛平贵听令！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵出窑。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "中军官到此何事？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "元帅初点大卯，军情紧急，速速回营听点！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "将军不下马，"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "各自奔前程。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。薛平贵进窑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊薛郎，方才何人到此？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "中军到此。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "到此何事呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "只因元帅初点大卯，叫我速速回营听点。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊薛郎，你这就走么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "这就走了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有什么言语，嘱咐为妻几句？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "事到如今，我方寸已乱，你叫我讲些什么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎啊！你此番出兵，不定三年五载才能回来，叫为妻依靠何人？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！为夫此番征战西凉，不定三年五载才得回来。与你留下十担干柴、八斗 老米。若是不够哇！你……回转相府，叫你父另选才郎去吧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎啊！曾记得与我爹爹三击掌？纵然饿死寒窑，也是不回去的了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好哇！难得三姐有如此的志量。为夫此番征战西凉，与你留下的柴米若是不够， 你在这窑前、窑后、窑左、窑右，与人家浆浆洗洗、缝缝连连。等为丈夫回 得家来，我是一家一家，登门叩谢。话已讲明，我要告辞了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎，你当真要走么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "走了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待为妻送你一程。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "外面风大，不送也罢！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "一定要送！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如此，有劳三姐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭泣。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊三姐，不要悲伤。为夫此番出征，你在寒窑，保重身体要紧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你一路之上，须要留心在意，多加谨慎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵撞窑门。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊薛郎！怎么样了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不妨事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏出窑。薛平贵拉马。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "夫妻们双双出窑门，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "好一似万把刀刺在我心。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "但愿你此一去旗开得胜，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "自有那探马儿来报佳音。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "西凉路上你要多加谨慎，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "你在这寒窑内耐度光阴。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "送薛郎送至在三岔路——"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "口， 我的夫哇！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "叫人难舍又难分。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "从空降下无情剑，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "斩断夫妻两离分！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "流泪眼观流泪眼，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "断肠人送断肠人。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "宝钏难舍薛平贵，"
        },
        {
