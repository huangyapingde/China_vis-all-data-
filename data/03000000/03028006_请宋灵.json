      "hangdang": "净"
    },
    {
      "name": "牛皋",
      "hangdang": "净"
    },
    {
      "name": "宋徽宗",
      "hangdang": "老生"
    },
    {
      "name": "宋钦宗",
      "hangdang": "老生"
    },
    {
      "name": "太后",
      "hangdang": "旦"
    },
    {
      "name": "宋太祖",
      "hangdang": "红生"
    }
  ],
  "plot": "金兀术南犯，掳去徽、钦二帝。岳飞奉诏北伐，大破“八卦阵”。金兀术不敌，许放二圣回宋。徽、钦二帝\n以无颜复见百姓，自缢。岳飞哀痛之余，要搬请皇灵，命金主身穿重孝，写具降表出城迎接。金主假允，为\n岳飞看破，暗作准备。及献表，金兀术举剑刺岳飞，被牛皋所败。岳飞搬皇灵南归。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、哈迷蚩、木罕同上。〖点绛唇〗。"
        },
        {
          "character": "木罕",
          "type": "念",
          "text": "匹马金枪世间无，赫赫威名震帝都。一心想夺花世界，要把宋室一扫除！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "孤，大金邦三太子完颜木罕。老王晏驾，众卿保孤登基。四弟带兵去伐中原， 屡有捷音前来。 啊军师！"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "狼主！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "这宋室天下，一时不能归孤，如何是好？"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "此非一日之功，总由天命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀狼主：四太子擒来两个大邦皇帝。"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "押上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押宋徽宗、宋钦宗、太后同上。"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "呔！两个昏君，见了孤家，为何不跪？"
        },
        {
          "character": "宋徽宗、宋钦宗",
          "type": "同白",
          "text": "孤乃天朝圣主，岂跪犬羊！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "来，将这两个昏君斩了！"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "为何拦阻？"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "将他斩首，岂不便宜了他？"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "将那通宵殿下，烧得通红，我与狼主，高坐饮酒，叫这两个昏君，在殿上站立。 殿下有火，焉能站得稳？必须趴在地下。这样取笑，岂不是好？"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "此计甚好。 巴图鲁，照计而行。押下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押宋徽宗、宋钦宗、太后同下。"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "将酒宴摆在通宵殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同上。"
        },
        {
          "character": "大太监",
          "type": "念",
          "text": "一封丹草诏，飞下九重霄。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "咱家，德子。奉皇旨意，调岳元帅扫灭金囚。 孩子们，打道哇！"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、哈迷蚩、木罕同上。"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "将二昏君押上殿来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番将同允。四小番押宋徽宗、宋钦宗、太后同上。"
        },
        {
          "character": "宋徽宗",
          "type": "西皮摇板",
          "text": "心中恼恨张邦昌，"
        },
        {
          "character": "宋钦宗",
          "type": "西皮摇板",
          "text": "不该将孤献番邦。"
        },
        {
          "character": "宋徽宗",
          "type": "西皮摇板",
          "text": "有朝一日回朝转，"
        },
        {
          "character": "宋钦宗",
          "type": "西皮摇板",
          "text": "要把金囚一扫光！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "先生请！"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "狼主请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "先生，将这两个昏君，打在五国城中，坐井观天，岂不是好？"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "好啊，将昏君押至五国城，好生看守。 来，押下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小番押宋徽宗、宋钦宗、太后同下。哈迷蚩、木罕同下，四番将、四番兵同随下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四黑龙套引岳飞同上。"
        },
        {
          "character": "岳飞",
          "type": "引子",
          "text": "帐下站立千员将，统领雄兵百万郎。"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "志气凌云冲霄汉，赤胆忠心保江山。龙凤旌旗空中展，丹心一点斗牛寒！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅，姓岳名飞字鹏举。宋室驾前为臣。可恨朝中奸佞张邦昌等将二圣献于番 营。俺蒙后宫娘娘恩赐龙凤旗二面，扫灭金囚。正是："
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "老天遂人愿，迎请二圣还！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云、张宪、施全、王贵、牛皋、何元庆、郑怀、张显同上。"
        },
        {
          "character": "岳云、张宪、施全、王贵、牛皋、何元庆、郑怀、张显",
          "type": "同念",
          "text": "柳荫拴战马，虎帐夜谈兵。"
        },
        {
          "character": "岳云、张宪、施全、王贵、牛皋、何元庆、郑怀、张显",
          "type": "白",
          "text": "启元帅：圣旨下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "香案接旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "圣旨下。"
        },
        {
          "character": "岳飞、岳云、张宪、施全、王贵、牛皋、何元庆、郑怀、张显",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞、岳云、张宪、施全、王贵、牛皋、何元庆、郑怀、张显同跪。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "跪听宣读，诏日：命岳飞带领众将，扫灭金囚，迎请二圣回朝。旨意读罢，望 诏谢恩哪！"
        },
        {
          "character": "岳飞、岳云、张宪、施全、王贵、牛皋、何元庆、郑怀、张显",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "有劳公公，捧旨前来，后堂留宴。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "朝命在身，不敢久停。告辞！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "奉送！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监、四太监同下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官，校场听点！"
        },
        {
          "character": "岳云、张宪、施全、王贵、牛皋、何元庆、郑怀、张显",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四红龙套、四绿龙套、四番将、哈迷蚩、木罕同上。"
        },
        {
          "character": "木罕",
          "type": "唱",
          "text": "四弟领兵把贼扫， 旗开得胜转回朝。 将身且坐宝帐道， 且听探马报根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大丞相上。"
        },
        {
          "character": "大丞相",
          "type": "念",
          "text": "忙将岳飞事，奏与狼主知。"
        },
        {
          "character": "大丞相",
          "type": "白",
          "text": "参见狼主！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "大丞相请坐。"
        },
        {
          "character": "大丞相",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "大丞相上殿，有何本奏？"
        },
        {
          "character": "大丞相",
          "type": "白",
          "text": "启禀狼主：今有岳飞带领倾国人马，杀到我国来了！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "啊！先生可曾听见？大丞相奏道，今有岳飞带领倾国人马杀到我国来了！先生 计将安出？"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "就命四太子出马，一仗成功。"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "替孤传旨：宣四弟上殿！"
        },
        {
          "character": "哈迷蚩",
          "type": "白",
          "text": "四太子上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金兀术上。"
        },
        {
          "character": "金兀术",
          "type": "念",
          "text": "当年大破潞安州，要把宋室一扫除！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "参见兄王！"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "御弟少礼，请坐。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "谢坐。宣弟上殿，有何国事议论？"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "今有岳飞带领人马，杀到我国来了。特请御弟商议退兵之计。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "兄王放心，待小弟出马，抵挡岳飞。"
        },
        {
          "character": "木罕",
          "type": "白",
          "text": "须要小心！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "木罕、哈迷蚩、大丞相同下。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "巴图鲁！"
        },
        {
          "character": "四红龙套、四绿龙套、四番将",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": "四红龙套、四绿龙套、四番将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀同上，同起霸。"
        },
        {
          "character": "牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀、张显",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "牛皋"
        },
        {
          "character": "张显",
          "type": "白",
          "text": "张显。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "施全。"
        },
        {
          "character": "王贵",
          "type": "白",
          "text": "王贵。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "岳云。"
        },
        {
          "character": "张宪",
          "type": "白",
          "text": "张宪。"
        },
        {
          "character": "何元庆",
          "type": "白",
          "text": "何元庆。"
        },
        {
          "character": "郑怀",
          "type": "白",
          "text": "郑怀。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "张显、施全、王贵、岳云、张宪、何元庆、郑怀",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "元帅升帐，两厢伺候！"
        },
        {
          "character": "张显、施全、王贵、岳云、张宪、何元庆、郑怀",
          "type": "同白",
          "text": "请！ （牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀自两边分下。〖急急风〗。四白龙套、四黑龙套、 四上手、岳飞同上，牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀同随上。）"
        },
        {
          "character": "牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀、张显",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀、张显",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅带领兵和将，要把金邦踏平阳！众位将军，人马可齐？"
        },
        {
          "character": "牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀、张显",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑怀同允。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖急急风〗。金兀术、四番将、四番兵同上，岳飞、牛皋、张显、施全、王贵、岳云、张宪、何元庆、郑"
        },
        {
          "character": null,
          "type": "text",
          "text": "怀同上。钥匙头会阵。）"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "呔！马前来的敢是金兀术？"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "然！"
        },
        {
          "character": "岳飞",
          "type": "白",
