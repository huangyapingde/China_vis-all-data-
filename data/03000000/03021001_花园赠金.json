{
  "script_id": "03021001",
  "title": "花园赠金",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "薛平贵",
      "hangdang": "小生"
    }
  ],
  "plot": "唐丞相王允，生有三女：大女王金钏，嫁苏龙，官居户部；二女王银钏，配魏虎，兵部侍郎；三女王宝钏，\n因溺爱，许于二月二日，在十字街头，高搭彩楼，抛球选婿。王宝钏为求佳婿，携婢至花园焚香祈祷。事毕，\n发觉园外有一花郎倒卧，使婢问明，知是薛平贵。王宝钏见其人品不凡，并非久困之人，意有所属。乃命\n婢往取衣服银两相赠，并嘱薛平贵及期至彩楼前，接球入赘。",
  "notes": "为全部《王宝钏》之第一折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "每日刺绣龙凤袄，侍奉双亲到白头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟暗上。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "奴家，王宝钏。爹爹王允，官居首相。母亲陈氏，生我姐妹三人——大姐金钏， 许配苏龙。二姐银钏，许配魏虎。只有奴家尚未婚配。这且不言。只因昨夜 偶得一梦，梦见一颗斗大红星，坠落卧房，将我惊醒。不知主何吉凶？我不免 去到花园焚香祝告。 丫鬟！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "捧定香盘，带路花园！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏离座。"
        },
        {
          "character": "王宝钏",
          "type": "西皮三眼板",
          "text": "昨夜晚一梦甚稀奇， 斗大的红星坠落房里。 只惊得奴家汗满体， 不知是凶还是吉？ 叫丫鬟带路花园里，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟捧香盘引王宝钏同进园门。丫鬟摆香盘，王宝钏上香跪拜。"
        },
        {
          "character": "王宝钏",
          "type": "西皮三眼板",
          "text": "双膝跌跪——"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "在丹墀。 夜梦红星甚稀奇， 因此到花园将神祈。 叩罢头来——"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "身站起，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏站起，归座。丫鬟撤去香盘。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "小坐片时暂歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "身上无衣御寒凉， 肚内饥饿实难当。 将身来在大街上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵走小圆场。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "抬头只见府门墙。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "俺，薛平贵。乃长安人氏。只因时运不佳，落在这乞讨之中。来此已是王相府 的花园门首。身体困倦，不免在此打睡片时。正是："
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "丢开心中事，昏沉睡阳台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵卧睡。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "丫鬟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟允。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我闷坐花园，甚是无聊，到哪里去玩耍玩耍？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "咱们到花园门外，玩玩去吧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此，带路！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏离座，随丫鬟同出门。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "呦，小姐，大事不好啦！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "外面着火啦！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏看薛平贵。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏想。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "丫鬟，你远看？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是火！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "近观呢？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是一个花郎。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你去将那花郎唤醒，带进花园，我有话讲。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏进门，归座。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "花郎醒来！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "原来是丫鬟姐。唤我何事？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "我家小姐叫你进去，有话问你。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵站。丫鬟引薛平贵同进门。薛平贵向王宝钏作揖。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "参见小姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏自想。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀且住！看这花郎，两耳垂肩，双手过膝，乃大贵之相，为何落在乞讨之中？ 嗯！我自有道理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏对薛平贵。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊花郎，你家住哪里，姓甚名谁？一一讲来，也好周济于你。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐容禀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "小姐在上容我禀， 细听花郎说分明： 家住本国长安地， 父母早已命归阴。 若问花郎名和姓， 薛平贵就是我的名。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "听他言来自思忖： 容貌不像受苦的人—— 两耳垂肩贵相品， 龙眉虎目帝王尊。 夜梦红星是有准， 莫非应在此人的身？ 彩球之事——"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "对他论，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏左右两顾。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "又恐丫鬟在旁听。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊丫鬟，去到绣房取银子一锭、衣服一件。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊花郎，方才你言道家中父母双亡，你可有……"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有什么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "可有妻室呀？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏用袖掩面作羞。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐说哪里话来！落在乞讨之中，哪里来得银钱娶妻呀？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我有一言，不好启齿。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐有何金言，尽管请讲。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊花郎，我对你实说了吧：我父约定二月二日，在十字街前，高搭彩楼，抛球 招赘。是日你可站在楼前。倘若姻缘有分，也未可知。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "里面都是王孙公子，哪有花郎之份？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我有一言，你且听了！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "二月二日事有准， 切莫错过好光阴。 倘若姻缘事有分， 你是天台路上的人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐，银两、衣裳在此。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "付与花郎，叫他去罢。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多谢小姐！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "辞别小姐出园门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵作揖，欲出门。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "转来！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "小姐还有何话云？"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "你若不来失了信， 就是忘恩负义的人！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "小姐！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "小姐不必细叮咛， 平贵岂是负义的人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵出门，下。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "奴家暗把天祝定， 二月二日配良姻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、丫鬟同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}