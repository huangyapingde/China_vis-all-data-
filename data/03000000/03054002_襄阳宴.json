        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟驾到，未曾远迎，面前恕罪！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "岂敢！少来问安，宗兄海涵！"
