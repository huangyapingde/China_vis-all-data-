          "character": "刘备",
          "type": "唱",
          "text": "弟谢宗兄恩浩荡， 亲送长亭赐琼浆。 回头我对宗兄讲， 小弟言来听端详： 愿兄寿同山岳样， 愿兄福共海天长。 弟兄酒罢分别往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四御林军、四太监、四将官、蒯越、蔡瑁、张允同下。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "又见玄德泪两行。 含悲忍泪把马上，"
        },
        {
          "character": "刘备",
          "type": "哭",
          "text": "宗兄啊！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "倒叫我心中痛断肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘表下。"
        },
        {
          "character": "伊籍",
          "type": "唱",
          "text": "皇叔且慢抖丝缰， 伊籍向前话商量。"
        },
        {
          "character": "伊籍",
          "type": "白",
          "text": "启皇叔：此马不可骑也！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，何言此马不可骑也？"
        },
        {
          "character": "伊籍",
          "type": "白",
          "text": "昨日蒯越见府君言讲，此马有不好之处。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有什么不好之处？"
        },
        {
          "character": "伊籍",
          "type": "白",
          "text": "皇叔，昨日谋士蒯越言说：此马名曰“的卢”，最妨主人。言那张武乘骑，已 遭不幸，因此将马又送回皇叔。皇叔须要三思！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "多蒙先生指教！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "生死只可由命闯， 吉凶之事怎提防！"
