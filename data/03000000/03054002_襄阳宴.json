{
  "script_id": "03054002",
  "title": "襄阳宴",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘表",
      "hangdang": "老生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "蔡氏",
      "hangdang": "旦"
    }
  ],
  "plot": "刘备大破张武、陈孙，旋归襄阳。刘表赐宴，并遣关羽、张飞、赵云往巡汉中、南越、夏口等处。蔡夫人患\n之，进谗刘表。刘表乃迁刘备于新野。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四将官、蔡瑁、张允引刘表同上。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "玄德贤弟领兵将， 替孤扫灭贼强梁。 军中探马来报讲， 灭了二贼称心肠。 孤也曾把那旨意降， 预备酒宴与琼浆。 探马二次来报讲， 孤王迎接出襄阳。"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启主公：刘、关、张得胜而回，离荆州十里安营！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "吩咐摆队出城迎接！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "摆队出城迎接！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内唱",
          "text": "自从荆州领兵将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、四上手、四将官、赵云、张飞、关羽、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "扫灭二贼姓名扬。 一路之上威风荡， 队伍齐整兵将强。 诸军齐把凯歌唱， 众将各个喜非常。 得意鞭敲金镫响， 马到成功回荆襄。 十里长亭扎营帐， 整理军务回朝堂。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启使君：荆州刘主公带领文武，出城迎接，已到十里长亭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场设荆州城门。〖吹打〗。四蓝文堂、四将官、蔡瑁、张允引刘表同出门，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖吹打〗。四红文堂、四红大铠、四上手、四将官、赵云、张飞、关羽、刘备同上，四蓝文堂、四将官、"
        },
        {
          "character": null,
          "type": "text",
          "text": "蔡瑁、张允引刘表同上，刘表下马，刘备看。）"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "啊贤弟！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊宗兄！"
        },
        {
          "character": "刘表、刘备",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "左右，看酒来，我与刘族弟接风，庆贺得胜酒！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "人来看过御酒浆， 尊声贤弟听端详： 全仗贤弟去扫荡， 灭却二贼威名扬。 非是愚兄美言讲， 交锋还是刘、关、张。 愚兄捧酒敬贤弟， 敬酒略表兄心肠。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "谢过宗兄美言讲， 交锋对垒古之常。 仁兄洪福有天相， 好比皓月照万方。 也是贼子该命丧， 多谢迎接出荆襄。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "人来看过葡萄酿， 回头再敬赵、关、张。 三位可称英雄将， 感谢交锋血战场。 手捧御酒来奉上， 多谢三位受风霜。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "刘主恩待我兄长， 理应效劳到疆场。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "刘公待主恩德广， 感谢赐饮御酒浆。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "刘主深恩山海样， 老张最喜饮琼浆。 来、来、来将酒满斟上，"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "看大杯伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监换大杯斟酒。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "多吃几杯有何妨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞饮酒。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "吃得老张精神爽， 得胜酒吃得个喜心肠、理所应当！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你就是好饮哪！"
        },
        {
          "character": "刘表",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "张飞",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "好个猛勇翼德将， 亚赛当年楚霸王。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "仁兄！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "此处焉能细谈讲， 你我进城叙衷肠。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "宗兄一同雕鞍上，"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "回头再叫众儿郎： 钦赐御宴俱升赏， 功劳簿上姓名扬。 满营将士摆队往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同领下。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "炮响三声进荆襄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘表下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（场设荆州城门。〖大吹打〗。刘备、刘表、四红文堂、四红大铠、四上手、四将官、赵云、张飞、关羽、"
        },
        {
          "character": null,
          "type": "text",
          "text": "四蓝文堂、四将官、蔡瑁、张允同上，同进城，同下。）"
        },
        {
          "character": null,
          "type": "text",
          "text": "（〖吹打〗。刘备、刘表、四红文堂、四红大铠、四上手、四将官、赵云、张飞、关羽、四蓝文堂、四将官、"
        },
        {
          "character": null,
          "type": "text",
          "text": "蔡瑁、张允同上，四上手同下，四将官同下。众人同挖门，分两边站，刘备、刘表同坐。）"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟剿灭贼寇，受尽风霜，兄心不忍。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "弟为国勤劳，何言“风霜”二字？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启主公：宴齐。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "伺候了！待我在诸公面前，每人敬酒三杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同入座。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宗兄，只行常饮。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "表乃一番敬意。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宗兄奉敬一杯也就是了！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "兄遵弟之命，表落俗套了哇，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘表与关羽、张飞、赵云各敬一杯酒。"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "我等不敢当了。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟，诸位将军请！"
        },
        {
          "character": "刘备、关羽、张飞、赵云",
          "type": "同白",
          "text": "请哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同饮酒。〖牌子〗。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "仁兄！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "兄有许多心事，贤弟听了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宗兄请讲！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "各路诸侯起战争，"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宗兄请！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "民遭涂炭受苦情。 愚兄虽居荆州郡， 内有大事在心中。 南越时常犯边境， 汉中张鲁要取州城。 江东有意来吞并， 曹操久已要交兵。 愚兄为此常忧闷， 怎能挡住保安宁？"
        },
        {
          "character": "刘备",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "刘备席前笑盈盈， 解劝宗兄免愁容。 些许之事何足论， 扫灭烟尘谈笑中。 二弟关羽威风凛， 三弟翼德惯战征。 子龙破过金锁阵， 万马营中有威名。 各去分守各州镇， 暗中抵挡各路兵。 三弟南越把兵领， 二弟威镇汉中营。 三江口险要须防紧， 四弟赵云有奇能。 各个要路安排定， 哪怕贼人起战争！ 调拨当否请思忖， 宗兄还须酌量行。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "此计保守荆州郡， 何愁军马不太平。 贤弟安排我应允， 果然胸中韬略精。"
        },
        {
          "character": "刘表、刘备",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟这一调动，荆州九郡可以无忧矣！"
        },
        {
          "character": "刘表",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "弟要告辞了！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟再饮几杯。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "弟酒已够了，改日再饮。告辞了！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟一路鞍马劳乏，理应歇息，请哪！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "宗兄从此休忧闷， 纵有征战弟担承。 何惧张鲁来叫阵， 就是孙、曹哪在心！ 辞别宗兄出府门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、赵云、张飞、关羽同下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "闲暇你我再谈心！"
        },
        {
          "character": "刘备",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "刘表",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "看来是我真侥幸， 扫灭二贼赖同宗。 孤王即忙传将令， 犒赏众将与三军。 此一番孤王心安静， 孤有玄德永安宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引蔡氏同上。"
        },
        {
          "character": "蔡氏",
          "type": "唱",
          "text": "适才宫娥报一信， 玄德班师回州城。 从此刀兵俱安静， 全仗桃园享太平。 将身且把后宫进， 候主回宫问分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡瑁上。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "蔡瑁",
          "type": "唱",
          "text": "急忙且把后宫进， 见了贤妹说详情。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "啊贤妹！"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "啊！兄长来了，请坐！"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "兄长不在前厅，进内必有要紧之事？"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "贤妹，我妹丈听从刘备之言，将关、张、子龙三人分镇汉中、南越、三江夏口， 我想日后恐有变乱。"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "兄长，刘玄德遣将巡边，乃是好意。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "贤妹有所不知，他若久居荆州，各处串遍，将来必为大患。叫他三将巡边，又 必得与他兵权。再者刘备为人心术不正，乃是一个见利忘义之徒，焉能同守荆 州以心腹相待？怎奈妹丈不听良言，将来必遭其害也！"
        },
        {
          "character": "蔡瑁",
          "type": "唱",
          "text": "口称贤妹听兄论， 莫把刘备当好人。 若不早早安排定， 久后遗害与外甥。 一旦玄德根基稳， 定成大患起祸根。 关、张犹如两只虎， 刘备好似混江龙。 常山赵云多骁勇， 浑身是胆谁不闻？ 安能共保九州郡， 有朝一日必变心。 妹丈忠厚少学问， 难防日后大祸生。"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "蔡氏",
          "type": "唱",
          "text": "听兄讲的是实情， 叫我此时心着惊。 若依兄长你所论， 有何妙计保安宁？"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "依兄之见，除非叫刘备离了荆州，方保无忧。"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "就依兄长之言。少时你妹丈来时，我与他商议，赶走刘备就是。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
