{
  "script_id": "03031005",
  "title": "双摇会",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "大奶奶",
      "hangdang": "旦"
    },
    {
      "name": "二奶奶",
      "hangdang": "旦"
    },
    {
      "name": "李相公",
      "hangdang": "小生"
    },
    {
      "name": "邻居甲",
      "hangdang": "丑"
    },
    {
      "name": "邻居乙",
      "hangdang": "丑"
    },
    {
      "name": "书童",
      "hangdang": "丑"
    }
  ],
  "plot": "李相公娶妻二人，因争风吃醋，日夜吵闹，四邻不安。一日，李相公自外归，二妻又因争房大吵。于是邻人\n献策：以摇骰解决房次。但摇骰后，房次并未解决，纠纷依然存在。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "大奶奶",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大奶奶上。"
        },
        {
          "character": "大奶奶",
          "type": "念",
          "text": "我不恕人人难恕，人能容我我难容。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我、王氏。配夫李相公。我们相公在家的日子少，出外的日子多。在外边交了 些狐朋狗友。也不知听了哪个坏种嘎杂子的话，又娶了一个二奶奶。自从把她 娶进门来，把我好比伤风的鼻涕——可就给甩啦！今儿个趁着相公没在家，我 不免把二奶奶给叫出来，抓个错儿打她一顿，出出我这口怨气。就是这个主意。 我说二奶奶，你给我滚出来吧！"
        },
        {
          "character": "二奶奶",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二奶奶上。"
        },
        {
          "character": "二奶奶",
          "type": "念",
          "text": "忽听大奶奶唤，急忙到跟前。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "大奶奶，我们这儿有礼啦！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "罢啦！坐下吧！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "告坐。您把我叫出来，有什么事情吗？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我问你，你干什么哪？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我梳完了头，打了一个盹儿。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你可倒好，吃饱了食困，饿了发呆。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "您有什么事呀？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我从娘家带点儿活来，你帮我做做。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "您这屋太黑，上我屋里做去吧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你那屋里闹臭虫，咱们上厅房里做去吧！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "好吧，咱们走哇！"
        },
        {
          "character": "大奶奶",
          "type": "唱",
          "text": "姐妹好比一枝花，"
        },
        {
          "character": "二奶奶",
          "type": "唱",
          "text": "十人见了九人夸。"
        },
        {
          "character": "大奶奶",
          "type": "唱",
          "text": "将身来在厅堂下，"
        },
        {
          "character": "二奶奶",
          "type": "唱",
          "text": "姐妹双双把活拿。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我说妹妹，今儿个你做绣鞋，我做坎肩。做可是做，谁也不许瞧谁的！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "谁要瞧谁的哪？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "谁不是东西！咱们做吧！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "做呀！"
        },
        {
          "character": "大奶奶",
          "type": "唱",
          "text": "手拿钢针把活做， 上绣蝴蝶扑灯蛾。"
        },
        {
          "character": "二奶奶",
          "type": "唱",
          "text": "相公一去不回转， 思想相公懒做活。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二奶奶睡。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "这么热闹，又睡啦。火绒的脑袋——一蹭就着！ 二奶奶，我说你醒醒！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你倒是做活呀！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "做得啦您哪！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "做得啦？别“您”哪！我瞧瞧！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "慢着！您不是说做得了“谁也不准瞧谁的”吗？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "只许我瞧你的，不许你瞧我的。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "谁瞧谁的，谁不是东西！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我偏要瞧！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "不叫你瞧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我偏瞧！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "给你瞧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "没起杠就摔啦。瞧这粗针大麻线的。 我说二奶奶，你这儿来！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你这活谁教给你的？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我妈教给我的。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "连你妈带你都不是东西！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "你妈才不是东西呢！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你要价还价，我打死你呗！"
        },
        {
          "character": "大奶奶",
          "type": "唱",
          "text": "手使家法将你打， 打死贱人染黄沙。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "您饶了我吧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "饶你不难，你得叫我乐一乐。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "怎么乐呀？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你得叫我一声亲亲的、热热的、象牙筷子挑凉粉、一挑一哆嗦、哆哩哆嗦、颤 颤巍巍儿的我的小干妈儿。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你叫我！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我叫您？您听着：亲亲的、热热的、象牙筷子挑凉粉、一挑一哆嗦、哆哩哆嗦、 颤颤巍巍儿的我的小干妈儿呀！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "唉！干儿子！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "叫谁呢？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "叫你哪。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "干儿子叫我哪！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你不答应我打死你！干儿子！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "滚起来！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "今儿个还是您吃斋的日子哪！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "对啦，今儿个还是我吃斋的日子哪！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "是您吃“雷公斋”的日子。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你才怕雷劈哪！我告诉你说，今儿个打也打了你啦，骂也骂了你啦，相公回来， 不许你告诉他。你要告诉他，我一脚把你子肠踢折了，叫你一辈子不能生养。 正是："
        },
        {
          "character": "大奶奶",
          "type": "念",
          "text": "口念千声佛，早晚一炉香。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "罢！罢！罢！阿弥陀佛！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我把你这老——"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "老什么？老什么？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "老……老姐姐。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "可称得起是你的老姐姐。我今儿个要不是吃斋的日子，我含口凉水把你咽了。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "好大嗓子眼儿！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "阿弥陀佛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大奶奶下。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我把你这老不是东西呀！"
        },
        {
          "character": "二奶奶",
          "type": "唱",
          "text": "将身来在厅堂下， 等候相公转回家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李相公、书童同上。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "（唱）一日离家一日深， 好似孤雁宿寒林。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "到了。 书童，上前叫门！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "师父，我两条腿跟您四条腿儿跑，跑了这么一道儿，好容易到了。怎么叫门还 是我的事？再说，您也没教过我叫门哪。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "叫门都不会？站远些，待我来叫。 二娘开门来！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "谁叫门哪？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "相公回来了。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "相公回来啦？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二奶奶开门。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "相公请进！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "二娘请！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "相公请坐。相公一路辛苦啦！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "何言辛苦！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "师父！师父！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "你怎么不进去？"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "我没带着钱。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "怎么讲话？随我进来。见过你师娘。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "我说师父，我们家把我交给您，是跟您念书学好来了，您怎么带我——"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "少说废话！这是你的二师娘。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "参见二师娘！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "这小子鬼头鬼脑的！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "师父，咱们走吧！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "今日天色已晚，在此安歇了。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "我要饿了哪？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "有你的饭吃。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "我要渴了哪？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "有你的水喝。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "我要困了哪？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "滚下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童下。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "啊二娘，自我走后，大娘待你如何？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "相公啊！"
        },
        {
          "character": "二奶奶",
          "type": "唱",
          "text": "自从相公离家下， 大娘终日打骂咱。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "二娘不必啼哭，待我把她叫了出来，打她一顿，与二娘出气也就是了。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "算了吧！我问问你，你今儿个回来，在哪屋里睡呀？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "自然在二娘屋里睡。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "如此请！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "李相公",
          "type": "唱",
          "text": "今日好比七月七，"
        },
        {
          "character": "二奶奶",
          "type": "唱",
          "text": "牛郎织女会佳期。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李相公、二奶奶同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大奶奶上。"
        },
        {
          "character": "大奶奶",
          "type": "唱",
          "text": "急急走来不消停， 两步当做一步行。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "哎呀慢着！怎么半夜听见马叫唤？多半是相公回来啦。一声儿不言语在二奶奶 屋里忍啦。有来，我上窗跟底下听听去。"
        },
        {
          "character": "李相公",
          "type": "内白",
          "text": "啊二娘，自我走后，大娘待你如何？"
        },
        {
          "character": "二奶奶",
          "type": "内白",
          "text": "自从相公走后，大娘终日打、每日骂哟！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "哈哈！这两个不要脸的！一声儿没言语，睡啦。谁也甭睡安定了！ 咳！两个不要脸的给我滚出来吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童、李相公、二奶奶同上。书童下。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "二奶奶您辛苦啦！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "岂敢岂敢！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "这不是相公吗？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "他是相公啊！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我知道。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "知道吗，你问？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我要问！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "你问吧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你多咱回来的呀？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "他昨儿晚上回来的。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "没问你！你回来怎么不上我屋里去呀？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "他上你屋去，我屋里不是票了吗。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你当我当着相公，不敢打你哪？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "你敢打！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我说打就打。"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "慢来慢来！我今日才得回来，就是这样吵吵闹闹，真真气死我也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李相公搬椅欲坐，大奶奶撤椅欲坐，二奶奶撤椅。邻居甲、邻居乙同上。"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "邻居甲",
          "type": "唱",
          "text": "忽听得那一呀哈， 那一呀哈哈啊哈哈， 街坊家闹哇吵吵， 那一呀哈，那一呀哈！"
        },
        {
          "character": "邻居乙",
          "type": "唱",
          "text": "半夜里呀，三更天睡也睡不着哇！"
        },
        {
          "character": "邻居甲",
          "type": "唱",
          "text": "睡不着那一呀哈，你就该起来坐着。"
        },
        {
          "character": "邻居乙",
          "type": "唱",
          "text": "倒不如哇，上前去细问根苗哇，那一呀哈。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邻居乙一拍邻居甲的肩膀，邻居甲往前一看，邻居乙对着邻居甲的臀部说。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "你听见没有？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "你怎跑我这儿打电话来啦！"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "隔壁儿李相公三更半夜放着觉不睡，为什么这么打打呱呱、骂骂咧咧的？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "依你便怎么样哪？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "咱们给劝劝去。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "三辈子修不下好街坊。走！"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "别走！到了。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "别倒！留着喂狗。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "你自己吃吧。你瞧见没有？还是半掩门儿。推开了，来个大敞门儿。进来进来！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "见见当家人。 李相公！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "二位到此何事？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "三更半夜。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "半夜三更。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "放着觉不睡。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "为什么这么打打呱呱、骂骂咧咧？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "家务事一言难尽。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "老二呀，你知道“一言难尽”吗？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "不知道哇！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "“一言难尽”，就是“难尽一言”吗！"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "别挨骂了！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "见见大奶奶！"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "大奶奶，我们这儿有礼啦！"
        },
        {
          "character": "大奶奶",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "得！大奶奶裂啦！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "什吗？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "乐啦！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我当是谁呢，原来是二位老王八！"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "老人家！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你们三更半夜放着觉不睡，来意我知道啦。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "干什么来啦？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "上我们这儿端尿盆儿来了吧？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "不干那差事。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "那么你们干什么来了？"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "三更半夜，你们放觉不睡，为什么这么打打呱呱，骂骂咧咧？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "二位老人家，别人家的事，你们不知道；惟有咱们家的事——"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "你们家的事？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "没有你们二位不知道的。"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "也有知道的，也有不知道的。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我们相公在家的日子少，出外的日子多，也不是听了哪个坏种、嘎杂子的话啦， 又娶了这么一个二奶奶。自从把她娶进门来，把我好有一比！"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "比作什么？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "好比那伤风的鼻涕——可就给我们甩啦！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "这一甩可难受哇！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "甩啦，也不要紧。我们相公昨儿个晚上回来，一声儿没言语就上她那屋里睡去 啦。有知道的说我们相公不好，有那不知道的呢，说我们娘儿们吃醋捏酸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大奶奶把鼻涕甩在邻居甲脸上。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "得！我给吃了。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "那多脏啊！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "这个！大补元气。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "不能听一面之词，见见二奶奶。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "对！"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "二奶奶，我们这儿有礼啦！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我当是谁哪，原来是二位老乌龟。"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "什么？老邻居。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "你们二位放着觉不睡，你们的来意，我知道啦，八成上我们这儿吃接奶来了吧？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "不！不！我这么大岁数不吃接奶啦。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "干什么来啦？"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "你们放着觉不睡，为什么这么打打呱呱，骂骂咧咧？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我们相公自从把大奶奶娶过门来，有这么七八年啦，老也没开过怀儿。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "噢！没生养过。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "什么，你说我没开过怀儿？你们打听打听，太太在娘家养活过七八个——"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "什么？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "小猫儿、小狗儿的。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "好！吓我一跳。二奶奶您接着说！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "把我们娘儿们娶过门来，为的是生儿呀——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二奶奶拍邻居甲肩膀。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "养女！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二奶奶拍邻居乙肩膀。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "大哥！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "老妹子！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "常言说的好：“春天不下种，苗打何处生”啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二奶奶把鼻涕甩在邻居乙脸上。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "我瞧你怎么啦？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "得！我也吃了。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "吃了怎样？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "专治咳嗽。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "老二呀，你说她们这是为什么呀？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "为吃醋。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "胡说，瞧你这么大岁数说这话！不为吃醋。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "为什么？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "为吃陈醋。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "更酸。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "你有主意没有？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "把她们的家给分了吧。"
        },
        {
          "character": "大奶奶、二奶奶",
          "type": "同白",
          "text": "我们过好好的日子，不分家！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "她们不分家。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "分家跟分家不同。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "怎么不同？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "这一个月，分为两半个月：一个占上半个月，一个占下半个月。省得她们这么 打打呱呱，骂骂咧咧。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "这个主意不错。 李相公、大奶奶、二奶奶站齐了！ 老汉，你说吧！"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "给你们把家分了吧！"
        },
        {
          "character": "李相公、大奶奶、二奶奶",
          "type": "同白",
          "text": "我们不分家！"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "分家跟分家不同。"
        },
        {
          "character": "李相公、大奶奶、二奶奶",
          "type": "同白",
          "text": "怎么不同？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "这一个月，分为两半个月：一个占上半月，一个占下半月。省得你们这么打打 呱呱、骂骂咧咧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我占上半个月！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我占上半个月！"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "劝！劝！劝！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "慢来慢来！你也占上半月，她也占上半月，这下半月我往哪里去呀？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "你上我那儿寻宿儿去呀！"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "干脆抽签儿吧！"
        },
        {
          "character": "大奶奶、二奶奶",
          "type": "同白",
          "text": "抽签有假。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "摇会，谁摇的点儿大，谁占上半月。"
        },
        {
          "character": "大奶奶、二奶奶",
          "type": "同白",
          "text": "我们听信儿。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "谁有骰子？ 李相公有骰子没有？"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "无有。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "大奶奶有骰子没有？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "二奶奶有骰子没有？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "没嘚。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "也没有。 老汉，你有没有？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "我劝架，带骰子干什么！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "劝架怎能不带骰子呢？往后连麻将牌都得带着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邻居甲掏。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "瞧见没有，“四平头”。过过眼，给你们搁里头啦。谁先摇吧？"
        },
        {
          "character": "大奶奶、二奶奶",
          "type": "同白",
          "text": "我先摇！我先摇！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "大奶奶在大，大奶奶先摇。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你们二位谁是我跟前的——"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "什么？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "说合人儿呀！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "有我们二位。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "劳您驾，给我助助威。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "您放心吧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我得叨念叨念。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "你骂谁呢？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我祷告呢！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "祷告谁？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "祷告马王爷。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "马王爷管什么？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "马王爷三只眼，中间儿的那只眼单管咱们娘儿们的事。 娼妇！贱人！今天跟你摇会，明天还与你抽签哪！"
        },
        {
          "character": "大奶奶",
          "type": "唱",
          "text": "拜上拜上多拜上， 拜上马王听端详： 保佑弟子得了会， 一封清香答上苍。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "别瞧！有人瞧。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "瞧可是瞧，可别给我碰了！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "要是碰了呢？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "碰了，给我包出来！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "包不起。哈哈！好大点儿。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "多大点儿？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "两六、一个五——十七点。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "道喜道喜！"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "大奶奶，您大喜啦！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我不洗，修脚穿袜子。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "这会您得了。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我摇了多少点儿？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "十七点。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "真的？我瞧瞧去。啊哈哈哈……二位老人家，可不是十七点吗！瞧这个骰花儿 呀，可就瞧出咱们娘儿们的良心来啦。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "好，在手心儿里哪！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "这叫做：人容天不容！人容天不容来吧，差！差！差！叫二奶奶摇吧。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "二奶奶，请您摇会！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "大奶奶摇了多少点儿呀？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "十七点。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "一共多少点儿呀？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "一共十八点。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "还有一点，我不摇了，我们让啦！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "老汉哪，二奶奶这一让可上书了。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "上什么书啊？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "“四书”。圣人云：二奶奶见会不摇者，真乃节妇也。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "别胡说啦！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "大奶奶，二奶奶不摇了，人家让了。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "什么，让啦？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "对咯。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "不行，偏得叫她摇！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我不摇！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "要你摇！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "偏不摇！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "要你摇！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "偏不摇！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "劝！劝！劝！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "你就碰它一碰。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "对，我就碰它一碰。二位老人家，谁是我跟前的——"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "说合人呀。"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "有我们哪。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我得祷告祷告。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "祷告谁？"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "祷告金花娘娘，她单管我们这摇会的事。 娼妇！贱人！今天跟你摇会，明天还跟你抽签呀！"
        },
        {
          "character": "二奶奶",
          "type": "唱",
          "text": "拜上拜上多拜上， 拜上金花老娘娘： 保佑弟子得了会， 一炷清香答上苍。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我瞧瞧！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "别动！有人瞧！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "别给碰了，要是碰了，性命牵连。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "我瞧。哈哈，好大点儿！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "多么大的点儿？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "“三块煤”黑呼呼——十八点。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "道喜去。 二奶奶大喜啦！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "是姑娘，是小子呀？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "谁催生来啦？这个会呀，您得了！"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我摇了多少点儿呀？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "十八点。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "真的吗？"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "真的。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "我瞧瞧去。啊哈哈哈……可不是十八点吗！二位老人家，瞧这个骰花儿可就瞧 出我们的良心来啦。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "好，在胳肢窝里哪。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "这才是：人容天不容！人容天不容来吧，差！差！差！告诉她去！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "大奶奶这会——"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我得啦。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "您哪，票啦！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "她摇了多少？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "十八点。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "真的？我瞧瞧去。可不是十八点吗！这是摇的吗？八成是摆的吧？这是谁的骰 子？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "我的。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "连人带骰子都给我滚出去！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "哈哈！好哇！你糟蹋会头。 李相公，赔骰子！"
        },
        {
          "character": "李相公",
          "type": "白",
          "text": "给你二两银子。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "你还扔不扔了？我还有呢。 老汉哪，这架劝不了啦们走吧！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你们回来。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "八成又给二两。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "二位老人家，今天这会是二奶奶得啦，我在大，她在小，我脸上抹不开，我要 买这只会。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "拿什么买哪？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "我娘家赔送的簪环首饰、四季衣服、坐桶、马桶，还有一根儿——"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "棒锤！"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "我给您言语一声儿。 二奶奶，大奶奶要买您这只会。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "拿什么买呀？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "簪环首饰、四季衣服、还有一根——"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "棒锤。"
        },
        {
          "character": "二奶奶",
          "type": "白",
          "text": "要有卖这会的，我还买哪。 相公，咱们睡觉去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二奶奶拉李相公同下。"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "大奶奶，人家说要有卖这会的，她还买哪！"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "二位劳您驾。"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "好说。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "你们二位站齐了！"
        },
        {
          "character": "邻居甲、邻居乙",
          "type": "同白",
          "text": "要谢谢咱们。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "给我滚出去吧。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "得！推出来啦。"
        },
        {
          "character": "邻居甲",
          "type": "白",
          "text": "我没白来，闹二两。"
        },
        {
          "character": "邻居乙",
          "type": "白",
          "text": "我偷他一根蜡。那边儿又打起来了。劝劝去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邻居甲、邻居乙同下。"
        },
        {
          "character": "大奶奶",
          "type": "白",
          "text": "他们睡觉去啦。有来，我上吊，吓唬吓唬他们。 我上吊咯！ （李相公、二奶奶同上，大奶奶用手绢套李相公的脖子，二奶奶用手绢套李相公的脖子，大奶奶、二奶奶同 拉李相公下。）"
        },
        {
