        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "啊，哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "汤怀、何元庆、张宪、张奎",
