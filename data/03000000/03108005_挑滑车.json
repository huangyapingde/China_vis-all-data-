        {
          "character": "高宠",
          "type": "白",
          "text": "且慢！元帅，今当圣驾在此，末将要在元帅台前领教。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "何事如此？"
        },
        {
          "character": "高宠",
          "type": "白",
          "text": "元帅，末将虽是不才，既已将身许国，自当竭尽绵薄，报效朝廷。今日大战番 营，全营将官俱有差遣，单是末将无差，难道我是那无用之辈么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "用者当用，本帅焉有不识将才之理。今观将军神色不正，两军阵前，恐有闪失， 故而未敢相委。"
        },
        {
          "character": "高宠",
          "type": "白",
          "text": "元帅之言差矣！为大丈夫者，临阵交锋，生而无欢，死而何惧；不入虎穴，焉 得虎子！"
        },
        {
          "character": "高宠",
          "type": "唱",
          "text": "高宠一心把国保， 杀敌救主立功劳！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "高将军既然讨令，就命你执掌军中大纛旗。此乃军中之大任，不可擅离！"
        },
        {
          "character": "高宠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高宠叹气，失望下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "请主到校场祭旗。"
        },
        {
          "character": "皇帝",
          "type": "白",
          "text": "吩咐摆驾。"
