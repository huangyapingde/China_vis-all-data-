        {
          "character": "岳飞、李刚、王渊、何元庆、张宪、汤怀、郑怀、张奎、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。众人同走圆场，同下。"
