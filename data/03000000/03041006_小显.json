{
  "script_id": "03041006",
  "title": "小显",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "罗成",
      "hangdang": "小生"
    }
  ],
  "plot": "罗成死后，李世民等往祭之。罗成显魂诉苦，并托后事。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。四鬼卒引罗成同上。"
        },
        {
          "character": "罗成",
          "type": "点绛唇",
          "text": "豪气冲霄，英风飘渺，魂魄绕，胆战心摇，何日将仇报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上高台。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "身前为大将，死后作忠魂。捐躯何足论，英名万古存。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "吾乃越国公罗成鬼魂是也。只因苏烈兴兵犯界，圣上命元吉挂帅，命俺为前战 先行。不想被奸王陷害，在淤泥河乱箭身亡。今有二主秦王与众家国公前来吊 祭。不免前去托妻寄子，把我的苦处细表一番。 众鬼卒！"
        },
        {
          "character": "四鬼卒",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "驾风前往！"
        },
        {
          "character": "四鬼子",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下高台。扯四门。"
        },
        {
          "character": "罗成",
          "type": "唢呐二黄原板",
          "text": "黑暗暗雾沉沉随风飘荡， 冷飕飕凄惨惨转回家乡。 我主爷来吊孝龙驾光降， 众王侯见灵台也要悲伤。 叫鬼卒！"
        },
        {
          "character": "四鬼卒",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "罗成",
          "type": "唢呐二黄原板",
          "text": "驾阴风急忙——"
        },
        {
          "character": "罗成",
          "type": "唢呐二黄散板",
          "text": "前往，"
        },
        {
          "character": "四鬼卒",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒同下。"
        },
        {
          "character": "罗成",
          "type": "唢呐二黄散板",
          "text": "可叹我英雄汉乱箭身亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场设灵堂。〖牌子〗。门子上，打扫灵堂。罗春上，罗妻抱罗通上。"
        },
        {
          "character": "罗妻",
          "type": "引子",
          "text": "儿夫含冤死，母子茹悲辛。"
        },
        {
          "character": "四龙套",
          "type": "内同白",
          "text": "二主驾到！"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "批牌子。四龙套、秦琼、徐勣、尉迟恭、程咬金引李世民同上，同祭灵。四龙套同下。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "妾夫有何德能，敢劳二主与众家国公前来吊祭！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "王兄为国身亡，礼当如此。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "真乃有道明君！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王要在此陪灵。众家国公俱在灵堂陪伴小王一宵。"
        },
        {
          "character": "秦琼、徐勣、尉迟恭、程咬金",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、秦琼、徐勣、尉迟恭、程咬金、罗妻、罗春同打盹。〖起二更鼓〗。"
        },
        {
          "character": "罗成",
          "type": "内二黄导板",
          "text": "天下荒荒无真主，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒引罗成同上，罗成立椅。"
        },
        {
          "character": "罗成",
          "type": "回龙",
          "text": "上苍降下了紫薇星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下椅。"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "青龙投胎太原郡， 那燕山又降下白虎星。 俺生在罗门为公子， 长大成人武艺超群。 一十七岁保唐主， 俺也曾东荡西除、南征北战、昼夜杀砍、到如今只落得一命归阴。 将身儿且把灵堂进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成进灵堂，上灵台。"
        },
        {
          "character": "罗成",
          "type": "二黄原板",
          "text": "又只见我主爷瞌睡沉沉。 众国公一个个俱已困， 苦命的娇妻伴我灵。 义子罗春身戴孝， 最可叹无依无靠、孤苦伶仃、三岁的罗通好不伤心。"
        },
        {
          "character": "罗成",
          "type": "哭头",
          "text": "我的儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "罗成",
          "type": "西皮导板",
          "text": "恨只恨三千岁挂了帅印，"
        },
        {
          "character": "罗成",
          "type": "西皮慢板",
          "text": "俺罗成倒作了马前先行。 头一阵枪挑了李天寿， 有功不赏反加刑—— 责打了为臣我四十军棍， 身带棍伤还要出兵。 从清晨杀到了——"
        },
        {
          "character": "罗成",
          "type": "西皮二六板",
          "text": "午时正， 午时杀到夜黄昏。 紧闭四门——"
        },
        {
          "character": "罗成",
          "type": "西皮快板",
          "text": "不得进， 单人独骑我杀退贼兵。 淤泥河，遭围困， 飞蝗骤雨箭穿身。 望求千岁奏一本， 说俺罗成死惨情。 母老妻娇要照应， 三岁的罗通也要加恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。罗成下灵台。"
        },
        {
          "character": "罗成",
          "type": "西皮摇板",
          "text": "若要君臣重相会， 大破龙门臣见君。 （四鬼卒引罗成同下。〖起五更鼓〗。李世民、秦琼、徐勣、尉迟恭、程咬金、罗妻、罗春同醒。四龙套同 暗上。）"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "我等告辞了。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "多谢二主与众家国公！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "摆驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "批牌子。四龙套、秦琼、徐勣、尉迟恭、程咬金引李世民同下。"
        },
        {
          "character": "罗妻",
          "type": "白",
          "text": "夫哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗妻哭。罗春、罗妻抱罗通同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}