{
  "script_id": "03058004",
  "title": "青峰岭",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "徐凤英",
      "hangdang": "武旦"
    }
  ],
  "plot": "刘飞虎、江老鼠霸占青峰岭，田虎之妻徐凤英力败刘飞虎、江老鼠，占其山。蔡京命旗牌李虎押解粮饷往太\n原，路过岭前，为徐凤英所擒，夺去粮饷。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四女兵领徐凤英同上，徐凤英起霸。"
        },
        {
          "character": "徐凤英",
          "type": "念",
          "text": "头戴金盔凤翅飘，身披铠甲络丝绦。腰挎三尺龙泉剑，要学男儿女英豪。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "奴，徐凤英。奉了大王之命，夺取青峰岭。 众女兵！"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "杀上前去！"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵引刘飞虎、江老鼠同上，刘飞虎、江老鼠同起霸。"
        },
        {
          "character": "刘飞虎",
          "type": "点绛唇",
          "text": "霸占青峰，"
        },
        {
          "character": "江老鼠",
          "type": "点绛唇",
          "text": "我又一个霸占青峰，"
        },
        {
          "character": "刘飞虎",
          "type": "点绛唇",
          "text": "论英雄，八面威风！"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "这几日，我的大便不通。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "大便不通，你就该吃巴豆。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "我害怕。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "怕什么？"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "怕的是拉稀跑肚。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "一蹬儿，两蹬儿，上头挂着红杏儿。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "一耗子，上灯台，偷油吃，下不来。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "南通州，北通州，南北通州通南北。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "东当铺，西当铺，东西当铺当东西。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "大大王、刘飞虎。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "二大王、江老鼠。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "你我弟兄霸占青峰岭，倒也逍遥自在。只是山寨缺少粮草，这便如何是好？"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "这有何难！且命喽啰们下山，拔他们几根烟袋拿上山来，也够你我弟兄使用。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "哎呀贤弟，你好大才小用！想当初抽旱烟使的是白铜锅、虎皮杆、翡翠嘴，拿 上山来，也够你我使用。如今抽的是洋烟卷，每人手里拿着根火燎杆，拿上山 来，怎够你我弟兄使用？"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "且听探马一报。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "徐凤英讨战！"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "刘飞虎",
          "type": "扑灯蛾",
          "text": "心中乱如麻，乱如麻。"
        },
        {
          "character": "江老鼠",
          "type": "扑灯蛾",
          "text": "两腿弹琵琶，弹琵琶。"
        },
        {
          "character": "刘飞虎",
          "type": "扑灯蛾",
          "text": "人说凤英武艺好，"
        },
        {
          "character": "江老鼠",
          "type": "扑灯蛾",
          "text": "哪个男儿胜似她！"
        },
        {
          "character": "刘飞虎",
          "type": "扑灯蛾",
          "text": "今日下山与她战，"
        },
        {
          "character": "江老鼠",
          "type": "扑灯蛾",
          "text": "明日下山与她杀。"
        },
        {
          "character": "刘飞虎",
          "type": "扑灯蛾",
          "text": "战战战！"
        },
        {
          "character": "江老鼠",
          "type": "扑灯蛾",
          "text": "杀杀杀！"
        },
        {
          "character": "刘飞虎",
          "type": "扑灯蛾",
          "text": "杀她不过，"
        },
        {
          "character": "江老鼠",
          "type": "扑灯蛾",
          "text": "我趴在地下认干妈。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "得啦，愣叫她打死，别叫她麻死！"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "咱们跟她嘎啦嘎啦。"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "来呀！带我的走狗！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵、徐凤英同上，会阵。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "呔！二贼通名受死！"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "大大王刘飞虎！"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "二大王江老鼠！"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "你怕我不怕？"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "尔等将山寨献出，如若不然，刀下做鬼！"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "你跟她嘎啦嘎啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江老鼠下。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "徐凤英啊徐凤英！我看你年纪小，脚儿好，我劝你下得马来，跟我拜了天地， 你看好也不好？"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "一派胡言！放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐凤英、刘飞虎同起打。刘飞虎、四喽兵同败下，徐凤英、四女兵同追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "乱锤。刘飞虎、江老鼠同上。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "哎呀贤弟呀！徐凤英杀法厉害，如何是好？"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "我倒有个主意：你蹲下我骑着你。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "你别挨骂啦！"
        },
        {
          "character": "徐凤英",
          "type": "内白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐凤英、四女兵同上，同开打。刘飞虎、江老鼠同败下，徐凤英、四女兵同追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘飞虎、江老鼠自两边分上。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "得啦！你把水都闹浑啦。我瞧出来啦，她要咱们的青峰岭，你有主意没有？"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "我是一点主意也没有。这可怎么好哇？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "我倒是有主意。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "你有什么主意？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "你蹲下。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "蹲下干嘛？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "我骑着你。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "你别挨骂啦。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "干脆！咱们把青峰岭让给她就结啦。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "就这么一说，就让给她？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "让给她！"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "让给她？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "让给她。不让给她怎么办？"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "让给她就让给她吧。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "我给她前面引路。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "我给她牵马坠镫。"
        },
        {
          "character": "徐凤英",
          "type": "内白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐凤英、四女兵同上。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "二贼还不将山寨献出？"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "得啦！拿您这么个人，干嘛跟我们俩嘎杂子一般见识。您的来意，我们明白啦， 情愿将青峰岭，奉送您啦！"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "我给您哪牵马，"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "我给您哪引路。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "如此带路上山！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、刘飞虎、江老鼠引四女兵、徐凤英同上。"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "咱们见见新寨主。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘飞虎、江老鼠同向徐凤英。"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "参见新寨主！"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "你二人有何本领？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "我们哥俩，一点能力也没有。我就会放屁。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "我就会尿炕。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "仓库有何钱粮？快快献出！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘飞虎、江老鼠同背供。"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "有的，狼到咱们哥儿俩这儿啦，那咱们跟她说去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘飞虎、江老鼠同向徐凤英。"
        },
        {
          "character": "刘飞虎、江老鼠",
          "type": "同白",
          "text": "我告诉您说：我们哥儿俩一个大也没有。我们要是有，不在您身上花，那算我 们哥儿俩不会花，我们哥儿俩连饭落子也还没哪。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "这有何难！这有令旗一面，去到湖北田虎帐下，必然收留你等，去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐凤英付令旗。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "你瞧这个。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "念什么？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "这个念“今日准演”的“今”。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "这个念“全体大会”的“会”。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "得啦！别胡说啦，这个念“令”。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "念“令”？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "念“令”。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "有什么用？"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "用处大啦。咱们进了饭馆，什么好吃，咱们要什么吃；什么好喝，咱们要什么 喝；一吃一喝，吃的酒足饭饱，咱们拿起这个来，就这么一晃，一个大不给， 站起一走。"
        },
        {
          "character": "江老鼠",
          "type": "白",
          "text": "不用说，人家臭奏一通。"
        },
        {
          "character": "刘飞虎",
          "type": "白",
          "text": "嘿嘿！人家扒衣裳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江老鼠、刘飞虎同下。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "众女兵，两厢搜来！"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵同搜。"
        },
        {
          "character": "四女兵",
          "type": "同白",
          "text": "四下皆空。"
        },
        {
          "character": "徐凤英",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "李虎",
          "type": "内白",
          "text": "车夫们，趱行者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手引李虎同上。"
        },
        {
          "character": "李虎",
          "type": "念",
          "text": "虎背熊腰豹子胆，志气凌云八面威。"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "俺、旗牌官李虎。奉了蔡相钧旨，押解饷银，去往山西太原交纳。看前面这座 高山峻岭，惯出歹人。 嘚！车夫们，弓上弦，刀出鞘，过了此岭，方保无虞。速速趱行者！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
