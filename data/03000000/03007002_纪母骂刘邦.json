{
  "script_id": "03007002",
  "title": "纪母骂刘邦",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "纪母",
      "hangdang": "老旦"
    },
    {
      "name": "刘邦",
      "hangdang": "老生"
    }
  ],
  "plot": "汉高祖刘邦平定天下后，大封功臣；惟对荥阳替死之纪信，不与封典。群臣请求追封，刘邦反谓纪信冒称君\n王，功不抵罪。随何不满，告知纪信之母。纪母极为愤怒，亲至金殿责骂。刘邦格于众议，乃饰词辩解，重\n予封赠。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张良、萧何、韩信、陈平、樊哙、随何同上。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "下官张良。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "下官萧何。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "下官韩信。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "下官陈平。"
        },
        {
          "character": "樊哙",
          "type": "白",
          "text": "下官樊哙。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "下官随何。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "列位公侯请了！"
        },
        {
          "character": "萧何、陈平、樊哙、随何",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "天下已定，我主大封功臣，分茅列土，加官进爵。今在未央宫赐宴，我等躬逢 其盛。远远望见圣驾来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引刘邦同上。"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "臣等接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良、萧何、韩信、陈平、樊哙、随何同迎进。"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "臣等见驾，愿我皇万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "内侍摆宴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同摆宴。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿请！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "万岁请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤自斩蛇起义以来，灭秦破楚，抚有天下。虽赖众卿之功，实赖三杰之力也！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "请问万岁何谓三杰？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "运筹决胜，孤之智谋，不如张良；用兵布阵，孤之韬略，不如韩信；理财行政， 孤之才能，不如萧何。此三人乃当世之人杰也。孤何幸而得之！"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "虽三杰有功于国，然非万岁不能知；亦非万岁不能用也。"
        },
        {
          "character": "张良、韩信、萧何",
          "type": "同白",
          "text": "谢万岁！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "子房智略世少有； 韩元帅乌江用计谋； 萧丞相治国是好手， 众卿戮力大功收。 内侍与孤斟美酒， 君臣同饮太平瓯。"
        },
        {
          "character": "萧何",
          "type": "唱",
          "text": "萧何席间正饮酒， 忽然一事上心头， 急忙离席来启奏， 尊声万岁听根由： 纪信荥阳功为首， 可怜他替主一命休； 今日诸臣受恩厚， 请万岁追封到荒坵。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "刘邦闻言双眉皱， 卿家奏本没来由。 当日荥阳孤逃走， 纪信登车赚楚囚。 虽然救驾功劳有， 假扮天子罪为头。 将功折罪孤不究， 往事休提一笔勾。 丞相开怀且饮酒， 人死何必再封侯。"
        },
        {
          "character": "萧何",
          "type": "唱",
          "text": "萧何不敢再开口，"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "张良一旁暗点头。"
        },
        {
          "character": "韩信",
          "type": "唱",
          "text": "韩信座上把眉皱，"
        },
        {
          "character": "陈平",
          "type": "唱",
          "text": "陈平低头自揣忧。"
        },
        {
          "character": "樊哙",
          "type": "唱",
          "text": "樊哙怒气冲牛斗，"
        },
        {
          "character": "随何",
          "type": "唱",
          "text": "随何不语泪双流。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "众卿放量多饮酒， 畅饮葡萄饱珍馐。 宴罢之后袍袖抖，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦下。"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同唱",
          "text": "臣等送驾转龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良、陈平、萧何、韩信、樊哙同下。"
        },
        {
          "character": "随何",
          "type": "唱",
          "text": "随何此刻心难受， 腹中好似浇滚油。 他将忠臣当猪狗， 救驾替死不封侯。 怒冲冲出离了宫门口， 见了伯母说从头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "纪母上。"
        },
        {
          "character": "纪母",
          "type": "引子",
          "text": "两鬓苍苍，痛吾儿，为国身亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪夫人、纪子同上。"
        },
        {
          "character": "纪夫人",
          "type": "引子",
          "text": "大节凛冰霜，抚孤子，奉养高堂。"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "婆婆万福！"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "罢了。坐下。"
        },
        {
          "character": "纪子",
          "type": "白",
          "text": "参见祖母！"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "罢了。 媳妇！自你丈夫在荥阳替主赴难，随何有信也曾言道，汉王发下誓愿，母受鸿 恩，子食俸禄，至今未受半点恩荣。从前还可说是干戈未息，无暇及此；如今 天下已定，为何不见恩诏，莫非汉王食言乎？"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "儿观汉王，鹰顾狼视，可与共患难，不可与共富贵。况我家薄有良田，尚堪度 日；当日伤心之事，婆婆提它作甚？"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "嗐！儿呀！"
        },
        {
          "character": "纪母",
          "type": "唱",
          "text": "坐草堂未开言痛心疾首， 想起了纪信儿珠泪双流。 当日里荥阳城功劳少有， 舍性命替君难楚营去投。 那项羽中巧计汉王逃走， 他临行发誓愿必有报酬。 到如今干戈息音信无有， 因何故加恩诏不下龙楼！"
        },
        {
          "character": "纪夫人",
          "type": "唱",
          "text": "老婆母休得要双眉紧皱， 年迈人禁不住万种忧愁。 儿虽死孙已长忠臣有后， 我家中尚温饱薄有田畴。 创业君哪一个思念故旧， 到后来飞鸟尽良弓必收。"
        },
        {
          "character": "纪母",
          "type": "唱",
          "text": "但愿得老天爷多多保佑， 一家人守田园快乐无忧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何上。"
        },
        {
          "character": "随何",
          "type": "唱",
          "text": "怒气不息向前走， 见了伯母说原由。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "伯母在上，侄儿拜揖。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "贤侄少礼。落坐。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "谢坐。 啊，嫂嫂！"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "叔叔！"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "贤侄公事勤劳，何暇至此？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "小侄今日为一事前来。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "为了何事？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "现今天下大定，汉王正位，大封功臣，小侄等皆已封侯赐爵。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "有功必赏，真乃有道明君！"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "说什么有道明君，据侄看来是无道昏君！"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "伯母！想当日我兄长替君赴难之后，小侄有信前来，言道：汉王发下誓愿，富 贵同享，以酬救主之功。伯母可记得否？"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "以往之事提它作甚？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "伯母、嫂嫂有所不知。昨日汉王大宴功臣，萧何奏请汉王，要追封我兄救驾之 功。那汉王反说：假扮天子大逆不道，就该问斩，既然人死，也不深究；功不 掩罪，断无封侯之理！"
        },
        {
          "character": "纪母",
          "type": "哭",
          "text": "哎呀！"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "婆婆醒来！"
        },
        {
          "character": "纪母",
          "type": "西皮导板",
          "text": "闻此言气得我浑身乱抖，"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "好昏君！"
        },
        {
          "character": "纪母",
          "type": "唱",
          "text": "大骂昏王礼不周。 忘却荥阳将你救， 我儿替死一命休。 当日誓言出你口， 反而无情恩作仇。 越思越气难忍受， 即刻上殿辩理由。"
        },
        {
          "character": "纪夫人",
          "type": "西皮摇板",
          "text": "母亲年高六十九， 好似风烛泪双流。 何必上殿去斗口， 争此虚名不如休。"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "汉王威权真少有， 一言不合斩人头。 我劝伯母且罢手， 怕得是此去命难留。"
        },
        {
          "character": "纪母",
          "type": "西皮摇板",
          "text": "人生不过百年寿， 忠义名儿万古留。 他将我儿当猪狗， 死后尚且不封侯。 怎忍胸中气一口， 拼着老命闯龙楼。 随何带路快快走！"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "母亲去不得！"
        },
        {
          "character": "纪母",
          "type": "西皮摇板",
          "text": "儿等不必苦攀留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪母下。"
        },
        {
          "character": "纪夫人",
          "type": "西皮摇板",
          "text": "叔叔保护随娘后，"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "嫂嫂放心谅无忧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何下。"
        },
        {
          "character": "纪夫人",
          "type": "西皮摇板",
          "text": "此去吉凶猜不透， 手掩柴扉泪双流。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪夫人拉纪子同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、张良、韩信、陈平、樊哙、萧何、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "耳听得三声长乐钟， 摆驾出了未央宫。 灭秦破楚归一统， 全仗文臣武将功。 韩信有谋樊哙勇， 还有那萧何、张良、与陈平。 泗上亭长真侥幸， 天命攸归定太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何上。"
        },
        {
          "character": "随何",
          "type": "唱",
          "text": "纪母已在朝门等， 引见汉王诉不平。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "臣随何见驾，愿吾皇万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "启奏万岁：今有纪信之母有本口奏，朝门候旨。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "金殿乃尊严之地，岂是妇女出入之所，见她作甚？"
        },
        {
          "character": "张良、萧何、韩信、陈平、樊哙、随何",
          "type": "同白",
          "text": "启奏万岁：亡臣纪信与臣等同共患难，匪伊朝夕。其母既有本口奏，陛下当念 荥阳替主赴难之功，容她上殿，以显圣德汪洋，厚待功臣之意。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿所奏，正合孤意。 内侍宣纪太君上殿！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "宣纪太君上殿！"
        },
        {
          "character": "纪母",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪母上。"
        },
        {
          "character": "纪母",
          "type": "唱",
          "text": "忽听金殿宣一声， 来与亡儿诉不平。 既到此间舍了命， 怒气不平立殿廷。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "皇伯母怒气不息，上得殿来有何本奏？"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "你还是明知，还是故问？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤焉能知伯母心中之事？ 内侍，看坐！ 皇伯母有本慢慢奏来。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "嗐！万岁啊！"
        },
        {
          "character": "纪母",
          "type": "唱",
          "text": "未曾开言心酸痛， 尊声万岁听分明： 今日江山归一统， 可记得当年荥阳城。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "寡人闻言龙心痛， 想起当年救驾功。 替孤赴难丧了命， 折孤的良将怎不疼！"
        },
        {
          "character": "纪母",
          "type": "唱",
          "text": "既是万岁念前功， 亡儿在黄泉也感情。 但是满朝加恩重， 为什么纪信不追封？"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "恨孤王酒醉乱了性， 萧何奏本未分明。 君无戏言保信用， 因此不能再追封。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "纪母",
          "type": "西皮二六板",
          "text": "未曾开言叹一声， 点点珠泪洒前胸。 我主被困荥阳境， 无有能将敌重瞳。 纪信登车虽丧命， 他不该头戴王帽、身穿黄袍，假扮天子，大逆不道有罪名。 万岁当日恩情重， 曾对苍天把誓盟。 母受皇恩子食俸， 我纪家代代儿孙享恩荣。 今日已然天下定， 功罪二字要分明。 纪信虽死罪未定， 争什么替主赴难到楚营全无半点功。 朝廷之上君言重， 愿代亡儿领罪名。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "闻言拭泪心酸痛，"
        },
        {
          "character": "韩信",
          "type": "唱",
          "text": "可见人在有人情。"
        },
        {
          "character": "萧何",
          "type": "唱",
          "text": "昨日酒醉今当醒，"
        },
        {
          "character": "陈平",
          "type": "唱",
          "text": "我看君王怎样行！"
        },
        {
          "character": "樊哙",
          "type": "唱",
          "text": "鸿门宴救驾我真侥幸，"
        },
        {
          "character": "随何",
          "type": "唱",
          "text": "他舍命救主是第一功臣！"
        },
        {
          "character": "刘邦",
          "type": "西皮二六板",
          "text": "皇伯母说话欠聪明， 酒后之言不可听。 当日荥阳誓言重， 昧却良心天不容。 皇伯母且把气平定， 细听孤王来加封： 皇伯母年高德又重， 一品太君享恩荣； 久闻皇嫂有贤性， 节义夫人受诰封； 贤侄年小难大用， 孝义郎冠戴把身荣。 一家满门食君俸， 再赐你黄金万两、彩缎百端送家中，表一表恩情。 修盖庙堂把忠臣供， 春秋致祭寡人要亲行。 龙书案上一声请， 请！请！请！伯母安然自在下龙廷。"
        },
        {
          "character": "纪母",
          "type": "西皮摇板",
          "text": "匍匐叩谢皇恩重， 一家大小受荣封。 非是吾贪图富贵求封赠， 功罪二字要分明。 创业之君受天命， 宽仁大度自不同。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪母下。"
        },
        {
          "character": "刘邦",
          "type": "西皮摇板",
          "text": "寡人金殿加恩宠， 怕的是将相寒心怨朝廷。 萧丞相进前孤有命： 从今后酒后不谈公。 君臣一笑浮云净，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良、萧何、韩信、陈平、樊哙、随何同下。"
        },
        {
          "character": "刘邦",
          "type": "西皮摇板",
          "text": "管教那群雄入壳中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦下。"
