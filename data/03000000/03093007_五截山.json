{
  "script_id": "03093007",
  "title": "五截山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "王平",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "黄忠",
      "hangdang": "老生"
    },
    {
      "name": "徐晃",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "张郃",
      "hangdang": "净"
    }
  ],
  "plot": "曹操遣徐晃、王平守汉水抵御蜀军，徐晃欲背水扎营，王平苦劝不听。兵败，徐晃反责王平。王平愤而投刘\n备，刘备用为向导使，杀败曹军。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四文堂、王平、徐晃同上。"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "领兵汉水把贼扫，"
        },
        {
          "character": "王平",
          "type": "唱",
          "text": "胜负全凭计谋高。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "王将军请了！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "你我奉了魏王钧旨，汉水截战，我欲命军士渡水列阵，待等黄忠、赵云到来， 一鼓擒之，将军意下如何？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "哎呀将军哪！我军若渡水列阵，倘蜀兵骤至，我军急切难退，如之奈如？"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "昔日韩信背水为阵，所谓“置之死地而后生”也！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "韩信因料定敌人无谋，故设此计。今将军能料黄忠、赵云之意么？"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "你且莫管，看我渡水取胜者！ 来，速搭浮桥，列阵防守，以待蜀兵到来！"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "军到急切必踊跃，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引徐晃同下。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "王平",
          "type": "唱",
          "text": "他不听我言把祸招。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、张著、黄忠、赵云同上。"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "鳌鱼脱去金钩钓，"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "猛虎归洞回山巢。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "请坐！老将军辛苦了！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "哎，说什么辛苦不辛苦，俺只道曹兵有限，故而带领五百小卒，同了张将军杀 到曹营大寨，心想劫他的粮草，夺他的军器。谁想到了北山角下，正待放火烧 他粮草，不料曹操亲统大兵数万，一拥而来，老夫左冲右闯，如入无人之境。 正在杀得高兴之际，忽见赵将军也在其内。"
        },
        {
          "character": "黄忠",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "这一战杀得好爽快也！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵某若不进去相请老将军出来，此时那些曹兵都被老将军杀尽了！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "尽哪却也难尽，只是杀得那贼东逃西散，兵将丧胆，虽未擒着张郃，眼见那贼 锐气尽也！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "如此，老将军之功也！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "黄忠、赵云、张著",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀二位将军：曹操亲统大兵，追到我营来了！"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "二位将军，曹军骤至，我军恐难抵敌，就该紧闭寨门才是！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "住了！此乃紧要关头，若要紧闭寨门，守则必死，弃则被擒！"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "依将军只见？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺在当阳，单枪匹马，觑那曹兵八十三万人马如同草芥。今日曹兵，何足惧哉！ 老将军后帐歇息。只须弓弩手百名，埋伏营外壕中，将旗鼓尽皆掩息，待俺 赵云独自立于门首，曹兵来时，但看俺枪尖一摆，万弩齐发也！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "俺非是沽名把誉钓，"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "但看曹兵鼠窜逃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手引张著、黄忠同下。赵云执枪上马站营门。四文堂、张郃、杜袭、曹洪、许褚、曹操、伞夫同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "启魏王：蜀营辕门大开，旗鼓皆无，只有赵云单枪匹马独自立于营门，此时不 可进兵！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待孤看来！ 唔呼呀，其中定有奸诈，快快收兵！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "放箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操惊。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "收兵收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、张郃、杜袭、曹洪、许褚、曹操、伞夫同逃下。四上手、张著、黄忠同上。"
        },
        {
          "character": "赵云、黄忠",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "赵云、黄忠",
          "type": "同白",
          "text": "追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖牌子〗。四龙套、刘封同上，刘封上高。四文堂、张郃、杜袭、曹洪、许褚、曹操、伞夫同拜上，过场，"
        },
        {
          "character": null,
          "type": "text",
          "text": "同下。赵云、黄忠、张著、四上手同追上。刘封下高。）"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "二位将军，刘封在此！"
        },
        {
          "character": "赵云、黄忠",
          "type": "同白",
          "text": "小将军因何至此？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "军师命我到此虚张声势，且喜曹操弃寨而逃，你我同去搬他粮草，好去报功。"
        },
        {
          "character": "赵云、黄忠",
          "type": "同白",
          "text": "言之有理。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "老将军请！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "可笑那曹瞒贼是伤弓之鸟，"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "未交锋即溃败胆破魂消。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "众将官检军器收拾粮草，"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "回到了大营中去表功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四文堂、王平、徐晃同上。"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "轰轰炮震响连天，"
        },
        {
          "character": "王平",
          "type": "唱",
          "text": "干戈不住民倒悬。"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "身披铠甲不辞倦，"
        },
        {
          "character": "王平",
          "type": "唱",
          "text": "骅骝几见解征鞍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四文堂、王平、徐晃同列阵，同下。赵云、黄忠、张著、四上手同上。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "堪笑曹操无识见，"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "望影而逃心胆寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、徐晃同冲上。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "呔，赵云！俺徐晃等候多时了！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "这厮好不知分晓！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "杀这匹夫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、徐晃同起打。四下手、徐晃同败下。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "徐晃渡水而去。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "不必追赶，回营去者！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "鼠辈无知何大胆，"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "我军得胜回营盘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、徐晃同败上。四文堂、王平暗同上。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "好杀呀，好杀！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "将军受惊了！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "我受的什么惊！你是王平？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "正是末将。将军为何如此？"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "我把你这贪生怕死的小辈，不知耻的匹夫！你我俱是奉命而来，便当协力相助， 蜀兵排山倒海杀到，你为何袖手不理？真真气死我也！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "将军要渡水列阵，王平也曾劝阻，你要学韩信背水拒敌的故事；我道赵云、黄 忠非比等闲，将军一定要如此而行！今番之败，乃是自取，怎么怪起末将来了！ 我若离此大营，只恐此时老营亦无救矣！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "你明明缩头保性命， 指东说西反怪人。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "速即王平推出斩，"
        },
        {
          "character": "四下手、四文堂",
          "type": "同白",
          "text": "元帅正与蜀兵交战，先斩大将，于军不利，望求元帅饶恕！"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "一捆四十不容情！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二下手押王平同下。幕内打王平。二下手搀王平同上。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "谢元帅的责！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "我打的你可公？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "不公！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "打的你可是？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "不是！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "可知食君之禄，当报君恩，须晓临敌不顾命！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "你可知道："
        },
        {
          "character": "王平",
          "type": "念",
          "text": "智士当要见机作，阘茸只念征战心。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "谁是智士，谁是阘茸？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "我虽不智，你便是阘茸！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "呸！赶出帐去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、徐晃同下。"
        },
        {
          "character": "王平",
          "type": "唱",
          "text": "我枉自随征空受任， 满腹雄才难显能。 含恨忍痛将己问，"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王平",
          "type": "唱",
          "text": "自不见机怨谁人！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平哪，王平！你还分什么智士、阘茸，是你自己不见机，误投奸人麾下。唉， 倒不如弃曹归刘，做个明哲保身。 军士们，尔等愿随者随，不愿随者各自散去！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "我等久有此心，怎奈将军未曾言过，今既如此，我等无不愿随！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "好哇！与我备下鞍马，焚烧营寨，一同投降去者！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同放火。四下手、徐晃同上。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "王平，你敢是反了？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "你老爷反了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平、徐晃同起打。徐晃败下，王平、四文堂同追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、徐晃同上。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "且住！王平背反我主，就此弃寨，报与魏王去者！"
        },
        {
          "character": "徐晃",
          "type": "唱",
          "text": "怎知王平要谋叛， 急速报与魏王前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、徐晃同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、张郃、杜袭、曹洪、许褚、曹操、伞夫同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "惭愧呀，惭愧！我道赵云带兵有限，故而亲率大兵追赶，不料他用了以逸待劳 之计。若非老夫识破，定然深入险地！ 众将官，后面追兵怎么样了？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "魏王只顾退兵，其实赵云早已收军了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "咳，孤遇这厮，几次失利，故而事事留心。如今兵败寨失，往何处驻扎方好？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "前面已是阳平关，那里可以屯军。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好，兵撤阳平关！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启魏王：赵云不过一旅之师，见我军潮涌而来，无可抵敌，故设此疑兵之计， 惊退我军。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "赵云哪，赵云，你的胆也忒大了；曹操哇，曹操，你的胆也忒小了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、四下手同上。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "参见魏王！"
        },
