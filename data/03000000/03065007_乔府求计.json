{
  "script_id": "03065007",
  "title": "乔府求计",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "乔玄",
      "hangdang": "老生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    }
  ],
  "plot": "鲁肃因刘备借荆州久索不还，至乔玄府中求计。乔玄为解析天下大势，指出孙、刘不宜轻起战端。鲁肃不纳\n其言，辞去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、鲁肃同上。"
        },
        {
          "character": "鲁肃",
          "type": "引子",
          "text": "只为荆州忧闷，终日不展愁眉。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "忆昔当年赤壁，火攻天下称奇。英雄沉于水底，曹瞒魄散魂飞。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "下官，鲁肃。只为桃园弟兄借去我国荆州屯兵养马，是我从中作保。昔日言明： 得了东西两川，即刻归还。如今他等东西两川俱得，全然不提荆州二字。吾 主为了此事，终日忧闷，有所谓：食君之禄，当报君恩。我想乔太尉乃是三朝 元老，胸中必有高见。不免去往乔府，求一妙计，讨回荆州。 左右，开道乔府。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "鲁肃",
          "type": "西皮原板",
          "text": "三国英雄纷纷闹， 天地人和刘、孙、曹。 年年兴兵南北剿， 岁岁征战血染袍。 曹阿瞒中原称王号， 铜雀台上气概高。 刘备占住荆州道， 吾主终日把心焦。 安排打虎牢笼套， 准备金钩钓海鳌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、鲁肃同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "乔玄",
          "type": "内西皮导板",
          "text": "前三皇后五帝历代有道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乔玄上。"
        },
        {
          "character": "乔玄",
          "type": "西皮慢板",
          "text": "夏桀王宠妹喜社稷倾消。 汤伐夏国号商南巢放暴， 殷纣王宠妲己苦害群僚。 周文王访贤士渭水垂钓， 姜子牙灭成汤扶保周朝。 周幽王宠褒姒风台发笑， 五霸强七雄出累动枪刀。 秦始皇归一统长城修造， 传二世楚汉争百姓奔逃。 汉高祖创基业其功非小， 四百年至桓灵又起风潮。 献帝时有董卓豺狼当道， 欺天子灭诸侯势压群僚。 王司徒除董卓连环计巧， 天降下蜀、魏、吴三分汉朝。 曹孟德占中原称为王号， 我主爷坐东吴雨顺风调。 刘皇叔踞西川仁德有道， 这才是天地人裂土分茅。 到如今干戈息狼烟尽扫， 马放山甲入库快乐逍遥。 武将军再不用南征北剿， 文职官也不用费尽心劳。 乔松山在东吴官封国老， 享不尽太平福常把香烧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。四文堂、中军、鲁肃同上。"
        },
        {
          "character": "鲁肃",
          "type": "唱",
          "text": "吾主爷坐东吴治国有道， 终日里为荆州愁锁眉梢。 鲁子敬在马上对天祝告， 但愿得把荆州讨转回朝。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "来此乔相府。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "向前通禀！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子出，问。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "鲁大夫求见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "候着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子进内。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启相爷：鲁大夫求见。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "说我出迎。回避了！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "相爷出迎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乔玄出迎。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫在哪里？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "鲁肃、乔玄",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "鲁肃、乔玄",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、乔玄同进门，四文堂、中军、院子同下。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉请上，肃大礼参拜！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫少礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃行礼。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "告坐！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫驾到，未曾远迎，当面赎罪。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "岂敢。来得鲁莽，太尉海涵！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫驾临，有何见谕？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "只为刘备借去我国荆州，久借不还，主公忧闷，此事乃下官作保，心想讨还荆 州，苦无良策。太尉乃三世元老，必有高见。特来求一妙计，讨回荆州，望乞 指示。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "听大夫之言，要讨取荆州么？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "依老朽之见，荆州不讨也罢。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "若不讨回，岂不失了主公的锐气。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "你可记得赤壁鏖兵多亏何人？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "令婿周郎。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "非也，多亏孔明先生。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "乔玄",
          "type": "西皮二六板",
          "text": "曾记得曹瞒打战表， 要把东吴一笔消。 雄兵百万如山倒， 吓坏了东吴众群僚。 文官准备写降表， 武将不敢动枪刀。 不是孔明计策好， 东吴早已降了曹。 黄盖苦肉献粮草， 凤雏连环巧计高。 不是孔明暗地保， 怎能够赤壁把兵鏖。 只烧得战船都沉了， 百万儿郎水上飘。 到如今太平无事好， 情理二字一旦抛。 荆州不过弹丸地， 何必累次把心焦。 劝大夫休把荆州讨， 免得军民受煎熬。"
        },
        {
          "character": "鲁肃",
          "type": "西皮快板",
          "text": "太尉说话言不妙， 长他志气灭吾朝。 孔明破曹计虽好， 吴侯也曾费辛劳。 文官昼夜忙不了， 武将何曾解战袍。 渔人取利令人恼， 不讨荆州留祸苗。 借荆州本是下官保， 岂肯与他两开交。"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "休要提起你作保， 大夫做事也不高。 三翻四次把荆州讨， 何曾讨转半分毫。 一取荆州损粮草， 我婿周郎带箭逃。 二取荆州美人计， 吴太后弄假成真、在甘露寺内把亲招。 三取荆州更不妙， 中了孔明计笼牢。 只杀得人头马后掉， 贯甲将军血染袍。 损兵折将还事小， 我婿周郎一命抛。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "提起令婿周郎命丧巴丘，还是下官搬尸回来。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "可还记得路过哪些险要？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "云蒙山。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫，你只知搬尸回来，可记得你那丢脸现丑的日子？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "年深日久，下官忘怀了。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "曾记得大夫搬尸回来，路过云蒙山，在那宜阳江中，现出一员大将，头戴乌油 盔，身穿乌油甲，手执丈八矛，大吼一声：“呔！东吴搬尸的是谁？”只吓得 大夫战战兢兢，躬身答道：我乃东吴鲁——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乔玄作身段。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "一个“鲁”字未曾出口，你就掉在那船舱之中。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那是下官靴大失足。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "说什么靴大失足，分明被那张飞吓掉了你的三魂。那时节幸喜掉在那船舱里面， 若是掉在宜阳江中，那些江水，你一时怎能喝得干哪？"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "大吼一声如雷啸， 你战战兢兢跌一跤。 吓得你歪戴乌纱帽， 身上斜穿紫罗袍。 三魂七魄都失了， 阎王面前走一遭。 再三再四苦哀告， 张翼德才饶了你的命一条！ 若不是素日之间孙、刘两家的情义好， 大夫一命赴阴曹！ 你若要把荆州讨， 提防张飞丈八矛。"
        },
        {
          "character": "鲁肃",
          "type": "唱",
          "text": "太尉休得来取笑， 从前事儿一旦抛。 刘备、孔明兵将少， 不敢与我国动枪刀。"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "你道刘备人马少， 他有五虎将英豪： 黄忠八十刚强好， 百步穿杨箭法高。 马孟起斩将赛虎豹， 在渭水杀曹操割须又弃袍。 赵子龙生来胆不小， 在长坂坡前称英豪。 关羽春秋韬略好， 千里独行胆量高。 张翼德大吼如雷啸， 一声喝断当阳桥。 严颜八十不为老， 挡住西川路一条。 五虎上将比不了， 一个个杀气森森广略韬。 想想西蜀众将校， 我东吴哪一个比他高？"
        },
        {
          "character": "鲁肃",
          "type": "唱",
          "text": "太尉说话年迈了， 忘了我国将英豪： 文官阚泽韬略妙， 凌统、甘宁是英豪。 蒋钦、周泰年纪少， 程普、潘璋志亮高。 丁奉、徐盛武艺好， 韩当、吕蒙将名标。 众将奋勇把荆州讨， 只怕那五虎解战袍！"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "你道东吴战将好， 老朽看来没一条。 凌统、甘宁无智略， 蒋钦、周泰小儿曹。 丁奉、徐盛铡马草， 程普、潘璋是毛包。 韩当战策全不晓， 吕蒙粗卤汉一条。 五虎若把东吴到， 怕的马仰尸骸抛。 孙、刘正在结交好， 何必又要动枪刀？ 劝你莫把荆州讨， 免得军民受煎熬。"
        },
        {
          "character": "鲁肃",
          "type": "唱",
          "text": "听罢言来心焦躁， 怎知吾腹内巧计高。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉，刘备倒有还荆州之意，但有一人不允。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "何人不允？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "关羽不允。昨日主公命诸葛瑾过江求亲，关羽口出不逊之言。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "什么不逊之言？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他说：虎女岂配犬子。将诸葛瑾赶出账外。吴侯大怒，埋怨下官当初不该作保。 为此，下官定下了一计，不用一枪一刀，管保荆州唾手而得。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫定了何计？老夫倒要领教。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "在宜阳江中，摆下酒宴大会。舱内埋伏甲兵，请云长过江赴宴，酒席宴前讨取 荆州。他还了扁罢！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "他若不还呢？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他若不还，金钟为号，钟声一响，伏兵齐起，生擒关羽。哪怕他不还荆州！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "此计可是大夫所定？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是下官所定。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "择于几时？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "本月十三日接他前来，荆州岂不是唾手而得？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "且住，那孔明先生可在荆州？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孔明若在荆州，下官我也不敢造次！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "好计，好计。酒席宴前何人陪宴？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "少不得下官陪宴。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "是你陪宴？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "乔玄",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉为何发笑？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "非是老朽发笑，我笑只笑大夫你，好藐视关羽也！"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "非是老朽微微笑， 堪羡关羽有略韬。 屯兵聚义把贼扫， 谁人不知是英豪？ 失徐州被困土山道， 万般无奈暂降曹。 三日宴来五日醪， 上马金下马银赐过锦袍。 美女十人他不要， 夜读春秋一通宵。 后来写下辞曹表， 挂印封金不取分毫。 那曹操霸陵桥边备醇醪， 酒祭青龙火焰飘。 独行千里保皇嫂， 不中曹瞒计笼牢。 你把关羽轻视了， 难瞒孔明妙算高。 大夫今把荆州讨， 水底捞月枉费劳！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "下官定的此计，神鬼难测，谅关羽难以知晓。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "孔明可知？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孔明若在此，下官也不能定下此计。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "谅你也不能哪。老朽倒有一计。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "请问大夫，河下船只可多？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "战船多得很，要它何用？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "你把战船三十只一连，五十号一连，都把它连将起来。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那岂不是送关羽的归路么？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "不是关羽归路，是大夫的生路哇！"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "船上安排连环套， 江边搭起一浮桥。 倘若关羽行霸道， 你好走来你也好逃。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "两旁都是我国将士，谅他插翅难飞！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "老朽还有一计。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "又有什么计策？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "你回去备下三牲祭礼，掀开你家祖先堂，祭过你的祖先；再备精美的酒席一桌， 与你令正夫人吃上几杯分别酒哇！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吃饱了会上怎生动手？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "哪还容得你动手哇！"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "宜阳江上把荆州讨， 酒席宴前惹祸苗。 酒要多吃饭要饱， 做一个饱鬼赴阴曹。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "下官此来，非求计而来。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "到此作甚？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请太尉前去陪宴。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "陪宴何不早讲？请！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乔玄作闪腰。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "喔唷唷！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉怎么样了？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "与大夫施礼，闪了我的腰了。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哪是闪了腰，分明是怕关羽的刀。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "偃月刀我却不怕。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "你怕作么？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "我怕关羽身后一员虎将。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他叫什么名字？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "名叫周仓。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "咳，无名小卒，怕他作甚？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "你道周仓无名小卒，老朽单单怕那一个呀！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "怕他何来？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "你道周仓无名小， 他是将中一英豪。 两军阵前烟尘扫， 双手惯用紫金镖。 此番会上他必到， 酒席宴前惹祸苗。 大夫一言讲差了， 劈头就是那一刀。 老朽年迈七十了， 不把性命换酒肴。 闲来亭园观花草， 闷来书房把琴操。 闲事闲非不问好， 学一个忙里偷闲、自在逍遥。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉既不肯前去，下官告辞了。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "老朽相送！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "逢君一席话，"
        },
        {
          "character": "乔玄",
          "type": "念",
          "text": "胜读十年书。"
        },
        {
          "character": "鲁肃、乔玄",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃行。"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫请转！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃复回。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉唤回，有何话讲？"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "我有几句话你要牢牢谨记。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "太尉请吩咐！"
        },
        {
          "character": "乔玄",
          "type": "白",
          "text": "大夫哇！"
        },
        {
          "character": "乔玄",
          "type": "唱",
          "text": "昔日张良品玉箫， 赤胆忠心保汉朝。 逼霸王自刎在乌江道， 一统山河爵禄高。 得撒手来且撒手， 得饶人来把人饶。 此去要把荆州讨， 关羽智略比你高，枉费徒劳。"
        },
        {
          "character": "乔玄",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乔玄下。"
        },
        {
          "character": "鲁肃",
          "type": "唱",
          "text": "指望乔府领高教， 闻语颜面似火烧。 此番会上设圈套， 纵是鹰鹞也难逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}