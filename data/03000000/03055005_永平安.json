{
  "script_id": "03055005",
  "title": "永平安",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "呼必显",
      "hangdang": "小生"
    },
    {
      "name": "潘洪",
      "hangdang": "净"
    }
  ],
  "plot": "呼必显至雁门关，先示恭顺，赚得潘洪印信，然后捕获解京。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四校尉、四马夫、旗牌背圣旨、伞夫引呼必显同上。"
        },
        {
          "character": "呼必显",
          "type": "念",
          "text": "金殿领圣命，捉拿叛逆臣。"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "本爵，扫殿侯呼必显。今奉万岁旨意，去至雁门关散放军粮，暗中捉拿老贼潘 洪。今乃黄道吉日，正好启程。 众将官，一路之上，不可马踏青苗，骚扰黎民，违令者斩！人马缓缓而行！"
        },
        {
          "character": "四白龙套、四校尉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同领下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、四红大铠同上，同站门。潘洪上。"
        },
        {
          "character": "潘洪",
          "type": "点绛唇",
          "text": "执掌兵权，威风八面，兵百万，煽动狼烟，谋主锦江山！"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "辕门战鼓响呛呛，继业父子困两狼。只因吾儿死得苦，箭射七郎一命亡。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "老夫，太宰潘。宋室为臣，官拜当朝太师。膝下所生二男一女。女儿潘氏，宋 王宣进西宫。长子潘强，次子潘豹。只因潘豹在天齐庙设下百日擂台，打了九 十七擂，还剩三擂未满，不想杨七郎出得府来，上了擂台，将我儿三拳两脚， 打死在擂台之上。老夫闻听此信，随即哭上金殿。好一个宋主皇爷，降下那继 业“家教不严”之罪，即时将七郎推出午门斩首。只因为方良臣打来战表，要 夺宋室天下，可恼八贤王在金殿连保数本，圣上赦了他的死刑，命杨继业带领 人马，前去征剿，得胜回来，将功折罪。是老夫昼夜寻思，心生一计，暗修一 封草柬，投到北国萧银宗驾前，命他带领兵将，夺取大宋江山。是老夫在金殿 挂了元帅大印，圣上命杨家父子以为马前先行。杨继业在金殿连推不去，八贤 王命呼延赞以为杨家保官。是老夫去至行宫，黄道吉日，停兵不战；黑道之期， 命他父子出营杀贼。谁知杨继业父子得胜回来。老夫一计不成，又生二计， 暗与胡潮静定下一计，言道营中缺粮，命那呼延赞去往雁门关搬运粮草。谁想 那老儿出得营去，竟自气呕身亡。杨继业见他保官身死，随即带领二子反出大 营。是老夫用白牌调他父子回营。不想杨七郎将老夫白牌打碎。杨继业老儿命 六郎延昭进帐求情。老夫传下将令，打了他一捆四十，又命他父子将胡儿斩尽 杀绝。谁知他父子被胡儿围困两狼山，杨继业命他七子延嗣回营求救。老夫将 他诓下马来，用酒灌醉，绑在芭蕉之上，射了一百单三箭。今日闻得杨继业老 儿碰碑身亡，他六子延昭失落，不知去向。因此老夫今日升帐，发放军情。 “帅”旗无风自动，必有军情。 站堂军，伺候了！"
        },
        {
          "character": "四红龙套、四红大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "龙虎台前出入，貔貅帐内传宣。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启太师：圣旨下！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "何人押旨？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "扫殿侯呼必显押旨。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "啊！呼必显这娃娃也出京来了？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "离此多远？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "十里长亭。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "吩咐摆队相迎！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": "四红龙套、四红大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、四红大铠同摆队，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "呼必显、四白龙套、四校尉、马夫、旗牌、伞夫同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四红龙套、四红大铠、潘洪同上，正场站一字。呼必显、四白龙套、四校尉、马夫、旗牌、伞夫同上。众"
        },
        {
          "character": null,
          "type": "text",
          "text": "人同下。四红龙套、四红大铠、潘洪、呼必显、四白龙套、四校尉、马夫、旗牌、伞夫同上，同挖门。）"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "老太师在上，末将参拜！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "你乃圣命钦差，不拜也罢。"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "焉有不拜之理？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "如此，有罪了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。呼必显拜。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "来，与钦差看座！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "老太师在此，哪有小将的座位？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "有话叙谈，焉有不坐之理。"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "如此，多谢老太师！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "钦差是金殿接旨，还是午门接旨？"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "乃是午门接旨。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "因何不宣读？"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "内封外发，请太师亲自开读。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "如此，老夫有僭了！ 吾皇万岁！万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘洪开旨读。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "第一道圣旨：圣上念边关众将受尽风霜之苦，钦发赏银十万，赏赐将士。 钦差！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "老太师！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "吾主真乃是有道明君！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "有道明君！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "吾皇万岁！万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘洪开旨读。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "第二道圣旨：调取上方宝剑还京。 钦差！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "老太师！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "圣旨上因何调取上方宝剑还京？"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "这无非去旧而换新。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "去旧换新？"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "传令下去，命胡潮静带领四十名长枪手，护送上方宝剑还京！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。 下面听者！老太师有令：命胡潮静带领四十名长枪手，护送上方宝剑还京！"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "吾皇万岁！万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘洪开旨读。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "第三道圣旨：后宫娘娘有密旨前来，请问老太师金安。 钦差！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "老太师！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "自盘古以来，只有臣问君安，哪有反礼而行的道理？"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "老太师与后宫娘娘乃是父女之情，当得一问。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "只是龙恩忒重了。 吾皇万岁！万万岁！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "请问老太师，小将从京而来，观见十里一墩，五里一铺，是我国营盘，还是他 国地界？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "乃是我国营盘。"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "倘若胡儿前来要战，众将焉能一时到齐？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "无妨。老夫有白牌一面，一调即至。"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "啊老太师！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "钦差！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "小将要看看老太师虎威，不知老太师意下如何？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "看看老夫虎威，这有何难？ 来，传旗牌进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "旗牌进见！"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "柳营春试马，虎帐夜谈兵。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见元帅！有何将令？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "老夫有白牌一面，调众将齐至大营理事。正是："
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "令出山摇动，"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "军威鬼神惊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "中军，将酒宴摆至后帐，与钦差接风！"
        },
        {
          "character": "呼必显",
          "type": "白",
          "text": "多谢老太师！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "钦差，你要随我来呀！"
        },
        {
          "character": "潘洪、呼必显",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "呔！里面有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下手甲上。"
        },
        {
          "character": "下手甲",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "元帅有白牌一面，调众将齐至大营伺候，不得有误！"
        },
        {
          "character": "下手甲",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。下手甲跪请。安殿邦上，与下手甲交耳。"
        },
        {
          "character": "安殿邦",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安殿邦、下手甲同下。"
        }
      ]
    },
    {
