          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄龙、下手丙同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "呔！里面有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下手丁上。"
        },
        {
          "character": "下手丁",
          "type": "白",
          "text": "作什么？"
        },
        {
