{
  "script_id": "03096001",
  "title": "借赵云",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵云",
      "hangdang": "小生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "公孙瓒",
      "hangdang": "老生"
    },
    {
      "name": "典韦",
      "hangdang": "净"
    }
  ],
  "plot": "曹操攻徐州，徐州牧陶谦求助于刘备。刘备至公孙瓒处借兵，公孙瓒命赵云带兵往救。途中二人共话天下大\n势，各抒己怀。抵徐后，张飞见赵云年轻，颇轻之。赵云战败曹将典韦，张飞始拜服。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "千军容易得，一将最难求。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "俺、刘备。陶恭祖搬我弟兄，护卫徐州，打了一仗，不能取胜。闻听北鄙公孙 瓒帐下兵多将广，不免前去借将破曹。 军士们！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "带马伺候！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "背地里恨曹贼做事不正， 欺天子灭诸侯势压当今。 我弟兄打一仗不能取胜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同下。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "我特地到北鄙借将回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、公孙瓒同上。"
        },
        {
          "character": "公孙瓒",
          "type": "引子",
          "text": "威震在北鄙，儿郎胆战惊。"
        },
        {
          "character": "公孙瓒",
          "type": "念",
          "text": "辕门战鼓响催军，镇守北鄙四海闻。常山收来子龙将，各路诸侯胆战惊。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "老夫、公孙瓒。前者收来一将，姓赵名云字子龙。也曾命他操演八门金锁大阵， 不知可曾演熟。帅字旗无风自动，必有军情。 来！"
        },
        {
          "character": "四蓝文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": "四蓝文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "龙虎台前出入，貔貅帐下传宣。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启爷：刘使君到。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四上手、刘备同上。公孙瓒迎，刘备下马。四上手同下。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "公孙兄！"
        },
        {
          "character": "公孙瓒、刘备",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、公孙瓒同进门。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这厢有礼！"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "还礼！请坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "贤弟驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "岂敢！备来得卤莽，公孙兄海涵。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "岂敢！闻得你弟兄护卫徐州，为何一人来到北鄙？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "公孙兄有所不知，陶恭祖搬我弟兄护卫徐州，打了一仗，不能取胜。闻得公孙 兄帐下兵多将广，特来借将破曹。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "你只顾你徐州，难道就不顾我北鄙么！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "破曹之后，弟亲自送将回营。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "须要言而有信！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "那个自然。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "中军听令！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "命赵云带领三千人马，随刘使君徐州解围。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "告辞！"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "且慢。备得有酒，与贤弟同饮。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "叨扰了。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂同摆酒。"
        },
        {
          "character": "公孙瓒",
          "type": "西皮原板",
          "text": "中军帐摆酒宴一言奉上， 尊一声刘使君细听端详： 久闻你弟兄们宽洪大量， 劝贤弟宽怀饮叙叙衷肠。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "公孙兄！"
        },
        {
          "character": "刘备",
          "type": "西皮快二六板",
          "text": "陶恭祖望良将昼夜立等， 哪还有闲工夫来饮杯巡。 施一礼辞兄长忙踏金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同上。刘备上马。四上手同下。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "破曹后弟还要送将回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "公孙瓒",
          "type": "西皮散板",
          "text": "借去了三千兵虎将一员，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂同下。"
        },
        {
          "character": "公孙瓒",
          "type": "西皮散板",
          "text": "怕只怕刘玄德有借无还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙瓒下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上，起霸。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "大鹏展翅时未逢，待等春雷起蛟龙。英雄谋略孙武智，当保明主振九重。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺、姓赵名云字子龙，乃常山真定人也。前者在袁绍帐下为将，只因磐河大战， 满营将官俱有差遣，把俺赵云闭口不提。是我进帐讨令，可恨袁绍目不识人， 藐视英雄，将俺赶出不用。我正在盘河牧马，观见一将，被颜良、文丑杀得 卸甲丢盔，命在旦夕。那时俺单枪匹马，去至阵前，杀退颜良、文丑，救了此 人性命，问起情由，原来是我主公孙瓒。是我投在他的帐下，指望他是明主， 谁知此人性情高傲，不纳忠言！唉，困煞英雄也！"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "可叹男儿时未逢， 苍天因何困蛟龙！ 俺好似伍员未得地， 好比范增遇重瞳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "令下：赵云听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "命你带领三千人马，随刘使君前往徐州破曹解围，不得有误！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "且住！今有刘备前来借兵破曹，我闻此人乃汉室后裔，等他到来，见机而行便 了。"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "自古英雄爱英雄， 大义计谋在胸中。 耳旁听得銮铃动， 那厢来了玄德公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "在帐中辞别了公孙兄， 借到了三千兵大将子龙。 来至在教场用目观定，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "我见了赵将军施礼打躬。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "那厢敢是赵将军？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "来的敢是刘使君？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赵将军！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "刘使君！"
        },
        {
          "character": "刘备、赵云",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "久闻将军英雄盖世，今日一见，果然名不虚传。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云乃草莽之夫，怎当使君如此称赞！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我弟兄若得将军，必然一战成功，何劳备苦战哪！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺不过得主公允借，当顺情而去，何言成功在我！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，赵将军是顺情而去？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赵将军，你看天气尚早，吩咐步下三军，缓缓而行，你我马上叙谈叙谈。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "如此，使君请来传令。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不敢，赵将军请！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "请！ 嘚众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "人马缓缓而行，一路之上，不可骚扰百姓，马踏青苗，违令者斩！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云欲上马，刘备向前牵马、捉镫。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "这做什么？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "与将军坠镫。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "这就不敢。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "当得的。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "不敢。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备欲上马，赵云向前牵马、捉镫。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赵将军这做什么？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "与使君坠镫。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "越发不敢！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "当得的。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、刘备同上马。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赵将军，你看天下惶惶，众诸侯刀兵四起，日后成王霸业者，但不知是谁？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云方才言过，我乃草莽之夫，不识帝王之尊，使君请道其详。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，赵将军不知？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "云不知。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！赵将军不知么——哦哦哦，赵将军！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "刘使君！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备想起一人。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哪一人？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我想河北袁绍，有颜良、文丑辅佐于他，日后成王霸业，必定是袁绍了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "就是那袁绍？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "我把他好有一比。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "比做何来？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "塚内枯骨！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "将军此言差矣。当世英雄，怎能比做塚内枯骨？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "他倚仗颜良、文丑，藐视天下英雄，焉能成其大事！袁绍他不能。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "他不能？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "他不能。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦哦哦，他不能。赵将军，备又想起一家英雄来了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哪一家英雄？"
        },
        {
          "character": "刘备",
