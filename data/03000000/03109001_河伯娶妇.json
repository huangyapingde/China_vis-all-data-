          "text": "阿农，你要往哪里去？"
        },
        {
          "character": "阿农",
          "type": "白",
          "text": "找我那苦命的女儿去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阿农欲投水，长老拦住。"
