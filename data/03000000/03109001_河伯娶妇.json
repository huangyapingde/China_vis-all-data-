        {
          "character": "二勇士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二勇士押廷掾、四小巫同下。"
        },
        {
          "character": "西门豹",
          "type": "白",
          "text": "廷掾作恶多端，本府定予重办，尔等回去也要好自生理。"
