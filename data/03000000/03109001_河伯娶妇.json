        },
        {
          "character": "阿农、阿农女、五乡民",
          "type": "同唱",
          "text": "从今后男耕女织乐逍遥！"
        },
        {
          "character": "西门豹",
          "type": "白",
          "text": "乡亲们，回去吧。"
        },
        {
          "character": null,
          "type": "stage",
