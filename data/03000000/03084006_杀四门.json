      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场设城。四文堂、四太监、大太监引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "孤好比孔圣贤蔡城遇祸， 孤好比关云长夜困土坡， 孤好比顺水舟江中失舵， 孤忧愁何日里才罢干戈？"
