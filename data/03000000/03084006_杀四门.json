      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四太监、大太监引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "命韩岐搬救兵免灾避祸， 搬来了高爱卿颇有才学。 在阵前打一仗番营踏破， 进城来偶得下卸甲疯魔。 御外甥倘若是身遭不测， 是何人保孤王驾转朝阁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
