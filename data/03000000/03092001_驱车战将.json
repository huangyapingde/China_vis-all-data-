        {
          "character": "南宫长万",
          "type": "唱",
          "text": "只怪我战敌军一时失败， 英勇名成画饼愧煞将才！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万下。"
        }
      ]
    },
