        {
          "character": "南宫长万",
          "type": "白",
          "text": "今已痊愈，母亲不必挂念。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "大王言讲何来？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "如今两国合好，免动干戈，因此大王并未加罪。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": "仇牧",
          "type": "内白",
          "text": "仇大人到！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "母亲请到后堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫母下。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧上。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "仇大人到此何事？"
        },
        {
          "character": "仇牧",
