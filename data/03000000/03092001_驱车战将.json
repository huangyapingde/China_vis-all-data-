          "text": "真乃英雄也！待孤亲自与你松绑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁庄公与南宫长万松绑。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "将军请便！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万出帐，想，复又转回。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "将军，转来做甚？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "蒙大王这样恩厚，使俺南宫长万无地自容。待某回去，奏知我主，两国结为盟 好，永罢干戈。大王意下如何？"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "但凭将军。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "某愿立字作证。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "慢来，将军右臂带有箭伤，焉能提笔！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "区区箭伤，何足道哉！若不立字为证，何以取信于大王！南宫长万呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。南宫长万写。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "大王请看。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "有劳将军。你我后会有期。将军请便！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "颠复兵山毁车甲，从前英名枉自夸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万下。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "大王因何将他放走？"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "想那南宫长万，不过一勇之夫，闻得此人事母至孝，故而将他放走。"
        },
        {
          "character": "公子偃、歂孙生",
          "type": "同白",
          "text": "大王这样仁慈，臣等皆服。"
