{
  "script_id": "03092001",
  "title": "驱车战将",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "南宫长万",
      "hangdang": "武生"
    },
    {
      "name": "南宫母",
      "hangdang": "老旦"
    }
  ],
  "plot": "宋闵公命大将南宫长万助齐攻鲁，为鲁军所擒，被释回国。宋闵公对南宫长万不满，屡加讥讽，南宫长万怒，\n杀宋闵公。公子御说逃奔鲁国，请兵诛南宫长万。鲁庄公领兵至宋，诈开宋城，进攻南宫长万。南宫长万\n欲护其母逃往陈国，因寡不敌众，母子均为鲁军所杀。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、齐桓公同上。"
        },
        {
          "character": "齐桓公",
          "type": "唱",
          "text": "周天子封列国齐邦为上， 战鲁国失了机败在疆场。 管夷吾知兵法才宏智广， 怕只怕那鲁国趁势猖狂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲍叔牙上。"
        },
        {
          "character": "鲍叔牙",
          "type": "唱",
          "text": "鲁庄公把齐邦忒以小量， 二次里领人马侵犯边疆。"
        },
        {
          "character": "鲍叔牙",
          "type": "白",
          "text": "臣、鲍叔牙见驾，大王千岁！"
        },
        {
          "character": "齐桓公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "鲍叔牙",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "齐桓公",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "鲍叔牙",
          "type": "白",
          "text": "启奏大王：今有鲁庄公领兵犯界，甚是猖狂，特来奏与大王知道。"
        },
        {
          "character": "齐桓公",
          "type": "白",
          "text": "卿家有何计策？"
        },
        {
          "character": "鲍叔牙",
          "type": "白",
          "text": "启奏大王：不如修书一封，下到宋闵公那里，搬兵求救，两家合兵，共灭鲁国， 不费吹灰之力也。"
        },
        {
          "character": "齐桓公",
          "type": "白",
          "text": "依卿所奏。溶墨伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。齐桓公修书。"
        },
        {
          "character": "齐桓公",
          "type": "白",
          "text": "旗牌走上！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "旗牌走上！"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见大王！有何吩咐？"
        },
        {
          "character": "齐桓公",
          "type": "白",
          "text": "这有书信一封，下到宋闵公那里。快去！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "齐桓公",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "仇牧、华督、公子御说、南公牛同上。"
        },
        {
          "character": "仇牧、华督、公子御说、南公牛",
          "type": "同白",
          "text": "下官——"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "仇牧。"
        },
        {
          "character": "华督",
          "type": "白",
          "text": "华督。"
        },
        {
          "character": "公子御说",
          "type": "白",
          "text": "公子御说。"
        },
        {
          "character": "南宫牛",
          "type": "白",
          "text": "南宫牛。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "列位大人请了！"
        },
        {
          "character": "华督、公子御说、南宫牛",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "大王升殿，你我分班伺候！"
        },
        {
          "character": "华督、公子御说、南宫牛",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、宋闵公同上。"
        },
        {
          "character": "宋闵公",
          "type": "引子",
          "text": "巍巍宫殿，自在安然。"
        },
        {
          "character": "宋闵公",
          "type": "念",
          "text": "乾坤浩荡日月明，列国强弱各分争。周室何能安天下，到处狼烟不太平！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "孤、宋闵公。自先君晏驾，众卿保孤为君。今当设立早朝。 众卿，有本早奏，无本退班！"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "启奏大王：齐桓公差人前来下书，大王请看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧呈书。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "待孤一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。宋闵公看书。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "众卿，那齐桓公书信上面言道：鲁国人马，侵犯齐国地界，甚是猖狂。请孤发 兵相救，众卿有何高见？"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "启奏大王：齐桓公与我国交好甚厚，既来求助，焉有不救之理？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "依卿所奏。何人挂帅，前去助阵？"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "臣启大王：那南宫长万有万夫不挡之勇，何不命他挂帅，前去助阵。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "宣南宫长万上殿！"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "大王有旨：南宫长万上殿！"
        },
        {
          "character": "南宫长万",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万上。"
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "杀气贯虹霓，寒光照铁衣。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "臣、南宫长万见驾，大王千岁！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "千千岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "今有齐桓公书信到来，言道：鲁国兴兵犯界，请孤发兵前去助阵。就命将军带 领甲车五百乘，前去助阵，你予南宫牛以为前部先锋，卿家意下如何？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "区区鲁国，弹丸之地，何劳众兵相助？待为臣选车一百乘，前去助阵，足以够 了。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "就依卿家。得胜回来，定有封赏。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "公子偃、歂孙生同上，双起霸。"
        },
        {
          "character": "公子偃",
          "type": "念",
          "text": "紫金盔齐眉盖顶，鱼鳞甲裹体护身。"
        },
        {
          "character": "歂孙生",
          "type": "念",
          "text": "展旌旗英雄临阵，银战枪神鬼昔惊！"
        },
        {
          "character": "公子偃、歂孙生",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "公子偃。"
        },
        {
          "character": "歂孙生",
          "type": "白",
          "text": "歂孙生。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "将军请了！"
        },
        {
          "character": "歂孙生",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "大王升帐，你我两厢伺候。"
        },
        {
          "character": "歂孙生",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四龙套、鲁庄公同上。〖点绛唇〗。"
        },
        {
          "character": "鲁庄公",
          "type": "念",
          "text": "可恨齐邦自称雄，横夺无忌害众生。君王有道天心顺，踏平万里扫烟尘！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "孤、鲁庄公。可恨齐国，以强抑弱，妄自尊大，因此孤家统领人马，与齐侯一 决胜负。 二位将军！"
        },
        {
          "character": "公子偃、歂孙生",
          "type": "同白",
          "text": "大王！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "二卿有何妙计，可灭齐国？"
        },
        {
          "character": "歂孙生",
          "type": "白",
          "text": "大王但放宽心，依为臣看来，那齐国人马，一个个好似插标卖首。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀大王：宋国南宫长万带领人马，与齐国助战！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "且住！探马报道，宋国发来人马，与齐国助战。想那南宫长万，有万夫不挡之 勇，今日交战，胜负未可量也！"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "为臣倒有一计在此。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "将军有何妙计？"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "大王前去与他交战，将他引至云山之外；大王赐为臣一哨人马，俱穿虎豹之皮， 黑夜之间，一拥冲出，宋兵必然大乱，那时杀他一个落花流水。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "此计甚妙。就命卿家前去埋伏。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子偃下。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四大铠、四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "带马迎敌者！"
        },
        {
          "character": "四大铠、四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "南宫长万",
          "type": "内西皮导板",
          "text": "气冲虹霓马咆哮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、南宫牛、南宫长万同上。"
        },
        {
          "character": "南宫长万",
          "type": "西皮快板",
          "text": "马鞍桥斜挎斩将刀。 日照金盔龙斗宝， 风吹连环锁甲绦。 大丈夫赤胆忠心把国保， 驱车战将要立功劳。 儿郎们抖擞精神你们把贼讨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、歂孙生、鲁庄公同上。"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "谁胜谁败论英豪。"
        },
        {
          "character": "鲁庄公",
          "type": "西皮摇板",
          "text": "孤家领兵替天行道， 通上名来好把兵交！"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "南宫长万谁不晓，"
        },
        {
          "character": "鲁庄公",
          "type": "西皮摇板",
          "text": "无知匹夫小儿曹！"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "摇唇鼓舌真可笑， 羊入虎口你怎脱逃！ （四下手、南宫牛、南宫长万、四龙套、歂孙生、鲁庄公同会阵，四下手、南宫牛、四龙套、歂孙生同钻烟 筒下。鲁庄公、南宫长万同起打。鲁庄公败下，南宫长万追下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四虎形、公子偃同上。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "埋伏了！ （四虎形、公子偃同虚下。四龙套、歂孙生、鲁庄公同败上，过场，同下。四下手、南宫牛、南宫长万同追 上。四虎形、公子偃同上。四下手、南宫牛同惊退。）"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "啊！且住。鲁国人马假扮虎豹之形，将我国人马吓退。今日必须与他决一死战， 方能退敌。 众将官！"
        },
        {
          "character": "四下手、南宫牛",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "听我一令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。南宫长万做身段。"
        },
        {
          "character": "四下手、南宫牛",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "莫道虎豹猛，阵前要立功。鞭敲金蹬响，回国受赏封。 （四下手、南宫长万同下。四虎形同下。南宫牛、公子偃同起打，双收下。南宫长万上，鲁庄公随上，同起 打。公子偃、歂孙生同续上，同起打。南宫长万败下，歂孙生、公子偃同追下。）"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "真乃一场好战也！"
        },
        {
          "character": "鲁庄公",
          "type": "唱",
          "text": "长万骁勇世间少， 可算将中一英豪。 看过弓箭传令号， 等他到来射儿曹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万败上，公子偃、歂孙生同追上，同起打。鲁庄公放箭。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "看箭！ （鲁庄公下。南宫长万中箭，四上手同拥上，同擒住南宫长万，同拥下。南宫牛上，与公子偃、歂孙生起打， 南宫牛败下。歂孙生、公子偃同收下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、鲁庄公同上。歂孙生、公子偃同上。"
        },
        {
          "character": "公子偃、歂孙生",
          "type": "同白",
          "text": "启禀大王：擒来南宫长万，请大王发落！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "押了上来！"
        },
        {
          "character": "歂孙生",
