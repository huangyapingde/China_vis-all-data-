{
  "script_id": "03007005",
  "title": "十道本",
  "alias": [
    "宫门带"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "褚遂良",
      "hangdang": "老生"
    },
    {
      "name": "李渊",
      "hangdang": "老生"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "李建成",
      "hangdang": "丑"
    },
    {
      "name": "李元吉",
      "hangdang": "丑"
    },
    {
      "name": "张妃",
      "hangdang": "旦"
    },
    {
      "name": "刘妃",
      "hangdang": "旦"
    },
    {
      "name": "长孙无忌",
      "hangdang": "老生"
    },
    {
      "name": "徐勣",
      "hangdang": "生"
    },
    {
      "name": "秦叔宝",
      "hangdang": "生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    }
  ],
  "plot": "唐初，高祖李渊患病，皇子李世民入宫侍疾。三更出宫时，发觉皇子李建成、李元吉与父妃饮酒纵乐，乃将\n玉带挂于宫门，借以警告。李建成等见带后，与妃计议，诬奏李世民调戏，并以玉带为证。李渊不察，立命\n处斩。褚遂良列举历代宠妃乱国故事，并辩明世民冤枉，李渊始醒悟，遂赦免李世民；并对褚遂良重加升赏。",
  "notes": "故事源出于《隋唐演义》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四内侍引李世民同上。"
        },
        {
          "character": "李世民",
          "type": "引子",
          "text": "海晏河清，保父王，驾坐龙廷。"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "奉命征战北可汗，尉迟保驾转长安。皇兄设下恨毒计，要害小王丧黄泉。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王李世民。奉了父王旨意，征战北国，幸喜得胜回朝。可恨皇兄设计毒害小 王，多亏尉迟解破其情，将金壶打碎，小王幸免被害。本当奏知我父王，怎奈 父王染病在床，诚恐又添一场愁闷。曾在太医院取得太平汤药，不免进宫与父 王煎汤。 内侍，摆驾进宫！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "父王赦旨出帝京， 尉迟保驾转西秦。 皇兄设下药酒计， 要害小王命残生。 内侍臣保驾宫廷进， 表表小王贤孝心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四内侍引李渊同上。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "都只为御梓童命归仙境， 因此上为王的染病在身。 内侍臣搀扶王龙床安定， 还须要却烦虑静养精神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "内侍摆驾进龙廷， 父王台前问安宁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "儿臣见驾，父王万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿平身。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿进宫为了何事？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "儿臣在太医院，取得太平汤药，进宫与父王熬煎。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "我儿真乃孝心。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "内侍，金炉伺候！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "父王暂时卧龙床， 儿臣进宫煎药汤。 屈膝跪在尘埃地， 拜天拜地拜三光。 但愿父王身无恙， 焚香顶礼谢上苍。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "儿孝心感动天和地， 药下咽喉病离身。 空养建成、元吉子， 并不进宫问安宁。 为父日后归天境， 儿就是东宫守阙龙。 谯楼鼓打三更尽， 皇儿暂且出宫廷。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "父王但把心放定， 朝中大事儿担承。 拜别父王出宫门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍扶李渊同下。李世民走圆场。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "为何还有作乐声？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "啊？我父王染病龙床，为何还有歌舞之声？有了，我且寻声而去，探听明白便 了！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "听谯楼鼓打三更尽， 看是何人作乐声！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李建成、李元吉、张妃、刘妃同上。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "手挽手儿进宫廷，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "我和你饮酒到天明。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "将酒宴摆至在西宫院，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "二姨母听封受君恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "将身儿来至在西宫院，"
        },
        {
          "character": "李建成、李元吉",
          "type": "同白",
          "text": "请呀！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "皇兄、御弟饮杯巡。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "哎呀，且住！原来皇兄、御弟与二姨母饮酒，纲常败坏。我且躲在一旁，听他 们讲些什么？"
        },
        {
          "character": "李建成、李元吉",
          "type": "同白",
          "text": "请呀！"
        },
        {
          "character": "张妃",
          "type": "唱",
          "text": "走上前来忙跪定，"
        },
        {
          "character": "刘妃",
          "type": "唱",
          "text": "幼主封我哪一宫？"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "有日小王登龙位，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "封你昭阳掌正宫。"
        },
        {
          "character": "张妃",
          "type": "唱",
          "text": "叩罢头来龙恩谢，"
        },
        {
          "character": "刘妃",
          "type": "唱",
          "text": "四起八拜谢王恩。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "有朝父王晏了驾，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "你是当今的一嗣君。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "江山大事虽我掌，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "怕的是世民不答应。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "开刀先把世民斩，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "再杀徐勣与魏征。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "马、段、袁、刘皆斩尽，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "一朝天子一朝臣。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "句句言来伤风化， 败坏人伦胡乱行。 怒气不息打进去，"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "又恐伤了手足情。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "哎呀！我若打进宫去，岂不伤了手足之情。有了，我不免解下玉带，挂在宫门， 惊动他们便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民解带，挂。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "腰中解下白玉带， 暗地打动手足心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下。内侍暗上。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "什么响亮？"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "内侍看来！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "玉带悬挂宫门。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "一见玉带挂宫门，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "二姨母快救命残生。"
        },
        {
          "character": "张妃",
          "type": "白",
          "text": "你二人不必惊慌，待我姐妹将计就计，上殿启奏一本。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "计上加计商议定， 管叫世民丧残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引李渊同上。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "宫中服药精神爽， 悼念御妻神暗伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张妃、刘妃同上。"
        },
        {
          "character": "张妃、刘妃",
          "type": "同白",
          "text": "万岁做主！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "梓童为何这等模样？"
        },
        {
          "character": "张妃、刘妃",
          "type": "同白",
          "text": "今有二主秦王，二更二点进宫调戏我二人。万岁做主！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "世民素行仁孝，孤王不信。"
        },
        {
          "character": "张妃、刘妃",
          "type": "同白",
          "text": "万岁不信，现有夺下他的玉带为证。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": "张妃、刘妃",
          "type": "同白",
          "text": "万岁请看。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "一见玉带怒气生， 胆大奴才乱宫廷！ 你二人暂且回宫去，"
        },
        {
          "character": "张妃、刘妃",
          "type": "同唱",
          "text": "管叫世民丧残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张妃、刘妃同下。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "内侍臣摆驾金殿进， 快宣皇儿李世民。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下，引李世民同上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "忽听父王宣世民， 忙上金殿问分明。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "见臣见驾，父王万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "儿是世民？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "是世民。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "好奴才！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士暗同上。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "把儿当作擎天柱， 奴才竟是忤逆人。 吩咐两旁武士手， 推出午门问斩刑。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "一言未发来问斩， 叫我有话不敢言。 因何将儿推出斩？ 说明儿死也心甘。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "奴才不必将我问， 现有玉带作证凭。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "却原来为的是联珠带，"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "父王！父王！父王呀！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "吓得我三魂少二魂。 本当说出二兄长， 又恐伤了手足情。 望父王饶了儿的命， 父王呀！ 还望看在父子情。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "手摸胸膛想一想， 此事可行不可行？ 吩咐两旁武士手， 推出午门问斩刑。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "含悲忍泪下龙廷， 看是何人把本申？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士推李世民同下。长孙无忌上。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "武士",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "长孙无忌",
          "type": "唱",
          "text": "迈步撩袍上龙廷， 品级台前臣见君。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "臣长孙无忌见驾，吾皇万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "二主秦王身犯何罪，推出午门问斩？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "蠢子不正，扰乱宫廷，故而问斩。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "想秦王有十大汗马功劳，只可以赦，不可以斩。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "孤王龙心已定，定斩不赦。"
        },
        {
          "character": "长孙无忌",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "长孙无忌",
          "type": "唱",
          "text": "当年驾坐太原省， 隋炀帝无道灭人伦。 二主爷大战王世充， 才保我主坐龙廷。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "无忌奏本大欺情，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士暗同上。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "敢在金殿藐寡人。 吩咐殿前武士手， 他与奴才同罪刑。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "绑下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、四太监、大太监同下。"
        },
        {
          "character": "长孙无忌",
          "type": "唱",
          "text": "早知他是无道君， 不该保他坐朝廷。 忍悲含泪下龙廷， 看是何人保我生？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众武士拥长孙无忌同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐勣上。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "一见秦王上了刑， 不由徐勣心胆惊。 急急忙忙金殿奔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦叔宝、程咬金同上。"
        },
        {
          "character": "秦叔宝、程咬金",
          "type": "同唱",
          "text": "见了先生礼相迎。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "二公慌慌张张为了何事？"
        },
        {
          "character": "秦叔宝",
          "type": "白",
          "text": "二主秦王不知身犯何罪推出午门问斩。我等上殿保本。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "此本你我保不下来。有人来了，你我暂退朝房便了。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "三人一同朝房进，"
        },
        {
          "character": "褚遂良",
          "type": "内白",
          "text": "先生慢走！"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "那旁又来褚先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、程咬金、秦叔宝同下。褚遂良上。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "反了呀！反了呀！"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "听说要斩二主君， 砍断了擎天柱一根。 万岁不准忠良本， 长孙无忌问斩刑。 这都是奸妃用的计， 谁知我主认了真。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "这，这，这，也罢！"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "歪戴乌纱斜插带， 假装疯魔去见君。 大摇大摆金殿进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、李渊同上。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "与他个君不君来臣不臣。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣，褚遂良见驾，吾皇万岁，万万岁！请了！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "啊？胆大的褚遂良，上得殿来衣冠不整，莫非你疯了？"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣倒不曾疯了，只恐万岁你昏了。二主秦王身犯何罪，推出午门斩首？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奴才扰乱宫廷，因此斩首！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "想二主秦王，东荡西杀，南征北剿，有十大汗马功劳。将他斩首，君心何忍， 这臣心何安哪！"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "想当年驾坐太原省， 三搜晋阳才为君。 二主大战王世充， 瓦岗寨收了众英雄。 美良川前收敬德， 千秋岭前战罗成。 大唐收了罗世信， 才保我主坐龙廷。 争来江山多安稳， 为何要斩创业人？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "胆大褚遂良，上殿言君之过。绑了！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "万岁！臣有十道条陈，容臣奏完，再斩不迟。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "呈上龙书案，寡人看来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣修本不及，乃是口奏。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这第一道条陈奏的是夏禹王坐了一十七代，四百五十八载。后出一君， 名曰桀王，宠爱一妃，名唤妹喜。那桀王听信妹喜之言，以酒为池，以肉为 林，忠臣良将，俱已遭害。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "到后来有道反无道， 汤王定计安黎民。 南曹岭桀王丧了命， 只落得江山一旦倾。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "大胆褚遂良，毁谤孤王。武士手绑了！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "啊，万岁！臣奏过一道，还有九道未奏，容臣奏完，再斩不迟。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "奏来！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这第二道条陈奏的是成汤王得了桀王天下，传至三十一代。后出一君， 名曰纣王，宠爱一妃名叫妲己。他驾前有两个谗臣，一名费仲，一名尤浑。 那纣王听信妲己之言，盖一楼名曰摘星楼。造下炮烙之刑，残虐百姓。比干丞 相割心而亡，贾氏夫人坠楼而死，姜后娘娘挖目剁手，东宫太子一旦逐出，黄 家父子反出五关。到后来姜尚兴兵伐纣，可叹那纣王只落得火焚摘星楼台而亡。 万岁你看他也是宠爱奸妃无道的昏君。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "褚遂良奏本孤心恨， 把孤比作无道君。 寡人至德安天下， 要学尧舜不差毫分。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "再将三道条陈奏来！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这道条陈奏的是周朝。那周文王得了纣王的天下，后出一君，名曰幽 王，宠爱一妃，名曰褒姒，生得面貌如花。怎奈进宫以来，永无笑容。那幽王 无计可施，他驾前有一谗臣，名叫虢石父。是他奏道：万岁要娘娘发笑不难。 在骊山设宴，火焚烟墩。那幽王听信虢公所奏，就在骊山火焚烟墩。各路诸侯 见烟墩火起，想必国家有难，一个个顶盔贯甲，兵临城下。观见他君妃在楼台 饮酒取乐，一个个乘兴而来，败兴而返；那褒姒一见哈哈大笑。后来犬戎作乱， 那幽王又将烟墩点起。各路诸侯言道：想必他君妃又在那里饮酒取乐，你我 各保汛地要紧。万岁，你看那幽王为褒姒一笑不值紧要，失落周室家邦，他还 死在乱军之中。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "幽王无道掌乾坤， 骊山设宴焚烟墩。 各路诸侯无救应， 只落得江山化灰尘。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "幽王无道戏耍诸侯，提他做甚？再将四道条陈奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这道条陈奏的是东周列国周惠王驾前有一家诸侯，名曰晋献公。他宠 爱一妃名唤骊姬。前妃所生二子，长子申生，次子重耳。那骊姬在献公面前搬 弄是非，要害申生太子一死，那献公执意不听。骊姬一计不成，又生二计。用 蜂蜜擦头，到御花园观花，命申生公子保驾采花。蜜蜂围绕头上，申生太子不 解其意，在后面用扇搧开。那献公在楼台之上观见，言道：这奴才果有戏母之 心。吩咐殿前武士，把申生太子推出午门问斩。来在午门，众大臣拦路言道： 千岁有满腹含冤，为何不奏知你父王：申生太子言道：我若奏知我父王，我父 王大怒，必将骊姬斩首。斩了骊姬不关紧要，有日我父王思想骊姬成病，岂不 是小王之罪？小王只可一死，不做那不忠不孝之人。万岁，为臣看来，二主秦 王与前朝申生太子一般无二。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "着呀！"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "晋献公本是无道君， 听信谗言斩亲生。 世民本是无义子， 淫乱宫闱问斩刑。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "再将五道条陈奏来！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣这道条陈奏的是楚平王在临潼斗宝，多亏伍子胥力举千斤鼎，压定各国为下 邦。到后来秦楚结亲，楚平王闻听无祥女生得天姿国色，有意纳妾，怎奈儿媳 不好启齿。他驾前有一谗臣，名叫费无极，奉旨往秦国迎亲。行至钟离山前， 用金顶轿改换银顶轿，无祥女改换马昭仪。好个伍子胥，保定皇家四口反出昭 关，去往吴国借兵。可叹那平王死后，只落得鞭尸三百有余。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "楚平王本是无道君， 父纳子妻乱人伦。 子胥后来发人马， 鞭尸三百留骂名。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "那父纳子妻，乃是酒色昏君，提他做甚？再将六道条陈奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这道条陈奏的是姑苏吴王宠爱一妃，名唤西施。他驾前有一谗臣，名 唤伯嚭。那吴王信西施、伯嚭之言，起造一台，名唤姑苏台。挑选天下出色女 子，去往楼台饮酒取乐。那吴王日饮千杯不醉，夜用十美陪伴。到后来勾践兴 兵前来，只杀得吴王有家难奔，有国难投。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "姑苏吴王无道君， 听信谗言选红裙。 越王勾践发人马， 吴国从此不太平。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "再将七道条陈奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这道条陈奏的是齐宣王在桑园射猎，收来一妃，名唤无盐，手使春秋 大棍压定各国。只因宠爱一妃，名曰夏迎春。那无盐娘娘身怀六甲，那夏迎春 讨下收生代劳旨意，用金丝狸猫剥去皮尾。启奏大王道：那无言娘娘产生妖魔 鬼怪。齐宣王大怒，将无盐娘娘推出斩首，多亏满朝文武保奏，打入冷宫。后 来吴起伐齐，只落得跪门求救。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "齐宣王本是无道君， 宠爱奸妃夏迎春。 后来吴起发人马， 只落得跪门去求兵。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "齐宣王宠妃害贤，怎比孤王？将八道条陈奏来！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这道条陈奏的是齐湣王宠爱一妃，名曰邹赛花。他驾前有一宦官名叫 伊立。那湣王听信邹妃之言，要害东宫太子一死。后来乐毅兴兵，前来追赶湣 王。赶得他有家难奔，有国难投。只落得日晒湣王，路剐邹妃。万岁！这就是 前朝宠妃灭子的报应啊！"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "宠妃灭子害忠臣， 他将湣王比寡人。 待等奏完十道本， 定与奴才同罪名。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "再将九道条陈奏来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "容奏：臣这道条陈奏的是前朝杨广欺娘奸妹，败坏人伦，后来亡国丧身。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "杨广本是无道君， 欺娘奸妹乱宫廷。 五花棒下丧了命， 才保我主坐龙廷。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "将十道条陈奏完，孤王定要将你碎尸万段。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "褚先生十道条陈奏了九道，只管奏来，自有咱家帮助于你。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "万岁，臣这十道条陈奏的是前朝君王与本朝皇帝一般无二。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士暗同上。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "褚遂良奏本孤心恨， 道道条陈刺寡人。 吩咐殿前武士手， 推出午门问斩刑。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "冤枉！"
        },
        {
          "character": "武士",
          "type": "同白",
          "text": "褚遂良喊冤。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "召回来！"
        },
        {
          "character": "武士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "谢万岁不斩之恩。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "非是孤王不斩于你，为何口喊冤枉？"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "臣有一事不明，要在万岁驾前领教！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "何事不明？"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "二主秦王什么时候进宫？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "一更一点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "什么时候煎汤熬药？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "二更二点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "什么时候出宫？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "三更三点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "二位皇娘奏道，抓袍夺带什么时候？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "二更二点。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "二主秦王一更一点进宫，二更二点煎汤熬药，三更三点才得出宫。二位皇娘奏 二更二点，岂不是冤枉？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "现有玉带，拿去看来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "待臣看来。 万岁，我想这抓袍夺带，必是你一拉，我一扯。这玉带之上并无一点伤损，岂 不是大大冤枉？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "寡人看来。"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "啊嗐！"
        },
        {
          "character": "褚遂良",
          "type": "白",
          "text": "哎嗐！"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "寡人如醉方才醒， 险些错斩李世民。 孤王急忙下龙廷， 手提羊毫写分明： 一赦皇儿李世民， 二赦长孙无忌卿。 忙将赦旨交与你， 快到法场走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、太监、武士同下。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "手捧赦旨下龙廷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同笑。"
        },
        {
          "character": "褚遂良",
          "type": "唱",
          "text": "笑坏两班文武臣。 文班中笑坏了先生徐勣， 武班中笑坏了叔宝、程咬金。 全都笑我不怕死的褚遂良，"
        },
        {
