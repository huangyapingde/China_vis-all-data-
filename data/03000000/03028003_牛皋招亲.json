      "hangdang": "生"
    }
  ],
  "plot": "金国魔利支令兵围困藕塘关。该关总镇金节乞援于岳飞。岳飞命牛皋先行助战。牛皋至藕塘关，乘醉上阵，\n击死魔利支，大获全胜。金节以姨妹戚赛玉相配，牛皋不敢从，适岳飞至，破格成全。洞房之夕，英雄美人，\n比剑对联，极尽新婚乐事。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四番兵同上，同站门。魔利支上，上高台。"
        },
        {
          "character": "魔利支",
          "type": "点绛唇",
          "text": "杀气冲天，儿郎勇敢，扫南蛮，奋勇当先，要把江山占！"
        },
        {
          "character": "魔利支",
          "type": "念",
          "text": "豪杰等在海外边，凌云志气冲九天。我今统领人和马，要夺宋室锦江山。"
        },
        {
          "character": "魔利支",
          "type": "白",
          "text": "某，大金邦大平章魔利支。奉了老王之命，带领十万大兵，夺取宋室江山。前 面已是藕塘关，正好夺取。 儿郎的，藕塘关去者！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四文堂、旗牌引金节同上。"
        },
        {
          "character": "金节",
          "type": "唱",
          "text": "藕塘关前旌旗飘， 帐下儿郎杀气高。 将身且坐宝帐道， 提防金寇把兵交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启总镇：金兵攻打藕塘关，离城不远。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "众将官，迎敌者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、金节同走圆场。魔利支、四番兵同上，会阵。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "唗！大胆番将，为何兴兵犯境？"
        },
        {
          "character": "魔利支",
          "type": "白",
          "text": "住了，奉了我国狼主之命，前来夺取藕塘关。大兵已到，还不下马投降！"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "一派胡言，放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金节、魔利支同起打。金节败下。"
        },
        {
          "character": "魔利支",
          "type": "白",
          "text": "追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魔利支、四番兵同追下，魔利支、四番兵、金节同上，起打。金节败，进城下。"
        },
        {
          "character": "魔利支",
          "type": "白",
          "text": "儿郎的，团团围住。歇兵三日，再来骂阵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魔利支三笑，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、金节、旗牌同上。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "且住！番将十分骁勇，如何是好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金节寻思。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "有了：我不免修书一封，下到岳元帅那里，搬兵求救。 来，溶墨伺候！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "书信呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。金节修书。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "旗牌，将此书信，急速下到岳元帅大营，不得有误！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "众将官，小心防守！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨虎、余化龙、汤怀、牛皋同上。"
        },
        {
          "character": "杨虎",
          "type": "念",
          "text": "山川扰攘战征时，"
        },
        {
          "character": "余化龙",
          "type": "念",
          "text": "浑似展布一局棋。"
        },
        {
          "character": "汤怀",
          "type": "念",
          "text": "只争当机先一着，"
        },
        {
          "character": "牛皋",
          "type": "念",
          "text": "任他诈伪到头输。"
        },
        {
          "character": "杨虎",
          "type": "白",
          "text": "杨虎。"
        },
        {
          "character": "余化龙",
          "type": "白",
          "text": "余化龙。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "汤怀。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "牛皋。"
        },
        {
          "character": "杨虎",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "余化龙、汤怀、牛皋",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "杨虎",
          "type": "白",
          "text": "元帅升帐，两厢伺候！"
        },
        {
          "character": "余化龙、汤怀、牛皋",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、四上手、中军、岳飞同上。"
        },
        {
          "character": "岳飞",
          "type": "点绛唇",
          "text": "奉命点将，威风飘荡；中军帐，摆列刀枪，要把敌扫荡！"
        },
        {
          "character": "杨虎、余化龙、汤怀、牛皋",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "杨虎、余化龙、汤怀、牛皋",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "旌旗招展列辕门，武将当立汗马勋。但愿得遂凌云志，迎还二圣方称心。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅，岳飞。宋室为臣，只因金兵作乱，本帅奉命统领人马前去剿灭。闻得金 兵来犯藕塘关，不知守将金节胜负如何，本帅甚为放心不下。站堂军，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "门上哪位听事？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "奉金总镇所差，求见元帅。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着！ 启禀元帅：金总镇差官求见。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "传他进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。 元帅传你，小心了！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。 与元帅叩头！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "罢了，起来。奉何人所差，到此何事？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "藕塘关金总镇所差，现有书信，元帅请看。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "呈上来！待本帅一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞看信。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "原来番兵围困藕塘关，请本帅前去解围。 旗牌，晓谕你家总镇，就说本帅大军随后就到。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众位将军！金人围困藕塘关，哪位将军愿带领人马前去解围，当帐请令。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "元帅，这“国家兴亡，匹夫有责”。末将不才，愿带领人马，前去援救藕塘关， 何患胡寇不平，金人不灭？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "好！命你带领三千人马，援救藕塘关，听我令下！"
        },
        {
          "character": "岳飞",
          "type": "唱",
          "text": "此番领兵把贼扫， 旗开得胜美名标。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "当年项羽行兵险， 三军在后己当先。 衔枚急走如飞箭， 又何患不奏奇功在藕塘关前？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官！兵发藕塘关去者！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、中军、金节同上。"
        },
        {
          "character": "金节",
          "type": "引子",
          "text": "藕塘遭围困，但等好音回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "岳元帅大兵已临城下。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "带马，迎接元帅去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、牛皋同上。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "藕塘关总镇金节，迎接元帅！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "免叩头。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "谢元帅！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "俺不是元帅，俺乃先行统制牛皋，元帅还在后头呢。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "啊，小小一个统制，见了本镇理应叩头；怎么反叫本镇免叩头，真真岂有此理！ 这是探子报事不明。 左右，将报事的重责四十！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋怒。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "你住了！金总镇休怪探子报事不明，迁怒于他。想咱牛皋每次出兵，俱打岳元 帅旗号。哦、哦是了，想是你瞧俺牛皋不起，此处用俺不着，三军的！拨马转 去，走！走！"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "慢来慢来！看在将军面上，不责罪于他也就了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "这便才是。你若难为了他，咱牛皋就无有体面了。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "是。本镇得罪了。请将军进城驻扎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋下马。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "总镇请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、金节、四龙套、四红龙套同走圆场，挖门。牛皋、金节同入座。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "不知牛将军驾到，未曾远迎，当面恕罪！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "岂敢！末将来得鲁莽，总镇海涵！"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "备得美酒，与牛将军接风。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "怎么，有酒？"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "有酒。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "好，讨扰了！"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、金节同饮。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊总镇，你这酒席，可是诚心请咱牛皋的么？"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "自然是诚心。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "既是诚心，就该换大杯、大坛！"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "好，好，好。 中军，看大杯、大坛伺候！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "请哪！饮哪！干哪！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊，斟上，斟上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋笑，饮。金节背供。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "怎么岳元帅用了一个莽撞的先行？这样好酒贪杯，岂不耽误国家大事！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！金兵攻打藕塘关甚紧！"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "哎呀，金兵攻打藕塘关甚紧，牛皋这样贪杯，如何是好？这……"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊总镇，俺在这里吃酒，你在一旁这么唧唧咕咕的，成什么待客的样儿啊？"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "将军有所不知，金兵攻打藕塘关甚紧！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "怎么讲？"
