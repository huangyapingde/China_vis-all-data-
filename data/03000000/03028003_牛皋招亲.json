        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "岂不知军中有令：“临阵招亲者斩”！你执意相劝小弟在此完婚，岂不是引诱 我走入歧途么！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "哈哈哈……好个遵守军纪的牛将军，真不愧是栋梁之材。贤弟，有什么差错， 本帅一律承当。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "小弟不敢哪！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "不必推辞。众位将军护送牛将军去拜花堂，本帅随后就到。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "众位哥弟，不要强迫从事，此事真真难为咱牛皋了。"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "调和麴药多加料， 倒罍酣醉破番僚； 须知不饮被旁人笑， 金总镇成全爱慕英豪。 霎时鸾凤随唱好， 谢元帅的恩情如山高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀、杨虎、余化龙同推牛皋。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哎呀，不要拉拉扯扯的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀、杨虎、余化龙推牛皋同下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "随本帅前去贺喜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金节上。"
        },
        {
          "character": "金节",
          "type": "念",
          "text": "张灯结彩耀辉煌，鼓乐喧天惹人忙。"
        },
        {
          "character": "汤怀",
          "type": "内白",
          "text": "新郎到！"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。岳飞、牛皋、汤怀同上。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "设备既齐，就请汤将军赞礼上来！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "遵命！伏以："
        },
        {
          "character": "汤怀",
          "type": "念",
          "text": "阵前矫捷猛将，洞房腼腆新郎；英雄淑女配成双，祝谐百年欢畅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金夫人、丫鬟搀戚赛玉同上，牛皋、戚赛玉同拜天地。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "请元帅吃杯喜酒！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "慢来，慢来！本帅要将牛将军送入洞房，再来吃酒。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "元帅，你要送我到哪里去呀？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "我送你去到洞房啊！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哎呀大哥，你送我到洞房？这一阵哪，可比不得藕塘关前那一阵。这洞房之事， 我是不惯的，我是不去的呀！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "不必多言。 啊，众位将军，拉拉扯扯送入洞房！"
        },
        {
          "character": "汤怀、杨虎、余化龙",
          "type": "同白",
          "text": "牛将军，走哇！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哎，不要拉拉扯扯的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金夫人、丫鬟搀戚赛玉同下。汤怀、杨虎、余化龙拉牛皋同下。"
        },
        {
          "character": "金节",
          "type": "白",
          "text": "请元帅吃杯喜酒！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "讨扰了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。丫鬟上，铺床摆酒。金夫人搀戚赛玉同上，入洞房，丫鬟、金夫人同下。"
        },
        {
          "character": "杨虎、汤怀、余化龙",
          "type": "内同白",
          "text": "进去，进去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨虎、汤怀、余化龙推牛皋同上。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "牛将军请进洞房，我们少陪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨虎、余化龙同下。牛皋拉汤怀。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "汤将军，你不要走！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "我怎么不走哇？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "我们一同进去呀！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "洞房，我如何能进去呀！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "无妨事，我们一同进去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋拉汤怀。汤怀推开牛皋。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "诶，你要小心伺候呀！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "你不要拉拉扯扯的！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "牛将军，你要小心伺候啊！哈哈哈……少陪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀下。"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋学戚赛玉音。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "小姐请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋恢复本音。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "小姐你不住在自己家内，却住在姐丈家中，是何原故？"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "将军有所不知。只因我自幼父母双亡，依靠姐姐度日。多蒙姐丈延师教授，文 则习得经诗书史，武则习得剑戟刀枪。近日金兵入寇，我正愁身为女流，不能 上阵杀敌，不想得配将军，今后当与将军一同报国也！"
        },
        {
          "character": "戚赛玉",
          "type": "唱",
          "text": "不幸幼年父母丧， 依靠姐姐度日光。 习就武艺韬略广， 愿助将军保家邦。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "我听小姐之言，你乃是文武双全，真可算巾帼英雄也！"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "常言道虎将门中出虎子， 书香门第出文豪。 武艺高强文事好， 算我牛皋艳福高。"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "不敢，不敢。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "好，看这洞房，倒也宽敞，我有意陪伴小姐比拳一回，也好瞻仰瞻仰。"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "如蒙将军不弃，我就要献丑了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "她言道曾学过全身武艺， 她可比班婕妤堪与名齐！ 今宵里洞房中比拳游戏，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、戚赛玉同比拳。牛皋败。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "不成，还得来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、戚赛玉同打，戚赛玉推牛皋。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "险些儿翱翔凤把虎来骑！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "哟！原来还不如我呀！"
        },
        {
          "character": "戚赛玉",
          "type": "唱",
          "text": "适才间我与他比拳游戏， 却原来不如我空长须眉。"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "看小姐武艺精令人难比， 到来日破金邦好比吹灰。"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "啊将军，你我比剑一回如何？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "不用比了。小姐武艺变幻莫测，咱牛皋实实地敬服。来日征讨金邦时节，多了 一条臂膀。小姐，你真是我的贤内助了！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "将军夸奖了！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "想这洞房之夕，理应尽兴欢乐，我有意与小姐畅饮几杯，以庆你我登科之喜！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "一同把盏便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、戚赛玉同饮。"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "如跃如飞如凤影， 若隐若现若流星。 洞房之中把酒饮， 登科之喜乐融融。 牛郎如梦我就方初醒，"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "娘子请！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "戚赛玉",
          "type": "唱",
          "text": "将军何必过奉承。 雕虫小技焉足论， 能人之上有能人。 一同努力求深进，"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "功夫一到自然成。 助为夫灭金邦二圣迎请， 全仗小姐显威能。 今宵且把香醪饮，"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "请！ 几杯聊敬美人心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋饮。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊小姐，天时不早，安歇了吧！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "慢着。我还有几句话说哪！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "有话快快请讲！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "将军听了！"
        },
        {
          "character": "戚赛玉",
          "type": "唱",
          "text": "良缘得配非偶然， 尊声将军听我言： 昔日有个苏小妹， 三难新郎佳话传。 今宵洞房效才女， 请君题诗对对联。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "听小姐之言，敢莫是要叫咱吟诗对对么？"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哎呀，我不认识字呀！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "你不能对，那我就要少陪了！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "嘿，别介，别介！只是不要难为咱牛皋。好，出题，出题。"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "等我想想。啊，“海棠”。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "这“海棠”？我对“山药”！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "“海棠花”？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "“山药蛋”！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "妙哇！辞虽不雅，字却工整。好，好，好！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "既是好，就同入罗帏吧！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "别忙，我还有哪！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "怎么还有？出题，出题！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "“金环”？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "“宝剑”！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "“一对金环”？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "“三尺宝剑”！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "“红粉佳人”？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "“黑脸大汉”！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "“红粉佳人，耳坠一对金环”。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "“黑脸大汉，腰悬三尺宝剑”。"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "哎呀妙哇！不料将军有此大才，令人钦佩。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "夸奖了。哈哈哈！你我安歇了吧！"
        },
        {
          "character": "戚赛玉",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "戚赛玉",
          "type": "念",
          "text": "“士为知已者用”，"
        },
        {
          "character": "牛皋",
          "type": "念",
          "text": "“女为悦已者容”。"
        },
        {
          "character": "戚赛玉",
          "type": "念",
          "text": "英雄儿女婚姻定。"
        },
        {
          "character": "牛皋",
          "type": "念",
          "text": "今宵好似鸳鸯戏水其乐融融。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋、戚赛玉同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
