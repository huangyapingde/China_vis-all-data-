        {
          "character": "裴玉莲",
          "type": "白",
          "text": "谢坐。将生员唤到府中，有何见谕？"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "只因老夫府下缺少一代笔先生，故请先生到来屈就屈就。"
