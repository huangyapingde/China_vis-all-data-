{
  "script_id": "03020002",
  "title": "游湖阴配",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "李蕙娘",
      "hangdang": "旦"
    },
    {
      "name": "裴玉莲",
      "hangdang": "小生"
    },
    {
      "name": "贾似道",
      "hangdang": "净"
    }
  ],
  "plot": "南宋末季，平章贾似道退职家居，携宠妾李蕙娘游西湖。途遇张氏女，贾似道艳其美，舍李而追张。适有举\n子裴玉莲与李蕙娘遇，互有爱慕意，李蕙娘故遗手帕于桥侧。事为贾家奴仆所见，促李蕙娘去。贾似道追及\n张，使仆致意愿置妾媵，张母不允，贾似道欲行强抢劫，会裴玉莲尾随李蕙娘亦至，锐身排难，张母女得乘\n机逸去。贾仆迁怒于裴玉莲，因诱询姓氏居址，将图陷害，裴玉莲遽以实告。贾似道归家，奴又告以李蕙娘\n与裴生之事。贾似道怒杀李蕙娘。李蕙娘魂入幽冥，诉冤状，冥中悯其无辜，赐李蕙娘阴阳扇使还阳世与裴\n生作百日团聚。李蕙娘持扇觅裴生，时裴玉莲已为贾似道赚入府中，囚之书房，并遣奴苗义杀以泄愤。李蕙\n娘以扇扑苗义于地，偕裴玉莲垣逃。值期满鬼卒衔命招李蕙娘，李蕙娘与裴玉莲遂生离死别。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾似道上。"
        },
        {
          "character": "贾似道",
          "type": "引子",
          "text": "官居首相，告职归，乐守田园。"
        },
        {
          "character": "贾似道",
          "type": "念",
          "text": "我本当朝一首相，如今告老转还乡。紫袍乌纱居人上，无非浮云梦一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子暗上。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "老夫，贾似道。宋室为臣。只因年迈，告老还乡，来在这杭州居住。夫人早丧， 是我纳一小星，名唤蕙娘，倒也称心如意。今乃西湖庙会之期，不免带领蕙 娘前去，一来降香，二来游赏西湖。 来！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "请夫人出堂！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "请夫人出堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引李蕙娘同上。"
        },
        {
          "character": "李蕙娘",
          "type": "念",
          "text": "红颜自古多薄命，一树梨花压海棠。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "参见老爷！"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "谢坐。将妾身唤出，有何吩咐？"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "今日乃西湖庙会之期，将娘子唤出，随老夫前去，一来拈香，二来游赏西湖。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "妾身奉陪。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "家院，吩咐外厢带马，车辆伺候！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "外厢备马，车辆伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、车夫同上。"
        },
        {
          "character": "贾似道",
          "type": "唱",
          "text": "人来带马会场往，"
        },
        {
          "character": "李蕙娘",
          "type": "唱",
          "text": "游赏西湖走一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张王氏上。"
        },
        {
          "character": "张王氏",
          "type": "引子",
          "text": "先夫早丧，学孟母，教子有方。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "张王氏",
          "type": "白",
          "text": "老身，张王氏。先夫张公，曾在宋室为臣，不幸中年亡故。膝下无儿，所生一 女，名唤秀英，今年一十七岁了，随定老身习学针黹，倒也十分可爱。只是老 身已逾花甲，女儿尚未字人，也是一桩心事。这且不言。今乃西湖庙会之期， 不免带领女儿前去降香。 家院！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "张王氏",
          "type": "白",
          "text": "请小姐出堂！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请小姐出堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、张秀英同上。"
        },
        {
          "character": "张秀英",
          "type": "念",
          "text": "长在深闺内，德操效孟光。"
        },
        {
          "character": "张秀英",
          "type": "白",
          "text": "参见母亲！"
        },
        {
          "character": "张王氏",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "张秀英",
          "type": "白",
          "text": "谢坐。将女儿唤出，有何训教？"
        },
        {
          "character": "张王氏",
          "type": "白",
          "text": "今乃西湖庙会之期，意欲带领我儿前去降香。"
        },
        {
          "character": "张秀英",
          "type": "白",
          "text": "女儿遵命。"
        },
        {
          "character": "张王氏",
          "type": "白",
          "text": "家院，吩咐车辆伺候！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "车辆伺候！"
        },
        {
          "character": "张王氏",
          "type": "唱",
          "text": "母女们同上车离了家下，"
        },
        {
          "character": "张秀英",
          "type": "唱",
          "text": "一路上观不尽野草闲花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "书童引裴玉莲同上。"
        },
        {
          "character": "裴玉莲",
          "type": "唱",
          "text": "一日离家一日深， 好似孤雁宿寒林。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "小生裴玉莲，乃湖广人氏。今乃大比之年，进京赴考。来此杭州地面，身体十 分疲倦，不免找一店房歇息歇息。 裴安，带路！"
        },
        {
          "character": "裴玉莲",
          "type": "唱",
          "text": "裴安带路往前奔， 见一店房且安身。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "来此已是店房。 店家！"
        },
        {
          "character": "店家",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "念",
          "text": "孟尝君子店，千里客来投。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "相公住店吗？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "正是。将马带过！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是。客官用些什么？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "取杯茶来！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是。 茶到。相公吃过饭了没有？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "前途用过了。啊店家，我心中甚是烦闷。你们这里可有什么消遣的所在无有？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我们这儿最出名的就是西湖。今天又是庙会，您何不到那儿逛逛去哪？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "好，裴安看守门户，我就此去也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家、书童同下。"
        },
        {
          "character": "裴玉莲",
          "type": "唱",
          "text": "独坐旅店心闷倦， 前去游湖散心田。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴玉莲下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡知奋上。"
        },
        {
          "character": "胡知奋",
          "type": "念",
          "text": "天子重英豪，文章教尔曹。万般皆下品，唯有读书高。"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "学生胡知奋。家父胡不高，在这杭州城里开了一座绸缎店，生意倒也十分发财。 我学生是黉门秀士。今日是西湖庙会之期，有心前去逛会，怎奈不识路径， 怎样的前去？看那旁有两个人来，想必也是逛会的。待我同他们一块儿去。"
        },
        {
          "character": "张三、李四",
          "type": "内同白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张三、李四同上。"
        },
        {
          "character": "张三",
          "type": "念",
          "text": "从早离了家，"
        },
        {
          "character": "李四",
          "type": "念",
          "text": "拐骗做生涯。"
        },
        {
          "character": "张三",
          "type": "白",
          "text": "张三。"
        },
        {
          "character": "李四",
          "type": "白",
          "text": "李四。"
        },
        {
          "character": "张三",
          "type": "白",
          "text": "兄弟，今儿个是西湖庙会。咱们哥俩到那儿，顺便弄他两档子。"
        },
        {
          "character": "李四",
          "type": "白",
          "text": "好，走哇！"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "二位是逛会的吗？"
        },
        {
          "character": "张三、李四",
          "type": "同白",
          "text": "是呀！您也是逛会的吗？"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "是的。我不认识道路，我们一同走吧。"
        },
        {
          "character": "张三、李四",
          "type": "同白",
          "text": "好，一块儿走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡知奋、张三、李四同走圆场。裴玉莲上。"
        },
        {
          "character": "裴玉莲",
          "type": "唱",
          "text": "杭州城内好风景， 那旁站定一伙人。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "且住！适才闻得店家言道：今日乃西湖庙会之期，甚是热闹。只是不晓路径， 如何前去？看那旁有一伙人，想是逛庙的，待我问来。 啊，三位敢是逛庙的么？"
        },
        {
          "character": "张三、李四",
          "type": "同白",
          "text": "是啊，是啊！您也是逛庙的吗？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张三、李四",
          "type": "同白",
          "text": "咱们一块儿走吧！"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "正要同往。"
        },
        {
          "character": "张三、李四",
          "type": "同唱",
          "text": "尊声二位一同行，"
        },
        {
          "character": "裴玉莲",
          "type": "唱",
          "text": "且到庙会散愁情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "慧静上。"
        },
        {
          "character": "慧静",
          "type": "念",
          "text": "扫地不伤蝼蚁命，爱惜飞蛾纱罩灯。"
        },
        {
          "character": "慧静",
          "type": "白",
          "text": "小僧，慧静。今乃本庙开会之期，不免打扫佛堂，准备施主前来括香便了。 （慧静打扫。家院、丫鬟、张王氏、张秀英同上，张王氏、张秀英同烧香毕，家院、丫鬟、张王氏、张秀英 同下。四青袍、丑院子、贾似道、李蕙娘同上，贾似道、李慧娘同烧香。四青袍、丑院子、贾似道同下。裴 玉莲、张三、李四、胡知奋同上。李蕙娘出门，见裴玉莲对视笑，与裴玉莲互拍手笑下。）"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "哎，你看那女子，“把合”你来着！"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "无有什么。"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "我看见了！"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "无有什么。"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "我看见了嘛！"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "岂有此理！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴玉莲下。"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "你走了也不成啊！我到底要看看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡知奋跑下。四青袍、丑院子、贾似道、李蕙娘、车夫同上。"
        },
        {
          "character": "贾似道",
          "type": "唱",
          "text": "烧罢了一炉香忙回家转， 大路旁天然景美丽可观。"
        },
        {
          "character": "李蕙娘",
          "type": "唱",
          "text": "催车辆往前行上桥观看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李慧娘上桥。四青袍、丑院子、贾似道同下。裴玉莲、胡知奋、张三、李四同上。"
        },
        {
          "character": "李蕙娘",
          "type": "唱",
          "text": "见那人身俊俏貌似潘安。 （李蕙娘对裴玉莲做打手势，裴玉莲上桥，李蕙娘欲言又止，凡做三次，胡知奋看出神，张三、李四从后同 将胡知奋的衣服脱下。张三、李四同下。李蕙娘欲言，遗手帕笑下。裴玉莲拾帕随下。）"
        },
        {
          "character": "胡知奋",
          "type": "白",
          "text": "哎呀！我的衣服，被他们偷去了，待我追这狗娘养的去！ （胡知奋下。张三、李四同上，同跑下，胡知奋追上，下。院子、丫鬟、张王氏、张秀英、二车夫、四青袍、 丑院子、贾似道、李蕙娘、车夫同上。）"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "看那女子生得十分美貌。贾六上前提亲。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "是啦。 老院公请过来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "那小妞儿是谁呀？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "那是我家小姐。你问她做甚？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "不是，因为我们太师爷挺喜欢你们小姐的。把她给我们太师爷，你看怎么样？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "真乃胡说！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子打丑院子。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "好好，打我。 太师爷！他不答应，他还给我一个满脸花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴玉莲上。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "不识抬举。抢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同欲抢，裴玉莲上前拦。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、丫鬟、张王氏、张秀英同下。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "啊，这位员外，不必如此。她乃是良家妇女，不要如此莽撞。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "这！"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "请回去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、丑院子、贾似道同下。李蕙娘看裴玉莲不语，丑院子上，拍李蕙娘。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "员外叫您哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李蕙娘羞下。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "这位相公贵姓啊？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "小生裴玉莲。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "听您说话不像此地人哪？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "乃湖广人氏。只因进京赴试，从此经过。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "您住在哪儿啦？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "就住在前面大元店内。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "是是是。刚才的事，多劳您驾啦。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子下。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "方才那一娘子，生得十分美貌，不知是谁家的家眷。方才那人也忘记问他。那 娘子与我手帕一方，待我观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴玉莲念。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "“蕙娘”。手帕上面写着“蕙娘”二字，想是那女子之名。且自由他。天色 不早，不免回店歇息便了。正是："
        },
        {
          "character": "裴玉莲",
          "type": "念",
          "text": "无心栽种河边柳，谁知杨柳尽成行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴玉莲下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾似道、丑院子、李蕙娘同上。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "娘子后面歇息去吧。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李蕙娘下。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "哈哈哈……好个绝色女子！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "您还乐哪？没捡着板子，差点儿丢扇门。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "此话从何说起？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "是您不知道哇。方才不是有人给咱们了事来着吗？您走后，蕙娘就跟那小子眉 来眼去。嘿，要不是我，您早当上这个啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子比手势。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "有这等事！唤蕙娘。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "蕙娘快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引李蕙娘同上。"
        },
        {
          "character": "李蕙娘",
          "type": "念",
          "text": "忽听老爷呼唤，吓得胆战心寒。若为西湖之事，还须巧言遮辩。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "参见老爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾似道怒。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "坐下！"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "谢坐。老爷怒气不息，为着谁来？"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "我就为你来。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "为妾身何来？"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "适才在西湖，你与那狂徒眉来眼去，难道欺压老夫年迈不成？"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "哪有此事！"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "你还敢抵赖？有人得见！"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "何人得见？"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "家童得见，上前对词！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "你跟那少年眉来眼去的，我不叫你，你还不回来哪。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "李蕙娘",
          "type": "唱",
          "text": "骂声奴才真大胆， 老爷面前进谗言。 走上前来将你打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李蕙娘打丑院子耳光。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "贾似道",
          "type": "唱",
          "text": "大胆贱人尚巧言。 手持钢刀将你斩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾似道杀死李蕙娘。李蕙娘下。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "将尸首拖了下去！蕙娘已死，但此事不可泄露于外，你等俱要小心！"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "贾似道",
          "type": "念",
          "text": "蕙娘做事大不该，败我家风为何来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "李蕙娘",
          "type": "内二黄导板",
          "text": "聚三魂归七魄随风飘荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李蕙娘上。"
        },
        {
          "character": "李蕙娘",
          "type": "二黄摇板",
          "text": "星凄凄月惨惨好不凄凉。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "我乃蕙娘鬼魂是也。只因前日游赏西湖，遇一少年公子，是我一见倾心。不想 被恶奴看破，告知老贼，将我一刀杀死。是我阴魂不散，不免去至阎君殿前告 他一状便了！"
        },
        {
          "character": "李蕙娘",
          "type": "二黄摇板",
          "text": "这才是无端的大祸天降， 冤魂鬼无归宿心意彷徨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李蕙娘下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同上，同堆鬼。判官上，跳判。"
        },
        {
          "character": "判官",
          "type": "念",
          "text": "掌案在阴曹，一支笔如刀。包相执法后，不敢差分毫！"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "我乃阴曹阎君殿下掌案判官是也。今乃三、六、九日，开放酆都。 众鬼卒，酆都去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒、判官同走圆场。李蕙娘上，过场，下。"
        },
        {
          "character": "鬼卒甲",
          "type": "白",
          "text": "有一恶鬼擅闯酆都！"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "将她抓来见我！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒同下，同揪李蕙娘上。李蕙娘跪。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "唗！何处恶鬼，胆大擅闯酆都。讲！"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "判官爷容禀："
        },
        {
          "character": "李蕙娘",
          "type": "二黄摇板",
          "text": "都只为贾似道害我命丧， 因此上求判爷代禀阎王。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "你既前来告状，可知阴曹规矩？"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "小鬼不知，请判爷指教。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "判官",
          "type": "二黄导板",
          "text": "三十三天登宝殿，"
        },
        {
          "character": "判官",
          "type": "二黄原板",
          "text": "有牛头和马面站立两边。 行善的俱在桥上过， 作恶的一个个打入奈河间。 叫怨鬼随我到阎罗宝殿， 见了阎君说根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒、判官、阎君同上。〖点绛唇〗。"
        },
        {
          "character": "阎君",
          "type": "念",
          "text": "赏善罚恶不稍偏，阴阳虽隔理一般。人间多少不平事，一到森罗便雪冤。"
        },
        {
          "character": "阎君",
          "type": "白",
          "text": "我乃五殿阎君是也。适才朝罢地藏王而归。 掌案的：有何事议？"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "启阎君：今有阳世蕙娘，被贾似道杀死，冤魂不散，前来酆都鸣冤。"
        },
        {
          "character": "阎君",
          "type": "白",
          "text": "押上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒押李蕙娘同上，李蕙娘跪。"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "参见阎君！"
        },
        {
          "character": "阎君",
          "type": "白",
          "text": "唗！胆大恶鬼，为何被贾似道杀死？讲！"
        },
        {
          "character": "李蕙娘",
          "type": "白",
          "text": "阎君容禀："
        },
        {
          "character": "李蕙娘",
          "type": "唱",
          "text": "都只为游西湖被杀命丧， 望阎君开大恩放我还阳。"
        },
        {
          "character": "阎君",
          "type": "白",
          "text": "原来如此。掌案的，查看她的阳寿可满？"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "领旨！ 启阎君：蕙娘阳寿该活七十二岁，今方二十一岁身死，且与东斗星有百日姻缘 之分。请阎君定夺。"
        },
        {
          "character": "阎君",
          "type": "白",
          "text": "既然如此，赐她阴阳宝扇，送她去到阳世与东斗星了却百日姻缘，再来复命。 掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎君下。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒、判官、李蕙娘同走圆场。众鬼卒同押李蕙娘过桥，同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丑院子上。"
        },
        {
          "character": "丑院子",
          "type": "念",
          "text": "有福之人人侍奉，无福之人侍奉人。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "小子，贾六。只因那日游赏西湖，我家姨奶奶蕙娘，跟一个少年书生裴玉莲眉 来眼去，被我看见，告知我家相爷。我家相爷将蕙娘杀死。这几天相爷又想起 那个书生。是我说：“我知道这个书生住处。”今日奉了我家相爷之命，去请 裴生。不免这就去，这就去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": "裴玉莲",
          "type": "内二黄导板",
          "text": "自那日西湖归心神不定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴玉莲上。"
        },
        {
          "character": "裴玉莲",
          "type": "唱",
          "text": "每日里一阵阵记挂在心。 那蕙娘真乃是绝世姿品， 唯嫦娥与西施堪与比伦。 忘不下缱绻情心神不稳， 坐店房思蕙娘神志不宁。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "小生，裴玉莲，乃湖广人氏。只因进京赴试，来在杭州。那日游赏西湖，偶遇 蕙娘。回来之后，身体即感不适。已命书童去至大街，买些果品来用。还未见 到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子上。"
        },
        {
          "character": "丑院子",
          "type": "念",
          "text": "奉了相爷命，来请裴相公。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "来此已是。 嘿，店小二！"
        },
        {
          "character": "店家",
          "type": "内白",
          "text": "来啦，来啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "六爷，什么事呀？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "我问问你：有一位裴相公住在你们这儿吗？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是啊！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "请出来，说我要见。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是啦。 裴相公门外有人找您！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家下。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "啊裴相公！"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "啊，管家到此何事？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "奉了我家相爷之命，请您到我们那儿去。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "你家相爷是哪个？"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "就是贾似道、贾太师。您不是还给管过闲事来着吗？"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "我与他素不相识，请我做甚？我是不能前去。"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "四海之中，皆是朋友。您去一趟没关系。"
        },
        {
          "character": "裴玉莲",
          "type": "白",
          "text": "我是不能前去！"
        },
        {
          "character": "丑院子",
          "type": "白",
          "text": "走吧，走吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑院子拉裴玉莲同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引贾似道同上。"
        },
        {
          "character": "贾似道",
          "type": "唱",
          "text": "我命家童前街往， 请来裴生做商量。 将身且坐二堂上， 且听家院报端详。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "老夫，贾似道。那日带领蕙娘去到西湖游玩，不想蕙娘这贱人，竟与什么裴生 调情，坏我家风。是我回得家来，将这贱人杀死。贾六言道：与蕙娘调情那人， 现仍住在杭州。已命他前去将他请来，三更时分，将他杀死，以杜外间耳目。 贾六去了这半日，为何还不见到来！"
