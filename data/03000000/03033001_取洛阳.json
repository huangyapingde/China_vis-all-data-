  "plot": "刘秀白水村起义后，直逼洛阳，时守将苏献智勇兼备，殊非他城易取。刘帅邓禹乃行苦肉计。刘将马武、岑\n彭原为王莽武科有隙，时又相互争功。邓禹料岑彭必败，反令岑彭出兵取洛阳，命马武备酒接风。马武不服，\n忿然归帐。岑彭果中苏献诱兵之计，败归。马武乘隙置酒辱岑彭，并恶言犯邓禹，要重回太行山落草。邓\n禹乘势重责马武，并遂之。马武忿归太行，路经洛阳，忽计诈降苏献以诳洛城。苏献信之。时汉将吴汉、姚\n期、杜茂、岑彭等已奉命埋伏城下。开城之际，一拥而入，苏献终于被擒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴汉上。上手甲执“吴”字旗随上，吴汉起霸。"
        },
        {
          "character": "吴汉",
          "type": "念",
          "text": "杀妻献关辅汉刘，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚期上。上手乙执“姚”字旗随上，姚期起霸。"
        },
        {
          "character": "姚期",
          "type": "念",
          "text": "血战沙场有数秋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭上，上手丙执“岑”字旗随上，岑彭起霸。"
        },
        {
          "character": "岑彭",
          "type": "念",
          "text": "腰中宝剑常带血，"
        },
        {
          "character": "马武",
          "type": "内白",
          "text": "啊咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武上，上手丁执“马”字旗随上，马武起霸。"
        },
        {
          "character": "马武",
          "type": "念",
          "text": "杀却王莽方罢休！"
        },
        {
          "character": "吴汉、姚期、岑彭、马武",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "吴汉",
          "type": "白",
          "text": "吴汉。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "姚期。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "岑彭。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "马武。"
        },
        {
          "character": "吴汉",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "姚期、岑彭、马武",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "吴汉",
          "type": "白",
          "text": "元帅升帐，攻取洛阳，你我辕门伺候。"
        },
        {
          "character": "姚期、岑彭、马武",
          "type": "同白",
          "text": "带马！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴汉、姚期、岑彭、马武同上马，同走圆场，同下马。"
        },
        {
          "character": "吴汉",
          "type": "白",
          "text": "打了几鼓？"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "辕门二鼓。"
        },
        {
          "character": "吴汉",
          "type": "白",
          "text": "元帅尚未升帐，你我两厢伺候！"
        },
        {
          "character": "姚期、岑彭、马武",
          "type": "同白",
          "text": "请！ （四上手自两边分下。吴汉、姚期对拱手自两边分下。岑彭、马武同比粗。〖四击头〗。岑彭、马武同亮相， 自两边分下。）"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四站堂军、邓禹、刘秀同上。"
        },
        {
          "character": "邓禹",
          "type": "点绛唇",
          "text": "统领雄兵，威风凛凛，灭莽贼，汉室重兴，攻打洛阳城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘秀授令，邓禹接令。邓禹正坐，刘秀旁座。"
        },
        {
          "character": "邓禹",
          "type": "念",
          "text": "白水起义展疆场，六韬三略腹内藏。夺取州县如反掌，中兴汉室取洛阳！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "本帅，邓禹。自白水起义以来，逢州得州，遇县得县，看前面已是洛阳，必须 激将而行。 来！"
        },
        {
          "character": "四站堂军",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "众将进帐！"
        },
        {
          "character": "四站堂军",
          "type": "同白",
          "text": "众将进帐。"
        },
        {
          "character": "吴汉、姚期、岑彭、马武",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴汉、姚期、岑彭、马武同上。"
        },
        {
          "character": "吴汉、姚期、岑彭、马武",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "罢了。见过主公。"
        },
        {
          "character": "吴汉、姚期、岑彭、马武",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "吴汉、姚期、岑彭、马武",
          "type": "同白",
          "text": "谢主公！有何将令？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "吴汉、姚期听令！命你二人，解押粮草，不得有误。"
        },
        {
          "character": "吴汉、姚期",
          "type": "同白",
          "text": "得令。 带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴汉、姚期同下。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "啊元帅，小王有意攻取洛阳，不知命何将出马？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "臣观我营将士，并无一人，能敌那苏献者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武意欲讨令，岑彭抢先一步。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "元帅，赐俺岑彭一支将令，带领本部人马，夺取洛阳。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你慢喳！岑将军，闻听人言，那洛阳城池坚固，况且那苏献用兵如神，你去焉 能取胜？此事让与咱马武，定能一战成功！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "马将军，俺今此去，取不下洛阳，永不与主公出力报效。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "哎，我说你去不得，你就去不得！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "俺去得！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你去不得！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "俺去得！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你去不得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭、马武同欲动武，刘秀劝。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "皇兄啊！"
        },
        {
          "character": "刘秀",
          "type": "西皮散板",
          "text": "二将不必来争斗， 小王言来听从头： 哪个若得苏献首， 凌烟阁上美名留。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "嗯！你二人不必争论，本帅在武科场中，也曾见过你二人的高下。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "元帅，想当年在那武科场中，那王莽老贼中了岑彭的像貌，不中俺马武的奇才， 今日帐中争功，岑彭你好不羞啊。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "马武！想当年岑爷夺魁，扬名天下，谁人不知，哪个不晓？你是扠出科场的丑 鬼马武！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "丑鬼马武！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "喳喳喳……哇呀呀……"
        },
        {
          "character": "马武",
          "type": "西皮散板",
          "text": "怒气不息站帐口，"
        },
        {
          "character": "马武",
          "type": "西皮快板",
          "text": "岑彭小儿听从头： 洛阳举子俺为首， 志气凌云贯斗牛。 王莽贼见俺的面貌丑， 扠出科场某把反诗留。 兴汉灭莽心已久， 奉命带甲统貔貅。 以貌压众岂能长久， 得意洋洋你好不害羞！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "马武！"
        },
        {
          "character": "岑彭",
          "type": "西皮散板",
          "text": "马武不必夸海口， 岑爷言来听从头： 考场夺魁俺为首， 插花披红占鳌头。 文韬武略胸中有， 岑爷一怒招尔的头。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你招哪个的头？"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "招你的头！招打！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "俺招你的头，呸！招打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭、马武同打。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "皇兄啊！"
        },
        {
          "character": "刘秀",
          "type": "西皮散板",
          "text": "何必怒气冲牛斗， 得罢休来且罢休。"
        },
        {
          "character": "岑彭、马武",
          "type": "同白",
          "text": "主公啊！"
        },
        {
          "character": "岑彭",
          "type": "西皮散板",
          "text": "主公传令臣先走，"
        },
        {
          "character": "马武",
          "type": "西皮散板",
          "text": "马武单刀斩贼酋。"
        },
        {
          "character": "岑彭",
          "type": "西皮散板",
          "text": "虎落平阳怎反手，"
        },
        {
          "character": "马武",
          "type": "西皮散板",
          "text": "仇如山海怎罢休。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭、马武同跪。"
        },
        {
          "character": "邓禹",
          "type": "西皮散板",
          "text": "二将休要来争斗， 本帅言来听根由： 不念素日功劳有， 定取你二人项上头。"
        },
        {
          "character": "岑彭、马武",
          "type": "同白",
          "text": "喳！"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "啊元帅，看在小王的份上。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "臣遵命。"
        },
        {
          "character": "邓禹",
          "type": "西皮散板",
          "text": "看主金面饶恕了，"
        },
        {
          "character": "岑彭、马武",
          "type": "同白",
          "text": "谢元帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭、马武同起立。"
        },
        {
          "character": "邓禹",
          "type": "西皮散板",
          "text": "从前事儿一笔销。 岑彭进前听令道，"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你拿过来吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武欲抢令箭。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "邓禹",
          "type": "西皮散板",
          "text": "胆大马武犯律条！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "啊，元帅！难道说俺马武我就不如他么？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "你呀？"
        },
        {
          "character": "马武",
          "type": "白",
