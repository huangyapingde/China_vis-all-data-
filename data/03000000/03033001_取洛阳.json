        {
          "character": null,
          "type": "stage",
          "text": "马武进帐。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "元帅！岑彭败阵而归，就该将他斩首，以正军法！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "军家胜败，古之常理，何罪之有？"
