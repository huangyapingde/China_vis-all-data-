        },
        {
          "character": null,
          "type": "stage",
          "text": "邓禹与岑彭耳语。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "得令！带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭上马，下。"
