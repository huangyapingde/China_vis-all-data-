          "text": "马武！岑爷我占先了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭下。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "去你的！"
        },
        {
          "character": "马武",
          "type": "西皮散板",
          "text": "不曾出兵我先料就， 损兵折将转回头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜茂上。"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "罢了，见过主公。"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "将军无令进帐何事？"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "元帅命岑彭攻取洛阳，只怕不能取胜。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "如何？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "你是怎么知道？"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "末将洛阳人氏，颇知地理。他不但不能得胜，还要损兵折将而归。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "哎咳！着！着！着！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "杜茂",
          "type": "白",
          "text": "元帅赐末将一支将令，生擒那苏献入帐！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "嘿嘿，又来了一个争功的！"
        },
