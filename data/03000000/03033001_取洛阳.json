          "character": "岑彭",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "扠出帐去！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马武起。"
        },
        {
          "character": "马武",
