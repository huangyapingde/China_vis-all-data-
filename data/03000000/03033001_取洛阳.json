        },
        {
          "character": "邓禹",
          "type": "西皮散板",
          "text": "将军虽好我不用，"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你当真不用？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "当真不用。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "果然不用？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "果然不用。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "你不用吗？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "不用。"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "不用就罢！"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "岑彭！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "邓禹",
          "type": "西皮散板",
          "text": "抖擞精神立功劳。"
        },
        {
          "character": "岑彭",
