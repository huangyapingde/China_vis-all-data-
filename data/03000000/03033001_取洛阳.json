        {
          "character": null,
          "type": "stage",
          "text": "四牢子手押马武同下。"
        },
        {
          "character": "邓禹",
          "type": "西皮散板",
          "text": "腹内机谋怎能讲，"
        },
        {
          "character": "四牢子手",
