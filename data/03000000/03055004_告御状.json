{
  "script_id": "03055004",
  "title": "告御状",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "宋太宗",
      "hangdang": "老生"
    },
    {
      "name": "赵德芳",
      "hangdang": "小生"
    },
    {
      "name": "呼延必显",
      "hangdang": "小生"
    }
  ],
  "plot": "杨延昭回京，告潘洪十大罪状。宋太宗赐旨三道，命呼延必显至雁门关捉拿潘洪。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引宋太宗同上。"
        },
        {
          "character": "宋太宗",
          "type": "引子",
          "text": "龙楼凤阁九重霄，有道君王坐龙朝。"
        },
        {
          "character": "宋太宗",
          "type": "念",
          "text": "午夜漏声催箭晓，九重春色醉仙桃。旌旗日暖龙蛇动，宫殿风微燕雀高。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "孤、大宋天子国号雍熙在位。只因胡儿打来战表，寡人命潘洪挂帅，杨家父子 以为先行，前去征剿，不知胜负如何。今日早朝。 内侍，展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨。展放龙门哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳上。"
        },
        {
          "character": "赵德芳",
          "type": "念",
          "text": "感叹忠良事，奏与叔王知。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "儿臣见驾，叔王万岁！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "平身，赐坐。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "皇儿上殿，有何本奏？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "启奏叔王：今有呼延老将军与杨家做保，气呕身亡了！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "唉，老将军哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋太宗哭。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "杨老将军围困两狼山，里无粮草，外无救兵，命七子回营搬兵求救。潘太师不 发人马倒也罢了；反提起打子之仇，将七将军绑在芭蕉树上，乱箭射死。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "咳，我朝又丢了一员虎将！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "杨老将军在两狼山下，望兵兵不到，望子子不归，在李陵碑下尽忠而亡！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "皇儿怎么知道？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "杨郡马回朝来了。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "为何不上殿见孤？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "他有父孝在身，不敢上殿。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "恕他无罪。 内侍，宣杨郡马上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "杨郡马上殿哪！"
        },
        {
          "character": "杨延昭",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "高拨子",
          "text": "为上殿先打朝王鼓， 午门外来了我叩阁臣。 朝前走不见了我的年迈父， 朝后看又不见七弟小英雄。 往日里上金殿弟兄们成双摆对， 到如今只落得延昭一个人。 凄惨惨悲切切把金殿来上， 有罪的杨延昭见圣君。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "罪臣、杨延昭见驾，吾皇万岁！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "杨郡马为何不抬起头来？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "恕卿无罪。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "头顶何物？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "御状。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭呈状，宋太宗看，念。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "“具叩阁人罪臣杨延昭，今告太师潘洪按兵不发，谋篡山河等……”"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "唔！大胆杨郡马！别人可以告得，潘太师乃当今国丈，你都敢告？吃小王一锏！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "皇儿，只要他告得有理。有道是：王子犯法，与庶民同罪。可以告得。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "可以告得？ 杨郡马，万岁准告，你有什么冤枉？一一诉来！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "容奏！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "杨延昭跪金阶啼哭掉泪， 尊一声万岁爷和八贤君。 我这里写就了御状一纸， 听为臣一本一本奏当今： 那胡儿打来了连环战表， 他要夺吾主爷锦绣乾坤。 潘仁美在金殿挂了帅印， 臣父子在马前做了先行。 在三关领兵来点卯， 误了日期问典刑。 多亏了呼延将军把情讲， 赦却了父子戴罪立功。 一计不成把二计定， 可怜他年迈之人气死边庭。 黄道日不发人和马， 黑煞日期要兴兵。 五百名校刀手把守关门上， 他要臣父子们将胡儿斩尽绝根。 要得胜许我们回营交令， 斩不尽杀不绝不许回营。 臣父子只得决一死战， 围困在两狼山好不惨情。 被番兵四下里围成铁桶， 内无粮草外无救兵。 命七弟回大营搬兵取救， 潘太师提起了打子事情。 将臣弟绑法标屈死可悯， 射一百单三箭一命归阴。 臣的父两狼山望兵不到， 他望子来子亦无音。 命臣我探听七弟信， 可怜他年迈人李陵碑下丧残生。 臣当初八个人把幽州闯， 到如今只剩下为臣一人。 没奈何逃出了边关外， 写下了御状叩明君。 臣不告圣天子三宫六院， 臣不告王子与龙孙； 臣不告朝中公侯驸马， 臣不告文武众公卿； 臣不告五府并六院， 臣不告各府州县共子民； 臣不告解粮官限误时刻， 十道本告的是太师潘洪。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "告他何来？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "一告他私通辽邦打战表， 二告他谋篡山河是真情； 三告他文官挂了武帅印， 四告他要臣父子做先行； 五告他逼得那呼延老将丧了命， 六告他上方宝剑乱斩人； 七告他公报私仇射死我七弟， 八告他害我父李陵碑下命归阴； 九告他在边关开怀畅饮， 十告他卖官爵私受金银。 臣告他若有一事错， 情愿枭首在午门。 杨延昭心中苦楚说不尽！"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "贤王听来也伤心。"
        },
        {
          "character": "宋太宗",
          "type": "唱",
          "text": "这是君也哭来，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "我臣也哭，"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "小王落泪，"
        },
        {
          "character": "大太监",
          "type": "唱",
          "text": "两旁内侍臣大放悲声。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "万岁准了臣的本， 君是君来臣是臣。 万岁不准臣的本， 回到火塘为庶民。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "皇儿传旨：可有粗心胆大之臣，去到雁门关提拿潘洪进京问罪？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳向内。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "万岁有旨：可有粗心大胆之臣，去到雁门关提拿潘洪进京问罪？"
        },
        {
          "character": "呼延必显",
          "type": "内白",
          "text": "呼必显愿往！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "启奏叔王：呼必显愿往。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "随旨上殿！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "随旨上殿。"
        },
        {
          "character": "呼延必显",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延必显上。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "扫殿侯呼必显见驾，吾皇万岁！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "万万岁！ 贤爷千岁！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "呼卿，命你去到雁门关提拿潘洪进京问罪，可有此胆量？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "小臣有此胆量。求万岁赐臣三道圣旨！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "哪三道圣旨？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "头道圣旨：提上方宝剑。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "二？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "二道圣旨：发饷银十万犒赏三军。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "三？"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "三道圣旨：后宫娘娘问候老太师金安。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "件件依从。正是："
        },
        {
          "character": "宋太宗",
          "type": "念",
          "text": "圣旨到北番，"
        },
        {
          "character": "呼延必显",
          "type": "念",
          "text": "捉拿奸佞还。"
        },
        {
          "character": "赵德芳",
          "type": "念",
          "text": "但愿多仔细，"
        },
        {
          "character": "呼延必显",
          "type": "白",
          "text": "贤爷！"
        },
        {
          "character": "呼延必显",
          "type": "念",
          "text": "臣知非等闲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延必显下。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "朝事已毕，请驾回宫！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}