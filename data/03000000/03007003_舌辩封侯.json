{
  "script_id": "03007003",
  "title": "舌辩封侯",
  "alias": [
    "扑油鼎；一名：蒯彻装疯"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "蒯彻",
      "hangdang": "老生"
    },
    {
      "name": "刘邦",
      "hangdang": "老生"
    }
  ],
  "plot": "汉高祖即位后，杀害功臣韩信，并诬蒯彻同谋作反。蒯彻乃佯装疯狂，希图避祸。及被陆贾寻获，往见刘邦。\n蒯彻历数杀戮功臣之非，刘邦以油鼎威胁，蒯彻不为所屈。刘邦恐失众心，乃赦蒯彻罪复封侯爵，并为韩\n信立祠享祀。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同上，站门，陆贾骑马上。"
        },
        {
          "character": "陆贾",
          "type": "念",
          "text": "堪叹忠良不到头，枉争功绩觅封侯。将军战马今何在，帅印高悬五凤楼。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "下官姓陆名贾。汉王驾下为臣，官居大夫。主听谗言，道韩信谋反叛上；萧何 设计将他诓进京来，在未央宫中，被吕后斩首。又言蒯彻主谋，汉王命我拿他 上殿问罪。 校尉们！"
        },
        {
          "character": "众校尉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "蒯文通乃是忠义之臣；若是相遇，不可造次。"
        },
        {
          "character": "众校尉",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "觅访去者。"
        },
        {
          "character": "陆贾",
          "type": "唱",
          "text": "秦始皇行无道惹动兵火， 南五岭北长城贪心太多。 东巡海西阿房民兵封锁， 愿子孙万万代独掌山河。 焚书籍坑儒生损德致祸， 巡视到沙丘地命如飞蛾。 楚怀王有仁德国安民乐， 将江山付刘项社稷重托。 灭嬴秦楚汉争军中有我， 说诸侯齐归汉俺同随何。 大乾坤归一统锦添花朵， 眼见得忠良臣如雪消磨。 未央宫杀韩信萧何起祸， 道他要兴人马杀进朝阁。 攀出了蒯文通与信结伙， 今拿他见天子休想命活。 奉君诏我不敢一时闲坐， 紧加鞭催坐马急快如梭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "二乞丐",
          "type": "内同白",
          "text": "打疯子，打疯子！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒯彻上。"
        },
        {
          "character": "蒯彻",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "都道我是疯魔谁能猜得， 倒落得无烦恼嬉笑呵呵。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "我姓蒯名彻字文通。曾与韩元帅兴汉灭楚，可恨萧何设计，道韩信欲谋天下， 攀出我与他同心叛逆。可怜三齐王命丧未央；又来拿我。是我假装疯魔，暂避 眼前之祸。韩元帅，三齐王！我累次劝你：留得霸王在，三齐王位在；勒逼霸 王死，三齐王位止。今果应我文通之言。身为统兵元帅，丧于妇人之手啊！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "叹只叹韩元帅诬遭其祸， 他执意不听劝自入网罗。 楚霸王在一日你心安乐， 霸王死三齐王骤起风波。 汉刘王得了地礼疏情刻， 心疑你起反意将广兵多。 恨萧何设奸计诓虎离座， 你身丧未央宫一命南柯。 彭越死英布亡三侯瞑目， 连累我蒯文通也难逃脱。 随机变装疯魔沿街避祸， 严父骨慈母肉难以舍却。 小胆人怎舍得高官厚爵， 光阴过马加鞭日月如梭。 去愁眉开笑脸在此坐卧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二乞丐同上。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "疯子！疯子！"
        },
        {
          "character": "蒯彻",
          "type": "笑",
          "text": "哈哈……"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "深施礼尊一声我儿……"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "不要玩笑。"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "我儿的哥哥。"
        },
        {
          "character": "二乞丐",
          "type": "白",
          "text": "胡说！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哈哈……快哉，乐哉！"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "你为什么这等快哉、乐哉？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "你二人问我的快乐呀？听了！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "今日里请宾客花厅欢乐，"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "为了什么事情？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "为匹配美佳人晏开东阁。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "你连饭都没有吃的，还有银子娶老婆么？我问你丈人是谁呀？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "我丈人是土地身受香火，"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "你丈母娘呢？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "听了！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "我丈母娘是庙内土地婆婆。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "谁给你作的媒人？"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "问媒人你两个惹他不过，"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "难道是皇帝么？"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "论爵位比皇帝还大许多。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "还大呢！他是谁呢？"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "天皇氏为媒证婚姻定妥，"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "说大话。你妻子好不好哇？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "好的好的。"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "我娇妻是广寒月里嫦娥。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "可有人与你道喜？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "有的有的！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "老寿星与王母同来庆贺，"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "吃的什么？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "有的有的！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "吃珍馐和美味人参燕窝。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "你头上没有戴的怎么拜堂成亲？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "我有呀！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "头戴着有新郎帽金花两朵，"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "你穿的什么？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "有有！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "腰系有白玉带身穿紫罗。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "可有人与你送亲？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "有的！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "送亲的二舅子你们两个，"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "胡说！我二人是你舅子么？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "你与我作舅子胜念弥陀。"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "又胡说！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哎哟！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "话重烦说得我腹中饥饿，"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "啊，有了！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "在怀内取出了面食馍馍。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "你吃，你吃！"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "不吃脏东西！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "咳！小人无福呀！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "此乃是瑶池内仙食仙果， 暗中有八宝丹五味调和。"
        },
        {
          "character": "众校尉",
          "type": "内同白",
          "text": "拿疯子！"
        },
        {
          "character": "二乞丐",
          "type": "同白",
          "text": "哎哟！有人拿你，我们快走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二乞丐同下。蒯彻呆望。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "耳边厢只听得人声吆喝， 休放走疯魔汉暗中逃脱。 火燃眉已近身无处藏躲，"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哎呀！罢！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "学孙膑卧羊圈足不敢挪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉引陆贾同上。"
        },
        {
          "character": "陆贾",
          "type": "唱",
          "text": "军民报蒯文通羊圈独卧， 下雕鞍静听他可是疯魔。"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "我哭声韩元帅， 尊声三齐王啊！ 挣得江山刘家坐， 你的功劳一旦抛却。 我文通命似风前烛， 如雪见日水流成河。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哎呀！屈死的韩元帅！"
        },
        {
          "character": "众校尉",
          "type": "同白",
          "text": "拿疯子。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "军士们闹轰轰指名叫我， 不出这羊圈门看他们如何。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "文通先生，是我陆贾在此，不必装疯，只管出来。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "呀，是陆大夫么？"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "我出来了！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "魏庞涓斗孙膑身惹重祸， 去双膝伏朱亥暗地相和。 孟尝君茶车计庞涓错过， 到后来马陵道涓入网罗。 是忠良见侯士何须藏躲， 常言道丑媳妇怕见公婆。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "呀！大夫！"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "先生装的好疯呀！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哎！吾是被奸臣萧何气疯的。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "不必装疯。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "大夫敢是请旨拿我？"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "我非请旨拿你。只因萧何又在圣驾台前奏道，你是假疯，命我寻你上殿。依我 之见，先生急速逃走，我上殿见君，只说寻你不着，谅萧何再不追究了。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "呀，为人在世性命由天，我岂肯连累大夫。既是萧何说我假疯，我就疯个样儿 与他看看。呈刑具来！"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "到了午门再上吧。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "朝廷王法岂可不遵！拿上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众校尉同上刑具。"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "在大街上刑具甘心加锁， 见汉王自有个情顺理和。 纵摆下尖刀山舍命闯过， 既要到阴曹府何惧阎罗。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "走！走！走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同拥下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四值殿、六太监、王陵、樊哙、萧何、陈平、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "朕设朝龙耳听净鞭三响， 自三皇至炎帝多少帝王。 尧传舜舜传禹天地恩养， 至商纣宠妲己淫乱朝堂。 姜子牙奉师命肩背神榜， 周武王始诛纣社稷久长。 恨幽王得天下无福受享， 在骊山放烽火自讨灭亡。 周辙东王纲坠诸侯结党， 逞干戈尚游说俱怀不良。 始春秋终战国兵多将广， 五霸强七雄出兵火难藏。 嬴秦氏始兼并贪心妄想， 传二世朕与项接战咸阳。 汉江山归一统朕已执掌， 恨韩信谋大位倚势癫狂。 斩首在未央宫谅无冤枉， 今诛却蒯文通方快心肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆贾上。"
        },
        {
          "character": "陆贾",
          "type": "唱",
          "text": "但愿得君恩厚文通赦放， 再若听萧何言文武慌忙。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "启万岁：臣将蒯文通拿到。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "啊，拿到了？"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "午门候旨。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "将油锅设在殿下！"
        },
        {
          "character": "四值殿",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四值殿同将油锅放在下场台口。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "陆贾替朕传旨，将叛逆文通押上殿来！"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "领旨。 武士听者：万岁传旨，将文通押上殿来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众校尉押蒯彻同上。"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "手戴有铁链扭如同上绑， 屈死鬼入地狱不惧阎王。 站立在殿角下偷眼观望， 文武臣执象笏摆列两旁。 贼萧何竟敢称汉大丞相， 陈平计办金垒救了汉王。 左朝臣名王陵事母至孝， 将樊哙在鸿门独逞刚强。 汉刘王福分大帝星明朗， 听谗言斩功臣自心不良。 俺到这森罗殿活命不想， 要学那殷比干剖心而亡。 再不作假疯魔大胆上闯， 生和死在顷刻万代名扬。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "启万岁：叛逆蒯彻当面。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "这就是害人的萧何！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "唗！蒯彻见朕为何不跪？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "啊！我那韩元帅不在此，教我去跪何人？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "岂不知韩信是孤之臣么？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "吾闻桀犬吠尧，各为其主。我受韩信推食之恩，只知有韩信，不知有陛下。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "这等说来，无怪你与韩信同谋造反！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "啊！这话是何人说的？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "韩信言道：若听蒯文通之言，免遭其冤。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "既有这话，叫他出来与我质对。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "叛逆韩信，早被寡人斩了。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "啊，韩元帅被你斩了？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "叛逆之贼，什么元帅！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "哎呀！陛下身为一朝天子，怎么这样糊涂！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "唗！怎见寡人糊涂？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "既是韩信道我同谋造反，就该拿我质对。为何听了谗言，将忠良斩首？可怜他 的功劳，化为灰烬，人人落泪，个个悲哀。哎呀万岁！太平原是将军定，哪见 将军享太平！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "国荒乱待韩信明珠在掌， 太平年主受福斩尽忠良。 在咸阳楚汉争刀兵交攘， 屡次见假龙现真龙隐藏。 都亏你在月下将韩信追访， 道他有韬略法能灭霸王。 学文王拜姜尚圣贤榜样， 为元戎掌生杀谁敢癫狂！ 九里山摆一阵将士尊仰， 韩元帅用兵法鬼伏神忙。 只杀得天地昏日月不旺， 只杀得众儿郎呼父唤娘； 只杀得年老人寸步难往， 只杀得闺门女躲避闺房； 只杀得楚战将东逃西散， 只杀得尸堆山血染长江； 只杀得逼虞姬先把命丧， 只杀得、楚霸王、抛盔弃甲、匹马单枪、力尽才自刎乌江。 韩信有盖世功龙心自想， 道他反几员将多少儿郎？ 兴萧何败萧何奸谋多广， 你是个人面貌禽兽心肠。 万岁爷今不把韩信旌奖， 天下人都道主是无道昏王。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "都道你舌辩徒言不虚谎，"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "值殿官！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "将蒯彻下油锅禁止言狂。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "将他扠下油锅。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "且慢！油锅在哪里？"
        },
        {
          "character": "值殿官",
          "type": "白",
          "text": "这是油锅！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "是煮我的？哈哈哈……"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "蒯彻，寡人传旨，将你扠下油锅，你为何发笑？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "韩生阻谏霸王不要迁都，霸王大怒，将韩生用油锅烹死；吾主今日学了霸王之 见，烹我文通。 韩元帅！三齐王！你在阴曹相等，俺即来也！ 萧何呀，贼子！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "你不该在君前虚言毁谤， 把一个有功臣屈死未央。 大梁王名彭越何事犯上， 你设计将他斩人人恓惶。 将他的死尸首作成肉酱， 送与那九江王诈言糕糖。 下咽喉霎时间腹内不爽， 吐江心变螃蟹英布身亡。 俱是你贼萧何奸谋计广， 我既到深山内何惧豺狼！ 脱去了破衣衫油锅火葬，"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "学梅伯抱红柱一死何妨！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "住了！蒯彻愿下油锅，难道你不怕死？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "唉！俺到此地，谅难活命，岂望生乎！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "韩信谋反，可是真情？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "万岁道韩信谋反是真，他在九里山，大摆三十六营，小埋伏七十二处，统领雄 兵百十余万，战将千百余员。天下斩杀之权，在他掌握之中，那时不反，岂到 此时才反？列位大人思想，万岁龙心参详。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "啊，啊，啊，萧丞相。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "臣、臣、臣。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "你沉下水要淹死的！哎呀万岁，韩信死得冤枉啊！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "论运筹帷幄中张良名望， 临阵上败又胜韩信计强。 张子房出奇计箫声响亮， 吹散了子弟兵离了咸阳。 见吾主斩功臣他也胆丧， 因此上弃官职学道游方。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "活百岁也难免黄泉不往， 伴君王谅无有善终下场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒯彻扑油锅，拦。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "住了！将油锅搭了下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四值殿同将油锅抬下。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "蒯文通诉出了韩信冤枉！"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "韩信是开国忠良啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒯彻哭。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "朕心中细思量大失主张。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "内侍！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "领文通即穿戴一品冠蟒，"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "臣不作官。"
        },
        {
          "character": "众臣",
          "type": "同白",
          "text": "君旨难违。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒯彻随大太监同下。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "朕只为秦无道国乱民荒。 亏众卿灭项羽烟尘扫荡， 汉江山归一统帝道遐昌。 三齐王威权大兵多将广， 心疑他起反意夺朕家邦，故斩忠良。"
        },
        {
          "character": "陈平",
          "type": "唱",
          "text": "喜孜孜尊一声萧老丞相， 俺陈平才学浅腹少文章。 你与君不远邻也是乡党， 还需要秉忠心治国安邦。"
        },
        {
          "character": "王陵",
          "type": "唱",
          "text": "臣慈母为君国舍身命丧， 在战场知有君不知有娘。 吾主爷洪福大刀藏马放， 我王陵要仗你量如海江。"
        },
        {
          "character": "樊哙",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "樊哙",
          "type": "唱",
          "text": "俺樊哙心直爽临阵冲撞， 鸿门宴保吾主匹马单枪。 你害我我害你看谁上当， 不学那三齐王被你计诓。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "萧何",
          "type": "唱",
          "text": "文武臣俱道我君前毁谤， 只羞得话难言脸上无光。 我本待在金殿直言奏上， 怕的是君惭愧我罪难当。 宰相量如沧海息气忍让，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监领蒯彻同上。"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "滚油锅提出了三九冰霜。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "为臣死罪。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "卿家忠义之言，寡人如梦初醒。朕发饷银，与韩信、彭越、英布建造忠臣庙， 春秋二祭。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "谢吾皇万岁，万万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "封卿为“舌辩侯”。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "臣不敢奉君。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "要学范蠡，舟泛五湖，不作文种受戮。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "卿家呀！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "父子亲君臣义朝思暮想， 非是那越勾践败国之王。 范大夫泛五湖心有志量， 那文种贪富贵哪知不良。 汉江山仗众卿洪福朕享， 君治国民有家不敢荒唐。 携卿手同见过萧何丞相， 一殿臣休争论你弱我强，辅朕尊良。"
        },
        {
          "character": "蒯彻",
          "type": "白",
          "text": "领旨。 啊，丞相！"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "蒯彻",
          "type": "唱",
          "text": "俺是个直心肠快言清爽， 老丞相沧海量恕某癫狂。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿随朕进宫与舌辩侯压惊，卿等陪宴。"
        },
        {
          "character": "众臣",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}