{
  "script_id": "03046003",
  "title": "白良关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "尉迟宝林",
      "hangdang": "净"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "徐懋功",
      "hangdang": "老生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    },
    {
      "name": "梅秀英",
      "hangdang": "旦"
    },
    {
      "name": "刘国桢",
      "hangdang": "净"
    }
  ],
  "plot": "唐太宗出征，尉迟恭为先行。兵至白良关，守将刘国桢，为尉迟恭鞭伤；其子宝林，奋而出战。先是，尉迟\n恭之妻梅秀英，身怀宝林，为刘国桢霸占，时逾十馀年。宝林战败尉迟恭，归告母氏。其母始诉底细，旋自\n尽。宝林出阵，父子相认，杀死刘国桢，同见唐太宗。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引唐太宗同上。"
        },
        {
          "character": "唐太宗",
          "type": "引子",
          "text": "龙门展放开，文武拜金阶。"
        },
        {
          "character": "唐太宗",
          "type": "念",
          "text": "金殿上香烟缭绕，瑞彩升紫雾飘飘。众公卿丹墀拜倒，圣天子驾坐龙朝。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "孤、大唐天子贞观在位。自登基以来，风调雨顺，国泰民安。今当设立早朝。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 展放龙门哪！"
        },
        {
          "character": "徐懋功",
          "type": "内白",
          "text": "嗯嚇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐懋功上。"
        },
        {
          "character": "徐懋功",
          "type": "念",
          "text": "周刚打战表，上殿奏当朝。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "臣、徐勣见驾，吾皇万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "臣启万岁：今有北国周刚打来连环战表，请我主御览。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐懋功呈表，唐太宗看表。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "唔呼呀，原来是北国周刚打来连环战表，要孤御驾亲征。 卿家，何计退贼？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "万岁，可命护国公以为正帅，鄂国公以为副帅，鲁国公以为前站先行，保护我 主御驾亲征，哪怕那胡儿不灭？"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "卿家替孤传旨，宣护、鄂、鲁三家国公上殿！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "领旨。 万岁有旨：宣护、鄂、鲁三家国公上殿！"
        },
        {
          "character": "秦琼、尉迟恭、程咬金",
          "type": "内同白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、尉迟恭、程咬金同上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "大将生来志量高，"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "旗开得胜显功劳。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "三十六路宣花斧，"
        },
        {
          "character": "秦琼、尉迟恭、程咬金",
          "type": "同念",
          "text": "凌烟阁上把名标。"
        },
        {
          "character": "秦琼、尉迟恭、程咬金",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、尉迟恭、程咬金同跪。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "秦琼、尉迟恭、程咬金",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、尉迟恭、程咬金起。"
        },
        {
          "character": "秦琼、尉迟恭、程咬金",
          "type": "同白",
          "text": "宣臣等上殿，有何国事议论？"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "今有北国周刚打来连环战表，孤要御驾亲征。护国公听封！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "以为正帅！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "鄂国公听封！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "以为副帅！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "鲁国公听封！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "以为前站先行！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "三家国公，保孤御驾亲征。"
        },
        {
          "character": "徐懋功、秦琼、尉迟恭、程咬金",
          "type": "同白",
          "text": "朝事已毕，请驾回宫。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐太宗下。大太监、四太监同下。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "众家国公，回府披挂！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "鄂国公为何拦阻？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "某家有一事不明，要在列公台前领教。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "有话坐下讲。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "有何金言？当面请讲！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "我等金殿奉旨，领兵扫北，末将昨晚偶得三梦，不知主何吉兆，要在列公台前 领教。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "请问这头一梦？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "这头一梦，末将带领家丁，郊外射猎，乱草之中，窜出一只白兔。某家左手持 弓，右手搭箭，照定白兔射去。那兔带箭而逃。某家催马就赶，赶到太行山下， 只见那山喀喳喳倒将下来。不知主何吉兆？"
        },
        {
          "character": "徐懋功、秦琼",
          "type": "同白",
          "text": "这！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我想是不祥之兆！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "此番扫北，必须要靠山近水安营扎寨，山要倒啦，砸也把咱们砸死啦。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "请问这第二梦？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "这第二梦，某家全身披挂，与盖苏文交战，战了数十馀合，那贼战某不过，败 下阵去。某家催马就赶，赶到海岸之上，只见那海水它就哗喇喇一啸而干。不 知主何吉兆？"
        },
        {
          "character": "徐懋功、秦琼",
          "type": "同白",
          "text": "这！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "还是不祥之兆！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "水要干啦，渴也把咱们给渴死啦。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "请问这第三梦？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "这第三梦，末将清晨起来，书房净面。丫鬟报道：后花园中百花开的茂盛。末 将前去观看，左手执镜，右手指花，只见那花开花谢，镜落尘埃，分为两半。 不知主何吉兆？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "这！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "愈发是不祥之兆啦！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "此番扫北，圣上好比花心；众家国公好比花瓣，花开花谢，恐怕不久咱们就要 散摊子啦！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "不是这样讲。 鄂国公，此番扫北，必有夫人、公子相会。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "夫人、公子相会。"
        },
        {
          "character": "尉迟恭",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老黑呀，你还乐哪？你投唐以来，只有黑、白二女，哪有夫人、公子流落在北 国哪？分明他耻笑你我武将无后啊。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "就是他？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不是他，还是我吗？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "先生哪！想末将投唐以来，只有黑、白二氏，哪有夫人、公子相会？你分明笑 我武将无后！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "山人道你有夫人、公子相会，并非嘲笑。你休要误会。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "且慢！常言道：梦从心头起。讲什么吉凶祸福！不必争论，你我披挂要紧！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "列公啊！"
        },
        {
          "character": "徐懋功",
          "type": "唱",
          "text": "忆昔马邑遭寇乱， 居民百姓掳北边。 尉迟宝眷怎能免， 不然因何无信传？ 此番扫北去征战， 可能相会在北番。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "两国交锋在眼前， 家务事休提作战当先。 回头便把咬金唤， 你今做了先行官。 速到校场把人马点， 保主圣驾征北番！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "元帅那里把令传， 咬金做了先行官。 回头便把老黑唤，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老黑你可记着！"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "夫人面前你要替我问安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。四龙套同暗上。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "先生说话言太潜， 细听某家说根源： 投唐来只有那黒、白二氏女， 哪有那妻室孩儿失落在北番？ 怒气不息我就跨雕鞍，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲带马，尉迟恭上马。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "扫北国一战成功奏凯回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、四龙套同下。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "运筹决算你执掌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        },
        {
          "character": "徐懋功",
          "type": "唱",
          "text": "十八家国公保大唐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐懋功下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "忆昔当年在瓦岗，贾家楼上一炉香。三十六路宣花斧，一斧劈开老君堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套自两边分上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "俺、程咬金。奉了元帅将令，校场点动人马。人马齐备。远远望见元帅来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引秦琼、尉迟恭同上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "金装锏盖世无双，"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "水磨鞭保定唐王。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "圣驾到此，速报我知。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "唐太宗",
          "type": "内白",
          "text": "圣驾到！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "启元帅：圣驾到。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "一同接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠引唐太宗同上。"
        },
        {
          "character": "秦琼、尉迟恭、程咬金",
          "type": "同白",
          "text": "参见万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "传孤旨意：文武百官免送；大兵打从得胜门而出，就此响炮离京！"
        },
        {
          "character": "秦琼",
