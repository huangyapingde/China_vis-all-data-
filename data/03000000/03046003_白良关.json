        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林上。"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "适才间与唐将会一阵， 他国元帅鸣金收兵。 迈虎步且把那二堂来进， 母亲台前问安宁。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "孩儿参见母亲！"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "吿坐。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "全身披挂，与何人交战？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "与唐将交战。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "胜负如何？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "两军阵前，未分胜负，他国元帅鸣金收兵。明日孩儿定取那贼黑头！"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "可曾问过那唐将的名姓？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "复姓尉迟、名恭、字敬德。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "复姓尉迟、名恭、字敬德。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "梅秀英",
          "type": "唱",
          "text": "听说儿夫到来临， 怎不叫人喜在心。 回头我对孩儿论， 为娘言来听分明： 刘国桢不是儿的亲——"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "噤声！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林、梅秀英同两望。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "亲什么？"
        },
        {
          "character": "梅秀英",
          "type": "唱",
          "text": "亲生的父，"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "梅秀英",
          "type": "唱",
          "text": "尉迟恭他是儿的老爹尊。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "说什么亲来不是亲， 倒叫孩儿解不明。 走向前来忙跪定，"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "快与孩儿说详情。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "起来，坐下。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "吿坐。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "儿呀，你我母子原不是本地人氏。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "哪里人氏？"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "山西马邑县人氏。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "因何至此？"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "只因刘国桢作乱，反抢马邑县，将为娘掠进关来，强霸为婚。本当不允，怎奈 身怀你这小冤家——"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "话已说明。报仇也在你，不报仇也在你！"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "有何为证？"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "钢鞭为证。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林拿鞭看。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "“尉迟宝林！尉迟宝林！”哎呀！"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "看过钢鞭果是真， 反把仇人当严亲。 手持钢鞭前堂奔，"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "前堂打死刘国桢。"
        },
        {
          "character": "梅秀英",
          "type": "白",
          "text": "有道是：单丝不能成线，孤树不能成林。明日阵前，与你父亲说明，再报此仇， 也还不迟。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "怎奈孩儿恶气难消！"
        },
        {
          "character": "梅秀英",
          "type": "念",
          "text": "暂将恶气存腹内，"
        },
        {
          "character": "尉迟宝林",
          "type": "念",
          "text": "今晚且做懵懂人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅秀英、尉迟宝林同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引秦琼、尉迟恭、程咬金同上。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "小将讨战，还要尉迟老将出马。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "昨日阵前大交兵， 娃娃武艺果然能。 人来带过马能行，"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "须要小心！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "两军阵前见机行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "三军与爷严肃静！ 且听探马报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、程咬金、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十—场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林上。"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "二堂领了母亲命， 两军阵前认天伦。 催马加鞭战场奔， 尉迟老将快出营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "昨日阵前饶儿命， 今日又来送残生。 水磨钢鞭朝下打！"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "这一鞭看在父子情。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃敢是怯战？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "老将，非是你少爷怯战，此处窄小，这跑、跑不开你少爷的马；这抡哪！抡不 开你少爷的鞭。看前面有一柳林，你我那里见个高下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃，任你设下虎穴龙潭，你老爷何惧？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "如此你要来呀！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "怎的不来？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "你要来呀！"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "叫声老将忙随定！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "这娃娃有什么巧计生？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林上。"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "来在柳林下战马， 老将到此我认爹尊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "催马加鞭到柳林，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林跪。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "只见娃娃跪埃尘。 你老爷我日抢三关夺八寨， 夜探白壁介休城。 唐天子脱袍卷鞭某才归真主，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "北国闻名害头疼。"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "老将不必起疑心， 我是你孩儿要认——"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "认什么？"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "要认爹尊。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "战我不过该归顺， 为什么阵前认爹尊？"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "家住山西马邑县， 我母名叫梅秀英。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "这娃娃提起了那梅秀英， 想起当年家事情： 祖居山西马邑县， 夫妻们打铁度光阴。 铁中得了纯钢宝， 打成了雌雄鞭二根。 别的来历我不问，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "阵前认父有何凭？"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "老将若是不肯信， 现有钢鞭做证凭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林递鞭，尉迟恭看鞭。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "“尉迟宝林！”"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭看自己鞭。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "“尉迟敬德！”"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "一见钢鞭果是真， 父子们相逢在柳林。 钢鞭挑起亲生子，"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "翻身上了马能行。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "为父仇人哪一个？"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "白良关中刘国桢。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "宝林前面把路引！"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "白良关去杀刘国桢。"
        },
        {
          "character": "尉迟宝林",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "尉迟宝林",
          "type": "唱",
          "text": "紧消停来慢消停， 父子还须定计行。 假战三合败了阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟宝林下。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "钢鞭一举晓三军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        }
      ]
    },
