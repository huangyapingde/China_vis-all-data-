{
  "script_id": "03101002",
  "title": "水淹七军",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "庞德",
      "hangdang": "净"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    },
    {
      "name": "于禁",
      "hangdang": "老生"
    }
  ],
  "plot": "樊城被关羽围困，破在且夕。曹操遣于禁、庞德驰援。庞德预制木榇，誓与关羽决战。于禁嫉功，将七军移\n屯罾口川，关羽乘襄水上涨，放水淹没七军，生擒庞德、于禁。关羽割去于禁两耳，放归，以辱曹操。庞德\n不降，被斩，关羽甚惜之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "庞德上，起霸。"
        },
        {
          "character": "庞德",
          "type": "念",
          "text": "头带金盔一点红，身披铠甲透玲珑。上阵全凭刀和马，要擒关羽立奇功。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "某、姓庞名德，字令名。奉了魏王钧旨，去至樊城解围。元帅升帐，辕门候令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵、于禁同上。〖点绛唇〗。"
        },
        {
          "character": "于禁",
          "type": "念",
          "text": "楚、汉争雄旧战场，分合天下一兴亡。中原逐鹿三分势，赤胆忠心报魏王。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "本帅、姓于名禁字文则。今有关羽攻打樊城甚急，曹仁累战难胜，魏王命我为 帅，庞德以为前战先行，去到樊城解围。今乃黄道吉日，正好开兵。 来！"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "庞将军进帐！"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "庞将军进帐！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "报！庞德告进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德进。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "将军少礼！请坐！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "谢座！唤末将进帐，有何将令？"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "今奉命前来樊城解围，魏王有命，言道那关羽智勇双全，不可轻敌。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "元帅！某今去至樊城，要带木榇一口，与关羽决一死战，定要叫他的一世英名 付与流水！若是不胜，就战死沙场！"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "唗！未曾出兵，先自出言不利，本当将你斩首，唯恐兴兵不吉。暂且记下。 众将官！兵发罾口川！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "且慢！想罾口川这一地名，恐与元帅不利，不去也罢。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "本帅用兵，神鬼难侧。不必多言，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "赤面丹心扶社稷，秉赤胆、保定汉室；威镇华夏、盖世奇，灭孙、曹一统华夷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "参见父王！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "北拒曹瞒东拒吴，威镇荆襄保西都。义存汉室尊帝统，志在春秋一部书。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某、关羽。大哥西川为王，三弟镇守阆中，某家总督荆襄一带。那曹仁被某一 战，困在樊城。闻听曹操命于禁带兵前来，也曾命人打探，未见回报。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报事的！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "随我来！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子进帐。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有庞德带定木榇，前来讨战，百般叫骂。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好个胆大庞德，竟致前来骂阵。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "任尔纵有千军勇，难逃关某偃月刀！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "前去迎敌！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊！ 众将官，迎敌去者！"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、周仓、关羽同上，四魏兵、庞德同上，同会阵。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "呔！马前来的，敢是关羽？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "然！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "关羽，久闻你英雄自命，目中无人，俺今日带来木榇一口，要与你决一死战。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "庞将军，尔身为大将，临阵何必出此不利之言！依关某相劝，归顺西蜀，不失 封侯之位。将军思之。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "一派胡言！看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、庞德同架住，四蜀兵、四魏兵同钻烟筒下。关羽、庞德对刀，关羽勒马停刀。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "敢是怯战？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你家元帅鸣金，何言怯战？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "既是俺家元帅鸣金，你我明日再战！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "但凭于你。"
        },
        {
          "character": "庞德",
          "type": "念",
          "text": "收兵卷旗号，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德下。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "明日动干戈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、周仓同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、周仓、四蜀兵同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵、庞德同上。四车夫持车旗同上。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "何处粮草？"
        },
        {
          "character": "四车夫",
          "type": "同白",
          "text": "蜀营粮草。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "抢回大营。"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵拥四车夫同下，庞德随下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、周仓、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吩咐下去，人不可卸甲，马不可离鞍，明日五鼓天明，大战庞德。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "人不可卸甲，马不可离鞍，五鼓天明，大战庞德！"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵同下。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "传令已毕！"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "正在厮杀忽卷旗，是何战策使人疑？强中自有强中手，庞德小儿未可欺。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "适才与庞德交战，若不是于禁鸣金收兵，某家险遭不测！老了哇！老了！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "想当年弟兄们曾结义， 乌牛白马祭苍天。 大破黄巾兵百万， 虎牢关前显桃园。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "庞德好铠甲也！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "头戴着乌油盔齐眉盖顶， 身穿着乌油甲甲似龙鳞。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "跨下一骑好马也！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "跨下一骑乌骓马， 亚赛关某赤兔胭脂。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "庞德好刀法也！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "手使着青铜刀一把， 亚赛关某偃月寒。 思来想去心烦乱，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "且把春秋仔细观。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报事的！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "随俺来！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "庞德抢去粮草！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "传令下去，三军不可自乱，三日内自有粮草应用。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "下面听者！"
        },
        {
          "character": "四蜀兵",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "主帅有令：三军不可自乱，三日内自有粮草应用。"
        },
        {
          "character": "四蜀兵",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "传令已毕。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "立地擎天大丈夫，目空北魏藐东吴。今日竟为敌所误，再把春秋仔细读。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀来！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀哇，刀！自从你到某手，过五关斩六将，何等威风，如今遇见小小的庞德竟 战他不过，真真的——"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "青龙刀何等威风煞气，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "庞德小儿，尔好威风，尔好煞气！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "尔归顺曹瞒藐视关将。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平上。"
        },
        {
          "character": "关平",
          "type": "念",
          "text": "将相本无种，男儿当自强。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "参见父王！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "启父王：今有于禁，将人马撤入罾口川！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "出帐观营！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "离却了九顶八宝中军帐， 又听得曹营内、大小儿郎闹嚷嚷。 大破黄巾兵百万， 虎牢关前把名扬。 过五关来斩六将， 擂鼓三通斩蔡阳。 在古城弟兄曾相会， 带领人马镇荆襄。 关平、周仓把土山上， 上得山来看四方！ 这边厢高来，那边低， 山高水低不相宜。 看罢营寨哈哈笑，"
        },
        {
          "character": "关羽",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": "关平、周仓",
          "type": "同白",
          "text": "为何发笑？"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "笑只笑，于禁不会用兵机。 关某若使一条计， 笼中之鸟怎能飞！ 关平、周仓归营去， 准备战船与水具。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报事的！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "随俺来！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "白河水涨。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探！"
        },
        {
