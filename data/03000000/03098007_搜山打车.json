{
  "script_id": "03098007",
  "title": "搜山打车",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "程济",
      "hangdang": "老生"
    },
    {
      "name": "建文帝",
      "hangdang": "小生"
    }
  ],
  "plot": "明成祖以靖难为名，兴兵直取金陵。建文帝与吏部尚书程济乔装逃出，潜居白云观。礼部尚书严震直奉旨搜\n山，获建文帝，打入囚车，押解入都。程济拦路，痛诋严震直。严震直悔悟，打车自刎。程济与建文帝遂得\n逃走。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二差役引严震直同上。"
        },
        {
          "character": "严震直",
          "type": "引子",
          "text": "居官秉忠心，食俸禄，当报君恩。"
        },
        {
          "character": "严震直",
          "type": "念",
          "text": "在朝执政扶乾坤，但愿四海息烟尘。口道忠心与赤胆，却另怀藏一片心。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "下官、严震直。燕王驾下为臣，官拜尚书之职。只因我主放走建文帝，有吏部 程济保护，逃出皇城，不知去向。昨日探马报道，离城十里之外，有一白云观， 来了一僧一道，相貌不俗，决非等闲之辈。今奉王命，带领长随前去捉拿。 如果是他君臣二人，斩草除根，以免后患。 来！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "城外白云观去者！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "建文帝",
          "type": "内白",
          "text": "阿弥陀佛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "建文帝上。"
        },
        {
          "character": "建文帝",
          "type": "四平调",
          "text": "乾坤混乱干戈动， 何日才得定太平。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "我、建文帝。自从逃出皇城，君臣暂在白云观隐身，观院却还僻静，倒也清闲。 今日忽然眼跳心惊，不知主何先兆，令人好难解也！"
        },
        {
          "character": "建文帝",
          "type": "四平调",
          "text": "为什么心惊肉又跳？ 行不安来坐不牢。 见乌鸦不住当头叫， 吉凶祸福难猜着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。四青袍、二差役、严震直同上。"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "来此已是白云观。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "打了进去！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二差役同打门，同进。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "哈哈哈……你在这里？"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "啊！你们是些什么人？为何打进我的观来？"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "呀呀呸！事到如今，还想隐瞒，难道我不认得你是建文帝么？"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "你认得我是建文帝，难道我就不认得你是严震直么？"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "今日才认得你严老爷！"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "建文帝",
          "type": "四平调",
          "text": "你平白无故起波涛， 苦害忠良为哪条？ 天理昭彰循环报， 难逃骂名万古标！"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "严震直",
          "type": "四平调",
          "text": "今奉旨意出皇朝， 海角天涯捕亡逃。 这是你自作自受大限到， 却又何必絮叨叨？"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "来呀！铁链手扭打上囚牢！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同与建文帝带手铐，车夫上，搀建文帝上车，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "程济",
          "type": "内白",
          "text": "无量佛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济上。"
        },
        {
          "character": "程济",
          "type": "四平调",
          "text": "昨奉师命送故交， 一路凄凉落叶飘。 叹人生徒把名利抱， 朝东暮西奔波劳。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "程济。昨奉师命，护送故交，畅谈彻夜。今朝洒泪而别。想大师定在观中悬望。 不免急急赶回便了。"
        },
        {
          "character": "程济",
          "type": "四平调",
          "text": "回复师命忙就道， 怕的是大师愁闷心焦。 为何此时身发躁？ 遍体生津似水浇。 白云观路不远急行来到， 猛抬头见面前岔事一条。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "啊！这山门被毁，隔扇打坏，是何缘故？也罢！不免请出大师一问，便知端的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济向内。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "有请大师！有请大师！有请大师！ 啊，大师不见，想是在观外游玩，待我寻找。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济出门。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "啊大师，啊大师！哎呀，好奇怪也！"
        },
        {
          "character": "程济",
          "type": "四平调",
          "text": "为什么叫不应来寻不着， 难道说这半山出了妖魔？ 只见那山门坏隔扇打破， 大师踪迹难捉摸。 急得我程济心如油火， 费思索解不出其故为何。"
        },
        {
          "character": "四青袍",
          "type": "内同白",
          "text": "嗯咳！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "哎呀！那厢来了一伙人役，待我闪在一旁，听他们讲些什么。正是："
        },
        {
          "character": "程济",
          "type": "念",
          "text": "要知心腹事，但听口中言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二差役同上。"
        },
        {
          "character": "二差役",
          "type": "同念",
          "text": "奉了严爷命，捉拿建文君。来在中途路，想起老道人。"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "请啦！"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "请啦！"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "你我奉了严尚书之命，捉拿建文皇帝。皇帝拿获了，中途路上，严爷又想起什 么老道程济来啦，又命你我二次捉拿。咱们观中走走！"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "走喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二差役同走圆场。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "来此已是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二差役同向内。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "老道程济！老道程济！ 这边不见，那边寻找。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二差役同向内。"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "老道程济！老道程济！"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "四下不见，难道叫你我变一个不成吗？"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "你我先去回复严爷！"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "言之有理。请！"
        },
        {
          "character": "差役甲",
          "type": "念",
          "text": "回复严命，不见道人。"
        },
        {
          "character": "差役乙",
          "type": "念",
          "text": "四下无有，哪里找寻！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程济上。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "哎呀，愧煞我也！适才听差役言道，建文帝被他们拿住；中途路上，又想起我 程济，故此前来捉拿。想我对天发下誓愿：永保大师无事；今日被他们拿去， 有何脸面去见去世的先帝也！"
        },
        {
          "character": "程济",
          "type": "二黄导板",
          "text": "料不想平地风波祸事到，"
        },
        {
          "character": "程济",
          "type": "回龙",
          "text": "莫非是天绝人定数难逃？"
        },
        {
          "character": "程济",
          "type": "二黄原板",
          "text": "好容易死中求活把君保， 十六载的功劳一旦抛。 为人不能全忠孝， 枉在人间逞英豪？"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "程济",
          "type": "二黄原板",
          "text": "跟踪差役——"
        },
        {
          "character": "程济",
          "type": "二黄散板",
          "text": "踉跄就道， 要救大师出笼牢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四青袍、二差役、车夫、建文帝、严震直同上。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "人役们！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "离城多远？"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "十里之遥。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "就此趱行者！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同走圆场。"
        },
        {
          "character": "程济",
          "type": "内白",
          "text": "严老先生慢走！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "启爷：有一老道赶来。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "想是程济赶来。我不寻他，他倒来赶我。 人役们！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "人马扎住，路旁等候便了！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "程济",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济上。"
        },
        {
          "character": "程济",
          "type": "二黄摇板",
          "text": "疾走不觉路途远， 奔得我两腿疼痛汗不干。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "我道是谁，原来是严老先生。请了！"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "我道是谁，原来是程济。你赶来做甚？"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "我特来贺喜。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "贺的什么喜？"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "我想燕王为了建文帝，花费多少兵马钱粮，不曾拿获。如今被严老先生所擒， 必得千金赏、万户侯，岂不可贺呀？"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "嗯！因功受赏，理所当然。我与兄台交厚，故意放你逃走，为何自投罗网？"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "深感你的恩情！多谢你的美意！"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "些许薄情，何足挂齿？"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "严震直啊，老匹夫！想你我当日一殿为臣，俱食朝廷的俸禄，同受皇家的深恩。 不幸圣上失和，骨肉生变，为臣者理应秉定忠心，纠正朝纲才是。如今你不 能替主分忧，反将主献与仇家，严震直啊老匹夫！你死在九泉，有何脸面去见 那太祖高皇噢！"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "程济",
          "type": "二黄摇板",
          "text": "你也曾食过他的俸禄在朝廊， 你也曾封妻荫子门楣光。 自古来忠臣相标榜， 岂可事仇把旧主伤？ 全不念身受恩重如山样， 全不念君王赐字授金章。 到如今媚新主大义全忘， 岂不怕留骂名万古传扬？ 谄媚人直同那鹦鹉学唱， 讲节操怎能比苏武牧羊？ 这行为衣冠中禽兽一样，"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "贼子呀贼子！"
        },
        {
          "character": "程济",
          "type": "二黄摇板",
          "text": "你焉能禄位功名永久长？"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "苦哇！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "哎呀且住！那旁囚车里面，乃是我主大师，我赶到此间，原为略尽君臣之义， 不免向前相劝一番便了！"
        },
        {
          "character": "程济",
          "type": "三叫头",
          "text": "大师！我主！哎呀大师呀！"
        },
        {
          "character": "程济",
          "type": "二黄导板",
          "text": "自盘古到如今乾坤混乱！"
        },
        {
          "character": "程济",
          "type": "三叫头",
          "text": "大师！我主！哎呀大师呀！"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "人役们！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "小心扎住者！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "程济",
          "type": "二黄慢板",
          "text": "哪有个帝王身上囚槛？ 现如今王纲坠奸臣当权， 难指望一统太平年。 可怜主也曾东西战， 可怜主也曾把民安； 可怜主九五之尊却被那燕王篡， 可怜主失却了锦绣江山； 可怜主吃只有黄虀淡饭， 可怜主穿只有补衲僧衫； 可怜主受尽了千般磨难， 可怜主皈佛教了却尘缘。 本打算图清净万事不管， 落一个自怨自艾、自劝自慰、隐居深山。 谁想到风波起又被拘管， 系缧绁好一似罪犯当官。 惨凄凄囚车旁与我主会面， 倘不幸晴天霹雷、我主有险、微臣束手、心如箭攒。 但愿主此一去少受颠险， 但愿主一路上清吉平安； 但愿主蒙燕王骨肉情念， 但愿主得生路乐享田园。 恨当朝文武臣旧恩不感， 我程济死九泉也难心甘。 在车前哭得我肝肠痛断、肝肠痛断，"
        },
        {
          "character": "程济",
          "type": "哭头",
          "text": "我那被屈含冤的主啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同哭。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "我不许你哭！"
        },
        {
          "character": "程济",
          "type": "二黄摇板",
          "text": "大限到怎能够妙手回天！"
        },
        {
          "character": "四青袍、差役甲",
          "type": "同哭",
          "text": "哎呀！"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "什么事情，你们这么哭哇？"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "你还没听见吗？"
        },
        {
          "character": "差役乙",
          "type": "白",
          "text": "听见什么？"
        },
        {
          "character": "差役甲",
          "type": "白",
          "text": "听见什么？想这样的差事，你我还当它干什么？谁不是建文帝的臣子，哪个不 是他的子民？吃他的粮饷长大的，还要拿他请功受赏，天理何在？良心何存？"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "你我不如各自散去了吧！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同二黄摇板",
          "text": "为人不把良心正， 后来如何把官升。"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "散啦！"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "人役们！"
        },
        {
          "character": "四青袍、二差役",
          "type": "同白",
          "text": "什么事情？"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "你们不遵国法，违令者斩！"
        },
        {
          "character": "二差役",
          "type": "同白",
          "text": "什么，斩？剐都不怕你。先给你一下子，你别妄自尊大啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二差役同打严震直，同下。四青袍同下。"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "且住！看他君臣二人哭得可怜。人役们俱已离叛，我还有何脸面生在人世？也 罢！不免拜谢老王爵禄之恩，寻个自尽了吧！"
        },
        {
          "character": "严震直",
          "type": "二黄摇板",
          "text": "跌跪尘埃珠泪滚， 吃什么爵禄报什么恩？ 为臣不能救主命， 子孙万代落骂名。 三尺龙泉出了鞘，"
        },
        {
          "character": "严震直",
          "type": "白",
          "text": "程济！"
        },
        {
          "character": "严震直",
          "type": "二黄摇板",
          "text": "放你君臣远逃生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严震直打车。"
        },
        {
          "character": "严震直",
          "type": "三叫头",
          "text": "我主！老王！罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严震直自刎死。"
        },
        {
          "character": "建文帝、程济",
          "type": "同白",
          "text": "哎呀严尚书啊！"
        },
        {
          "character": "建文帝",
          "type": "二黄摇板",
          "text": "一见尚书丧了命， 你为小王轻了生。"
        },
        {
          "character": "程济",
          "type": "二黄摇板",
          "text": "谁叫你背主求荣图侥幸， 报应循环天鉴明。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "哎呀大师呀！尚书已死，众将已散，此时不走，等待何时！"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "就此逃走了吧！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "走了吧！"
        },
        {
          "character": "建文帝、程济",
          "type": "同唱",
          "text": "闯破玉笼飞彩凤， 挣开金锁走蛟龙。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师！"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "卿家！"
        },
        {
          "character": "程济、建文帝",
          "type": "同白",
          "text": "走！走！走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济、建文帝同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}