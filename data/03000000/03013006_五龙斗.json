{
  "script_id": "03013006",
  "title": "五龙斗",
  "alias": [
    "双观星；一名：勾家滩"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "王彦章",
      "hangdang": "净"
    },
    {
      "name": "李克用",
      "hangdang": "净"
    },
    {
      "name": "高宝童",
      "hangdang": "童"
    },
    {
      "name": "石敬瑭",
      "hangdang": "童"
    }
  ],
  "plot": "五代初期，李克用率部将李嗣源、刘肇基、刘智远、郭彦威、石敬瑭、高宝童等与朱温部将王彦章交战。石\n敬瑭、高宝童夜观天星，设计擒敌。李克用分派兵将埋伏于二虎山，并与众将轮战王彦章，王彦章力尽势败，\n终于自杀。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手、四番将、王彦章同上。〖点绛唇〗。"
        },
        {
          "character": "王彦章",
          "type": "念",
          "text": "虬须眈目脸笑丧，忆昔黄河渡逞强。自与存孝斗智后，气得豪杰投梁王。"
        },
        {
          "character": "王彦章",
          "type": "白",
          "text": "某，王彦章。昔年霸占黄河渡口，自与李存孝斗智之后，某家投奔梁王朱温帐 下为将，梁王晏驾，某家霸占勾家滩，每日操演兵将，要夺唐室天下。今乃操 演之期。 来呀！"
        },
        {
          "character": "四番将",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "王彦章",
          "type": "白",
          "text": "打道校场。"
        },
        {
          "character": "四番将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌引高宝童、石敬塘同上。"
        },
        {
          "character": "高宝童",
          "type": "念",
          "text": "志气昂昂贯斗牛，"
        },
        {
          "character": "石敬塘",
          "type": "念",
          "text": "心中怨恨几时休。"
        },
        {
          "character": "高宝童",
          "type": "念",
          "text": "狭路相逢难回避，"
        },
        {
          "character": "石敬塘",
          "type": "念",
          "text": "不是冤家不聚头。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "石敬塘",
          "type": "白",
          "text": "石敬塘。"
        },
        {
          "character": "高宝童",
          "type": "白",
          "text": "高宝童。"
        },
        {
          "character": "石敬塘",
          "type": "白",
          "text": "贤弟请了！"
        },
        {
          "character": "高宝童",
          "type": "白",
          "text": "兄长请了。"
        },
        {
          "character": "石敬塘",
          "type": "白",
          "text": "你我奉了母亲之命，来报杀父冤仇，昨日与水贼打了一仗，水贼大败而回，免 战高悬，如何是好？"
        },
        {
          "character": "高宝童",
          "type": "白",
          "text": "兄长，看今夜月朗星稀，你我同到观星台，观看那水贼是何星宿临凡。"
        },
        {
          "character": "石敬塘",
          "type": "白",
          "text": "言之有理。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "家将，掌灯！"
        },
        {
          "character": "石敬塘",
          "type": "二黄导板",
          "text": "听谯楼打罢了初更时分，"
        },
        {
          "character": "石敬塘",
          "type": "唱",
          "text": "小豪杰单人独骑、独骑单人、悄悄静静、静静悄悄、私出唐营观看天星。"
        },
        {
          "character": "高宝童",
          "type": "唱",
          "text": "在家中遵奉了母亲之命，"
        },
        {
          "character": "石敬塘",
          "type": "唱",
          "text": "都只为我的父，为国家，秉忠心，东挡西除，南征北战，朝朝暮暮、暮暮朝朝、 时时刻刻，哪得安宁，枉费劳心。"
        },
        {
          "character": "高宝童",
          "type": "唱",
          "text": "叫家将掌银灯观星台上，"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "上台来熄银灯观看天星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四木星同上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "观东方甲乙木木星在位， 木字上坐定了四位星君。 奎木狼、斗木獬、井木犴、角木蛟位星君俱亦在座， 并无有一星君降下凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四木星同下。李嗣源上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "我道那李嗣源是哪一个， 却原来鼍龙星降下凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源下。四火星同上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "观南方丙丁火火星在位， 火字上坐定了四位星君。 觜火猴、尾火虎、翼火蛇、室火猪四位星君俱亦在位， 并无有一星君降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四火星下。刘智远上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "我道那刘智远是何星位， 却原来火龙星降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘智远下。四金星同上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "观西方庚辛金金星在位， 金字上坐定了四位星君。 牛金牛、娄金狗、鬼金羊、亢金龙四位星君俱亦在位， 并无有一星君降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四金星同下。刘肇基上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "我道那刘肇基是哪一个， 却原来亢金龙降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘肇基下。四水星同上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "观北方壬癸水水星在位， 水字上坐定了四位星君。 轸水蚓、箕水豹、参水猿、壁水獝四位星君俱亦在位， 并无有一星君降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水星同下。郭彦威上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "我道那郭彦威是哪一个， 却原来小青龙降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭彦威下。四土星同上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "观中央戊己土土星在位， 土字上坐定了四位星君。 氐土貉、女土蝠、胃土雉、柳土獐四位星君俱亦在位， 并无有一星君降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四土星同下。李克用上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "我道那老大王是哪一个， 却原来老白虎降下了凡尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用下。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "一罗睺二计都，飞腾下马， 三才星四水星，点水成冰； 五太阳六太阴，阴阳水火， 七巧星八卦星，点就乾坤； 九天罡十地煞，明星朗朗， 左福星右福星瑞气腾腾； 紫薇星坐至在当中正， 二十八宿、北斗星。 天河里、天河外、里八层、外八层、满天星斗俱观尽， 不知水贼什么星。 展开了八卦从头看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王彦章、李克用领唐将同上，望门同下。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "八卦之中看分明。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "呀！"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "我道那王彦章是何名将， 却原来天河降下摆渡星。 观罢星斗把月台下， 明日里进宝帐，见了老大王细说分明，要报那杀父冤仇，要定计行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "石敬瑭、高宝童同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引李克用同上。"
        },
        {
          "character": "李克用",
          "type": "唱",
          "text": "旌旗不住空中扬， 将士纷纷摆战场。 水贼伤孤数员将， 唐朝何日定安康。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "石敬塘、高宝童同上。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "观罢星斗进宝帐， 见了祖公说端详。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "参见祖公。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "谢祖公。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "命你二人观星，可知水贼是何星宿临凡？"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "孙儿观星，水贼乃天河内降下摆渡星临凡。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "既知此星，怎么处置？"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "孙儿倒有一计在此。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同白",
          "text": "祖父可命人去到二虎山，立一碑牌，上写“二虎山，勾家滩，雁落沙滩无藏， 獐入虎口必亡，管教水贼命丧。”"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "好，你二人辛苦，后面歇息。"
        },
        {
          "character": "石敬塘、高宝童",
          "type": "同唱",
          "text": "辞别祖父出宝帐，"
        },
        {
          "character": "李克用",
          "type": "唱",
          "text": "明日里定擒王彦章。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "来！吩咐众将，全身披挂，校场听点。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "李克用",
          "type": "念",
          "text": "安排巧计擒贼将，明日活捉王彦章。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源、刘智远、刘肇基、郭彦威同上，同起霸。"
        },
        {
          "character": "李嗣源",
          "type": "念",
          "text": "大将生来性情刚，"
        },
        {
          "character": "刘智远",
          "type": "念",
          "text": "万马军中逞豪强。"
        },
        {
          "character": "刘肇基",
          "type": "念",
          "text": "校场点动兵和将，"
        },
        {
          "character": "郭彦威",
          "type": "念",
          "text": "要拿水寇王彦章。"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "李嗣源。"
        },
        {
          "character": "刘智远",
          "type": "白",
          "text": "刘智远。"
        },
        {
          "character": "刘肇基",
          "type": "白",
          "text": "刘肇基。"
        },
        {
          "character": "郭彦威",
          "type": "白",
          "text": "郭彦威。"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "将军请了。老大王兴兵要灭水贼王彦章，你我两厢伺候。"
        },
        {
          "character": "刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手引李克用同上。"
        },
        {
          "character": "李克用",
          "type": "点绛唇",
          "text": "忆昔沙陀，将广兵多，战将勇，屡动干戈，要把群贼破！"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "参见老大王。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "李克用",
          "type": "念",
          "text": "忆昔沙陀领大兵，曾替唐王去战争。水贼伤孤数员将，唐朝何日定太平。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "孤，李克用。只因水贼王彦章挡住孤家去路，伤孤数员大将。今日兴兵，必须 扫灭水贼，方消孤恨！ 众将！"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "老大王！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "你等命人去往二虎山，立一碑牌，上写“二虎山，勾家滩，雁落沙滩无藏，獐 入虎口必亡，管教水贼命丧。”"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "兵发二虎山！"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "得令！ 众将官，兵发二虎山！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同走圆场。"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "来此二虎山。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "人马列开！命你等埋伏在二虎山，水贼到此，截杀一阵，只许败，不许胜，引 他到来，孤自有妙计收服于他。"
        },
        {
          "character": "李嗣源、刘智远、刘肇基、郭彦威",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源、刘智远、刘肇基、郭彦威同下。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "众将官，勾家滩去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖急急风〗。四文堂、四下手、四番将、王彦章同上，过场，同下。李嗣源、刘智远、刘肇基、郭彦威、"
        },
        {
          "character": null,
          "type": "text",
          "text": "双收，下场下。四上手、四文堂、四下手、四番将同会阵，刘智远上，接连环，王彦章上，归总攒，打唐将"
        },
        {
          "character": null,
