{
  "script_id": "03054008",
  "title": "一请诸葛",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "徐庶",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "徐母",
      "hangdang": "老旦"
    },
    {
      "name": "司马徽",
      "hangdang": "老生"
    }
  ],
  "plot": "徐庶至许昌，往见乃母。徐母责以大义，忿而自尽。徐庶始悟，遂辞曹操守孝。徐庶去后，水镜往新野访徐\n庶，亦荐诸葛亮。刘备乃往隆中，礼聘未遇，败兴而返。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四文堂、四大铠、张郃、许褚、张辽、曹洪、夏侯渊、夏侯惇、李典、乐进、于禁、曹仁、中军引曹操同"
        },
        {
          "character": null,
          "type": "text",
          "text": "上。）"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "执掌威权，收天下，文武英贤。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "汉室江山气运终，四方群起各争锋。老夫坐镇许昌地，搜罗天下众英雄。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫，曹操，在汉帝驾前为臣，官居首相。一切内外军国大事，皆由老夫一人 作主，天子不敢闻问。这且不言。只因曹仁、李典失守樊城，我闻刘备军中有 一徐庶，此人怀有奇才。亦曾命程昱套写笔迹，修写假信，命曹用去往新野， 诓那徐庶到来。去了许久，还未见回来。 站堂军，伺候了！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用上。"
        },
        {
          "character": "曹用",
          "type": "念",
          "text": "忙将徐庶事，报与相爷知。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "叩见相爷！小人交差。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "谢相爷！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你诓那徐庶怎么样了？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "徐庶诓到，现在府外。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站立一旁。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众位将军，随孤出府迎接。"
        },
        {
          "character": "张郃、许褚、张辽、曹洪、夏侯渊、夏侯惇、李典、乐进、于禁、曹仁",
          "type": "同白",
          "text": "啊！ 有请徐先生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "啊丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊元直！"
        },
        {
          "character": "徐庶、曹操",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请！ 丞相在上，徐庶参拜！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "元直少礼，请坐！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "久闻先生高明传于四海，才志贯满宇宙。几次想会，无由得见。今将令堂自颍 州请入许昌，讨得华翰，才把先生请至此处，实遂我平生之愿也！ 来，看茶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用献茶。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "元直请茶！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "丞相、众位将军请！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "张郃、许褚、张辽、曹洪、夏侯渊、夏侯惇、李典、乐进、于禁、曹仁",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "老母多蒙丞相款待，庶感恩非浅！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "理所当然。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "愚下归顺来迟，望丞相休得见怪！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "丞相，容庶见过家母，再与丞相相谈。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生真孝子也！ 曹用，将徐先生领到馆驿，见过徐太夫人！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢丞相！暂时相别。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "少刻奉陪。请！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "先生，随我来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用、徐庶同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "左右预备酒宴，与徐先生接风。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟、徐母同上。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "叹儿夫一旦间去世甚早， 徐康儿寿命短命赴阴曹。 思想起惨凄凄无依无靠， 不由我年迈人珠泪如潮。 恼恨这奸曹操设下圈套， 每日里在馆驿好不心焦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母坐。曹用上。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "启太夫人：徐先生由新野而来，现在馆外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母怒。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "啊！叫他进来！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "有请徐先生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "随我来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶进门，曹用、二丫鬟同暗下。徐庶跪哭。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "一见老娘忙跪倒， 点点珠泪往下抛。 孩儿忙把娘亲叫， 恕儿来迟望母饶。 儿罪深重该万死， 连累老娘受煎熬。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母哭。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "儿在新野却然好， 就该忠心扶汉朝。 为娘在此儿怎晓， 来至许昌为哪条？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "娘亲言道有蹊跷， 中了奸相计笼牢。 老母发书儿来到， 因此星夜见年高。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "奴才！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "听儿之言娘心恼， 果然心中少略韬。 儿来许昌事非小， 一定扶保奸曹操。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "儒子！你飘荡江湖，数载有余。近闻你辅保玄德，所为得其主也。为娘心中甚 是喜欢。指望身得荣耀，改换门庭。你今凭一纸只字，不辨真假，舍其真而投 其假，这么一点机关都参解不透，还要扶佐明主以图王霸之业么？以后还有什 么面目在人前讲文论武？你这个冤家，跪在这里，不许起来。等老身回来发落 于你。唉，儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母哭，恨，下。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "如今自知入圈套， 来见老母枉徒劳。 老娘怒恨来训教， 进退两难在今朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟同上。"
        },
        {
          "character": "二丫鬟",
          "type": "同白",
          "text": "哎呀徐先生，大事不好啦！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "啊！何事惊慌？"
        },
        {
          "character": "二丫鬟",
          "type": "同白",
          "text": "太夫人在后房悬梁自尽啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用暗上，听。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "待我报与丞相知道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用下。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "哎呀，现在哪里？"
        },
        {
          "character": "二丫鬟",
          "type": "同白",
          "text": "随我来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟、徐庶同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场设徐母尸。二丫鬟引徐庶同上。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "哎呀，娘啊！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "一见老娘命丧了，"
        },
        {
          "character": "徐庶",
          "type": "三叫头",
          "text": "老娘！母亲！唉，娘啊！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "不由徐庶珠泪抛。 我哭哭一声老娘亲！ 我叫叫一声儿的娘啊！啊啊啊，儿的娘啊！ 只因入了贼圈套， 连累老娘赴阴曹。"
        },
        {
          "character": "徐庶",
          "type": "哭",
          "text": "娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用引程昱同上。"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "听得曹用一声报， 伯母自尽为哪条？ 曹用带路馆驿到， 见了元直说根苗。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "先生啊！"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "且免悲伤休泪掉， 安葬伯母要酬劳。"
        },
        {
          "character": "徐庶",
          "type": "哭",
          "text": "娘啊！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "先生请坐！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "程先生请坐！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "元直，伯母今日已死，也是她老人家阳寿已满。须要置办棺椁，预备寿衣，停 放入殓要紧。待我禀明丞相，文武吊丧，择选黄道发引。先生，随我一同去见 丞相。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "先生先行，我徐庶随后就到！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "先生，你一定要来啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱下。"
        },
        {
          "character": "徐庶",
          "type": "哭",
          "text": "唉，娘啊！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "心中暗把奸曹恨， 逼勒老娘丧残生。 从今住在许昌郡， 一计不献与曹营。 人前不把韬略论，"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "只念玄德情义深！"
        },
        {
          "character": "徐庶",
          "type": "哭",
          "text": "唉，娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶、二丫鬟、曹用同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四文堂、四大铠、张郃、许褚、张辽、曹洪、夏侯渊、夏侯惇、李典、乐进、于禁、曹仁、中军引曹操同"
        },
        {
          "character": null,
          "type": "text",
          "text": "上。）"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "适才曹用报一信， 徐母一命归了阴。 假意殷勤言语顺， 要买元直扶乾坤。 将身且把大厅进， 等候程昱报信音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱、徐庶同上。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "二人同把府门进， 见了丞相说详情。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "元直少礼，请坐！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "徐庶",
          "type": "哭",
          "text": "唉，娘啊！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "元直且免悲伤。伯母已死，也是阳寿已满。 程谋士，就在馆驿高搭席棚，与徐老伯母急速预备寿衣，置办棺椁，吉时装殓； 元直披麻带孝，相请高僧高道，超度亡魂，与伯母免罪！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "下官遵命。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢丞相！启丞相：我母已死，我徐庶要在老母坟前守孝。百日孝满，再来扶保 丞相，重整汉室基业。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "慢说百日，就是周年半载，又待何妨？办理丧事要紧。 程谋士，预备祭礼，文武随同行礼，选择黄道吉日，与伯母安葬发引。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "多谢丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、糜竺、糜芳、简雍、张飞、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
