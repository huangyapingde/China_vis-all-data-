        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "观看此人多英俊， 举止动作甚斯文。 头带儒巾端又正， 皂氅青衫紧着身。 绿绒丝绦腰中系， 足登云履不染尘。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊！来的可是卧龙先生么？"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "啊！尊驾贵姓？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吾乃新野刘备，特来拜访先生。"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "吾非孔明，乃卧龙之友也，姓崔名州平，博陵人氏。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "久闻先生高名，可肯见教？若是慨允，席地一坐，足见高情。"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "岂敢岂敢！既是明公不弃，相坐一叙。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "大哥如今心太胜， 他想孔明迷了心。 不论是谁全恭敬， 难道卧龙他是天外人？ 你我弟兄威远震， 谁不知桃园结义名？"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "三弟休得语高声， 大哥听见怒气嗔。 兄长定然有高论， 你我只可一旁听。"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "这里有许多石块，大家坐下叙谈叙谈。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请坐！"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "大家请坐！"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "请坐。"
        },
        {
          "character": "崔州平",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "崔州平",
          "type": "唱",
          "text": "明公要见诸葛亮， 不知所为哪一桩？"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "目今汉室君软弱， 权臣当道起干戈。 意欲扶君除奸恶， 无有谋士保山河。 水镜、徐庶曾举荐， 命我南阳请诸葛。 当世高人休错过， 聘请前来治邦国。"
        },
        {
          "character": "崔州平",
          "type": "唱",
          "text": "闻听公言笑呵呵， 尊声明公请听着： 治乱之道公即可，"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "领教先生渡坎坷！"
        },
        {
          "character": "崔州平",
          "type": "唱",
          "text": "自古治乱贤良佐， 乱极生治果无讹。 犹如阴阳消长落， 寒来暑往两相合。 除却强秦汉业建， 高祖斩蛇人难学。 二百年平帝起下祸， 出了王莽来篡夺。 光武中兴莽除却， 全仗邓禹定干戈。 今请孔明扶汉祚， 他的奇才能治国。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "先生今去何处所？"
        },
        {
          "character": "崔州平",
          "type": "唱",
          "text": "我也前来拜诸葛。"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "明公，你如将孔明请出茅庐，他定能扭转乾坤，治此大乱。他的韬略兵机，神 通妙策非我等可比，只是怕他不允。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我到茅庐，小童说道，并未在家。不知往何方去了。"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "既是如此，我也就不去了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我有意请先生同到新野，不知尊意如何？"
        },
        {
          "character": "崔州平",
          "type": "白",
          "text": "我乃山野愚民，命小福薄，难当重任。“功名”二字，久不想矣。他日再会！ 哈哈哈……请哪！哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔州平下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "兄长，方才崔州平所言如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "“危邦不入，乱邦不居，邦有道则显，无道则隐”。此乃儒家之见。但如今 汉室将倾，民有倒悬之苦，愚兄岂肯坐视！因此昼夜悬思，力图匡扶社稷，整 理河山。奈力所不能，只有求贤访才，共图大事。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "兄长念祖宗之基业，理当如此。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟知兄之肺腑也。一同上马，回转新野！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "兄弟马上闲谈论， 远远望见新野城。 不见诸葛发躁性， 还须耐性访贤能！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}