{
  "script_id": "03053002",
  "title": "铡包勉",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "包勉",
      "hangdang": "丑"
    },
    {
      "name": "赵秉",
      "hangdang": "净"
    },
    {
      "name": "王延龄",
      "hangdang": "老生"
    }
  ],
  "plot": "包拯奉旨往陈州放粮，首相王延龄与司马赵秉同至长亭饯行。包拯侄包勉亦至，私与赵秉吿己充县令受贿事。\n赵秉故当众吿包拯。包拯按律拟铡包勉。包勉许金三千，乞赵秉求情。赵秉代求，包拯不允。包勉复哀求\n王延龄。王延龄悯其孤，泣求于包拯。包拯始饶包勉一死。赵秉即向包勉索谢，包勉不与。赵秉因讥笑包拯。\n包拯大怒，立铡包勉。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂引王延龄同上。"
        },
        {
          "character": "王延龄",
          "type": "引子",
          "text": "调和鼎鼐，位列三台。"
        },
        {
          "character": "王延龄",
          "type": "念",
          "text": "丹凤来朝宇宙春，终天雨露四时新。世间最好全忠孝，臣报君恩子奉亲。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "老夫、王延龄。奉了万岁旨意，去往长亭与包拯饯行。 左右，打道长亭！"
        },
        {
          "character": "四红文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四蓝文堂引赵秉同上。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "我道是谁，原来是王大人！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "原来是赵大人！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "哪道而去？"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "老夫奉王命，去往长亭与包拯饯行。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "老朽也为此事而来。你我此去，好有一比！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "南天门外打闪——"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "一路的邪气。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "呃！“一路的神气”！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "不错，一路的神气。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "你我并道而行！"
        },
        {
          "character": "王延龄、赵禀",
          "type": "同白",
          "text": "打道长亭！"
        },
        {
          "character": "四红文堂、四蓝文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四蓝文堂同挖门。〖牌子〗。"
        },
        {
          "character": "四红文堂、四蓝文堂",
          "type": "同白",
          "text": "来到长亭。"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "伺候了！"
        },
        {
          "character": "四红文堂、四蓝文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。王朝、马汉引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊，列位大人！"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "明公！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "包拯、王延龄、赵秉",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "请坐！不知明公驾到，未曾远迎，当面恕罪！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "岂敢！学生有何德能，敢劳大司马、恩师饯行！"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "此乃圣命。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "宴齐。"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "我等把盏。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "摆下就是。"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "明公请！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "六幺令。门子引包勉同上。"
        },
        {
          "character": "包勉",
          "type": "念",
          "text": "奉了母亲命，长亭来钱行。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "来此已是长亭。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "看我的马扎伺候！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "拿我禀帖，对里面去说，包大老爷求见。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "是。 门上哪位在？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "烦劳通禀，包大老爷求见。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "候着！ 启爷：包大老爷求见。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "明公！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "大司马！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "想我朝有几个姓包的？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "姓包的？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "嗳，姓包的。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "就是学生一人。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "为何又来一个姓包的？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "朝中新上任的官儿同名共姓，也是有的。 来，传话出去，堂上有列位大人在此，新上任的官儿越城而过！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "是。 来！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "里面传出话来，堂上列位大人在此，新上任的官儿越城而过。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "启老爷：里面传话出来，堂上列位大人在此，新上任的官儿越城而过。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "你对里面说去，包大老爷一定要见！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "我家老爷一定要见。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "候着。 启爷：外面包大老爷一定要见。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "叫他报履历而进！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "是。 里面传话出来，叫你们报履历而进！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "启爷：传话出来，叫老爷报履历而进。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "你对里面去说，家住江南庐州府、合淝县、状元桥、小包村，赐进士出身，做 过一任岳州萧山县知县，姓包名勉，包大老爷一定要见！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "里面有人么？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "你对里面去说：家住江南庐州府、合淝县、状元桥、小包村，赐进士出身，做 过一任岳州萧山县知县，姓包名勉，包大老爷一定要见！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "启爷：外面言道：家住江南庐州府、合淝县、状元桥、小包村，赐进士出身， 做过一任岳州萧山县知县，姓包名勉，包大老爷一定要见！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "原来是侄男包勉到了。 大司马、恩师暂坐一时。"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "待我出去看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯出门。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "包勉在哪里？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "三叔在哪里？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "包勉，你不在家中侍奉你母，来到长亭作甚？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "奉了我母之命，来到长亭与三叔饯行。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你抬头观看，长亭之上，列位大人甚多，你当讲则讲，不可胡言乱语！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "侄男如今是会讲话的了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "如此随为叔的进来。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯领包勉同进。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "包勉，见过众位大人！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "小侄遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉背供。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀且住！看长亭之上，列位大人甚多，我与哪家见礼，还是不与哪家见礼？ 也罢！我与他一个撒网礼。 列位大人，我这里有礼了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉见礼。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，你这是怎样行礼？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "此礼有个名堂。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "什么名堂？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "渔翁站在船头上——"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "这一网全在其内。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "你三叔也在其内？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "除去我三叔。"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "明公，这是何人？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "小侄包勉。"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "原来是令侄大相公。来，看座！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢！列位大人在此，哪有他的座位？"
        },
        {
          "character": "王延龄、赵秉",
          "type": "同白",
          "text": "有话叙谈，哪有不坐之理！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "如此，包勉谢过列位大人！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "列位大人，我这里又要有礼了哇！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，不要撒网，再要撒网，连你三叔也撒在其内了。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "取笑了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师，学生此番陈州放粮，有何金言，当面指教。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "你我后面一叙。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯向赵秉。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "大司马暂坐一时。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师请！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄、包拯同下。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "嘿！有道是：好话不背人，背人没好话。跑到背地捣鬼去了！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "卑职参见老大人！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，适才见过礼了。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "有道是：礼多人不怪。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "好一个“礼多人不怪”。娃娃，坐下吧！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，你口称“卑职”，在哪里为过官来？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "做过一任岳州萧山县知县。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "官儿虽小，倒是一个正印。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "不错，是一个正印。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，老夫在朝内为官，不知帘外为官的风俗。你要说与老夫一听！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "这有何难？吏部领了凭，上了任，拜了庙，这就要升堂理事，把放吿牌抬将出 去。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "可有打官司的？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "怎么无有哇！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "都是怎样的官司？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "房粮地土，奸情盗案，还有赌博官司。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，这赌博官司都是怎样问法？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "大堂之上，放下两堆荆棘。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "要它何用？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "叫他们拿手去抓呀！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "这手岂不抓烂了哇？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "抓烂了手，他们就赌不得钱了哇。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "哎呀，你包家真是辈辈清官！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "呀老大人，这清官难做得很哪！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "怎么难做得很呢？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "不才做了一任岳州萧山县，任期未满，连我的纱帽带我老婆的裤子都赔在里面 了哇。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "哎呀，太赔苦了哇！后来便怎样？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀老大人，后来我就贪了哇！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "贪了什么？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "贪了赃了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，你是怎样的贪法？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "再有打官司的，大堂之上，放下两个木捅。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "要它何用？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "叫他们往里丢！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "丢什么？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "丢银子。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "怎样的丢法？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "原、被吿一齐带上堂来，叫他们往里丢！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "丢满了怎么样？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "算他赢。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "丢不满？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "算他输啊！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "这两家一齐丢满？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "我又有了主意了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "有了什么主意呀？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "退在二堂，摆上一桌丰盛酒席。请上一位师爷，与他两家说和说和，也就完了 哇。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，你的好计呀！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "本来是好计！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "后来赚银多少？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "一任未满，我就赚银十缸。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "这银子往哪里去了？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "拿到我三叔家中去了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "你三叔可曾知道？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "先前不知。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "后来呢？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "后来就知道了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "知道了把你怎么样呢？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "倒把我升了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "倒把你升了？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "升了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "升在哪里？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "把我升在杭州府抱娃子去了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "哎呀娃娃，那是坏了哇！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "可不是坏了哇！老大人，方才说的，乃是几句戏言，不要对我三叔言讲；你要 对我三叔言讲，我三叔铁面无私，必要铡我一死。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "老夫乃是口直心快之人，有一句要说一句！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀，只怕坏在你的身上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王延龄同上。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师请！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "明公请！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "大司马请坐！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "明公请坐！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "适才老朽嘱咐你的言语，要牢牢紧记！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "学生紧记。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "明公，令侄大相公口称“卑职”，他在哪里为过官来？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "做过一任岳州萧山县知县。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "官儿虽小，倒是一个正印。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "娃娃年幼，他不会为官。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "他不会为官，一任岳州萧山县知县未满，就赚银十缸。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "就是他？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "不是他，还是老朽不成么！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，将他座位撤去！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝撤包勉座位。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "启禀三叔：长亭之上，列位大人赐小侄一个座位，三叔因何撤去？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "慢说尔的座位，少时连你的站处也是无有！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "若论国法，无有座位；论起家法，你吃过我母亲的奶，你与我还是“弟兄”相 称！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "尔待怎讲？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "“弟兄”相称！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你进前来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯打包勉。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来，绑了！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝绑包勉。"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "在长亭气坏了包文正，"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "骂一声小包勉胆大畜生。 在长亭你就该睁眼观定， 尽都是满朝中文武公卿。 那一旁陈世美当朝驸马， 那一旁马子建皇王宠臣， 这一旁老恩师不必讲论， 那一旁老赵秉冷本参人。 叫王朝和马汉铜铡搭定，"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同抬铡。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "放下，放下！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "搭下去！"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "少时间铡包勉即刻登程。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀，不好了！"
        },
        {
          "character": "包勉",
          "type": "西皮摇板",
          "text": "不该不该大不该， 不该长亭来饯行。 走向前来忙跪定， 望求大人讲人情。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃，跪在我的面前作甚？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "适才我与老大人说了几句戏言，我三叔如今要铡我一死。望求大人与我讲个人 情！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "你三叔铁面无私，只怕人情有些讲不下来。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "不教你老人家白讲啊！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "孝敬你老人家一千两银子。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "不够！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "二千两。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "不够本钱！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "我不曾与你老人家搭伙做买卖，讲什么够本不够本哪？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "有道是：脸面值千金哪！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "谢你老人家三千两。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "打哪里送去？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "打从你后门而入。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "呃！后花园门送去。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "暧，不错，后花园门而入。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "什么时候？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "三更时分。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "凭你的造化！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉走大边下。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "明公，我这厢请礼了！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "大司马，施礼为何？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "适才令侄大相公说了几句戏言，看在老朽的分上，将他饶恕了吧！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你怎么讲？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "将他饶恕了吧！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "开言叫声老赵秉， 絮絮叨叨讲人情。 我若不看你年迈，"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "你敢打老朽？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "不敢！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "你敢骂老朽？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "不敢！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "谅你也不敢！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "你与包勉一路行！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "嗳，铡的乃是你包家后代，与我赵家什么相干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉走小边上。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀老大人，这人情可曾准下？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "三言两语……"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "准下了？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "碰了！那旁有一个白胡子老头儿，你哀求他去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵秉走大边下。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "唉呀，害苦了我了！"
        },
        {
          "character": "包勉",
          "type": "西皮二六板",
          "text": "赵大人讲情情不准， 不由包勉吃一惊。 走向前来忙跪定， 望求大人讲人情。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "包勉，你跪在我面前作甚？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "我三叔要铡我一死，望求大人讲个人情！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "你三叔铁面无私，只怕这人情有些讲不下来。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "不教你老人家白讲，孝敬你老人家三千两银子。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "满口胡言！凭你的造化！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀，这位大人倒是一位清官，不爱财呀，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉下。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "啊明公！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "适才包勉说了几句戏言，看在老朽的面上，将他饶恕了吧！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师呀！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "手拉手儿到屏风， 恩师面前打一躬。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "适才听令侄大相公言道，你吃过他母亲乳奶，看在嫂娘份上，将包勉饶恕了吧！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师啊！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "提起了嫂娘吴妙真， 学生言来听分明： 我母生我三日整， 各个道我是妖精。 将我丢在坑洞内， 多亏嫂娘救残生。 大哭一声天地震， 提此事叫我好惨情。 嫂娘将我来抱定， 将我抱在他房中。 一日吃她三遍乳， 抚养学生长成人。 七岁读书到十五， 多亏嫂娘抚养恩。 小包勉萧山为县令， 不会为官管子民。 包勉犯了贪赃罪， 休怪学生不徇情。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "王延龄",
          "type": "唱",
          "text": "当初亏我救你命， 你今就该准人情。 老朽讲情你不准， 看来你是无义人！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "我今铡了包勉子， 我不心疼你心疼！"
        },
        {
          "character": "王延龄",
          "type": "唱",
          "text": "手拉手儿下长亭，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "王延龄",
          "type": "唱",
          "text": "一同上殿见圣君。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "恩师说话欠思忖， 絮絮叨叨讲人情。 长亭不看恩师面，"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "你敢打老朽？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "不敢！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "你敢骂老朽？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "也不敢！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "谅你也不敢！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "要想准情万不能！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉上。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀老大人，这人情可曾准下了？"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "你三叔铁面无私，人情不准，你自己哀吿去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄下。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀，不好了！"
        },
        {
          "character": "包勉",
          "type": "唱",
          "text": "王大人讲情不能准， 吓得我包勉两泪淋。 走向前来把话论， 尊一声三叔听分明： 不看僧面看佛面， 不看鱼情看水情。 鱼情水情全不看， 家中还有我的老娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉哭。"
        },
        {
          "character": "包拯",
          "type": "叫头",
          "text": "包勉！"
        },
        {
          "character": "包勉",
          "type": "叫头",
          "text": "三叔！"
        },
        {
          "character": "包拯",
          "type": "叫头",
          "text": "我儿！"
        },
        {
          "character": "包勉",
          "type": "叫头",
          "text": "叔父！。"
        },
        {
          "character": "包拯",
          "type": "叫头",
          "text": "唉，儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯哭。"
        },
        {
          "character": "包勉",
          "type": "叫头",
          "text": "唉，叔父啊！"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "包勉哭得珠泪滚，"
        },
        {
          "character": "包拯",
          "type": "叫头",
          "text": "包勉！"
        },
        {
          "character": "包勉",
          "type": "叫头",
          "text": "三叔！"
        },
        {
          "character": "包拯",
          "type": "叫头",
          "text": "我儿！"
        },
        {
          "character": "包勉",
          "type": "叫头",
          "text": "叔父！"
        },
        {
          "character": "包拯",
          "type": "叫头",
          "text": "唉，儿呀！"
        },
        {
          "character": "包勉",
          "type": "叫头",
          "text": "唉，叔父啊！"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "哭的为叔好伤心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄、赵秉自两边分上。"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "儿出任萧山为正印， 尔就该秉正报朝廷。 尔今犯了贪赃罪， 怎不叫我动无名！ 我有心将你来铡定，"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "那旁叹坏了恩师王大人。 我本当不铡包勉子，"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "不要铡他一死啊！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "怕的是老赵秉冷本参人。 左难右难难坏我，"
        },
        {
          "character": "包拯",
          "type": "哭头",
          "text": "我的儿啊！"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "又恐怕绝了包家根。 罢罢罢人情来准定，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师！"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "看在恩师饶畜生。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "来，与大相公松绑！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "多谢三叔！多谢老大人！ 来，看我的衣冠伺侯，我要回去了哇！哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包勉欲下。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "娃娃哪里去？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "我三叔把我饶恕了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "拿来！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "拿什么来？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "银子。"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "人情又不是你老人家讲下来的，与我要什么银子啊？"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "你要回家去？"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "我要回家去呀！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "我打发你回老家去！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀，好话你要多讲！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "那是自然的。 啊明公，将令侄大相公饶恕了吗？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "看在大司马的份上，将奴才饶恕了。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "你不要铡他一死；若是铡他一死，你包家就没有摇钱树了哇！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "赵秉—言出了唇， 将包勉送入枉死城。 人来将他来铡定！"
        },
        {
          "character": "包勉",
          "type": "白",
          "text": "哎呀，完了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍自两边分上，王朝、马汉同铡包勉。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "只见尸首两离分。 不该不该大不该， 不该长亭来钱行。 尸首白绫来裹定， 大大棺木装尸灵。 撩袍端带长亭进，"
        },
        {
          "character": "包拯",
          "type": "西皮二六板",
          "text": "手提羊毫写分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯修书。"
        },
        {
          "character": "包拯",
          "type": "西皮二六板",
          "text": "上写包拯来拜定， 拜上嫂娘吴妙真： 我今铡了包勉子， 铡了包勉有报文。 书信下在合肥郡！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝欲下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "转来！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "劝我嫂娘少悲声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯哭。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝下。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "辞别众位足踏镫，"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "明公！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "恩师有话快些云。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "此番陈州放粮，有老朽书信，方可回来；无有老朽书信，千万不可回来。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "曾记得在金殿逼死马妃之事么？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "恩师一言来提醒， 提醒南柯梦中人。 辞别恩师上能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉带马。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "啊明公！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "回头只见老赵秉。 有朝犯在包拯手， 铜铡之下不徇情！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、马汉、包拯同下。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "哎呀，好好一个包勉，就丧在你手！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "也是他命该如此。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "那包拯此番放粮回来，岂肯与你干休！"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "我吿职还乡，又怕他何来？"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "你也只好吿职还乡。你我一同上殿交旨。"
        },
        {
          "character": "赵秉",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}