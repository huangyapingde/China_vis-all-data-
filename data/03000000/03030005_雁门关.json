        {
          "character": "孟良",
          "type": "白",
          "text": "哈哈哈，好机会也！"
        },
        {
          "character": "孟良",
          "type": "唱",
          "text": "宋王有道洪福降， 中国京剧戏考 《雁门关》【五本】 8 不顾戴月与披霜。"
        },
        {
          "character": "孟良",
