    }
  ],
  "plot": "萧太后因青莲、碧莲被擒后投降宋朝，又知驸马木易乃杨继业之子杨延辉，愤欲将杨延辉及其子女斩首，萧\n天佐施计奏请将杨延辉等绑至城楼问斩，要挟佘太君放还青莲、碧莲。孟良欲私往辽营刺探军情，查明妖术\n真相。焦赞以其有意邀功，心生嫉妒，乃以假葫芦装酒，易其所佩火葫芦。孟良背假葫芦至辽营佯装韩驸马\n巡营兵士，骗过二更夫。二更夫闻有酒香，欲请孟良出酒同饮。孟良将二更夫灌醉，并乘机将张猛之宝葫芦\n盗回。辽营失宝，宋军再战耶律休哥获胜。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延辉上。"
        },
        {
          "character": "杨延辉",
          "type": "引子",
          "text": "身居番邦，夜梦里，想念萱堂。"
        },
        {
          "character": "杨延辉",
          "type": "念",
          "text": "父子领兵赴辽邦，沙滩被擒招东床。虽然只身居北塞，思念老母暗愁肠。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "本宫，四郎延辉。宋室为臣。当年双龙大会被擒在此。蒙太后高恩，将碧莲公 主招我为婿。生有二子，取名宗祥、宗瑞。前日闻报，我母统领大兵扫灭北番， 我八弟诓了令箭诈开雁门关。宋兵攻至都城，二位公主奉命出兵，未知胜负。 咳！八弟呀！你只顾过营探母，倘有不测，你一双儿女性命难逃。我也曾讨 令出关，想见母一面，太后恐军情败露，叫我静养宫廷。只是心悬两地，好不 忧闷人也！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "父子保宋在汴梁， 双龙赴会到辽邦。 可怜我父两狼丧， 弟兄大半阵前亡。 虽然被擒招驸马， 受恩深重配鸾凰。 身心两地空悬望， 闷恹恹心内好凄凉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番上。"
        },
        {
          "character": "小番",
          "type": "念",
          "text": "忙将惊天事，报与驸马知。"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "启禀驸马爷：大事不好了！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "二位公主出战，俱被杨家女将擒去了！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "俱被杨家女将擒去了！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "听说公主她被擒， 不由本宫痛伤心。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "来，请你二位阿哥！"
        },
        {
          "character": "小番",
          "type": "白",
          "text": "有请二位阿哥！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宗祥、宗瑞同上。"
        },
        {
          "character": "宗祥",
          "type": "唱",
          "text": "宫廷瑞霭从天降， 中国京剧戏考 《雁门关》【五本】 2"
        },
        {
          "character": "宗瑞",
          "type": "唱",
          "text": "龙楼凤阁映画梁。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "孩儿请安！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "将儿唤来，有何训教？"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "只因你姨母青莲公主失了令箭，被宋营盗去，诈开雁门；你母亲与你姨母出战， 不想俱被宋营擒去。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "不好了！"
        },
        {
          "character": "宗祥",
          "type": "唱",
          "text": "闻听我母入罗网，"
        },
        {
          "character": "宗瑞",
          "type": "唱",
          "text": "点点珠泪洒胸膛！"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同唱",
          "text": "爹爹速把银安上， 快快搭救我亲娘。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同哭",
          "text": "母亲哪！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "我儿且免悲伤。为父上殿奏请太后，领兵搭救你母亲便了。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "爹爹出兵，孩儿也要前去！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "咳！此战非同小可，太后未必叫你们前去呀！有了，待为父教导于你，你二人 随为父同到太后驾前讨令，太后若是不允，你们就说学了一身武艺，可以擒拿 宋将。儿呀，记下了。随为父上殿去者！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "嘱咐言语记心上， 千万不要语癫狂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延辉、宗祥、宗瑞同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众番兵、香姐、香郎、萧太后同上。"
        },
        {
          "character": "萧太后",
          "type": "引子",
          "text": "狼烟未静，每日里，杀砍不宁。"
        },
        {
          "character": "香姐、香郎",
          "type": "同白",
          "text": "太后，我妈怎么还不回来呀？"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "你娘出兵，两日不见回来，莫非被杨八郎留在宋营了？哎！青莲哪青莲！你无 此事便罢；若有此事，你一双儿女要想活命也就难了！"
        },
        {
          "character": "香姐、香郎",
          "type": "同白",
          "text": "哎呀太后宽恩吧！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "不必痛哭，但听一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀太后：青莲公主降了宋营；碧莲公主被擒。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "啊！碧莲也被擒去了吗？再去打探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "你们可曾听见？你母降顺宋营。 来呀！将他二人绑起来！"
        },
        {
          "character": "香姐、香郎",
          "type": "同白",
          "text": "太后饶了孩儿吧。我妈岂肯投降宋营，她是被杨家擒了去的。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "哪是擒了去的？分明是见了杨八郎，就舍不得回来啦。我有言在先，她要降了 宋营，我就将你二人斩首。 来呀，将他二人推出斩了！"
        },
        {
          "character": "香姐、香郎",
          "type": "同白",
          "text": "哎呀不好了！"
        },
        {
          "character": "香姐",
          "type": "唱",
          "text": "一声令下如雷震，"
        },
        {
          "character": "香郎",
          "type": "唱",
          "text": "浑身是口也难分。 中国京剧戏考 《雁门关》【五本】 3"
        },
        {
          "character": "香姐",
          "type": "唱",
          "text": "悲悲切切下龙廷，"
        },
        {
          "character": "香郎",
          "type": "唱",
          "text": "太后不念骨肉情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "香姐、香郎同下。杨延辉领宗祥、宗瑞同上。"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "萧、宋不和干戈振， 数载征战不安宁。 含悲忍泪金殿进， 太后驾前请令行。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "儿臣见驾，太后千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "驸马平身。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "谢太后！"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "孩儿请太后金安。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "起来吧。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "太后，为何将香姐、香郎斩首？"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "他们两人没有良心，故而将他们斩首。为婆以后就靠你二人了。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "我们哥俩情愿侍奉太后。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "你二人情愿侍奉我吗？等为婆百年之后，这江山就是你兄弟二人的了。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "谢过太后！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "太后为何将香姐、香郎斩首？"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "驸马还不知道吗？二位公主出马，俱被杨家女将把她们擒去了！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哦！二位公主俱被杨家女将擒去了！儿臣情愿领兵擒那杨八郎，救回二位公主。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "她姐妹二人俱降宋营，那青莲见了杨八郎不肯回来，倒也罢了；那碧莲与那宋 营无亲无故，她也不肯回来，你说可气不可气！"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "真是可气！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "你弟兄也恨她吗？好哇，你这才算是有义气的孩子哪！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "启奏太后：且将青莲公主一双儿女赦回，待儿臣出马，将他三人擒来，一同斩 首，也不为晚。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "咳！驸马你可去不得，你看我跟前并无接位之人，韩驸马未曾生子，那无义的 八郎与那两个丫头，纵然回来，我也要杀了他们。你要出马，倘若也被宋将擒 去，如何是好？"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "太后但放宽心。儿臣此去，定要擒他三人回来，以消太后之恨。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "好！既然如此，须要早早回来。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "儿臣领旨！"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "孩儿也要前去。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "你二人年青幼小，提不动刀，杀不了人，不必前去。"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "孩儿学得一身武艺，此去定要抢个头功！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "驸马他们去得吗？"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "他二人虽然年幼，倒有一身武艺，可以去得。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "既是去的，下面披挂去吧！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延辉拟下。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "将香姐、香郎赦回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众番兵同应。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀太后：小人打听得木易驸马就是南朝杨四郎，他是改名换姓的。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "报子",
          "type": "stage",
          "text": "中国京剧戏考 《雁门关》【五本】 4"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "什么？你是杨四郎改名换姓的呀！好大胆的畜生！ 来！将他父子都绑起来！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哎呀太后啊！容儿臣一言说明，纵死九泉也得瞑目了！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "有话快讲！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "儿臣蒙太后深恩，相依驾前一十二载，心无二意，情愿一死。求太后赐儿臣人 马，将他三人一并擒来，若是辜负太后圣意，再将儿臣斩首也还不迟。如若不 然，哎呀太后哇，儿死也是不能瞑目哇！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "唗！我哪些待你不好？你和碧莲通同作弊，叫她先到宋营，你再在我跟前讨下 人马，带子出征，你夫妻竟敢同谋，扰乱我的江山。你们都是一党，我焉能留 你？都给我推出斩了！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "猛虎出林遇陷阱， 身无罪过问斩刑。 望乞太后饶儿的命！"
        },
        {
          "character": "杨延辉",
          "type": "哭头",
          "text": "太后哇！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "押下殿去！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "苦苦哀告她也不留情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众番兵押杨延辉、宗祥、宗瑞同下。萧天佐、萧天佑、萧天龙、萧天虎同上。"
        },
        {
          "character": "萧天佐、萧天佑、萧天龙、萧天虎",
          "type": "同白",
          "text": "刀下留人！"
        },
        {
          "character": "萧天佐、萧天佑、萧天龙、萧天虎",
          "type": "同唱",
          "text": "两国不合起战争， 朝朝暮暮不太平。"
        },
        {
          "character": "萧天佐、萧天佑、萧天龙、萧天虎",
          "type": "同白",
          "text": "臣等见驾，太后千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "哎呀众卿啊，他们都闹开了！"
        },
        {
          "character": "萧天佐",
          "type": "白",
