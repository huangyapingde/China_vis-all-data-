        {
          "character": null,
          "type": "stage",
          "text": "谢苗上。"
        },
        {
          "character": "谢苗",
          "type": "唱",
          "text": "更鼓相催天明亮， 奉命调回众儿郎。"
        },
        {
          "character": "谢苗",
          "type": "白",
          "text": "啊！将军请了！"
        },
        {
          "character": "张猛",
