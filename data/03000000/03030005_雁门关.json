        },
        {
          "character": "谢苗",
          "type": "白",
          "text": "元帅就要发兵，齐去辕门伺候。"
        },
        {
          "character": "张猛",
          "type": "白",
          "text": "带了法宝前去。啊！葫芦为何不见？ 众军士走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵自两边分上。"
        },
