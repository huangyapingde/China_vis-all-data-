        {
          "character": "孟良",
          "type": "白",
          "text": "都醉了。"
        },
        {
          "character": "孟良",
          "type": "唱",
          "text": "酒醉如泥一般样， 寻个妙计进帐房。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "且喜他二人酒醉，我不免将他的衣服剥下，穿着我的身上，混进帐去，看个明 白便了。"
        },
        {
          "character": "孟良",
          "type": "唱",
          "text": "太白好酒捞月丧， 吴王贪酒失家邦。 巡卒号衣穿身上，"
