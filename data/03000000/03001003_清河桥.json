{
  "script_id": "03001003",
  "title": "清河桥",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "斗越椒",
      "hangdang": "净"
    },
    {
      "name": "养由基",
      "hangdang": "小生"
    }
  ],
  "plot": "楚庄王兵伐陆国时，斗越椒在朝谋叛，杀死司马蔿贾，夺取剑印，并率军迎杀楚庄王。斗越椒勇猛，众将不\n敌；楚庄王挂榜招贤，养由基来营投效。斗越椒自恃善射，约养由基在清河桥比箭，终被养由基射死，叛乱\n遂平。",
  "notes": "源出《东周列国志》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝大铠引斗越椒同上。"
        },
        {
          "character": "斗越椒",
          "type": "引子",
          "text": "怨恨在心头，欲夺九龙楼。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "金殿解印常带羞，一场仇恨记心头。昏王不恤功臣后，满腔怒愤岂甘休。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "某，斗越椒世袭司马剑印。为征郑邦，公子茷自陷身死；昏王道某按兵不举， 将司马剑印付与蔿贾执掌；朝中之事，不用我父子提调。此恨难消！为此设一 筵席，请蔿贾到来，索取剑印，以便图谋大事；又命我儿贲皇，打听昏王消息， 一去数日未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马甲引斗贲皇同上。"
        },
        {
          "character": "斗贲皇",
          "type": "念",
          "text": "探得庄王征伐事，回府商议好施行。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "爹爹，孩儿拜揖。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "罢了，坐下！"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "打听庄王几时回朝？"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "庄王征伐陆浑，乘势欲吞陆国，回朝无定。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "回朝无定？哈哈哈！备我名贴设宴，请蔿贾到来。正是："
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "心存篡夺消仇恨，"
        },
        {
          "character": "斗贲皇",
          "type": "念",
          "text": "准备干戈血染衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蔿贾上。"
        },
        {
          "character": "蔿贾",
          "type": "引子",
          "text": "耿直忠心，代朝事，掌握艰衡。"
        },
        {
          "character": "蔿贾",
          "type": "念",
          "text": "忧国忧民鬓如银，君王征伐未回程。心中常防诡秘辈，心机用尽费精神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "老夫，蔿贾。楚庄王驾前为臣，官居首相。前者斗越椒郑国失利，大王解其剑 印，拜我为大司马，统理朝纲。大王亲征陆国，尚未回朝，心中防备越椒变异。 幸喜朝野平靖，四边安闲，真正是食君之禄，报君雨露之恩也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "奉命请相国，阶前听施行。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "啊，哪位在？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "斗司马请太师过府一叙，有贴呈上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请稍候。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启爷：斗司马有贴相请。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "待我一看。越椒顿首……伏乞台驾光临。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔿贾看。〖牌子〗。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "批有几行小字。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "啊，还有小字？ 唔唔！来者君子，不来小人。哎呀，甚是蹊跷！ 你可回复来人，就说老夫即来赴宴。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。 斗府来人呢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "回复斗司马，太师即来赴宴。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "哎呀且住。斗越椒顿起枭心，灾祸非浅。 来，请夫人、公子出堂。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请夫人、公子！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴氏、蔿敖同上。"
        },
        {
          "character": "吴氏",
          "type": "念",
          "text": "阀阈世家受皇封，"
        },
        {
          "character": "蔿敖",
          "type": "念",
          "text": "父为忠良代天行。"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "相公！"
        },
        {
          "character": "蔿敖",
          "type": "白",
          "text": "孩儿拜揖。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "一同坐下。啊，啊，啊，罢了啊，罢了！"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "相公何故如此长叹？"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "只为斗越椒请我过府筵宴，外写小字道：来者君子，不来小人。我想那贼必为 解印之仇，此去吉凶莫辨。"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "既有怀疑，不去也罢。"
        },
        {
          "character": "蔿敖",
          "type": "白",
          "text": "爹爹，自古宴无好宴；况且那贼诡计多端，还是不去为妙。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "我蔿贾秉性公直，岂惧奸佞；若不赴宴，必生别计。依我之见，你母子悄悄避 往梦泽山，安守田舍，免遭贼戮。庄王回朝，自有旌奖。"
        },
        {
          "character": "吴氏、蔿敖",
          "type": "同白",
          "text": "嗐！还是不去的为妙。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "你们哪里知道，想老夫啊！"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "自幼窗前习孔孟， 圣贤事业常留心。 越椒金殿解剑印， 羞愧难当众功勋。 心生巧计将我哄， 假设筵席夺权衡。 主意拿稳去谈论， 拚得一死报先君。"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "相公啊！"
        },
        {
          "character": "吴氏",
          "type": "唱",
          "text": "蔿氏辅楚秉忠正， 岂似越椒奸佞人。 赴宴须防有伤损， 凡事总要三思行。"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "昨夜南柯得一梦， 头戴金花挂彩红。 醒来遍体全颤动， 只怕此去定有凶。"
        },
        {
          "character": "蔿敖",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "蔿敖",
          "type": "唱",
          "text": "既然狐疑当谨慎， 越椒所为有奸心。 引番若去必伤损， 岂忍骨肉两离分。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "嗐！"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "这些言语已自省， 纵受惨戮为先君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启爷：斗府又来催请了。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "啊，又来催请了！院子，快传家将伺候！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "家将们走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家将同上。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "参见太师，有何吩咐？"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "斗越椒请我赴宴，连催几次，尔等可戎装护卫同往。"
        },
        {
          "character": "吴氏、蔿敖",
          "type": "同白",
          "text": "众将！斗越椒有解印之仇，相爷此去，吉凶莫测，尔等不可大意。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "啊，我等记下了。"
        },
        {
          "character": "蔿敖",
          "type": "白",
          "text": "夫人啊！人生天地之间，但恐不得其名，何必做此儿女之态。只愿我儿勿作宦 途之想，趁早归农，不得延留。 来，带马！"
        },
        {
          "character": "蔿敖",
          "type": "唱",
          "text": "适才言辞牢记准， 不可留恋速归农。 辞别夫人出府庭， 此行未定死和生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍贾、四家将同下。"
        },
        {
          "character": "吴氏",
          "type": "唱",
          "text": "相公性情刚过分，"
        },
        {
          "character": "蔿敖",
          "type": "唱",
          "text": "惟愿两家得和平，"
        },
        {
          "character": "吴氏",
          "type": "唱",
          "text": "我儿细心探音信，"
        },
        {
          "character": "蔿敖",
          "type": "唱",
          "text": "心神恍惚不安宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴氏、蒍敖同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒上。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "为摘剑印心不忿， 假意设宴压朝臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲皇上。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "蔿贾到了。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "唔唔，鼓乐相迎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马甲自两边分上。四家将、蔿贾同上。〖牌子〗。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "司马公！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师请！"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "司马公相召，不知有何见教？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "大王御驾未回，朝中之事皆老太师料理，真忠心也！"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "一来大王洪福，二来司马威名，老朽无非滥竽尸位而已！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "来，摆宴。某与太师畅饮一回。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "叨扰了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。斗贲皇安席。合桌，蒍贾坐左，斗越椒坐右，斗贲皇坐蒍贾下。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "太师请！"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师，某有一言相告。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "有何金言，当得领教。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "你且听道："
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "风吹花烛浪悠悠，满腔怨恨在心头。斗氏辅楚功高厚，金殿解印是何仇？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "啊啊，老太师！某家世代辅楚，屡建奇功，挣来司马剑印；昏王不念功勋，将 剑印摘去，罢职不用。老太师，今日相请，乞老太师摘还剑印，可能允否？"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "哦哦，司马，这剑印乃大王敕赠，非老朽所执。大王不久回朝，自有恩旨还你 剑印。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "呔！蔿贾，你把庄王压制某家，今还剑印便罢，再若支吾，你要打点了！"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "呕，你言差矣！"
        },
        {
          "character": "蔿贾",
          "type": "西皮导板",
          "text": "身为司马掌兵权，"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "食王爵禄报龙颜。 统兵伐郑心肠变， 父子按兵不向前。 二王被困死山涧， 大王恼怒泪珠涟。 金殿解印无脸面， 也非老夫奏巧言。 如此施计假赴宴，"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "斗司马！"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "辜负斗氏累代贤。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "蔿贾不必巧言辩， 某家含怨非一天。 今日交还印和剑， 已过之事全不言； 若是不还印和剑，"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "要你老命赴九泉。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "庄王出兵难得见， 今日有口也难言。 原知官高必有险， 伴君犹如伴虎眠。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "不如一死忠名显， 落个芳名遗万年。 （蒍贾碰。斗越椒刺蒍贾死下。四家将、四下手同开打。家将甲逃下。斗越椒追杀三家将同下。家将甲冲下。 斗越椒上。）"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老贼已死，一不做二不休。我儿听令！"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "命你沿路探听庄王消息；为父往蔿贾家中搜取剑印，然后迎战庄王，一鼓剿灭 便了！"
