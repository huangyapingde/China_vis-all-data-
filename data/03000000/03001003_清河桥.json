          "character": "楚庄王",
          "type": "白",
          "text": "且把大刀演来！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "帐前一令来传下， 不由豪杰笑哈哈。 手提大刀如戏耍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基舞刀。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "些许技艺何足夸。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "刀法虽好，只是斗越椒神箭厉害。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "大王，小将也曾学习箭法，也能射个凤凰追尾箭。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "何谓凤凰追尾箭？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "就在百步之外，立一高杆，上挂黄旗一面。头箭射中黄旗；二箭射中头支箭杆； 这第三箭射倒旗杆，都要随旗落地。这就叫凤凰追尾箭。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "啊！你有这样神箭，就在这百步之外，立起高杆，演射一观。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "凤凰追尾无虚诈， 大王敕旨演箭法。 抖擞精神连三把，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "擂鼓。养由基连射三箭。"
        },
        {
          "character": "四红大铠、四红文堂",
          "type": "同白",
          "text": "好箭！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "速速传旨把贼拿！"
        },
        {
          "character": "楚庄王",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "小将武艺果不假， 定能保孤坐中华。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "养由基，孤王赐你盔铠，速速披挂，迎杀斗越椒。孤王掠阵！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "谢过大王把马跨， 定把越椒一鼓拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "看来孤王洪福大， 天助小将来扶咱。 众将个个齐披挂， 接应小将把贼拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
