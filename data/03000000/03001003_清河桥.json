        {
          "character": "养由基",
          "type": "白",
          "text": "大王听禀："
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "一颗明珠土内藏，数载未曾放霞光。六韬三略智谋广，上阵能挡百万郎。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "哎呀千岁！"
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "凭他父子是好汉，俺也与他摆战场。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "有什么武艺，演来一看。"
