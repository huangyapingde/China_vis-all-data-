{
  "script_id": "03091008",
  "title": "马房释放",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "陈荣",
      "hangdang": "老生"
    },
    {
      "name": "奎顺",
      "hangdang": "小生"
    }
  ],
  "plot": "陈文古欲买好友奎文吉家藏宝物“瑞霓罗帐”；奎文吉不肯。陈文古设计陷奎文吉入狱，并将奎子奎顺禁于\n马房内，命老仆陈荣刺杀之。陈荣不忍，放奎顺逃走，已则自刎死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈文古上。"
        },
        {
          "character": "陈文古",
          "type": "念",
          "text": "斩草不除根，萌芽依旧生。斩草要去根，萌芽永不生。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "在下、陈文古。我有一好友名叫奎文吉，他家有一宝物，名叫瑞霓罗帐，是我 叫他价卖与我，他执意不肯，因此我用酒将他劝醉，将短刀、银两藏在他的身 边，推往大街之上，被那巡更之人拿走，当他偷盗杀人，送往公堂，苦打成招， 问成死罪。他妻子骂上我门，是我用计，以石灰将她眼目揉瞎，打入磨房， 又将他子奎顺打入那马房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈碧桃暗上，偷听。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "我想这一不做二不休，不免叫老家院陈荣于三更时分去到马房，将奎顺一刀刺 死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈碧桃下。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "岂不是没有后患了么！就是这个主意。 陈荣哪里！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣上。"
        },
        {
          "character": "陈荣",
          "type": "引子",
          "text": "老迈年高，叹光阴，何时得了！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "老汉、陈荣。正在后面检点，大爷呼唤，只得近前。 大爷在上，老奴叩头！"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "站起来！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "谢大爷！"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "看茶来！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣取茶。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "大爷请茶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈文古取杯饮，取银放杯内。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "接杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣接杯，看。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "呀，杯内有白银一锭，是何缘故？待我收下，他有来言，我有去语。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "陈荣，杯内可有什么？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "只见白银一锭，是老奴收下了。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "赏与你的。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "谢大爷！"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "陈荣，大爷待你如何？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "大爷待小人恩重如山。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "我有桩心事要你去办，你可愿去？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "只要去得的，老奴焉敢不去！"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "命你三更时分，去到马房，将奎顺一刀刺死！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "哎呀，大爷！杀人之事，老奴不敢去！"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "住口！胆大的狗才，叫你走东不敢到西。你若不去，活活打死你这老狗！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣背供。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "我老糊涂了，此番去到马房，杀也在我，不杀也在我。嗯，自有道理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣向陈文古。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "大爷，老奴愿去，只是无有利器。"
        },
        {
          "character": "陈文古",
          "type": "白",
          "text": "随我来！ 这有钢刀一把，杀了奎顺，方可见我；杀不了奎顺，死也不要见我！去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈文古下。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "陈文古，好贼子啊！"
        },
        {
          "character": "陈荣",
          "type": "唱",
          "text": "陈文古做事心忒狠， 暗害好友丧良心。 朋友的妻儿你要个个杀尽， 我岂肯为虎作伥做罪人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣下。陈碧桃上。"
        },
        {
          "character": "陈碧桃",
          "type": "唱",
          "text": "屏风后面听言讲， 父亲为何把人伤！"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "奴家、陈碧桃。在屏风后听爹爹呼唤陈荣，命他三更时分去到马房，将奎家二 相公一刀刺杀，我不免挡住宅门，候陈荣到来，问个明白。"
        },
        {
          "character": "陈碧桃",
          "type": "唱",
          "text": "可叹我母去世早， 撇下女儿受煎熬。 爹爹行事太可恼， 要害奎顺为哪条？ 我既知情救为妙， 不然一命赴阴曹。 将身站此宅门道， 等候陈荣问根苗。"
        },
        {
          "character": "陈荣",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣上。"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "老院公转来！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "院公！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "原来是小姐。老奴叩头！"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "站起来。夜静更深，你往哪里去？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "老奴奉了大爷之命，前后检点。"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "哪里是前后检点，分明奉了我爹爹之命，去到马房，将奎顺二相公一刀刺杀， 是与不是？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "小姑娘，老奴心事却被你猜着了！"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "老哥偌大年纪，为何这样世事不懂？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "老奴也是无可奈何。"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "老哥，这有银子一锭，去到马房，杀也在你，不杀也在你。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "谢小姐！"
        },
        {
          "character": "陈碧桃",
          "type": "白",
          "text": "偌大年纪，你是懂事人哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈碧桃下。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "小姐，哎呀，小姐呀！"
        },
        {
          "character": "陈荣",
          "type": "唱",
          "text": "好一个贤德陈小姐， 他比陈荣胜十分。 这样女子世间少， 后来必定是贵人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣下。奎顺上。"
        },
        {
          "character": "奎顺",
          "type": "念",
          "text": "泪似湘江水，滚滚不住流。"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "小生、奎顺。只为瑞霓罗帐，陈文古将我父亲害在监中，老母打入磨房，好不 气杀我也！"
        },
        {
          "character": "奎顺",
          "type": "唱",
          "text": "一霎时急得我三魂不在， 七魂悠悠又转来。 恨贼子来把我害， 冤仇何日才得解开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣上。"
        },
        {
          "character": "陈荣",
          "type": "唱",
          "text": "急急忙忙把马房找， 耳听谯楼二鼓敲。 黄犬不住高声叫， 狂风一阵灭灯苗。 黑夜间观不见路途道， 房内不见小儿曹。 是何人把这风走了， 陈文古知道怎肯饶！ 东廊不见西廊去找， 他一觉睡着静悄悄。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "啊，看奎家二相公，竟此睡着了！也罢，待我老汉惊醒于他。 二相公有人行刺于你！"
        },
        {
          "character": "奎顺",
          "type": "唱",
          "text": "听一言来魂魄掉， 跪在尘埃求命饶。 有恩须当恩来报， 无仇杀我为哪条？ 望求开恩释放了， 结草衔环报恩高。"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯饶命！"
        },
        {
          "character": "陈荣",
          "type": "唱",
          "text": "二相公哭得如酒醉， 铁石人闻也泪抛。 我本待将他释放了， 陈贼知道怎肯饶！ 手执钢刀将他砍， 他口口声声只叫饶。 我还是杀的好放的好， 倒叫老汉无计较。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "陈荣",
          "type": "唱",
          "text": "宁可人头高杆吊， 老汉放你去远逃！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "二相公，老汉不杀你，放你逃走了吧！"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "谢老伯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奎顺下。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "走的好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奎顺上。"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "走不得！文古贼子，重重禁门，叫我往哪里逃走！ 老伯，走不得！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "二相公为何转来？"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯，贼子重重禁门，我往哪里逃走！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "呀！这贼子重重禁门，叫他往哪里逃走！哦，有了！ 二相公，马房后倒塌一垛土墙，老汉送你那里逃走了吧！"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "有劳老伯！"
        },
        {
          "character": "陈荣",
          "type": "唱",
          "text": "二相公不必泪嚎啕， 老汉言来听根苗： 遇着清官只管告，"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯那厢有人！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "什么人，待老汉看来！ 原来是系马的桩儿，待老扶助你一把。"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "高了上不去！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "我找个石块垫着，二相公帮我一把！"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "这做什么？"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "打了脚！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "不要高声！"
        },
        {
          "character": "陈荣",
          "type": "唱",
          "text": "好与你父母把仇消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奎顺上。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "走得好！一路之上，不知他可有盘费，待我叫他转来。 二相公转来！"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯，我走的好好，叫我转来何事？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "你一路之上可有盘费？"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯，我不过是求乞而已！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "二相公，你乃读书之人，焉能作求乞之事？老汉有白银一锭，带在身旁，也好 做个盘费！"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯大恩，请上受我一拜！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "不瞒你说，这银子不是我的，是陈碧桃陈小姐的。你要拜，看绣楼上有红灯一 盏，你与她多拜几拜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奎顺拜，下。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "这一下脱了身，走得好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奎顺上。"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "走不得，走不得！我走了不大要紧，陈文古向他要人，他把什么人交还？走不 得！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "为何又转来了？"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯，我走了不大要紧，陈文古向你要人，你把什么人交还与他？"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "二相公，只要你脱身，休管老汉了！"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "老伯，我情愿一死，岂肯连累于你？将我杀了吧！"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "陈荣",
          "type": "念",
          "text": "好个有志奇男子，他比陈荣胜十分。世间多少男儿汉，要想比他万不能。"
        },
        {
          "character": "陈荣",
          "type": "白",
          "text": "二相公，那厢有人来了！"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈荣自刎。"
        },
        {
          "character": "奎顺",
          "type": "白",
          "text": "不好了！受我一拜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奎顺拜。"
        },
        {
          "character": "奎顺",
          "type": "哭",
          "text": "老伯伯啊……唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奎顺下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}