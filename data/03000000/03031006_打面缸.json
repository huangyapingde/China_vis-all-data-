        {
          "character": null,
          "type": "stage",
          "text": "张才下。"
        },
        {
          "character": "周腊梅",
          "type": "南锣",
          "text": "有腊梅，掩柴扉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周腊梅下。王书吏上。"
        },
        {
          "character": "王书吏",
