{
  "script_id": "03039005",
  "title": "雪杯圆",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "莫怀古",
      "hangdang": "老生"
    },
    {
      "name": "傅氏",
      "hangdang": "老旦"
    },
    {
      "name": "戚继光",
      "hangdang": "老生"
    },
    {
      "name": "莫豪",
      "hangdang": "小生"
    },
    {
      "name": "陆炳",
      "hangdang": "老生"
    }
  ],
  "plot": "傅氏遇赦得还，遂往蓟州探夫墓。时莫怀古亦归省仆茔。夫妻相会，并收莫文禄为义子。莫豪为师所救，更\n名攻读，后任巡抚。恨父为戚继光所害，寻隙报复，及至戚府，重会“一捧雪”，举家方得团聚。嗣经陆炳\n参奏，严嵩父子削官为民，乞讨终生。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、门子引莫豪同上。"
        },
        {
          "character": "莫豪",
          "type": "引子",
          "text": "满腹经纶，凭韬略，扶保朝廷。"
        },
        {
          "character": "莫豪",
          "type": "念",
          "text": "自幼苦读坐寒毡，哪知磨穿铁砚难。至今才把鳌头占，将令一出神鬼寒！"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "本院、莫豪。爹爹莫怀古。只因我父上京补官，不知为了何事，冒犯严府，在 蓟州堂上，一命身亡。严府二次又有文书到来，将我母子发往边外充军。多亏 义仆之子文禄顶名代罪。是我改名白元，跟随方先生江右攻读，已有七载。上 京赴试，才得平步身荣。蒙圣恩钦放巡按，部院军民两管。因此牌发蓟州，寻 他一个错处，好与我爹爹报仇。 门子！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "传令起马！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "大人有令！起马！"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "莫怀古",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "昔日补官上帝邦， 可恨奸佞起不良。 义仆莫成把命丧， 悲思常忧泪两行。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "下官、莫怀古。因上京补官，可恨汤勤那贼，在严爷面前搬动是非，道我隐瞒 皇家器皿，有误国欺君之罪。是我闻听此言，弃官而逃。又被严府校尉在蓟州 将我拿获。多亏义仆莫成替我丧命。又蒙戚贤弟修书一封，将我荐到边庭他的 门生那里，隐姓埋名，已有七载。今戚贤弟有书信前来，叫我回去。为此一路 而来，已离蓟州不远。速速趱行便了！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "一日行程一日深， 好似孤雁宿寒林。 背地里只把奸贼恨， 害我夫妻两分离。 义仆莫成替丧命， 逃往边庭隐姓名。 今有贤弟修书信， 因此投奔蓟州城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "傅氏上。"
        },
        {
          "character": "傅氏",
          "type": "引子",
          "text": "千层浪里翻身转，百尺高杆得命还。"
        },
        {
          "character": "傅氏",
          "type": "念",
          "text": "孤雁单飞实可怜，青春一去永不还。堪叹光阴容易过，几载不觉两鬓斑。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老身、傅氏。配夫莫怀古。只因我家老爷上京补官，不知为了何事，冒犯严府。 可叹我老爷在蓟州堂上，一命身亡。严府二次又有公文到来，将我母子发往 边外充军。多亏义仆之子文禄，与我那莫豪孩儿顶名代替，我那莫豪孩儿随方 先生江右攻读去了。幸遇皇恩大赦，我主仆才得回来。昨日在店中住宿一宵。 今日早起，趱路要紧。闻听人言，我家老爷坟墓在蓟州西门以外柳林之下。此 地离蓟州不远，不免前去看看我老爷的坟墓。 文禄哪里？"
        },
        {
          "character": "莫文禄",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄上。"
        },
        {
          "character": "莫文禄",
          "type": "念",
          "text": "光阴似箭如眨眼，幸遇皇恩赦诏颁。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "奶奶在上，文禄拜揖！"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "罢了。店饭钱已然算清，收拾行囊包裹，辞别店东，我们趱路吧！"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄向内。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "啊店主东，我们在此打搅了！"
        },
        {
          "character": "店家",
          "type": "内白",
          "text": "好说。恕不远送了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅氏、莫文禄同出门。"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "自从老爷离帝京， 蓟州堂上丧残生。 严府二次文书到， 将我母子问充军。 皇恩赦诏得侥幸， 主仆才得转回程。 鞋弓袜小把路奔， 两足疼痛步难行。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "文禄！"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "奶奶！"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "我两足疼痛，难以行走。在此歇息歇息。你可前去问问，此处是什么地方。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄向内。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "众路人",
          "type": "内同白",
          "text": "请了！"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "借问一声：此处是什么地方？"
        },
        {
          "character": "众路人",
          "type": "内同白",
          "text": "蓟州西门以外，柳林之下。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "借重了。 啊奶奶，这就是蓟州西门以外，柳林之下。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "前去看看，哪是你爷爷的坟墓。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄走小圆场，看，念。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "“明故太常寺正卿莫公之墓”。 奶奶，爷爷的坟墓就在这里。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅氏走小圆场，看，念。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "“明故太常寺正卿莫公之墓。”哎，老爷呀！"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "一见坟墓珠泪滚， 好似钢刀刺我心。 指望进京加官赠， 又谁知蓟州堂上命归阴。 实指望夫妻同欢庆， 谁知今朝两离分。 哭老爷哭得我咽喉哽， 老爷呀！ 再要相逢万不能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄睡。莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "乘马来至在柳林， 阴风阵阵好惊人。 下得马来离金镫， 管家坟墓哪厢存？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "来此已是柳林。但不知哪是管家的坟墓。待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古看，念。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "“明故太常寺正卿莫公之墓。”哎，管家呀！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "一见坟墓泪珠滚， 黄土埋葬小莫成。 这样义仆世间少， 坟前祭拜在天灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古看。"
        },
        {
          "character": "莫怀古",
          "type": "念",
          "text": "小小门儿两扇开，只见坟墓眼前排。若问此是谁家墓，犯官有罪在此埋。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "奸贼呀奸贼！有我怀古在世一日，与你誓不两立也！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "恨奸贼把我的牙咬坏， 屈害忠良为何来？ 你在我在冤仇在， 奸贼呀！ 你死我亡两丢开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅氏看莫怀古。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "啊，你是何人，为何抱住我家的坟墓痛哭啊？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "此乃是我家的坟墓，怎说是你家的坟墓呢？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "此乃是我老爷莫怀古的坟墓，怎么是你家的坟墓哇？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你敢是傅氏么？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "啊，我在钱塘，哪一个不叫我一声“夫人”？你是甚等样人，敢叫我是“傅氏”？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "哎呀夫人哪！我是你丈夫莫怀古在此。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "哎呀老爷呀，我是前来看你的坟墓，痛哭你一场，我主仆还要趱路，你不要吓 我，你不要吓我呀！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "啊夫人，不要害怕，我不曾死。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "怎么，你不曾死？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "我不曾死。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "如此我老爷有两样贵处。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "哪两样贵处？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "我老爷前有梅花痦，后有三台骨。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "夫人请看。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "待我来看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅氏看莫怀古。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "你当真是我老爷莫怀古回来了？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "哎，老爷呀！"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "只知你在蓟州命丧了，"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "夫妻们团圆在今朝。"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "你年迈来我年老，"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "不觉两鬓似银条。"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "问声雪艳她可好？"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "乌鸦拆散凤凰巢。"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "忠义莫成今何在？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "夫人你来看！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "蓟州堂上他代劳。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "听说莫成命丧了， 不由老身泪双抛。 这样义仆世间少， 莫成啊！ 留下美名万载标。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "夫人不必哭了。你因何也来到此地？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老爷哪里知道，自从你走之后，闻听人言，你冒犯严府，命丧蓟州。严府二次 有公文到来，将我母子发往边外充军。多亏义仆之子文禄与莫豪孩儿顶名代替， 你我的孩儿跟随方先生江右攻读去了。我主仆幸遇皇恩大赦，才得回来。又 闻听人言，老爷坟墓在这西门以外柳林之下。故此前来看扫。不想老爷也来到 此地，夫妻到在这里相会了。文禄他、他、他……也来了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "文禄也来了？叫他前来见我！"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "文禄醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄醒。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "奶奶何事？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "你爷爷回来了。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "我爷爷回来了？ 啊爷爷回来了！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "怎么不见我家爹爹？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你爹爹么？爷爷乃是乘马；你家爹爹乃是步行，还在后面呢。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "待我看来。 爹爹，你怎么还不回来呀？你孩儿在此盼望于你。 啊爷爷，我爹爹怎么还不见回来，他往哪里去了？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "儿呀，你当真要见你家爹爹么？"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "要见我家爹爹。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "哎呀儿呀，这坟墓葬埋的就是你家爹爹呀！"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "怎么讲，这就是我爹爹的坟墓么？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "这就是你爹爹的坟墓。"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "哎呀爹爹呀！"
        },
        {
          "character": "莫文禄",
          "type": "唱",
          "text": "一见坟墓珠泪滚， 好似钢刀刺我心。 孩儿三岁母丧命， 七岁又死父天伦。 可叹文禄好命苦， 爹爹呀！ 抛下孩儿靠何人？"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "苍天哪苍天！想我文禄三岁亡母，七岁亡父，怎的不痛煞人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄气椅。"
        },
        {
          "character": "莫怀古、傅氏",
          "type": "同白",
          "text": "文禄醒来！"
        },
        {
          "character": "莫文禄",
          "type": "唱",
          "text": "三魂渺渺归阴府，"
        },
        {
          "character": "莫文禄",
          "type": "三叫头",
          "text": "爹爹！我父！哎呀爹爹呀！"
        },
        {
          "character": "莫文禄",
          "type": "唱",
          "text": "七魄茫茫又还魂。 指望父子重相见， 阴阳阻隔在柳林。 哭爹爹哭得我咽喉气尽，"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "莫文禄",
          "type": "唱",
          "text": "不如一死赴幽冥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫文禄欲碰，莫怀古拦。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "儿呀，你爹爹已死，焉能复生？不必哭了。 啊夫人，我有意把文禄收在膝下，以为螟蛉义子，不知夫人意下如何？"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "待妾身当面问来。 文禄，你爷爷有意将你收在膝下，以为螟蛉义子，不知你意下如何？"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "如此爹娘请上，受孩儿一拜！"
        },
        {
          "character": "莫怀古、傅氏",
          "type": "同白",
          "text": "好了，不要拜了。"
        },
        {
          "character": "莫文禄",
          "type": "唱",
          "text": "双膝跪在地埃尘， 拜谢爹娘收育恩。 孩儿年幼要教训， 从今只当你亲生。"
        },
        {
          "character": "莫文禄",
          "type": "哭",
          "text": "哎呀爹爹呀！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "儿呀，不要哭了。 夫人，此地离蓟州不远，你我且到戚贤弟衙内暂住几日，再作道理。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老爷言得极是。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "夫人请来乘马。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "这马让文禄骑了吧！"
        },
        {
          "character": "莫文禄",
          "type": "白",
          "text": "孩儿年幼，还走得动。这马还是母亲乘骑了吧！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "好一个孝顺的孩儿！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "好一个文禄小姣生， 与他爹爹是一样人。 怀古若要得侥幸， 难忘却他父替死恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古、傅氏、莫文禄同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引戚继光同上。"
        },
        {
          "character": "戚继光",
          "type": "引子",
          "text": "奉命镇蓟州，日夜心耽忧。"
        },
        {
          "character": "戚继光",
          "type": "念",
          "text": "堪叹严府礼不周，夺杯问斩怀古头。若非陆炳韬略有，本镇焉能回蓟州。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "本镇、戚继光。叨蒙圣恩，官复蓟州总镇。只因日前莫仁兄冒犯严府，道他隐 瞒皇家器皿，有欺君之罪。严府行文，命马上校尉沿途追赶。不想在本镇地面 将他拿获。多亏他家义仆莫成代替死罪。是本镇修下书信，将莫仁兄荐到边庭 魏门生那里隐姓埋名。不想汤勤这厮，又在严府世蕃面前搬动事非，道莫怀古 人头不真。严世蕃大怒，将我革职，一同解京对审原案。多亏陆年兄将此案审 明，又将雪艳断与汤勤为妻，吩咐衙役人等，假意与汤勤庆贺，备下酒宴，将 汤勤用酒灌醉。三更时分，雪艳将汤勤刺死房内。可怜我那仁嫂为夫尽节自缢 而亡。日前阖朝三百六十名进士联衔奏本，参那严贼。圣上大怒，将严嵩父子 收禁在监。幸得皇恩大赦，是我修书与莫仁兄，叫他回来，可以安然无事。去 了许久，未见回音。 来，伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "忙将莫爷事，报与总爷知。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启总爷：莫老爷到。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "说我有请！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。〖吹打〗。莫怀古、傅氏、莫文禄同上。戚继光迎。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁嫂也回来了，实是难得。请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅氏、莫文禄同下。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁兄！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "几载未见，承蒙贤弟救兄活命之恩，当面谢过！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "不知仁兄驾到，未曾远迎，望乞恕罪！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "岂敢！愚兄别后，但不知这桩事情是怎生落案？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "自从仁兄去后，汤勤那厮又在严府搬动是非，道仁兄首级乃是假的。严世蕃大 怒，将弟革职，连仁嫂一同解京对审原案。多亏陆年兄将此案审明。虽然落案， 只是作了一桩无才之事！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "哪桩“无才”之事？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "陆仁兄将仁嫂断与汤勤了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "真乃无才！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁兄道他“无才”，小弟看来倒也“有才”！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "怎么又“有才”呢？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "他不将仁嫂断与汤勤，仁兄之事，不能落案；严府二差，不能销票；小弟也不 能原任为官。是陆仁兄心生一计，叫衙内人役，假意庆贺，用酒将汤勤灌醉。 仁嫂三更时分，将汤勤刺死。可叹仁嫂为夫尽节，她也自刎而亡了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "啊，雪艳自刎而亡了！哎，妻呀！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "闻言不由伤心痛， 点点泪珠洒前胸。 哭贤妻你情深义又重， 替夫尽节立有功。"
        },
        {
          "character": "戚继光",
          "type": "唱",
          "text": "仁兄不必心酸痛， 志广才高陆年兄。 节烈仁嫂把命送， 这冤仇已报感苍穹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "龙虎台前出入，貔貅帐内传宣。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启元帅：巡按大人在此下马。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "此乃要事。仁兄请至后面少坐片时。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "暂时告别！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "少刻奉陪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古下。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "中军听令：吩咐五营四哨，全身披挂，迎接巡按大人，不得有误！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。戚继光、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "莫豪",
          "type": "内唱",
          "text": "旌旗招展山岳震，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、门子引莫豪同上。"
        },
        {
          "character": "莫豪",
          "type": "唱",
          "text": "刀枪剑戟耀日明。 背地只把继光恨， 害得我父子两离分。 我母充军无音信， 一家人死散好苦情。 催动人马往前进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、门子、莫豪同走小圆场。四文堂、四大铠、四将官、中军引戚继光同上，戚继光迎。"
        },
        {
          "character": "戚继光",
          "type": "唱",
          "text": "蓟州城戚继光迎接大人。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "蓟州总兵戚继光迎接大人。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "蓟州总兵戚继光迎接大人。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "蓟州总兵戚继光迎接大人。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "察院伺候！ （四文堂、四大铠、门子、莫豪同下，四文堂、四大铠、四将官、中军、戚继光同随下。四文堂、四大铠、 门子、莫豪同上，四文堂、四大铠、四将官、中军、戚继光同随上，戚继光跪。）"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "参见大人！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "起！免！仪门打躬！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光起，打躬。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "多谢大人！"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "去了盔甲，再来叙话。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "是。 两厢退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。戚继光、四文堂、四大铠、四将官同下。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "参见大人！"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "军册簿呈上。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "是。 军册簿呈上，大人请看。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫豪对门子。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "按册查点！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子查点。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "钱粮？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "解清。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "仓库？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "充实。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "兵丁？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "强状。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "刀枪？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "明亮。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "启禀大人：仓库充实，查点并无缺少。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫豪起立，背供。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "哎呀且住！本院来到蓟州，指望拿他的错处与我爹爹报仇。谁知他人马精壮， 仓库充实。苍天哪苍天！活活气煞我也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫豪作心痛状、坐。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "啊贵镇，大人偶得疾病，如何是好？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "不妨，有药酒可以调治。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "快快取来！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光下，拿杯上。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "药酒在此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子接酒灌莫豪。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "大人醒来！"
        },
        {
          "character": "莫豪",
          "type": "唱",
          "text": "适才一阵魂不定， 心中慌乱冷汗淋。 睁开二目强镇静， 见此玉杯暗沉吟。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "我看此杯，好似我家传家之宝，缘何落在此地？噢噢是了，想是我爹爹命丧他 手，戚继光将我家传家之宝隐瞒起来。要报此仇，就在这只杯子上面。 来，将蓟州总镇与我绑了！"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同绑戚继光。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "啊大人，为何将卑职绑了？"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "唗！大胆蓟州总镇，盗取我家传家之宝。待本院打本进京，定要参掉你的前程！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大人请息怒，此杯现有杯主。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "杯主是何人？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "卑职说了出来，惟恐前程难保！"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "不妨。本院保你无事。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "杯主人乃是莫怀古。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "此人还在么？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "还在。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "今在何处？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "卑职衙内。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "暂且松绑。传来相见！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "多谢大人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光向内。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "仁兄快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "贤弟何事？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "小弟惹出一件祸事来了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "什么祸事？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "这位大人，方才偶得疾病，是小弟将你那只杯子倒上甘酒献与大人。不料大人 一见此杯，就这么“唗”了一声，他说小弟盗了他传家之宝，就将小弟绑起来 了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你是怎样回答？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "我说此杯原有主。他说杯主是谁？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你怎么回答？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "我就说出你来了。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "哎呀，你怎么单单要说出我来呢？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大人叫我传你，快走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光扯莫怀古同进。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大人，杯主来了。"
