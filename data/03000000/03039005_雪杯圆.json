          "character": "莫怀古",
          "type": "白",
          "text": "也来了。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "待孩儿打本进京，将这“一捧雪”进献当今，自有好音前来。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "我儿言得极是。随为父去到后堂，见过儿的母亲。"
        },
        {
          "character": "莫豪",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "莫怀古",
          "type": "念",
          "text": "曾记当年遭魔障，骨肉分离各一方。"
        },
        {
          "character": "莫豪",
          "type": "念",
          "text": "苍天默佑重聚会，"
        },
        {
          "character": "戚继光",
          "type": "念",
          "text": "相逢原归蓟州堂。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "好一个“相逢原归蓟州堂”。后堂摆宴，与你戚叔父压惊！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
