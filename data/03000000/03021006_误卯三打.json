{
  "script_id": "03021006",
  "title": "误卯三打",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "小生"
    },
    {
      "name": "苏龙",
      "hangdang": "老生"
    },
    {
      "name": "魏虎",
      "hangdang": "净"
    },
    {
      "name": "代战公主",
      "hangdang": "旦"
    }
  ],
  "plot": "薛平贵别妻王宝钏，回营误卯。元帅魏虎因受岳父王允嘱托，借故欲斩薛平贵。经苏龙劝阻，乃捆打四十。\n薛平贵至西凉与代战公主交战，获胜回营；魏虎复借庆功为由，用酒将薛平贵灌醉，缚于红鬃马上，驱至西\n凉，为敌所获。西凉王反以其女代战许之；西凉王死，薛平贵得代战公主之助，继位银安殿。",
  "notes": "为全部《王宝钏》之第六折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四铠将、中军、苏龙、魏虎同上。〖点绛唇〗。苏龙、魏虎同归座。"
        },
        {
          "character": "苏龙",
          "type": "念",
          "text": "一颗皇家印，令箭调三军。"
        },
        {
          "character": "魏虎",
          "type": "念",
          "text": "马踏花世界，保主定乾坤。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "俺，苏龙。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "俺，魏虎。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "今奉圣命，扫灭西凉。 中军过来，传令下去，击鼓听点！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "击鼓听点！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "前营！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "后营！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "左营！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "右营！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "未到。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "啊？本帅初点大卯，先行因何不到？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "披挂来迟，请元帅宽点二卯。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "吩咐起鼓。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "起鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "场面起鼓。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "前后营！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "左右营！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "未到。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "啊？二卯不到，其情可恼！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "天气炎热，请元帅宽点三卯。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "吩咐起鼓，单点先行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四铠将同允。场面起鼓。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "未到。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "未到。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "未到！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "啊？本帅连点三卯，先行竟敢不到，哪里容得？来呀，将误卯牌挂出！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "薛平贵",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "来在营门外，勒马下雕鞍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下马。"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "一见误卯牌，叫人心胆寒！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "报！先行告进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵进门。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵跪。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "唗！本帅连点三卯，竟敢不到。你往哪里去了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "披挂来迟。望元帅恕罪！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "番贼前来讨战，你也披挂来迟不成？哪里容得，推出斩了！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "且慢！为何将他斩首？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "他误了卯期，故而将他斩首。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "斩不得！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "怎么斩不得？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "未曾出兵，先斩先行，于军不利！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "斩不得，我可打得？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "打么？嗯，但凭于你！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "来呀，两捆八十，与我打！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "为何两捆八十？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你也是元帅，我也是元帅，你四十，我四十，岂不是八十？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "我的四十不打了。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你的四十不打，我是要打的。 来呀，一捆四十，与我着实地打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同打薛平贵。薛平贵跪。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "谢元帅的责！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "我打得你可公？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不公！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "打得你可是？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不是！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "不公也要公，不是也要是。传令下去，兵发西凉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵起。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "众将官，兵发西凉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四铠将同允。〖牌子〗。苏龙、魏虎、薛平贵同上马，同走圆场。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "人马撤回！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "呕！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牌子止。四龙套、四铠将分站大小边。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "唗！今乃黄道吉日，出兵征战西凉。这样慢吞吞地行走，几时能到西凉？哪里 容得？斩了，斩了！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "且慢！又斩哪个？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行平贵。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "斩不得！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "斩不得？我还是打！来呀！两捆八十，与我打！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "你四十，也就够了。为何要打八十？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "还是你四十，我四十！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "我的四十免了！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你免我不免。 来，扯下去打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同打薛平贵。薛平贵跪。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "谢元帅的责！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行听令：吩咐三军，急急而行，往西凉去者！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "得令！ （薛平贵起。苏龙、魏虎、薛平贵同上马。四龙套、四铠将同下。苏龙、魏虎、薛平贵编辫子。薛平贵与魏 虎撞，魏虎倒，薛平贵下马扶魏虎起。）"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "人马撤回！"
        },
        {
          "character": "四龙套、四铠将",
          "type": "同白",
          "text": "呕！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四铠将自两边分上，分站大小边。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "唗！胆大先行，将本帅撞倒马下。哪里容得？ 来呀，与我打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同打薛平贵。薛平贵跪。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "谢元帅的责！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行听令：命你攻打头阵！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "末将两腿疼痛，不能乘骑，怎能交战？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "两腿疼痛，不能乘骑，我却会治！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏虎拔剑威吓。薛平贵惧怕，持枪上马，下。四龙套同随下。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "三军的，就在此地安营扎寨！ （苏龙、魏虎、四铠将同下。代金、代银随四番兵自上场门同上。薛平贵随四龙套自下场门同上，会阵，起 打。代金、代银同败下。薛平贵追下，四龙套同随下。）"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四番兵引代战公主同上。代金、代银同上。四龙套引薛平贵同上。四龙套自上场门同下。代金、代银、四"
        },
        {
          "character": null,
          "type": "text",
          "text": "番兵自下场门同下。代战公主与薛平贵起打。代战公主败下。四龙套自上场门同上，过场，同追下。薛平贵"
        },
        {
          "character": null,
          "type": "text",
          "text": "耍下场追下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四番兵、代金、代银、代战公主同上，同进城。关城。四龙套、薛平贵同上，城上挥旗、鸣金。薛平贵领"
        },
        {
          "character": null,
          "type": "text",
          "text": "四龙套自上场门同下。四番兵、代金、代银、代战公主自下场门同下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苏龙上。"
        },
        {
          "character": "苏龙",
          "type": "念",
          "text": "先行去交兵，未见转回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引薛平贵同上。薛平贵下马，龙套甲接枪。四龙套分站两边，薛平贵进门。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "罢了。胜负如何？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大获全胜。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "本帅备酒，与先行贺功。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多谢元帅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引魏虎同上，魏虎下马，进门。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "先行回来了？攻打头阵，得胜而归。本帅营中准备酒宴，与你贺功。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "元帅抬爱，末将怎敢！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你要来的，你一定要来的呀！ 来，带马回营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套戊递马鞭，魏虎上马，随四龙套同下。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "魏虎害我，如何是好？"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "有我在此，料无妨害。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "全仗元帅。 来，带马魏营去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲递马鞭，薛平贵上马，下。四龙套随苏龙同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引魏虎同上。"
        },
        {
          "character": "魏虎",
          "type": "念",
