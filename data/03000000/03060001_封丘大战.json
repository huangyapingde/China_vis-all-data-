{
  "script_id": "03060001",
  "title": "封丘大战",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "史彦超",
      "hangdang": "老生"
    },
    {
      "name": "高行周",
      "hangdang": "净"
    }
  ],
  "plot": "苏逢吉谗害史弘肇。史弘肇弟史彦超镇守封丘，其子携仆投之。大将高行周奉命往攻，封丘城破，史氏全家\n自尽，史彦超败阵，突围而逃。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀亮、王皇、刘闵同上，同起霸。"
        },
        {
          "character": "高怀德、高怀亮、王皇、刘闵",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "高怀德。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "高怀亮。"
        },
        {
          "character": "王皇",
          "type": "白",
          "text": "王皇。"
        },
        {
          "character": "刘闵",
          "type": "白",
          "text": "刘闵。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "高怀亮、王皇、刘闵",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "父帅升帐，你我两厢伺候！"
        },
        {
          "character": "高怀亮、王皇、刘闵",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、高行周同上。"
        },
        {
          "character": "高行周",
          "type": "点绛唇",
          "text": "奉命点将，威风浩荡，中军帐，摆列刀枪，要把封丘荡！"
        },
        {
          "character": "高怀德、高怀亮、王皇、刘闵",
          "type": "同白",
          "text": "参见父帅！"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "高怀德、高怀亮、王皇、刘闵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "父子三人威风凛，冲锋破敌建功勋。奉命扫荡封丘郡，擒捉彦超方称心。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "本帅、高行周。奉命捉拿归德节度使史彦超，因此统兵前来。昨日远探报到， 此处离归德不远，必须倍道而行，攻其不备。 怀德、怀亮，吩咐大小三军，拔营起寨，速速趱行！"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "啊！ 众将官，拔营起寨，速速趱行！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "李崇矩",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李崇矩、史耀先同上。"
        },
        {
          "character": "李崇矩",
          "type": "唱",
          "text": "恼恨奸贼心太狠，"
        },
        {
          "character": "史耀先",
          "type": "唱",
          "text": "苦害我一家为何情？"
        },
        {
          "character": "史耀先",
          "type": "白",
          "text": "哎呀老哥哥呀！你我主仆逃出府来，投奔哪里安身才是？"
        },
        {
          "character": "李崇矩",
          "type": "白",
          "text": "公子，想那二老爷现在归德，统兵镇守。你我主仆投奔那里，一来报信，二来 也好让二老爷作一准备。"
        },
        {
          "character": "史耀先",
          "type": "白",
          "text": "老哥哥说得极是。你我急速前去便了！"
        },
        {
          "character": "史耀先",
          "type": "唱",
          "text": "含悲忍泪把路上，"
        },
        {
          "character": "李崇矩",
          "type": "唱",
          "text": "见了那二老爷细说端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李崇矩、史耀先同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军、史彦超同上。"
        },
        {
          "character": "史彦超",
          "type": "引子",
          "text": "豪气冲霄汉，法森严，保主江山。"
        },
        {
          "character": "史彦超",
          "type": "念",
          "text": "秋草初黄杀气多，腥风血漠动干戈。龙蛇蟠绕旌旗列，霜雪凝冰剑戟磨。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "本镇、史彦超。北汉为臣，官拜归德节度。兄长弘肇，在朝奉君。只因边邻不 靖，日日操演兵将，以防不测。这几日本镇心惊肉跳，不知为了何事？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "风旗上，过场，下。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "啊，帅字旗无风自动，其中必有军情。 站堂军，伺候了！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李崇矩、史耀先同上。"
        },
        {
          "character": "李崇矩、史耀先",
          "type": "同白",
          "text": "门上哪位在？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "李崇矩",
          "type": "白",
          "text": "烦劳通禀，就说帅爷的侄公子求见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军向史彦超。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启禀帅爷：府门以外，有一老仆，手拉幼童，口称是帅爷的侄公子。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "叫他进来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请公子！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史耀先、李崇矩同进门。"
        },
        {
          "character": "史耀先",
          "type": "白",
          "text": "唉，叔父哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史耀先哭。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "为何这等模样？"
        },
        {
          "character": "李崇矩",
          "type": "白",
          "text": "哎呀二老爷呀！只因我家大老爷奏本谏君，那后主非但不听，反将大老爷与太 夫人一家老幼同斩市曹！"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "你怎么讲？"
        },
        {
          "character": "李崇矩",
          "type": "白",
          "text": "问斩市曹！"
        },
        {
          "character": "史彦超",
          "type": "三叫头",
          "text": "母亲！兄长！唉，娘呀！"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "听一言不由我魂消魄化，"
        },
        {
          "character": "史彦超",
          "type": "三叫头",
          "text": "母亲！兄长！唉，娘呀！"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "只气得史彦超咬碎银牙。 回头来便把那昏王叫骂， 可叹我一家人命染黄沙。"
        },
        {
          "character": "李崇矩",
          "type": "白",
          "text": "二老爷呀！"
        },
        {
          "character": "李崇矩",
          "type": "唱",
          "text": "这件事虽是那后主作差， 内有个苏逢吉暗把计发。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "好贼子！"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "苏逢吉老奸贼真真胆大， 有什么冤与仇要害全家？ 手拉娇儿大堂下， 快请夫人说根芽。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、史夫人同上。"
        },
        {
          "character": "史夫人",
          "type": "唱",
          "text": "每日里在后堂香烧佛念， 但愿得吾老爷禄位高迁。 小丫鬟报一信二堂来见，"
        },
        {
          "character": "史夫人",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "史夫人",
          "type": "唱",
          "text": "为什么皱双眉泪洒胸前？ 走向前道万福躬身下站， 尊老爷呼唤我所为哪般？"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "夫人有所不知情， 下官言来听分明： 长兄金殿去奏本， 逢吉老贼把计生。 昏王传旨将全家斩， 连累了年迈的娘亲命归阴。 我一家无故遭毒狠， 幸喜逃出这条根。"
        },
        {
          "character": "史夫人",
          "type": "唱",
          "text": "老爷不必两泪淋， 就该发兵报冤情。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "听一言来心猛省， 大丈夫不如女钗裙！ 夫人且把二堂进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史夫人、丫鬟同下。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "中军！"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "拿我令箭到各营。 就说是爷要兴人马！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史彦超、史耀先同下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "各营将官听者：元帅有令，命你等全身披挂，齐至校场听点！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、高怀德、高怀亮、王皇、刘闵、高行周同上。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "前面已是归德境界。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "人马列开！好一处平川之所，就在此处安营扎寨，歇兵三日，前去攻城！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "探子",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "探子奉将令，四路探军情。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "俺、史元帅帐下得力探子是也。今有高行周奉旨统兵数万，攻取归德。不免报 与主帅知道便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军、史彦超同上。"
        },
        {
          "character": "史彦超",
          "type": "念",
          "text": "柱石功勋凭三略，大将横行十万师。台上霜威凌草木，军中杀气燕飞迟。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "本帅、史彦超。只因兄长奏本谏君，被昏王将吾全家问斩市曹，为此点动人马， 要与母、兄报仇。正是："
        },
        {
          "character": "史彦超",
          "type": "念",
          "text": "怒气冲霄汉，兴师报仇冤！"
        },
        {
          "character": "探子",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "打探军情事，报与主帅知。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！探子告进！元帅在上，探子参！"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "有何军情？起来讲！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "元帅容禀！"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "探子领将令，四路去打听：行周领人马，夺取归德城！"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "那贼兵势如何？"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "那贼兵势浩荡，一路之上，好不威严人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "赏你银牌一面，再去打探！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "史彦超",
          "type": "白",
          "text": "且住！时才探子报道：高行周统兵前来。我不免去至敌楼，观其动静便了。 众将官，敌楼去者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "谗臣当道朝纲乱， 恨昏王无道听信谗言。 兄长金殿把本谏， 逢吉老贼他暗使巧机关。 害得我一家市曹斩， 白发老娘命染黄泉。 此一番统兵去交战， 拿住老贼活祭在灵前。 饮尔血，食尔肉，抽尔筋，剥尔皮，把尔的眼挖穿！ 人来与爷往前赶！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "到敌楼观动静细说根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史彦超、中军同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "高行周",
          "type": "内唱",
          "text": "奉命扫灭归德郡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、高怀德、高怀亮、王皇、刘闵、高行周同上。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "人强马壮似天神。 大队人马往前进， 大叫彦超快出城！"
        },
        {
          "character": "史彦超",
          "type": "内唱",
          "text": "恨昏王无道贪色酒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "场上设城。四龙套、史彦超同上城。"
        },
        {
          "character": "史彦超",
          "type": "哭头",
          "text": "娘啊！"
        },
        {
          "character": "史彦超",
          "type": "唱",
          "text": "叹慈颜不由人珠泪双流。 耳边厢又听得人喧马吼， 旌旗招展光射斗牛。 高行周坐雕鞍威风抖擞， 众儿郎似虎狼神鬼皆愁。 两边的众将士欲起争斗， 含悲忍泪说从头： 可叹我一家遭毒手， 年迈兄长血溅刀头。 为国忠良不长久， 俺情愿一死报冤仇。 劝尔等及早卸甲胄， 倘若迟延命难留。"
        },
        {
