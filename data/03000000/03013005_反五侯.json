{
  "script_id": "03013005",
  "title": "反五侯",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "李存孝",
      "hangdang": "武生"
    },
    {
      "name": "高思继",
      "hangdang": "老生"
    },
    {
      "name": "李克用",
      "hangdang": "净"
    }
  ],
  "plot": "五代时，诸侯乱争。赫连图与李克用交战，为李克用之义子李存孝所败。赫连图部将高思继英勇异常，请令\n出战。李存孝时正患病，为诸兄所激，力疾迎敌；终将高思继擒获，并劝服归降。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二青袍引郭从周同上。"
        },
        {
          "character": "郭从周",
          "type": "念",
          "text": "定下牢笼套，逼反栋梁臣。"
        },
        {
          "character": "郭从周",
          "type": "白",
          "text": "下官郭从周。奉了朱千岁之命，造下药酒一瓶，和钢刀一把，命五路诸侯，服 毒而亡。 来，开道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高思继上。"
        },
        {
          "character": "高思继",
          "type": "念",
          "text": "白盔白甲白旌旗，刀枪剑戟放光辉。上阵全凭银战杆，万马营中无人敌。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "俺，高思继。在赫元帅帐下，以为前战先行。元帅吩咐，三日小操，五日大操。 今乃大操之期，前来在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高思继坐门椅。四小军引赫连图同上。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "本帅，赫连图。在朱温驾前为臣，官拜统兵大元帅，奉旨镇守五路等处。今大 操之期。 来，传先行进帐！"
        },
        {
          "character": "四小军",
          "type": "同白",
          "text": "先行进帐！"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "高思继告进。 元帅在上，末将参见！"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "少礼。站下。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "有何将令？"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "吩咐人马下校场操演！"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "元帅有令：人马校场操演！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军同允。"
        },
        {
          "character": "郭从周",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "免操。接旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。郭从周上。"
        },
        {
          "character": "郭从周",
          "type": "白",
          "text": "旨下。跪！诏曰：先王驾崩，未曾奔丧，罪之有一；新主登基，未来朝贺，罪 之有二；朝贡三载不进，罪之有三。圣上赐钢刀一把，药酒一瓶，命五路诸侯， 服毒而亡。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "赫连图",
          "type": "唱",
          "text": "听一言来怒气生， 骂声梁王无道君。 叫人来将他推出斩！"
        },
        {
          "character": "郭从周",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "高思继",
          "type": "唱",
          "text": "元帅息怒听下情。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "元帅，此人大笑，必有缘故。元帅必须问明。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "将他招回来。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "将他招回来！"
        },
        {
          "character": "郭从周",
          "type": "白",
          "text": "要斩便斩，如此三番两次，好不耐烦！"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "本帅将你斩首，为何发笑？"
        },
        {
          "character": "郭从周",
          "type": "白",
          "text": "我笑元帅有勇无谋。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "怎见得有勇无谋？"
        },
        {
          "character": "郭从周",
          "type": "白",
          "text": "李家父子，累次欺压我五路诸侯，何不发兵剿灭？"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "久有此心，缺少参谋。"
        },
        {
          "character": "郭从周",
          "type": "白",
          "text": "小官愿为参谋。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "好，请到后营！"
        },
        {
          "character": "郭从周",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭从周下。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "老将军听令！"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "命你押解粮草军前听用，不得有误！"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "得令。 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高思继下。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "来！传我将令，调各路诸侯，辕门听点。"
        },
        {
          "character": "四小军",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "赫连图",
          "type": "念",
          "text": "将军手段高，要灭小儿曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高思继上。"
        },
        {
          "character": "高思继",
          "type": "唱",
          "text": "在营盘领了元帅令， 押解粮草要小心。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "俺高思继。奉了元帅将令，押解粮草，马上加鞭！"
        },
        {
          "character": "高思继",
          "type": "唱",
          "text": "豪杰若得凌云志， 要作皇家栋梁臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高思继下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "四大铠",
          "type": "内同白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。四大铠同上。"
        },
        {
          "character": "大铠甲",
          "type": "白",
          "text": "众位将军请了。元帅有令，命我等辕门伺候。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。四大铠同下。四下手引赫连图同上。"
        },
        {
          "character": "赫连图",
          "type": "念",
          "text": "怒气高千丈，李鸦太不良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同上。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "元帅在上，我等参见！"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "元帅呼唤我等，有何军情？"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "只因李鸦父子，欺压我五路诸侯。请众位将军一同剿灭！"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "几时发兵？"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "即刻发兵！"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "众将官！起兵前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李存孝上，起霸。"
        },
        {
          "character": "李存孝",
          "type": "念",
          "text": "自幼生来胆气高，扭断朱温带一条。生擒活捉孟觉海，降龙伏虎任逍遥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同上。"
        },
        {
          "character": "李存孝",
          "type": "白",
          "text": "俺、十三太保李存孝。自兴兵以来，灭了黄巢，父王爱我如同掌上之珠。帐前 雄兵百万，战将千员，一个个见俺存孝，魄散魂飞。探子报道，朱温用离间之 计，逼反五路诸侯，要与某家对敌，俺岂容他猖狂。 军士们，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四大铠、赫连图同上，会阵。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "李存孝",
          "type": "白",
          "text": "俺乃十三太保李存孝。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "呔！大胆存孝，为何要灭我五路诸侯，是何道理？"
        },
        {
          "character": "李存孝",
          "type": "白",
          "text": "赫连将军，休中那朱温反间之计，将军若肯归降，少不得官封王位。倘若迟延， 兵败被擒，悔之晚也。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "休得多言，放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李存孝、赫连图同起打，赫连图败下，李存孝擒四大铠。"
        },
        {
          "character": "李存孝",
          "type": "唱",
          "text": "大吼一声如雷贯， 豪杰英雄气冲天。 多少上将丧吾手， 乌鸦敢到凤巢边。 叫小军与我忙卸镫，"
        },
        {
          "character": "李存孝",
          "type": "白",
          "text": "哎呀，不好！"
        },
        {
          "character": "李存孝",
          "type": "唱",
          "text": "寒病打倒将一员。 小军扶我进宝帐， 好教我有口也难言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "赫连图",
          "type": "内西皮导板",
          "text": "大战一场力不加，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引赫连图同上。"
        },
        {
          "character": "赫连图",
          "type": "唱",
          "text": "残兵败将乱如麻。 众将且归营门下， 再思良策把他拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高思继上。"
        },
        {
          "character": "高思继",
          "type": "唱",
          "text": "免战牌高挂在营门口， 见了元帅问根由。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "末将交令。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "老将军，粮草可曾催到？"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "俱已催到。元帅为何将免战牌高悬？"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "只因李存孝杀法骁勇，故而将免战牌高挂。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "元帅何不传下将令，待末将前去擒来。"
        },
        {
          "character": "赫连图",
          "type": "白",
          "text": "老将军须要小心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赫连图、四下手同下。"
        },
        {
          "character": "高思继",
          "type": "白",
          "text": "得令！ 众将官，催动人马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高思继下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源上。"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "俺李嗣源。奉父王之命，大战高思继。马上加鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源下。李存信上。"
        },
        {
          "character": "李存信",
          "type": "白",
          "text": "俺李存信。奉父王之命，生擒高思继。马上加鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李存信下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "老军引李克用同上。"
        },
        {
          "character": "李克用",
          "type": "引子",
          "text": "闷坐虎帐，心内惊，吾儿染病。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "孤、李克用。只因李存孝擒来四将，回营得了卸甲风症。不免去到病房，探望 一回。 老军！"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "带路病房去者！"
        },
        {
          "character": "李克用",
          "type": "唱",
          "text": "二国好似龙虎斗， 一来一往统貔貅。 若得吾儿病体好， 保定唐王数百秋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用、老军同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二太保同上。"
        },
        {
          "character": "太保乙",
          "type": "念",
          "text": "对面山上乌鸦叫，"
        },
        {
          "character": "太保甲",
          "type": "念",
          "text": "炮炸的窟窿炮知道。"
        },
        {
          "character": "太保乙",
          "type": "白",
          "text": "御弟！"
        },
        {
          "character": "太保甲",
          "type": "白",
          "text": "皇兄！"
        },
        {
          "character": "太保乙",
          "type": "白",
          "text": "自从父王收了李存孝，把你我都不放在眼里。我们想个什么主意，害却于他， 岂不有了出头之日？"
        },
        {
          "character": "太保甲",
          "type": "白",
          "text": "我有个主意。"
        },
        {
          "character": "太保乙",
          "type": "白",
          "text": "你有什么主意？"
        },
        {
          "character": "太保甲",
          "type": "白",
          "text": "煮一斗米干饭，教他吃了胀死他。"
        },
        {
          "character": "太保乙",
          "type": "白",
          "text": "那不好，我倒是有个主意。"
        },
        {
          "character": "太保甲",
          "type": "白",
          "text": "你有什么主意？"
        },
        {
          "character": "太保乙",
          "type": "白",
          "text": "吩咐三军，擂鼓呐喊，就说高思继骂阵。他性如烈火，带病出战，被高思继杀 了你我就有出头的日子。"
        },
        {
          "character": "太保甲",
          "type": "白",
          "text": "此计甚好，我们去把他搀出来。 喂！十三兄弟，出来走走！"
        },
        {
          "character": "李存孝",
          "type": "内西皮导板",
          "text": "寒病打倒李存孝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李存孝上。"
        },
        {
          "character": "李存孝",
          "type": "唱",
          "text": "不由豪杰心内焦。 再不能与父王把驾保， 再不能阵前枪对刀。 忧闷闷坐在病床上， 咬定牙根似火烧。"
        },
        {
          "character": "太保甲、太保乙",
          "type": "同白",
          "text": "（皇兄）（御弟）吩咐众将摇旗呐喊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
