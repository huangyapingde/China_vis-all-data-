{
  "script_id": "03104001",
  "title": "晋阳城",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "秦彝",
      "hangdang": "老生"
    },
    {
      "name": "秦夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "北周，大司马杨忠率兵伐北齐，杀死北齐领军大将秦旭。秦旭子秦彝镇守晋阳，杨忠因又攻秦彝，欲除后患。\n秦彝出战，不胜，闭关拒守；参谋高阿古劝降，秦彝杖之，又责令守西门。高阿古暗通杨忠，献城投降。\n秦彝部将秦安护秦夫人及幼子秦琼逃走；秦彝奋战，力竭被杀。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨广、杨林、杨明、杨勇、杨素、李国贤同上，同起霸。〖粉蝶儿〗。"
        },
        {
          "character": "杨广、杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "杨广。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "杨林。"
        },
        {
          "character": "杨明",
          "type": "白",
          "text": "杨明。"
        },
        {
          "character": "杨勇",
          "type": "白",
          "text": "杨勇。"
        },
        {
          "character": "杨素",
          "type": "白",
          "text": "杨素。"
        },
        {
          "character": "李国贤",
          "type": "白",
          "text": "李国贤。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "元帅升帐，你我两厢伺候。请！"
        },
        {
          "character": "杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四龙套、四上手同上，同站门。杨忠上。"
        },
        {
          "character": "杨广、杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "杨忠",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "杨广、杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "杨忠",
          "type": "念",
          "text": "南征北战数十年，万马营中掌兵权。国家兴亡天心转，要夺北周锦江山。"
        },
        {
          "character": "杨忠",
          "type": "白",
          "text": "老夫、杨忠。北周驾前为臣，官居大司马，执掌兵权。只因皇王无道，天下荒 乱，朝中大权，归我一人执掌。前者兵伐北齐，将他国领兵大将秦旭夫妇擒杀。 他有一子，名唤秦彝，镇守晋阳城，十分骁勇，只恐将来他要子报父仇。有 道是：斩草要除根。因此点动人马，扫灭晋阳，捉拿秦彝，以除后患。 众位将军！"
        },
        {
          "character": "杨广、杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "元帅！"
        },
        {
          "character": "杨忠",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "杨广、杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "杨忠",
          "type": "白",
          "text": "兵发晋阳去者！"
        },
        {
          "character": "杨广、杨林、杨明、杨勇、杨素、李国贤",
          "type": "同白",
          "text": "兵发晋阳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "奉了元帅命，四路探军情。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "俺、探子是也。奉了秦元帅之命，打探军情。闻听杨忠在朝专权，将秦老元戎 和太夫人杀死，今又带领人马前来扫灭晋阳，不免回关报与元帅知道。就此马 上加鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高阿古上。"
        },
        {
          "character": "高阿古",
          "type": "念",
          "text": "为人不用计和谋，怎能身挂紫罗袍。"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "下官、高阿古。在晋阳秦元帅帐下，官居参谋。是我有心归顺杨家，怎奈我家 元帅不知天命，执意不肯，我也只好待机而动。今日元帅去往校场操演人马， 这般时候，还不见到来。"
        },
        {
          "character": "秦彝",
          "type": "内白",
          "text": "众将官！"
        },
        {
          "character": "四龙套、四大刀手、四火牌军、秦安、周彬",
          "type": "内同白",
          "text": "有！"
        },
        {
          "character": "秦彝",
          "type": "内白",
          "text": "回操！"
        },
        {
          "character": "四龙套、四大刀手、四火牌军、秦安、周彬",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "元帅来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、四大刀手、四火牌军、秦安、周彬、秦彝同上。"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "元帅操演人马，多受辛苦。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "为国勤劳，何言辛苦！"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "适才元帅去往校场操演人马之时，下官闻报：杨忠带领人马前来攻取晋阳，老 元戎、太夫人尽忠一死。不知是真是假？"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "少时探子回报，便知分晓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "打探军情事，报与元帅知。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "探子吿进！元帅在上，探子叩头！"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "打探哪路军情？起来讲！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "元帅容禀！"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "小人探得杨忠将老元戎、太夫人斩首，帯领人马杀奔晋阳来了。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "那杨忠带领人马杀奔晋阳来了。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦彝晕。"
        },
        {
          "character": "秦彝",
          "type": "唱",
          "text": "听一言气得我昏迷不醒，"
        },
        {
          "character": "秦彝",
          "type": "三叫头",
          "text": "爹爹！母亲！唉，爹娘啊！"
        },
        {
          "character": "秦彝",
          "type": "唱",
          "text": "大骂杨忠狗奸臣。 杀死我爹娘心何忍， 此仇不报枉为人！"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "且住！可恨杨忠贼子将我爹娘杀死，带领人马前来扫灭晋阳。此仇不报，等待 何时？ 众将官！"
        },
        {
          "character": "四龙套、四大刀手、四火牌军、秦安、周彬",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "迎敌者！"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "参谋为何拦阻？"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "我想杨忠此番攻取晋阳，必然是兵精粮足。想这晋阳不过弹丸之地，元帅若要 迎敌，只恐不能取胜。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "依参谋之见？"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "依下官之见，不如紧守城池，看他的兵势如何，再作道理。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "参谋此言差矣！"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "何差？"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "想那杨忠贼子久怀篡逆之心，有我父子在朝，他不敢谋反，因此将我爹娘杀死。 有道是：父母之仇不共戴天。如今他领兵攻取晋阳，这也是他飞蛾投火，正 好报仇，为何惧而不战？"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "元帅既然要战，下官也不敢拦阻；只是必须派人紧守城池，以防不测。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "就命参谋紧守城池，不得有误。"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高阿古下。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套、四大刀手、四火牌军、秦安、周彬",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "迎敌者！"
        },
        {
          "character": "四龙套、四大刀手、四火牌军、秦安、周彬",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同出城，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、四大刀手、四火牌军、秦安、周彬、秦彝同上。四龙套、杨广、杨素同上，同开打。杨广、杨素"
        },
        {
          "character": null,
          "type": "text",
          "text": "同败下，秦彝领四龙套、四大刀手、四火牌军、秦安、周彬同追下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、杨林、杨明、杨勇、李国贤同上，四龙套、四大刀手、四火牌军、秦安、周彬、秦彝同上，会阵，"
        },
        {
          "character": null,
          "type": "text",
          "text": "同起打。四龙套、杨林、杨明、杨勇、李国贤同败下，秦彝领四龙套、四大刀手、四火牌军、秦安、周彬"
        },
        {
          "character": null,
          "type": "text",
          "text": "同追下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、杨忠同上。"
        },
        {
          "character": "杨忠",
          "type": "唱",
          "text": "旌旗招展困晋阳， 刀枪剑戟似秋霜。 四面埋伏天罗网， 捉拿秦彝小儿郞。 下得马来山岗上， 观看两家动刀枪。 （杨忠登高台。〖急急风〗。四龙套、杨林、杨明、杨勇、李国贤同上，四龙套、四大刀手、四火牌军、秦 安、周彬、秦彝同上，同起打。四龙套、杨林、杨明、杨勇、李国贤同败下。）"
        },
        {
          "character": "秦彝",
          "type": "唱",
          "text": "在沙场只杀得天昏地暗， 众儿郞一个个奋勇当先。 恨不能将奸贼碎尸万段！ （〖扫头〗。四龙套、杨广、杨素同上，同起打。四龙套、四大刀手、四火牌军、秦安、周彬、秦彝同下， 四龙套、杨广、杨素同追下。）"
        },
        {
          "character": "杨忠",
          "type": "唱",
          "text": "在山岗见众将与贼交战， 小秦彝可算得盖世奇男。 叫人来带坐骑忙回营转，"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "杨忠",
          "type": "唱",
          "text": "必须要思良谋扫灭狼烟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、四大刀手、四火牌军、秦安、周彬、秦彝同败上，同进城，同下。关城。八龙套、杨广、杨素、"
        },
        {
          "character": null,
          "type": "text",
          "text": "杨林、杨明、杨勇、李国贤同上。）"
        },
        {
          "character": "杨广",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": "杨素、杨林、杨明、杨勇、李国贤",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高阿古上。"
        },
        {
          "character": "高阿古",
          "type": "唱",
          "text": "杨忠围困晋阳城， 个个儿郎杀气生。 元帅出城去会阵， 两军阵前大交兵。 将少兵微终何用， 黎民涂炭受苦情。 胜负二字堆料定， 且听探马报军情。 （四龙套、四大刀手、四火牌军、秦安、周彬、秦彝同上，四龙套、四大刀手、四火牌军、秦安、周彬自两 边分下。）"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "元帅出兵，胜负如何？"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "悔不听参谋之言，中了那贼诱兵之计，如今大败而回。惭愧呀惭愧！"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "那杨忠围困城池，如何是好？"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "参谋有何良策，以解此危？"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "下官有一言，不知当讲不当讲？"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "参谋有话，但讲何妨？"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "我想老元戎不知天时，无端丧命。元帅身为大将，岂不知顺天者昌，逆天者亡！ 依下官之见，不如带了晋阳印信，出城投降。一来可保功名富贵，二来黎民 免遭涂炭。有道是：识时务者方为俊杰。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "参谋说哪里话来！想那杨忠，久存篡逆之心，将我爹娘杀死，食贼之肉，难消 此恨。如今有仇不报，反去降敌，为人不如禽兽，岂不留下骂名千载，遗臭万 年。参谋此话就不必再讲了。"
        },
        {
          "character": "高阿古",
          "type": "白",
          "text": "元帅之言，可算忠孝双全。怎奈杨忠兵强将勇，战之不胜，守之无救，倘若城 池一破，玉石皆焚，自身尚且难保，焉能兼顾他人？倒不如开城投降，你我还 可各保性命。如若不然，休怪高某不忠于元帅。"
        },
        {
          "character": "秦彝",
          "type": "白",
          "text": "你待怎讲？"
