          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄，大事泄露，如何是好？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "吾弟休虑，待兄临阵，以破曹兵。 廖、张二将！今日出战，非比等闲，要记下了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "晋公人马，围宫放火。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "再探！杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火彩。四文堂、四上手、四将、司马昭同上，同会阵。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "钟会逆贼，因何谋反？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、钟会、司马昭同起打。钟会败下，司马昭追下。"
        }
      ]
    },
    {
      "scene_id": 18,
      "name": "第十八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜维软靠、甩发上，与四将打，四将同败下。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "哎呀，好心痛也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维摔坐子，起。"
        },
        {
          "character": "姜维",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "事到如今，岂惧心痛，誓诛逆贼，以报先师！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维耍下场。"
        }
      ]
    },
    {
      "scene_id": 19,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "钟会、司马昭同上，对刀起打。姜维上，打，砍萝卜头子。四将同跑下。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "好心痛也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟会上。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄，因何心痛？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "呀呀呸！谁是你的仁兄？谁是你的仁兄？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维用剑砍钟会头，钟会下。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "俺一片忠心，只望一计害三贤。事已将成，谁想心忽大痛，此乃天绝炎汉，待 俺拜谢先皇，自尽便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。姜维跪拜，将甲上，用枪刺姜维，姜维跪夺枪反打将甲抢背，姜维立起接四将攒，四将同败下。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "圣上啊圣上！臣力尽矣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维拔剑自刎。司马昭、钟会同上，对打，司马昭擒钟会。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "姜维已死，将钟会绑回故宫。收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
