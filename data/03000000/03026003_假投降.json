      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、丘建、姜维、钟会、卫瓘同上，同入座。"
        },
        {
          "character": "姜维、卫瓘",
          "type": "同白",
          "text": "参见都督！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "二位将军少礼，请坐。"
        },
        {
          "character": "姜维、卫瓘",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "设三分公座。钟会正场，姜维大边，卫瓘小边。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将邓艾押上帐来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "邓艾押上帐来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手抬轿押邓艾同上。"
        },
        {
          "character": "邓艾",
          "type": "唱",
          "text": "怒气难平心头恨， 钟会忌才陷我身。 果然弓藏因鸟尽，"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "钟会呀钟会！"
        },
        {
          "character": "邓艾",
          "type": "唱",
          "text": "狡兔死后尔走狗烹。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "钟会，我把你这忌才的恶贼，今将某陷害，尔也难逃一刀之苦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟会笑。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "邓艾，谅你这养犊小儿，恃宠狂妄。吾今奉诏讨贼，何言陷害！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "邓艾！匹夫！你侥幸成功，自以为是。谁想你仍死在某家面前，尔羞也不羞？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾低头，卫瓘背躬。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "事已至此，休得多言。快快开刀！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将他推出斩首！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾三笑。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "钟会，我死之后，你要小心了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾下。钟会笑。刽子手甲献头上。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "号令辕门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刽子手甲应，下。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "末将告退！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "监军请便。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "谢都督！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫瓘作相，下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "后堂摆筵，与仁兄杯酒谈心。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟会、姜维挽手同下。四龙套自两边分下。"
        },
        {
          "character": "丘建",
          "type": "白",
          "text": "且住！前者卫监军送我黄金千两，叫我窥探镇西将军的行踪。今见他二人踪迹 可疑，不免至后堂暗中察看，亦好报与监军知道。正是："
        },
        {
          "character": "丘建",
          "type": "念",
          "text": "要知心腹事，但听口中言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丘建下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "钟会挽姜维同上。"
        },
        {
          "character": "钟会",
          "type": "唱",
          "text": "弟兄挽手后堂进， 你我商定大计行。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄请坐。今日成功皆吾兄之力，弟当面谢过。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "吾弟何出此言？想今虽然成功，兄尚有一言奉告。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄请讲！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "想当年越大夫文种不从范蠡于五湖，卒伏剑身死；韩信不听蒯通良言，致有未 央宫之祸。此二人岂非功名赫赫，只为利害未明。今吾弟功业已成，何不归隐 峨嵋之阳，以乐晚年也！"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "想邓艾枉立功一朝丧命， 天地间兴废事到底分明。 从此后定计谋乘时应运， 方不愧大丈夫明哲保身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丘建自大边暗上，偷听。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "兄言差矣！弟今年未及四旬，岂肯做此退闲之事。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "既然如此，兄有一事奉告。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维出图。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "昔先师武侯，以此图献与昭烈先皇，且曰：益州之地，沃野千里，国富民殷。 以吾弟智力所能，则霸业可成矣。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "好啊！吾意已决。事成则取天下，不成退守西蜀。但恐众将不服，如何是好？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "无妨！兄将本部人马，调至故宫。元宵日大张灯火，众将饮宴，有不从者，囚 在后宫，秘密杀之。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丘建作怕，下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "全仗吾兄，事成后富贵共之！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "兄明日亲至各部，调齐军将，元宵节起义便了。"
        },
        {
          "character": "钟会",
          "type": "唱",
          "text": "全仗仁兄相扶助！"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "早成霸业展宏图。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、钟会同下。"
        }
      ]
    },
    {
      "scene_id": 16,
