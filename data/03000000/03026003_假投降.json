{
  "script_id": "03026003",
  "title": "假投降",
  "alias": [
    "一计害三贤"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "姜维",
      "hangdang": "武生"
    },
    {
      "name": "邓艾",
      "hangdang": "净"
    }
  ],
  "plot": "邓艾取绵竹后，直逼成都。刘禅迎降。姜维迫于情势，遂密议诈降钟会。适钟会欲用姜维之智除邓艾，独揽\n西川；姜维亦欲乘二将不合，灭之以复蜀汉。因伪与钟会结为金兰。钟会用姜维计上书言邓艾有反意，并奉\n诏杀邓艾。姜维复献西川图，假辅钟会别图霸业以抗司马昭。事为司马昭洞悉，星夜赶至成都，擒杀钟会。\n姜维乃率众迎敌，以心痛病复发，壮志未酬，竟自刎死。",
  "notes": "此剧经刘砚芳先生协助校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、黄皓、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "自那日报邓艾兵犯皇图， 教寡人肠九转日夜难舒。 但愿得诸葛瞻将贼擒获， 一霎时飞报到奏捷成都。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谯周上。"
        },
        {
          "character": "谯周",
          "type": "唱",
          "text": "邓艾已取绵竹郡， 诸葛驸马丧残生。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "启奏陛下：大事不好了！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "今有诸葛驸马父子阵亡，绵竹已失，邓艾必然进兵夺取成都。请旨定夺！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "驸马疆场把忠尽， 去了擎天柱一根。 回头便对谯周论， 快宣文武众朝臣。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "领旨！ 万岁有旨：众文武上殿！"
        },
        {
          "character": "刘谌、郤正、蒋显、邓良",
          "type": "内同白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌、郤正、蒋显、邓良同上。"
        },
        {
          "character": "刘谌",
          "type": "唱",
          "text": "连日飞将军情紧，"
        },
        {
          "character": "郤正",
          "type": "唱",
          "text": "邓艾兵困绵竹城。"
        },
        {
          "character": "蒋显",
          "type": "唱",
          "text": "诸葛驸马临敌阵，"
        },
        {
          "character": "邓良",
          "type": "唱",
          "text": "但愿捷报到朝廷。"
        },
        {
          "character": "刘谌、郤正、蒋显、邓良",
          "type": "同白",
          "text": "臣等见驾，陛下万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "刘谌、郤正、蒋显、邓良",
          "type": "同白",
          "text": "谢万岁！宣臣等上殿，有何国事议论？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "顷接飞报，诸葛瞻父子战死绵竹。邓艾若再进兵，则成都危矣。众卿速筹退兵 之策！"
        },
        {
          "character": "刘谌、郤正",
          "type": "同白",
          "text": "启陛下：现在成都兵微将寡，难以迎敌。不如早弃成都，奔南中七郡，可以自 守。然后召大将军姜维进兵，再求克复未迟。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "启陛下：此事不可！南蛮乃久反之人，陛下投之，必受其害。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "蜀、吴同盟，今既事急，可往投之。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "益发不可！自古以来，无寄他国为天子者。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "南中七郡不能往， 欲投东吴理不当。 众卿速筹良谋上， 早退邓艾保孤王。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "事到如今，朕只求平安，便割地求和，未为不可。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "陛下既愿求和，依臣之见，不如降魏，魏必列土以封陛下。这上，可安宗庙； 这下，可保黎民。请陛下思之！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤已思之：若再动兵，难免百姓受苦。今闻大夫之言，朕心已决。速备降表， 降魏便了。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "住了！谯周竖儒，妄论社稷大事。自古焉有降天子？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "今大臣皆议降魏，独你仗血气之勇，欲使满城流血么？此处用你不着，出宫去 吧！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "刘谌",
          "type": "念",
          "text": "捐身酬列祖，搔首泣苍穹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌恨，下。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "谯周速作降书，同侍中张绍、都尉邓良捧定玉玺，往雒城请降。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谯周下。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、师纂、邓忠、邓艾同上，同站斜一字。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "催军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、师纂、邓忠同领起，同走圆场。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "军马为何不行？"
        },
        {
          "character": "师纂",
          "type": "白",
          "text": "前面已是成都，请令定夺！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "将成都团团围住！"
        },
        {
          "character": "四龙套、四下手、师纂、邓忠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、黄皓、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "念",
          "text": "独坐深宫内，心烦意不宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启万岁：北地王在太庙自刎了！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "哎，儿呀！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "可叹刘谌把忠尽， 顷刻父子两离分。 耳边又听炮声震， 快宣朝臣入宫廷。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "万岁有旨：群臣上殿哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谯周、邓良同上。"
        },
        {
          "character": "谯周、邓良",
          "type": "同念",
          "text": "破碎三分国，可惜旧江山。"
        },
        {
          "character": "谯周、邓良",
          "type": "同白",
          "text": "臣，（谯周）（邓良）见驾，陛下万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "平身。谯周，命你当殿再写降书。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谯周写。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "陛下御览！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅看降书。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "就命卿家随同孤王去到魏营投献迎降。"
        },
        {
          "character": "谯周",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤再修手诏，命蒋显晓谕姜维，早早投降。 传众文武上殿！"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "众文武上殿哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋显、郤正、张峻同上。"
        },
        {
          "character": "蒋显、郤正、张峻",
          "type": "同白",
          "text": "参见陛下！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "众卿随孤一同出城，迎降去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。刘禅换素褶、甩发，领四太监、黄皓、谯周、邓良、蒋显、郤正、张峻同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、师纂、邓忠、邓艾同上。"
        },
        {
          "character": "邓艾",
          "type": "念",
          "text": "年来征战无暇日，成都今日竖降旗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "蜀主君臣前来投降。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "大摆队伍，迎接蜀主进营！"
        },
        {
          "character": "师纂",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖牌子〗。四龙套、四下手、四大刀手、师纂、邓忠、中军、邓艾同上，邓艾坐帐。四朝臣、张峻、谯周、"
        },
        {
          "character": null,
          "type": "text",
          "text": "刘禅同上。谯周捧表、刘禅捧印盘同跪。邓艾下位接印、表，搀刘禅。）"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "大王请起。归顺天朝，自有封赠。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "谢都督！请都督进城。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "摆队进城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。刘禅扶邓艾上马，邓艾拦，请刘禅上马。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、廖化、张翼同上，同站门。姜维披蟒、软靠上。"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "屯田避祸恨奸佞， 统领雄狮镇剑门。 连日心惊神不定， 可恨奸贼乱朝廷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启都督：太仆蒋显押旨前来！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。蒋显上。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "请太仆开读圣谕！"
        },
        {
          "character": "蒋显",
          "type": "白",
          "text": "此旨不必开读。只因邓艾入川，主上业已投降，命下官捧旨前来，请大将军早 日投降。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "蒋显",
          "type": "白",
          "text": "请大将军早日投降！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维气椅。"
        },
        {
          "character": "蒋显、廖化、张翼",
          "type": "同白",
          "text": "大将军醒来！"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "听此言不由人心头愤恨，"
        },
        {
          "character": "蒋显",
          "type": "白",
          "text": "大将军醒来！"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "主上投降是何心？ 欲将情由把太仆问，"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "吾等三军死战，主上何故投降？"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "只见众将乱纷纷。"
        },
        {
          "character": "廖化、张翼",
          "type": "同白",
          "text": "大将军，可恨黄皓将阴平防兵撤去，克减军士钱粮，我等恨不得生食其肉！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "哎！主辱臣死，待某自刎了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化、张翼同夺剑。"
        },
        {
          "character": "廖化、张翼",
          "type": "同白",
          "text": "大将军不必如此。我等愿随大将军，另图良策。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维背躬。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "且住！看人心思汉，不免密定诈降之计，去往钟会营中诈降。管叫邓艾、司马 昭一班奸贼，自行杀害，再扶保我主重整江山，但愿苍天助俺三分力也！"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "诈降妙计安排定， 偷天换日鬼神惊。 众将进前听号令， 要把中原一扫平。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "廖化、张翼你二人附耳上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化、张翼同附耳，同作点头。"
        },
        {
          "character": "廖化、张翼",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "太仆，吾今行此计，愿太仆助之。"
        },
        {
          "character": "蒋显",
          "type": "白",
          "text": "愿听指挥。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "廖化、张翼、四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "就此往钟会营中去者！"
        },
        {
          "character": "廖化、张翼、四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四黑龙套、四下手、丘建、钟会同上。"
        },
        {
          "character": "钟会",
          "type": "引子",
          "text": "愤恨难平，嫉邓艾，偷渡阴平。"
        },
        {
          "character": "钟会",
          "type": "念",
          "text": "登台拜帅统兵将，妙算神机似子房。可恨明珠轻脱掌，反为人做嫁衣裳。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "某，钟会。驻兵在此，与姜维相持，反被邓艾小儿行险收川，真叫人十分恼恨。 欲设法除却邓艾，只是未有机会。 左右，伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启都督：姜维前来投降。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "噢！姜维前来投降。再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "且住！姜维此来，倘是真心，某除邓艾易如反掌；若是假意，这，某自有道理。 来！吩咐击鼓升帐。 （钟会下。〖急急风〗。四龙套、四下手、四大刀手、丘建同上，同站门。钟会上，亮相。〖四击头〗。钟 会入大帐。）"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "丘建！"
        },
        {
          "character": "丘建",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "传姜维一人进帐！"
        },
        {
          "character": "丘建",
          "type": "白",
          "text": "得令！ 都督有令：命姜维一人进帐！"
        },
        {
          "character": "姜维",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二军士引姜维同上。"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "国破家亡成画饼， 九伐中原枉逞能。 慢解佩剑心酸痛，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维作凄凉，将剑交二军士。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "你二人下面候令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二军士同应，同下。"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "且进大帐看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维望，悲愤、跺脚。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "报！姜维告进！"
        },
        {
          "character": "四龙套、四下手、四大刀手",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维挖门进。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "镇西将军在上，亡国之臣姜维拜见！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "伯约来何迟也？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维作相。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "国家全军在我，今日至此，犹为速也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟会起立。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "某久知伯约乃当代奇才，惜刘禅孱弱，致有今日。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "久闻都督自淮南以来，算无遗策。司马氏之盛，皆公之力，维深佩服。若邓艾 小儿，维当决一死战，安肯归降！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "邓士载收川有功，伯约不可妄言。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "那邓艾行险侥幸，恃宠而骄。维归降将军，愿领兵征除邓艾，以雪亡国之恨！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "邓征西功高望重，伯约不可妄言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维怔，想。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "既然如此，维请死帐前，以表此心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维欲撞，钟会急出帐拉住。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "伯约休要如此。 掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、四大刀手同下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "伯约请坐！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "邓艾行险，我岂不知。适才之言，乃相试耳。吾欲除却此人，伯约肯相助否？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "维愿效犬马之劳。但此事不宜造次，须定计而行。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "伯约之言，正合我意。某愿同兄结为兄弟，幸勿推却！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "维乃亡国之臣，怎敢仰攀。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "休得过谦。 丘建，香案伺候！"
        },
        {
          "character": "丘建",
          "type": "白",
          "text": "香案齐备。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "请仁兄上香！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "大胆了！"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "我二人结金兰三生有幸，"
        },
        {
          "character": "钟会",
          "type": "唱",
          "text": "对苍天发誓愿愿共死生。"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "你我望空忙拜定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、钟会同拜。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟会欲下拜。姜维扶钟会。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、钟会同笑。"
        },
        {
          "character": "钟会",
          "type": "唱",
          "text": "患难相扶不离分。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "酒宴伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。姜维、钟会同入席。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖园林好〗。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "贤弟，兄闻邓艾收川之后，大彰功绩，不肯班师。吾弟何不趁此上书晋公，报 告邓艾有不臣之意。未识可否？"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "妙啊！照此而行。 丘建溶墨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖江儿水〗。钟会修书。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄请看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维看。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "可速差人前往。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "传下书人！"
        },
        {
          "character": "丘建",
          "type": "白",
          "text": "传下书人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见都督！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "罢了。将此封章，封呈晋公，不得有误！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "钟会",
          "type": "念",
          "text": "晓夜莫停住，"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "驰报似流星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄再饮几杯。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "兄酒已够了。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四月华旗、四上手、四将、司马昭同上。〖点绛唇〗，〖水龙吟〗。司马昭入帐。"
        },
        {
          "character": "司马昭",
          "type": "念",
          "text": "拜将封王气概雄，文韬武略在胸中。转战疆场干戈动，一统山河掌握中。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "孤，晋公司马昭。只因命钟会、邓艾二人伐蜀，大功已成。只是邓艾上书，颇 有骄傲之意，反形已露，为此孤甚忧虑也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "将甲",
          "type": "白",
          "text": "哪里来的？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "钟镇西将军，有封章呈上。"
        },
        {
          "character": "将甲",
          "type": "白",
          "text": "候着！ 启晋公：钟会下书人求见。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "传！"
        },
        {
          "character": "将甲",
          "type": "白",
          "text": "晋公传你。小心了！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。 小人与晋公叩头！"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "奉何人所差？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "钟将军所差。封章呈上！"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "下面伺候！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "待我拆开一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "卫瓘、邵悌进见！"
        },
        {
          "character": "四上手、四将",
          "type": "同白",
          "text": "卫瓘、邵悌进见。"
        },
        {
          "character": "卫瓘、邵悌",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫瓘、邵悌同上。"
        },
        {
          "character": "卫瓘",
          "type": "念",
          "text": "大志安军国，"
        },
        {
          "character": "邵悌",
          "type": "念",
          "text": "机谋不等闲。"
        },
        {
          "character": "卫瓘、邵悌",
          "type": "同白",
          "text": "参见晋公！"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "少礼。请坐。"
        },
        {
          "character": "卫瓘、邵悌",
          "type": "同白",
          "text": "告坐。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "今有钟会封章，道邓艾反形已实。命卫将军领兵五万入蜀，以为监军；再使钟 会伺察邓艾，如有反形，就势诛之！"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "卫瓘",
          "type": "念",
          "text": "亲承晋公令，统兵兼程行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫瓘下。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "我看钟会亦有二心，卫瓘监军恐难成功。待孤即日起兵，驻扎陇西便了。 众将官！"
        },
        {
          "character": "四上手、四将",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "后日随孤起兵征西。掩门！"
        },
        {
          "character": "四上手、四将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、丘建、姜维、钟会同上。"
        },
        {
          "character": "钟会",
          "type": "念",
          "text": "杯酒重增知己兴，"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "灯花同照有心人。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "仁兄请坐！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "前者上书晋公，怎么还未见回音？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "吾料晋公回书，旦夕即至。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "卫监军到。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖牌子〗。四文堂引卫瓘同上。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "都督！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "监军！"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "此位是？"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "此人即姜伯约也。二公见过。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "瓘久慕将军英名，今日相会，真乃有幸。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "亡国之臣，何劳夸奖！"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "晋公有命示知都督，知邓艾反形已成，请即征讨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟会视卫瓘作神气。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "既有晋公钧命，敢求监军领兵征伐邓艾，本督大兵随后，谅监军必无推却的了。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "下官理当遵命，只请伯约同征，谅不误事。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "好！就请伯约统本部随行。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂引卫瓘同下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "丘建！令大小三军，明日五鼓发兵前往。正是："
        },
        {
          "character": "钟会",
          "type": "念",
          "text": "疆场催战马，"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "征尘满铁衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
