      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、师纂、邓忠、邓艾、四龙套、丘建、姜维、钟会二龙出水分上，同会阵。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "钟会，你敢是造反？"
        },
        {
          "character": "钟会",
