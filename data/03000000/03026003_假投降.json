      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四蜀兵、廖化、张翼同上，同站门。钟会、姜维同上。"
        },
        {
          "character": "钟会",
          "type": "念",
          "text": "定霸图王真快意，"
