    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套引卫瓘同上，卫瓘下马。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "且住！看钟会之意，欲令邓艾杀我，以正其罪。这，我自有妙法。我看钟会麾 下，丘建乃狗狼之辈，待我用金银买通此人，暗暗窥测钟会便了。"
        },
        {
          "character": "卫瓘",
          "type": "唱",
          "text": "我使丘建暗窥探， 管叫钟会难自专。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引邓艾同上。"
        },
        {
          "character": "邓艾",
          "type": "唱",
          "text": "不是偷渡阴平道， 怎能飞达上青霄。 自收西川迫降表， 大权独掌乐逍遥！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "师纂、邓忠同上。"
        },
        {
          "character": "师纂",
          "type": "唱",
          "text": "钟会统领人马到，"
        },
        {
          "character": "邓忠",
          "type": "唱",
          "text": "见了父帅说根苗。"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "启（主）（父）帅！今有钟会领兵前来，请令定夺。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "钟会领兵前来，莫非有劫我之意？起兵迎敌者！"
