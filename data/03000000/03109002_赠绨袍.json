{
  "script_id": "03109002",
  "title": "赠绨袍",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "范睢",
      "hangdang": "老生"
    },
    {
      "name": "须贾",
      "hangdang": "净"
    }
  ],
  "plot": "战国时魏国范睢随大夫须贾出使齐国，受到齐相礼遇，须贾嫉贤忌能，向魏相魏齐进谗，范睢被魏齐命人狠\n打昏厥。魏齐以为范睢已死，弃之郊外，范睢醒后被秦使王稽载回秦国，改名张禄，秦王任其为相。须贾使\n秦，范睢扮作穷人，去见须贾，适逢大雪，须贾见其寒冷，赠以绨袍，范睢乃恕须贾之罪。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引驺衍同上。"
        },
        {
          "character": "驺衍",
          "type": "引子",
          "text": "偃武修文，保齐王，位列商卿。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "下官驺衍。齐王驾前为臣，官居上大夫之职。只因当年湣王无道，乐毅伐齐， 可恨魏邦不念素日盟好，竟自出兵，暗助乐毅。如今，我国自田法章接任以来， 政事大治，各国皆来修聘，唯有魏国尚未通使。我主已派人催聘，未见回音， 我不免去到朝房，探听消息。 左右！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "打道朝房！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、须贾同上。"
        },
        {
          "character": "须贾",
          "type": "引子",
          "text": "满怀智谋，展雄才，位列朝台。"
        },
        {
          "character": "须贾",
          "type": "念",
          "text": "自从列侯三晋分，脱颖而出立功勋。魏国勤政兵强盛，蒙君器重列群臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "下官，须贾。魏王驾前为臣，官居中大夫之职。只因魏王染病，不能临朝。特 命相国魏齐，代理朝政。前者，齐邦用孙膑之谋，在马陵道射死我国大将庞涓， 为此求和罢兵，留我国公子申在齐为质。昨日，相国魏齐，欲命下官出使齐 邦，一来求放公子申回国，二来还他三年贡物。想我平日口拙辞钝，不善词令， 恐应对有误，误了大事。是我有一舍人，名唤范睢，此人满腹经纶，有谈天 说地之才，若与同行，万无一失。 来！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "有请范先生！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子向内。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请范先生！"
        },
        {
          "character": "范睢",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢上。"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "满腹经纶空怀抱， 何日登云上青霄！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "须大夫！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "范先生请坐。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "有座。唤范睢出来，有何见教？"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "下官奉命出使齐邦，前去修聘，下官口拙辞钝，诚恐应对有失。有心保荐先生， 同使齐邦。故而请范先生前来，同到相府，计议此事，切无推却！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "既承大夫保荐，焉敢推辞，你我就此同至相府，拜谒丞相，也好启行。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "言得极是。来！"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "吩咐备马。"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同下。"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "且喜范叔来应允，"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "赴齐修聘事非轻。"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "还仗高才口悬河，"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "今日方得展经纶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾、范睢同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、魏齐同上。"
        },
        {
          "character": "魏齐",
          "type": "唱",
          "text": "昔与齐邦来争斗， 两国交兵用计谋。 寡众不敌我败走， 魏君至今面带羞。 伤我栋梁庞涓将， 从此后帷幄之中少运筹。"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "本阁，魏齐。辅佐魏王，身为首相。只因魏王染病，命我代理国政。前与齐国 交战，伤我大将庞涓，从此一蹶不振。有意派须贾出使齐国修聘，两国永结和 好。已然奏明魏王，命他即日启程，为何还不见启行？ 左右！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾上。"
        },
        {
          "character": "须贾",
          "type": "念",
          "text": "奉命使齐修聘礼，荐得名士伴我行。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "参见丞相！"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "须大夫少礼，请坐。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "已命大夫前往齐国修聘，为何还不启行？"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "行李已发，启行在即，只因须贾素日口拙辞钝！恐误大事，欲携一辩士同行。 门下有一舍人，名唤范睢，颇有才干，口若悬河，意欲携之同行，特请丞相应 允。"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "此人现在何处？"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "现在门外。"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "既然如此，就请前来相见。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾向内。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "丞相有命，范睢进见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢上。"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "荐贤保国辅政道， 同使齐邦褂紫袍。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "啊范先生，见过丞相！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "是。大梁下士范睢，参见丞相！"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "先生少礼，请坐！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "适才须大夫保举先生大才，此番使齐，倘若求得公子回国，奏明魏王，定加重 用。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "范睢同须大夫出使齐邦，定不辱君王之命。"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "全仗范先生。你二人今日启行便了！"
        },
        {
          "character": "须贾、范睢",
          "type": "同白",
          "text": "遵命。拜别了！"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "奉君命同范叔入齐为使，"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "求公子去修聘自有机宜。"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "满腹中周公礼安邦大志，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾下。"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "学子产展辩智大显才思。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢下。"
        },
        {
          "character": "魏齐",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "魏齐",
          "type": "念",
          "text": "出使去修聘，两国结和平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、驺衍同上。"
        },
        {
          "character": "驺衍",
          "type": "念",
          "text": "七国争强多兵力，偃武修文保临淄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启爷：魏国使臣到。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "魏国使臣到此，吩咐动乐相迎。有请！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是！ 吩咐动乐相迎。有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾、范睢同上。"
        },
        {
          "character": "须贾、范睢",
          "type": "同白",
          "text": "驺大夫！"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "二位大夫请坐！"
        },
        {
          "character": "须贾、范睢",
          "type": "同白",
          "text": "告坐！"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "二位大夫，今有一事不明，意欲请教二公。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "下官乃是正使，大夫有何金言，请讲当面。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "先主在世，与贵国向来和好，后燕国乐毅，与我国交战，贵国不念素日和好， 竟结连乐毅，同攻我国；如今，见我国强盛，又虚言来此修聘，请问大夫，这 信义何在？"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "啊大夫，范睢有几句下言奉告。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "先生有何言语，请讲当面。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "与明君定邦交信义为上， 动干戈背盟约失信我邦， 奈大王丈大国为君骄妄， 约五国共出兵非只我邦。 今大王称英武多收人望， 奉君命修和好来到上邦。 是亲邻为睦邦应多礼让， 却不该因小节失了欢畅。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "范大夫之言令人钦佩，即同入朝，而见我主。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "且慢！只须范大夫一人前去，请须大夫暂在馆驿等候。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "如此，请须大夫在馆驿等候，待我见了齐王，再作道理。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "范大夫请！"
        },
        {
          "character": "驺衍",
          "type": "唱",
          "text": "约同贤士入朝往，"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "范大夫，随我来！"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "自有言语说齐王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驺衍引范睢同下。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "呀呀呸！这老儿只要范睢一人去见齐王，难道我须贾竟不如这门下的舍人不成！ 实实令人难堪！哼！想那范睢，乃是我门下舍人，为我所荐，才得身为副使， 他竟也如此得志高气扬，目中无我，真正得岂有此理！等待归国之后，寻他 一个差错，方叫他知道我须贾得厉害！正是："
        },
        {
          "character": "须贾",
          "type": "念",
          "text": "为人莫心善，无毒不丈夫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、王稽同上。"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "俺，秦国使臣王稽。奉了秦王之命，前往魏国修聘。 人役们！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "须贾、范睢同上。"
        },
        {
          "character": "须贾",
          "type": "念",
          "text": "心中怀怨恨，"
        },
        {
          "character": "范睢",
          "type": "念",
          "text": "修聘转回程。"
        },
        {
          "character": "文堂",
          "type": "内白",
          "text": "驺大夫到！"
        },
        {
          "character": "须贾、范睢",
          "type": "同白",
          "text": "快快有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、二旗牌捧黄金、锦囊引驺衍同上。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "范大夫！"
        },
        {
          "character": "须贾、范睢",
          "type": "同白",
          "text": "驺大夫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驺衍不理须贾，坐。"
        },
        {
          "character": "驺衍",
          "type": "白",
          "text": "我主钦佩范大夫大才，意欲留范大夫在此居官，封为客卿之职，并赐赠薄礼一 份。来来来，请范大夫收纳！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "慢来！范睢随定须贾大夫，出使贵邦，如今修聘已毕，当与须大夫同归，焉能 在此居官，望乞见谅！叩谢大王美意，望驺大夫善为我辞。"
        },
        {
          "character": "驺衍",
          "type": "白",
