      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。四太监、大太监、昭襄王同上。"
        },
        {
          "character": "昭襄王",
          "type": "引子",
          "text": "祖业相承，威震西戎！"
        },
        {
          "character": "昭襄王",
          "type": "念",
          "text": "坐镇关中自为尊，纵横天下扫烟尘。人强马壮兵将勇，赫赫威名震西秦。"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "孤，秦昭襄王在位。自即位以来，朝政内尊母后，外有穰候，并专国政，因此 国威大振。前命使官前往各国修聘，遇有贤能之上相约回朝，共辅朝政。今当 早朝。 内侍，展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 展放龙门哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王稽上。"
        },
        {
          "character": "王稽",
          "type": "念",
          "text": "魏国邀名士，还朝奏君知。"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "王稽见驾，大王千岁！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "卿家平身！"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "卿家此番出使魏邦，可遇贤能之士否？"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "臣出使魏国，途中遇一张禄先生，此人才智，不在范睢之下，颇有治国安邦之 策，臣已将他请来，现在殿下候旨。"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "如此，快快宣他上殿！"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王稽向内。"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "大王有旨，宣张先生上殿！"
        },
        {
          "character": "范睢",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢上。"
        },
        {
          "character": "范睢",
          "type": "念",
          "text": "投秦改名姓，为赚魏邦人。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "臣，外臣下士张禄见驾，大王千岁！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "先生平身。赐坐！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "孤承先王基业，立国西秦，欲继穆公之业，先生何以教寡人？"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "臣闻明君立国，有功者赏，有能者官，功大者禄尊，才高者爵重。今臣不远千 里，投拜王庭，君以臣为有用，请悉臣之说。只是臣昔在魏邦之时，曾闻人言： 秦只知有太后、穰候，而不知有大王，臣如献治秦之策，恐大王亦不能用耳！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "先生若有良策教我，寡人无不行之，愿先生直言无隐。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "闻穰候欲伐齐失计忒甚， 韩和魏与秦邦近在比邻。 愿大王亲楚国严防三晋， 论远交与近攻威震乾坤。"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "噢！"
        },
        {
          "character": "昭襄王",
          "type": "唱",
          "text": "治国安邦多妙论， 先生雄才实堪钦！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "即拜卿家为相，加封应侯，即日秉政，以慰寡心。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "谢大王！臣启大王：臣乃草野下士，乍膺朝政，恐众文武不服。"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "如此，赐卿尚方宝剑，如有不尊钧命者，先斩后奏。领旨下殿！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "献策治安膺王命， 执掌相印保乾坤。 生杀予夺皆我任， 修明朝政强西秦。 强兵秣马军威振， 施仁厚德沐君恩。 远交近攻尊古训， 教化礼仪治万民。 故用张禄为名姓， 欲赚须贾到来临。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢抱剑下。"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "爱卿！"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "恭送相印袍服，即日请张先生秉政。"
        },
        {
          "character": "王稽",
          "type": "白",
          "text": "遵旨，朝事已毕，请驾回宫！"
        },
        {
          "character": "昭襄王",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、昭襄王、王稽自两边分下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、须贾同上。"
        },
        {
          "character": "须贾",
          "type": "念",
          "text": "秦用张禄为首相，欲将军威临魏邦。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "某，须贾。只因昭王薨逝，新君安厘王即位，闻得秦国用新相张禄之谋，要伐 我邦，相国魏齐，畏秦之强，十分忧惧。想那秦相张禄，乃我国人士，岂无乡 土之情，今令我为使，先拜张相，后谒秦王，许以贡纳，免动干戈。 车辆贡物可已齐备？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "须贾",
          "type": "念",
          "text": "但愿不负君王命，求息干戈去西秦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四文堂、四旗牌、中军、范睢同上。"
        },
        {
          "character": "范睢",
          "type": "引子",
          "text": "远交近攻尊古训，隐姓埋名保西秦。"
        },
        {
          "character": "范睢",
          "type": "念",
          "text": "文章盖世未沉沦，一朝得志上青云。为避飞灾更名姓，易名张禄相西秦。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "本阁、张禄。自入西秦，更名张禄，拜为首相，各国都有大夫前来称贺。魏国 必差须贾至此。今日天降大雪，我不免卸了冠带，改扮贫人落魄的样子，去到 宾馆窥探须贾的光景，看他如何待我。 中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "在"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "看贫人衣服！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下，取衣上。范睢换衣。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "中军，你附耳上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢与中军耳语。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "喳……得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四旗牌、中军自两边分下。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "多亏了王稽兄将我救引， 我随他连夜里投奔西秦。 大王他求贤能如渴思饮， 献奇策拜相国扶保秦君。 闻须贾作使臣来到我境， 扮作个落魄人试探故人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "齐使臣、燕使臣、赵使臣、韩使臣同上。"
        },
        {
          "character": "齐使臣",
          "type": "白",
          "text": "列为大人请了！"
        },
        {
          "character": "燕使臣、赵使臣、韩使臣",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "齐使臣",
          "type": "白",
          "text": "秦君新拜张禄为相，我等前去庆贺，就此前往。"
        },
        {
          "character": "齐使臣、燕使臣、赵使臣、韩使臣",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐使臣、燕使臣、赵使臣、韩使臣同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、二旗牌、车夫、须贾同上。"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "奉命出使往西秦， 拜贺新相礼殷勤。 行来又遇风雪紧， 山村楼阁玉装成。 连日趱行入秦境， 见一人冰花满面雪满身。 衣单衫薄身寒冷， 似曾相识曾相逢。 等他前来细相认， 且在路旁看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢扮贫穷人上。"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "可怜我有家难投奔， 困在异乡作流民。 空有文章难济困…… 苍天啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢站在一旁偷看须贾。"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "莫非是范睢来显灵！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "啊呀且住！那雪中站立之人，为何与范睢容貌相似，莫非真是范睢显灵不成！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾急往回走。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "须大夫请了！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "你……真是范睢吗？"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "正是范睢在此。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "打鬼！打鬼！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "你我故友相逢，何言打鬼二字？"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "你已被魏齐打死，怎么今在此处？"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "那日将我弃置荒郊，次日方醒，幸遇一位客商搭救，是我不敢回去，只得逃奔 秦邦，苟延性命。如今落魄此地，举目无亲，近又天降大雪，看看就要冻毙。 幸亏今日遇见大夫，不然范睢险些作了他乡之鬼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范睢拭泪。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "唉！不想你落魄如此！"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "故人落魄心悲痛， 他乡故知倍伤情！ 忙将绨袍来相赠，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾脱斗篷与范睢。"
        },
        {
          "character": "范睢",
          "type": "唱",
          "text": "大夫恩德铭心中。 等待来日登青云， 不忘绨袍一袭恩！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "区区不必挂意。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "如今身体虽暖，奈我今日尚未用饭，腹中甚为饥饿，惭愧！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "你我同车寻一酒馆，沽饮几杯，以消严寒。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "我乃贫寒之人，怎敢与大夫同车。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "这有何妨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾向四文堂、二期牌。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "你等暂回宾馆伺候。"
        },
        {
          "character": "四文堂、二旗牌",
          "type": "同白",
          "text": "是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、二旗牌同下。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "请来上车。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾、范睢同上车。"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "且寻杜康消寒冷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾、范睢同走圆场，至酒肆。"
        },
        {
          "character": "须贾",
          "type": "唱",
          "text": "沽饮三杯好谈心。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "酒家！"
        },
        {
          "character": "酒保",
          "type": "内白",
          "text": "来啦！来啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "念",
          "text": "迎风沽美酒，开坛十里香！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "二位里边请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "须贾、范睢同进门。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "请问二位，用点什么酒啊？"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "好酒取来！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保下，取酒上。"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "唤你再来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保背供。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哎呀且住！看这穷人模样的，长得和我们的新相爷一个模样，莫非他老人家又 出来私访民情啦？我可得小心着点儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保下。"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "啊范先生，今日异地重逢，聊叙故旧之情。下官昔有得罪之处，尚祈海涵！"
        },
        {
          "character": "范睢",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "须贾",
          "type": "白",
          "text": "秦王新拜张禄为相，我奉大王之命，前来拜贺，近闻秦欲兴兵伐魏，想秦魏两 国，素称和好，倘若争斗起来，生灵就要惨遭涂炭，故而临行之时，大王命我 先见新相一面，晓以道义，永结和好，使两国的百姓免受刀兵之苦！"
        },
        {
          "character": "范睢",
