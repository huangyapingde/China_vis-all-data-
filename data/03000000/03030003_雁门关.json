    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "孟金榜",
      "hangdang": "旦"
    },
    {
      "name": "蔡秀英",
      "hangdang": "旦"
    }
  ],
  "plot": "萧太后知令箭被杨延顺带过宋营，欲将青莲公主斩首，铁莲、碧莲二公主上前求情，方准戴罪立功。青莲、\n碧莲同至宋营搦战，企图伺机将杨延顺擒回。佘太君知青莲、碧莲公主皆为子媳之辈，遂命蔡秀英、孟金榜\n迎敌，并嘱其不准伤害青莲、碧莲。双方交兵，二公主中绊马索均被擒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四马夫、耶律休哥同上。"
        },
        {
          "character": "耶律休哥",
          "type": "点绛唇",
          "text": "将士英豪，儿郎虎豹，军威浩，杀气冲霄，要把大宋扫！"
        },
        {
          "character": "耶律休哥",
          "type": "念",
          "text": "韬略军营帐，雄师振朔方。戎马翻风起，南渡万里江。"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "某，耶律休哥。北国为臣，官拜平章大元帅。奉太后旨意，镇守黑水河。闻听 宋兵北伐，本要发兵迎敌，只是未奉旨意，不敢擅离汛地。也曾命人前去打探， 未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：韩驸马到。"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。韩昌上"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "驸马到此，有何军务？"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "只因宋兵征伐我邦，被本宫围困，不想被驸马王司徒诓去令箭，那佘氏婆子命 杨家一干女将杀进雁门关，本宫败阵至此，望乞元帅发兵救应！"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "本帅早就有意发兵，只是未奉太后旨意，不敢擅离汛地。既是驸马亲身到此， 即刻发兵前去。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "那杨家女将武艺高强，必要多带人马，挑选名将，方可抵御！"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "本帅前番收来二将：一名张猛，一名谢苗，武艺高强。命他二人同行，驸马意 下如何？"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "既然有此好将，传来本宫一见。"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "来，传谢苗、张猛进帐！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "传谢苗、张猛进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谢苗、张猛同上。"
        },
        {
          "character": "谢苗",
          "type": "念",
          "text": "宝剑霜锋气概雄，旌旗高卷海天宫。"
        },
        {
          "character": "张猛",
          "type": "念",
          "text": "一声长啸山河动，云鸟飞腾紫雾中！"
        },
        {
          "character": "谢苗",
          "type": "白",
          "text": "元帅传唤，你我一同进帐。"
        },
        {
          "character": "张猛",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "谢苗、张猛",
          "type": "同白",
          "text": "元帅在上，末将打躬！"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "罢了，见过驸马！ 中国京剧戏考 《雁门关》【三本】 2"
        },
        {
          "character": "谢苗、张猛",
          "type": "同白",
          "text": "驸马千岁！"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "站下。"
        },
        {
          "character": "谢苗、张猛",
          "type": "同白",
          "text": "啊！传唤末将，有何差遣？"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "驸马前来调兵，你二人可能杀退杨家女将？"
        },
        {
          "character": "谢苗、张猛",
          "type": "同白",
          "text": "我二人蒙元帅提拔，当效犬马之劳，以报国恩！"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "凭何谋略？"
        },
        {
          "character": "谢苗",
          "type": "白",
          "text": "末将拳打猛虎，力敌万人。能使一把三股钢叉，百步之外，能取上将首级也。"
        },
        {
          "character": "谢苗",
          "type": "唱",
          "text": "蒙元帅提拔我感戴高恩， 生衔环死结草正当出征； 论英武凭谋略胜似韩信， 在宝帐效廉颇志气凌云。"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "张猛有何武艺？"
        },
        {
          "character": "张猛",
          "type": "白",
          "text": "末将蒙海外异人传授，赠我葫芦一个，若遇敌人交战，将葫芦祭起，现出神兵， 临阵斩将，犹如反掌也！"
        },
        {
          "character": "张猛",
          "type": "唱",
          "text": "两军阵遇敌将各显本领， 葫芦内放神兵鬼怕神惊； 任他是汉武侯能摆八阵， 我学那黄承彦指路将星。"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "驸马心意如何？"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "只要二将杀退宋兵，乃国家之幸也。就请元帅传令发兵！"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "遵命。 巴图鲁！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延辉上。"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "宋王有道坐汴梁， 老母领兵到番邦。 我在北国十二载， 珠泪滚滚想亲娘。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "本宫，杨延辉。昔年在金沙滩被擒，是我改名木易光，蒙太后洪恩，将碧莲公 主招赘于我；八弟匹配青莲公主。昨日闻报，韩昌败阵而回；我母亲来到雁门， 我有意与八弟商议，同往宋营见母一面。咳！怎奈太后有旨，驸马大臣除了 朝房金殿，不准同在一处。眼见得母子不能相会了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "念",
          "text": "侍奉金枝客，常伴玉叶人。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启禀驸马爷：今有青莲公主失掉令箭，太后将她押上金殿去了。铁莲公主有帖 请碧莲公主一同上殿保奏。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "起过了。 呜呼呀！想那金批令箭，乃军中斩杀之要物，怎能失掉？嗯！待我问个明白。 我且问你，你可知道那王驸马在与不在？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "大概王驸马不在宫中。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "有请公主。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有请公主！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主上。"
        },
        {
          "character": "碧莲公主",
          "type": "唱",
          "text": "寒梅开放绣房香， 野鸟枝头带冰霜。 中国京剧戏考 《雁门关》【三本】 3 春风未到芙蓉帐， 面对菱花巧梳妆。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "公主来了，请坐！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "驸马呼唤咱家，有什么事呀？"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "只因青莲公主失落太后的金批令箭，已将她押上金殿。铁莲公主有帖前来，请 公主入朝，一同保奏。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "哎呦！令箭乃是军中的号令，怎么会失掉了呢？咳！好不小心哪！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "公主与她有姊妹之情，就该上殿保奏！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "待咱家上殿走走。 来呀！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "带路！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": "碧莲公主",
          "type": "唱",
          "text": "连环玉佩叮当响， 每日随朝带御香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监、碧莲公主同下。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哎呀且住！青莲公主失掉了令箭，八弟又为何不在宫中呢？哦哦是了，想是八 弟瞒过公主，盗了令箭，混出雁门关去了，咳！八弟呀八弟，你只顾母子、夫 妻相会，却害了青莲公主和一双儿女，作那刀头之鬼矣！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "杀身难报父母养， 夫妻同林鸟一双。 大限来时各自丧，"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "八弟呀！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "因何做事欠思量！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "想我在北番一十二载，招赘碧莲公主，所生两个孩儿，怎能回转天朝？也罢！ 不免上殿打听青莲公主的吉凶如何也！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "为人若照常情讲， 忠孝二字理所当。 可怜却是青莲女， 只怕难免刀下亡。 急忙且把金殿上， 假装痴迷问端详！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延辉下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、四宫女引萧太后同上。"
        },
        {
          "character": "萧太后",
          "type": "唱",
          "text": "忆昔当年沙滩上， 杀得杨家众逃亡。 可叹老王把命丧， 哀家只得掌家邦。 马放南山同安享， 刀枪入库乐无疆。 年年宫中把宴尝， 军兵欢欣乐安康。 今有大宋兴兵将， 要与我国动刀枪。 等候令箭调兵将， 本后出师扫宋邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有宋将拿了太后的令箭，诈开关口，杀进雁门，将把关将官杀死，韩驸马兵 败，那杨家女将离都城不远。 中国京剧戏考 《雁门关》【三本】 4"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "怎么着，宋将拿了我的令箭杀进雁门关来了吗？ 哎呀且住！令箭在公主府中，怎么会落在宋将之手哪？其中必有缘故。 吩咐我国人马好好保护城池，快去！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "来，将青莲公主押上殿来！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵同下，押青莲公主同上。"
        },
        {
          "character": "青莲公主",
          "type": "唱",
          "text": "驸马诓令出关往， 满心忧悸意彷徨。 太后宣我把殿上， 假意装作不知详。"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "孩儿见驾，母后千岁！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "你把令箭快快交来，我即刻就要发兵啦！"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "哎呀母后哇！儿将令箭收藏好了，不知被何人盗去，母后做主。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "既是被人盗去，怎么又落在宋将之手，诈进雁门关，杀败我国的兵将呢？"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "此事孩儿一概不知。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "唗！好奴才！"
        },
        {
          "character": "萧太后",
          "type": "唱",
          "text": "父亡母寡将儿养， 暗使毒计诓为娘！ 自古一令传千将， 为何失落在宋邦？"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "喂呀母后哇！"
        },
        {
          "character": "青莲公主",
          "type": "唱",
          "text": "母后懿旨谁敢抗？ 令箭不知落何方。 哀告母后龙心放，"
        },
        {
          "character": "青莲公主",
          "type": "白",
          "text": "喂呀母后啊！"
        },
        {
          "character": "青莲公主",
          "type": "唱",
          "text": "望求母后作商量。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启奏太后：奴才打听明白，奉令出关之人，乃是王司徒王驸马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青莲公主惊。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "啊！难道说王驸马他降了宋朝了吗？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "他不叫王司徒，他是南朝的杨八郎杨延顺，改名王司徒。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "再去打探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "大胆的奴才，既知道他是杨八郎，就该禀知为娘；谁知你反在我跟前，千方百 计诓去令箭。咳！丫头，你你你该当何罪呀！"
        },
        {
          "character": "萧太后",
          "type": "唱",
