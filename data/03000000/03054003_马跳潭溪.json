        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "听一言来吃一惊， 好叫赵云难解情。 为何到此无踪影？ 众军与爷四下寻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四下手、四将官、蔡瑁同上同下。四文堂、四上手同找寻。"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "并无踪影。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "众将官，蔡瑁哪里去了？"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "已然进城。"
        },
        {
          "character": "赵云",
