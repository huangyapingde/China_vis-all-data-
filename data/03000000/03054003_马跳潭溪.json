{
  "script_id": "03054003",
  "title": "马跳潭溪",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "刘表",
      "hangdang": "老生"
    },
    {
      "name": "蔡瑁",
      "hangdang": "净"
    },
    {
      "name": "蔡氏",
      "hangdang": "旦"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    }
  ],
  "plot": "蔡氏权重，拟立己子刘琮，废长子刘琦。刘表患之，请教刘备。刘备居馆驿，蔡瑁谋袭，经伊籍报信，刘备\n星夜奔新野。蔡瑁假托庆功，再邀刘备宴襄阳，筵前行刺未果。刘备伺机入厕，急出西门，马跳潭溪，幸免\n于难。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "光阴似箭催得紧， 分别不觉整一春。 玄德每日自思论， 只愁汉业一旦倾。 刘备但得一步稳， 必整汉室锦乾坤。 怎能除却曹奸佞， 玄德才称智谋人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家将同上。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "启主公：荆州有书信前来，主公请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将甲呈书。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宗兄有书信到来，待我拆开观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备看书。〖牌子〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，原来宗兄请我议事。 来，对下书人言讲，说我随后就到。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将甲下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，带马伺候！"
        },
        {
          "character": "家将乙",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将乙带马。家将甲上。"
        },
        {
          "character": "家将甲",
          "type": "白",
          "text": "启主公：小人吩咐下书人回往荆州去了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好，荆州去者！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "宗兄来了书和信， 必有军务大事情。 家将与爷带能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上马。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "去往荆州走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、二家将同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引刘表同上。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "且喜干戈得宁静， 难解心中肺腑情。 命人去把玄德请， 心腹之事对他明。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启主公：刘使君到。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "听说玄德到来临， 急忙出府来接迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家将引刘备同上，二家将同下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊宗兄！一向可好？"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "有劳承问！贤弟请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘表、刘备",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "弟兄挽手府门进，"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "许久未见兄挂心。 人来将宴来摆定！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监摆酒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "弟又要叨扰了哇，哈哈哈……"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟说远了，哈哈哈……贤弟请哪！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "兄长请！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "待兄亲自把酒斟。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "弟不敢当了，哈哈哈……"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟请！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "手擎酒杯把话论， 说与贤弟智谋人： 去岁劝孤攻许郡， 曹操不在去破城。 金石良言孤未允， 失却机会难再寻。 袁绍被曹遭灭尽， 招降数万精壮兵。 青、冀、幽、兖俱归顺， 班师回郡显奇能。 又差曹仁把兵领， 命他前来镇樊城。 眼看荆州被吞并， 请弟商量怎样行。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "机会错过休再等， 迟早不同自有因。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘表哭。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "兄长如何这光景， 为难之事向弟云。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "贤弟既然再三问， 且听愚兄细言明： 荆妻陈氏早丧命， 至今留下一条根。 长子刘琦过柔性， 办理国事非贤能。 自从续娶你蔡氏嫂， 所生刘琮有雄心。 看他行事颇聪敏， 说出言语甚中听。 意欲立他秉国政， 又怕群臣心不平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡氏暗上，偷听。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "欲待立长按本礼， 内有事情颇难心。 将佐兵丁甚齐整， 执掌都是蔡家人。 掌管军务权衡重， 要想削除万不能！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘表哭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "兄长，自古废长立幼乃取乱之道。若忧蔡氏权重，可削除之。不可溺爱幼子而 废长也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘表沉吟。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备哭。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "贤弟呀！"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "谁废谁主心不定， 不能取决故伤心。 贤弟因何珠泪滚， 请对为兄细说明。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "兄长既要听其情， 且听愚弟讲分明： 心中不爽添忧闷， 只为汉业一旦倾。 何时除却贼奸佞， 何人整理汉江洪。 刘备不觉白双鬓， 老将至矣功未成。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "贤弟当初多侥幸， 你在许昌兄知闻。 青梅煮酒英雄论， 言语到今记得真。 能大能小亦能隐， 须要等待时机临。 此时求得身安稳， 纵横四海显奇能。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "那曹操昔年青梅煮酒论英雄时，曾问贤弟：“猜一猜天下英雄是谁？”贤弟答 言：“淮南袁术。”曹操说：“他乃塜中枯骨。”弟又言：“河北袁绍。”曹 操说：“色厉胆薄，好谋寡断，干大事而惜身，见小利而忘命，非英雄也！” 弟乃又问：“愚兄刘表，江东孙伯符，益州刘季玉，张绣、张鲁、韩遂等如何？ ”曹操彼时言到：“这些人皆算不了英雄。今天下之英雄，惟使君与操耳。” 以曹操之权力，犹不敢居贤弟之先，何愁功业不建乎！哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宗兄，恨小弟如今无栖身之地。若有基业，天下碌碌之辈，诚不足虑也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "君子之心能容忍， 大丈夫能屈也能伸。 小弟若能有天运， 立志整理旧乾坤。 现无居址空亡奔， 碌碌庸庸暂寄身。 龙逢浅水遭了困， 虎落平川怎能行！ 有朝一日春雷震， 轰轰烈烈显威名。"
        },
        {
          "character": "刘表",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "言多语失不敢论， 默默无闻自思忖。 告辞回馆弟安寝，"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "兄送贤弟到府门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡氏暗下。二家将同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "告辞兄长跨鞍镫， 不觉红日向西沉。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家将同下，刘备下。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "天下英雄属使君， 不禁腹内暗沉吟。 骨肉相逢谈不尽， 怎叫寰宇不三分？ 将身且把内室进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫娥引蔡氏自下场门同上。"
        },
        {
          "character": "蔡氏",
          "type": "唱",
          "text": "急忙向前笑相迎。 主公请坐同坐定， 有语开言禀府君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡氏怒。"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "主君，我想皇叔不过汉室宗支。自他进荆州以来，何相待如同骨肉一般！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "常人言，他的仁义过天，四海闻名。适才妾在屏风后面听了半晌，原来传言失 真。对主公不思感恩报德，反讲大话压人！"
        },
        {
          "character": "蔡氏",
          "type": "唱",
          "text": "带笑开言尊主君， 妾身拙言听分明： 当言不言缺恩爱， 没了你我夫妻情。 你待皇叔情意重， 可惜辜负一片心。 说什么他乃同宗姓， 同宗共祖一脉亲。 方才狂语欺太甚， 只知有己目无人。 要对旁人还可论， 不该在荆州乱胡云。 英雄之气他怎称？ 未必他心似我心。 相劝主公细思忖， 莫把皇叔当好人。 若不早把注意定， 将来为患定非轻！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "唉，这是哪里说起！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘表摇头怒，急下。"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "蔡氏",
          "type": "唱",
          "text": "越思越想越难忍，"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "蔡氏",
          "type": "唱",
          "text": "快请蔡瑁进内厅！"
        },
        {
          "character": "二宫娥",
          "type": "同白",
          "text": "有请蔡都督！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡瑁上。"
        },
        {
          "character": "蔡瑁",
          "type": "念",
          "text": "要去心头恨，拔却眼中钉。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "啊贤妹！"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "兄长请坐！"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "告坐。贤妹唤兄前来，有何事议？"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "我想刘备虽然镇守新野，此人奸诈太甚，若不早除，将来荆州九郡付与他人。 刘备现在馆驿，不如及早害了刘备，荆襄可保。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "待我暗派五百精壮兵丁，今夜围困馆驿，哪怕刘备飞上天去！"
        },
        {
          "character": "蔡氏",
          "type": "白",
          "text": "只要急速行事！"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "蔡氏",
          "type": "念",
          "text": "兄妹定下牢笼计，"
        },
        {
          "character": "蔡瑁",
          "type": "念",
          "text": "刘备难逃掌握中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡氏、蔡瑁同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内二黄导板",
          "text": "馆驿中打罢了初更十分，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家将引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "因何故心不安坐卧不宁？ 白昼间言语失自悔自恨， 酒醉后透露了腹内真情。 想必是宗兄他心中怀恨， 怕的是那蔡氏暗中窃听。 刘景升若听信蔡氏讲论， 嫉妒妇搬是非波浪自生。 秉灯烛心烦闷难以安寝， 到天明别宗兄急早登程。"
        },
        {
          "character": "伊籍",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伊籍上。"
        },
        {
          "character": "伊籍",
          "type": "唱",
          "text": "适才间众兵丁纷纷议论， 那蔡瑁设巧计起下毒心。 急忙忙到馆驿前来送信， 泄机关早叫那玄德逃生。"
        },
        {
          "character": "伊籍",
          "type": "白",
          "text": "皇叔，快些开门来！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "耳听得有人声将门叩定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备开门，看。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "原来是伊先生大驾光临。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，伊先生，夤夜来至馆驿何事？"
        },
        {
          "character": "伊籍",
          "type": "白",
          "text": "哎呀皇叔啊，大事不好了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "伊籍",
          "type": "白",
          "text": "今有蔡瑁派兵五百，来围馆驿，欲害皇叔。是我夤夜前来送信。皇叔急速起身； 若是迟慢，大祸临身！"
        },
        {
          "character": "刘备",
          "type": "白",
