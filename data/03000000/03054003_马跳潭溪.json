    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备骑马上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "锤下险些遭不幸， 多亏伊籍泄牢笼。 三弟劝孤孤不信， 幸有四弟赵子龙。 勒住丝缰来观定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "一道大溪横路中。 宽有半箭水势涌， 波浪滚滚甚是凶。 襄阳会上逃出命， 苍天哪！ 莫非溪水送了终？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊呀且住！无有摆渡船只，又无桥梁可过，俺意欲涉水而过，不知水的深浅？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊杀声。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，看城内尘土飞空，无数追兵，看看追上。哎呀，此乃是天绝我也！天哪！ 苍天！我刘备倘能日后恢复旧业，重整江山，今日马跳潭溪，逃命过去；不 然只有死在水中，焉肯落在贼人之手也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "此时叫我心忙乱， 好似钢刀把心穿。 溪河水势多凶险， 令人一见心胆寒。 襄阳邀请来赴宴， 谁知设下巧机关。 只望同心共扶汉， 心如日月义同天。 越思越想心好惨， 活活拆散我桃园。 纵马下溪催走战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备三打马。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "波浪滔滔往上翻。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，果应伊籍所说，此马妨主，此马不可骑也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "此话今日方应验， 只恐性命难保全。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备三打马。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "马跳潭溪身纵起， 恰似云雾一样般。 飞身一纵过西岸，"
        },
        {
          "character": "刘备",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "跳过了潭溪回头观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四下手、四将官、蔡瑁同上。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "啊使君，请公作陪，抚慰群臣，何故逃席而去？岂不辜负我主公待公一片好心！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "将军哪！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "蔡将军不必假殷勤， 你自己做事自己明。 我与你无仇又无恨， 两次三番害我身。 你主待我多亲近， 刘备并无生异心。 还望将军细思忖， 谁是谁非谁不仁？ 不是逃席是逃命， 险些溪内丧残生。 请回不必多言论， 他年相逢再补情。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备失陪了哇，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "蔡瑁",
          "type": "唱",
          "text": "只见刘备他逃命， 众将拨马进西门。 本督马上传将令， 回转城中捉赵云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
