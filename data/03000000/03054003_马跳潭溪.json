        {
          "character": "刘表",
          "type": "白",
          "text": "都督有何军情议论？"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "启主公：刘备有叛乱之意。在馆驿墙壁之上题了反诗四句，不辞而去！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "孤王不信。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "主公不信，即请主公亲到馆驿观看，便知真假。"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "好，孤亲去观看。 内侍摆驾，馆驿去者！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场，同进馆驿。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "墙上现有诗句，主公请看！"
        },
        {
          "character": "刘表",
          "type": "白",
          "text": "待孤看来。唔呼呀！"
        },
        {
          "character": "刘表",
          "type": "念",
          "text": "“数年徒守困，空对旧山川。龙岂池中物，乘雷欲上天！”"
