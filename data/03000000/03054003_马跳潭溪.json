        {
          "character": null,
          "type": "stage",
          "text": "四将官同一翻、两翻。"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "并无刘备。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "起过了。 啊！想必走漏风声，连夜逃出城去。也罢！待我替他墙上写反诗一首。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡瑁写诗。〖牌子〗。"
