        {
          "character": "刘表",
          "type": "唱",
          "text": "离间之计久自明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡瑁上。"
        },
        {
          "character": "蔡瑁",
          "type": "唱",
          "text": "昨夜与妹把计定， 今日早朝奏主君。"
