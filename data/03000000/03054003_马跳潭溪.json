    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引刘表同上。"
        },
        {
          "character": "刘表",
          "type": "唱",
          "text": "孤王有道荆州掌， 民安国泰乐安康。 扫灭二贼凯歌唱， 全仗桃园刘、关、张。 何惧孙曹齐反上， 怎当荆襄水军强。 桃园威镇多兴旺， 张鲁怎敢犯边疆！ 玄德足智韬略广， 子龙、关、张威名扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手、四将官引蔡瑁同上。"
        },
        {
          "character": "蔡瑁",
          "type": "唱",
          "text": "玄德逃出天罗网， 纵放猛虎上山岗。"
        },
        {
          "character": "蔡瑁",
          "type": "白",
          "text": "参见主公！"
