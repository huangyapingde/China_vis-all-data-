          "type": "stage",
          "text": "刘备下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场设城门。二兵丁同上，刘备上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "刘备逃出天罗网， 犹如蛟龙下长江。 催马且把西门闯，"
        },
        {
          "character": "二兵丁",
          "type": "同白",
          "text": "玄德公，要往哪里去？"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "并不答言抖丝缰。"
        },
        {
          "character": null,
