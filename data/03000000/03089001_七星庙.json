{
  "script_id": "03089001",
  "title": "七星庙",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "佘赛花",
      "hangdang": "旦"
    },
    {
      "name": "杨继业",
      "hangdang": "小生"
    }
  ],
  "plot": "杨继业与佘赛花交战，败于佘赛花，逃至七星庙内。佘赛花赶至，二人相互爱慕，结为夫妇。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。女马童上，备马。"
        },
        {
          "character": "女马童",
          "type": "白",
          "text": "请姑娘上马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘赛花上，起霸。四文堂、四女兵同上。"
        },
        {
          "character": "佘赛花",
          "type": "西皮导板",
          "text": "我翻身跨上桃花马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女马童带马，佘赛花上马。"
        },
        {
          "character": "佘赛花",
          "type": "西皮摇板",
          "text": "佘塘关来了我佘赛花。 心中恼恨杨家将， 不该把我兄长杀。 父王帐中令传下， 倒教奴家怒气发。 扣定玲珑锦战甲， 梨花银枪手中拿。 叫三军与我把关下！"
        },
        {
          "character": "四文堂、四女兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四女兵同下。"
        },
        {
          "character": "佘赛花",
          "type": "西皮摇板",
          "text": "要与那杨家将动杀法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女马童、佘赛花同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手引杨继业同上。"
        },
        {
          "character": "杨继业",
          "type": "西皮流水板",
          "text": "两国不和把仗打， —来一往动厮杀。 将身且坐营盘下， 再听探马报根芽。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "佘赛花讨战！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "带爷的枪马！"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "人来带过少爷的马， 阵前去会佘赛花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘赛花、四文堂、四女兵、女马童同上，打过合。"
        },
        {
          "character": "佘赛花",
          "type": "西皮摇板",
          "text": "阵前来了杨家将， 不由奴家怒胸膛。 提枪拍马往前闯， 少时教你无下场。 （佘赛花、四文堂、四女兵、女马童、杨继业、四文堂、四上手同钻烟筒下，杨继业、佘赛花同上，同起打， 杨继业败下，佘赛花追下。杨继业上。）"
        },
        {
          "character": "杨继业败下，佘赛花耍枪花下。四上手、四女兵同上，同起打，双下。杨继业败上，佘赛花追上，同起打、杨继业",
          "type": "白",
          "text": "且住！看这个丫头杀法厉害，杀得我上天无路，入地无门，这便如何是好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业看。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "七星庙，七星庙！来此已是七星庙，待我下马进庙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下马，进庙。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "待我将门闭上，在此处躲避一时，再作道理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘赛花上。"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "啊！适才与杨家小将交战，被奴将他杀得大败，他在前面跑，奴在后面赶，来 在此地，为何不见？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘赛花看。"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "七星庙，七星庙！想是他在庙中藏躲，看他将庙门关闭，这便怎么处？待奴喊 叫一声。 呔！杨家小将听着：你家姑娘在此等候，你快开庙门，与姑娘再战三合！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这个丫头，她竟自赶来了！她叫我开门与她再战。 你家少爷在庙内安身，任凭你这丫头说得天花乱坠，你少爷就是不开门的了！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "看他执意不肯开门，这便如何是好？哦哦有啦，待我吓他一吓。 杨家小将，你隐藏庙内，不肯开门，待奴吩咐三军，将庙墙团团围住，四面放 起火来，将庙宇烧坏，管叫你死无葬身之地！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀，这个丫头言道：吩咐三军，将庙宇烧坏，要叫我死无葬身之地，这便怎 好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业跪拜。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "望求神圣保佑，望求神圣保佑！ 呔，佘赛花丫头，既叫你少爷开门，你少爷敢开庙门，只怕你不敢下马！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "你既敢开庙门，你姑娘就敢下马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业跪拜。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "望求神圣多多保佑！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "你姑娘下马来了！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "待我与你开门！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "你开来！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业开门，佘赛花执枪刺杨继业，杨继业夺枪，绑佘赛花跪地。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "我看你这丫头，还往哪里走！待我将她的战马，牵进庙来，将庙门关闭了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业拴马。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "好杀呀好杀！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "好战哪好战！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "好跑哇好跑！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "好赶哪好赶！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "赶的你家少爷是燕儿不下蛋。"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "赶的你姑娘是一身的透汗。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你这丫头，实实的好狠心哪！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "你的心肠也就不软！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "怎见得你少爷心狠？"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "你为何将奴家兄长杀死？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你就不该赖了我的亲事！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "那是我爹爹做主，与奴什么相干？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你倒推得干净！今日你既被擒，我且问你：你是愿意一死，还是愿意一活？"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "死是怎样讲，活是怎么说？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你要是愿意死呀，我就是这一枪，将你刺死！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "这一活呢？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这一活么？来来来，你就与我成亲事、拜天地！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "我呀，我愿意一死！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这个丫头她愿意一死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业提枪。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "来，你看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘赛花闪开。"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "慢来！我愿意一活。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你愿意一活？好好好，来来来，拜天地吧！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "你看世界之上，哪有捆着绑着拜天地的？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你是想叫我与你松绑啊？"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "那是自然。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "我要与你松了绑，怕你一时反悔，你须要与我对天盟誓！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "我一生一世，就是不会盟誓。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你既不会盟誓，你还是与我一死吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业倒提枪。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "来，看枪！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "我盟誓，我盟誓！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你不要害怕，你看这是枪把，枪头儿在这一头儿呢。你与我盟誓吧！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "皇天在上，我佘赛花在下，我今与小将成亲，若有三心二意，天厌之，天厌之！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "什么叫做“添胭脂”？你还要添粉不成？"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "此乃是个咒语。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这是一句咒语！待我与你松绑。"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "你看今日在庙内，你我夫妻何处安身？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这有何难？你我就将马褥子拿下来，铺在殿内，就此成亲便了。你我来呀！ （佘赛花欲拔剑砍杨继业，杨继业退。小过门。杨继业比手势要佘赛花拜天地，佘赛花羞，宝剑入鞘。杨继 业暗拔佘赛花宝剑，以剑砍佘赛花，佘赛花急拔剑，见剑被杨继业拔去，向杨继业讨剑，杨继业比手势要佘 赛花拜天地。）"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你我就此一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘赛花、杨继业同拜。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "二人庙内双跪定，"
        },
        {
          "character": "佘赛花",
          "type": "西皮摇板",
          "text": "夫妻双双把亲成。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "先拜天地与神灵，"
        },
        {
          "character": "佘赛花",
          "type": "西皮摇板",
          "text": "然后夫妻把礼行。"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "在庙中成就了婚姻事，"
        },
        {
          "character": "佘赛花",
          "type": "西皮摇板",
          "text": "倒凤颠鸾叙恩情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四女兵同上，双过合，同下。"
        },
        {
          "character": "杨继业",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "杨继业",
          "type": "西皮摇板",
          "text": "良缘今日得配定，"
        },
        {
          "character": "佘赛花",
          "type": "西皮摇板",
          "text": "一同上马住了刀兵。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "你我就此回营！"
        },
        {
          "character": "佘赛花",
          "type": "白",
          "text": "将军一同进关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四女兵自两边分上。"
        },
        {
          "character": "杨继业、佘赛花",
          "type": "同白",
          "text": "众将官！"
        },
        {
          "character": "四上手、四女兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "杨继业、佘赛花",
          "type": "同白",
          "text": "带马回关！"
        },
        {
          "character": "四上手、四女兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}