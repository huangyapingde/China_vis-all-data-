{
  "script_id": "03109004",
  "title": "贺后骂殿",
  "alias": [
    "烛影计"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵匡义",
      "hangdang": "老生"
    },
    {
      "name": "贺后",
      "hangdang": "旦"
    },
    {
      "name": "赵匡胤",
      "hangdang": "老生"
    },
    {
      "name": "赵德昭",
      "hangdang": "小生"
    },
    {
      "name": "赵德芳",
      "hangdang": "小生"
    },
    {
      "name": "潘洪",
      "hangdang": "净"
    },
    {
      "name": "赵普",
      "hangdang": "老生"
    },
    {
      "name": "苗宗善",
      "hangdang": "丑"
    },
    {
      "name": "曹彬",
      "hangdang": "老生"
    },
    {
      "name": "杨继业",
      "hangdang": "老生"
    }
  ],
  "plot": "赵匡胤死，其弟赵匡义接帝位。贺后以赵匡胤死因不明，使太子赵德昭上殿质问。赵匡义大怒，欲斩赵德昭，\n赵德昭撞死于金殿之上。贺后携二子赵德芳上殿，列举历朝乱臣贼子之罪，以数赵匡义之过。赵匡义谢罪，\n赐贺后尚方剑，改昭阳院为养老宫，为太后居之。并加封赵德芳为八贤王，赐凹面金锏，可上打昏君，下\n打谗臣。至此，贺后只得忍痛回宫。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、二太监引赵匡义同上。"
        },
        {
          "character": "赵匡义",
          "type": "引子",
          "text": "江山归大宋，成一统，盛世兴隆！"
        },
        {
          "character": "赵匡义",
          "type": "念",
          "text": "朱、李、刘、石、郭，梁、唐、晋、汉、周。算来多少载，播乱几春秋。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "本爵，赵匡义。乃大宋武德皇帝之弟。蒙兄王宠爱，封为晋王。只因当年，母 后晏驾之时，有言在先：日后兄皇宾天，由我执掌江山。现今，兄皇龙体有恙， 十分沉重。忽然传旨：将长子德昭，立为东宫。难道母后临终之言，就罢了 不成！为此，邀请心腹大臣，共议此事。 左右！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘强、潘豹同上。"
        },
        {
          "character": "潘强",
          "type": "念",
          "text": "百官俱请到，"
        },
        {
          "character": "潘豹",
          "type": "念",
          "text": "归来报晋王。"
        },
        {
          "character": "潘强、潘豹",
          "type": "同白",
          "text": "启禀千岁：众位大人到！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "命他们进见！"
        },
        {
          "character": "潘强、潘豹",
          "type": "同白",
          "text": "众位大人进见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘洪、赵普、苗宗善、曹彬同上。"
        },
        {
          "character": "潘洪、赵普、苗宗善、曹彬",
          "type": "同白",
          "text": "千岁！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "列位大人请坐！"
        },
        {
          "character": "潘洪、赵普、苗宗善、曹彬",
          "type": "同白",
          "text": "谢坐！千岁相召，不知有何钧谕？"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "两厢退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监、四龙套同下。"
        },
        {
          "character": "潘洪、赵普、苗宗善、曹彬",
          "type": "同白",
          "text": "千岁相召，有何密议？"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "只因当年母后晏驾之时，也曾留有遗言：兄皇宾天，命我执掌宋室江山。如今 兄皇又立东宫，不知是何主见？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "老臣亦是不解！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "千岁，可记得当年箭射花蕊夫人的事么？"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "这个……唉！"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "潘洪一言来提醒， 箭射花蕊结冤情。 眼见江山难坐稳，"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "众卿！"
        },
        {
          "character": "赵匡义",
          "type": "西皮摇板",
          "text": "大事全仗众贤卿！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "箭射花蕊，是孤之过。今日之事，众卿何以助我？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "千岁，那杨广弑父，骨肉冤仇，古已有之。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "卿家差矣！孤若行此，岂非被朝野唾骂！"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "想千岁与万岁，乃是手足兄弟，就该进宫探视，见机而行。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "如此，卿等暂退，明日再议。"
        },
        {
          "character": "潘洪、赵普、苗宗善、曹彬",
          "type": "同白",
          "text": "臣等告退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘洪、赵普、苗宗善、曹彬同下。二太监同暗上。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "带马进宫！"
        },
        {
          "character": "二太监",
          "type": "同白",
          "text": "喳！"
        },
        {
          "character": "赵匡义",
          "type": "西皮原板",
          "text": "盛衰成败有天运， 从来半点不由人。 此番进宫去探病， 兄皇驾前见机行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监引赵匡义同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引贺后同上。"
        },
        {
          "character": "贺后",
          "type": "西皮原板",
          "text": "武德君坐江山哪得安静， 十八载又何曾乐享太平。 到如今卧龙床身染重病， 暗地里告苍天保佑安宁！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "哀家贺后。只因万岁身得背疮之病，已卧病多日。当年，陈抟先生曾留下丹药 三付。现存一付，已命两个皇儿前去煎煮。但愿服下此药，圣体早日痊愈。为 何尚未见皇儿到来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德昭、赵德芳同上。"
        },
        {
          "character": "赵德昭",
          "type": "西皮摇板",
          "text": "只因父王身染病， 丹药煎好进宫廷。"
        },
        {
          "character": "赵德昭、赵德芳",
          "type": "同白",
          "text": "母后千岁！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "我儿平身！丹药可曾煎好？"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "已然煎好。母后请看！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "将丹药放下，皇儿等暂退！"
        },
        {
          "character": "赵德昭、赵德芳",
          "type": "同白",
          "text": "遵旨！"
        },
        {
          "character": "赵德昭",
          "type": "西皮摇板",
          "text": "但愿父王身安稳，"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "满斗焚香谢神灵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德昭、赵德芳同下。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "宫娥，随我进宫！"
        },
        {
          "character": "四宫娥",
          "type": "同白",
          "text": "是！"
        },
        {
          "character": "贺后",
          "type": "西皮摇板",
          "text": "手捧汤药把宫进， 但愿早日除病根。 龙体康复身安稳， 清香万炷谢神灵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后捧药下，四宫女同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "搀扶了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监扶赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄原板",
          "text": "幼年间沙场上辛苦受尽， 到如今生背疮疾病缠身。 叫内侍搀孤王龙床依定， 只觉得金玉体难以支撑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后捧药上。"
        },
        {
          "character": "贺后",
          "type": "二黄摇板",
          "text": "手捧着丹药汤后宫来进， 愿万岁用此药病痛离身。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "妾妃见驾，吾皇万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "御妻平身！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "赐座！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "谢座！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "丹药可曾煎好？"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "已曾煎好，万岁请用！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": "赵匡胤",
          "type": "二黄摇板",
          "text": "陈抟师留丹药医道有准， 下南唐全仗他救了寡人。 伸双手接玉杯勉强扎挣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤打翻药杯。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "贺后",
          "type": "二黄摇板",
          "text": "见玉杯碎尘埃令人心惊！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "御妻不必悲伤。自古生死有定，你且在床边稍坐，孤要静养片时。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤进入大帐内。赵匡义上，太监暗上。"
        },
        {
          "character": "赵匡义",
          "type": "念",
          "text": "为探兄皇病，夤夜叩宫门。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "来此已是，待我叩环。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡义叩门。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "何人叩环？"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "晋王前来问病叩安！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启万岁：晋王前来问病叩安。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "圣上正在安睡，叫他暂且回府，待圣上醒来，转奏便是。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "万岁安睡未醒，千岁暂且回府，待万岁醒来转奏便是。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "既然圣上正在安睡，但不知何人传的旨意？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "娘娘的旨意。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "孤与万岁，乃是手足兄弟，万岁既然有病，怎么不叫我见？与我转奏：晋王一 定要见！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启娘娘：晋王一定要见圣上。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "依仗圣上之弟，就敢抗旨？再传旨：叫他速退！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤醒。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何事喧哗？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "晋王要进宫问安。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "这是他夤夜前来，要万岁的江山来了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "休得如此多虑。宣他进宫！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "万岁宣晋王进宫！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡义进宫。太监下。"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "臣匡义见驾，兄皇万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "御弟平身！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "谢兄皇！ 娘娘千岁！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "平身！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "万岁，御榻之前，哪有臣子的座位？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "晋王与孤，乃是同胞兄弟。 御弟坐下！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "谢座！兄皇，这几日病体如何？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤已病入膏肓，恐不久人世矣！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "兄皇不必忧虑，吉人自有天相。倘若兄皇……"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "啊晋王，万岁有病，你说话还要仔细些！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "啊兄皇，可还记得母后临终之言？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "古遵治命，不遵乱命。母后临终之言，提它则甚！"
        },
        {
          "character": "赵匡义",
          "type": "白",
          "text": "这个……臣遵懿旨。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "御妻且退，孤要与晋王叙叙手足之情。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "万岁有病，臣妾不敢远离左右。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤要与晋王商议大事，你且回后宫去吧！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "晋王，万岁有病，要仔细讲话！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后下。"
        },
        {
          "character": "赵匡胤",
          "type": "叫头",
          "text": "御弟！"
        },
        {
