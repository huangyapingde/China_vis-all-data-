{
  "script_id": "03034004",
  "title": "陵母伏剑",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "王母",
      "hangdang": "老旦"
    }
  ],
  "plot": "楚汉相争，刘邦大将王陵大败项羽于成皋。项羽回江东，重整军马，伺韩信出兵燕赵，直取东虢；并差人解\n获陵母，以离其心。王陵率众迎敌，皆获大胜。项羽用季布计，先劝陵母不果，复绑陵母于阵前，逼王陵降。\n王陵见母，苦痛难当，欲拼一死。陵母大怒，斥其不该以母子私情有误国家大事。王陵吐血回营，差部将\n叔孙通探母。陵母复以利害直陈；犹恐累王陵，遂伏剑自刎。项羽为收王陵计，以厚礼葬之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "项庄上，起霸。"
        },
        {
          "character": "项庄",
          "type": "念",
          "text": "楚汉分兵灭秦邦，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "季布上，起霸。"
        },
        {
          "character": "季布",
          "type": "念",
          "text": "文韬武略腹内藏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟离昧上，起霸。"
        },
        {
          "character": "钟离昧",
          "type": "念",
          "text": "威风凛凛英雄将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙且上，起霸。"
        },
        {
          "character": "龙且",
          "type": "念",
          "text": "一战成功定咸阳。"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "俺，（项庄）（季布）（钟离昧）（龙且）。"
        },
        {
          "character": "项庄",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "季布、钟离昧、龙且",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "项庄",
          "type": "白",
          "text": "大王发兵，两厢伺候！"
        },
        {
          "character": "季布、钟离昧、龙且",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四文堂、四下手、二马童引项羽同上，项羽上高台。"
        },
        {
          "character": "项羽",
          "type": "点绛唇",
          "text": "嬴秦驾崩，楚汉争锋，刀兵动，眼阔天空，山河归一统。"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "参见大王！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "项羽",
          "type": "念",
          "text": "匹马冲锋敌万人，纵横南北灭三秦。拔山举鼎威名振，统领雄兵扫烟尘。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "孤，项籍，字羽，尊号霸王。自江淮起义以来，百战百胜，殄灭嬴秦，平定关 中。可恨刘邦屡次与孤争夺基业。身经数十余战，未分胜负。只因前番与刘邦 在成皋交战，被他帐下王陵损伤孤的兵将，孤只得回转江东，重整人马；一面 派人去至沛郡捉拿王母，以离其心。孤今日发兵拟报成皋之恨。决先夺东虢， 以振军威。 众将官！"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "兵发东虢去者！"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖五马江儿水〗。项羽下位上马，领众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、中军引王陵同上。"
        },
        {
          "character": "王陵",
          "type": "引子",
          "text": "幼习兵机，学忠孝，礼仪为先。"
        },
        {
          "character": "王陵",
          "type": "念",
          "text": "志气凌云贯斗牛，南征北战几时休！男儿须展擎天手，他年名刊五凤楼。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "本帅，王陵。汉王驾前为臣，官拜右将军之职。奉命镇守东虢一带等处。可恨 重瞳刺杀义帝，独霸关中；吾主特起义兵与霸王大小数十余战。多亏韩元帅深 谋远略，两下互有胜负。今我主又命元帅兵发燕赵去了，令俺代理军务。惟恐 霸王乘虚兴兵，因此日夜操兵防守。 来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "陈平",
          "type": "内白",
          "text": "陈大人到！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "陈大人到。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请陈大人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平上。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "啊元帅！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "先生请坐！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "不知先生驾到，有失远迎，当面恕罪！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "岂敢！下官来得卤莽，元帅海涵！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "岂敢！先生到此必有所为？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "下官奉了大王之命，前来伺候元帅。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "先生说哪里话来，俺王陵碌碌庸才，唯恐难胜其任，还望先生不时指教。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "不敢！元帅调度有方，运筹帷幄，下官倾心佩服。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "先生夸奖了。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有霸王带领大兵三十万，直奔关前而来。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "来！传令下去，大小三军，全身披挂，辕门听点，不得有误！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "先生请！"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "元帅请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖出队子〗。四文堂、周勃、周昌、纪信、随何同上。"
        },
        {
          "character": "周勃、周昌、纪信、随何",
          "type": "同白",
          "text": "俺，（周勃）（周昌）（纪信）（随何）。"
        },
        {
          "character": "周勃",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "周昌、纪信、随何",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "周勃",
          "type": "白",
          "text": "元帅升帐，你我去至辕门伺候！"
        },
        {
          "character": "周昌、纪信、随何",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "周勃",
          "type": "白",
          "text": "众将官，打道辕门！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手引王陵同上。"
        },
        {
          "character": "王陵",
          "type": "粉蝶儿",
          "text": "杀气腾空， 奉圣命，统领雄兵。 众英雄，共灭重瞳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、叔孙通、周勃、周昌、纪信、随何自两边分上。"
        },
        {
          "character": "陈平、叔孙通、周勃、周昌、纪信、随何",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "陈平、叔孙通、周勃、周昌、纪信、随何",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "王陵",
          "type": "念",
          "text": "忆昔当年宴鸿门，楚汉分兵灭嬴秦。重瞳违约图霸业，干戈何日得安宁！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "本帅，王陵。只因重瞳与我主自定咸阳以来，不守怀王之约，强霸为尊。前在 成皋被某一战，人马伤其大半。今又兴兵前来，夺取东虢，岂肯容他猖狂？ 周勃、周昌听令！"
        },
        {
          "character": "周勃、周昌",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "命你二人带领本部人马，今晚三更时分，前去偷营劫寨！"
        },
        {
          "character": "周勃、周昌",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周勃、周昌同下。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "纪信、随何听令！"
        },
        {
          "character": "纪信、随何",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "二路截杀，本帅大兵随后。"
        },
        {
          "character": "纪信、随何",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪信、随何同下。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "二位先生听令！"
        },
        {
          "character": "陈平、叔孙通",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "看守城池，不得有误！"
        },
        {
          "character": "陈平、叔孙通",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、叔孙通同下。"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "抬枪带马！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王陵上马，出城，领四上手、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。四文堂、周勃、周昌同上。"
        },
        {
          "character": "周勃、周昌",
          "type": "同白",
          "text": "放起火来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！ （四文堂同放火。项庄、季布、钟离昧、龙且同上，起打。纪信、随何同上，同打。项庄、季布、钟离昧、 龙且同败下，周勃、周昌、纪信、随何、四文堂同追下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引项羽同上。"
        },
        {
          "character": "项羽",
          "type": "念",
          "text": "旌旗遮日月，威名镇诸侯。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "左营起火！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "抬枪带马！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "项羽上马，领四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（项庄、季布、钟离昧、龙且同败上，周勃、周昌、纪信、随何同追上，开打。项庄、季布、钟离昧、龙且"
        },
        {
          "character": null,
          "type": "text",
          "text": "同败下。项羽上，开打，周勃、周昌、纪信、随何同败下，项羽追下。）"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、王陵同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（周勃、周昌、纪信、随何同上，项羽上，开打。王陵上，打快枪，项羽败下。项庄、季布、钟离昧、龙且"
        },
        {
          "character": null,
          "type": "text",
          "text": "同上，单对打。项庄、季布、钟离昧、龙且同败下。）"
        },
        {
          "character": "王陵",
          "type": "白",
          "text": "败兵不可追赶。人马回关！"
        },
        {
          "character": "周勃、周昌、纪信、随何",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "项羽领项庄、季布、钟离昧、龙且、四文堂同上。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "嗐！"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "参见大王！死罪呀死罪！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "哎！是孤一时大意，与尔等无干。"
        },
        {
          "character": "项庄、季布、钟离昧、龙且",
          "type": "同白",
          "text": "谢大王！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "适才阵上与孤交战，那一将官可是王陵？"
        },
        {
