          "character": "王母",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "季布",
          "type": "白",
          "text": "太夫人暂受一时之苦，少时自有定夺。 来呀，押至前营！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "苍天哪，天！这也是老身养儿子的结果呀啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "季布下。四下手押王母同下。"
        }
      ]
