{
  "script_id": "03084001",
  "title": "送京娘",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "赵京娘",
      "hangdang": "旦"
    }
  ],
  "plot": "赵匡胤投亲不遇。路过古寺，见山寇劫掳赵员外之女赵京娘，赵匡胤抱打不平，杀死山寇，送赵京娘归。赵\n京娘感其德，愿以身相许。赵匡胤不允，结为异姓兄妹。及至赵京娘家，赵员外又提亲，赵匡胤怒拒之。赵\n京娘娘含羞自尽，魂送赵匡胤行。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四喽兵、张广、周进同上。"
        },
        {
          "character": "张广、周进",
          "type": "同念",
          "text": "自幼生来在绿林，杀人放火任咱行。经商客旅山前过，必须留下买路银。"
        },
        {
          "character": "张广、周进",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "张广。"
        },
        {
          "character": "周进",
          "type": "白",
          "text": "周进。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "俺兄弟二人在这华山脚下打家劫舍。看今日天气清和，正好下山抢掠。 众喽兵，带马下山！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "赵员外",
          "type": "内西皮导板",
          "text": "只为心愿把香焚——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、赵员外、赵京娘同上。"
        },
        {
          "character": "赵员外",
          "type": "唱",
          "text": "花香难起马蹄尘。 耳边又听鸾铃震， 想必贼人下山林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、张广、周进同上。"
        },
        {
          "character": "张广、周进",
          "type": "同白",
          "text": "呔！留下买路金银，放尔过去！"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "二位大王爷，小老儿进香而回，身旁并无金银，望大王爷放我等过去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周进看赵京娘。"
        },
        {
          "character": "周进",
          "type": "白",
          "text": "大哥，他言道是烧香还愿的，并无金银。你看这一女子十分美貌，将她抢上山 去，岂不是好？"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "就依贤弟。 呔！那一老头儿，你既然无有金银，就将这女子与俺留下；如若不然，要了尔 的狗命！"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "哎呀！大王爷饶命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外叩头。"
        },
        {
          "character": "张广、周进",
          "type": "同白",
          "text": "抢！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵同抢赵京娘下，张广、周进同下。赵员外、院子同追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "褚元上。"
        },
        {
          "character": "褚元",
          "type": "念",
          "text": "不受尘埃侵，清淡自甘心。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "贫道、褚元。曾拜陈搏老祖为师。忽然心血来潮，不免庙外了望了望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、张广、周进同抢赵京娘上。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "贤弟，看这个女子十分美貌，愚兄偌大年纪，无有妻室，把她让与愚兄吧！"
        },
        {
          "character": "周进",
          "type": "白",
          "text": "大哥偌大年纪，你还要什么妻室？小弟正在青春，理当让与小弟。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "贤弟不要争论。将此女子寄在庙内，再去抢掠，若有绝色女子，你我一人一个； 若无女子，你我谁也不要。"
        },
        {
          "character": "周进",
          "type": "白",
          "text": "好好好！ 老道，将此女子寄在你的庙内，不可放走了她！"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "二位大王，这庙内乃清净所在，焉能容留女子？况且房屋又少，诸多不便。还 是请二位大王将她带到旁处去吧！"
        },
        {
          "character": "周进",
          "type": "白",
          "text": "呔，休要饶舌！若是将她放走，定不与你甘休！"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "众喽兵，再去抢掠！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、张广、周进同下。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "唉！这是哪里说起！这位小姐，请到后面去吧！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "道长若能救得奴家，感恩非浅。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "小姐，这些强盗十分厉害，我若惹他，一来放火烧庙，二来性命难保。暂在后 面歇息，待贫道慢慢设法搭救于你。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "全凭道长。 唉，爹娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘哭下。褚元下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "投亲不遇心悔恨， 抬头只见日西沉。 身入荒郊迷路径， 浑身战抖汗淋淋。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "俺，赵匡胤。去到首阳山投亲，不想外祖母早已迁移。行至此处，浑身疼痛， 冷汗淋淋，不知是何缘故，不免在此石阶之上歇息歇息再走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤坐。褚元上。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "唉！这伙强盗抢来这一女子，藏在我的庙中，是她苦苦哀求于我，叫我搭救于 她。若不设法搭救，她就要死在我的庙内，这便如何是好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火彩。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "且住！看此人红光罩体，定非池中之物，壮士醒来！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "忽听有人将我唤， 只见道长在面前。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "壮士何必在此打睡？请到庙内歇息。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "怎敢打扰！"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "庵观寺院，来者有份。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "褚元引赵匡胤同进庙。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "请问壮士尊姓大名？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "俺姓赵，东京人氏。请道长尊姓大名？"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "贫道褚元。曾拜陈搏老祖为师。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "失敬了！"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "岂敢！备得有斋，请赵壮士去至禅堂用饭。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "多谢了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "褚元引赵匡胤同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘上。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "心恨强盗忒大胆， 擅抢民女理不端。 眼望双亲难得见， 不知何日转家园。 将身来在大佛殿， 拜求佛祖保平安。 搭救京娘脱此难，"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "苍天哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "散步闲游到殿前。 耳旁听得哭声喊，"
        },
        {
          "character": "赵京娘",
          "type": "哭",
          "text": "爹娘啊！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "观见女子起疑端。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "且住！想这庙内哪里来的女子？待我问过老道。 禇道长快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "褚元上。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "壮士何事？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "想你乃是出家之人，在这庙内私藏女子，是何理也？"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "壮士有所不知，这女子名叫赵京娘，父女进香，被强人抢到庙中，命小道藏在 空房里面。若是将她放走，强人回来，放火烧庙，我的性命难保！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "道兄，将这女子唤出，待我问个明白，设计救她出去，你看如何？"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "壮士，不要多管闲事！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊！听你之言，莫非你与那伙强盗同党不成？"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "不是，不是，不是！待我唤她前来。 啊小姐，这一壮士搭救于你，快快出来相见。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "莫非强盗他又来了？"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "不是，不是。快快上前相见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘出见赵匡胤。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "壮士，若能救奴回家，死不忘恩！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "小姐之事，俺已尽知。俺情愿将你救出，你看今晚月朗星明，快些随俺逃走， 有俺保护，料然无事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘背供。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "此人要带我连夜而逃，莫非与强人同党？如若随他同行，岂不羊入虎口？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘愁。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你不要背地沉吟。俺对你实说了吧：俺乃东京人氏，姓赵，名匡胤，字玄郎。 我父金殿都指挥赵宏殷，只因俺在东京杀死御勾栏数十名，故尔闯祸，逃出门 外。俺一生专管不平之事。今见小姐有此大难，焉能袖手旁观？有道是：男女 之嫌，焉有不知？俺赵某做事，唯天可表！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "原来是贵公子，失敬了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "事不宜迟，快快随俺逃走！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩公请上，受奴一拜。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "快快请起！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "恩公请上奴拜定， 见义勇为救奴身。 多谢道长来指引， 奴家感德不忘恩。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "这有竹杖一根，以为执手之用。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "多谢道长。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "黑夜逃走要谨慎， 披星戴月奔途程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、赵京娘同下。"
        },
        {
          "character": "褚元",
          "type": "唱",
          "text": "赵小姐逃出天罗境， 强人到此把话云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、张广、周进同上。"
        },
        {
          "character": "张广、周进",
          "type": "同白",
          "text": "老道，那一女子哪里去了？"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "二位大王，那一女子被一个红脸大汉将她救走了！还将我痛打一顿呢。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "有这等事？快快追赶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、张广、周进同下。"
        },
        {
          "character": "褚元",
          "type": "白",
          "text": "这两个强盗焉能是赵公子的对手？不免将此事报于师傅知道便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "褚元下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、赵京娘同上。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "多蒙恩公施恻隐， 来生结草报君恩。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "小姐把心宽放定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内呐喊声。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "想是贼人到来临。 小姐林内把身隐， 且看赵某将贼擒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下。四喽兵、张广、周进同上。"
        },
        {
          "character": "张广、周进",
          "type": "同白",
          "text": "小辈休走！快将女子留下；如若不然，刀下做鬼！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "胆大的强盗！擅抢民女，休走，看棍！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、张广、周进同起打。赵匡胤打死张广、周进，四喽兵同逃下。赵京娘上，怕。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "小姐不要害怕，强盗被某打死，这有马匹，快些乘骑，俺赵某步行随后。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩公，奴家乘马，恩公步行随后，奴心何安？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "小姐不要推辞，请来上马！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "如此有僭了！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "深施一礼把马上，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "抑强扶弱理应当。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、赵京娘同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵夫人上。"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "员外还愿把香降， 至今不见转还乡。 将身且坐草堂上，"
        },
        {
          "character": "赵员外",
          "type": "内白",
          "text": "哎呀不好了！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "前庭喧哗为哪桩？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、赵员外同上。"
        },
        {
          "character": "赵员外",
          "type": "唱",
          "text": "急急忙忙回家往， 见了安人说端详。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "哎呀安人哪！为夫同女儿烧香归来，路过华山脚下，女儿被强人抢去了！"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "女儿被强人抢去了！"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "听说女儿被贼抢， 好似钢刀刺胸膛。 只说还愿把香降，"
        },
        {
          "character": "赵夫人",
          "type": "哭头",
          "text": "女儿啊！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "平白无辜遭祸殃。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "安人不必啼哭，待我禀报官府，捉拿强盗，打听女儿下落。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "但凭员外。"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "同白",
          "text": "唉，儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外、赵夫人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": "赵匡胤",
          "type": "内二黄导板",
          "text": "披星戴月兼程进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘、赵匡胤同上。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "此时才算放了心。 脱离龙潭家门进， 举家团聚谢大恩。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "劝小姐且把那宽心放定， 俺匡胤抱不平不望报恩。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "坐至在马鞍鞒双目观定， 只见他英雄像、貌非凡，奴起了爱慕之心。 奴这里低下头暗自思忖， 忽然一计想在心。 奴这里假意儿乘骑不稳，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "望小姐要谨慎多多留心。 跌下了马鞍鞒必有伤损， 一路上道路崎岖，你的马快，我的步慢，马上步下，各自当心，你要保重多留 神。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "趁此时奴有心将他挑定， 看他知情不知情。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "小姐且用目观定， 你看那西北乾天起乌云、霎时大雨要降临。 行到此前不着店、后不着村， 去到哪里把身存？"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "看前面松林内有座碑亭，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "快些打马莫消停。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "转瞬之间乌云滚， 来至亭外，下了能行，暂避身形。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下马。雷鸣、电闪、下雨声。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "小姐，大雨倾盆，请到亭内暂避。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "亭内虽然窄小，二人倒能容得。外面雨大，请进亭内来吧！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "俺在檐下稍立片刻。小姐可知道男女有别？瓜田李下之嫌，俺赵某不可违也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤睡。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "平白无辜遭危困， 多蒙公子脱灾星。 杀死强盗消了恨， 千里迢迢送奴行。 我这里将披风与他盖定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘与赵匡胤盖衣。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "夜宿碑亭缘结三生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘睡。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "俺匡胤平生侠义性， 萍水相逢抱不平。 我颇知李下冠不整，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤见赵京娘衣羞。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呃！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "莫忘瓜田纳履起别心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤睡。赵京娘醒。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "公子醒来，公子醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤醒。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "小姐言讲什么？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "想奴系深闺弱女，随父进香而回，被陷贼人之手。幸蒙公子搭救，千里迢迢， 送奴还乡，此恩此德，没齿难忘。倘蒙公子不弃，愿执箕帚，不知公子尊意可 否？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "小姐，禁声哪禁声！想俺与你萍水相逢，挺身相救，不过伸其大义；岂似那些 盗匪之辈，先存苟且之念？不经之言，休要出口！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "公子休得见怪。奴非淫贱之女，弱体余生，皆为公子所赐。此身之外，别无答 报。但得妾婢之身服侍公子，死也暝目。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘哭。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "住了！俺因你误遭贼人之手，故尔不辞跋涉，相送回乡。谁想你出此不经之言！ 俺匡胤平生正直无私，若有邪念，天神共见！你若邪心不退，俺便辞你而去， 休怪匡胤有始无终！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "公子息怒，奴言冒犯，并非邪念。若不嫌弃，情愿结为仁义兄妹，料无推辞的 了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这倒使得。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩兄请上，受小妹一拜！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "兄也有一拜！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "蒙仁兄伸大义令人钦仰，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "俺匡胤生就了侠义心肠。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "在亭前施一礼急忙拜上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "请贤妹快上马早返故乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘、赵匡胤同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵员外、赵夫人同上，院子随上。"
        },
        {
          "character": "赵员外",
          "type": "唱",
          "text": "女儿无音常挂念，"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "盼得为娘两眼穿。"
        },
        {
          "character": "赵员外",
          "type": "唱",
          "text": "可恨贼人忒凶险，"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "恐怕性命难保全。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "唉！自从女儿被强人抢去，不知生死存亡。也曾命人四路打听，至今杳无音信， 想必凶多吉少。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "想你我夫妻年过半百，只有此女，一旦落于贼人之手，好不痛煞我也！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "骂声强盗心忒狠， 擅枪民女乱胡行。 料想我儿难活命，"
        },
        {
          "character": "赵夫人",
          "type": "哭头",
          "text": "我的儿呀！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "怎不教娘痛在心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、赵京娘同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "星夜离了蒲州郡， 心猿意马奔前程。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "手挽丝缰用目睁， 只见来到我家门。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩兄慢走，已到我家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下马。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩兄少待，待小妹进去禀知爹娘。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹请进，愚兄在外等候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘进门。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "爹娘在哪里？爹娘在哪里？"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "同白",
          "text": "哎呀女儿呀！"
        },
        {
          "character": "赵京娘",
          "type": "哭",
          "text": "喂呀爹娘啊！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "见双亲不由儿珠泪滚滚， 今日里脱虎口转回家门。"
        },
        {
          "character": "赵员外",
          "type": "唱",
          "text": "幸喜得我的儿有了活命，"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "焚高香千顶礼叩谢神灵。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "我儿身遭虎口，怎能脱离此难？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "多蒙东京赵公子杀死强人，千里迢迢送儿回家。赵公子还在门外。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "快快请他进来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外出门迎接。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "恩公在哪里？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊员外！"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "请进！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外引赵匡胤同进门。"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "同白",
          "text": "多蒙恩公救出小女，使我一家团聚。此恩此德，怎生答报？恩公请上，受我夫 妻一拜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外、赵夫人同拜。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "此乃小事。员外、安人，何必这等恭敬！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤还礼。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "恩公满身灰尘。 家院，带领恩公后面沐浴更衣！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "多谢了！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子引赵匡胤同下。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "快些预备酒饭，我去陪伴恩公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外下。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "儿呀，既被贼人抢去，这一大汉怎样搭救于你？说与为娘知道。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "母亲容禀。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "都只为仙山把香敬， 中途路上遇强人。 贼子行事心不正， 幸遇公子到来临。 杀死强人搭救儿的命， 千里相送转家门。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "我来问你，这男女一同行路，多有不便哪！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "他乃东京赵指挥之子赵匡胤，侠肝义胆，见义勇为，只为行路不便，孩儿与他 结为仁义兄妹。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "话虽如此，但男女之嫌，外人不得而知。为娘有意将儿终身许配与他，不知我 儿意下如何？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "母亲千万不可造次！此人性如烈火，正直无私。亲事之事，千万莫要说起。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "嗯，我儿后面梳洗去吧。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "员外快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外上。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "安人何事？"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "女儿回来，是为天幸。想他男女千里而来，何不将女儿许配这位公子，员外心 意如何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "我也正有此心。 家院，快快备酒！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子摆酒。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "有请恩公！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "仗义相送行千里，今日才得放宽心。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "员外！"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "备得有酒，与公子同饮。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "叨扰了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。赵匡胤、赵员外同饮酒。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "公子，我有一言，不好启齿。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有何金言，请讲当面。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "小女蒙公子救命，无以答报，愿将小女许配公子，料无推辞的了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "住了！俺好意不惮千里之劳，送你女儿回家，反将这无礼不经之言污辱于我。 俺若贪恋你女，在路上早已成就，何必至此？真正岂有此理！俺去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤翻桌，拿棍下。"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "同白",
          "text": "公子休走！公子休走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外、赵夫人同追下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘上。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "幸感公子义气正， 何日才得报恩情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐，大事不好啦！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "赵公子不知为了何事，大怒而去。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "忽听丫鬟来报信， 想必发怒为提亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下，丫鬟随下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤执掍上，赵员外追上，拉。赵京娘追上，拉棍跪地。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩兄休要发怒，此乃小妹爹娘不会讲话，冒犯恩兄，还要看在小妹的面上啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘哭。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹不必强留。想俺赵匡胤不辞劳苦，送你回家，你举家团圆，反出此不经之 言，俺匡胤之心，唯天可表。不要拦阻，俺就此去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤推开赵京娘，上马，下。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "此事乃是你二老不是，女儿若非赵公子搭救，我家焉能团圆？此恩此德，何日 得报哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘哭下。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "世界上哪有这样的好人！唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘上。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "爹娘做事不思想， 一片恩情付汪洋。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "且住！恩兄发怒而去，奴家终身之事，传扬于外，有何脸面复出闺门？不免悬 梁自尽了吧！恩兄少等，小妹阴魂相送于你呀！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "遥望前堂忙拜定， 拜谢父母养育恩。 手执罗带寻自尽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扫头。赵京娘上吊。丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "哎呀不好！ 有请安人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵夫人上，赵员外、院子同随上。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐自尽了！"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "同白",
          "text": "哎呀！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "一见我儿寻自尽，"
        },
        {
          "character": "赵员外",
          "type": "唱",
          "text": "好似钢刀刺在心。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "将尸首搭了下去。"
        },
        {
          "character": "丫鬟、院子",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、院子同托赵京娘下，丫鬟、院子同上。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "安人，女儿为了何事自尽？"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "皆是由你一人身上所起。"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "为我何来？"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "你不该在酒席筵前提起亲事，断送我女儿性命，岂不是由你这老天杀的身上所 起！"
        },
        {
          "character": "赵员外",
          "type": "白",
          "text": "唉！女儿已死，怨我也是枉然。 家院。置办棺木，盛殓小姐！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "赵员外、赵夫人",
          "type": "同白",
          "text": "唉，女儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵员外、赵夫人同哭，同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘上。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "凄惨惨冷飘飘阴风一阵， 又来了自尽的京娘鬼魂。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "奴家，赵京娘阴魂是也。多蒙赵公子送奴回家，不想爹娘言语冒犯公子。是我 悬梁自尽。公子一路行程，路径不熟，不免护送一程，以报他相送之恩。远远 望见赵公子来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "且住！行至此间，天已黄昏，路径不熟，如何是好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤见灯光。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "唔呼呀！看前面有一灯光，待我直奔灯光而去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘引赵匡胤同走圆场。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊！行至此处，辨不出东西南北，是何缘故？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩兄不必惊慌，我乃赵京娘鬼魂在此。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "小姐，何言“鬼魂”二字？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩兄啊！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "阴风惨惨把言进， 奴今一命赴幽冥。 感兄千里将妹送，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "原来果是京娘魂。 千错万错休怪我， 怨你父母起疑心。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "小妹生而不能报大恩， 但愿你登九五、请来那高道高僧超度奴的亡魂。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哎呀恩兄啊！"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "鹏程万里多侥幸，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "建造庙宇表芳名。"
        },
        {
          "character": "赵京娘",
          "type": "唱",
          "text": "恩兄送我千余里， 奴今送你百里程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸡叫声。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "恩兄，你看金鸡初唱，天色渐明。望恩兄前途保重，小妹不能远送了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎呀且住！不想京娘娘悬梁一死，她的灵魂送俺三百余里。 京娘啊，贤妹，俺赵匡胤有日得地，必要追封于你呀！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "多蒙灵魂把路引， 相送匡胤百里程。 速速打马往前进， 早到关西避灾星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}