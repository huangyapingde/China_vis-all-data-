{
  "script_id": "03013001",
  "title": "渭水河",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "姬昌",
      "hangdang": "老生"
    },
    {
      "name": "姜尚",
      "hangdang": "净"
    }
  ],
  "plot": "殷末，西伯姬昌广行仁政，招贤纳士。一日，樵夫武吉误伤门军致死，应抵罪。因请西伯予限七日，归家别\n母。途经渭水河滨，见姜尚垂钓，告知其事。姜尚教以法术，隐身避罪。姬昌卜其已死，不再追究。后姬昌\n夜梦飞熊，亲出访贤。途遇武吉，询知姜尚教其避罪之事。遂命武吉导往渭滨，面请姜尚至西岐辅政。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引姬昌同上。"
        },
        {
          "character": "姬昌",
          "type": "引子",
          "text": "为建帝基，一路平安，到西岐。"
        },
        {
          "character": "姬昌",
          "type": "念",
          "text": "纣王无道宠妲己，苦害忠良受凌逼。孤王来在西岐地。重整山河统华夷。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "孤，西伯侯姬昌。只因纣王无道，信宠妲己，苦害忠良，是孤来在西岐，自立 帝基。那日有一樵夫，名叫武吉，将孤门军打死，拿他问罪。他言道：家有八 旬老母，无人侍奉。孤王念他是一孝子，赐他斗米贯钱，限定七日前来抵罪， 去了数十余天不见到来。我不免在八卦之中，查看吉凶。 内侍，香案伺候。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小拉子。姬昌卜卦。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "摇动了金钱告上苍， 八卦之中显示明祥。 单见单来仄见仄， 查不出小武吉落于何方。"
        },
        {
          "character": "姬昌",
          "type": "念",
          "text": "春有寅萌芽出土，夏有寅火炼金身。秋有寅黄叶落地，冬有寅滴水成冰。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "呜呼呀，我道此人还在，原来入土而亡。他今一死不大紧要，可叹他八旬老母， 无人侍奉。唉，可叹呐，可叹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起更鼓。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "回避了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同下。"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "孤王建业在西方， 只为江山昼夜忙。 东路反了姜文焕， 南路鄂广反陈塘。 他两家俱有那书信来往， 叫孤王领人马去反商王。 臣反君来小犯上， 倒不如稳坐西岐乐安康。 移步儿来至在灵台上， 且做南柯梦一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "飞熊上，扑帐子。"
        },
        {
          "character": "姬昌",
          "type": "二黄导板",
          "text": "孤王正在睡朦胧，"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "只见飞熊扑帐中。 手使宝剑将你斩， 化阵清风无影踪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "千岁醒来。"
        },
        {
          "character": "姬昌",
          "type": "二黄导板",
          "text": "适才朦胧见一怪，"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "醒来依然在灵台。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "内侍。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "宣散宜生上殿。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "领旨。 散宜生灵台见驾。"
        },
        {
          "character": "散宜生",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "散宜生上。"
        },
        {
          "character": "散宜生",
          "type": "念",
          "text": "袖里乾坤大，怀揣日月明。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "散宜生见驾，主公千岁。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "谢坐。宣臣来见，有何圣谕？"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "孤王三更时分，梦一飞熊入帐，抓伤孤的左膀，不知主何吉凶？"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "这？此乃大吉之兆。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "主公传旨，郊外射猎，不得虎臣，必得良将。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "先生替孤传旨。"
        },
        {
          "character": "散宜生",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "姬昌",
          "type": "念",
          "text": "昨夜飞熊入帐来，"
        },
        {
          "character": "散宜生",
          "type": "念",
          "text": "郊外射猎访贤才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "武吉",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武吉上。"
        },
        {
          "character": "武吉",
          "type": "念",
          "text": "胆大天下去得，刚强寸步难行。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "小子武吉。自从那日上山砍樵，进城去卖，偶遇姬千岁门军，被我失手打死。 那姬千岁拿我问罪。我曾言道：家有八旬老母，无人侍奉。那姬千岁念我是一 孝子，赏我斗米贯钱，回家见母一面，限定七日前来抵罪。不想行至渭水河边， 见一老者在那里垂钓，他见我面带煞气，必有凶事。是我将打死门军之事， 对他实言。他教我一个法儿：回到家中，老母床前，挖一土井，宽要七尺，深 要丈二，口含灯芯糯米，睡在井内。躲过七七四十九日，方保无事。今当四十 八天，老母肚中饥饿，只得将我唤醒，命我上山砍樵，卖了钱文，买米度日。 正是："
        },
        {
          "character": "武吉",
          "type": "念",
          "text": "上山擒虎易，开口告人难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武吉下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "南宫适、北宫高、辛甲、辛免同上，同起霸。"
        },
        {
          "character": "南宫适",
          "type": "点绛唇",
          "text": "扶保西岐，"
        },
        {
          "character": "北宫高",
          "type": "点绛唇",
          "text": "同心协力，"
        },
        {
          "character": "辛甲",
          "type": "点绛唇",
          "text": "立帝基，"
        },
        {
          "character": "辛免",
          "type": "点绛唇",
          "text": "四海归一，"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同点绛唇",
          "text": "方显英雄气。"
        },
        {
          "character": "南宫适",
          "type": "白",
          "text": "南宫适。"
        },
        {
          "character": "北宫高",
          "type": "白",
          "text": "北宫高。"
        },
        {
          "character": "辛甲",
          "type": "白",
          "text": "辛甲。"
        },
        {
          "character": "辛免",
          "type": "白",
          "text": "辛免。"
        },
        {
          "character": "南宫适",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "北宫高、辛甲、辛免",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "南宫适",
          "type": "白",
          "text": "主公郊外射猎，两厢伺候。"
        },
        {
          "character": "北宫高、辛甲、辛免",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四太监、二太子、姬昌同上。"
        },
        {
          "character": "姬昌",
          "type": "引子",
          "text": "旌旗遮日月，郊外访贤臣。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "郊外去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫适、北宫高、辛甲、辛免同允。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "众将官，郊外去者。带马！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。骨牌对。武吉自下场门上。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "前道为何不行？"
        },
        {
          "character": "人役",
          "type": "同白",
          "text": "樵夫挡道。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "人马列开！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊。樵夫当面。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "樵夫叩头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬昌惊。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "下跪可是武吉？"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "见了孤王为何不抬起头来？"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "嗯？限定七日前来抵罪。为何今日才来见孤，该当何罪？"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "千岁容禀：那日多蒙千岁天恩，放小子回家，见母一面，不想行至渭水河边， 见一老者在那厢垂钓，他见我面带煞气，必有凶事。是我将打死门军之事对他 言明。他教我小小一个法儿：回到家去，老母床前，挖一土井，宽要七尺，深 要丈二，口衔灯芯糯米，睡在其内。躲过七七四十九日，方保无事。今乃四十 八天，我母不解其意，将我唤醒，命我上山砍樵，进城去卖，不想闯了千岁御 驾。也是小人命该如此，情愿领罪。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "可曾问过那渔人的名姓？"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "不曾问得。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "垂钓所在？"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "渭水河边。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "将柴担放下，引孤前往。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "且慢。启奏父王：为国访贤，必须换了便服。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "看衣改换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "合龙口。姬昌更衣。"
        },
        {
          "character": "南宫适、北宫高、辛甲、辛免",
          "type": "同白",
          "text": "撒下围场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四太监、南宫适、北宫高、辛甲、辛免同下。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "武吉。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "带路。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "樵夫道那渔翁颇有奥妙， 因此上带皇儿亲走一遭。 叫武吉你与孤向前引道， 青的山绿是水难画难描。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜尚上。"
        },
        {
          "character": "姜尚",
          "type": "唱",
          "text": "纣王无道贪色酒， 午门外盖下了摘星楼。 比干丞相遭毒手， 贾氏夫人坠高楼。 昨夜晚在土台观看星斗， 算就了西伯侯灭纣兴周。 移步儿来至在渭水河口， 那一边来的是西伯王侯。"
        },
        {
          "character": "姬昌",
          "type": "内白",
          "text": "武吉带路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武吉、二太子、姬昌同上。"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "太平鸟不住当头叫， 叫得孤王心内焦。 土台上坐定了白发老道， 手拿着钓鱼竿自在逍遥。 我看他倒有那仙家奥妙， 但不知他腹中可有略韬。 叫武吉你与我暂且退了， 二皇儿向前去细问根苗。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "是。啊，那渔人请了。"
        },
        {
          "character": "姜尚",
          "type": "念",
          "text": "钓、钓、钓，大鱼不到小鱼到。用尔不着，去吧。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "好生与你见礼，为何佯装不睬？"
        },
        {
          "character": "姜尚",
          "type": "念",
          "text": "从来未识金龙面，要见明君便开言。"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "好大的口气。 啊，父王，那渔翁言道：从来未识金龙面，要见明君便开言。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "敢是尔等轻慢于他？"
        },
        {
          "character": "二太子",
          "type": "同白",
          "text": "儿臣不敢。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "待我向前。 啊，渔人请了。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道稽首。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "口称“稽首”，在哪座名山修炼？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "昆仑学道。稽首为尊。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "在此作甚？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "在此垂钓。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "钓的什么鱼？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "西海鳌鱼。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "小小竹竿，焉能钓得鳌鱼？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "钓竿虽小，能坠千斤。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "借来一观。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "请看。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "呜呼呀！为何用直钩垂钓？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道心直性直，故而用直钩垂钓，有道是：“愿者上钩”。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "但不知谁愿谁不愿？"
        },
        {
          "character": "姜尚",
          "type": "念",
          "text": "耐烦等到群鱼到，自有鱼儿来吞钩。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "请问渔人尊姓大名？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道姓姜名尚字子牙，"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "道号？"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "飞熊。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "“飞熊”！应孤梦兆也。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "来者上姓？"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "在下西伯侯姬昌。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "原来是姬千岁，失敬了。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "不在西岐，来在渭水作甚？"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "特请先生，扶保姬氏河山。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道才疏学浅，不敢当此重任。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "先生不必推辞。 武吉，"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "封你开路先锋，准备车辇伺候。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "武吉",
          "type": "念",
          "text": "不是姜太公，焉能作先锋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武吉下。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "请先生转至大营。"
        },
        {
          "character": "姜尚、姬昌",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "久闻先生今相见，"
        },
        {
          "character": "姜尚",
          "type": "唱",
          "text": "姜子牙八十二才遇名贤。"
        },
        {
          "character": "姬昌",
          "type": "唱",
          "text": "孤王江山全仗你，"
        },
        {
          "character": "姜尚",
          "type": "唱",
          "text": "要保江山万万年。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬昌、姜尚同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、南宫适、北宫高、辛甲、辛免、四太监、二太子、武吉、姜尚、姬昌同上。〖吹打〗。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "启千岁：车辇齐备。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "请先生登辇。"
        },
        {
          "character": "姜尚",
          "type": "白",
          "text": "贫道有僭了。"
        },
        {
          "character": "姜尚",
          "type": "唱",
          "text": "听号炮三声响旌旗招展， 满营中众将官齐跨雕鞍。 对主公施一礼忙登车辇， 姜子牙坐车辇细把君观： 前三皇后五帝年深日远， 有尧舜并禹汤四大名贤。 西伯侯夜得兆飞熊扑面， 散宜生奏一本郊外访贤。 打樵汉名武吉引君来见， 姜子牙八十二才遇名贤。 行八百单八步住了车辇， 到后来保周室八百八年。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "启千岁：西岐众百姓，头顶香盘，迎接千岁、先生进城。"
        },
        {
          "character": "姬昌",
          "type": "白",
          "text": "香盘撤去，摆队进城。"
        },
        {
          "character": "武吉",
          "type": "白",
          "text": "香盘撤去，摆队进城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同进城，同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}