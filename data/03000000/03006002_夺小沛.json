        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嗐！大哥，咱弟兄威名，谁人不晓，来此狗子辕门，有什么惊怕？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不要放肆，待我前去投帖。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待弟上前说一声便了。"
        },
