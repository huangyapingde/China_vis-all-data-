        {
          "character": "刘备、张飞",
          "type": "同白",
          "text": "只怕射不中。"
        },
        {
          "character": "陈兰",
          "type": "白",
          "text": "但愿射的中。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "草包少说话。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "就请温侯射戟！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "有僭了！"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "吕奉先施一礼二家恕罪， 凭天理俺与你二家解围。 白银铠似雪飞玲珑玉珮， 罩发冠双凤尾胸上飘垂。 今不是十八国临潼赴会， 俺不是伍子胥独占首魁。 养由基箭穿杨惊神服鬼， 汉李广使神箭耀目光辉。 俺射戟但愿你二家和美， 射不中再厮杀天意相随。 众将官休乱队各归营位！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "暗祝告过往神忍泪含悲。 老天爷相助我汉室刘备！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布射中戟。"
        },
        {
          "character": "纪灵",
          "type": "唱",
          "text": "这一番心血力今被风吹。"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "即吩咐马步兵各自散队， 息战鼓掩旌旗独自回归。 斟一杯饯行酒屈膝下跪，"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "看在我吕布面饶恕这回。"
        },
        {
          "character": "纪灵",
          "type": "唱",
          "text": "回营去见吾主何言答对？"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "我与你书一封何须愁眉？"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "但凭温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "看交房四宝伺候！"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "秉忠心全大义不把主背， 罢干戈他却是难把兵催。 见你主你还要好言相对， 有大事纪将军俱向我推。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": "纪灵",
          "type": "唱",
          "text": "出营门不由我钢牙咬碎，"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "马来！ 再领兵将小沛马踏成灰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵、陈兰、雷簿同下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "细思量今退兵面带惭愧，"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "俺一箭十万众卷甲而归。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "退雄师全不用交锋对垒，"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "到底是纪灵贼惧怕翼德。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "多谢温侯解围之恩。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "此乃天意，布何敢领谢。但是将军千万不要忘了射戟之恩。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我若忘了射戟之恩，对天誓表。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "但凭使君。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "老天在上，刘备若忘温侯射戟之恩，我就……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "就福大量大，后来定坐天下。皇帝起来，不要盟誓。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "温侯听了：老天在上，刘备若忘温侯射戟之恩，我就天知地知。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "请起。久闻桃园弟兄大义，今日一见，果然名不虚传。后帐摆宴，同饮几杯， 再回小沛便了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "多谢温侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "纪灵讨战！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待俺老张出马。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "些小之事，后帐歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、张飞同下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "众将官！抬枪带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、雷薄、陈兰、纪灵同上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "纪灵为何又来讨战？"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "受我主礼乱，为何反助刘备？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "休得胡言，放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起打。纪灵、雷薄、陈兰同败下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}