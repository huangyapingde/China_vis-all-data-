{
  "script_id": "03006002",
  "title": "夺小沛",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "吕布",
      "hangdang": "小生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "纪灵",
      "hangdang": "净"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    }
  ],
  "plot": "袁术派部将纪灵攻夺小沛。袁术恐吕布援助刘备，馈吕布粮米。吕布深恐袁术得势，威胁徐州，乃约请刘备、\n纪灵到营置酒解和。席间，吕布施展本领，于百步外箭射画戟。纪灵慑于吕布威势，罢战而去。",
  "notes": "《夺小沛》故事源出《三国演义》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "雷簿、陈兰同上，同起霸。"
        },
        {
          "character": "雷簿",
          "type": "念",
          "text": "静听边关报，"
        },
        {
          "character": "陈兰",
          "type": "念",
          "text": "三军紧战袍。"
        },
        {
          "character": "雷簿",
          "type": "念",
          "text": "大将跨战马，"
        },
        {
          "character": "陈兰",
          "type": "念",
          "text": "威名镇九霄。"
        },
        {
          "character": "雷簿",
          "type": "白",
          "text": "俺、雷簿。"
        },
        {
          "character": "陈兰",
          "type": "白",
          "text": "陈兰。"
        },
        {
          "character": "雷簿",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "陈兰",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "雷簿",
          "type": "白",
          "text": "元帅点兵，两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、纪灵同上。"
        },
        {
          "character": "纪灵",
          "type": "点绛唇",
          "text": "将士英雄，军威压众，兵将勇，战马如龙，令出山摇动。"
        },
        {
          "character": "雷簿、陈兰",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "二位将军少礼。"
        },
        {
          "character": "雷簿、陈兰",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "纪灵",
          "type": "念",
          "text": "将在谋略兵在操，暴虎憑河皆难逃。奉命攻打小沛地，再擒吕布立功劳。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "某大将纪灵。奉了袁主之命，先擒桃园兄弟，后灭吕布小儿，以图大业，今乃 黄道吉日。 雷、陈二位将军，人马可曾齐备？"
        },
        {
          "character": "雷簿、陈兰",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "就此兵发小沛去者！"
        },
        {
          "character": "雷簿、陈兰",
          "type": "同白",
          "text": "兵发小沛去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引吕布同上。"
        },
        {
          "character": "吕布",
          "type": "引子",
          "text": "英雄并立，叹将士，难缷征衣。"
        },
        {
          "character": "吕布",
          "type": "念",
          "text": "忆昔当年保丁原，后灭董卓已除奸。堪笑各处狼烟起，谁不尊重吕奉先。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "某吕布。幼习兵马，颇知战法，虽无黄公三略，也知吕望六韬。天下英雄，闻 名丧胆。前者夺了徐州，袁术闻知，星夜差人来至吾营，许送粮米五万，战马 百匹，金银一万两，彩缎千匹，使我夹攻刘备。谁想失信于我，俺欲领兵征伐， 被陈宫谏阻。我念刘备乃义气英雄，请他弟兄屯兵小沛去了。前次有书到来， 恐袁术攻打小沛，求我救应。至今未见动静，为此每日操兵演将，以防对敌。 来，伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "忙将军务事，报与元帅知。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启温侯：今有袁术命纪灵谋夺小沛，又命韩将军送来粮二十万。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "请韩将军迎宾馆待茶，我就去奉陪。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "且住！前许我金银、粮米、彩缎、马匹，直到如今，未见一物。今日纪灵夺取 小沛，恐我帮助刘备，因此送来粮二十万，使我不救玄德。唔，吾想桃园弟兄 屯兵小沛，未必能为吾害；若袁术并了玄德，则北连泰山诸将以图吾，我不能 安枕矣。也罢！我不免修书一封，请他二家到来，我在内中解围。 来，浓墨伺候！"
        },
        {
          "character": "吕布",
          "type": "西皮导板",
          "text": "威风凛凛站虎帐，"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "上下将士似虎狼。 撩袍端带公座上， 手提羊毫写几行。 亦非是待客葡萄酿， 军国大事有商量。 二封书信忙修上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌暗上。"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "明日定要赏我光。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "将书分送。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "战败疆场在濮阳, 众诸侯见我心也慌。 丁原不仁剑下丧， 枪挑董卓一命亡。 虎牢关前打一仗， 大战桃园刘关张。 三人合打连环仗， 只杀得儿郎丧疆场。 方天画戟手中掌， 张飞把俺金冠伤； 气得某家收兵将， 含羞带愧脸无光。 三军与我忙退帐， 明日两军免争强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "小沛小城、为县令，感戴皇恩。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "桃园聚义结金兰，弟兄恩义重如山。从军剿灭黄巾觉，丹心辅保汉江山。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "俺、刘备，楼桑人也。自破黄巾，屡建奇功。今身为县职，镇守小沛。前者三 弟酒醉，被吕布夺了徐州县城，又蒙归还。今坐二堂，心神不定，不知为了何 事？ 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启爷，纪灵来夺小沛。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "且住！纪灵发兵前来夺取小沛。 来，请二爷、三爷进帐。"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "请二爷、三爷送帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "英雄义气薄云天，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "结拜金兰非等闲。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "白马祭天牛祭地，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "凌烟阁上美名传。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "参见大哥！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "贤弟少礼。请坐。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "请坐。传小弟出来，有何军情？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "刚才探马报道：纪灵带兵前来，夺取小沛。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "啊！纪灵要战？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来，抬枪带马！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱兄弟一同出城，杀退纪灵这厮。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且慢！大哥自有主见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二位贤弟随我上城，观看阵势，也好御敌。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "带马伺候。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "小沛小城未坐稳， 无知袁术又逞能， 卷旗息鼓观营阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、张飞同上城。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "杀气冲天乱纷纷。 战鼓响声如雷震，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵带雷簿、陈兰、四文堂同上，同排一字，同下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哇呀哇呀！哇呀呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "将似虎狼马如龙。 若去交锋难得胜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、张飞同下城。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "顷刻要失小沛城。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二位贤弟，纪灵兵多将广，如何抵敌？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱弟兄出城杀他一阵，怕他何来！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "若是胜了？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "若是胜了，杀退纪灵，生擒袁术。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "若是败了，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "若是败了，咱弟兄走他娘的。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "使不得。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱还有个绝妙的计。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "越妙越好。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将俺老张的首级割下，高高的挂在城楼，纪灵一见骇怕，哪怕他不收兵回去。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你的计不是走就是死。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "不走不死，俺老张就无计了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "徐州温侯下书人求见。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "候着。 徐州温侯下书人求见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "传他进来。"
        },
        {
          "character": "青袍甲",
          "type": "白",
          "text": "下书人进来。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见使君。温侯有书呈上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿过来！不要看。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这做什么？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "那吕布狗子的书信，还有什么好意。不要看！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看了好作准备。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "要看你们拿去看。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待我拆开一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你回去拜上温侯，就说桃园弟兄随后就到。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "书信上面写的什么言词？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吕布见纪灵夺我城池，修书前来，教吾弟兄过营饮宴，与我二家解围。二弟可 去？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "相随大哥。三弟可去？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "要去你们去，咱不去。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "你怎么不去？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "那吕布前者夺俺的徐州，仇人见面，就起凶心。要去你们去，咱还是不去。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟不去，敢是惧怕那吕布？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊！走走走！我怕他！我怕他！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "还要安排二位皇搜。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我自有道理。吩咐五百兵丁，保护城池；余下兵将听我吩咐！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "攻城掠地动刀兵， 袁术平日喜战争； 吕布书来解愁闷， 弟兄亲自到辕门。 大小将士随营阵， 五百兵丁紧守城。 三弟休把吕布恨， 怕的玉石尽皆焚。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "刀枪剑戟要齐整， 铠甲鲜明五色分。 此去好比鸿门宴， 某樊哙保定刘使君。 大哥且将心放定， 管保大哥平安无事转沛城。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "纪灵小儿何足论， 非是小弟自逞能。 百万的黄巾已平靖， 大小战场数百征； 那纪灵纵然有本领， 有道是一人拼命万夫难存。 张翼德生来太烈性， 全仗着乌骓马丈八蛇矛枪一根。 小吕布他与我旧有恨， 他不该前日里趁我酒醉带领人马暗夺徐州城。 要去何须多议论， 老张一世不怕人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、中军、吕布同上。"
