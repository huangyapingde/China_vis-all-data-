{
  "script_id": "03091006",
  "title": "乌盆记",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘世昌",
      "hangdang": "老生"
    },
    {
      "name": "张别古",
      "hangdang": "丑"
    },
    {
      "name": "赵大",
      "hangdang": "丑"
    },
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "刘升",
      "hangdang": "丑"
    },
    {
      "name": "赵妻",
      "hangdang": "旦"
    },
    {
      "name": "判官",
      "hangdang": "净"
    }
  ],
  "plot": "刘世昌外地经商，结算帐目后，携仆回家，中途遇雨，借宿于窑户赵大家中。赵大夫妻见财心动，将刘世昌\n主仆谋害，并将二人剁为肉泥，烧制成乌盆。适张别古至赵家索欠债，刘世昌鬼魂向张别古伸诉冤情，张别\n古诉于包拯处，冤乃昭雪。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "刘世昌",
          "type": "内白",
          "text": "趱行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘升、刘世昌同上。"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "青山绿水观不尽， 人投旅店鸟归林。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "在下，刘世昌，南阳人氏。贩卖绸缎为生。离家数载，今将货物发完，收清账 目，归家探望双亲。 刘升！"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "前面什么所在？"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "离此不远，就是东大洼。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "看天气不好，你我速速趱行！"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "刘世昌",
          "type": "西皮原板",
          "text": "叹人生世间名利牵， 抛父母撇妻子离故园。 道旁美景懒得看， 披星戴月奔家园。 霎时间一阵天色变，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷声。冲头，乱锤。"
        },
        {
          "character": "刘世昌",
          "type": "西皮散板",
          "text": "狂风大雨遮满天！ 刘升带路往前趱， 夜宿旅店把身安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌、刘升同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "赵大",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "数板",
          "text": "自幼生来命不堪，又会烧盆又会烧砖。一份家财俱花尽，只落得身穿破衣衫、 破衣衫。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我，赵大。不幸父母双亡，是我夫妇二人在这定远县东大洼烧窑度日。看今日 天气晴和，不免将老婆唤出，将这些盆子晒晒，也好到集镇上去卖。 老婆子哪里？"
        },
        {
          "character": "赵妻",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻上。"
        },
        {
          "character": "赵妻",
          "type": "数板",
          "text": "我们当家的是个能人儿，又会烧砖又会烧盆儿。小两口，过日子儿，忙忙活活 有个意思儿。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "我说当家的，叫我干什么呀？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "看今日天气晴和，叫你出来，我们来晒晒盆，也好到集镇上去卖。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "好，咱们来抬盆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻抬盆。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "当家的，这个太大啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小着点儿吧。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "太小啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "得啦，将就点儿吧！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "哟，阴啦天儿啦，咱们抬进去吧。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "抬进去。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "又晴啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "再抬出去。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "又阴啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "得啦，别找骂啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、赵妻同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘升、刘世昌同上。"
        },
        {
          "character": "刘世昌",
          "type": "西皮散板",
          "text": "行了一程又一程， 浑身上下水淋淋。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "看那旁有一人家，上前借宿，好话多讲。"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "嘿！你们这儿是店么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "可有女人陪着睡觉吗？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我们这里是住户人家，不是妓院，也不是旅店！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "嗯！这奴才，不会讲话！ 啊兄台，这厢有礼！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这才是人说话哪！您是做什么的？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "我们行至此间，天降大雨，前不着村，后不着店，望兄台方便一二借宿一宵， 感恩匪浅。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "您既是借宿，请您进来吧。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "将马带进。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌、刘升、赵大同进门。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "您请坐吧。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "您贵姓啊？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "在下刘世昌。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "哪儿的人氏？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "南阳人氏。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "做何生理？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "贩卖绸缎为生。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "是个发财的买卖！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "小本钱。请问兄台上姓？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我叫赵大。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "原来是赵大哥！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "不敢，不敢。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "做何生理？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "开了一座盆儿窑。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "也是发财的买卖！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "不算大买卖。您可曾用过饭哪？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "不用客气，我们这儿有现成的。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "只是打搅不当！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "哪儿的话呢，我给您预备去。 家里的，快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻上。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "来了一个好买卖，你快快预备药酒去！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "是啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵妻下，上。赵妻将酒饭递与赵大，下。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "酒也来啦，饭、茶也来啦，请您二位用吧。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "叨扰了！"
        },
        {
          "character": "刘世昌",
          "type": "西皮原板",
          "text": "好一个赵大哥真慷慨， 霎时间酒饭摆上来。 不幸在中途被雨溉， 萍水交打搅理不该。 到明天自当多谢拜， 昏昏沉沉倒在土台。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "天不早啦，您该歇着啦。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大下。刘世昌、刘升同睡。起鼓。"
        },
        {
          "character": "刘世昌",
          "type": "西皮导板",
          "text": "霎时一阵肝肠断，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌吐。"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "刀搅柔肠为哪般？ 是是是来明白了， 中了赵大的巧机关！ 回头便把刘升唤，"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "刘升，刘升！哎呀！"
        },
        {
          "character": "刘世昌",
          "type": "西皮摇板",
          "text": "想必奴才丧黄泉！ 眼望着南阳高声喊，爹娘啊！ 阴曹地府走一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌死。"
        },
        {
          "character": "刘升",
          "type": "西皮导板",
          "text": "霎时一阵心头乱，"
        },
        {
          "character": "刘升",
          "type": "西皮摇板",
          "text": "腹内疼痛为哪般？ 是是是来明白了， 中了赵大巧机关！ 急忙快把主人唤，"
        },
        {
          "character": "刘升",
          "type": "白",
          "text": "主人，主人！哎呀！"
        },
        {
          "character": "刘升",
          "type": "西皮摇板",
          "text": "想必一命丧黄泉！ 眼望南阳高声叫，哎呀我的爸爸呀！ 阴曹地府去申冤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘升死。赵大、赵妻同上，赵大开门，看。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "他二人已死，将他们尸首剁成肉泥，放在窑内烧盆吧！"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "你我就这么办！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、赵妻同抬刘世昌、刘升，同剁。判官暗上，站桌上。"
        },
        {
          "character": "赵妻",
          "type": "白",
          "text": "哎呀，我瞅墙上那个判官直瞪眼睛，我有点儿害怕！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你怕什么！咱们干咱们的，怕他何用！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、赵妻剁完。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "得啦，这一下子咱们可就发了财啦，赶快叫泥瓦匠先盖起房子来再说。正是："
        },
        {
          "character": "赵大",
          "type": "念",
          "text": "禹门三级浪，平地一声雷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、赵妻同下。判官下桌。"
        },
        {
          "character": "判官",
          "type": "念",
          "text": "着道金阶怒气多，只因不中状元科。唐王赐某青锋剑，颁请天下斩妖魔。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "吾乃终南山进士钟馗是也。今有赵大夫妻将刘世昌主仆谋害，是我亲眼看见， 我不免指引他去往县台那里申诉。啊，一言未尽刘世昌冤魂来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌上。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "参见判爷！"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "有何冤枉，朝上诉来！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "在下，刘世昌，被赵大谋害，愿在公堂告诉！"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "为何不去告诉？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "奈无引见之人。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "我与你作一见证。"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "谢判爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌、判官同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "张别古",
          "type": "内白",
          "text": "嗯咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古上。"
        },
        {
          "character": "张别古",
          "type": "数板",
          "text": "年迈时衰，老来无子好伤怀。妻丧早，命运乖，只落得奔忙劳碌打草鞋、打草 鞋！"
        },
        {
          "character": "张别古",
          "type": "念",
          "text": "人老屈腰把头低，树老焦梢叶儿稀。茄子老了一兜子儿，倭瓜越老越好吃。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "老汉，张别古。打草鞋为生。这两天生了一场毛病，没有出去做买卖。今日病 好啦，一个钱儿没有，我想起城南赵大，欠我两双草鞋钱。不免前去要了来， 也好度日，就此走走。 待我出了门儿，关上门儿，我再锁上门儿，门儿呀门儿，你好好看着我的门儿， 不要叫羊吃了我的被窝！老啦老啦，再也不能小啦；若是小了，可就费了事 啦。说话之间到啦！ 哎呀，房子怎么翻盖啦，还是搬了家啦！待我再来看看！损德堂赵。是他的堂 号！待我叫叫看。 赵大，赵大！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大上。"
        },
        {
          "character": "赵大",
          "type": "念",
          "text": "忽听叫赵大，胆战心如麻。纵然将事发，有钱全不怕。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "赵大，赵大！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "原来是老小子！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "好说，小小子儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古背躬。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "啊，他哪里抢来的钱，穿的这么好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古向赵大。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "是我！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你来做什么？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我找你有两句话说。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "有话这里讲？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不在这里讲，在哪里讲？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这里风大，吹了我的舌头！在会客厅里讲话！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有了钱就有了会客厅啦！我不认识，你头里走。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "跟我走。进大门儿！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "进大门儿。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "进二门儿！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "进二门儿。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "走穿廊！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "走穿廊。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "过游廊！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哦，过游廊。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "抬起脚来！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小心黄鼠狼！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你们这里狼倒不少！你还到了到不了哇？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "就算到了吧。跟我进来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、张别古同进门。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "这个地方真不错，好像一个戏台。待我来坐一会儿。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "哎，走开！这个地方你也坐得么？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "坐坐也不要紧哪！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "木能生火，你可晓得烧了你的屁股！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你坐着怎么不烧哇？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我是福大量大！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我坐哪儿呀？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你坐在地下！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我就坐在地下。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "有什么话说？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你前些日子拿了我两双草鞋，还没给我钱，今天你该给我啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "什么！我头上戴的什么？我身上穿的什么？脚底下蹬着什么？我能欠你的草鞋 钱？你胡说八道！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎呀，发了财他全忘啦！有啦。 赵大爷，您听错啦，不是您欠我的草鞋钱，是您伙计拿了我两双草鞋没给钱， 写在您的账上啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这话才对。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有钱给我，我好走。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "钱哪，都用铁丝儿串起来啦！为你还开串不成？没有钱！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有银子没有？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "银子都浇了银山啦！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有票子没有？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "有当票两张！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "当票我也没有钱赎，我就是讨饭短个盆儿！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你跟我到盆儿库里去。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "啊，盆也有了库啦！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "大爷有钱！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你头里走。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "跟我来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、张别古同走小圆场。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你这两天倒好，没生毛病？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你不要胡说！到啦，你瞅上中下三层！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你把上层的给我一个。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "上层是进贡的，你不能用。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "中层的与我找一个。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "中层的是公伯王侯使的，你不能用。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "下层的与我找一个。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "下层的是来往客商使的，你不能用。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "那么着我在大堆里挑一个吧。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "这倒可以使得。我替你拣一个吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大取盆。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我告诉你，这个盆儿它还有个名儿！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "它叫什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "它叫乌盆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌上。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "这个名儿倒不错。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你去吧！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你们这里狼太多，我弄不清楚，你把我带出去吧。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "好，你跟我出来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大、张别古同走圆场。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "好啦，到啦！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我出去啦。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你回来，你回来！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "回来做什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你到外头打听打听，有那小姑娘、小小子儿买两个来。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "要小姑娘、小小子儿做什么？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小姑娘服侍你大奶奶。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "小小子儿呢？"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "服侍大爷我。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哦，有了钱真会出花头儿！有咧，待我来拿他开开心！ 大爷，小姑娘没有，有个小小子儿。"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "小小子儿在哪儿哪？"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "你远看！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "没有人！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "近看！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "啊，就是你呀！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎，不错！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "我没有钱给你买棺材！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我当你们家活祖宗！"
        },
        {
          "character": "赵大",
          "type": "白",
          "text": "你滚出去呗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵大关门，下。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "啊，老天哪老天！我想赵大与我一样的人，为何他会发起财来？咳！"
        },
        {
          "character": "张别古",
          "type": "念",
          "text": "莫道东风常向北，北风也有转南时！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "张别古！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "是哪一位？"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "唉，老丈！"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "老丈不必胆怕惊， 我有言来你是听： 休把我当做了妖魔论， 我本屈死一鬼魂！"
        },
        {
          "character": "张别古",
          "type": "二黄原板",
          "text": "他那里叫一声张别古， 倒叫我年迈人糊里糊涂！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎呀且住！常言说得好：少年见鬼，还得三年；老来见鬼，就在眼前！不好， 拿起盆儿来走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌挡。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我打这边儿走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌挡。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "我打那边儿走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘世昌挡。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎哟，鬼打墙！"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "我忙将树枝摆摇动，"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎呀，好大风！"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "抓一把沙土扬灰尘！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "哎呀，好大尘土！"
        },
        {
          "character": "刘世昌",
          "type": "二黄原板",
          "text": "我和你远无冤近无有仇恨， 望求老丈把冤申！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不好，弄得我鼻子里、嘴里、眼睛里都是些黄土泥！拿起盆儿来走哇！"
        },
        {
          "character": "张别古",
          "type": "二黄摇板",
          "text": "急急忙忙往前进， 不觉来到城隍庙门。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "说话之间，到了城隍庙啦。我听人说：城隍老爷顶灵啦，待我进去许个愿，叫 这鬼不跟着我才好！就是这个主意。就此走走！张别古进庙来！"
        },
        {
          "character": "张别古",
          "type": "数板",
          "text": "躬身下拜，尊一声城隍老爷细听明白：只因赵大该我钱财，我去讨债。他没有 钱，给了我一个盆折了债。这个盆儿它是个妖怪，半路途中说出话来！望城隍 老爷与我遮盖，明日里猪头三牲一棵白菜，我一定买来！我一定买来！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "好，愿也许了，待我来叫叫看。 乌盆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古听。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "城隍爷真灵，鬼也不跟着我啦，待我回去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古出门。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "慢着，我连吃饭钱都没有，哪有钱还愿！不好，城隍爷闹起来，比鬼还凶，待 我打退了愿吧！二次进庙来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张别古进门。"
        },
        {
          "character": "张别古",
          "type": "数板",
          "text": "躬身下拜，尊一声城隍老爷细听明白：只因赵大不该我的钱财，我没去讨债。 这个盆它不是妖怪，半路途中它没有说出话来。望城隍不要与我遮盖，明日里 猪头三牲一棵白菜，我不能买来！我不能买来！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "城隍爷，我方才说的话，算是拉倒啦！好，愿也不许啦，待我再来叫叫看。 乌盆！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不好，鬼又来啦！拿起盆儿来走！"
        },
        {
          "character": "张别古",
          "type": "二黄摇板",
          "text": "急急忙忙往前行， 不觉来到自己家门。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "到了自己家了！"
        },
        {
          "character": "张别古",
          "type": "数板",
          "text": "我放下了棍儿搁下了盆儿，拿起了钥匙捅开了锁的屁股门儿。我拿起了棍儿拿 起了盆儿，急急忙忙进了我的门儿。搁下了棍儿放下了盆儿，回手关上了我的 门儿，我看你是神是鬼怎么进我的门儿！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "张别古！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "不好，把鬼关在屋里啦！"
        },
        {
          "character": "刘世昌",
          "type": "白",
          "text": "老丈啊！"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "有什么话你说吧！"
        },
        {
          "character": "刘世昌",
          "type": "反二黄三眼",
          "text": "未曾开言泪满腮， 尊一声老丈听开怀："
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "家住哪里？"
        },
        {
          "character": "刘世昌",
          "type": "反二黄三眼",
          "text": "家住在南阳城关外，"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "离城多远？"
        },
        {
          "character": "刘世昌",
          "type": "反二黄三眼",
          "text": "离城十里太平街。"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "姓甚名谁？"
        },
        {
          "character": "刘世昌",
          "type": "反二黄三眼",
          "text": "刘世昌祖居有数代，"
        },
        {
          "character": "张别古",
          "type": "白",
          "text": "什么行业？"
        },
        {
          "character": "刘世昌",
          "type": "反二黄三眼",
          "text": "务农为本颇有家财。 奉母命上京做买卖， 贩卖绸缎倒也生财。 前三年也曾把货卖， 收清账目转回家来。 路过定远县交界， 忽然问老天爷降下雨来。 主仆们至赵大窑门外， 借宿一宵起祸灾。 赵大夫妻将我谋害， 他把我尸骨未曾葬埋！ 烧成乌盆在窑卖， 幸遇老丈讨债来。 可怜我含冤已三载，已三载！ 老丈啊！"
        },
