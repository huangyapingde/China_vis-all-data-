{
  "script_id": "03033004",
  "title": "过巴州",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "严颜",
      "hangdang": "老生"
    },
    {
      "name": "徐大汉",
      "hangdang": "净"
    }
  ],
  "plot": "刘备统兵入川，诸葛亮命张飞取巴州。张飞与巴州守将严颜率兵大战，相持不下。严颜遂遣卒假扮乡民，混\n进张飞营，虚告入川路径。事为张飞所发觉，将计就计，反令士兵假扮张飞，以赚严颜。结果，严颜果被擒，\n破口大骂。张飞亲手解缚，并与下跪。严颜感于心，乃降，且作入川向导。",
  "notes": "故事源出《三国演义》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套持枪引严颜同上。"
        },
        {
          "character": "严颜",
          "type": "念",
          "text": "辕门外战鼓声催，众儿郎虎豹雄威。奉军令巴州镇守，令鹰鹞插翅难飞。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "老夫、严颜。镇守巴州一带等地。闻得张飞小儿攻打巴州，岂肯容他猖狂！ 众将官！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "迎敌者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引张飞同上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "豹头环眼须似钢，当阳桥前美名扬。大吼一声桥梁断，吓退曹营百万郎。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱、汉将张飞。奉了先生、大哥之命，攻打巴州。 三军的，马来马来！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下手甲带马，张飞上马，张飞、四下手同走圆场。四龙套、严颜同上，同会阵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！来的敢是严颜？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "然！"
        },
        {
          "character": "张飞",
          "type": "三笑",
          "text": "啊哈！啊哈！啊哈哈哈......"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "张飞，为何发笑？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "严颜！我道你是天神下界，原来是一个老匹夫！怎受得某家一战？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "一派胡言！ 众将官，压住阵角！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "一言怒恼严老将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手自两边分下。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "张飞小儿听端详： 巴州之内访一访， 赫赫威名天下扬！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "闻言怒发三千丈， 严颜老儿听端详： 某三气周瑜芦花荡， 大吼一声断桥梁。 劝你早将巴州让， 稍若延迟枪下亡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、严颜同起打，张飞败下，严颜追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且住！严颜老儿来得厉害，再若来时，回马鞭伤他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜上。张飞、严颜同起打，严颜败下，张飞追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "严颜上。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "适才阵前打一仗， 张飞武艺果然强。 催马加鞭高坡上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞接箭下。严颜下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且住！严颜老儿暗放冷箭，不是某马走如飞，险遭不测。 三军的，将巴州围住了！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、严颜同上。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "适才高坡把箭放， 不知张飞生和亡。 将身且坐宝帐上， 唤出老军说端详。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "适才老夫暗放冷箭，不知张飞生死存亡，我不免命老军前去打探。 来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "唤老军进见！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "老军进见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军甲、老军乙同上。"
        },
        {
          "character": "老军甲",
          "type": "念",
          "text": "老军无别干，"
        },
        {
          "character": "老军乙",
          "type": "念",
          "text": "埋锅又造饭。"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "参见总爷！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "唤我二人进帐，有何吩咐？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "命你二人去到张飞营中，探听动静，可敢前去？"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "小人们不敢前去！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "怎么不敢？"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "那张飞杀人不眨眼，小人们不敢前去！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "无妨！待老夫教导你们，他若问时，你就说：“我们是西川巴州好百姓，为母 许愿，去到四川峨眉山烧香还愿。去时，不见千岁扎营在此；回来，千岁扎营 在此，挡住小人的归路。望千岁开一线之恩，放小人们回去，见了妻儿老小， 感激千岁大恩大德！”"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "他要问西川路径呢？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "你就说：南是山，北是水，中间有一蜿蜒小道；骑不得马，坐不得轿，一人步 行，方能过去。"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": "严颜",
          "type": "念",
          "text": "我今吩咐你，"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同念",
          "text": "怎敢误迟延！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军甲、老军乙同下。严颜、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "张翼德在营中自思自叹， 昼夜里战沙场哪得安然。 都只为那张松地理图献， 某大哥一心要夺取西川。 眼望着西川地路途遥远，"
        },
        {
          "character": "四下手",
          "type": "内同白",
          "text": "唔！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "又听得营门外闹嚷声喧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "拿住奸细。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "绑了上来！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！ 将奸细绑上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。四下手绑老军甲、老军乙同上。"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "参见千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "唗！大胆奸细！竟敢前来窥探？推出斩了！"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "且慢！留头讲话！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "我们是西川巴州好百姓，为母许愿，去到四川峨眉山烧香还愿。去时，不见千 岁扎营在此；回来，千岁扎营在此，挡住小人的去路。望千岁开一线之恩，放 小人们回去，见了妻儿老小，感激千岁大恩大德！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我且问你：既是西川百姓，西川路径哪里好走，哪里好行？"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "南是山，北是水，中间有一蜿蜒小道；骑不得马。坐不得轿，一人步行，方能 过去。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "可是实言？"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "句句实言。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好！ 三军的！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "每人赏他们一串铜钱，去吧！"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "多谢千岁！我们回去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军甲、老军乙同出门，同偷听。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军的，随俺老张夜过巴州！"
        },
        {
          "character": "老军甲、老军乙",
          "type": "同白",
          "text": "张飞要夜过巴州。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军甲、老军乙同下。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "还是奸细，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "抓回来！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "去远了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "起过了。 且住！俺老张正在营中用计，又被严颜差来的奸细听得去了。这便如何是好？ 有了：临行之时，先生赐我锦囊一封，打开观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞拆锦囊。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "“先生赐妙计，将军看端倪：若要擒严颜，除非两张飞。”"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呀呀呸！呀呀呸！想这汉营之中，只有老张一人，哪有第二？"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "启禀三千岁！马棚有一草包徐大汉，与千岁面貌相同。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "唤他前来！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "徐大汉进帐！"
        },
        {
          "character": "徐大汉",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐大汉上。"
        },
        {
          "character": "徐大汉",
          "type": "念",
          "text": "咱本一员将，站在草头上。行走如瓜滚，连他娘的母猪赶不上。"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "咱、徐大汉。正在后面铡草喂马。千岁呼唤，不知有何吩咐？待我进帐汇报。 徐大汉告进！参见千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "下跪可是徐大汉？"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "抬起头来！"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "有罪不敢抬头！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀喳！喳！喳！ 三军的，俺老张就是这个样儿？"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "就是这个样儿。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "起来起来！"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "徐大汉，今晚俺老张我要用用你。"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "怎样用我？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "出兵打仗用你。"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "不成将！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "怎么“不成将”？"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "无有盔铠甲。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "赐你半副掩旗甲，披挂去吧！"
        },
        {
          "character": "徐大汉",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐大汉下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军的！今晚俺老张夜过巴州，都要小心，听我吩咐！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "坐在宝帐传将令， 大小三军听分明： 今晚夜过巴州郡， 鞍前马后要小心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐大汉上。"
        },
        {
          "character": "徐大汉",
          "type": "白",
