{
  "script_id": "03053004",
  "title": "打龙袍",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "李后",
      "hangdang": "老旦"
    },
    {
      "name": "宋仁宗",
      "hangdang": "小生"
    },
    {
      "name": "王延龄",
      "hangdang": "老生"
    },
    {
      "name": "陈琳",
      "hangdang": "丑"
    },
    {
      "name": "郭槐",
      "hangdang": "丑"
    }
  ],
  "plot": "包拯放粮回朝，请宋仁宗观灯，故以雷殛张继保灯戏演出。宋仁宗以为谤己，欲将包拯问斩。老太监陈琳备\n述当年狸猫换太子事，宋仁宗始悟，赦包拯，斩郭槐，亲迎李后还朝，李后命包拯行罚。包拯打宋仁宗龙袍\n以代。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "太阳一出金钟鸣，文臣武将朝寡人。万民安乐尧舜世，五谷丰登太平春。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤、大宋天子赵祯。只因陈州干旱三载，也曾命包拯前去放粮，至今未见回朝。 内侍，展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "展放龙门哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "念",
          "text": "忙将包拯事，奏与万岁知。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "臣、王延龄见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平身！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "臣启万岁：今有包拯放粮冋朝，在午门候旨。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "替孤传旨，宣包卿上殿！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "领旨。 万岁有旨：包拯上殿！"
        },
        {
          "character": "包拯",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "忽听传旨宣包拯， 陈州来了放粮臣。 撩袍端带我就上龙廷， 品级台前臣见君。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣、包拯见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平身！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家，将放粮之事奏与朕知！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "现有放粮本章，请我主龙目御览。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗看本章。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家放粮有功，光禄寺摆宴，与卿家贺功。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "为何拦阻？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣在午门外设办花灯，请我主观灯散闷。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家前面安置，孤王御驾随后。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "万岁准了臣的本， 要辩国太受苦情。 午门巧办花灯彩， 办灯打动有道的君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。"
        },
        {
          "character": "王延龄",
          "type": "唱",
          "text": "辞别万岁下龙廷， 不知包拯是何心？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄下。"
        },
        {
          "character": "宋仁宗",
          "type": "唱",
          "text": "包拯回朝奏一本， 去到午门观花灯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "灯官上。"
        },
        {
          "character": "灯官",
          "type": "念",
          "text": "君乐臣乐民安乐，五谷丰登太平年。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "我、灯官便是。奉了包大人之命，在此巧办花灯。远远望见圣驾来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王延龄同上，四太监、大太监引宋仁宗同上，宋仁宗坐。"
        },
        {
          "character": "宋仁宗、包拯",
          "type": "同白",
          "text": "将灯名报上来！"
        },
        {
          "character": "灯官",
          "type": "数板",
          "text": "休要吵，休要闹，细听我把灯名报一报：—团和气灯，二仙和合灯，三阳开泰 灯，四季平安灯，五子夺魁灯，六国封相灯，七擒孟获灯，八仙过海灯，九子 十成灯，十面埋伏灯。这个灯，那个灯，灯名一时报不清。往后瞧，又一层， 吕布、貂婵大闹凤仪亭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花灯上，过场，下。"
        },
        {
          "character": "灯官",
          "type": "数板",
          "text": "往后瞧，又一篇，昭君打马和北番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花灯上，过场，下。"
        },
        {
          "character": "灯官",
          "type": "数板",
          "text": "往后瞧，又一套，青风亭雷击张继保！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花灯上，过场，下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "将办灯人拿下！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "为何阻拦？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "为何将办灯人拿下？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灯官暗下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "为何办这不忠不孝之灯？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "慢说不忠不孝之灯，就是不忠不孝之人，臣朝现有。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家奏来，孤家将他碎尸万段！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣不敢冒奏。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "恕卿无罪！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "就是万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士暗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "宋仁宗",
          "type": "唱",
          "text": "武士将他忙上捆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同绑包拯。四太监、大太监、宋仁宗同下。"
        },
        {
          "character": "王延龄",
          "type": "唱",
          "text": "转面瞒怨小包拯。 有本就该当殿奏， 不该午门藐视君。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "老恩师不必胆怕惊， 学生言来听分明： 自古道忠臣不怕死， 怕死焉能做忠臣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄、包拯同下。四武士随同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大大监、宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "唱",
          "text": "适才午门看花灯， 竟是不忠不孝人。 借题发挥真可恨， 看来有意藐视君。 怒气不息龙廷进， 快宣包拯朝寡人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "包拯拿到。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押上殿来！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "将包拯押上殿来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士押包拯同上。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "大喝一声上绑绳， 午门外来了闯祸臣。 放心大胆我把龙廷进， 问我一言答一声。"
        },
        {
          "character": "宋仁宗",
          "type": "唱",
          "text": "包拯做事不思忖， 不该午门藐视君！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "陈州放粮转回京， 赵州桥前遇冤情： 天齐庙，臣审问， 才知国母受苦情。 口口声声龙国太， 因此午门办花灯。 万岁要将为臣斩， 外国闻知你是无道的君！"
        },
        {
          "character": "宋仁宗",
          "type": "唱",
          "text": "莫非得了疯癫症， 快请名医究原因。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "非是臣得了疯癫症， 国太言语记得清。 千言万语你不信， 景阳宫问一问，二十年前的老陈琳。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士押包拯同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "金牌宣，银牌召，宣亚父陈琳上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "金牌宣，银牌召，宣亚父陈琳上殿哪！"
        },
        {
          "character": "陈琳",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈琳上。"
        },
        {
          "character": "陈琳",
          "type": "唱",
          "text": "金牌宣来银牌召定， 景阳宫来了老陈琳。 二十年也未曾将我宣定， 今日宣召为何情？ 迈步且把金殿进， 万岁驾前问安宁。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢、陈琳见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "亚父平身！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "赐坐！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "谢坐！二十余年未曾宣召，今日宣奴婢上殿，有何国事议论哪？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤有一事不明，要在亚父台前领教。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "万岁有何事不明，当面请讲，何言“领教”二字？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤王是哪宫所生，哪宫所养？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "我主乃李娘娘所生，狄娘娘所养。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "可曾全记？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢全记。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "奏来！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏！只因癸未年间，李娘娘身怀我主龙体，宫中刘妃在老王面前讨下一道收 生代劳的旨意。哪里是收生代劳，原来是一条奸计——她与内侍郭槐乃是姑表 之亲，命郭槐将外国进来的金色狸猫剥去皮尾，换了我主龙体，在老王驾前奏 道：李娘娘产生妖怪。老王闻奏大怒，将李娘娘推出午门斩首。多亏满朝文武 保奏下来，死罪已免，活罪难容，将李娘娘打在寒宫冷院。那刘妃一计不成， 与郭槐又生二计——定于八月十五日火焚冷宫。但见火光一起，也不知李娘娘 生死存亡。此事约有二十余载，今日怎么问起奴婢来了？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只因包拯回朝，言说母后还在。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "既然国母还在，就有当年老王游御花园所赐黄绫诗帕，上有寇老先生所题诗句 为证。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "可曾全记？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢全记。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "奏来！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏！"
        },
        {
          "character": "陈琳",
          "type": "念",
          "text": "春风得意花千蕊，秋月扬辉桂一枝。天降紫微接宋后，一对行龙并雄雌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈琳四看。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "看什么？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "包拯回朝，不在金殿奉君，万岁差他哪里去了？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "亚父有所不知，只因包拯还朝，在午门设摆花灯，藐视孤王，已推出午门问斩。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "陈琳",
          "type": "唱",
          "text": "万岁要斩将奴婢斩， 快快赦回有功臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "将包拯赦回。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "包拯赦回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "百尺高竿得活命， 千层浪里又复生。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁不斩之恩！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "非是孤王不斩于你。你道母后还在，有何为证？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "现有黄绫诗帕为证。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯呈帕，宋仁宗看。"
        },
