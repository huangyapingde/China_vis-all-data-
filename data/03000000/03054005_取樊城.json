{
  "script_id": "03054005",
  "title": "取樊城",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "徐庶",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "曹仁",
      "hangdang": "净"
    }
  ],
  "plot": "徐庶投刘备，拜为军师。曹操遣吕旷、吕翔攻新野；徐庶派张飞、赵云杀之。曹仁、李典复倾樊城之兵来犯，\n亦为赵云等大破。曹仁败归樊城，而樊城早为关羽所得。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。四文堂、二青袍抬酒引孙乾同上。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "俺，孙乾。奉了主公之命，长亭备宴，与公子刘琦饯行。 来，打道长亭！"
        },
        {
          "character": "四文堂、二青袍",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内唱",
          "text": "叔侄同出新野城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四上手、简雍、糜竺、糜芳、关羽、张飞引刘备、刘琦同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "为叔与侄亲送行。 并马同行把话论， 恨只恨蔡瑁嫉妒心。 席前暗把刀兵隐， 为叔看破巧计生。 这匹的卢快的紧， 跳跃潭溪万丈深。"
        },
        {
          "character": "刘琦",
          "type": "唱",
          "text": "倒是叔父有福份， 方得此马有救星。 又道是邪不能侵正， 吉人天相话果真。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "来在长亭下金镫，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾、四文堂、二青袍同上，孙乾看酒。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "我与贤侄来饯行。 但愿你父身无病， 福寿长春多康宁。 相劝贤侄多谨慎， 继母台前加殷勤。 早晚之间多孝顺， 免叫你父两难心。 贤侄请来把酒饮， 饮毕急速转回程。"
        },
        {
          "character": "刘琦",
          "type": "唱",
          "text": "谢过叔父多恭敬， 感念待侄厚恩情。 辞别叔父上能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同带马，同下。"
        },
        {
          "character": "刘琦",
          "type": "唱",
          "text": "叔侄在此把路分。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘琦下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "刘琦上马心难忍， 席前对我叙伤情。 蔡氏心毒意又狠， 只恐刘琦丧残生。 大事次子来拿定， 难免孙、曹动刀兵。 大家齐把雕鞍整， 人马纷纷进东门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "日前水镜来指引， 急速投奔新野城。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "俺，姓徐名庶，字表元直。乃颍州人氏。只因抱打不平，伤害人命，是我用粉 涂面披发而逃，改名单福，流落他乡，遍访名师，结交良友，讲天论地，说王 讲霸，虽无移山倒海之能，实有经天纬地之手。只因那一日在水镜先生家借宿， 那司马德操指引于我，转来新野，投奔刘备。远远望见玄德公人马来也。待 我在此吟歌，打动于他便了！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "将身站立且候等， 吟歌打动他人听。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四上手、简雍、糜竺、糜芳、关羽、张飞引刘备同上。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "天地反复， 人类欲殂； 大厦将倾， 一木难扶。 四海有贤， 要投明主； 圣明礼贤， 却不知吾。"
        },
        {
          "character": "徐庶",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备听，点头，想。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "勒住丝缰来观定， 不由心中暗沉吟。 看这先生非凡品， 歌语清奇品貌尊。 水镜先生对我论， 凤雏、卧龙二贤臣。 二位贤臣并相请， 汉家基业定重兴。 莫非今日巧相遇， 卧龙、凤雏有一人。 弃镫离鞍下能行， 走向前来礼相迎。 方才歌词妙得紧， 足见台驾甚高明。 光临新野三生幸， 不才眼内少识人。 刘备前来把驾请， 略进粗茗表寸心。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "哎呀，不敢当！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "萍水相逢怎相肯， 不才是个白衣人。 既承呼唤我遵命， 高攀大驾现丑行。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "你我挽手衙署进， 众位将军随后跟。 来到衙署先生请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同挖门，刘备站小边，徐庶站大边。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "重新见礼分主宾。 左右快把茶来敬，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "带笑开言把话云。 请问仙乡居何境， 尊姓高名备愿闻。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "若问在下名和姓， 祖籍原是颍州人。 姓单名福元直号， 皆因久闻使君名。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "贫道久闻使君招贤纳士，特来相访，未敢轻自造次，故尔狂歌于市。幸遇明公 不弃，实遂我平生之愿也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备想。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，是了。告便。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备背供。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "喂呀，那晚水镜先生家来了一人借宿，是我窃听，水镜先生把那人以元直称之， 原来却是此人，想来是一位大贤也，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备向徐庶。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "哈哈哈……使君，方才愚下见明公所骑之马，望乞明公赐在下一观，不知肯否？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这有何妨。左右，把马揭去鞍辔，拉了上来，与单先生观看。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同下，同拉马上。徐庶看马。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "明公，此马名为的卢，有千里脚程。但只一件！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "这匹马定妨主人，不知此话是与不是？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "此话应验过了。此马乃江夏逆叛张武坐骑，张武死于阵前；日前马跳潭溪，全 仗此马。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "张武是它妨死，越潭是它功绩。日后此马还要妨主。我有一法，永无妨碍。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "公有何法，恳求指教？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "此法轻易不传与人。将此马送与相好的朋友，他骑妨死了他，明公再骑，永久 安稳。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哈哈哈……看茶来，这位客人还要趱路，此处地方窄小，也不敢相留尊驾，有 误途程！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "哈哈哈……明公啊！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "带笑开言自夸奖， 尊声明公听端详： 素闻使君宽洪量， 招贤礼士果非常。 不远千里来投往， 如此轻慢为哪椿？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备不才，虽不敢言招贤纳士，却也识人。并非面憎尊驾。汝初到新野，理该教 我行好事，作好人，才是正理；却怎么反教我损人利己？我若用你言，坏我一 世声名。我这里用你不着，请！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "哈哈哈……哎呀，怪不得人人都说明公广行仁德，是我不肯深信，故用此言相 试。果然如此，可见得话不虚传。明公有如此海量，何愁霸业不成！我愿尽力 扶保，共成大事！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "腹中暗自赞水镜， 所说之言俱是真。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "品貌不俗多端正， 水镜先生认识人。 鸾凤展翅飞腾起， 人伴贤良智略深。 为何单提马妨主？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，是了！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "想必试探我的心。 先生此话果真应， 祸福共之永不分。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我刘备就拜你为军师，执掌新野大军。 来，看宴伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。文堂甲看酒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请！ 众位将军请！"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同饮酒。〖牌子〗。"
        },
        {
          "character": "探子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启主公：樊城发兵前来，离城不远。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，先生啊！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "前者探马来禀报， 曹操遣将镇樊城。 要图荆襄两城郡， 虎视湖广起贪心。 今日发兵来犯境， 定是先取新野城。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "兵来将挡古明论， 速派大军退敌人。 明公听我传将令， 护卫新野众黎民。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "但凭军师。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "张将军近前听密令， 速去挑选一千兵。 离城百里埋伏隐， 曹兵来时休战征。 待等曹兵败了阵， 奋勇杀敌莫消停。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "先生命我把兵领， 曹兵败阵照此行。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "急忙再传二支令， 尊声常山赵将军： 挑选精军一千整， 攻打头阵起战争。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "遵奉将令挡头阵， 奋勇杀贼退敌人。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "安排兵将新野镇， 拦挡樊城众曹兵。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "保护城池防范紧， 且听探马报信音。 先生到此备侥幸， 全仗你的韬略精。"
        },
        {
          "character": "刘备、徐庶",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四下手、四将官、吕旷、吕翔同上。"
        },
        {
          "character": "吕旷、吕翔",
          "type": "同念",
          "text": "奉命统领貔貅将，新野城外动刀枪。"
        },
        {
          "character": "吕旷、吕翔",
          "type": "同白",
          "text": "俺，（吕旷）（吕翔）。"
        },
        {
          "character": "吕旷",
          "type": "白",
          "text": "贤弟请了！"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "兄长请了！"
        },
        {
          "character": "吕旷",
          "type": "白",
          "text": "你我二人奉了曹仁将军命令，攻取新野，离城三十余里，看前面来了一支人马， 必是新野兵将。你我迎上前去！"
        },
        {
          "character": "吕翔",
          "type": "白",
          "text": "言之有理。 众将官，杀！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠、四上手、赵云同上，会阵。"
        },
        {
          "character": "吕旷",
          "type": "白",
          "text": "呔！尔是何人，敢挡某家去路？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "尔且听了！吾乃常山赵子龙是也！二贼留名！"
        },
        {
          "character": "吕旷",
          "type": "白",
          "text": "吾乃曹营大将吕旷！赵云休走，看枪！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哈哈哈……尔乃无名之将，敢与某家交战？若容尔走上两个回合，不为英雄也！"
        },
        {
          "character": "吕旷",
          "type": "白",
          "text": "一派胡言！放马过来！"
        },
        {
          "character": null,
          "type": "stage",
