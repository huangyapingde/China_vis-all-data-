{
  "script_id": "03004001",
  "title": "别宫祭江",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "孙尚香",
      "hangdang": "旦"
    },
    {
      "name": "吴国太",
      "hangdang": "老旦"
    }
  ],
  "plot": "蜀、吴失和之后，刘备妻孙尚香被留东吴，迨闻刘备战败，病死白帝城，孙尚香决志殉夫，乃入宫别母，要\n求临江设祭。力争之下，始得允许。孙尚香祭奠后，即投江以殉。",
  "notes": "《别宫》、《祭江》是两折紧连的节目，故事出于《三国演义》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫娥引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "引子",
          "text": "恹恹瘦损，怎能消，终日愁闷。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "别君常挂念，难忘夫妻情。虽无千丈线，万里系人心。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "哀家孙氏尚香。只因兄王为讨荆州，定下胭粉之计，将我招赘刘备，不想以假 成真。未及三载，他君臣又生一计，命人将我诓回东吴。思想起来，好不愁闷 人也。"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "孙尚香坐皇宫自思自想， 想起了刘皇叔好不惨伤。 遭不幸我父王龙归海藏， 仲谋兄承父业执掌朝纲。 坐江南据九郡贪心妄想， 他君臣定巧计要夺荆襄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫娥同上。"
        },
        {
          "character": "二宫娥",
          "type": "同白",
          "text": "启公主：大事不好了！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "二宫娥",
          "type": "同白",
          "text": "今有刘贤主，晏驾白帝城了！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "二宫娥",
          "type": "同白",
          "text": "晏驾白帝城了！"
        },
        {
          "character": "孙尚香",
          "type": "三叫头",
          "text": "皇叔！夫君！哎呀夫啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香气椅。"
        },
        {
          "character": "孙尚香",
          "type": "西皮导板",
          "text": "听一言只觉得神魂飘荡，"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "不由得尚香女泪洒胸膛。 实指望夫妻们同欢同畅，"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "皇叔哇……"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "要相逢除非是梦里黄粱。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且住。想皇叔与我有夫妻之义，他今晏驾白帝城，不免身穿孝服，去到江边一 祭便了。 宫娥们！"
        },
        {
          "character": "二宫娥",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "看孝服伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香换孝服。"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "宫娥女速摆驾长寿宫往， 别母后到江边祭奠一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香、四宫娥同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "吴国太",
          "type": "内西皮导板",
          "text": "一日偷闲一日安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二内侍引吴国太同上。"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "十日无事靠青天。 孙权他把大事管， 每日征战不得闲。 可恨曹丕把位篡， 图谋汉室锦江山。 我的婿刘备重兴汉， 三国纷纷有数年。 将身且坐皇宫院， 等候我儿来问安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上。"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "叹汉皇为社稷今把驾晏， 含悲泪进宫去参母问安。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "儿臣见驾，愿母后千岁！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "谢坐。喂呀呀……"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿啊，今日进宫，身穿素服，脸带泪痕，为了何事？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "启奏母后：今早宫人报道，刘皇叔晏驾白帝城了。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哦，刘皇叔晏驾了？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "唉，可叹哪，可叹！儿啊，你进宫何事？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "因此儿臣身穿孝服，奏知母后，要到江边一祭。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿啊，你虽然与他有夫妻之情，只是你兄王与他有敌国之恨，儿还祭奠他作甚？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "唉，母后啊！"
        },
        {
          "character": "孙尚香",
          "type": "西皮慢板",
          "text": "母后说话理太偏， 儿臣有本奏根源： 都只为荆州讨不转， 将儿定计把姻联。 荆州未及三年满， 又命周善诓儿还。"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "尚香儿说话理不端， 细听为娘说根源： 不幸儿父他把驾晏， 早年一命丧黄泉。 丢下基业无人管， 江南九郡付与孙权。 今日杀来明日战， 只为荆州他不还。 定计本是周郎献， 才把我儿配凤鸾。 劫儿回国是周善， 母女分别又团圆。 我儿一心去祭奠， 一滴何曾到九泉。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后啊！"
        },
        {
          "character": "孙尚香",
          "type": "西皮垛板",
          "text": "说什么祭奠空祭奠， 一滴何曾到九泉。 儿在东吴他在汉， 千里姻缘一线牵。 母后不叫儿祭奠， 不该与儿配婚男。"
        },
        {
          "character": "吴国太",
          "type": "西皮垛板",
          "text": "我儿本是闺阁女， 反道为娘来阻拦。 任儿说得莲花现， 为娘不准也枉然。"
        },
        {
          "character": "孙尚香",
          "type": "西皮垛板",
          "text": "儿要祭奠偏祭奠，"
        },
        {
          "character": "吴国太",
          "type": "西皮垛板",
          "text": "为娘阻拦要阻拦。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孙尚香",
          "type": "西皮垛板",
          "text": "母后不叫儿祭奠，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "孙尚香",
          "type": "西皮垛板",
          "text": "不如碰死娘面前。"
        },
        {
          "character": "吴国太",
          "type": "西皮垛板",
          "text": "我儿不必行短见， 为娘送你到江边。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "我儿不必如此，为娘同儿去江边一祭如何？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后年迈，不劳前去。现有宫娥陪伴，儿去去就回。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "内侍！"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "看半副銮驾，随你郡主去到江边一祭；千万不可叫你主公知道。"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后请上，儿臣就此拜别了！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哎呀儿啊，不过一时，何言“拜别”二字？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后啊……"
        },
        {
          "character": "孙尚香",
          "type": "西皮二六板",
          "text": "虽然暂离母后前， 为人需要孝当先。 辞别母后出宫院，"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "我儿要早去早回！"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "有泪不敢洒面前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "我儿江边去祭奠， 只怕要学古圣贤。 将身且坐皇宫院， 盼望娇儿早回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴国太、二内侍同下。"
        },
        {
          "character": "吴国太",
          "type": "stage",
          "text": "《祭江》"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第一场",
      "utterances": [
        {
          "character": "孙尚香",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四内侍、二宫女、车夫引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "二黄慢板",
          "text": "曾记得当年来此境， 浪打鸳鸯两离分。 从今后我不照菱花镜， 清风一线未亡人。"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "来在江边。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "香案摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祭奠毕。孙尚香脱衣。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四内侍、二宫女、车夫自两边分下。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "设祭长江岸，举目到西川。梦魂何日到，空教泪不干。"
        },
        {
          "character": "孙尚香",
          "type": "二黄导板",
          "text": "在江边摆祭礼一声告禀，"
        },
        {
          "character": "孙尚香",
          "type": "三叫头",
          "text": "皇叔！先主！哎呀夫哇……"
        },
        {
          "character": "孙尚香",
          "type": "回龙",
          "text": "尊一声汉皇叔在天之灵。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "好夫妻恶姻缘悲声不尽， 半空中须鉴妻一点诚心。 可叹你大英雄出世受困； 可叹你结桃园义共死生； 可叹你破黄巾功劳被隐； 可叹你虎牢关方显威名； 可叹你跳檀溪险些丧命； 可叹你三顾那诸葛先生； 可叹你败当阳夏口来奔； 可叹你烧赤壁同破曹兵； 可叹你占荆州周郎不忿；周郎不忿，我的夫哇！ 可叹你入虎穴东吴招亲。 好容易得西川坐立未定， 偏遇着战荆州二叔归神。 为报仇战猇亭遇着陆逊， 失计谋被他人火烧连营。 空负了五虎将九泉含恨， 空负了诸葛亮赤胆忠心。 看起来叹人生总是梦境， 必须要图一个万古留名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香祭奠毕。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且住。想我兄长，既不能容我，为妹此时不随皇叔一死，更待何时！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水旗同上。"
        },
        {
          "character": "孙尚香",
          "type": "反二黄摇板",
          "text": "江水茫茫波浪滚， 孙氏拜别养育恩。 叫声皇叔你且等，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "孙尚香",
          "type": "反二黄摇板",
          "text": "不如一死命归阴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香跳江，孙尚香、四水旗同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四水旗、龙王、孙尚香同上。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "敕旨下。跪！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "圣寿。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "今有孙尚香在江边为夫尽节，投江而死。蒙上帝怜悯，敕为枭矶娘娘。旨意度 罢，望诏谢恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香接旨。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "圣寿无疆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香换衣。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "众水卒！"
        },
        {
          "character": "四水旗",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "同我归位去者！"
        },
        {
          "character": "四水旗",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}