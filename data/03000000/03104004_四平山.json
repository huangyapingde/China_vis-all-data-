        {
          "character": "四龙套",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "李元霸、柴绍",
          "type": "同五马江儿水",
          "text": "但把烟尘齐扫， 永壮千秋， 不愧芳名贯九州。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "四舅，瓦岗有个秦叔宝你可知道？"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "临行之时，母亲再三嘱咐，道他是俺全家的大恩人，叫我千万不要伤他。可是 此人？"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "正是此人。那秦恩公最重义气，若是伤了他的朋友，犹如伤他一般。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "我怎能知晓他的朋友是何等模样？"
