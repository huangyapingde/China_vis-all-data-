        {
          "character": "柴绍",
          "type": "白",
          "text": "彼此。瓦岗弟兄近日可好？"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "他等好！着愚兄赶来致候。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "岂敢！只是我四舅元霸奉旨而来，他勇不可当，唯恐有伤瓦岗弟兄。这便怎么 处！"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "实不相瞒，愚兄奉徐军师之命，到此面见贤弟，商量个保全之计。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "若要保全么，附耳过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柴绍与尤俊达耳语。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "徐军师照此吩咐，管保无碍。"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "哦！是是是！承教了。告辞！"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "尤俊达",
          "type": "念",
          "text": "相逢才刹那，"
        },
        {
          "character": "柴绍",
          "type": "念",
          "text": "行色又匆匆！"
        },
        {
          "character": "尤俊达、柴绍",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤俊达下。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "啊四舅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李元霸上。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "啊姐丈，适才来者是谁？"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "哦！是来探听四舅几日可到，我已令他归报去了。看天色已晚，暂且扎营，明 日再行。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "儿郎的！"
