        {
          "character": "尤俊达",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐懋功、尤俊达自两边分下。"
        }
      ]
    },
    {
      "scene_id": 4,
