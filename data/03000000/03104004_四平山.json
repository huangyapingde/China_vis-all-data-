    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、齐国远、李如珪、王伯当、尤俊达、秦琼、裴元庆引徐懋功同上。徐懋功登高台。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "众位弟兄！"
        },
        {
          "character": "齐国远、李如珪、王伯当、尤俊达、秦琼、裴元庆",
          "type": "同白",
          "text": "军师！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "今有杨广召李元霸前来解围，此人勇不可当，我等欲罢不能。今日众位出战， 每人头插黄旗一面，方保无碍。"
        },
        {
          "character": "齐国远、李如珪、王伯当、尤俊达、秦琼",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "裴元庆",
          "type": "白",
          "text": "慢着！"
        },
        {
          "character": "裴元庆",
          "type": "念",
          "text": "未见强和弱，闻言心不平！"
        },
        {
          "character": "裴元庆",
          "type": "白",
          "text": "军师！那李元霸有何惊人之勇，你为何这般畏惧行事？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "他的英勇不要说是我们瓦岗，就是普天之下的好汉，也无有胜似他的！"
