        {
          "character": "裴元庆",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "裴元庆",
          "type": "点绛唇",
          "text": "是甚英豪，便称扬其枭？未见阵，话属虚谣，何故将人藐！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "休言虚谣，到时便见。 叔宝听令！"
