{
  "script_id": "03104004",
  "title": "四平山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "李元霸",
      "hangdang": "武生"
    }
  ],
  "plot": "隋炀帝被围四平山，召李元霸勤王。李渊知秦琼在瓦岗，念秦琼有临潼解围之恩，虑被李元霸所伤，乃遣柴\n绍同行，并使李元霸往斋堂别母。李母闻知，悬秦琼画像，告李元霸以临潼往事，嘱其如遇秦琼不可伤犯。\n徐懋功知李元霸来攻，大惊，急遣尤俊达往会柴绍。柴绍请瓦岗诸将头插黄旗为记，以便临阵避让。秦琼等\n均依计而行，唯裴元庆恃勇不从。及交战，李元霸大败各路兵将，惟见秦琼等即避去。后遇裴元庆，李元霸\n击以三锤，裴元庆不敌，败走。杨林截击，裴元庆大败杨林后，以羞见瓦岗诸将，策马他往。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "大太监",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、大太监同上。"
        },
        {
          "character": "大太监",
          "type": "侥侥令",
          "text": "烟尘委实强， 谁个把他降？ 眼见圣躬无倚仗。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "咱家，随宫太监是也。只因万岁被众反寇围困四平山，无敌大将军不能退敌， 令咱家星夜赶赴太原，召取赵王李元霸护驾勤王。看前面已是晋阳，快快加鞭 哪！"
        },
        {
          "character": "大太监",
          "type": "侥侥令",
          "text": "召英雄去勤王！ 召英雄去勤王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。院子暗上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "圣旨下！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启爷：圣旨下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、李元霸同上。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "香案接旨！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "圣旨下！跪！"
        },
        {
          "character": "李渊、李元霸",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "诏曰：朕为南幸，行至四平山，突被群寇阻住。特召赵王李元霸，星夜前往勤 王，令到即行。钦哉！"
        },
        {
          "character": "李渊、李元霸",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "王爷！"
        },
        {
          "character": "李渊、李元霸",
          "type": "同白",
          "text": "公公！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "皇上盼救兵甚急，务须早早而行。咱家可先复命去啦！"
        },
        {
          "character": "李渊、李元霸、大太监",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四校尉引大太监同下。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "儿呀！你今既受君命，理难耽迟。看尔武艺尽可去得，只是军机进退全凭谋略， 着尔姐丈柴绍与你搭伴同往，凡事若有不决，必须与他计议。天下英雄俱皆 不可轻放，只有那瓦——"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "爹爹为何欲言又止？"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "尔行色匆匆，不便细讲。且去辞别尔母，即便启程。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "李元霸",
          "type": "念",
          "text": "前堂辞严父，后庭别萱堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李元霸下。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "唉！想我当年临潼被劫，若非秦琼仗义，怎能保得全家。近闻他投入瓦岗，欲 将此情对元霸说知，只是国家大事，断难以私废公。若不暗地护他，又恐负他 大恩。这便怎么处！有了。 来！有请郡马爷！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是！ 有请郡马爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柴绍上。"
        },
        {
          "character": "柴绍",
          "type": "念",
          "text": "奋臂千山振，英勇百战强。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "岳父！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "贤婿！适有御令到来，召元霸赶往四平山退贼。但他年小，不谙谋略，要你搭 伴同往，凡事望你指点一二。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "小婿遵命！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "近闻秦恩公投在瓦岗，元霸不知底细，亦望贤婿留意，勿负他昔日深恩。"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "小婿自当留意。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "元霸内堂辞母，你也去收拾去吧！"
        },
        {
          "character": "柴绍",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "李渊",
          "type": "念",
          "text": "公私实难罄，"
        },
        {
          "character": "柴绍",
          "type": "念",
          "text": "恩怨要分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、柴绍自两边分下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场悬秦琼画像。李夫人上。"
        },
        {
          "character": "李夫人",
          "type": "解三酲",
          "text": "见亭台芳菲遍旺， 看衔泥紫燕双双。 那羽禽尚尔知依傍， 人岂可义相忘！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "妾身，窦氏。适闻王命到来，召元霸前去退贼。那秦恩公现在瓦岗，恐元霸到 彼相犯。为此，斋堂等待，候他进来辞我，我将始末对他说知，免致有伤恩公。"
        },
        {
          "character": "李夫人",
          "type": "解三酲",
          "text": "虽言国事难轻忘， 无如深恩当报偿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李元霸上。"
        },
        {
          "character": "李元霸",
          "type": "解三酲",
          "text": "绕回廊， 为召命难辞，来别萱堂。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "全身披挂，将欲何往？"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "启禀母亲：只为皇上被众反王困在四平山，特召孩儿前去退贼护驾。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "儿可知反王是哪几家？"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "孩儿曾见朝报，还记得几家。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "哪几家呢？"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "河北李子通，山后刘武周，瓦岗程咬金。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "瓦岗有个秦叔宝，儿可认得？"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "儿和他并无半面之识，却不认得。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "诺！这画上面的人儿便是！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "哦！儿道母亲供的是何神圣，每日焚香礼拜，原来供的是个强盗。哎！好没来 由。这样人供他做甚，待孩儿把他抓了下来！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "住手！他是我全家的大恩人，儿休得无礼！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "他对我家有何恩处呢？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "儿且坐下，听为娘道来！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "请母亲详示。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "当年先皇文帝议立今上储位，尔父曾经谏阻，先皇不听，卒竟立之。尔父恐祸 生不测，便告归田里。好个先皇，不弃功臣，授尔父为太原节度，即刻起行， 不料走到那临潼山啊！"
        },
        {
          "character": "李夫人",
          "type": "解三酲",
          "text": "一霎时喊声震荡， 突闪出无数强梁。 人喊马嘶骤行抢， 哪得脱祸免殃！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "啊！我家难道无有家将保护么？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "那时尔大哥幼小，二哥未生。虽有几名家将，无奈强梁甚众，何能济事！可叹 尔父杀前不能顾后，遮左不能挡右噢！"
        },
        {
          "character": "李夫人",
          "type": "解三酲",
          "text": "缘何保得全无恙， 看看全家要遭殃！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "哎呀！那时便怎么处呢？"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "诺！幸遇画上这位恩人，亏他一马双锏，把那些贼众啊！"
        },
        {
          "character": "李夫人",
          "type": "解三酲",
          "text": "打得来魂飘荡， 好似犬羊遇虎个个逃亡！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "喳喳喳，唔呼呀！若无此人救我全家，俺元霸还在那前世前生，何得能够出世， 此真是莫大之恩。待俺先来拜他几拜！"
        },
        {
          "character": "李元霸",
          "type": "解三酲",
          "text": "恕鲰生无有识人量， 相见甘心负荆杖。 躬身礼叩音容像， 从此后永铭不忘。"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "儿呀！此去若见恩公，千万不可相犯！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "谨遵母命！"
        },
        {
          "character": "李夫人",
          "type": "白",
          "text": "还有一言。你退了群雄之后，可叫你二哥从速搭伴回来。免娘悬望！"
        },
        {
          "character": "李夫人",
          "type": "解三酲",
          "text": "记我终朝倚望， 解了重围即回乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李夫人下。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "啊！哦！待我来仔细认他这么一认。喳、喳、喳、呀！"
        },
        {
          "character": "李元霸",
          "type": "解三酲",
          "text": "真雄壮， 只见他身粗面黄非比寻常！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李元霸下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "笑",
          "text": "嘻哈哈哈……"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "一阵全得胜，昏君奈若何！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "孤家，程咬金。喜得前番一战，打败宇文成都。昏君倒退四十馀里，正要火速 去擒杨广，徐懋功说恐怕中了他的诱兵之计，那时非但不能擒拿杨广，反而要 损伤各路兵将，故而停战。且候他几天再说吧！"
        },
        {
          "character": "徐懋功",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐懋功上。"
        },
        {
          "character": "徐懋功",
          "type": "滴溜子",
          "text": "探马儿，探马儿， 适才报道： 这回合，这回合， 谁做对手， 眼见将兵休！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "参见主公！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "嗯！看这光景，你又有什么词儿吧？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "启主公：大事不好了！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "有什么话你就老实说吧，别耍诈啦！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "适才探马报道：隋家救兵已到，闻听来将勇不可当，只恐各营无有对手。这便 怎么处！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你说的是谁呀？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "乃唐公李渊的四子，名叫李元霸。可算是当今第一好汉！"
        },
        {
          "character": "程咬金",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "宇文成都那般英勇，尚且被我小舅子裴元庆打得像乌龟一般，连头也不敢露， 还惧什么李元霸！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "那李元霸武艺胜过宇文成都十倍，裴元庆何能胜得过他！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "他厉害？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "厉害！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "他厉害！孤叫一十八路诸侯全都出马，难道还敌他不过吗！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "慢说一十八路诸侯，便将六十四家烟尘一齐出动，也要被他打得尸山血海！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎哟！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "啊！主公怎么样了？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你……别吓唬我成不成？"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "臣不敢虚言谎奏。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎呀！这可怎么好啊！快快与孤收兵，退回瓦岗！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "无故收兵，岂不被天下英雄耻笑！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "嗳！战又无人抵对，收又不能收兵，这可怎么好哇！干脆，三哥！这是我的命 小福薄，这个平天冠给你戴吧！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "那如何使得！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎呀！你这不是巢父洗耳，视天下将为敝屣乎！呵呵！真要急煞寡人了！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "臣有一计，可保瓦岗人马无恙，待要与主公商议。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "事在燃眉，有什么商量的呢！只要保得众家弟兄无碍也就结啦！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "如此，臣去办来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你先等等！你平日是最说理的，可知道主辱臣死吗？"
