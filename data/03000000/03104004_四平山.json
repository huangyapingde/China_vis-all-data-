        {
          "character": "徐懋功",
          "type": "白",
          "text": "命你冲杀一阵。李元霸委实骁勇，插了黄旗，可保无伤！"
        },
        {
          "character": "裴元庆",
          "type": "白",
          "text": "喳，喳，喳！军师！俺裴元庆七岁打虎，九岁便能冲锋。两柄银锤不知打死多 少上将，慢说李元霸是个人，他就是天上的蛟龙，俺也要打——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖冲头〗。"
        },
        {
          "character": "裴元庆",
          "type": "白",
          "text": "打落他的爪。教俺插甚黄旗，灭俺的锐气！"
        },
        {
          "character": "裴元庆",
          "type": "么篇",
          "text": "免轻言将人恼， 把元庆比众曹。 怎叫俺隐名藏颜遵什么教， 某也不惜生插那黄旗号！ 但看俺上阵杀敌追猛骁， 请静听谁高谁下分白皂！"
        },
        {
          "character": "徐懋功",
          "type": "念",
          "text": "休言自己力勇，未见他人高强！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "今日此战难免尸横遍野，血流成渠。我瓦岗仗此黄旗，可保无虞，休要执性， 还是领旗上！"
        },
        {
          "character": "裴元庆",
          "type": "白",
          "text": "军师！"
        },
        {
          "character": "裴元庆",
          "type": "煞尾",
          "text": "恁便有通灵耳先知晓， 怎知俺心如铁断难摇！ 只叫他见俺丧胆， 看旗开得胜夺豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴元庆下。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "收拾旗仗，护送主公，回归瓦岗。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人自两边分下。"
        }
      ]
    },
    {
