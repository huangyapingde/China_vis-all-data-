        {
          "character": "李元霸",
          "type": "五马江儿水",
          "text": "机关紧收，机关紧收， 免使群寇效尤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李元霸、柴绍同下。"
        }
      ]
