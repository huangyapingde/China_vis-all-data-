        {
          "character": "齐国远、李如珪、王伯当、尤俊达",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "各插黄旗，小心迎战！"
        },
        {
          "character": "齐国远、李如珪、王伯当、尤俊达",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐国远、李如珪、王伯当、尤俊达同下。"
        },
        {
          "character": "裴元庆",
          "type": "白",
          "text": "咦！"
        },
        {
          "character": "裴元庆",
          "type": "天下乐",
          "text": "抵多少左右分兵，也那非按条， 便施谋，谋也不高。 效不得下楼船王濬建功劳， 怎割得魏武袍？ 又不灭虞诩灶， 哪里是众火牛比得复齐豪！"
        },
        {
          "character": "徐懋功",
          "type": "白",
          "text": "裴元庆听令！"
        },
        {
          "character": "裴元庆",
          "type": "白",
          "text": "在。"
