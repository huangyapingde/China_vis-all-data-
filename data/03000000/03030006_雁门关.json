      "hangdang": "老生"
    },
    {
      "name": "杨延顺",
      "hangdang": "小生"
    },
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "碧莲公主",
      "hangdang": "旦"
    },
    {
      "name": "青莲公主",
      "hangdang": "旦"
    },
    {
      "name": "韩昌",
      "hangdang": "净"
    }
  ],
  "plot": "萧太后将杨延辉等绑至城楼行刑，佘太君闻讯，亦将碧莲、青莲二公主绑至城下。杨延辉、杨延顺分别于城\n上、城下求情，均无结果。杨延昭赶来，欲攻打城池，萧天佐见宋营兵山将海，始将萧太后劝回，宣布停刑。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵引韩昌同上。"
        },
        {
          "character": "韩昌",
          "type": "引子",
          "text": "南争北战，扫汴梁，夺取中原。"
        },
        {
          "character": "韩昌",
          "type": "念",
          "text": "三尺青锋耀雪光，腰悬明月箭弓张。葡萄美酒胭脂血，貂裘花添锦绣裳。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "某、韩昌。北国为臣。与宋室争战数载，干戈不宁。元帅出兵，不见回营。 巴图鲁！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！ 韩昌　　　伺候了！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵引耶律休哥同上。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "元帅大战宋兵胜败如何？"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "哎呀驸马呀！杨家兵将，甚是骁勇。谢苗、张猛死于阵前，眼见宋兵已到。驸 马快定良策迎敌才是！"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "啊？怎么二将阵亡，宋兵眼看就要杀奔大营来了！哎呀！何人敢去迎敌？"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "待某帐下问来。 呔，下面听者：眼看宋朝兵马要踏我营，有胆量出战者，上帐讨令！"
        },
        {
          "character": "耶律古",
          "type": "内白",
          "text": "耶律古愿往！"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "随令进帐！"
        },
        {
          "character": "耶律古",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "耶律古上。"
        },
        {
          "character": "耶律古",
          "type": "念",
          "text": "纵马抡枪杀气生，将军立志建奇功。战鼓咚咚惊人胆，两军阵前破敌兵！"
        },
        {
          "character": "耶律古",
          "type": "白",
          "text": "某、耶律古。随元帅征战杨家，命某看守大营。适才我军大败而回，元帅传令 下来，有人敢敌杨家兵将，进帐讨令！ 报！耶律古告进！驸马、元帅在上，末将打躬！"
        },
        {
          "character": "耶律休哥、韩昌",
          "type": "同白",
          "text": "你愿去抵挡杨家兵将么？"
        },
        {
          "character": "耶律古",
          "type": "白",
          "text": "非是末将夸口，任他有百万人马，俺一人也要杀他个片甲不回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "宋将在营外讨战！"
        },
        {
          "character": "耶律休哥、韩昌",
          "type": "同白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！ 中国京剧戏考 《雁门关》【六本】 2"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "将军快去迎敌！"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "多加小心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "耶律休哥、韩昌同下。"
        },
        {
          "character": "耶律古",
          "type": "白",
          "text": "得令！ 巴图鲁，迎敌去者！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "会阵。四文堂、四上手、四大铠、岳胜、杨宗保、焦赞、孟良、杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "呔！马上番将，通名受死！"
        },
        {
          "character": "耶律古",
          "type": "白",
          "text": "听者！我乃萧太后驾前骁骑将军耶律古是也。来将通名！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我乃大宋元帅杨延昭是也。"
        },
        {
          "character": "耶律古",
          "type": "白",
          "text": "我劝你早早收兵回去；如若不然，枪下作鬼！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "一派胡言！看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、耶律古同开打。耶律古败下。杨延昭追下。岳胜上，连环战。杨延昭杀耶律古，四番兵同大败下。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "杀进番营！"
        },
        {
          "character": "四文堂、四上手、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四大铠、岳胜、杨宗保、焦赞、孟良引杨延昭同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、韩昌、耶律休哥同上。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "哎呀元帅！探子报道：耶律古落马。宋兵骁勇如何是好？"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "你我冲出营去，再作道理！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四大铠、岳胜、杨宗保、焦赞、孟良、杨延昭同上，四番兵、韩昌、耶律休哥同败下。"
        },
        {
          "character": "四文堂、四上手、四大铠",
          "type": "同白",
          "text": "番兵落荒逃走。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "不必迫赶，闯进番营，搜寻军械！"
        },
        {
          "character": "四文堂、四上手、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、韩昌、耶律休哥同上。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "哎呀元帅！我国人马屡败，如何是好？"
        },
        {
          "character": "耶律休哥",
          "type": "白",
          "text": "驸马不必忧愁，暂退黑水河，整顿人马，再与宋兵决战。"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "言之有理。 巴图鲁！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "韩昌",
          "type": "白",
          "text": "暂退黑水河！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵引耶律休哥、韩昌同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主上。"
        },
        {
          "character": "碧莲公主",
          "type": "唱",
          "text": "蛾眉难展暗自叹， 来时有路去时难。 事出意料柔肠断， 中国京剧戏考 《雁门关》【六本】 3 儿夫也是改姓男，"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "咱家、碧莲公主。配夫木易光。因保我妹妹来到宋营，捉拿杨八郎。两军阵前 遇见宋营女将孟金榜，言说木易光是她丈夫杨四郎。可恨驸马与我一十二载的 夫妻，并未露出一言。驸马呀驸马！你早说实话，我也就不出战了！"
        },
        {
          "character": "碧莲公主",
          "type": "唱",
          "text": "胸中忧愁悔已晚， 思母想夫泪不干。 营盘清静甚冷淡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟金榜上。"
        },
        {
          "character": "孟金榜",
          "type": "唱",
          "text": "朔风透骨令人寒。"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "妹妹。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "姐姐来了，请坐！"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "妹妹为何愁眉不展？"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "姐姐呀！"
        },
        {
          "character": "碧莲公主",
          "type": "唱",
          "text": "自叹红颜多悽惨， 奴在宋营夫在番。 母后年迈不能见， 思想起来心不安。"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "贤妹呀！"
        },
        {
          "character": "孟金榜",
          "type": "唱",
          "text": "养育之恩当思念， 女生外向怎比男？ 但愿两国停征战， 夫妻同保宋江山。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "妹妹在此，恐驸马父子受害，如何是好？"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "你国兵将，怎能知晓驸马的真名实姓哪？"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "姐姐难道忘了吗？"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "忘了什么？"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "那日在两军阵前，你说驸马木易光，是你丈夫杨四郎，我国兵将谁没听见，他 们要报与我母后知道，我母后一定要他父子的性命。"
        },
        {
          "character": "孟金榜",
          "type": "白",
          "text": "是呀。待我禀明太君，调兵遣将，搭救他父子回朝。"
        },
        {
          "character": "碧莲公主",
          "type": "白",
          "text": "如此你我一同进帐。"
        },
        {
          "character": "孟金榜",
          "type": "唱",
          "text": "你国不该常造反，"
        },
        {
          "character": "碧莲公主",
          "type": "唱",
          "text": "宋王何必屡征番？"
        },
        {
          "character": "孟金榜",
          "type": "唱",
          "text": "可叹黎民遭涂炭，"
        },
        {
          "character": "碧莲公主",
          "type": "唱",
          "text": "士农工商皆不安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主、孟金榜同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手押香郎、香姐同上。"
        },
        {
          "character": "香郎",
          "type": "唱",
          "text": "皇太国法谁敢坏，"
        },
        {
          "character": "香姐",
          "type": "唱",
          "text": "姐弟无娘也伤怀。"
        },
        {
          "character": "香郎",
          "type": "唱",
          "text": "父亲诓令出关外，"
        },
        {
          "character": "香姐",
          "type": "唱",
          "text": "去到宋营不归来。"
        },
        {
          "character": "香郎",
          "type": "唱",
          "text": "母亲被擒必受害，"
        },
        {
          "character": "香姐",
          "type": "唱",
          "text": "谁人去取她尸骸。"
        },
        {
          "character": "香郎、香姐",
          "type": "同唱",
          "text": "不知母亲今何在？"
        },
        {
          "character": "香郎、香姐",
          "type": "同哭头",
          "text": "儿的娘啊！"
        },
        {
          "character": "香郎、香姐",
          "type": "同唱",
          "text": "与要相逢梦里阳台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《雁门关》【六本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手押宗祥、宗瑞、杨延辉同上。"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "大限已满天注载， 英雄怒目泪满腮。 隐姓埋名十二载， 匹配公主甚和谐。 所生二子接后代， 夫妻父子两分开。 四郎一死无妨碍，"
        },
        {
          "character": "杨延辉",
          "type": "哭头",
          "text": "碧莲妻！我的儿！啊……我那妻儿呀！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "可怜姣儿遭祸灾。"
        },
        {
          "character": "宗祥",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "宗祥",
          "type": "唱",
          "text": "萧、宋战争有数载，"
        },
        {
          "character": "宗瑞",
          "type": "唱",
          "text": "损兵折将遭祸灾。"
        },
        {
          "character": "宗祥",
          "type": "唱",
          "text": "母在宋营儿受害，"
        },
        {
          "character": "宗瑞",
          "type": "唱",
          "text": "铁石人闻也悲哀！"
        },
        {
          "character": "宗祥、宗瑞",
          "type": "同白",
          "text": "哎呀爹爹呀，你既是宋朝杨家将，就该对儿说明。到今天连累孩儿也受这一刀 之苦！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "儿呀，为父本欲说明；因你兄弟年幼，恐怕泄露消息。不料你母亲在两军阵前， 遇见你大娘孟金榜，她说出为父是南朝杨延辉，被探子报与太后，这才连累 你二人也受一刀之苦哇！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "父死子丧真凄惨， 咫尺如隔万重山。 都城军民俱悲叹，"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "灵魂飘渺到九泉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四女兵引佘太君同上。"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "令出如山掌兵权， 奉王旨意扫狼烟。 旌旗飘绕空中展， 众家儿郎各争先。 若得苍天遂我愿， 大宋一统太平年。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "碧莲公主、青莲公主同上。"
        },
        {
          "character": "碧莲公主、青莲公主",
          "type": "同唱",
          "text": "归心岂怕程途远,"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟金榜、蔡秀英同上。"
        },
        {
          "character": "孟金榜、蔡秀英",
          "type": "同唱",
          "text": "大宋、萧邦两有缘。"
        },
        {
