{
  "script_id": "03014001",
  "title": "芦花记",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "闵父",
      "hangdang": "老生"
    },
    {
      "name": "闵母",
      "hangdang": "旦"
    }
  ],
  "plot": "春秋时，贤士闵损，幼年丧母，父续娶，继母连生二子。其继母偏爱亲生而疏闵损。一日，闵损随父赴宴，\n在席前露寒栗状。及归，父责其故意造作出丑人前，以鞭笞之。不意衣破芦花飞出。其父乃悟系继母偏心，\n以芦花为絮，自难御寒。以故怒遣继母，并欲出之。闵损苦苦哀告其父，以“母在一子寒，母去三子单”语\n劝阻乃罢。其时继母甚愧悔，遂改过善视闵损。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "闵父",
          "type": "内西皮导板",
          "text": "数九隆冬腊月天，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵损执鞭御车、英哥、闵父同上。"
        },
        {
          "character": "闵父",
          "type": "西皮原板",
          "text": "风雪交加透骨寒。 父子们前村饮酒宴， 闵损御车回家园。 坐在车中抬头看， 银龙世界似仙山。 来在门首将车站，"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "闵父",
          "type": "西皮原板",
          "text": "见奴才抖战怒冲冠！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "哽！你这奴才，暖衣饱食，适才在前村饮酒中间，你在大众之前，浑身战抖， 作身上无衣之状，大伤为父的体面。如今回到家来，为何还这样的战抖？"
        },
        {
          "character": "闵损",
          "type": "白",
          "text": "哎呀，爹爹呀！孩儿身上衣服不能遮寒，故而如此。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "哦！你的衣裳不能遮寒，儿来看！你兄弟衣裳与你都是一样的，他身穿绸缎， 内絮张棉。他比你年小，他倒不冷，怎么单单你冷？"
        },
        {
          "character": "闵损",
          "type": "白",
          "text": "爹爹！孩儿自幼身体软弱，故而寒冷。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "奴才一派胡言！英哥，看皮鞭伺候！"
        },
        {
          "character": "闵父",
          "type": "西皮摇板",
          "text": "奴才说话不中听， 谁不知腊月是隆冬。 手执皮鞭用力打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵父打，闵损衣飞芦花。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "闵父",
          "type": "西皮摇板",
          "text": "打出芦花飞当空！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "庭前拷打闵损，芦花飞出。哦，是了。想是他继母那个不贤之人，起下狠毒心 肠，要将我这无娘的孩儿活活冻死！这样恶妇，岂能容她，不免将她休回娘家。 英哥！"
        },
        {
          "character": "英哥",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "请你外公、外婆来！"
        },
        {
          "character": "英哥",
          "type": "白",
          "text": "晓得了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "英哥下。"
        },
        {
          "character": "闵父",
          "type": "叫头",
          "text": "闵损！"
        },
        {
          "character": "闵损",
          "type": "叫头",
          "text": "爹爹！"
        },
        {
          "character": "闵父",
          "type": "叫头",
          "text": "我儿！"
        },
        {
          "character": "闵损",
          "type": "白",
          "text": "我父！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "闵损",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "闵父",
          "type": "二黄导板",
          "text": "手拉姣儿心好惨！"
        },
        {
          "character": "闵父",
          "type": "回龙",
          "text": "叫一声闵损儿件件桩桩、桩桩件件听为父细说根源："
        },
        {
          "character": "闵父",
          "type": "二黄原板",
          "text": "大不幸儿的母夭寿命短， 为父我因姣儿填房续弦。 实指望娶继母把儿怜念， 想不到那泼妇为人不贤。 我命她与孩儿把衣服来剪， 又谁知儿的晚娘心太偏。 亲生之子絮张棉， 前房之子她絮芦花不絮张棉。 适才间到前村去饮宴， 偏遇着北风凛凛大雪纷飞，观只见我的儿战战抖抖，在席前叫为父实实不堪。 盛馔不餐回家转， 吾儿御车浑身战抖无衣一般。 为父我见此情心火上， 又用皮鞭打衣衫。 打出芦花飞满天， 才知道儿的继母心肠偏。 一样儿子两样看， 害的儿，无娘的儿太不堪！泪珠滚滚心似箭穿！ 我的儿呀！ 想当初是为父见识太浅， 到如今后悔难，儿身冷，父心寒；儿心痛，父心酸；打在儿身，痛在父心，好 不可怜！ 父子们只哭得肝肠寸断……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "外公、外婆、英哥同上。"
        },
        {
          "character": "外公",
          "type": "念",
          "text": "忽听来请俺，"
        },
        {
          "character": "外婆",
          "type": "念",
          "text": "来到他家园。"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "大姐夫！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "闵父",
          "type": "二黄原板",
          "text": "又听得岳父母站立面前。"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "我二老有礼了！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "你有理，难道我无有理？"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "这是怎么讲话？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "里面讲话！"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "正要到里面坐坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "外公、外婆同坐。"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "请我二老前来，有何话讲？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "小婿有一事不明，要在二位大人台前领教！"
        },
        {
          "character": "外公",
          "type": "白",
          "text": "如此，吾就赐教。"
        },
        {
          "character": "外婆",
          "type": "白",
          "text": "说领教、领教，别说赐教。"
        },
        {
          "character": "外公",
          "type": "白",
          "text": "不错，不错，请教。他姐夫有话请讲当面，何言领教？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "请问二老大人：数九寒天，小孩衣裳之中，当絮何物取暖？"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "当用张棉。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "哦，原来是用张棉。你来看！ 吾这英哥孩儿身穿绸缎，内絮张棉；我那大孩儿身穿绸缎，内絮芦花，你女儿 她、她、她、她……为何如此的心偏哪？"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "棉花里边飞上一星半点芦花，也是有的。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "你来看，这是一星半点的么？"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "这是我们姑娘的错了！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "拿把刀来！"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "要刀何用？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "将我这无娘的孩儿杀了，也是你女儿错了！"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "我女儿未曾杀人。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "杀了就晚了！"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "活着是你家人，死了是你家鬼，嫁出来的女，泼出门的水，我们管不着。走了！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "英哥！"
        },
        {
          "character": "英哥",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "前门上锁，后门上闩。看你二人哪里走！"
        },
        {
          "character": "英哥",
          "type": "白",
          "text": "前门上锁，后门上闩，连沟眼也堵上。你们谁也别打算出去！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "英哥，文房四宝伺候！"
        },
        {
          "character": "英哥",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "闵父",
          "type": "西皮摇板",
          "text": "未曾提笔心意乱， 一旦拆散了恶姻缘。 恨贱人作事太阴险， 苦害我无娘的孩儿理不端。 她虽然未犯那“七出”条款， 我与你伯劳飞燕分离在两边。 写完了休弃书放下了笔砚， 快带你女儿回你们家园。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "二老请过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "外婆笑。"
        },
        {
          "character": "外公",
          "type": "白",
          "text": "笑什么？"
        },
        {
          "character": "外婆",
          "type": "白",
          "text": "给咱们面票子，叫咱们吃面。"
        },
        {
          "character": "外公",
          "type": "白",
          "text": "这是休书。你养的女儿被人休了！"
        },
        {
          "character": "外婆",
          "type": "白",
          "text": "女儿快来吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵母上。"
        },
        {
          "character": "闵母",
          "type": "西皮散板",
          "text": "忽听堂上唤一声， 怀抱姣儿出门庭。 爹娘到此来做甚？"
        },
        {
          "character": "外公",
          "type": "白",
          "text": "可气死我了！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "闵母",
          "type": "西皮散板",
          "text": "这样光景闷煞人。"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "爹爹在上，女儿有礼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "外公不理。"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "母亲在上，女儿有礼！"
        },
        {
          "character": "外婆",
          "type": "白",
          "text": "你有理，为娘无有理！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "你二人为了何事，如此烦恼？"
        },
        {
          "character": "外公",
          "type": "白",
          "text": "我也不知道。这有一张字纸，拿去看来！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "原来是一张休书！"
        },
        {
          "character": "外婆",
          "type": "白",
          "text": "那是你的贞节牌！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "可知为了何事？"
        },
        {
          "character": "外公",
          "type": "白",
          "text": "我也不知，你自己想来！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "啊，员外！要休为妻，不知为了何事？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "你自己作的事，反来问我！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "怒气不息，为着何来？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "就为你来！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "为妾身何来？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "我且问你：二孩儿身穿绸缎，内絮何物？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "内絮张棉。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "大孩儿身穿绸缎，内絮何物？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "内絮……这个……"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "哪个？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "也是张棉。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "你来看！ 芦花！芦花！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "一星半点，也是有的。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "这是一星半点？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "我只道芦花比张棉还暖，谁知反成了歹意！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "芦花既是发暖之物，为何不絮在你养的孩儿身上？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "絮在吾儿身上岂不寒冷？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "难道絮在我那无娘的孩儿身上，他就不冷么？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "他冷，与我什么相干？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "二位大人可曾听见？"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "没听见。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "英哥，将衣服脱下来！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "且慢！脱下衣服，我儿岂不寒冷？"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "你的孩儿寒冷，与我什么相干？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "他冷我心疼。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "难道说，把芦花絮在我那无娘的孩儿身上，他冷我就不心疼么？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "你疼你的，我疼我的。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "二位大人，可曾听见？"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "我们耳朵聋。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "似你这等狠毒妇人，拿了休书，下堂去罢！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "闵母",
          "type": "西皮摇板",
          "text": "员外一言出了唇， 羞得我低头难见人。 怀抱姣儿出门庭——"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "且慢哪！"
        },
        {
          "character": "闵父",
          "type": "西皮摇板",
          "text": "留下闵氏后代根。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "这是我闵家之后，焉能叫你带去，留下。快快与我走！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "闵母",
          "type": "西皮导板",
          "text": "在怀中夺去了亲生子，"
        },
        {
          "character": "闵母",
          "type": "西皮原板",
          "text": "不由人一阵阵泪湿衣襟。 他闵损就是父母养， 难道说我的儿不是娘生。 我怀儿十个月——"
        },
        {
          "character": "闵母",
          "type": "西皮二六板",
          "text": "痛苦受尽， 又谁知到如今落了个离分。 为姣儿累得我精疲力尽， 为姣儿日夜哺乳费多少辛勤。 絮张棉絮芦花太不公正， 因此事将奴家休出门庭。 左思右想泪难忍！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "哎呀！再三留恋，好无羞耻！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "闵母",
          "type": "西皮散板",
          "text": "员外催促不绝声。 无奈何带休书娘家去奔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵损跪。"
        },
        {
          "character": "闵损",
          "type": "白",
          "text": "娘呀！"
        },
        {
          "character": "闵损",
          "type": "西皮散板",
          "text": "闵损上前拉衣襟。 娘把休书交儿手， 转回哀告老天伦。"
        },
        {
          "character": "闵损",
          "type": "叫头",
          "text": "爹爹呀！"
        },
        {
          "character": "闵损",
          "type": "白",
          "text": "想我母亲，乃是女流，怜小不疼大。今日爹爹将儿母亲休了，抛下我这两个小 兄弟，又是无人抚养，爹爹仍然续弦另娶，岂不是又一番劳心。正所谓："
        },
        {
          "character": "闵损",
          "type": "念",
          "text": "母在一子寒，母去三子单。母在尚如此，母去更可怜。"
        },
        {
          "character": "闵损",
          "type": "白",
          "text": "爹爹开恩，宽恕我母亲罢……"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "闵父",
          "type": "二黄摇板",
          "text": "听一言来心好惨， 好一个贤孝孩儿闵子骞。 儿将休书顶头上， 端端正正跪堂前。"
        },
        {
          "character": "闵父",
          "type": "叫头",
          "text": "贤妻！啊，儿的慈母大贤人！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "想你虐待我那无娘的孩儿，身絮芦花，你实指望将他冻死。因此，我将你休弃。 你来看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵父指。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "我这贤孝孩儿，跪在我面前，苦苦哀求。他言道：母在一子寒，母去三子单。 看在我儿的份上，休弃之事，作为罢论。因此教他头顶休书，跪在你面前，望 你发一点慈爱之心。从今以后，不要虐待我那无娘的孩儿，留他一条小命。漫 说是卑人感激于你，就是他死去的亲娘，也感你大恩大德呀！"
        },
        {
          "character": "闵父",
          "type": "二黄原板",
          "text": "躬身施礼把话论， 叫一声大慈大悲大仁大义的大贤人。 遭不幸我前妻早年丧命， 都只为扶养孩儿才娶你来临。 指望你将姣儿用心照应， 谁想你丧天良下狠心虐待姣生。 你的儿他能够披麻戴孝， 我的姣生他也能顶丧驾灵。 你的儿他能够光祖耀宗， 我的儿他也能改换门庭。 你的儿他是那父生母养， 难道说我的儿不是娘生？ 自古道梅花树南枝暖来北枝冷， 一样的孩儿你两样心。 从今后为人母存心公正， 时时刻刻感你恩。 发天良改变了偏心任性， 就是他去世的娘亲在阴曹地府也感你的大恩。 我那不聪敏的妻呀！ 你若是一味地阴毒凶狠， 明有天地暗有鬼神。 千言万语说不尽，"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "你来看！"
        },
        {
          "character": "闵父",
          "type": "二黄原板",
          "text": "我的儿头顶休书端端正正跪在埃尘，口口声声叫娘亲，大贤人你可动心？"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "闵母",
          "type": "二黄摇板",
          "text": "员外言语是正论， 自恨从前太偏心。 忙将姣儿来扶起， 从今拿你当亲生。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "夫人哪！"
        },
        {
          "character": "闵父",
          "type": "二黄摇板",
          "text": "你今说话难凭信， 快对苍天把誓盟。"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "闵母",
          "type": "二黄摇板",
          "text": "听一言来跪埃尘， 过往神灵听分明： 今后再起不良意， 黄沙盖脸赴幽冥。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "谢夫人！"
        },
        {
          "character": "闵父",
          "type": "二黄摇板",
          "text": "一见我妻把誓盟， 为丈夫才得放宽心。 忙将姣儿交你手， 休书扯个碎纷纷。"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "二位大人，请来上席！"
        },
        {
          "character": "外公、外婆",
          "type": "同白",
          "text": "好难吃的酒哇！"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "贤妻请来上席！"
        },
        {
          "character": "闵母",
          "type": "白",
          "text": "你休了我吧！"
        },
        {
          "character": "闵父",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "闵父",
          "type": "白",
          "text": "不要如此，随我来呀！"
        },
        {
          "character": "闵父",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}