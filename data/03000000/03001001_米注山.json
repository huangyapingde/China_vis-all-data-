{
  "script_id": "03001001",
  "title": "米注山",
  "alias": [
    "付剑印"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "斗越椒",
      "hangdang": "净"
    },
    {
      "name": "公子茷",
      "hangdang": "武生"
    },
    {
      "name": "斗贲凰",
      "hangdang": "净"
    }
  ],
  "plot": "春秋时代，楚庄王兴兵伐郑，派斗越椒为帅，公子茷为副。斗越椒和公子茷素有间隙。公子茷争功先行，被\n郑将公子坚围困在米注山；斗越椒按兵不动，公子茷跳涧自杀。回师后，楚庄王怒责越椒，摘取他的司马剑\n印，交蔿贾执掌。陆国犯境，楚庄王亲自出征，命蔿贾留守，防备斗越椒叛乱。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蔿贾、苏从、潘尪、乐伯同上。"
        },
        {
          "character": "蔿贾",
          "type": "点绛唇",
          "text": "鹄立朝班，"
        },
        {
          "character": "苏从",
          "type": "点绛唇",
          "text": "景阳催赞，"
        },
        {
          "character": "潘尪",
          "type": "点绛唇",
          "text": "五更寒，"
        },
        {
          "character": "乐伯",
          "type": "点绛唇",
          "text": "待漏声残，"
        },
        {
          "character": "蔿贾、苏从、潘尪、乐伯",
          "type": "同点绛唇",
          "text": "共祝升平灿。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "上大夫蔿贾。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "下大夫苏从。"
        },
        {
          "character": "潘尪",
          "type": "白",
          "text": "右将军潘尪。"
        },
        {
          "character": "乐伯",
          "type": "白",
          "text": "谏议乐伯。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "列位请了！大王今日登殿，我等分班伺候。"
        },
        {
          "character": "苏从、潘尪、乐伯",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。四值殿、四太监、大太监引楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "引子",
          "text": "尧舜有道称圣君，河清海晏庆升平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王入座。蔿贾、苏从、潘尪、乐伯同叩参。"
        },
        {
          "character": "蔿贾、苏从、潘尪、乐伯",
          "type": "同白",
          "text": "臣等见驾，愿大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "蔿贾、苏从、潘尪、乐伯",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "三年号令从未申，每日宫中饮杯巡。凡鸟伏翅虽不展，飞则冲天也惊人。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤，楚庄王。承先祖宏图，嗣膺大宝。只因先君穆王，征伐郑邦，中途得病而 回，不幸身故，因此众卿扶孤登基。嗣位以来，号令不申，日事田猎，夜事笙 歌。自被大夫苏从谏奏，乃绝钟鼓之欢，重修朝纲大典。 众卿！"
        },
        {
          "character": "蔿贾、苏从、潘尪、乐伯",
          "type": "同白",
          "text": "臣。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "寡人意欲兴兵伐郑，以报先王之仇。众卿意见如何？"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "吾主欲报先王之仇，此乃人伦大义，并非妄动刀兵；正当兴师，胡为不可！"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "大王此番兴兵，非比寻常，只因我军三载未动，兵将懈弛，须得智勇之将统领， 训练士卒，操演战法，方可兴师。"
        },
        {
          "character": "潘尪",
          "type": "白",
          "text": "苏大夫言得极是。大王度量哪位大臣可能担此重任，为帅伐郑，方能一战成功？"
        },
        {
          "character": "乐伯",
          "type": "白",
          "text": "臣启大王：今有斗司马智勇双全，而且深知郑情，并谙地理，担此重任，必然 成功。望主详察！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿家之言，正合孤意。与孤传旨，宣斗越椒上殿！"
        },
        {
          "character": "乐伯",
          "type": "白",
          "text": "领旨。 大王有旨：宣大司马斗越椒上殿！"
        },
        {
          "character": "斗越椒",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒上。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "世代簪缨蒙君宠，权倾满朝第一功。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "臣，大司马斗越椒见驾，愿大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "谢座。大王宣臣上殿，有何国事议论？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤为先君之仇至今未报，命卿家统领人马伐郑。卿家可能当此重任？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "臣斗氏三代辅楚，多蒙荫庇，君恩浩荡，敢不尽心竭力！但不知命何臣为副帅？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤二弟公子茷英勇驰名，可为副帅，与卿同伐郑邦！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "臣启大王：二千岁英雄盖世，可以去得。只是二千岁性情高傲，军戒严整，不 当以徇人情，恐有不便。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿家遇事共同商议，必然成功。孤先赐卿兵符剑印，一应大小将官不遵者以军 法施行。即日兴兵。听孤旨下！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王金殿把旨传， 斗卿进前听孤言： 但愿得此去把贼扫， 旗开得胜转回还。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "辞别大王下殿口， 背转身来喜心头。 忠心耿耿答高厚， 扫平贼寇保龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王金殿把旨降， 御弟上殿作商量。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众卿，宣公子茷上殿！"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "领旨。 大王有旨：宣公子茷上殿！"
        },
        {
          "character": "公子茷",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷上。"
        },
        {
          "character": "公子茷",
          "type": "念",
          "text": "纬地经天雄心壮，弓马娴熟膂力强。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "臣公子茷见驾，愿兄王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "御弟平身。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "千千岁！兄王宣臣上殿，有何国事议论？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤命斗越椒统领大兵伐郑，以报先王之仇。命二弟为副帅先行，遇事共同商议。 御弟意下如何？"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "自古道，父母之仇，不共戴天。小弟早有伐郑之心，既有兄长严命，纵死何憾！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "御弟此去必然马到成功。听孤旨下！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "御弟此去心拿稳， 鞍前马后要小心。 令军前去把贼镇， 凌烟阁上标美名。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "兄王！"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "只为先王旧仇恨， 要把郑国一扫平。 辞别大王下龙廷， 血战沙场哪得安宁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "众将俱已下龙廷， 不由孤王喜在心。 此去狼烟俱扫净， 孤王才得太平春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "茷妻上。"
        },
        {
          "character": "茷妻",
          "type": "念",
          "text": "身受皇恩眷，同沾雨露恩。"
        },
        {
          "character": "公子茷",
          "type": "内白",
          "text": "回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引公子茷同上。茷妻接入，行礼，坐。"
        },
        {
          "character": "茷妻",
          "type": "白",
          "text": "兄王宣你，有何旨意？"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "夫人哪里知道！兄王兴兵伐郑，命斗越椒挂帅，下官以为前站先行。我与斗越 椒素有仇恨，到了阵前，难免他以公报私。"
        },
        {
          "character": "茷妻",
          "type": "白",
          "text": "老爷不必过虑。此番到了阵前，见机而行就是。后面披挂，待妾身替老爷点动 人马。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "有劳夫人！正是："
        },
        {
          "character": "公子茷",
          "type": "念",
          "text": "青龙背上屯军马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷下。"
        },
        {
          "character": "茷妻",
          "type": "念",
          "text": "白虎堂前点雄兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院暗上。"
        },
        {
          "character": "茷妻",
          "type": "白",
          "text": "家院！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "茷妻",
          "type": "白",
          "text": "传令下去，大小将官，全身披挂，二堂听点！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 下面听者：夫人有令：大小将官，全身披挂，二堂听点！"
        },
        {
          "character": "四将",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将软靠随四下手同上。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "参见夫人。"
        },
        {
          "character": "茷妻",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "茷妻",
          "type": "二黄导板",
          "text": "在二堂传将令前去伐郑，"
        },
        {
          "character": "茷妻",
          "type": "唱",
          "text": "众将官站两旁细听分明： 都只为先王爷的旧仇恨， 鞍前马后要小心。 耳边厢又听得盔甲声震， 想必是老爷他披挂来临。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷上。"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "兄王金殿传将令， 要把郑国一扫平。 撩铠甲迈虎步把二堂进， 有劳夫人点雄兵。"
        },
        {
          "character": "茷妻",
          "type": "唱",
          "text": "家院看过酒一樽， 我与老爷来饯行。"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "用手接过酒一樽， 背转身来祭神灵。 辞别夫人足踏镫， 但愿得扫逆贼奏凯回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷率四龙套、四将、家院同下。"
        },
        {
          "character": "茷妻",
          "type": "唱",
          "text": "一见老爷上能行， 且听探马报分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "茷妻下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "斗贲皇上。"
        },
        {
          "character": "斗贲皇",
          "type": "念",
          "text": "父子将相能文武，威名四海镇帝都。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "俺，斗贲皇。今日大王召俺爹爹上殿，不知为了何事？我父回来便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉引斗越椒同上，斗越椒入座。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "谢座。爹爹，大王召爹爹上殿有何国事议论？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "只因大王要报先王之仇，命父领兵伐郑，公子茷以为副帅。我想此人武艺高强， 必占头功。你我父子此去岂不空费一场！"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "啊，爹爹！难道就忘了息地之时，争功夺胜，羞辱你我父子么？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "哦，我儿提醒为父旧恨。今日兴兵，看他怎样行事。我儿速速披挂，校场伺候！"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "量小非君子，"
        },
        {
          "character": "斗贲皇",
          "type": "念",
          "text": "无毒不丈夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手引公子茷同上。"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "只为先王旧仇恨， 命我领兵伐郑城。 越椒挂了元帅印， 皇亲反作了马前先行。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "俺，公子茷。奉了兄王之命，带领人马，征战郑邦，与我父报仇。以斗越椒为 帅，俺为马前先行，共同兴兵。只因我与越椒旧有仇恨，恐他诡计多端，为此 不与他商议，直捣郑邦。倘若一战成功，教他空手而归。 呔，众将官，催动人马！"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "昔日郑城夺权柄， 奸贼不该胡乱行； 我为父仇报前恨， 赫赫扬扬师有名。 此番一战大功定， 看他父子怎收兵！"
        },
        {
          "character": null,
          "type": "stage",
