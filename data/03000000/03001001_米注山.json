          "text": "在那里。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手自两边围公子茷，公子茷跳涧死，下。"
        },
        {
          "character": "郑兵",
          "type": "白",
          "text": "楚将跳涧而死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子坚上。"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "哈哈哈……好一员虎将，跳涧而死！ 众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子坚率四上手同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八小军引斗越椒同上。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "我儿前去探音信，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲皇上。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "未知胜败输与赢。"
        },
        {
          "character": "斗贲皇",
          "type": "唱",
          "text": "米注山前困英俊， 一世英名落山坑。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "启禀爹爹：公子茷跳涧而亡。郑国人马离此不远！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "这是他贪功丧命，怨着谁来！ 众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手引公子坚公子上。斗越椒与公子坚会阵。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "唗！大胆反贼，逼死皇亲，还敢兴兵前来！通名受死！"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "郑国大将公子坚。来的敢是斗越椒？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "既知我名，早早收兵回去，教你主速纳降表请罪；如若不然，教你片甲不存！"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "一派胡言。放马过来！ （公子坚与斗越椒战，斗越椒败下。斗贲皇上与公子坚战，公子坚败下。四上手同上。斗贲皇与四上手同打， 四上手同下。公子坚上，战斗贲皇下。斗越椒上战公子坚下。斗越椒打四上手，公子坚上接四上手，公子 坚败下斗越椒追下。公子坚上。）"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "且住。越椒杀法骁勇，他若赶来，伤他一箭。 （斗越椒上，公子坚以箭射之。斗越椒接箭下。斗贲皇上与公子坚战。四上手攒阵同下。斗越椒上，以箭射 公子坚，公子坚下。八小军自两边分上。）"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "我儿你看郑国人马兵将，不弱于我军，莫若收兵回朝，再作计议。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "爹爹！倘若大王追问公子茷之事，如何是好？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "有为父承当。 众将官，人马回朝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒领众人同下。四上手引公子坚同上。"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "且住。斗越椒箭法百发百中，幸射中盔缨，不然险遭不测。 众将官，收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子坚率四上手同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "奉令探军情，晓夜不消停。陆国兴人马，掳掠未安宁。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "俺乃楚国庄王驾下探事官是也。今有陆浑小国造反，为此报与大王去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四值殿、四太监引楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王继位烽火靖， 每日宫中饮杯巡。 大夫苏从忠心耿， 不顾生死谏寡人。 因此孤王修国政， 图霸王业坐乾坤。 我令人马去伐郑， 不知谁败与谁赢？ 孤王且把朝堂进， 且看何人把本申。"
        },
        {
          "character": "苏从",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏从上。"
        },
        {
          "character": "苏从",
          "type": "唱",
          "text": "适才探得凶恶信， 大王闻知痛伤心。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "苏从见驾，大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "大夫为何这等慌张？"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "启奏大王：二千岁驱兵当先，杀往郑地，被困在米注山；因盼救兵不到，跳涧 身亡了！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "那越椒父子兵在何处？"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "他父子按兵不动。越椒今日败阵回朝，已在午门候旨。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "宣斗越椒上殿！"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "领旨。 大王有旨，宣斗越椒上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏从下。"
        },
        {
          "character": "斗越椒",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒上。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "愧赧见君三叩首，随机应变奏从头。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "臣斗越椒见驾，大王千岁！臣启大王：那二千岁不遵将令，自入虎穴而亡，臣 救之不及。死罪呀，死罪！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "你且平身。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤二弟私自向前，被困丧命；你奉旨伐郑，胜负如何？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "大王！我国兵将，已失锐气；而郑国人马仗其得胜之兵，不能挡其贼锋，故而 收兵回朝，君臣再定报仇之计。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤王早已闻知，你不必蒙哄。孤二弟好勇，自入虎穴，误丧其命；你按兵不发， 是何理也？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "吾主此言差矣！二千岁不来与臣商议，私自进兵，按理有误军之罪；今反责臣 按兵不发，其情可恼！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "嗐！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "辜负了先王爷托孤严命，"
        },
        {
          "character": "楚庄王",
          "type": "三叫头",
          "text": "二弟！子茷！御弟啊！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "不能够享荣华共乐安宁。 怨孤王大不该命你伐郑， 都只为君父仇子亦当行。 谁知你血气勇孤军前进， 只顾间被贼困尸弃山坑。 又谁知贼按兵违旨抗命， 不发兵不救援坠涧丧身。 你今死九泉下休把孤恨， 怨只怨逆冤家狠心贼臣。 孤愿你灵魂儿早登仙境， 孤明日设道场立旛招魂。 哭一声同胞弟年幼丧命， 御弟啊…… 你死在九泉下休怨寡人。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "我主说话理不顺， 且听为臣奏分明： 既命为臣挂帅印， 不该命他为副军。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "卿家不必巧言论， 孤王心下如明灯； 你父子通同做弊病， 按兵不发为何情？"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "他仗血气好逞胜， 不遵将令私出兵； 若论军令理当斩， 贪功无故自丧身。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "些小之事记仇恨， 忘大取小枉为人。 纵然我弟丧了命， 就该随后发救兵。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "大王不必罪为臣， 某将随后发救兵。 我军锐气俱丧尽， 为臣见机才收兵。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "纵然不能来得胜， 为王自有旨意行。 君要臣死敢违命， 父要子亡不得生。 抗旨藐法理当惩， 按兵不发当斩刑。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "我主休把话说尽， 为臣一本奏分明： 君王就该有性命， 为臣不是父母生？ 自古常言道得好， 王子犯法与民同。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "只为先王去伐郑， 二人阵前赌输赢。 只道你是擎天柱， 谁知人面禽兽心。 为王不把罪来论， 还看祖上有功勋。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "君违将令也当斩， 方能压服众三军； 江山也要臣子挣， 君王方得享安宁。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "臣有功来君有赏， 自将官职往上升。 你说此话抗君命， 胡言乱语为何情？"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "今日奏本君休恨， 莫说为臣我乱胡行。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "仗你先父有功勋，"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "斗氏楚国有三分。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王传旨将你斩，"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "先王封过不斩臣！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "将你官职来谪贬，"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "不能不能万不能！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "莫非起意要造反？"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "君王休要错疑心！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "莫非杀孤要行刺？"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "君不正来臣要行！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "众将齐来救孤命， 越椒金殿弑寡人！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "哇呀……"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "将身坐在金殿等， 昏王将我怎样行？"
        },
        {
          "character": "蔿贾",
          "type": "内白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔿贾上。"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "正在朝房得凶信， 越椒金殿藐视君。 撩袍跨步龙廷进， 大王为何发雷霆？"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "越椒金殿抗君命， 不遵国法弑寡人。"
        },
        {
          "character": "蔿贾",
          "type": "唱",
          "text": "为臣自有公平论， 把话说与司马听。"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "啊，司马公，为臣者当视君为父，君臣相斗，成何体统？你今有三行大罪，难 免众人议论。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "唔，某家有哪三行大罪？"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "你且听道！按兵不动，抗旨藐法，臣子谤君，还说不知？依老夫之见，将剑印 解下，上殿请罪，暂息君怒，而免众人议论。你要三思！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "哦，也罢！"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "要为篡国图谋事，且做吞声忍气人。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "臣，斗越椒见驾，大王千岁！念臣斗氏三代辅楚，有些小功劳，乞大王恕罪！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "将剑印付与蔿贾执掌。从今以后朝中有事无事，不与你父子相干。领旨下殿！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "领旨！ 啊！啊哈……哇呀……罢啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒下。苏从上。"
        },
        {
          "character": "苏从",
          "type": "念",
          "text": "听得边外贼起衅，急向丹墀奏分明。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "臣，苏从启奏大王：方才接得边报，陆浑小国造反。特来奏知！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哦！陆浑小国造反，其情可恼！封卿上大夫之职，与孤传旨，整顿人马，孤王 御驾亲征！"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "苏从",
          "type": "念",
          "text": "内患方消退，外寇又生端。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏从下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "蔿贾听封！"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "封卿为大司马，总理国政，慎防越椒。吩咐点动兵将，苏从、公子侧、潘尪随 孤御驾亲征陆国。朝中大事全赖卿家料理。孤王明日起兵。退班！"
        },
        {
          "character": "蔿贾",
          "type": "白",
          "text": "请驾还宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}