          "character": null,
          "type": "stage",
          "text": "斗贲皇上，起霸。"
        },
        {
          "character": "斗贲皇",
          "type": "念",
          "text": "父子英名遍宇宙，杀人破胆鬼神愁。跨下宝马乌骓吼，手持金枪似龙游。"
        },
        {
          "character": "斗贲皇",
          "type": "白",
          "text": "俺，斗贲皇。爹爹发兵，在此伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八小军引斗越椒同上，旗夫执纛旗随上。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "心怀大志久有谋，苦无机会使人愁。"
