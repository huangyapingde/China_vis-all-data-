        {
          "character": null,
          "type": "stage",
          "text": "斗越椒率斗贲皇、八小军同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手引公子坚同上，旗夫执纛旗随上。"
        },
        {
          "character": "公子坚",
          "type": "念",
          "text": "豹头环眼似铜铃，身长丈余盖世雄。郑邦也是天朝后，不服楚国自尊称。"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "某，郑国大将军公子坚是也。今有楚庄王无故兴兵，命斗越椒挂帅，公子茷为 副，兵伐我国。某奉大王之命。带领铁骑三千，与楚国对敌。 呔！众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四下手引公子茷同上。公子坚、公子茷会阵。"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "呔！来的敢是公子茷？"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "正是王爷。来将通名！"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "郑国大将军公子坚。你国无故兴兵，是何道理？"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "逆贼！吾父为你郑国气呕身亡，为此统兵扫平汝国，教尔鸡犬不留！"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "一派胡言。看枪！ （公子坚、公子茷同战。公子坚败公子茷追下。四上手、四下手同起打。公子坚、公子茷同杀上，公子坚败， 公子茷追下。众人同起打，同下。公子坚败上。）"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "且住！公子茷杀法厉害，这便怎么处？哦喝有了。俺不免诈败佯输，杀一阵， 败一阵，将他引到米注山下，然后伏兵齐出，量他难以飞上天去。 众将官，照计而行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷杀上。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "哪里走？ （公子茷、公子坚同战，公子坚败公子茷追下。公子坚、公子茷同上，公子坚败下。公子茷战四上手，四上 手同败下。公子坚上与公子茷战，公子坚败下，公子茷追下。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八小军引斗越椒同上。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "统领人马杀气生， 要把郑邦一扫平。 陡然想起前仇恨， 一心拔去眼中钉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰上。"
        },
        {
          "character": "斗贲凰",
          "type": "唱",
          "text": "适才探得机密信， 见了严亲说分明。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "启禀爹爹：孩儿打听公子茷被困米注山，爹爹救是不救？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "哦哈哈……他也有今日势败之时么！我想公子茷抢俺头功，不遵将令，私自出 兵，已干军法；我若不救，也有欺君之罪。 呔！众将官，停兵三日再兴兵前往！"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "人马扎住休前进， 权在我手任我行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒率斗贲皇、八小军同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "公子茷上。"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "杀来杀去无投奔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子坚上，公子坚与公子茷相杀，公子坚败下。四上手同上，围战，公子茷以枪招架。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "还不归降！"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "战得两膀汗淋淋。 这时血气忒用尽， 误中奸贼巧计行。 越椒与我有仇恨， 焉能就肯发救兵。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "公子茷",
          "type": "唱",
          "text": "大丈夫终有一日死， 为父报仇落美名。 弃枪抛戈下金镫， 一旦归阴随父行。"
        },
        {
          "character": "公子茷",
