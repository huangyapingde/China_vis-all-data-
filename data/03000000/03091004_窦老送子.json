          "type": "白",
          "text": "果然。"
        },
        {
          "character": "窦老",
          "type": "白",
          "text": "哈哈哈……哎呦！"
        },
        {
          "character": "刘高",
          "type": "白",
          "text": "随我后面用饭去！"
        },
        {
          "character": "窦老",
          "type": "白",
          "text": "来了，来了！难得呀，难得！哈哈哈……"
