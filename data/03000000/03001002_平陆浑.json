        {
          "character": "楚庄王",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "早知此会有蹊跷， 四面埋伏杀人刀。 安排厮杀破奸巧，"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "唔唔，陆浑！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "你却错用计一条。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王带公子侧、熊负羁同下。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "陆浑",
          "type": "唱",
          "text": "只望诈用牢笼套，"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "众将走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大番将、四蓝马甲自两边分上。"
        },
        {
          "character": "陆浑",
          "type": "唱",
          "text": "奋勇追赶把战交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。〖牌子〗。四蓝文堂、陆戎同上。"
        },
        {
          "character": "陆戎",
          "type": "白",
          "text": "某，陆戎是也。奉命把守东门。看火光高照，庄王君臣必定中计。 众将官，此地等候庄王便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧、熊负羁、楚庄王同冲上，打，同下。四女兵引陆芬花同上。〖牌子〗。"
        },
        {
          "character": "陆芬花",
          "type": "白",
          "text": "俺，陆芬花是也。奉命把守南门，擒捉庄王君臣。 众女兵，悄悄埋伏者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧、熊负羁、楚庄王同冲上。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "遍地火光齐照耀， 飞鸟有翅也难逃。 东门杀奔南门道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女将、陆芬花同上。"
        },
        {
          "character": "陆芬花",
          "type": "白",
          "text": "哪里走！ （众人同打。公子侧、熊负羁同架住陆芬花。楚庄王逃下，四蓝文堂、四女将、陆戎、陆芬花同追下。楚庄 王上。）"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "嗐！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "不该赴会中笼牢。 怨来怨去孤自讨， 险些白送命一条。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧、熊复羁同杀上。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀！你二人想是杀昏了，怎么连自己人都不认得。孤王在此。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "一时急迫，错认番将。"
