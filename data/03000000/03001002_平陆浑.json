        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "走啊！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "莫把小国轻视了， 还恐有人防城壕。 （托闸。陆浑率四蓝文堂、四蓝大铠、四下手、四女兵、陆戎、陆芬花同杀上。火彩烘下。四上手、潘尪同 上。〖牌子〗。）"
        },
        {
          "character": "潘尪",
          "type": "白",
          "text": "某，大将潘尪。奉命扎兵哨探。看城内火光齐发，大王必中奸计。 来呀！杀奔城壕者！ （陆浑追杀楚庄王、公子侧、熊复羁同上。潘尪接杀。陆浑率四蓝文堂、四蓝大铠、四下手、四女兵、陆戎、 陆芬花同败下。）"
        },
        {
          "character": "潘尪",
          "type": "白",
          "text": "大王受惊了！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "潘将军抵挡追兵，我三人先回营去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆浑追上打，潘尪驾住。陆戎、陆芬花接战，楚庄王逃下。公子侧、熊负羁抵陆戎。陆芬花同冲下。"
        },
        {
          "character": "四兵",
          "type": "同白",
          "text": "陆兵已退。"
