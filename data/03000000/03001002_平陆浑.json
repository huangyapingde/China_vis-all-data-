        {
          "character": "楚庄王",
          "type": "白",
          "text": "二位将军！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "四面必有暗令号， 准备沙场枪对刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！启大王：辕门火起。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "好不小心！大王请稍坐，小臣救火去也！"
