{
  "script_id": "03001002",
  "title": "平陆浑",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    }
  ],
  "plot": "陆国国王浑侵犯楚国边境，楚庄王率兵亲征；陆浑不敌，遂设计诈降，请楚庄王赴会，拟伏兵谋杀楚庄王。\n楚庄王预有准备，布置兵将迎敌，擒获陆浑弟妹。陆浑无奈降服。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "旗夫甲随苏从同上，苏从起霸。"
        },
        {
          "character": "苏从",
          "type": "念",
          "text": "威风凛凛胆气高，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗夫乙随公子侧同上。"
        },
        {
          "character": "公子侧",
          "type": "念",
          "text": "万马营中逞英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗夫丙随潘尪同上。"
        },
        {
          "character": "潘尪",
          "type": "念",
          "text": "丹心一点能贯日，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗夫丁随熊负羁同上。"
        },
        {
          "character": "熊负羁",
          "type": "念",
          "text": "深受皇恩荷圣朝。"
        },
        {
          "character": "苏从、公子侧、潘尪、熊负羁",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "苏从。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "公子侧。"
        },
        {
          "character": "潘尪",
          "type": "白",
          "text": "潘尪。"
        },
        {
          "character": "熊负羁",
          "type": "白",
          "text": "熊负羁。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "列位请了！只为陆浑犯界，大王御驾亲征。你我整顿人马伺候！"
        },
        {
          "character": "公子侧、潘尪、熊负羁",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四红文堂、四红大铠、四上手、伞夫引楚庄王同上。〖点绛唇〗，〖吹打〗。楚庄王上高台。"
        },
        {
          "character": "苏从、公子侧、潘尪、熊负羁",
          "type": "同白",
          "text": "参见大王！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "堂堂男儿立帝基，欲图大业统华夷。心谋六国归一统，方显威名传后裔。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤，楚庄王。只为陆浑造反，孤家亲领大兵，一则平定陆浑，二来乘势扫荡， 并吞一统，独霸天下。 啊，列位将军，人马可齐。"
        },
        {
          "character": "苏从、公子侧、潘尪、熊负羁",
          "type": "同白",
          "text": "早已齐备，候旨启驾。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "吩咐文武免送，响炮启行！"
        },
        {
          "character": "苏从、公子侧、潘尪、熊负羁",
          "type": "同白",
          "text": "呔！各官听者，大王传旨：文武免送，响炮启行啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、四下手、四女兵、陆戎、陆芬花、陆浑同上。〖粉蝶儿〗陆戎、陆芬花、陆浑并坐。"
        },
        {
          "character": "陆浑",
          "type": "念",
          "text": "陆国风化不甚古，"
        },
        {
          "character": "陆戎",
          "type": "念",
          "text": "要想中华立帝都。"
        },
        {
          "character": "陆芬花",
          "type": "念",
          "text": "列国纷纷惟楚胜，"
        },
        {
          "character": "陆浑、陆戎、陆芬花",
          "type": "同念",
          "text": "定决雌雄定干戈。"
        },
        {
          "character": "陆浑、陆戎",
          "type": "白",
          "text": "某——"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "陆国大王陆浑是也。"
        },
        {
          "character": "陆戎",
          "type": "白",
          "text": "二大王陆戎是也。"
        },
        {
          "character": "陆芬花",
          "type": "白",
          "text": "瓶壶公主陆芬花是也。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "某兄妹三人，占住陆地，统辖诸羌，称为小国。掳掠十数州郡财帛，称为富邦。 只是地辐窄小，不遂心愿。意欲创立一统，未知可否？"
        },
        {
          "character": "陆戎",
          "type": "白",
          "text": "皇兄欲图大业，必得先平荆楚；那边邦小国，何足为虑。"
        },
        {
          "character": "陆芬花",
          "type": "白",
          "text": "今日风景晴和，可将人马撤一平阳之地，一则行围射猎，又可演练兵将，预为 兴兵举动，何愁不能一统天下。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "言之极是。 呔！众将官，撤往平阳之地者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "撒下围场！ （众人同下。鹿形、虎形、熊形同上，同跳。四蓝文堂、四蓝大铠、四下手、四女兵、陆戎、陆芬花、陆浑 同上。）"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "打得飞禽走兽献上。"
        },
        {
          "character": "陆浑、陆戎、陆芬花",
          "type": "同白",
          "text": "大家畅饮一回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启狼主：楚庄亲领大兵，杀奔前来。请主定夺！"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "贤弟、贤妹，庄王兴兵前来，你我抖擞精神，杀他片甲不回！"
        },
        {
          "character": "陆戎、陆芬花",
          "type": "同白",
          "text": "呔！众将官，迎敌去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "楚庄王",
          "type": "内西皮导板",
          "text": "寡人初次领兵将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、四上手、四将官、伞夫引楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "要把陆国一扫光。 坐在雕鞍把旨降， 大小儿郎听端详： 人人奋勇精神壮， 一战成功定边疆。 眼望旌旗飘荡漾， 必是陆浑摆战场。 人马紧紧朝前往， 要擒反贼挂高岗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、四下手、四女兵、陆戎、陆芬花引陆浑同上。会阵。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "呔！来的敢是楚庄王？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤王便是。来的可是陆浑小子？"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "然也。呔，楚庄王！你占荆州数千里地界，自主为王，今日无故来犯我国，是 何道理？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "陆浑！我先王去世，你不问吊，罢贡不进；凭空掳掠民财，犯我边界，真乃盗 贼之辈。孤家大兵到此，就该早献降表，恁敢前来抗拒，真乃大胆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起打。陆浑、四蓝文堂、四蓝大铠、四下手、四女兵、陆戎、陆芬花同败下。"
        },
        {
          "character": "楚兵",
          "type": "同白",
          "text": "陆贼大败。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "扎下营寨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、四下手、四女兵、陆戎、陆芬花引陆浑同上。〖牌子〗。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "哎呀！庄王人马，果然历害，可谓霸国也。"
        },
        {
          "character": "陆戎",
          "type": "白",
          "text": "头阵就伤多少兵将，如何处之？"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "我有一计，杀他君臣片甲不回。"
        },
        {
          "character": "陆芬花",
          "type": "白",
          "text": "皇兄有何妙计？"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "我今前去诈降庄王，效齐桓公衣裳大会，请他君臣进城赴会。你我扣带兵将， 埋伏东南二门，酒过三巡，伏兵齐出，那时可一鼓而擒。"
        },
        {
          "character": "陆戎、陆芬花",
          "type": "同白",
          "text": "恐他不来赴会，如之奈何？"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "且用巧言赚他到来；他若不来，就不能称霸了。"
        },
        {
          "character": "陆戎",
          "type": "白",
          "text": "依计而行。"
        },
        {
          "character": "陆芬花",
          "type": "白",
          "text": "此去须要随机应变，若被看出，事难成矣！"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "这个自然。"
        },
        {
          "character": "陆浑",
          "type": "念",
          "text": "庄王不来非君子，"
        },
        {
          "character": "陆戎、陆芬花",
          "type": "同念",
          "text": "未必贪生作小人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四大铠、潘尪、苏从、熊负羁引楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "为王出兵两争斗， 要效风后灭蚩尤。 但愿一战功成就， 称王图霸服诸侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧上。"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "陆浑小国不禁斗， 一阵杀退就回头。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "禀大王：陆浑营外投降。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "啊？反贼不战就来投降，其中有诈。你可曾搜检明白？"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "臣已搜检明白。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哦，传武士，将陆浑押进营来！"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "将陆浑押进营来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手押陆浑同上。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "小国陆浑叩见大王千岁。小臣等不识天时，乞求恩赦，倾心附楚，死无二意。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "唔！大兵一到，就该早降；今日势败，假意诈顺，诱惑孤中计么？"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "小臣若有诡计，焉敢冒死而来？今请大王效齐桓公衣裳大会，若有歹意，皇天 不佑。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "唔唔……哈哈……孤王顺天行事，岂惧小小诡计！放你回去，孤准前去往赴会。 与他鞍马，出营去吧！"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "谢大王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手押浑同下。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "启大王：那小国初次见阵，心破胆寒；大王为何答应赴会？深临虎穴，恐有不 测！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿就不知昔日齐桓公九合诸侯，一匡天下，皆得管仲之力，孤今若不压服小国， 如何收服诸侯？孤家自有防备！公子侧、熊负羁内穿铠甲，外披袍服，随孤 赴会；潘尪带领人马，远远听探，倘有变动，前往接应；苏从紧守大营，听孤 吩咐！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "陆浑虽然已束手， 恐防奸巧在心头。 孤不赴会脸何有， 以后不能压诸侯。 就是刀山也要走， 要学桓公赴葵邱。 扎住大营紧防守， 诚恐奸人把营偷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂引陆浑同上。"
        },
        {
          "character": "陆浑",
          "type": "唱",
          "text": "衣裳大会计已就， 兵在战法将在谋。 但愿从此天保佑， 灭却庄王夺龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "番将上。"
        },
        {
          "character": "番将",
          "type": "白",
          "text": "禀国王：庄王君臣已到。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "他君臣到了，真是有胆量的。孤王与他酒过三巡，尔等远远伺候，只见火光一 起，即来围住。"
        },
        {
          "character": "番将",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "番将下。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "吩咐摆队相迎！ （〖牌子〗。众人同下。公子侧、熊负羁、楚庄王同上，过场，同下。扯城。四蓝文堂、四蓝马甲、番将引 陆浑同上。公子侧、熊负羁、楚庄王同上。〖吹打〗。接。）"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "大王亲临鄙地，万民仰望也！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "好说。孤王既允赴会，焉有不来之理！"
        },
        {
          "character": "番将",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "陆浑",
          "type": "白",
          "text": "大王请！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "贤君请！"
        },
        {
          "character": "陆浑",
          "type": "唱",
          "text": "大国君王驾来到， 军民欢接似唐尧。 从此两国来和好， 一杯薄酒慰贤劳。"
        },
        {
          "character": "楚庄王",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王替天来行道， 万民乐业贺皇朝。 哪路诸侯有不好， 孤王就要一鼓削。"
        },
        {
          "character": "陆浑",
          "type": "唱",
          "text": "大王仁义恩德好， 各国进贡齐贺朝。 手捧香醪放欢笑， 以后不敢犯边壕。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "好啊！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "陆君奸谋猜透了，"
        },
        {
          "character": "楚庄王",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤来赴会他怎晓！"
