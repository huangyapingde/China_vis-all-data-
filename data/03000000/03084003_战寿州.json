          "text": "何延锡走圆场，推门，进，见花迎春抱，花迎春惊。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "哟，你敢是贼吗？"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "二夫人，小将何延锡在此。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "不问你是谁，夤夜潜入室内，非奸即盗！"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "夫人有书，小将特来候教。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "胡说！我乃元帅侧室，岂能与人苟合，行此无耻之事？想是你私通了哪个丫鬟， 倒来疑赖我么？"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "鲜鱼吞钩虎伤弓， 湘江有水难洗清。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "我是夫人亲笔花笺约来的，又有安息香引路，如今怎么就变了挂？要是元帅知 道，我有书信为证，也还保得性命；只怕二夫你推不了这勾引的罪名！"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "你不勾引我不动， 凤凰栖身宿梧桐。"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "觑他真是风流种， 两面琵琶付楼东。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "何将军！"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "成就休要露行踪，"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "夫人！"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "忘恩负义天不容。"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "千万莫向人前诵，"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "这段姻缘巧相逢。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "请坐吃酒！"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "夫人，早些上床安眠，不要吃酒了。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "岂不知酒是媒人，不吃酒哪有兴头？"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "不错，酒是媒人，快请媒翁，哈哈哈……"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "酒是色的大主东， 凡事无酒不成功。 殷勤且把美酒奉， 好上巫山十二峰。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "夫人，酒已够了，早些睡吧。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "哪个不知我是夫人，要你来叫。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "不叫夫人，叫姐姐。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "我还年轻。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "我的妹妹！"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "我的哥哥！"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "好妹妹呀！"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "共入罗帏鸾交凤，"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "这欢乐喜遇春风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡、花迎春同进帐。徐金花上。"
        },
        {
          "character": "徐金花",
          "type": "念",
          "text": "事不关心，关心则乱。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷命二娘草写奏稿，不知可曾经写完，待我去看。来此已是她房门首，待我 叫门。"
        },
        {
          "character": "何延锡",
          "type": "内白",
          "text": "我的好妹妹！"
        },
        {
          "character": "花迎春",
          "type": "内白",
          "text": "我的好哥哥呀！"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "呀！何人在里面说话？开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡、花迎春同急出帐，同惊。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "你是大夫人么？"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "叫门何事？"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷催取奏稿。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "我已然睡啦，明早送去吧。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷立等要看。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "夫人先去，我随后就来。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "这等大胆，待我打进门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐金花打门进。"
        },
        {
          "character": "何延锡、花迎春",
          "type": "同白",
          "text": "哎呀不好！"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": "何延锡、花迎春",
          "type": "同白",
          "text": "夫人开恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡、花迎春同跪。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "啊！你是何延锡？"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "夫人饶命啊！"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷何等待你，岂知你人面兽心！"
        },
        {
          "character": "徐金花",
          "type": "唱",
          "text": "堂堂帅府威严重， 全然不怕刀剑锋。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "我也不与你讲，去见元帅发落。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "夫人，小将从今以后，再也不敢了。必当尽心办理军务，以赎今日之罪，望夫 人开恩！"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "嗯！若再如此，不但元帅法令森严，可知夫人的厉害！狗头暂记项上，去吧！"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "多谢夫人！我走哪里出去？ 啊，二夫人！"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "嗯……"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "哎哟，吓死我也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡下。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "妹妹，你乃知书达礼之人，怎么做出这等事来？"
        },
        {
          "character": "徐金花",
          "type": "唱",
          "text": "大义纲常廉耻重， 三从四德耀门风。 贪淫失节德丧尽， 玷辱家声污祖宗。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "蒙夫人教训，我知罪啦。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "知罪就好。奏稿可曾经写完？"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "未曾写完。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "快些写起来，送到上房去！"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "徐金花",
          "type": "念",
          "text": "古来多少红颜妇，尽在风流阵里亡。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "送夫人！"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "不消！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐金花下。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "今晚这桩事，幸喜被夫人看见，若是叫老爷看见，保管死无葬身之事！唉！下 次不可！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花迎春下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、八上手、四大铠、高怀亮、李重进引赵匡胤同上。〖点绛唇〗。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "丈夫志在觅封侯，英名标记五凤楼。试看宇宙澄清日，一统山河太平讴。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "本藩，南宋王赵。同兄王征南，兵抵寿州。守将刘仁瞻文武兼全，乃江南名将， 日前身带箭伤，闭关不出。今奉兄王之命，招降于他。若不归顺，再作攻城 之计。 先行！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "传令兵抵寿州城下！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "得令！ 嘚，众军士，元帅有令；寿州城去者！"
        },
        {
          "character": "四龙套、八上手、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐金花抱刘应宗上，花迎春扶刘仁瞻同上。"
        },
        {
          "character": "刘仁瞻",
          "type": "引子",
          "text": "两鬓霜斑兼泪痕，奈眼底，难扫烟尘。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷伤痕好些么？"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "略略好些。连日周兵可曾攻城？"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "张、何二将日夜守护，料无他虑。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内呐喊声。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "人马呐喊，必是贼兵攻城。唉，眼见得城池难保了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "贼兵攻危城，军民心战惊。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启老爷：周兵元帅南宋王赵匡胤，请爷城楼答话。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "啊！他此来必是招降于我。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷意下如何？"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "夫人，难道你不知我的心性？食君之禄，当以身报。决不能苟图富贵，屈膝求 生。看冠带过来！"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷伤痕未愈，不可前去。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "赵匡胤乃天下豪杰，职授藩王，掌元帅大印，非等闲之人。有道是：礼不可缺。 只求吾主洪福齐天，刘氏祖先有幸，三言两语，退了贼兵，合城百姓，得全 蚁命。若是打破城池，我刘仁瞻捐躯报国，只有此子，赵公决不加诛。你二人 有此保救，料无伤害。看冠带过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "过门。刘仁瞻换衣"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷小心在意！"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "夫人放心，决无妨碍。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "老爷，赵元帅若果招降，还是顺从了吧！"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "敢把降字轻出口， 不怕骂名万古留。 强打精神大堂走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐金花、花迎春同下。四龙套、四下手自两边分上。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "扳鞍踏镫上骅骝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场设城。四下手同上，同守城。"
        },
        {
          "character": "赵匡胤",
          "type": "内西皮导板",
          "text": "统领大兵到城壕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、八上手、四大铠、高怀亮、李重进引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "寿州军民魂魄消。 一路行兵妖氛扫， 敢来抗拒丧阴曹。 敬爱仁瞻声名好， 不忍攻城把他招。 江南将官有名号， 文韬武略算他高。 本帅亲自领兵到， 识时方称将英豪。 人马扎驻休罗唣， 传示城楼请英豪。"
        },
        {
          "character": "上手甲",
          "type": "白",
          "text": "城上听者：请你主帅答话！"
        },
        {
          "character": "下手甲",
          "type": "白",
          "text": "启元帅：周兵到。"
        },
        {
          "character": "刘仁瞻",
          "type": "内西皮导板",
          "text": "三军不住连声报，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、刘仁瞻同上。"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "手扶垛口往下瞧。 旌旗飘飘空中绕， 人马密密扎城壕。 三军队队似虎豹， 刀枪闪闪放光毫。 南宋王威风真显耀， 好似天神下九霄。 两个先行会过了： 怀亮本领果然高； 李重进不过巡营哨， 无名之辈小儿曹。 本帅开言把话表， 敬请南宋王听根苗。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "赵元帅请了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刘元帅请了！"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "赵元帅，刘某身带箭伤，不能拒敌。感元帅之德，不令攻城，刘某面谢！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "岂敢！刘元帅，你乃高明之士，何得执迷，连累身家？早当自省，不失封侯！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "城楼上队伍多齐整，"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "周营中将官杀气生。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "刘仁瞻真个威风凛，"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "赵匡胤赤面似天神。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "江南虎将为首领，"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "久闻江湖他为尊。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "若得仁瞻来降顺，"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "且把大义说知音。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "南宋王！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刘元帅！"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "刘某有言奉告。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刘元帅有言请道！"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "昔日我神尧高祖即位，灭夏定隋，开创唐室，一统基业。数百年来，遭逆叛朱 温之变，五帝纷争，共分唐室，五十二载。我主乃大唐谪派，只剩江南吴越弹 丸之地，自食安居，久思恢复旧地。你主占了东、西、北三方地界，尚且贪心 不足，今又兵临我界。我刘仁瞻守此孤城，捐躯报国，以尽臣子之道；决不苟 图富贵，屈膝求生也！"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "东都一半天子分， 江南一半紫微星。 两下各守俱安稳， 免得厮杀动刀兵。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刘元帅言得极是。但天下乃人人之天下，自古有德者居之，有力者得之。唐高 祖亦非创业天子，纳炀帝嫔妃，宿炀帝宫院，并吞天下，二百余年，福已尽矣。 天命归周，所有东、西、北三方俱服，惟江南吴越未下。我主亲统六师，赵 某督帅，勇将千员，取江南易如反掌。久慕元帅大名，乃江南名士，德才兼备， 不便攻城。故尔本要自前来，请元帅同归我主，富贵共之。元帅参详！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "劝明公切勿争强胜， 劝明公弃暗早投明。 妻封子荫多荣幸， 免致烽火害生灵。"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "南宋王休把巧言论， 仁瞻惟表一片心； 君臣大义岂乱紊， 怎肯背主忘国恩？ 宁可首级将刀刎， 献印投降万不能。 久闻元帅大英俊， 不义之言免出唇。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "寿州今已被我困， 将军好比风前灯。 劝你早早三思省， 应天顺人救黎民。"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "纵然兵强人马胜， 插翅难飞寿州城。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "好言良语你不听，"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "一臣不侍二主君。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "祸到临头有伤损，"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "自古怕死不忠臣！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "大小三军攻城进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠同攻城。"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "众将齐放箭雕翎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同放箭。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "螳螂之志休睹胜！"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "来日交锋定输赢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘仁瞻、四龙套、四下手同下。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "好个仁瞻忠烈性， 不愧江南掌权人。 众将努力将城困， 管叫玉石尽皆焚。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同拥下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}