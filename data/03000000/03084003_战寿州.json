{
  "script_id": "03084003",
  "title": "战寿州",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘仁瞻",
      "hangdang": "老生"
    },
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "高怀亮",
      "hangdang": "武生"
    },
    {
      "name": "徐金花",
      "hangdang": "旦"
    },
    {
      "name": "花迎春",
      "hangdang": "旦"
    }
  ],
  "plot": "南唐总制刘仁瞻，坐镇寿州。一日，刘仁瞻与妻徐金花、爱妾花迎春赏菊，部将何延锡来报军情，见花迎春\n风流貌美，约于三更在后花园幽会。时周将赵匡胤犯界，刘仁瞻开城迎战，中箭败回。三更将至，花迎春因\n服侍刘仁瞻恐失约，甚为焦急。刘仁瞻令花迎春回房写奏章求救，花迎春得此机会，遂与何延锡苟合。徐金\n花前往催取奏章，何延锡、花迎春无法躲避，跪求饶命。徐金花晓以大义，将二人宽免。赵匡胤至城下劝刘\n仁瞻归降，花迎春亦苦苦相劝，刘仁瞻不允，周兵遂将寿州围困。",
  "notes": "此系《南界关》前本，但其风格与《南界关》迥然不同，为保存资料，附刊之。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘仁瞻上。"
        },
        {
          "character": "刘仁瞻",
          "type": "引子",
          "text": "虎踞雄关多惆怅，秉忠心，报答君王。"
        },
        {
          "character": "刘仁瞻",
          "type": "念",
          "text": "食君爵禄当谨慎，只在纯忠一片心。从来卿相不易取，全仗胸中锦绣文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌暗上。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "下官，刘仁瞻，浙江钱塘人氏。出身武士，沙场建功，特授总制，坐镇寿州等 处。夫人徐氏，乃都指挥徐文达之女，力可兼人，万夫莫敌。所生一子，取名 应宗，尚在襁褓。次妾花氏迎春，金陵民家之女，诗词歌赋，弹唱兼全，下官 爱如珍宝，一应文书，俱是此女标发。这且不言。昨晚左参何延锡送来万寿菊 花，颜色鲜丽。也曾吩咐备酒，请夫人赏玩。 来，酒宴齐备了么？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "请夫人同二娘出堂！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。 请二位夫人出堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐金花、花迎春同上。"
        },
        {
          "character": "徐金花",
          "type": "引子",
          "text": "佐夫守城，逞雄威，遐迩闻名。"
        },
        {
          "character": "花迎春",
          "type": "引子",
          "text": "玉貌花容，常窃叹，有负芳春。"
        },
        {
          "character": "徐金花、花迎春",
          "type": "同白",
          "text": "老爷！"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "徐金花、花迎春",
          "type": "同白",
          "text": "老爷传唤妾等，有何吩咐？"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "夫人，昨日左参何延锡送来万寿菊花，颜色鲜丽，已曾吩咐备酒，请夫人赏玩。"
        },
        {
          "character": "徐金花、花迎春",
          "type": "同白",
          "text": "妾等奉陪。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "待妾把盏。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "不消，摆下。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "老爷，夫人请！"
        },
        {
          "character": "刘仁瞻、徐金花",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "一年一度黄菊开， 光阴迅速把人催。 太平盛世军民爱， 筵前酌酒且开怀。"
        },
        {
          "character": "徐金花",
          "type": "唱",
          "text": "夫受恩荣数十载， 丹心报国理应该。 膝下有子无挂碍， 万事已足位三台。"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "老爷威名镇四海， 夫人贤德女英才。 忠勇可夸刚强在， 淑性温柔是裙钗。"
        },
        {
          "character": "刘仁瞻",
          "type": "唱",
          "text": "二位夫人多和爱， 吾门侥幸真快哉。 妻贤家顺终无害， 祖宗积德出良才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡上。"
        },
        {
          "character": "何延锡",
          "type": "念",
          "text": "边报飞来到，紧急筹策功。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "哪位在？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "何老爷！"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "我有紧急军情求见元帅。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "请少待。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌进门。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启元帅：何参将有紧急军情求见。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "传他进来！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "元帅有请！"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "参见元帅，末将打躬！"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "少礼。有何军情？"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "今有周主拜赵匡胤为帅，高怀亮为先行，周主御驾亲征，兵渡淮西，一路斩关 夺寨，势如破竹，离寿州只有百里，飞报前来，请元帅定夺。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "有这等事！快取令箭，传齐众将校场伺候！"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡出门。"
        },
        {
          "character": "何延锡",
          "type": "念",
          "text": "无心划长策，有意看佳人。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "哎呀，好位标致的二夫人哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡下。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "花姬，快去写下晓谕，命何参将分派各乡市镇张挂，安慰百姓不得慌乱！"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花迎春出门。"
        },
        {
          "character": "花迎春",
          "type": "念",
          "text": "一言机关动，只愿那人来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花迎春下。"
        },
        {
          "character": "徐金花",
          "type": "白",
          "text": "老爷，周兵势大，应急写飞章上达天廷，请兵相助才是。"
        },
        {
          "character": "刘仁瞻",
          "type": "白",
          "text": "待我与周兵见个高下，再为计较。正是："
        },
        {
          "character": "刘仁瞻",
          "type": "念",
          "text": "酌酒观花未得快，"
        },
        {
          "character": "徐金花",
          "type": "念",
          "text": "岂料周兵潮涌来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘仁瞻、徐金花、旗牌同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、八上手、四大铠、高怀亮、李重进引赵匡胤同上。"
        },
        {
          "character": "四龙套、八上手、四大铠、高怀亮、李重进",
          "type": "同白",
          "text": "启元帅：已离寿州不远，无令不敢前进。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "人马列开！高贤弟攻打头阵！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮带四上手同下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "李将军二队接应！"
        },
        {
          "character": "李重进",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李重进带四上手同下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众将官，安扎营盘！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花迎春上，"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "蛾眉淡扫秋波俊， 锦被添香独自温。 有欢有乐无人近， 倚栏展转望行云。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "奴家，花氏迎春。生性娇媚，喜爱风流。虽然衣罗锦，食珍馐；怎奈兰房寂寞， 衾枕凄凉，好生闷怀。昨见何参领丰姿过人，又出少年，必是风流耐战之将。 若得此人偕欢，奴死无怨矣！"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "又不能传书寄信， 梦里会面话不真。 亦无良法来勾引， 叫我怎样把计行。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "我适才偷眼看他，他也留情于我，是他临去之时，又回头对我一笑，必是多情 种子。恰好老爷命我写下晓谕，叫他誊录，四路张挂，安慰民心。我不免趁此 机会，修书一封，藏在里边，约他明晚三更时分，从后花园越墙而进，与他欢 会一宵。有理呀，有理。待我先将晓谕写了起来！"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "口称元戎发号令， 晓谕四方众黎民： 周兵到来休惊恐。 自然退敌保安宁。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "晓谕写完。再将密约写了起来！"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "提笔拜上多拜上， 拜上参将听端详： 今日相见神惚恍， 奴心最喜少年郎。 期约明晚三更鼓， 槐树西角好越墙。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "且住！他就是进了花园，怎能知道我的卧房？倘若走差了路，被人识破，那还 了得？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花迎春想。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "哦，有啦，将这安息香点将起来，从墙下插起，一直插到我房门首，叫他闻香 引路而来，也就无妨了！"
        },
        {
          "character": "花迎春",
          "type": "唱",
          "text": "奴这里燃香为路引， 郎君只用慢推门。 千万休失银河渡， 鹊桥高架会双星。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "待我封了起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花迎春封信。旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "老爷严命，不敢消停。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "二夫人，老爷晓谕底稿可曾写起，早些送去。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "已封好啦。速叫值日兵丁送到何府去！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "花迎春",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "花迎春",
          "type": "念",
          "text": "有缘千里来相会，无缘对面不相逢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花迎春下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "何延锡上。"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "奉委提兵又下令， 准备貔貅好交兵。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "俺，何延锡。职授寿州参将，奉委提调兵将，明日校场听点。俱已传齐，不免 少息片时。嘿，今日去见元帅，看见二夫人，她往常见我，也还躲避，今日见 我，甚有顾盼之意。正所谓："
        },
        {
          "character": "何延锡",
          "type": "念",
          "text": "秋波光射斗牛宫，叫我魂飞上九重！"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "心猿意马栓不定， 坐卧神思想佳人。 若得襄王神女会， 不枉人生遇娉婷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "宝帐传晓谕，辕门将士遵。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启老爷：元帅有文书，请老爷观看。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡看谕。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "还有小柬一封。 过来！将这晓谕交与承发房誊写，张挂所辖境内，不得有误！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "这封小柬却是为何呢？“何将军私启”。哎哟，好奇怪，好奇怪呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡开信看。"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "花迎春付启何将军： 思念孤衾被儿温。 明晚三更越墙进， 跟寻香火奴房门。 入户同心共衾枕， 错过时光负青春。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "哈哈哈……妙哇！她有怜情意，我有采花心。密书约我明晚三更时分，入内成 其美事。哎呀天哪！但愿两不失误，我就立一个“鸿鸾天喜”牌位，早晚也点 安息香供之哟！"
        },
        {
          "character": "何延锡",
          "type": "唱",
          "text": "机缘凑合非今定， 月老簿上早注明。"
        },
        {
          "character": "何延锡",
          "type": "白",
          "text": "哈哈哈……我好喜也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何延锡下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引刘彦真同上。"
        },
        {
          "character": "刘彦真",
          "type": "引子",
          "text": "大展擎天手，周兵一鼓收。"
        },
        {
          "character": "刘彦真",
          "type": "白",
