        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉恨。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "你拿上前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁拿火盆上前。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "再上前来些。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁移火盆近林黛玉，林黛玉闭目。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "我的诗本子。 （雪雁找出诗稿与林黛玉。林黛玉点头，眼望小箱子。雪雁呆。林黛玉咳嗽吐血。雪雁倒水与林黛玉漱口， 紫鹃用手帕拭林黛玉口。林黛玉拿紫鹃手帕指箱子。）"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘躺着吧！雪雁妹妹，你把箱子打开，想是姑娘要用手帕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁开箱取出白手帕，交与林黛玉。林黛玉丢过一边。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "有字的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁寻出题诗旧帕。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘歇歇吧。何苦又劳神，等好了再瞧吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉接手帕看，咳。雪雁倒水与林黛玉饮。雪雁暗下。林黛玉看手帕。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "黛玉呀黛玉，你好糊涂也！想当初，一片痴心，为他憔悴。又谁知，薄幸的人 儿，口是心非，到今日抛撇下我，成就他的金玉良缘。咳，但愿他二人，百年 偕老就好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉撕帕，撕不动，恨。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘何苦自己又要生气！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉点头，咳嗽、吐血。紫鹃扶林黛玉。林黛玉将手帕投入火盆。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘，这是怎么啦？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉坐起喘息。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "掌灯上来。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "雪雁妹妹点上灯来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁上，点灯。林黛玉取诗稿翻。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘何必又费神思。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "我心里觉得空虚，倒想吃点粥水。雪雁，你去替我弄来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁下。林黛玉翻诗稿。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "一生心血，如此消磨尽了，好不惨伤人也！"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "林黛玉检诗稿心中凄怆， 五年来凭借你诉我衷肠。 可怜我幼年间椿萱凋丧， 走京师依外家影只形单。 春写愁春写怨缠绵惝恍， 好一似蚕自缚麝惜脐香。 到今朝息恹恹难保早晚， 倒不如断情根都付消亡。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "咳，罢了罢了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉焚稿。紫鹃急，呼。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "雪雁妹妹快来!"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁上。雪雁抢诗稿放地下乱扑。林黛玉往后仰压住紫鹃。紫鹃、雪雁同扶林黛玉卧下。紫鹃背躬。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘病情，十分危急，不免请奶奶们前来做主。咳，她们正忙着喜事，哪儿有 工夫来理这垂死之人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃哭。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "哦，有啦，我想大奶奶乃是寡居之人，他们结亲，一定要回避。 雪雁妹妹，你去请大奶奶过来。"
        },
        {
          "character": "雪雁",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪雁下。紫鹃抚问林黛玉。林黛玉不应。紫鹃掩泣。贾探春上。"
        },
        {
          "character": "贾探春",
          "type": "念",
          "text": "别院沸笙歌，病中人奈何？"
        },
        {
          "character": "贾探春",
          "type": "白",
          "text": "奴家，探春。闻说黛玉姐姐病危，急忙前来省视。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾探春入门。紫鹃惊起。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "三姑娘，你看看林姑娘的样儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃痛哭。贾探春携林黛玉手。"
        },
        {
          "character": "贾探春",
          "type": "白",
          "text": "林姐姐，林姐姐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉不应。贾探春哭。李纨、雪雁同急上，同入门。"
        },
        {
          "character": "李纨",
          "type": "白",
          "text": "林妹妹怎么样了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃咽不成声，指床上。李纨看林黛玉，与贾探春点头，各掩泣。林之孝妻、平儿同上。"
        },
        {
          "character": "平儿",
          "type": "念",
          "text": "前堂奉了奶奶命，"
        },
        {
          "character": "林之孝妻",
          "type": "念",
          "text": "要叫紫鹃扶新人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平儿、林之孝妻入门。"
        },
        {
          "character": "林之孝妻",
          "type": "白",
          "text": "原来大奶奶在此。二奶奶刚才与老太太商量啦，那边要用紫鹃姑娘去使唤使唤 哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃拭泪。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "林奶奶，这里的人还没死哪。等她死啦，我们自然都是要出去的。我们当奴才 的人，自然是要听主子的使唤。只是我伺候林姑娘一辈子，现在林姑娘也只挨 得一天半天的时候啦。求你做个好事，让我送了她的终，再去从新巴结别人吧！"
        },
        {
          "character": "紫鹃",
          "type": "唱",
          "text": "林姑娘她待我恩德不浅， 主和婢眼见得永别人天。 你、你、你、你看她喘如丝风刀将断， 怎忍心抱琵琶便过别船！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃大哭。林之孝妻冷笑。"
        },
        {
          "character": "林之孝妻",
          "type": "白",
          "text": "紫鹃姑娘这些话，倒说得好。只是我怎么去回二奶奶？"
        },
        {
          "character": "平儿",
          "type": "白",
          "text": "不要紧，要雪雁妹妹去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平儿携雪雁手。"
        },
        {
          "character": "平儿",
          "type": "白",
          "text": "好妹妹，你去一趟吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平儿向李纨。"
        },
        {
          "character": "平儿",
          "type": "白",
          "text": "这里的事，都费大奶奶的心啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平儿携雪雁同下，林之孝妻随下。李纨抚紫鹃。"
        },
        {
          "character": "李纨",
          "type": "白",
          "text": "好孩子，你别哭了。这是什么时候，你林姑娘的衣衾，还不替安顿，难道她一 个女孩儿家，你还叫她赤身露体，精着来光着去么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃大哭。贾探春哭。李纨且哭且说。"
        },
        {
          "character": "李纨",
          "type": "白",
          "text": "好孩子，你把我的心都哭乱了。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "哎呀，紫鹃妹妹在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃拭泪。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "我是不中用的人了。你服侍我几年，我原指望咱们两个总在一处，不想我……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉喘。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "妹妹，我这里并没有亲人，我的身子是干净的，你好歹求他们送我回去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉抬头看李纨、贾探春，点头、喘。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "哎呀哭啊！"
        },
        {
          "character": "林黛玉",
          "type": "唱",
          "text": "十七年苦生涯将我活怕， 到今朝风和雨断送名花。 万种忧千种愁一齐放下， 本来我清净身白玉无瑕。"
        },
        {
          "character": "林黛玉",
          "type": "白",
          "text": "宝玉！宝玉！你！你……好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林黛玉死。紫鹃哭。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘！姑娘！哎呀！"
        },
        {
          "character": "紫鹃",
          "type": "唱",
          "text": "一见姑娘丧了命， 不由紫鹃痛伤心。 叫一声姑娘黄泉略等，"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "姑娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃碰头。李纨、贾探春同扯住。"
        },
        {
          "character": "紫鹃",
          "type": "唱",
          "text": "等待我贱丫鬟一路同行。"
        },
        {
          "character": "紫鹃",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫鹃哭。李纨、贾探春同哭。李纨、贾探春同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}