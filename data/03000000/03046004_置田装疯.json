{
  "script_id": "03046004",
  "title": "置田装疯",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "徐茂公",
      "hangdang": "老生"
    },
    {
      "name": "黑氏",
      "hangdang": "老旦"
    }
  ],
  "plot": "尉迟恭因代薛仁贵解围，怒打李道宗，被贬归田。高丽国大将铁里金牙造反，指名索尉迟恭应战。徐茂公奉\n旨颁请，尉迟恭装疯，不愿出山。徐茂公乃令军士假意罗唣，诱尉迟恭出。尉迟恭不得已，始从征。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引徐茂公同上。"
        },
        {
          "character": "徐茂公",
          "type": "引子",
          "text": "忠心耿耿，扶保乾坤。"
        },
        {
          "character": "徐茂公",
          "type": "念",
          "text": "丹凤来仪宇宙春，置田雨露四时新。世间两事全忠孝，臣报君恩子孝亲。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "老夫，徐茂公。唐王驾前为臣，官拜殷国公之职。只因高丽国反了大将铁里金 牙，指名要尉迟老将军出马，现在鸭绿江前讨战。老夫奉了圣命，去到置田庄 搬取尉迟老将军平定高丽。 军士们！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "打道置田庄！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、徐茂公同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黑氏上。"
        },
        {
          "character": "黑氏",
          "type": "引子",
          "text": "功臣无故遭谗害，来作耕田种地人。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "老身，黑氏。夫君尉迟敬德。自从谪贬置田庄，倒也清闲自在。不料老相公前 日赴牛羊大会，偶得疯疾回来，令人忧心。今日草堂无事，不免请老相公出来， 闲话一回。 老相公，出来走走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭作疯态上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "妈妈，哎呀呀呀呀！妈妈，看庄外有人无有？"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑氏看。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "庄外无人。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "将门关好。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑氏关门。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "庄门关上了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "妈妈，你道我这病是真病呢，还是假病？"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "这病啊，老相公，自然是真，哪会有假？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哈哈哈……老夫不言，谅你不知。老夫前日赴牛羊大会，乡邻李拐儿一人来迟。 问他因何来迟，他说在城中探得一桩新闻，故尔来迟。问他打听什么新闻， 李拐儿言道：高丽国反了大将铁里金牙，指名要尉迟老将军出马，现在鸭绿江 前讨战。老夫闻听此言，一跤跌倒在地，故尔装成此病。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "原来如此，谢天谢地！老相公，今日草堂无事，何不将昔日投唐之事细说一番。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "妈妈不嫌耳烦，听我道来："
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "忆自投唐数十秋，金戈铁甲几时休？两道眉锁江山恨，一片心怀社稷忧。 水磨钢鞭一骑马，要把乾坤掌内收！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄原板",
          "text": "我也曾为国家辟土开疆， 我也曾为国家受尽风霜。 我也曾御果园救过圣驾， 我也曾入胡地削发改装。 挣下了国公位无福受享， 都只为李道宗那贼猖狂。 实指望举拳头将他打丧， 打落了他门牙惹起祸殃。 若不亏徐军师把本奏上， 险些儿老骨骸无处埋藏。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "原来如此。今日虽贬置田庄，倒还有些乐趣。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "怎么不乐！"
        },
        {
          "character": "尉迟恭",
          "type": "二黄原板",
          "text": "闲来时扮作那樵夫模样， 着草鞋拿板斧散步山岗。 自己耕自己食自己安享， 黄齑饭沟茗茶滋味深长。 闷来时邀邻翁山溪闲荡， 想从前封侯事春梦一场。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "如此说来，倒也清闲自在。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "妈妈看茶解渴。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑氏下。徐茂公上。"
        },
        {
          "character": "徐茂公",
          "type": "念",
          "text": "为国求良将，来到置田庄。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "来此已是。里面有人么？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "妈妈快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑氏上。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "唤我何事？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "外面有人叫门。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "外面何人叫门？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老夫徐勣到此。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "哎呀，老相公，徐军师来了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "这老儿又来多事。啊妈妈，徐军师足智多谋，少时与他说话，恐怕说到高兴之 时，动手舞脚，叫他识破机关，反为不便。妈妈可站在一旁，打一个暗号—— “看拐儿”，我就知道了。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "私场演，公场用，试演试演。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "使得使得。呔！"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "看拐儿。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊呦啊呦，哈哈哈……着啊！开门有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。黑氏开门。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "原来是徐军师，请！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "军师请坐！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐茂公坐。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "请问老夫人，老将军今在何处？"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "现在病房。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "请来相见！"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "是。 有请老相公！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊呦啊呦！军师，有病在身，恕不全礼！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "老将军，你我朝歌一别，此病从何而起？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊，哈哈哈……"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "军师，天有不测风云，人有旦夕祸福。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "是呀！请问军师：唐王驾安？"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "唐王安泰。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "各位国公可好？"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "各位国公问候老将军安好？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "岂敢！军师到此，有何见论？"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "老夫特奉圣命而来，调取老将军入朝议事。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "疾病缠身不能前往，望军师代为复命。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "圣旨下！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "有病在身，不能跪拜。这便怎么处？"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "请老夫人代跪吧！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "也罢！妈妈，少时军师读罢圣旨，老夫叫你谢恩，你就谢恩；不叫你谢恩，你 就不要谢恩！"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "圣旨下，跪听宣读！"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "皇帝诏曰：今有高丽反了大将铁里金牙，特命尉迟恭统领精兵，前往征剿。得 胜回朝，将功折罪，仍复国公之职。旨意读罢，望诏谢恩。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊妈妈，不要谢恩！不要谢恩！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "啊，老将军，你敢违抗圣旨么？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊哈哈哈……军师呀！"
        },
        {
          "character": "尉迟恭",
          "type": "西皮原板",
          "text": "非是我尉迟恭将旨违抗， 徐军师坐草堂细听端详： 我耳聋听不见战鼓响亮， 眼昏花看不见阵前儿郎； 使不得水磨鞭难以抵挡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭手舞足蹈。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "看拐儿！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎哟哎哟！"
        },
        {
          "character": "尉迟恭",
          "type": "西皮原板",
          "text": "骑不得乌骓马怎上战场？ 望军师回朝去把本奏上， 你就说尉迟恭染病在床。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "噢，既然如此，老夫告辞了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "妈妈代送！"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑氏送徐茂公出。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "老夫人请转！"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "徐茂公",
          "type": "念",
          "text": "莫信直中直，须防人不仁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐茂公下。黑氏进。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "徐军师去了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "适才我与徐军师说话，装得可像？"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "装得像。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哈哈哈……谅得那老儿也解我不透。转到后堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、黑氏同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐茂公上。"
        },
        {
          "character": "徐茂公",
          "type": "念",
          "text": "千军容易得，一将最难求。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "老夫适才与老将军讲话，黑夫人一旁说道：“看拐儿”。显见其中有诈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐茂公想。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "嗯，我自有道理。军士们走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同念",
          "text": "军师唤一声，何方将令行。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "军师在上，小人们叩头。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "谢军师！军师呼唤，有何差遣？"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "前面有一高大楼房。去到那里，就说我们是往高丽国去的军士，见你们房屋高 大，要借此房屋屯军养马；男子铡草，女子补衲袄！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "恐他不肯。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "倘若不肯，你们就罗唣。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "小人们怕惹出祸来！"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "有我担待。快去！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。"
        },
        {
          "character": "徐茂公",
          "type": "念",
          "text": "劝人休弄巧，弄巧反成拙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐茂公下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "来此已是，待我们叫门。 里面有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑氏上。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑氏出门。"
        },
        {
          "character": "黑氏",
          "type": "白",
          "text": "你们是作什么的？"
        },
        {
          "character": "四龙套",
          "type": "同白",
