{
  "script_id": "03001005",
  "title": "荥阳关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "唐狡",
      "hangdang": "武生"
    },
    {
      "name": "襄老",
      "hangdang": "丑"
    }
  ],
  "plot": "楚庄王欲图霸业，兴兵伐晋，兵临荥阳关，命襄老、唐狡攻取。襄老欲争首功，独出搦战；唐狡趁机暗袭，\n夺占荥阳，大胜晋师，直逼绛都。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、四将、四下手引先縠同上。〖点绛唇〗。"
        },
        {
          "character": "先縠",
          "type": "念",
          "text": "兄长奉命伐楚庄，可叹一命丧疆场。只为晋国咽喉地，带领雄兵镇荥阳。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "某，晋国副元帅先縠是也。只为楚庄兵伐我国，兄长先蔑已被斩首。吾主命下， 道那荥阳关乃晋国咽喉之所，命我带兵三千，前往镇守。如今楚兵蜂拥而至， 必夺此关，故此迅速前往。 众将官！人马速至荥阳关去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、公子侧、潘尪、襄老、唐狡、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "旗旛高展空照耀， 将士个个紧战袍。 先蔑人马平静了， 不扫晋成气怎消？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "啊，列位将军！"
        },
        {
          "character": "公子侧、潘尪、襄老、唐狡",
          "type": "同白",
          "text": "大王。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤王伐晋，一路夺了数城，势如破竹。前面已是荥阳关，乃是晋国咽喉之地。 有人取得此关，功劳第一，即封上卿之爵。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "小将唐狡愿取此关。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀，将军连日勤劳，今又独战前行，真贤臣也！就命将军随带本部人马攻取 荥阳；孤王大兵随后。听孤令下！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "一路斩关如风扫， 惟有荥阳要辛劳。 此去只须智谋巧，"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "小将军！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "要成大业在今朝。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "大王令下如雷暴， 不由壮气冲云霄。 食君爵禄当图报， 岂可贪生惜辛劳！ 此番若把关取了， 隐姓埋名乐逍遥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "为王统兵把晋扫， 险些一命赴阴曹； 不是当日存厚道， 怎得唐狡小英豪？ 能征惯战有计巧， 兵机智谋比人高。 此去荥阳摆战道， 众军戮力涌如潮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、公子侧、潘尪、唐狡、楚庄王同下。"
        },
        {
          "character": "襄老",
          "type": "唱",
          "text": "楚营能将有多少， 单单差遣小唐狡。 左思右想真难料， 满腔怨气不肯消。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "且住。想唐狡乃我部下小卒，大王如此重用，命他独取荥阳，我心中实是不服。 也罢，不如单人独骑，绕小路去往关前叫骂。守城将官必然出关迎敌，我国 将官前来抵杀，那时我乘势夺取荥阳，占住头功，以息唐狡威风也。"
        },
        {
          "character": "襄老",
          "type": "唱",
          "text": "自随楚国功不小， 出兵岂让小儿曹； 心中安排牢笼套，"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "襄老",
          "type": "唱",
          "text": "小将未必善开交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "襄老下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四老军、唐狡同上。"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "大营将官静悄悄， 独俺一人报当朝。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "俺，唐狡。帐前夸下大口，稳取荥阳关。想此城坚固，难以得破。适才有小军 报说，襄老单人独骑，绕小路骂贼出战。为此俺带领老军扮做樵夫，混进关去， 杀个落花流水，就可稳取此关也！"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "只愿苍天相佑保， 受恩深处不辞劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、四将、四下手、先縠同上。〖牌子〗。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "某，先縠。奉命把守荥阳关，闻得楚兵杀奔前来，曾命小军探听，未见回报。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "楚将骂关！"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "传鲍葵进帐！"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "鲍葵进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲍葵上。"
        },
        {
          "character": "鲍葵",
          "type": "念",
          "text": "身为大将披甲胄，全凭谋略定兵机。"
        },
        {
          "character": "鲍葵",
          "type": "白",
          "text": "先锋鲍葵参见元帅！"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "将军少礼。"
        },
        {
          "character": "鲍葵",
          "type": "白",
          "text": "有何将令？"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "楚兵前来攻城，命你带领一哨人马，从小路抄入楚军后队；听本帅号炮一响， 前后夹攻，将庄王君臣一鼓而擒，不得违误！"
        },
        {
          "character": "鲍葵",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "鲍葵",
          "type": "念",
          "text": "军威整齐候炮响，擒王斩将建奇功！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲍葵下。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "众将带马上关！"
        },
        {
          "character": "先縠",
          "type": "唱",
          "text": "可恨楚庄忒欺藐， 吾兄命丧马鞍鞒。 统领雄师打战表， 戴天之仇怎开交。 同主戮力把城保， 且看来的将英豪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "先縠下。襄老上。"
        },
        {
          "character": "襄老",
          "type": "唱",
          "text": "单人独骑出营哨， 要想头功压唐狡。 站立吊桥高声叫，"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "襄老",
          "type": "唱",
          "text": "守城将官出城壕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扯城。兵卒上。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "楚将骂关！"
        },
        {
          "character": "先縠",
          "type": "内西皮导板",
          "text": "忽闻小军一声报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "先縠上。"
        },
        {
          "character": "先縠",
          "type": "唱",
          "text": "睁开虎目往下瞧： 城下马嘶人喧闹， 并无队伍摆城壕； 却有一将年纪老， 有何诡计枪对刀。 叫儿郎开关摆战道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、先縠同冲出城。开打。唐狡上隐进城。"
        },
        {
          "character": "先縠",
          "type": "唱",
          "text": "骂城老将不许逃。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "通名受死！"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "唔，大丈夫行不更名，坐不改姓。呔，孺子！俺乃庄王驾前先锋襄老是也！"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "老弱残兵，枉送性命。去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "襄老下。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "老将逃走！"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "黄昏之时，恐有埋伏，收兵进关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "呔，开关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡上。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "哪里人马？"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "先元帅人马！"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "呔！先縠听了：楚将唐狡已取此关，快快束手归降，若有相持，明日交锋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡下。撤城。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "这厮用计赚了此关，如今将错就错。众将官，今夜去劫楚营，只要擒住庄王， 胜如百万雄师。杀奔楚营去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四上手、公子侧、潘尪、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "自掌楚业屡征讨， 各国闻名胆魂消。 陆浑无知已除剿， 晋、陈凭空起戈矛。 孤王御驾亲征讨， 马不停蹄挂战袍。 坐在大营听探报， 昼夜筹思费心焦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "唐将军已取荥阳关！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "我好喜也！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "唐狡虽然年纪小， 智取荥阳见识高。 众军不准卸盔靠， 准备关前枪对刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "晋兵劫营！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "这又奇了！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "晋兵既然失城道， 何敢前来劫龙巢？ 三军整齐枪和炮， 定灭晋兵莫放逃。 四下安排连环炮， 君臣弃营且奔逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "起更鼓。四蓝文堂、四蓝大铠引先縠同上。干牌子。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "杀进营去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "干牌子。"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "啊？庄王哪里去了？"
        },
        {
          "character": "四蓝大铠",
          "type": "同白",
          "text": "他君臣弃营逃走！"
        },
        {
          "character": "先縠",
          "type": "白",
          "text": "速速追赶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、公子侧、潘尪、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "远望荥阳难得到， 舍死忘生同奔逃。 一夜之间跑坏了， 认不出高低路哪条？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "耳边听得人马闹。 （楚庄王下。四蓝文堂、四蓝大铠引先縠同冲上，同杀，潘尪倒抵，鲍葵接上杀，唐狡冲上抵，轰同下。连 上，唐狡杀先縠死，杀鲍葵，襄老取首。四上手拥唐狡同下。公子侧、潘尪、楚庄王同上。唐狡、襄老同上。）"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "原来爱卿小唐狡！"
        },
        {
          "character": "唐狡、襄老",
          "type": "同白",
          "text": "大王受惊了！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "爱卿夺了荥阳，怎知孤王来此遇险？"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "小臣取了荥阳关，欲到天明请驾进城，心中转想贼子必然劫营；故命兵将把守 城池，单人独骑，前来救驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀，后面又有追兵来了！"
        },
        {
          "character": "唐狡",
          "type": "白",
