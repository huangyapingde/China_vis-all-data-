{
  "script_id": "03053006",
  "title": "双包案",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "假包拯",
      "hangdang": "净"
    }
  ],
  "plot": "包拯放粮回朝，为妖精所见。众妖扮假包拯等扰乱之。包拯遂请来天神降妖。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。大妖、二女妖、八小妖同上。"
        },
        {
          "character": "大妖",
          "type": "念",
          "text": "洞中修炼几千年，变化人形在世间。恼恨包拯屡作对，前往开封扰一番。"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "众位大仙！"
        },
        {
          "character": "二女妖",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "你我洞中修炼，甚是道遥自在。可恨包拯铁面无私，仗恃张捷，屡屡与我等作 对。今趁他陈州放粮，不在京都，前去扰乱一番。 众小妖听令！"
        },
        {
          "character": "八小妖",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "你等变作开封人役模样，待我变作包拯，你我一同前往开封扰乱一番！"
        },
        {
          "character": "八小妖",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "二位大仙，看守洞府！"
        },
        {
          "character": "二女妖",
          "type": "白",
          "text": "须要小心！"
        },
        {
          "character": "大妖、二女妖",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大妖、八小妖同下。"
        },
        {
          "character": "二女妖",
          "type": "同白",
          "text": "小心看守洞府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二女妖同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "包拯",
          "type": "内白",
          "text": "开道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四青袍、王朝、马汉、张龙、赵虎引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "秉忠心立朝堂扶保宋君， 龙图阁大学士代管民情。 俺包拯铁面无私忠心耿， 虎头铡威震些恶霸刁民。 追魂鞭、照妖镜把妖魔扫尽， 法堂上断公案神鬼皆惊。 只因为陈州地干旱三载百姓丧命， 奉圣旨去陈州放粮安民。 随带着王朝、马汉、张龙、赵虎衙役等， 一路上断了些土豪劣绅。 此一番放粮毕回朝复命， 为国家为黎民食王爵禄当尽忠心。 叫王朝与马汉开道前进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八小妖引大妖同上，同上高台。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "回龙廷写本章禀奏当今。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、王朝、马汉、张龙、赵虎、包拯同下。"
        },
        {
          "character": "大妖",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "众小妖！"
        },
        {
          "character": "八小妖",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "看包拯陈州放粮回来，打此经过。趁此机会，你等变作王朝、马汉等模样，待 我看来！"
        },
        {
          "character": "八小妖",
          "type": "同白",
          "text": "好，闪开了！"
        },
        {
          "character": "八小妖",
          "type": "同唱",
          "text": "运动法力摇身变，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火彩，八小妖同下，假四青袍、假王朝、假马汉、假张龙、假赵虎同上。"
        },
        {
          "character": "假四青袍、假王朝、假马汉、假张龙、假赵虎妖",
          "type": "同唱",
          "text": "就请大仙仔细观。"
        },
        {
          "character": "假四青袍、假王朝、假马汉、假张龙、假赵虎妖",
          "type": "同白",
          "text": "大仙，看我等变得可像？"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "变得倒也不错。"
        },
        {
          "character": "假四青袍、假王朝、假马汉、假张龙、假赵虎妖",
          "type": "同白",
          "text": "大仙变来，我等观看。"
        },
        {
          "character": "大妖",
          "type": "白",
          "text": "你等闪开了！"
        },
        {
          "character": "大妖",
          "type": "唱",
          "text": "摇身一变金光绕！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火彩，大妖下，假包拯上。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "假变包拯乐逍遥。 此番开封去搅扰， 个个小心莫辞劳。 驾起狂风开封到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场，假包拯坐。"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "带上了二施信细问恨苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施信、假施信同上。"
        },
        {
          "character": "施信、假施信",
          "type": "同白",
          "text": "参见大人！"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "施信",
          "type": "白",
          "text": "小人名叫施信。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "假施信",
          "type": "白",
          "text": "小人名叫施信。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "你二人谁是真的，谁是假的？从实招来！"
        },
        {
          "character": "施信、假施信",
          "type": "同白",
          "text": "我是真的，他是假的。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "听罢言来心头恼， 敢在开封欺老包。"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "真施信！"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "赐你皮鞭将他拷！"
        },
        {
          "character": "假施信",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "假施信打施信。"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "看他承招不承招？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内鸣锣。四青袍、王朝、马汉、张龙、赵虎引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "来在开封下了轿， 一见妖魔怒冲霄。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "呔！何方妖怪，敢坐老夫的法堂？"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "呔！何方妖怪，敢来老夫的法堂？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谁不知龙图阁大学士断事如神？劝你本早现了原形便罢；如若不然，可知老夫 照妖镜的厉害！"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "谁不知龙图阁大学士断事如神？劝你早早现了原形便罢；如若不然，可知老夫 照妖镜的厉害！"
        },
        {
          "character": "包拯、假包拯",
          "type": "同白",
          "text": "王朝、马汉，看照妖镜伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同取照妖镜，假包拯喷照妖镜。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊！老夫照妖镜百照百准，今日为何照不出他的原形来了？"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "啊！老夫照妖镜百照百准，今日为何照不出他的原形来了？"
        },
        {
          "character": "包拯、假包拯",
          "type": "同白",
          "text": "王朝、马汉，照妖镜收起！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同收照妖镜。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "反了哇！"
        },
        {
          "character": "假包拯",
          "type": "白",
          "text": "反了哇！"
        },
        {
          "character": "包拯、假包拯",
          "type": "同白",
          "text": "反了！"
        },
        {
          "character": "包拯、假包拯",
          "type": "同唱",
          "text": "不由老夫心头恼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖四击头〗。"
        },
        {
          "character": "包拯、假包拯",
          "type": "同白",
          "text": "嗯！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "大宋朝又出了二老包。"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "大宋朝又出了二老包。"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "老夫的威名谁人不晓？"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "老夫的威名谁人不晓？"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "尔竟敢在开封府假变臣僚！"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "尔竟敢在开封府假变臣僚！"
        },
        {
          "character": "包拯",
          "type": "唱",
          "text": "我劝你早把那原形现了，"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "我劝你早把那原形现了，"
        },
        {
          "character": "包拯、假包拯",
          "type": "同唱",
          "text": "少有迟延尔的命难逃！"
        },
        {
          "character": "包公",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "包公",
          "type": "唱",
          "text": "妖魔胆量真不小， 敢与老夫絮叨叨？ 俺包拯赤胆忠心君王保， 尔竟敢搅扰开封变臣僚！ 这真老包，假老包， 真假老包不差半分毫。 照妖镜，是法宝， 今日照不出他原形为哪条？ 这件事，怎样了？ 只气得包拯怒发冲冠气难消。 王朝与爷你就忙焚表！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。王朝焚表。"
        },
        {
          "character": "假包拯",
          "type": "唱",
          "text": "一见焚表心内焦。 倘若天师驾来到， 我的性命难保牢。 众仙预备快些跑， 回洞去搬来了众弟妹，齐心努力与他闹糟糕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "假包拯、假四青袍、假王朝、假马汉、假张龙、假赵虎同下。〖急急风〗。众天兵引天神同上。"
        },
        {
          "character": "天神",
          "type": "白",
          "text": "差官请了！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "天神",
          "type": "白",
          "text": "我等奉了天师之命，前来相助。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "妖魔搅闹开封，请尊神降妖。"
        },
        {
          "character": "天神",
          "type": "白",
          "text": "差官禀知包大人，我等降妖者！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "有劳尊神！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝下。"
        },
        {
          "character": "天神",
          "type": "白",
          "text": "众天兵，追赶妖魔去者！"
        },
        {
          "character": "众天兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}