{
  "script_id": "03029003",
  "title": "送灯",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张继贤",
      "hangdang": "小生"
    },
    {
      "name": "贾桂娟",
      "hangdang": "花旦"
    },
    {
      "name": "贾氏",
      "hangdang": "老旦"
    }
  ],
  "plot": "张继贤赴试遇虎，为壮士曾清所救，遂结金兰。曾清妹桂娟，色艳过人，恶霸万权强欲为婚。曾清扮女替妹，\n并嘱母贾氏许妹与张继贤。及提亲，张继贤不允。贾氏命桂娟夜晚送灯，张继贤见之惊喜，遂拜天地。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张继贤上。"
        },
        {
          "character": "张继贤",
          "type": "引子",
          "text": "笔底生花登池砚，半夜黄昏独自眠。"
        },
        {
          "character": "张继贤",
          "type": "念",
          "text": "未曾到京地，路遇猛虎逼。别却双亲面，谁知受孤栖。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "小生，姓张名继贤。乃湖广楚南人也。父亲在朝，官居武陵侯。小生忝入黌门。 上京应试，路遇猛虎，多亏打虎壮士搭救，小生与他结为八拜之交，他将我 留在他家。想起双亲，好不伤感人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏上。"
        },
        {
          "character": "贾氏",
          "type": "念",
          "text": "家有绢丝做生涯，织就绫罗与缎纱。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "老身，贾氏。所生一男一女：男名曾清，女名桂娟。可恨万权那贼，要强逼我 女儿为婚。我女儿执意不从。我曾清孩儿，假妆我女儿冲喜去了。临行之时， 叫我将女儿许配琴房那位相公。因此奉茶前来。 啊，相公开门来！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "来了。啊妈妈！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "相公请茶！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "多谢妈妈！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "一杯清茶，何必酬谢？此间不是叙话之所。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "请到琴房。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "随我来。相公请进！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "这厢有礼！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "还礼。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "请问相公，家住哪里，姓甚名谁？"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "小生姓张名继贤，乃湖广楚南人也。父亲官居武陵侯，小生忝在黌门。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "噢！原来是一位秀才官人，失敬了！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "岂敢。请问妈妈，那打虎壮士，是妈妈何人？"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "就是小儿。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "原来是义母，失敬了！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "岂敢！为何“义母”相称？"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "我与令郎拜为知交。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "小户人家怎敢高攀？"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "老身有一言不好启齿。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "有何金言？当面请讲。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "老身有一女，意欲许配相公，不知意下如何？"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "前恩未报，不敢从命。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "告便。 是呀！难怪他不从，他也从来没有见过我女儿的容貌啊。不免叫女儿梳妆起来， 送灯进房，拉拉扯扯，也要他做个女婿。 啊相公，少时有人送灯前来，老身失陪了！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "贾氏",
          "type": "念",
          "text": "试看蜘蛛牵引线，春来蝴蝶闹花枝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏下。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "方才那妈妈说，少时有人送灯前来。话便一句，叫小生好难解也！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "这妈妈说话好奇怪！ 倒叫小生解不开。 莫不是误入天台路？ 莫不是梦魂上阳台？ 将身坐在琴房内， 看是何人送灯来。"
        },
        {
          "character": "贾氏",
          "type": "内白",
          "text": "随娘来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏引贾桂娟提灯同上。"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "两道娥眉懒放开， 母女双双到此来。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "儿呀，你看好明月呀！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "是啊！"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "月移花影阑干外， 一阵香风扑面来。 桂花枝挂住了金凤钗，"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "挂着了为娘给你拿下来。"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "绿苔痕滑却我的绣花鞋。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "儿啊，为何不走？"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "鞋儿掉了。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "待为娘给你提上。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "好了。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "走吧！"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "一盏银灯照粉面， 羞容答答怎向前？"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "来此已是。送灯进去吧！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "我不进去！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "为什么？"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "难为情啊！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "这有什么难为情？灯在这儿，去也在你，不去也在你。为娘我去了。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "母亲，回来商量商量。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "有什么商量？为娘看你可以去得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏下。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "母亲转来！母亲转来啊！嗳，我那不明白的娘啊！"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "奴家生来命运蹇， 二八未配好良缘。 进琴房将银灯放在桌案， 坐在一旁不开言， 啊啊啊……不开言。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "琴房惊醒张继贤， 只见佳人赛天仙。 走向前来把礼见，"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "大姐，小生有礼了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张继贤看贾桂娟。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "妙啊！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "一双凤眼把人观。 小娘子请坐容客便， 有劳你送灯到此间。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "好说！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "请问大姐，那位妈妈是大姐何人？"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "乃是家母。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "小生不知，多有得罪！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "请问大姐,叫什么名字？"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "小字桂娟。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "妙啊！“桂”乃“丹桂”之“桂”，“娟”乃“婵娟”之“娟”，大姐，好个 响亮的名儿呀！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "我说你好个响亮的名儿呀！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "好个美名叫桂娟， 引得小生心不安； 自古高山出骏马， 茅菴草舍有婵娟。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "请问相公，高姓大名？"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "小生张继贤。乃湖广楚南人也。父亲官居武陵侯，小生忝入黌门，是个秀才。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "原来是一位秀才官人，失敬了！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "哈哈哈！"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "好个美名张继贤，"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "大姐叫什么名字？"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "桂娟。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "桂娟啊！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "不错，是桂娟。"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "连把奴名问几番。 莫不是母亲生巧计， 河边垂下钓鱼竿。"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "琴房内难坏了张继贤， 心猿意马怎开言？ 走向前来把礼见，"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "大姐，小生有礼了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张继贤作揖。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "方才见过礼了。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "先前不为恭敬，如今重来见过。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "想是他爱见礼？奴家还礼。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "大着胆儿扯衣衫。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "闺门女子非下贱， 你敢大胆发狂癫！"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "心中只把自己怨， 胆小怎能结姻缘？ 屈膝跪求施恻隐，"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "大姐！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "念小生在外实堪怜。"
        },
        {
          "character": "贾桂娟",
          "type": "唱",
          "text": "奴劝你休得胡乱言， 我母闻之送到官。 打你板子问你罪， 贪花容易后悔难。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "自古道色胆大如天， 哪怕王法送到官？ 大姐请来拜天地，"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "我不拜。"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "来啊！"
        },
        {
          "character": "张继贤",
          "type": "唱",
          "text": "我和你做一对并蒂莲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾氏暗上。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "咳！你们俩做的好事啊！气死老娘了。 你是桂娟？"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "不是桂娟，是娟桂。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "小贱人，羞不羞？羞不羞？"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "唔，啊义母，方才是小生的不是。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "不是你的不是，难道是是我的不是吗？"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "这！是小生衣衫长了，绊跌大姐在地，小生也跪下了。唔，连这一只也跪下了。"
        },
        {
          "character": "贾桂娟",
          "type": "白",
          "text": "母亲，他乃黌门秀才，母亲怎么受得了他拜？我这里陪跪了！"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "噫！他俩人竟同了心，打起和来了。"
        },
        {
          "character": "贾氏",
          "type": "唱",
          "text": "走向前来用手搀， 好姻缘反做歹姻缘。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "我先前叫你应允，你执意不从；如今见了她，喏喏喏，你……"
        },
        {
          "character": "张继贤",
          "type": "白",
          "text": "非是小生不允，山遥路远，未曾带得彩礼。"
        },
        {
          "character": "贾氏",
          "type": "白",
          "text": "谁要你聘礼？当着老身，多拜几拜就也是了！"
        },
        {
          "character": "张继贤、贾桂娟",
          "type": "同白",
          "text": "我们先前拜过了。"
        },
        {
          "character": "贾氏",
          "type": "白",
