{
  "script_id": "03096005",
  "title": "战长沙",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "黄忠",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "魏延",
      "hangdang": "净"
    },
    {
      "name": "韩玄",
      "hangdang": "老生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "关羽奉命攻长沙，守将韩玄命黄忠出战。黄忠落马，关羽释之。黄忠回城后，韩玄命其次日以箭射关羽。黄\n忠感关羽不杀之义，不忍伤其性命，只射盔樱。韩玄疑黄忠有降刘备之意，欲斩之。适魏延解粮回，求赦。\n韩玄不允。魏延杀韩玄，逼黄忠同投刘备。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "志气冲霄汉，赤胆忠心，保江山。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "蚕眉凤目秉忠心，青龙偃月破黄巾。苍天若助三分力，扭转汉室锦乾坤。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某、汉室关。奉命镇守荆州一带等处，某与军师打赌，夺取长沙。 军士们！"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "站立两厢，听某一令！"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "某奉军师将令差，"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "运筹帷幄坐将台。 旌旗不住空中摆， 大小儿郎逞雄才。 某家出世英名在， 哪把长沙挂心怀。 吩咐三军把马带，"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上马，四绿龙套同下。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "他日有功列三台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同上，双起霸。"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "老将年高大，"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "威震在长沙。"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "惯使穿杨箭，"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "保主锦中华。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "某、（黄忠）（魏延）。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "将军请了！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "元帅升帐，你我两厢伺候。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同下。四文堂、韩玄同上。"
        },
        {
          "character": "韩玄",
          "type": "引子",
          "text": "威震长沙，秉忠心，扶保乾坤。"
        },
        {
          "character": "韩玄",
          "type": "念",
          "text": "执掌兵权印，决策扫烟尘。忠心扶社稷，赤胆保龙廷。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "本帅，韩玄。奉我主之命，镇守长沙。今有桃园弟兄前来夺取长沙，不免传黄、 魏二将进帐，议论迎敌之计。 来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "传黄、魏二将进帐。"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "元帅有令，黄、魏二位将军进帐！"
        },
        {
          "character": "黄忠、魏延",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同上。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "（黄忠）（魏延）告进。参见元帅！"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "二位将军少礼。请坐！"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "谢坐。传末将等进帐，有何军情议论？"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "今有桃园弟兄，前来夺取长沙，请二位将军进帐，议论迎敌之计。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "启禀元帅：想长沙、桂阳、彝陵、武陵四郡，各有军兵把守，何惧桃园弟兄！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "但不知何人领兵前来？"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "且听探马一报，自见分晓。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "关羽讨战。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "二位将军！关羽讨战，哪位将军出马？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "元帅，既是关羽讨战，黄某情愿带领一支军马，生擒关羽入帐。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "且慢！老将军，我想关羽出世以来，过五关、斩六将，何等威风，人人皆知。 诚恐老将军前去，不是他人对手。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "魏将军此言差矣！老只老头上发，项下须。有道是："
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "虎老雄心在，年迈力刚强！"
        },
        {
          "character": "黄忠",
          "type": "西皮二六板",
          "text": "魏将军把话错来讲， 某家言来听端详： 赵国廉颇七旬上， 独战秦兵逞刚强。 你道关羽是好将， 岂不知强中自有强中强。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "老将军！"
        },
        {
          "character": "魏延",
          "type": "西皮流水板",
          "text": "老将军说话不思量， 某家言来听端详： 关羽生来是好将， 千里路上保皇娘。 过五关曾斩六员将， 擂鼓三通斩蔡阳。 将军去到阵头上， 诚恐难胜关云长。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "韩玄",
          "type": "西皮散板",
          "text": "魏将军说话少志量， 黄忠近前听端详： 我今与你一支令， 命你大战关云长。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "黄忠得令下宝帐， 背转身来自思量。 自古忠良无下场， 大将难免阵头亡。 人来与爷带丝缰，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同上。红龙套甲带马，黄忠上马。四红龙套同下。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "两军阵会一会关云长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        },
        {
          "character": "韩玄",
          "type": "西皮散板",
          "text": "黄忠得令出宝帐， 开言叫声魏文长： 我今与你一支令， 命你四路去催粮。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "魏延",
          "type": "西皮散板",
          "text": "元帅将令往下降， 命某四路去催粮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "韩玄",
          "type": "西皮散板",
          "text": "黄忠、魏延出宝帐， 且听探马报端详。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩玄、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套、关羽同上，四红龙套、黄忠同上，会阵。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "马前来的敢是关羽？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "然也！既知某家领兵前来，就该马前归顺。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "住了！你有何本领，竟敢前来夺取长沙？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "要问某的本领，你且听道！"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "勒马停蹄站沙场，"
        },
        {
          "character": "关羽",
          "type": "西皮慢二六板",
          "text": "黄忠老将听端详： 某大哥堂堂帝王相， 当今皇叔四海扬。 某三弟翼德猛勇将， 大吼一声断桥梁。 四弟子龙不可挡， 长坂坡前救小王。 三请军师诸葛亮， 神机妙算腹内藏。 我弟兄曾破黄巾兵百万， 颜良、文丑在某的青龙刀下丧无常。 过五关斩过六员将， 擂鼓三通斩蔡阳。 黄忠早把长沙让， 免得一命刀下亡。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "听罢言来用目望，"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "关羽果然不寻常： 头戴金盔明又亮， 身穿铠甲放毫光。 开言有语把话讲， 关羽听某说端详： 要取长沙休妄想， 除非日出在西方。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "三军摆下杀人场，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套、四红龙套同钻烟囱下。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "管叫你一命丧战场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、黄忠同起打。关羽败下，黄忠追下。关羽败上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住！黄忠杀法甚是骁勇，他若追来，拖刀计斩他下马！"
        },
        {
          "character": "黄忠",
          "type": "内白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上，起打。黄忠落马。四绿龙套、四红龙套自两边分上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "关羽，将俺打下马来，为何不斩？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "黄忠，某家出世以来，不斩落马之将。回营换马再战！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、黄忠同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好一员老将！收兵！"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、四绿龙套同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、韩玄同上。"
        },
        {
          "character": "韩玄",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、黄忠同上。四红龙套同下。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "末将交令。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "一旁坐下！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "老将军胜负如何？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "末将出兵，在两军阵前，不分胜负；明日定要生擒关羽入帐。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "好，听本帅一令！"
        },
        {
          "character": "韩玄",
          "type": "西皮散板",
          "text": "本帅帐中传令号，"
        },
        {
          "character": "韩玄",
          "type": "西皮快板",
          "text": "黄忠老将听根苗： 你若擒得关羽到， 凌烟阁上美名标。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、韩玄同下。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "元帅将令往下降， 出得宝帐自思量。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "且住！想某在两军阵前，被关羽打下马来，不忍杀害于我。想俺这百步穿杨， 百发百中，明日去到阵前，只射盔樱，不射咽喉，以报阵前不杀之恩也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套自两边分上。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "百步穿杨射得准， 显显某家手段精。 人来带过马能行，"
        },
        {
          "character": "红龙套甲",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红龙套甲带马，黄忠上马。四红龙套同下。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "阵前答报不斩恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "黄忠老将失了机，"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "他与某家比高低。 我把黄忠好一比， 绵羊见虎把头低。 将身且坐宝帐里，"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "且听探马报端的。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "黄忠讨战！"
        },
        {
