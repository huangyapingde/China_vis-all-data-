{
  "script_id": "03065003",
  "title": "战潼关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "马超",
      "hangdang": "武生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "曹操欲除马腾，矫诏调马腾为潼关太守，暗命董平截杀马腾于途中。马超得父凶耗，领西凉兵马伐曹报仇。\n曹操引兵拒超于潼关。马超英勇，大破曹兵，曹操割须弃袍而逃。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "袖内藏刀，位压群僚。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "眼看乾坤已破，一心想占山河。斩杀不由献帝，孙、刘已在掌握。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫、曹操。昨晚仰观天象，那西凉马腾，非但有不顺老夫之意，反有害老夫 之心。我不免请来夏侯渊、董平二将到此，一同商议，斩了马腾方好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启丞相：二位将军到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。夏侯渊、董平同上。"
        },
        {
          "character": "夏侯渊、董平",
          "type": "同白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二位将军请坐！"
        },
        {
          "character": "夏侯渊、董平",
          "type": "同白",
          "text": "谢坐。提调我等，有何事议？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "昨晚老夫仰观天象，那西凉马腾，非但有不顺老夫之意，反有害老夫之心。我 意欲斩了马腾方好。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "末将倒有一计。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "丞相假传圣旨一道，命马腾调升潼关。再发金牌一面，命董平将军劫杀马腾。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "言之有理。夏侯将军听命！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你假传圣旨，调马腾为潼关太守。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "董将军！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可持金牌拦路劫杀，取他首级，不得违误！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "夏侯渊、董平",
          "type": "同白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊、董平同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "马腾哪马腾！管叫你明枪容易躲，暗箭最难防！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引马腾同上。"
        },
        {
          "character": "马腾",
          "type": "引子",
          "text": "父子英雄将，奉王命，镇守西凉。"
        },
        {
          "character": "马腾",
          "type": "念",
          "text": "一口黄金印，令箭调三军。马踏花世界，与主保乾坤。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "老夫马腾。镇守西凉一带等处。我也曾命马岱前去运粮，为何不见到来？"
        },
        {
          "character": "马岱",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱上。"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "将相本无种，男儿当自强。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "参见父帅！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "运粮之事，怎么样了？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "粮草催齐，请父帅查点。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "我儿之功也。"
        },
        {
          "character": "夏侯渊",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "圣旨下！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "香案接旨！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "香案接旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引夏侯渊同上。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "圣旨下！马腾跪听宣读！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马腾跪。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "你父子镇守西凉有功，圣上见喜，封你为潼关太守，即刻上任。旨意读罢，望 诏谢恩！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马腾起。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "大人捧旨前来，多受风霜之苦。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "为国勤劳，何言辛苦！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "与大人摆宴。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "还要回朝交旨。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "不敢久留。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "告辞。带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊上马。四龙套、夏侯渊同下。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "儿啊，适才圣旨到来，命为父调升潼关，加官受爵，即刻起程。 来，与爷带马！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马腾上马，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引董平同上。"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "俺、董平。奉了丞相之命，劫杀马腾。 众将官，催马！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董平、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "马腾",
          "type": "内唱",
          "text": "有老夫在马上暗暗思想，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、马岱、马腾同上。"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "汉天子他待我恩重非常。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "俺、马腾。圣旨封我潼关太守。 众将官！"
        },
        {
          "character": "四文堂、马岱",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "四文堂、马岱",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "揭鞭打马往前闯，"
        },
        {
          "character": "董平",
          "type": "内白",
          "text": "金牌下！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "金牌到此为哪桩？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "这般时候，哪里来的金牌？"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "我儿躲在松林。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱下。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引董平同上。"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "马腾跪！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "只因你克扣军饷，圣上恼怒，斩你首级进京，接牌，看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董平斩马腾。四文堂同下。四下手、董平同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马超上。"
        },
        {
          "character": "马超",
          "type": "引子",
          "text": "父祖功勋，历代簪缨。"
        },
        {
          "character": "马超",
          "type": "念",
          "text": "历代功勋汉阁间，一身世业祖家传。我父执掌兵权印，威镇西凉半壁天。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "俺、马超。我父马腾，奉命镇守西凉一带。只因前日圣旨到来，宣我父进京， 加官受爵。我父去后，这几日心惊肉战，不知为了何事？且等马岱回来，便知 分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱上。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "参见兄长！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "回来了？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "大事不好了！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "只因曹操暗下假金牌，将父帅斩首道旁！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "斩首道旁！"
        },
        {
          "character": "马超",
          "type": "三叫头",
          "text": "爹爹！我父！哎呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "听说爹爹把命丧，"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "杀死我父为哪桩？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "马岱听令！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "吩咐庞德全身披挂，校场听点！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超、马岱同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "庞德上，起霸。"
        },
        {
          "character": "庞德",
          "type": "念",
          "text": "头戴金盔映日辉，身披铠甲抖雄威。两军扎下貔貅队，要把曹操魂魄追。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "俺、庞德。奉了公子将令，校场听点。人马点齐，公子来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四文堂、四马童、马岱、马超同上。"
        },
        {
          "character": "马超",
          "type": "念",
          "text": "恼恨曹贼心不良，残杀忠良霸朝纲。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "今日点兵与父报仇。马岱听令！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "兵马未动，粮草先行！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令！ 带马！"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童甲带马。马岱上马，下。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "庞德听令！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "命你攻打头阵！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "得令！ 带马！"
        },
        {
          "character": "马童甲",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童带。庞德上马，下。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "爹爹呀爹爹！孩儿兴兵，与父报仇，但愿我父灵魂，暗地保佑。拿住曹操，俺 要千刀万剐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "众将官，起兵前往！"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四下手、董平，四上手、四文堂、庞德自两边分上，会阵，同起打。庞德杀死董平。四下手同下，庞德、"
        },
        {
          "character": null,
          "type": "text",
          "text": "四上手、四文堂同追下。）"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引徐晃同上。"
        },
        {
          "character": "徐晃",
          "type": "念",
          "text": "辕门以外月儿高，马被雕鞍将挂袍。男儿若挂封侯印，斩将回来血染刀。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "某，徐晃。昨日曹丞相有文到来，言说马超倒反西凉，叫我谨守城池。且听探 马一报！"
        },
        {
          "character": "报子",
