        {
          "character": null,
          "type": "stage",
          "text": "朱元璋、刘基、徐母同登城。"
        },
        {
          "character": "徐达",
          "type": "内唱",
          "text": "四面俱是埋伏将！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达上，常遇春、胡大海、郭英、沐英同追上，两边分站。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "倒教豪杰无主张。 回头我对三刚讲， 听我把话说端详： 当年不该劫皇杠， 攀扯愚兄为哪桩？ 你为何庄后把火放？ 你不该火焚广泰庄。 烧死别人还罢了， 烧死了你的姑母、我的娘，你好狠心肠！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达打常遇春。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "我可要打啦！嘿！谁叫咱们是表兄弟哪！"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "哪有闲言对你讲？"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "你少理我！"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "大骂郭英无义郎！ 你不该假扮山寇样， 你不该用计将某诓， 你不该把我的庄来抢， 看起来你是个无义儿郎！"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "一见徐达到战场， 果然智勇世无双。 回头我对伯母讲， 相劝令郎来归降。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "军师安排埋伏将， 围困我儿在沙场。 城楼之上把话讲， 徐达我儿快快降！"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "猛听得有人把话讲， 抬头又见年迈娘。 烈火之中把命丧，"
