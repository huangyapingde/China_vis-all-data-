{
  "script_id": "03098002",
  "title": "广泰庄",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "徐达",
      "hangdang": "老生"
    }
  ],
  "plot": "朱元璋濠州起义后，闻徐达文武双全，欲拜为帅，遂同郭英去广泰庄礼聘。徐达以奉养老母为辞，坚不受命。\n刘基因命郭英等假扮山寇，赚徐达出庄；复命常遇春请走徐母，乘机烧庄。徐达无奈，乃投朱元璋。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "常遇春上，起霸。"
        },
        {
          "character": "常遇春",
          "type": "念",
          "text": "杀气腾腾鬼神愁，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭英上，起霸。"
        },
        {
          "character": "郭英",
          "type": "念",
          "text": "男儿志量觅封侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡大海上，起霸。"
        },
        {
          "character": "胡大海",
          "type": "念",
          "text": "腰中悬挂三尺剑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "沐英上，起霸。"
        },
        {
          "character": "沐英",
          "type": "念",
          "text": "灭却吴王保龙楼。"
        },
        {
          "character": "常遇春、郭英、胡大海、沐英",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "常遇春。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "郭英。"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "胡大海。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "沐英。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "列位将军请了！"
        },
        {
          "character": "郭英、胡大海、沐英",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "军师升帐，你我辕门伺候。"
        },
        {
          "character": "郭英、胡大海、沐英",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同暗上。"
        },
        {
          "character": "常遇春、郭英、胡大海、沐英",
          "type": "同白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同带马，常遇春、郭英、胡大海、沐英同上马，同走圆场。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "来到辕门。"
        },
        {
          "character": "常遇春、郭英、胡大海、沐英",
          "type": "同白",
          "text": "打了几鼓？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二鼓〗。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "打了二鼓。"
        },
        {
          "character": "常遇春、郭英、胡大海、沐英",
          "type": "同白",
          "text": "军师尚未升帐，你我两厢伺候。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、朱元璋、刘基同上。"
        },
        {
          "character": "刘基",
          "type": "点绛唇",
          "text": "威风凛凛，统领雄兵，扫烟尘，扭转朝廷，要把大元平。"
        },
        {
          "character": "常遇春、郭英、胡大海、沐英",
          "type": "同白",
          "text": "参见军师！"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "罢了。见过主公！"
        },
        {
          "character": "常遇春、郭英、胡大海、沐英",
          "type": "同白",
          "text": "参见主公！"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "常遇春、郭英、胡大海、沐英",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "刘基",
          "type": "念",
          "text": "昔日莲台打坐，胸中颇有才学。习就天文地理，保主锦绣山河。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "山人、刘基。保定主公，征战吴王张士诚，未能剿灭。今日升帐，再为商议。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "先生，孤王有意兴兵，怎奈军中缺一主帅，如何是好？"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "臣启主公：濠州城外有一广泰庄，内有一人，姓徐名达，此人文武双全。主公 若能请他前来，可以领兵挂帅。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "全仗先生。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "郭英听令！"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "命你保定主公，顺说徐达来降。同去同回，不得有误！"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "得令！ 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元璋、郭英同下。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "常遇春听令！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "命你催押粮草，军前听用。三日到齐，不得有误！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "得令！ 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春下。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐达上。"
        },
        {
          "character": "徐达",
          "type": "引子",
          "text": "隐居村庄，奉老母，乐享安康。"
        },
        {
          "character": "徐达",
          "type": "念",
          "text": "豪杰生来情性刚，文韬武略腹内藏。功名二字全不想，侍奉老母在高堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院暗上。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "俺、徐达。祖居濠州广泰庄。自幼随父习学武艺，十八般兵刃件件精通。本当 投一明主，出力报效；怎奈先父早亡，只有老母在堂，因此弃却功名，终日侍 奉老母。今乃家母寿诞之期，不免备下酒宴，与母亲上寿。 家院，酒宴可曾齐备？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达向内。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "有请母亲！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、徐妻同上。"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "我儿韬略广，"
        },
        {
          "character": "徐妻",
          "type": "念",
          "text": "侍奉老高堂。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "母亲在上，孩儿拜揖！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "罢了。请出为娘，有何话讲？"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "今乃母亲寿诞之期，孩儿备下寿酒，与母亲上寿。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "生受你们了。"
        },
        {
          "character": "徐达、徐妻",
          "type": "同白",
          "text": "老母在上，受（孩儿）（儿媳）一拜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达、徐妻同拜。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "不用拜了。"
        },
        {
          "character": "徐达",
          "type": "念",
          "text": "拜母寿同山岳永，"
        },
        {
          "character": "徐妻",
          "type": "念",
          "text": "但愿福共海天长。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院看酒，暗下。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "母子们在堂前同饮欢畅， 但愿得满门中乐享安康。 有一日我的儿身为良将， 受荣华荫子孙代代忠良。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "今乃是寿诞期寿酒献上， 侍膝前听教训美名传扬。 愿老娘身康健寿高福广， 儿情愿落孝名万古流芳。"
        },
        {
          "character": "徐妻",
          "type": "唱",
          "text": "一家人在堂前同饮佳酿， 但愿得满门中乐享安康， 但愿得老娘亲福寿共享， 尽孝道奉膝下代代传扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启家爷：朱千岁驾到。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "母亲请至后面。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我儿前去接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、徐妻同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元璋、郭英同上。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "师兄！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "师弟！请坐！"
        },
        {
          "character": "朱元璋、郭英",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元璋、郭英、徐达同坐。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "不知千岁驾到，未曾远迎，面前恕罪！"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "岂敢！我君臣来得鲁莽，将军海涵！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "岂敢！千岁到此，必有所为？"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "久闻将军才广学高，特地前来聘请将军，扶保孤王江山社稷。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "千岁说哪里话来！俺徐达才疏学浅，又有老母在堂，不敢从命。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "将军哪！"
        },
        {
          "character": "朱元璋",
          "type": "唱",
          "text": "将军此话欠思量， 细听小王说端详： 将军才高志又广， 做一个忠臣代代名扬。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "千岁把话错来讲， 细听徐达诉衷肠： 家有老母六旬上， 实实不能弃高堂。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "师兄！"
        },
        {
          "character": "郭英",
          "type": "唱",
          "text": "师兄说话欠思想， 小弟言来听端详： 千岁爱将真爱将， 就该一同保贤王。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "难比贤弟韬略广， 朝朝暮暮伴君王。 自古常言道得好， 忠孝不能两全扬。 家母年迈六旬上， 愚兄要做行孝郎。 时时刻刻奉膝下， 我难保千岁锦家邦。"
        },
        {
          "character": "郭英",
          "type": "唱",
          "text": "你今归顺朱皇上， 富贵荣华世代长。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "休把富贵对我讲， 徐达岂是小儿郎？ 自幼隐居广泰庄， 无忧无虑乐安康。"
        },
        {
          "character": "郭英",
          "type": "唱",
          "text": "听罢言来怒满膛， 不由豪杰冒火光。 千岁上马回营帐——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱元璋下。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "师兄！"
        },
        {
          "character": "郭英",
          "type": "唱",
          "text": "三日之内定遭殃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭英下。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "郭英说话太猖狂， 他把徐达当平常。 任你风狂浪又广， 稳坐舟中不开桨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套引常遇春同上。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "俺、常遇春。奉军师将令，各路催押粮草。且喜粮草催齐。 军士们，回营交令！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、胡大海、沐英引刘基同上。"
        },
        {
          "character": "刘基",
          "type": "念",
          "text": "主公请良将，未见转还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。朱元璋、郭英同上。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "主公回来了？"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "徐达可曾归顺？"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "执意不从，如何是好？"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "山人自有道理。"
        },
        {
          "character": "常遇春",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、常遇春同上。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "末将交令。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "粮草可曾催齐？"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "俱已催齐，军师查点。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "将军之功。 郭英听令！"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "命你假扮山贼模样，将徐达诓出庄来，算你头功！"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭英下。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "常遇春听令！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "刘基",
          "type": "白",
