        {
          "character": "朱元璋",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "想我儿乃是大孝之人。不如将老身用剑枷枷定，去至城楼，我自有计劝他归顺。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "只是伯母受屈了。"
        },
        {
          "character": "朱元璋",
          "type": "白",
          "text": "为孤王江山，怎敢有屈老夫人？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "主公不必过谦。 军师，看剑枷过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文堂甲看剑枷。"
        },
        {
          "character": "刘基",
