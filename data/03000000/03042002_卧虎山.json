{
  "script_id": "03042002",
  "title": "卧虎山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "伍辛",
      "hangdang": "武净"
    }
  ],
  "plot": "伍员伐楚，兵至昭关。昭关守将米南漥不支，求助于卧虎山大王即伍员之子伍辛。伍辛出阵连斩二将，继与\n伍员大战，枪法一辙，相持不下。后经叔父伍通道破原委，伍辛始认父，大破昭关。",
  "notes": "此剧与《父子圆》大致相同。然各有长短，故特刊之。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王九龙、王九虎同上，同起霸。"
        },
        {
          "character": "王九龙",
          "type": "念",
          "text": "兄是南山猛虎，"
        },
        {
          "character": "王九虎",
          "type": "念",
          "text": "弟是北海蛟龙。"
        },
        {
          "character": "王九龙、王九虎",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "王九龙",
          "type": "白",
          "text": "王九龙。"
        },
        {
          "character": "王九虎",
          "type": "白",
          "text": "王九虎。"
        },
        {
          "character": "王九龙",
          "type": "白",
          "text": "贤弟请了！"
        },
        {
          "character": "王九虎",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "王九龙",
          "type": "白",
          "text": "元帅发兵，在此伺候。"
        },
        {
          "character": "王九虎",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、四上手引伍员同上。"
        },
        {
          "character": "伍员",
          "type": "点绛唇",
          "text": "统领三军，扫灭奸臣，威风凛，各国闻名，谁敢犯吾境！"
        },
        {
          "character": "王九龙、王九虎",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "王九龙、王九虎",
          "type": "同白",
          "text": "谢元帅。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "炮响三声到校场，带领人马伐楚邦。此行破得昭关地，杀却奸贼灭昏王！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老夫，姓伍名员字子胥。前在楚国为臣。可恨平王无道，听信谗言，父纳子妻， 又将我伍氏满门斩尽杀绝。是我投奔吴国，借来大兵十万，与我爹娘报仇。 今乃黄道吉日。 二位将军！"
        },
        {
          "character": "王九龙、王九虎",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "攻打头阵！"
        },
        {
          "character": "王九龙、王九虎",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王九龙、王九虎同下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且住！二位先行前去，恐不能得胜。不免唤出柳贤弟二队接应。 来！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唤柳将军进帐！"
        },
        {
          "character": "上手甲",
          "type": "白",
          "text": "柳将军进帐！"
        },
        {
          "character": "柳展雄",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄上。"
        },
        {
          "character": "柳展雄",
          "type": "念",
          "text": "英雄志量广，随兄灭楚邦。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "某，柳展雄。正在后帐饮酒，听得元帅呼唤，待某进帐答话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄进帐。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "唤末将出来，有何差遣？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄命龙、虎二将攻打头阵，恐不能取胜。故劳烦贤弟二队接应。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "元帅但放宽心。待某家出马杀他个片甲不留。 三军的！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄上马，下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "柳贤弟此去，必然成功。 掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引米南漥同上。"
        },
        {
          "character": "米南漥",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，干戈耀，地动山摇，要把吴兵扫！"
        },
        {
          "character": "米南漥",
          "type": "念",
          "text": "大将生来兼智勇，胸藏韬略贯长虹。奉旨镇守昭关地，雀鸟插翅难飞腾。"
        },
        {
          "character": "米南漥",
          "type": "白",
          "text": "某，米南漥。楚国为臣。奉王旨意，镇守昭关。前曾画影图形，捉拿伍员，不 想他竟自逃出昭关。平王大怒，要将某斩首，多亏费大人保奏，官复原职，永 镇昭关。看“帅”字旗无风自动，必有军情。 来！伺候了！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "忙将伍员事，报与元帅知。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "元帅在上，小人叩头！"
        },
        {
          "character": "米南漥",
          "type": "白",
          "text": "打探哪路军情？起来讲！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！小人打探那伍员带领大兵十万，战将千员，前来伐楚，已离昭关不远。"
        },
        {
          "character": "米南漥",
          "type": "白",
          "text": "他的兵势如何？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "他的兵势啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "米南漥",
          "type": "白",
          "text": "赏你银牌一面，再探再报！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "米南漥",
          "type": "白",
          "text": "哎呀且住！伍员带兵伐楚，此事非同小可。本当修本回朝，出动大兵；怎奈措 手不及，这便怎么处？ 哦呵有了！某有一好友，名叫红袍伍辛，现在卧虎山为王，不免修书一封，请 他下山，挡住要路，断绝那伍员的粮草；再修书一封，报与费大人知道，请他 发兵前来，共灭伍员，岂不是好？不免后面修书便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍通上。"
        },
        {
          "character": "伍通",
          "type": "引子",
          "text": "闷坐山林地，常怀报仇心。"
        },
        {
          "character": "伍通",
          "type": "念",
          "text": "曾记当年起祸端，伍员逃难出昭关。自从离了楚国地，至今无有音信传。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "老夫，伍通。乃楚国人氏，在卧虎山为王。只因伍员逃难，他有一子，名叫伍 辛，年方三岁，托付于我。是我带往山寨，抚养成人，如今一十八岁，执掌山 寨大事。老夫今日闷闷不乐，不免山前山后，散步一回便了。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "独坐在山寨内心中烦闷， 想起了伍家的世代忠臣。 恨平王行无道为君不正， 听奸言屈害了伍家满门。 那伍员含悲愤逃了性命， 血海的冤仇恨常挂在心。 但愿得在吴国把兵来领， 杀奸贼报冤仇方称我心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍辛上，起霸。"
        },
        {
          "character": "伍辛",
          "type": "念",
          "text": "自幼生来虎豹胆，我父命我掌兵权。卧虎山前威风展，世人见某心胆寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵同暗上。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "某，伍辛。我父伍通，在卧虎山自立为王。只因爹爹年迈，将山寨之事，付我 执掌。昨日昭关米南漥有书信前来，伍员带兵伐楚，请某下山，挡住他的要路， 劫夺他的粮草。因此全身披挂，大战伍员。 众喽兵！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "山下去者！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、王九龙、王九虎同上。"
        },
        {
          "character": "王九龙",
          "type": "念",
          "text": "吴国将英豪，"
        },
        {
          "character": "王九虎",
          "type": "念",
          "text": "腾腾杀气高。"
        },
        {
          "character": "王九龙",
          "type": "白",
          "text": "贤弟请了！"
        },
        {
          "character": "王九虎",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "王九龙",
          "type": "白",
          "text": "卧虎山贼寇骂阵，领了元帅将令，攻打头阵，一同前往。"
        },
        {
          "character": "王九虎",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "王九龙、王九虎",
          "type": "同白",
          "text": "众将官！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "王九龙、王九虎",
          "type": "同白",
          "text": "起兵前往！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、王九龙、王九虎同走圆场。四喽兵引伍辛同上，同开打。伍辛打王九龙、王九虎死。柳展雄上。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "好小子！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛、柳展雄对打。柳展雄败下，伍辛、四喽兵同追下。柳展雄上。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "啊呀且住！这娃娃十分厉害，将龙、虎二将枪挑落马；某被他打了这一枪杆， 不是俺马走如飞，险些丧在他手。不免回营，报与元帅知道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手引伍员同上。"
        },
        {
          "character": "伍员",
          "type": "引子",
          "text": "志比天高，报冤仇，方展眉梢。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "曾记当年起征战，临潼赴会显奇能。子胥力举千斤鼎，各国诸侯俱震惊。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老夫，伍员。在吴国借来大兵十万，战将千员，前来伐楚报仇。探子报道：卧 虎山贼寇挡住去路。已命二先行与柳贤弟出马，未见回报。"
        },
        {
          "character": "柳展雄",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄上。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "哎哟哟哟！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "贤弟为何这等模样？"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "哎呀咱的哥，二位先行出马，遇见一员小将，被他枪挑马下；小弟一马当先， 也叫他这么一枪！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "枪到我的膀子上啦。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "他姓甚名谁？"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "未容我问，就把我枪回来啦。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "贤弟后帐歇息，待愚兄出马。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "你呀，恐怕也不中用。哎哟哟哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且住！卧虎山贼寇兴兵，二先行丧命，柳贤弟又败下阵来。待老夫亲自出马。 众将官！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "站立两厢，听我令下！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "老夫稳坐在大营， 探马儿郎来报军情： 卧虎山贼子挡路径， 二先行出马丧残生。 恨平王无道行不正， 父纳子妻灭人伦。 伍员闻言心恼恨， 弃楚逃出昭关城。 吴王驾前把兵领， 不报冤仇枉为人！ 临潼力举千斤鼎， 十八国诸侯闻吾名。 生擒活捉如虎豹性， 柳展雄见某害头疼。 一个个惧怕来归顺， 齐跪马前投降文。 卧虎山前吃败阵， 老夫亲自出大营。 抖抖精神卸袍带， 单人独骑把贼擒。 玲珑铠甲忙勒紧， 手持白虎鞭一根。 叫三军摆下埋伏阵！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手同下。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "就是那罗汉金刚也难脱身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵引伍辛同上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "威风凛凛下山林， 卧虎山前动刀兵。 三军与爷往前进！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵同下。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "捉拿楚国反叛臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手引伍员同上。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "伍员纵马战场下， 会会无知小娃娃。 行至阵前勒住马， 贼子出营会某家。"
        },
        {
          "character": "伍辛",
          "type": "内唱",
          "text": "忽听得老将把阵骂，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵引伍辛同上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "虎目圆睁观看他。 老将虽然年纪大， 白盔白甲白鬓发。 座下一骑白龙马， 论年纪赛过姜子牙。 赛闻仲无有麒麟跨， 赛天王无有黄金塔。 问一声老将名和姓， 通上名来好把你杀！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "你且听道哇！"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "勒住丝缰带住马， 阵前闪出小娃娃。 年纪不过十七八， 一身打扮赛哪吒。 赛杨戬缺少云雾马， 赛张奎无有地遁法。 赛殷郊无有他的法力大， 打将钢鞭手中拿。 临潼举鼎谁不怕？ 子胥威名扬天涯。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "听说来的楚伍员， 少爷与你把话云。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "子胥！我把你这欺君之贼！君要臣死，臣不死就为不忠。今日带兵前来伐楚， 遇着你家少爷休想活命。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "少爷一马来挡定， 谅你插翅难飞腾。 大鹏鸟我要摘尔翅， 麒麟兽也要抽尔的筋！"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "娃娃不要抖精神， 老夫岂怕你年少人？ 平王无道行不正， 父纳子妻灭人伦。 无极上殿奏一本， 害我满门把命倾。 三百余口俱杀尽， 家眷不曾留一人。 我与他君臣结仇恨， 要把他君臣千刀万剐方称我的心！"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "听罢言来怒气生， 太阳头上冒火星。 劝尔下马来归顺， 收你上山作先行。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "娃娃说话欠思忖， 只恐睁眼错认人。 白虎鞭一举催尔的命！"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "震得少爷虎腕疼。 豪杰催马假败阵，"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "老夫催马追尔的魂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、伍辛同开打，伍员、伍辛同相持下，四龙套、四上手、四喽兵同拥下。伍辛上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "适才与贼交一阵， 老将武艺果然精。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "对着子胥把雕翎放！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛射箭，下。伍员接箭。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "弓弦一响接雕翎。 伍员马上笑吟吟， 可叹这娃娃枉费心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。伍辛上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "豪杰马上抖精神， 要把老贼一鼓擒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "二次我把雕翎放！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛射箭，下。伍员接箭。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "接过雕翎箭二根。 他夸海口我不信， 正好抖抖我的老精神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。伍辛上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "老贼果然有本领， 连放二箭不沾身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "三次我把雕翎放！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛射箭，下。伍员接箭。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "射我咽喉差三分。 娃娃箭法果然准， 我接法比他射法能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。伍辛上。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "果然老贼好本领， 连放三箭不沾身。 催马来到校场等， 老贼到此大交兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "两下兴兵起战争， 一来一往定输赢。 劝你马前来归顺， 老夫收你做螟蛉。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "老贼休要夸海口， 逃脱我手算你能！"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "好言说来尔不信，"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "少爷与尔定输赢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛、伍员同杀，同相持下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍通上。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "山前山后观风景，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喊杀声〗。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "忽听得人马闹纷纷。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "且住！哪里人马喊嚷，待我站在山头一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通上山，望。伍员、伍辛同上，同起打，同相持下。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "站在山头观战阵， 原来父子大交兵。 前面走的伍辛子， 伍员兄长随后跟。 他父子若有好和歹， 血海冤仇报不成。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "哎呀，我道是官兵前来洗寨，却原来是父子交兵。这便怎么处？啊呵有了！不 免吩咐众将鸣金收兵便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵引伍辛同上。四龙套、四上手引伍员同上，同相打。〖内鸣金声〗。伍员住手。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "敢是怯战？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且慢！非是老夫怯战，你寨鸣金收兵，明日再战。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "把个死人头，暂寄在你的项上。 收兵！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵引伍辛同下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、四龙套、四上手同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍通上。"
        },
        {
          "character": "伍通",
          "type": "念",
          "text": "适才观阵罢，把话对儿明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛上。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "爹爹在上，孩子拜揖！"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "儿全身披挂，与何人交战？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "儿全身披挂，大战伍子胥。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "我想伍子胥有血海冤仇未报。你与他厮杀，是何理也？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "儿杀了伍子胥，与平王报仇。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "我儿自己的冤仇未报，反与旁人报得什么仇啊？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "爹爹，儿有什么冤仇，快对孩儿说明，儿即刻就报。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "儿报得冤仇？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "报得冤仇！"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "杀得奸贼？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "杀得奸贼！"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "哎呀儿呀！"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "未曾开眼泪先淋， 奸贼害儿一满门。 为父带儿逃了命， 血海冤仇未报成。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "爹爹，有何冤仇，快与孩儿说个明白！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛跪。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "要为父对儿说明么？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "你且起来。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "谢爹爹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛起。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "儿告坐。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "儿呀，当初一十八国争雄，不分上下。秦穆公设下临潼大会，各国诸侯，前来 斗宝。秦穆公传下一令，殿角有一千斤的铜鼎，若有人举起，称为“盟辅上将” 。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "可有人举起？"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "此时殿角闪出一人，头戴白银盔，身穿白银甲，左手撩袍，右手举鼎，在殿角 连绕三次，面不改色。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "举鼎者何人？"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "就是阵前那员老将。若问那人的根本喏！"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "临潼会力举千斤鼎， 十八国皆知楚伍员。 秦穆公一见心惊恐， 秦、楚两国结为亲。 无祥女本是太子配， 平王不该纳为婚。 伍家忠心去保本， 可怜满门把命倾。 到如今领兵报仇恨， 为何阻挡自家人？ 儿不是为父亲生子——"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "儿的亲生父是那一个？"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "伍员就是儿的老爹尊。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "听罢言来怒气生， 骂声无极狗奸臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛向内。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "三军与我带能行！"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "儿往哪里去？"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "反到楚国杀昏君。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "且慢！儿要报仇，却也不难，须依为父一件！"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "将山寨粮草，放下山去，随我去到阵前，儿父子相见，何愁大事不成，冤仇不 报？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "遵命！ 众喽兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵同上。"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "粮草放下山去，带马伺候！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "血海冤仇今日明，"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "铁石人闻也泪淋。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "伍辛儿将粮草来押定，"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "去到阵前认严亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通、伍辛、四喽兵同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手引伍员同上。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "伍员马上汗湿衣， 娃娃武艺是好的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内鼓声〗。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "耳边厢听得战鼓起， 黄尘滚处骑如飞。 圆睁虎目观仔细，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍辛上。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "马前来的少英奇。 昨日也曾把阵对， 儿的武艺果不虚。 非是老夫夸赞你， 十八国中你第一，儿是好的。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "走近前来屈膝跪， 论理儿该天雷劈。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "小娃娃定下诓军计， 诓我下马捉拿伍子胥。"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "爹爹把儿来忘记， 儿是伍辛把人依。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "听说伍辛面带喜， 不由老夫心猜疑。 将儿过继伍通弟， 此话是何人向尔提？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "乃是叔父伍通。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "有请叔父！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通上。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "昨日阵前观仔细， 来了堂兄伍子胥。 伍辛儿请为叔何用意？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "我爹爹在此。"
        },
        {
          "character": "伍通",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "会会吾兄把话提。 走向前来深施礼， 不觉白了发和须。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "战袍湿透伤心泪， 这小将是谁请说端倪。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "贼子抄家如水洗， 卧虎山前候信息。 抚养伍辛十八岁， 杀贼助兄一膀力。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "儿是伍辛？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "儿是伍辛。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "嘚！三军们！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "回营！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、伍员、伍辛、伍通同下。〖牌子〗。四龙套、四上手引伍员、伍辛同上"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "绑了！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同绑伍辛。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "抬起头来！儿是伍辛？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "儿是伍辛。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "呀呀呸！你三岁离父，如今长大成人，随你叔父学得一身武艺，指望与伍家报 仇，谁知你这忤逆之子，在疆场上妄图弑父。要你这不孝之子何用？ 来，推出斩了！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手绑伍辛同下。伍通上。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "听说要把伍辛斩， 吓得老夫心胆寒。 进得帐去忙分辨， 兄长发怒为哪般？"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "参见兄长！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "贤弟进帐，敢是讲情？"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "不敢！元帅看他年幼无知，将他饶恕。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "好一个大胆伍通！你纵侄弑父，颠倒人伦，还敢与他讲情？有人讲情，一同问 罪！"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "子胥将令往下传， 要斩伍辛染黄泉。 眼睁睁伍辛儿难得见，"
        },
        {
          "character": "伍通",
          "type": "哭头",
          "text": "我的儿呀！"
        },
        {
          "character": "柳展雄",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄上。"
        },
        {
          "character": "柳展雄",
          "type": "唱",
          "text": "又听军中哭连天。 见一老丈悲声惨，"
        },
        {
          "character": "柳展雄",
          "type": "夹白",
          "text": "老头儿！"
        },
        {
          "character": "柳展雄",
          "type": "唱",
          "text": "你是何人泪涟涟？"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "子胥堂兄把令传， 辕门外绑的他儿男。 父子分别十五载， 今日见面父子圆。 只因疆场来交战， 绑在辕门被刀餐。"
        },
        {
          "character": "柳展雄",
          "type": "唱",
          "text": "听一言来怒冲冠， 二哥但把心放宽。 待某进帐把情讲，"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "全仗将军！"
        },
        {
          "character": "柳展雄",
          "type": "唱",
          "text": "元帅发怒为哪般？"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "大哥为何发怒？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "贤弟有所不知，只因逆子伍辛疆场弑父，打了贤弟一枪，因此将他问斩。"
        },
        {
          "character": "柳展雄",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "打了我一枪，原来是我贤侄，我说不疼哪。今日父子相会，这么一点小事儿， 你要杀他？算了吧！ 三军们，将他放回来，放回来！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唗！山野村夫，不晓军规，出帐去吧！"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "元帅，俺侄儿伍辛，武艺高强，你不是他的对手。今日父子相会，你反要斩首， 俺老柳帮你伐的什么楚，报得什么仇？也罢！不如我先自刎了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳展雄佯欲自刎。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且慢！为一犬子，不要伤了你我结义之情，将逆子赦回来！"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "你不杀他，我也不死啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手押伍辛同上。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "伍辛！"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "你叫他爸爸！"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "你疆场与父动手，理当斩首。死罪已免，活罪难饶。 来，重责四十！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "哎哟！元帅，杀，你不杀了；打，你也算了吧！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "欺父如同欺天地， 伍家岂容不孝的？"
        },
        {
          "character": "伍辛",
          "type": "唱",
          "text": "爹爹分别儿三岁， 却叫孩儿怎认的？"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "着哇！"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "父子分别儿三岁， 却叫我儿怎认的？ 叫声娇儿且站起， 将门之子果不虚。 儿的武艺世无比，"
        },
        {
          "character": "柳展雄",
          "type": "唱",
          "text": "十八国诸侯谁敢欺！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "儿连放三箭，我真服你。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "比不得爹爹在临潼斗宝，举鼎千斤！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "山寨有多少人马？"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "三万余骑。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "好！合兵一处，大破昭关。"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "遵命。 众喽兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵同上。"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "伍辛",
          "type": "白",
          "text": "合兵一处，兵发昭关！"
        },
        {
          "character": "四龙套、四上手、四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}