{
  "script_id": "03097005",
  "title": "浣纱记",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "渔丈人",
      "hangdang": "丑"
    },
    {
      "name": "浣纱女",
      "hangdang": "旦"
    }
  ],
  "plot": "伍员逃出昭关，为大江所阻，幸遇渔丈人渡之过江。过江后，嘱渔丈人勿泄。渔丈人为消伍员疑而投江。伍\n员渡江后，途中饥饿。适遇浣纱女子，向之乞食。浣纱女以食济伍员。行时，嘱浣纱女勿泄。浣纱女为明己\n志，亦投江死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哎呀且住！前有长江，后有追兵，无舟可渡，如何是好！"
        },
        {
          "character": "渔丈人",
          "type": "内白",
          "text": "打鱼哟！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "呜呼呀，那厢有一渔船，待我将他唤来。 船家过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "渔丈人上。"
        },
        {
          "character": "渔丈人",
          "type": "唱",
          "text": "耳听岸上人唤我， 壮士呼唤却为何？"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "壮士唤我何事？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "烦劳老丈将我渡过江去。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "老汉这打鱼小舟从不渡人。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "多把银钱与你。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "我是不爱钱的。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老丈，我乃被难之人，你行个方便吧！"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "既然如此，待我渡你过江。请上船来。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "就请老丈快快开船！"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "好，待我扯起篷来。"
        },
        {
          "character": "渔丈人",
          "type": "山歌",
          "text": "万里孤篷一叶舟， 萧萧芦荻满江秋。 看君不是寻常客， 何事忧愁白了头？ 蹊跷啊，蹊跷啊！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "请问老丈，此歌从何而起？"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "我见你乃是一个壮年，为何忧愁满面，须发皓然？其中必有隐情，故而歌唱。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哦，原来如此。唉！"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "请问壮士，尊姓大名？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "这个——"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "为何不讲？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "我若说出真名实姓，恐怕走漏风声。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "你看舟中并无别人，但讲何妨。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "在下姓伍名员字子胥，楚国监利人也。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "原来是明辅将军。失敬了！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "船已抵岸，待我与你搭了扶手。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "多蒙老丈将我渡过江来，无物可谢。我这里有宝剑一口，上有七星，价值连城， 赠与老丈，以为渡江之费。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "慢来，慢来。老汉听说楚平王欲得将军，悬有万金之赏，我不图赏，岂图你的 酬谢！况这山路险要，将军岂可无剑！老汉打鱼江中，要它何用！请你速速去 吧。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老丈既不受剑，请问尊姓大名，日后相逢，也好答报。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "这个——日后你我相逢之时，你唤我渔丈人，我唤你芦中人也就是了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "如此，渔丈人。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "芦中人。"
        },
        {
          "character": "伍员、渔丈人",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": "伍员",
          "type": "西皮散板",
          "text": "多蒙渡我把江过， 日后当报这恩德。 临行与你拱拱手，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "渔丈人",
          "type": "西皮散板",
          "text": "可叹将军涉风波。 我把船儿忙摇过，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "西皮散板",
          "text": "再与老丈把话说。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "将军，为何去而复转？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老丈，非是我去而复转，后面倘有追兵，莫说伍员打此经过。"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "哎呀且住！老汉偌大年纪，冒着风险将他渡过江来，不料他反而疑我。万一后 面追兵将他拿住，必说是我泄漏，岂不以德为怨！也罢，我不免投到江中，也 好叫他安心而去。 啊将军，那边追兵来了！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "渔丈人",
          "type": "白",
          "text": "在那里！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "渔丈人投江，下。"
        },
        {
          "character": "伍员",
          "type": "扑灯蛾牌",
          "text": "老丈丧江河、丧江河， 不由人珠泪落！ 得展凌云志， 一定报恩德、报恩德！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老丈投江一死，不免将篷索砍断，以防不测。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "浣纱女上。"
        },
        {
          "character": "浣纱女",
          "type": "西皮慢三眼板",
          "text": "光阴一去快如梭， 人生在世能几何？ 不求富贵求安乐， 每日溪边浣纱罗。"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "溧阳史氏女。与寡母同居。年已三十，尚未嫁人。每日浣纱织罗，奉母度日。 看天气晴和，不免去到溪旁浣纱便了！"
        },
        {
          "character": "浣纱女",
          "type": "西皮慢三眼板",
          "text": "村边桃花——"
        },
        {
          "character": "浣纱女",
          "type": "西皮二六板",
          "text": "红灼灼， 垂柳绿叶映清波。 景色虽好刹那过， 辜负春光可奈何。 缓步从容溪边过， 临流倚石浣纱罗。"
        },
        {
          "character": "伍员",
          "type": "内西皮导板",
          "text": "豪杰打马奔吴国，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "西皮流水板",
          "text": "龙离沧海虎离窝。 力举千斤伍明辅， 压定了各国不敢动干戈。 天下英雄皆服我， 各路诸侯来求和。 盖世功勋无过错， 又谁知一旦起风波。 可叹我一家人无有结果，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员看。"
        },
        {
          "character": "伍员",
          "type": "西皮流水板",
          "text": "见一娘行浣纱罗。 行至此间腹内饿， 见她篮中饭与馍。 本当向前求济饿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下马。"
        },
        {
          "character": "伍员",
          "type": "西皮散板",
          "text": "含羞带愧无奈何！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员投石。"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "浣纱女",
          "type": "西皮流水板",
          "text": "忽见水底人影过， 落石击水却为何？ 想是壮士呼唤我， 只得低头把话说。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "娘行请了！"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "请了！客官敢是失迷路途？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "并非失迷路途，我乃避难之人，行至此间，腹中饥饿，见娘行篮中有饭食馍馍， 可否周济于我？"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "听客官之言，不像此地人氏，家住哪里，尊姓大名？请道其详。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唉，娘行听了！"
        },
        {
          "character": "伍员",
          "type": "西皮二六板",
          "text": "未曾开言心难过， 两眼不住泪如梭。 家住监利在楚国， 我的父就是伍相国。 伍子胥就是我， 临潼斗宝压服了各国。 恨平王无道贪酒色， 父纳子妻理不合。 我的父谏奏反得祸， 可怜我的一家满门三百余口见阎罗。 只剩下伍员人一个， 插翅不能逃出网罗。 幸遇东皋公周全我， 混出了昭关逃奔吴国。 行至在江边不能过， 多蒙渔丈渡江河。 一路行来腹饥饿， 但只见你的篮中有饭又有馍。 娘行若肯周济我， 没齿不忘大恩德。"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "浣纱女",
          "type": "西皮流水板",
          "text": "听罢言来珠泪落， 可叹将军受折磨。 请君饱餐免饥饿， 篮内取出饭与馍。"
        },
        {
          "character": "伍员",
          "type": "西皮散板",
          "text": "多谢娘行周济我， 用手拿起饭与馍。 一饭未足充饥饿， 千金相谢不为多。"
        },
        {
          "character": "浣纱女",
          "type": "西皮散板",
          "text": "将军不必言谢我， 区区小事值几何！ 阳关路上是非多， 请君快快离此河。"
        },
        {
          "character": "伍员",
          "type": "西皮散板",
          "text": "娘行一言提醒我， 男女交谈是非多。 辞别娘行奔吴国，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "浣纱女",
          "type": "西皮散板",
          "text": "盖世英雄受折磨。 浣纱未毕溪边坐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "西皮散板",
          "text": "再与娘行把话说。"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "将军为何去而复转？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "非是我去而复转，倘有追兵到此，莫说我伍员打此经过！"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "这—— 将军少待。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "娘行请便。"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "且住，我好心周济于他，反而疑心于我。也罢，不免投江一死，免他疑心便了。 将军，那旁有人来了！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "浣纱女",
          "type": "白",
          "text": "在那里！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "浣纱女投江，下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "娘行身投河， 两眼泪如梭。 你死皆因我， 可叹女娇娥。 日后若得仇报却， 建碑立旌报恩德。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且住！娘行投江一死，是非之地，不可久停，速速拉马走去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}