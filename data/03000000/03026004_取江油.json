        {
          "character": "郤正",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "卿家入宫，有何本奏？"
        },
        {
          "character": "郤正",
          "type": "白",
          "text": "臣启陛下：今有大将军姜维，因炎兴元年秋九月魏钟会入寇汉中，大将军姜维 现在剑阁拒敌，告急本章呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅看。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "钟会兵犯汉中境， 心中着忙胆战惊。 左难右难无计定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄皓作手势。"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "再与黄皓定计行。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "卿家暂且出宫，朕明日再降谕旨。"
        },
        {
          "character": "郤正",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "郤正",
          "type": "念",
          "text": "侍宦谗言乱朝政，一木难将大厦擎。"
