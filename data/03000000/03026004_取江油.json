        {
          "character": null,
          "type": "stage",
          "text": "郤正下。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "钟会兵犯汉中，如之奈何？"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "奴婢看来，此乃姜维欲立功名，故上此表。陛下宽心，不必疑惧。奴婢闻城中 有一神师，供奉一神，能知吉凶，可召来问之。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "好！既有神师，卿家可速速召来，朕一问休咎。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "奴婢领旨。"
        },
        {
          "character": "黄皓",
          "type": "唱",
          "text": "陛下但请放宽心， 万事临头不必惊。 此去虔诚神师请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄皓下。"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "黄皓忠肠慰朕心。 但愿神师多灵应， 得保朕躬享太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄皓、神师同上。"
        },
        {
          "character": "黄皓",
          "type": "唱",
          "text": "仙师且在宫门等， 待我奏知圣明君。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "启奏陛下：奴婢已将神师请到。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "快快宣他进见！"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "陛下不可。那神师乃是仙人，必须焚香迎请！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "内侍，焚香迎请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。巫婆上，黄皓引进，巫婆坐正场椅。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "陛下必须诚心拜祷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅焚香。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "朕蜀汉天子刘禅，于炎兴元年孟冬月己酉朔越九日，叩祝神庥，保朕天下升平， 魏寇自退，请示吉凶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅拜。巫婆打喷嚏，披发，袒一臂变花脸腔。"
        },
        {
          "character": "巫婆",
          "type": "白",
          "text": "哇呀呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巫婆出桌外跳。"
        },
        {
          "character": "巫婆",
          "type": "三笑",
          "text": "哈哈、哈哈、啊哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巫婆坐桌上。"
        },
        {
          "character": "巫婆",
          "type": "白",
          "text": "吾乃西川土神是也。万岁放心，乐享太平，何必多虑。再过几年，魏国江山， 自归陛下，切勿忧思。吾神去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巫婆三笑。"
        },
        {
          "character": "巫婆",
          "type": "白",
          "text": "哇呀呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巫婆从桌上摔下，作死。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "启陛下：神灵已去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄皓搀巫婆。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "卿家备金银彩帛，送与神师。"
        },
        {
          "character": "巫婆",
          "type": "白",
          "text": "多谢陛下。告辞了！"
        },
        {
          "character": "巫婆",
          "type": "唱",
          "text": "辞别陛下出宫门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巫婆下。"
        },
        {
          "character": "黄皓",
          "type": "唱",
          "text": "但请快乐放宽心。"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "神师此语添逸兴， 不由朕躬喜在心。 内侍摆驾后宫进， 从今朝暮饮杯巡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四大刀手各执刀斧引邓忠、师纂同上。邓忠、师纂同起霸。"
        },
        {
          "character": "师纂",
          "type": "念",
          "text": "沙尘惊蔽目，"
        },
