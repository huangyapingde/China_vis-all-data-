{
  "script_id": "03026004",
  "title": "取江油",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "邓艾",
      "hangdang": "老生"
    }
  ],
  "plot": "魏将邓艾、钟会奉命取西蜀，兵至剑阁，山势险峻，不易攻下。邓艾乃冒险偷渡阴平，进取江油。江油守将\n马邈欲降。马邈妻李氏叱马邈不忠，亲点兵将出城迎敌，获大胜。因马邈与邓艾里应外合，李氏卒败，以身\n殉国。",
  "notes": "此剧与《三国演义》本事不符。据《三国演义》本事载：李氏闻马邈降魏后，自缢身死。为求资料完备，特\n将此本附印，以供参考。\n此剧经刘砚芳先生协助校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。四太监、黄皓引刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "引子",
          "text": "海不扬波，乐春秋，永镇山河。"
        },
        {
          "character": "刘禅",
          "type": "念",
          "text": "日月辉三界，君臣乐八荒。盈廷歌济济，齐进万年觞。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "朕，蜀汉天子刘禅在位。承父皇基业，坐镇西川，四十二年，雨顺风调，黎民 乐业。前日黄皓奏道，自古天子有巡狩之仪，因此今日銮舆起行。 黄皓！"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "传旨命御林军开道，随朕巡狩。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "领旨。 御林军起銮，巡狩郊外去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军、车辇同上。四太监同持仪仗。"
        },
        {
          "character": "刘禅",
          "type": "西皮导板",
          "text": "荒郊巡幸驻龙辇，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四御林军、黄皓、刘禅同扯四门。"
        },
        {
          "character": "刘禅",
          "type": "西皮原板",
          "text": "君臣相恋乐安然。 四野山川花增艳， 农民耕种水稻田。 今日巡狩同游玩， 太平盛世官民欢。 卿家有本须进谏， 朕躬无不纳善言。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "啊卿家，今与朕同巡，天下有何利弊，可细细向朕躬奏明，即颁行天下。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "启陛下：奴婢不才，仰荷天恩，所知者不敢不奏。因川中连年大有，禾生双穗， 皆陛下洪福所致。只是军中耗费，未免太重。请降旨先将大都督姜维部下口 粮减少，令其散兵为农，以免耗费无用之饷；再将武都、阴平戍守之五千兵丁 撤去。现在三分天下，各守将土。况武都、阴平乃是天险之处，要防兵何用？ 这就是奴婢一片丹心，请陛下圣裁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "好，依卿所奏，即日施行。传旨今晚驻跸行宫，另寻意外之欢。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "领旨。 御林军，驾幸行宫，驻跸去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。众人同走圆场，同领下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大刀手、四将、卫瓘、钟会同上。"
        },
        {
          "character": "钟会",
          "type": "西皮散板",
          "text": "昨日阵前大交兵， 姜维智勇有才能。 我今守寨相持定， 且俟机会把功成。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "参见大将军！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "卫参谋少礼。请坐。"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "本帅，钟会。钦奉天子明诏、晋公钧命，领兵伐蜀。可恨邓艾小儿，每每恃才， 小视于俺。倘有机会，必先制服邓艾，然后再灭蜀兵。参谋以为如何？"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "主帅既与邓征西一同奉命伐蜀，倘若争论，恐伤和气。请主帅三思！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "某奉命督师，若邓艾有罪，也当斩之！"
        },
        {
          "character": "卫瓘",
          "type": "白",
          "text": "主帅应以宽大为怀。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "参谋哇！"
        },
        {
          "character": "钟会",
          "type": "西皮散板",
          "text": "钦承君旨晋公令， 督师监战把蜀平。 军法不明难服众， 怎能阵前把功成！"
        },
        {
          "character": "卫瓘",
          "type": "西皮散板",
          "text": "主帅严令人惊恐， 默默无言暗沉吟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "邓征西将军到。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "但不知带领多少人马？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "并无人马，只有马夫二名，随行旗牌一人。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "起过了。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "且住！想邓艾既未领人马前来，待本帅震慑于他。 众将官，腰悬宝剑，摆队迎接邓艾去者！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "摆队相迎！ （〖牌子〗。四文堂拿标子、四大刀手拿大刀、四将各佩宝剑同摆队下。卫瓘、钟会同下。二马童同上，马 童甲牵马，马童乙打旗，旗上写“征西将军邓”。旗牌随邓艾同上。）"
        },
        {
          "character": "邓艾",
          "type": "西皮散板",
          "text": "钟会平定汉中郡， 狂傲欺人自为尊。 又见营门军容盛，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂、四大刀手、四将、卫瓘、钟会同上。"
        },
        {
          "character": "邓艾",
          "type": "西皮散板",
          "text": "旁若无人叙寒温。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾下马。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "啊征西将军！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "镇西将军！"
        },
        {
          "character": "钟会、邓艾",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下，同上。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "征西将军驾到，未能远迎，当面恕罪！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "岂敢！某家来得莽撞，将军海涵！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "啊将军，彼此军务纷繁，今幸过营一叙，敬备小宴，恭请畅饮。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "如此打搅了。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "看筵伺候！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "排宴。〖牌子〗。中军跪。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将军情！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟会、邓艾同入座。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将军情！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖园林好〗。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "将军得了汉中，乃朝廷之大幸也。何不定策，早取剑阁？"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "若取剑阁，将军有何明见，即请示知！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾想。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "哦，将军欲取西川，以愚意度之，可引一支奇兵，从阴平小路，出汉中德阳亭， 径取成都。那姜维必撤兵去救成都，将军乘虚，夺取剑阁，可获全功也！"
        },
        {
          "character": "邓艾",
          "type": "西皮散板",
          "text": "忆昔韩信掌军机， 深谋智广显神奇。 吾今兵渡阴平地， 指日走马转旌旗。"
        },
        {
          "character": "钟会",
          "type": "西皮散板",
          "text": "听罢言来心欢喜， 将军谋略世间稀。 祝你早定成都建功绩， 麒麟阁上把名题。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将军奇才，令人可敬。自古道：用兵之法，置之死地而后生。将军此计，与韩 信可谓先后媲美，开我愚蒙，不胜佩服。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "将军休要过奖。想我欲行此计，能否成功，毫无把握。何劳预先夸奖！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将军此去，马到成功。某在此敬候捷音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾不悦。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "如此告辞了！"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "再饮几杯。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "讨扰盛筵，告辞了！"
        },
        {
          "character": "邓艾",
          "type": "西皮散板",
          "text": "辞别将军添豪气， 满怀壮志与天齐。 非是大言夸妙计，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二马童同带马。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾上马。"
        },
        {
          "character": "邓艾",
          "type": "西皮散板",
          "text": "管取一战定华夷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖四击头〗。邓艾下，二马童同随下。"
        },
        {
          "character": "钟会",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "钟会",
          "type": "西皮散板",
          "text": "人言邓艾多妙计， 依某看来不出奇。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "且住！想那邓艾之计，分明行险侥幸。想那阴平小路，皆高山峻岭，倘蜀兵有 备，岂不全军覆没。看来邓艾乃庸才耳。正是："
        },
        {
          "character": "钟会",
          "type": "念",
          "text": "深沉自足逞雄略，侥幸何能立大功。"
        },
        {
          "character": "钟会",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "师纂、邓忠同上。"
        },
        {
          "character": "师纂",
          "type": "念",
          "text": "勇敢酬知遇，"
        },
        {
          "character": "邓忠",
          "type": "念",
          "text": "英雄出少年。"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "师纂",
          "type": "白",
          "text": "师纂。"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "邓忠。"
        },
        {
          "character": "师纂",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "师纂",
          "type": "白",
          "text": "今日都督，往钟镇西营中议事，尚未回营，我等营门伺候！"
        },
        {
          "character": "二马童",
          "type": "内同白",
          "text": "大将军回营！"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "吩咐开门迎接！ （〖大开门〗。四蓝龙套、四大铠、四上手同上。邓艾、二马童、旗牌同上。师纂、邓忠同迎。邓艾一看， 下马进门，入大帐。）"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "参见（都督）（父帅）！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "罢了。可恼哇可恼！"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "父帅由钟将军营中归来，因何震怒？"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "你等哪里知道，因姜维兵屯剑阁，不能前进。某以实意相告，欲从阴平小路， 袭取成都，可恨彼以庸才视我，你道恼是不恼！"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "父帅且请息怒。须知“小不忍则乱大谋”。望乞恕之。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "彼料我不能袭取成都，待某与晋公修表一道。师纂、邓忠。"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "听我一令啊！"
        },
        {
          "character": "邓艾",
          "type": "西皮散板",
          "text": "军国大事非容易， 用兵不险不为奇。 西川道路虽险僻， 唯有阴平更崎岖。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "邓忠、师纂，某欲偷渡阴平，同建功业，你二人可愿舍身前往？"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "末将等愿随（都督）（父帅）建功，万死不辞！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "好哇！邓忠、师纂听令！"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "命你二人领五千精兵，各备钢刀利斧，不穿甲衣，前往阴平小道，凿山开路， 搭造桥阁。若有畏难者，军法示众。"
        },
        {
          "character": "师纂、邓忠",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "邓艾",
          "type": "念",
          "text": "欲求生富贵，"
        },
        {
          "character": "师纂、邓忠",
          "type": "同念",
          "text": "须下死功夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "师纂、邓忠领四上手同下。"
        },
        {
          "character": "邓艾",
