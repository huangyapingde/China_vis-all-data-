        {
          "character": "四蓝龙套、四大铠",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "邓艾",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、黄皓引刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "西皮原板",
          "text": "朕躬即位坐龙廷， 四十二载享升平。 朝政全凭孔明整， 五丈原中殒将星。 如今姜维持国柄， 现在沓中屯雄兵。 岂惧敌人来犯境， 剑阁险路怎样行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郤正上。"
        },
        {
          "character": "郤正",
          "type": "唱",
          "text": "钟会兵取汉中境， 忙上金阶奏圣明。"
        },
        {
          "character": "郤正",
          "type": "白",
          "text": "臣，郤正见驾，陛下万岁！"
