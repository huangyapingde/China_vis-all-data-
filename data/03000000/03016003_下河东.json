{
  "script_id": "03016003",
  "title": "下河东",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "呼延寿廷",
      "hangdang": "老生"
    },
    {
      "name": "欧阳方",
      "hangdang": "净"
    },
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "白龙",
      "hangdang": "副净"
    },
    {
      "name": "呼延凤英",
      "hangdang": "武旦"
    },
    {
      "name": "呼延妻",
      "hangdang": "旦"
    }
  ],
  "plot": "宋初，权臣欧阳方思谋帝位，暗结河东刘崇唆使反朝。刘崇遣其子白龙领兵入寇。宋主赵匡胤欲亲征，苦无\n良将为辅。欧阳方自请为帅，并力荐呼延寿廷为先行。实则欧阳方与呼延寿廷旧有嫌隙，既欲拥兵自厚，复\n欲借机杀害呼延寿廷以报旧恨。既抵军中，对呼延寿廷寻隙凌辱，竟诬呼延寿廷谋反，于宋主前杀之。更欲\n谋弑宋君，终以宋主英武未逞。",
  "notes": "《下河东》故事出于《飞龙传》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "少打关东闯关西，刺杀刘王费心机。陈桥多亏郑三弟，孤王才得立帝基。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤，赵匡胤。自登基以来，风调雨顺，国泰民安。今当早朝。 内侍，开放龙门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "欧阳方上。"
        },
        {
          "character": "欧阳方",
          "type": "念",
          "text": "河东打战表，上殿奏当朝。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "臣，欧阳方见驾，吾皇万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "欧阳丞相平身。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "臣启万岁：今有河东刘崇，打来连环战表。我主龙目御览！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "待孤看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。赵匡胤看。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呜呼呀，原来刘崇打来战表，叫孤御驾亲征。 欧阳丞相，但不知命何人挂帅？"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "老臣愿挂帅印。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "卿家乃是文职官员，怎挂得武将帅印？"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "臣启万岁：臣幼年习文，中年习武，习就文共武，扶保帝王都。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "既然如此，就命卿家挂帅。但不知何人为前部先锋？"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "今有呼延寿廷武艺超群，可以做得前部先锋。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如此，就命卿家宣他上殿。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "领旨。 万岁有旨：宣呼延寿廷上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延寿廷上。"
        },
        {
          "character": "呼延寿廷",
          "type": "念",
          "text": "忽听皇王宣，撩袍上金銮。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "臣，呼延寿廷见驾，吾皇万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "万万岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "今有河东刘崇打来战表，孤王御驾亲征。已令欧阳方挂帅，欲命卿以为前部先 锋。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "想那欧阳丞相乃是文职官员，焉能挂得武将帅印？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "寡人也是那样想。欧阳丞相奏道，少年习文，中年习武，习就文和武，扶保帝 王都。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "臣启万岁：臣与欧阳方有打牙仇恨，此番到了河东，恐怕他以公报私！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "臣启万岁：为主江山，哪有以公报私的道理？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "是啊！为孤江山，哪有以公报私的道理？待等平复河东回来，孤与你两家解和 此事。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "有道明君！朝事已毕，请驾回宫！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、赵匡胤同下。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "先行，你可知军中号令？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "身为武将，怎么不知军中号令！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "一卯不到？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "一捆四十。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "二卯不到？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "两捆八十。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "这三卯？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "这三卯！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "嗯？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "哼哼哼……不过是项上的人头。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "哼，你也知项上的人头！此番到了河东，你要与我打点了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "欧阳方下。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "贼呀，贼！"
        },
        {
          "character": "呼延寿廷",
          "type": "念",
          "text": "但将冷眼观螃蟹，看尔横行到几时？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延寿廷下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、呼延妻同上。"
        },
        {
          "character": "呼延妻",
          "type": "念",
          "text": "夫受皇家爵，妻沾雨露恩。"
        },
        {
          "character": "呼延寿廷",
          "type": "内白",
          "text": "回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、呼延寿廷同上。"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "老爷！"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "夫人。可恼啊可恼！"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "老爷今日下朝，为何这等烦恼？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "夫人哪里知道！只因河东刘崇，打来战表，要夺主上江山。万岁御驾亲征，欧 阳方挂帅，命下官以为先行，你道恼是不恼？"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "想那欧阳方乃是文职官员，焉能挂得武将帅印？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "下官也是这样讲。那奸贼奏道：幼年习文，中年习武，习就文共武，扶保帝王 都。"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "况且他与老爷有打牙之仇，恐怕到了那里以公报私！"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "好一有道明君，是他言道，平复河东回来，与我两家解和此事。"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "既然如此，老爷请至后堂披挂，待妾身点动人马。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "有劳夫人。正是："
        },
        {
          "character": "呼延寿廷",
          "type": "念",
          "text": "青龙背上屯青草，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延寿廷下。家院暗上。"
        },
        {
          "character": "呼延妻",
          "type": "念",
          "text": "白虎当头休扎营。"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "家院过来！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "传我将令，吩咐大小三军，二堂听点！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 下面听者：夫人有令，大小三军，二堂听点！"
        },
        {
          "character": "四龙套",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "呼延妻",
          "type": "二黄导板",
          "text": "在二堂替老爷忙传将令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "参见夫人！"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "呼延妻",
          "type": "回龙",
          "text": "叫一声众三军细听分明："
        },
        {
          "character": "呼延妻",
          "type": "二黄原板",
          "text": "都只为刘崇贼打来战本， 他要夺我主爷锦绣龙庭。 欧阳方在金殿挂了帅印， 我老爷倒做了马前先行。 耳边下又听得盔甲响声， 想必是我老爷披挂来临。"
        },
        {
          "character": "呼延寿廷",
          "type": "内二黄导板",
          "text": "这几载未出兵干戈宁静，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延寿廷上，起霸。"
        },
        {
          "character": "呼延寿廷",
          "type": "二黄摇板",
          "text": "身披铠甲亚似寒冰。 迈虎步且把二堂进， 有劳夫人点雄兵。"
        },
        {
          "character": "呼延妻",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "呼延妻",
          "type": "二黄摇板",
          "text": "家院看过酒一樽， 我与老爷来饯行。"
        },
        {
          "character": "呼延寿廷",
          "type": "二黄摇板",
          "text": "接过夫人酒一樽， 背转身来谢神灵。 辞别夫人足踏镫， 是好是歹走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、呼延寿廷同下。"
        },
        {
          "character": "呼延妻",
          "type": "二黄摇板",
          "text": "一见老爷上能行， 但愿此去早归程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延妻下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引欧阳方同上。"
        },
        {
          "character": "欧阳方",
          "type": "念",
          "text": "一朝权在手，便把令来行。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "来，先行可到？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "先行未到。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "传先行！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "传先行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、呼延寿廷同上。"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "我且问你：自盘古以来，还是元帅伺候先行，还是先行伺候元帅？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "自然是先行伺候元帅，哪有反理而行的道理！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "你既知先行伺候元帅，本帅到此多时，你往哪里去了？"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "这个……末将披挂来迟，望乞元帅恕罪！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "哼！哪里是披挂来迟？分明见俺挂了武将的帅印，你那心中不服！"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "末将不敢！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "谅你也不敢。记过一次！"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "圣驾到此，速报我知。"
        },
        {
          "character": "四武士",
          "type": "内同白",
          "text": "圣驾到！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "一同接驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士、四太监、大太监、伞夫、赵匡胤同上。"
        },
        {
          "character": "呼延寿廷、欧阳方",
          "type": "同白",
          "text": "参见万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "二卿少礼。人马可曾齐备？"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "传旨下去：文武百官一概免送；人马打从得胜门而出，就此响炮离京！"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "领旨。 先行！"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "欧阳方",
          "type": "白",
          "text": "万岁有旨，本帅有令，文武百官一概免送；人马打从得胜门而出，就此响炮离 京！"
        },
        {
          "character": "呼延寿廷",
          "type": "白",
          "text": "下面听者：圣上有旨，元帅有令，文武百官一概免送；人马打得胜门而出，就 此响炮离京！"
        },
        {
          "character": "八龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、呼延凤英同上。"
        },
        {
          "character": "呼延凤英",
          "type": "白",
          "text": "俺，呼延凤英。奉了嫂嫂之命，暗地保护兄长。 军士们，河东去者！"
        },
        {
