      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二下手押郑芝龙同上，郑芝龙坐。黄熙允上。"
        },
        {
          "character": "黄熙允",
          "type": "唱",
          "text": "总帅面前讨了令， 相劝乡亲郑芝龙。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "你二人回避了！"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二下手同下。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "将军别来无恙？"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "你又到此作甚？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "相劝将军来了。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "你看你家郑老爷被擒，敢来下说辞么？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "不敢不敢！略有几句言语，讲在将军面前。非劝将军归降，乃为同乡情谊。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "黄先生有话，请讲当面！"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "将军听了：黄某不才，自幼与将军同居一乡。后渐成长，虽与将军分别，故情 还在。今日将军被绑，刀临项首，弟看此景，心中不忍。自古道：贤臣择主而 事。昔日商纣王驾前有一宠臣，名唤黄飞虎，因纣王无道，君坏臣纲，黄飞虎 弃了故主投奔西歧文王。今总帅洪承畴曾为明室臣宰，与摄政王交锋，不意被 擒，见明室气数已尽，遂降大清，至今身为抚戎。又道是：丈夫之志，能屈能 伸。汉室关云长被困屯土山，也曾归顺曹营。将军现已被擒，眼见项首加刀， 还请你再思呀再想！"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "郑芝龙",
          "type": "唱",
          "text": "芝龙闻言暗思忖， 数语劝醒迷路人。 不如暂时且归顺， 再对故人把话云。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "先生苦口相劝，但不知如何降法？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "第一、留下发辫，遵守清室制度；第二、写下密书下到郑成功那里，叫他前来 归降。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "第一尚可，第二不能。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "怎么不能？"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "我子成功秉性纲烈，难得成功。末将不能允许。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "将军写信，总帅自有办法。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "如此我件件依从。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "待我与你松绑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄熙允与郑芝龙松绑。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "将军请坐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑芝龙坐。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "这里有文房四宝。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "待我写来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。郑芝龙修书。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "书已写完。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄熙允看书信。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "将军，随我总帅营中走走！"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄熙允、郑芝龙同下。"
        }
      ]
    },
