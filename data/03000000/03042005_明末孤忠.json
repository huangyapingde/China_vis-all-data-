{
  "script_id": "03042005",
  "title": "明末孤忠",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "郑成功",
      "hangdang": "武生"
    }
  ],
  "plot": "明末，洪承畴降清，兵扫江南。仙霞关守将郑芝龙败降，并诏其子郑成功。郑成功厉言拒绝，占据台湾，屯\n军厦门，且改厦门为“思明州”，力图复明。洪承畴部将胡希孔，为降郑成功，偷杀郑成功母、弟。郑成功\n大怒，身穿重孝，举兵报仇。胡希孔被剮，洪承畴退守武昌。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡希孔、李成栋同上，双起霸。"
        },
        {
          "character": "胡希孔",
          "type": "念",
          "text": "背明降清心中顺。"
        },
        {
          "character": "李成栋",
          "type": "念",
          "text": "随从总帅争江南，"
        },
        {
          "character": "胡希孔",
          "type": "白",
          "text": "李将军请了！"
        },
        {
          "character": "李成栋",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "胡希孔",
          "type": "白",
          "text": "总帅升帐，你我两厢伺候。"
        },
        {
          "character": "李成栋",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手引黄熙允、洪承畴同上。"
        },
        {
          "character": "洪承畴",
          "type": "引子",
          "text": "奉命总戎，把江南，一扫而平！"
        },
        {
          "character": "胡希孔、李成栋",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "站立两旁。"
        },
        {
          "character": "胡希孔、李成栋",
          "type": "同白",
          "text": "谢元帅！"
        },
        {
          "character": "洪承畴",
          "type": "念",
          "text": "统领貔貅下江南，赏罚分明在帐前。运筹帷幄经纬略，扶清灭明镇疆边。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "本帅、清封太师太保、恩赐黄马褂、赏戴红顶花翎总镇洪承畴。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "参谋、黄熙允。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "奉摄政王之命，统兵扫荡江南。真是兵强将勇，攻无不取，战无不胜。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：人马来到仙霞关。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "李成栋听令！"
        },
        {
          "character": "李成栋",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "命你攻打仙霞关，不得有误！"
        },
        {
          "character": "李成栋",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "总帅，不可呀不可！"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "参谋为何阻令？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "仙霞关总镇郑芝龙，他有一子，名唤郑森。此人相貌魁伟，十分骁勇，文武兼 备，年二十一岁，随父入朝。隆武皇帝看他相貌出奇，将来必为国家栋梁，赐 姓“朱”，改名“成功”。外人传闻，将“朱”字失去，呼之为“郑成功”。 其母田川氏。芝龙镇守仙霞关。总帅出兵攻打，倘有不利如何是好？"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "卑职与他同居一乡，有故旧之谊。愿到关内劝他归降。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "既然如此，命你即到关内劝降！"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄熙允下。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "洪承畴",
          "type": "念",
          "text": "参谋进关劝故人，营中等候喜信音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手引郑鸿逵、郑芝龙同上。"
        },
        {
          "character": "郑芝龙",
          "type": "念",
          "text": "弟兄两人奉圣命，"
        },
        {
          "character": "郑鸿逵",
          "type": "念",
          "text": "仙霞关内为总兵。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "平夷侯、郑芝龙。"
        },
        {
          "character": "郑鸿逵",
          "type": "白",
          "text": "定清侯、郑鸿逵。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "我弟兄二人奉隆武帝圣上之命，镇守仙霞关。如今刀兵扰乱，无日安宁。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启侯爷：敌营来了一人，口称侯爷的乡里，特来求见。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "叫他报名而进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄熙允暗上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "叫你报名而进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "报！乡人黄熙允告进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄熙允进。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "二位总镇在上，乡里人黄熙允有礼！"
        },
        {
          "character": "郑芝龙、郑鸿逵",
          "type": "同白",
          "text": "先生免礼。 左右，看座！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲与黄熙允看坐。"
        },
        {
          "character": "郑芝龙、郑鸿逵",
          "type": "同白",
          "text": "请坐！"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "黄先生来到关内，不知有何贵干？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "只因清营总帅洪承畴，统领三军来到关下，要与将军交战。愚下在总帅帐下吃 了小小一份俸禄，知二位乡亲在此镇守，倘然兵戈相见，必有胜负。依愚下之 见，若两国兵力相较，明不能敌清必矣。故弟在总帅面前讨下军令，来到关内， 劝二位兄台归顺大清，不知意下如何？"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "原来你是奉令顺说我二人降清的？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "若不看在同乡之情，难免皮肉吃苦。我今坐镇仙霞关，清兵到来，对阵交兵， 理所当然！"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "明军气力衰危，不能敌清。虽然交锋，也是有损无益，劳而无功。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "不必多言！"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "二位将军还要再思再想！"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "左右，叉出帐去！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同向黄熙允。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "出去！"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "快去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄熙允下。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "交锋去者！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、四下手、胡希孔、李成栋引洪洪承畴自上场门同上，四龙套、四上手引郑芝龙、郑鸿逵自下场门"
        },
        {
          "character": null,
          "type": "text",
          "text": "同上，同开打，四龙套、四上手、郑芝龙、郑鸿逵同败下，四龙套、四下手、胡希孔、李成栋、洪承畴同追"
        },
        {
          "character": null,
          "type": "text",
          "text": "下。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑鸿逵上，胡希孔上，同开打，郑鸿逵被杀，胡希孔下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑芝龙上。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀侯爷：二将军落马身亡。"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。李成栋上，开打，李成栋败下，郑芝龙追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手引洪承畴、黄熙允同上。"
        },
        {
          "character": "洪承畴",
          "type": "唱",
          "text": "为荣华与富贵扶保满清， 有本帅引人马来到江宁。 今日里仙霞关对阵交兵， 强与弱胜与败还未分明。 耳边厢又听得战鼓阵阵， 待本帅下战马细看分明。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "随我登高一望！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "啊！ （四龙套、四下手、黄熙允、洪承畴同登高。胡希孔、李成栋同败上，郑芝龙、四龙套、四上手同追上，同 打，胡希孔，李成栋同败下。郑芝龙、四龙套、四上手同上。）"
        },
        {
          "character": "郑芝龙",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈……"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "追！"
        },
        {
          "character": "四龙套、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、郑芝龙同追下。"
        },
        {
          "character": "洪承畴",
          "type": "唱",
          "text": "果然是那敌人杀法骁勇， 直杀得众兵丁东倒西倾。 正观战忽然间妙计心定， 唤先锋我有话对他说明。"
        },
        {
          "character": "下手甲",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下手甲下。下手甲引胡希孔同上。"
        },
        {
          "character": "胡希孔",
          "type": "白",
          "text": "总帅有何差遣？"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "敌将杀法厉害，绊马索伺候！"
        },
        {
          "character": "胡希孔",
          "type": "白",
          "text": "遵命！ （胡希孔撒绊马索，下。胡希孔、李成栋同败上，郑芝龙追上，胡希孔、李成栋同佯败，郑芝龙追，落马， 被擒。）"
        },
        {
          "character": "胡希孔",
          "type": "白",
          "text": "启总帅：敌将被擒。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "回营去者！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引黄熙允、洪承畴、胡希孔、李成栋同上。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "将敌将绑进帐来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "将敌将绑进帐来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押郑芝龙同上。"
        },
        {
          "character": "郑芝龙",
          "type": "唱",
          "text": "适才间在阵前对敌交锋， 偶失意落下马上了绑绳。 迈虎步进帐来昂首站定， 杀与剐任凭他号令施行！"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "胆大郑芝龙！既然被擒，还不帐下乞降？"
        },
        {
          "character": "郑芝龙",
          "type": "白",
          "text": "你郑老爷虽然被擒，有死而已，何言“乞降”"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "来，将郑芝龙推出辕门斩首！"
        },
        {
          "character": "二下手",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二下手押郑芝龙同下。"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "参谋敢是与他讲情？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "卑职愿去劝他投降。"
        },
        {
          "character": "洪承畴",
          "type": "白",
          "text": "但不知参谋怎样劝法？"
        },
        {
          "character": "黄熙允",
          "type": "白",
          "text": "第一、让他留发辫；第二、让他书召成功归顺。"
