          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。张良上。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "俺，张良。适才与夫人话别，急急走出相府。又恐圣上命人追赶，难免一场争 执。不免寻个僻静所在，换了衣巾，也好寻访我那恩师。正是："
        },
        {
          "character": "张良",
          "type": "念",
          "text": "不愿在朝为相宰，避却红尘世外来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂、门子、陈平、曹参、周勃、隋何同上。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "来到相府。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "前去通报。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "众位大人到。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请稍站。 有请夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟、张夫人同上。"
        },
        {
          "character": "张夫人",
          "type": "念",
          "text": "前堂高声语，后堂云板传。"
