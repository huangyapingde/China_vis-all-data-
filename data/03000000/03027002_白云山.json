        {
          "character": "张夫人",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "众位大人求见。"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请众位大人！"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同白",
          "text": "啊夫人，我等有礼！"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "众位大人请坐！"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同白",
          "text": "告坐。"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "众位大人驾到，未曾远迎，当面恕罪！"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同白",
          "text": "岂敢！我等奉旨前来，为何不见子房先生？"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "众位大人既是奉旨前来，必知拙夫告职之事。他朝罢归来，言道圣上洪恩，准 他入山修道，不曾收拾，急忙出府去了。留下几句言语，众位大人听了！"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同白",
          "text": "夫人请讲。"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "抛妻别子埋姓名， 不染红尘半毫分。 公卿皆有金石论， 在朝为官要小心。"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同白",
          "text": "哎呀！"
        },
        {
          "character": "陈平",
          "type": "唱",
          "text": "听罢夫人一席话，"
        },
        {
          "character": "曹参",
          "type": "唱",
          "text": "不由我等泪如麻。"
        },
        {
          "character": "周勃",
          "type": "唱",
          "text": "辞别夫人齐上马，"
        },
        {
          "character": "隋何",
          "type": "唱",
          "text": "见了万岁说根芽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、曹参、周勃、隋何同下。门子、四文堂同随下。"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "送别大人上鞍马， 修仙学道且由他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张夫人下。二丫鬟、院子同随下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张良上。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "贫道本是一天星， 修行学道入山林。 多年王侯成佛祖， 胜似为王万万春。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "山人，张子房。辞别汉王入山修炼，圣上怜念忠良，满朝文武追我还朝。此地 有片沙滩，待我在沙滩之上留诗一首，打发他们回去。正是："
        },
        {
          "character": "张良",
          "type": "念",
          "text": "几载兵书未展开，我主无故斩贤才！金印象简无心挂，怕学韩信剑下灾。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "张良题。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "留诗一首在沙滩， 我主龙心且自安。 君臣若要重相见， 除非龙行白云山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、门子、陈平、曹参、周勃、隋何同上。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "列位大人，追至此地，并无张良踪迹，你我回朝去吧！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "启禀大人：沙滩之上，有许多字迹，请大人观看。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "我等看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平看。"
        },
        {
          "character": "陈平",
          "type": "念",
          "text": "几载兵书未展开，我主无故斩贤才！金印象简无心挂，怕学韩信剑下灾。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "张良题。 有此诗句，你我回朝复旨便了！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "开道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂、门子、陈平、曹参、周勃、隋何同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张良上。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "且住！看圣驾来得甚急，无有歇足之地。待我变作渔翁、樵夫指引于他。 一变、二变，渔樵出现。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良下。渔翁、樵夫同上。"
        },
        {
          "character": "渔翁、樵夫",
          "type": "同唱",
          "text": "时过春夏又复秋， 黄河不断水自流。 镇国将军边廷老， 盖世元勋一旦休。"
        },
        {
          "character": "刘邦",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四御林军、陈平、曹参、周勃、隋何、大太监、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "张良学道往深山， 寡人心中不得安。 内侍摆驾朝前趱， 不知贤臣在哪边！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "渔樵挡道。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "带了上来！"
        },
        {
          "character": "渔翁、樵夫",
          "type": "同白",
          "text": "叩见万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "你二人可知张子房先生往哪里去了？"
        },
        {
          "character": "渔翁、樵夫",
          "type": "同白",
          "text": "子民不知。沙滩之上，留有诗句一首。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "念来孤王一听。"
        },
        {
          "character": "渔翁、樵夫",
          "type": "念",
          "text": "留诗一首在沙滩，我主龙心且自安。君臣若要重相见，除非龙行白云山。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "前面带路！"
        },
        {
          "character": "渔翁、樵夫",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "孤王创业数十年， 忠良贤士在身边。 子房今日辞王去， 难舍难分泪不干。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "渔翁、樵夫同暗下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "渔樵不见。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "噢！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "堪叹忠臣离朝阁， 江山好似浪里波。 御林军摆驾山坡过， 要学文王渭水河。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四云童、张良同上。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "我把红尘都看破， 怕的后来受折磨。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "且住！汉王驾到，此地无歇足之地，待我点化一座茅庵，留下隐语诗句，劝主 回去。"
        },
        {
          "character": "张良",
          "type": "念",
          "text": "“天灵灵，地灵灵，茅庵出现”。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "茅庵出。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "待我留诗一首："
        },
        {
          "character": "张良",
          "type": "念",
          "text": "白云山前泪两行，热血张良答君王。红颜常因薄情死，鸳鸯被弹竟伤亡。 牛耕田地人享谷，蚕做茧来却受殃。世上不平冤苦事，花残月缺少年亡。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "不是韩信把命丧， 朝中稳坐张子房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良下。四太监、四御林军、陈平、曹参、周勃、隋何、大太监、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "百鸟不住叫山岗， 卷旗息鼓没声张。 松林隐路人烟少， 不知贤臣在哪厢？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "启奏万岁：此地有所茅庵，壁上题有诗句！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "待孤看来。"
        },
        {
          "character": "刘邦",
          "type": "念",
          "text": "白云山前泪两行，热血张良答君王。红颜常因薄情死，鸳鸯被弹竟伤亡。 牛耕田地人享谷，蚕做茧来却受殃。世上不平冤苦事，花残月缺少年亡。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "看罢诗句泪两行， 庵前哭坏汉刘邦。 叹的文臣和武将， 悔不该误斩三齐王。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "此地现有文房四宝，待孤回诗一首。"
        },
        {
          "character": "刘邦",
          "type": "念",
          "text": "找寻踪迹到荒山，不见贤臣空见庵。日映红桃清节暖，风吹竹叶透襟寒。 丹炉苦炼尘灰重，壁上题诗墨未干。琴剑书箱依然在，子房何处把身安？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "御笔题。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "三宣四召不回朝， 白云山高乐逍遥。 明知你是仙家道， 点石成金不用烧。 朝中缺少擎天柱， 殿前何人挂紫袍？ 内侍与孤前引道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良上。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "哎呀，万岁呀！"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "臣愿我主福寿高。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "一见先生忙陪笑， 来了擎天柱一条。 今日得见贤臣面， 雪见太阳化水消。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "万岁爷不在龙凤阁， 来在郊外为哪条？"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "孤王闻言珠泪掉， 叫一声卿家听根苗： 先生去好比失却珍和宝， 先生去孤王未曾临九朝。 你今云游去修道， 孤王的江山坐不牢。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "万岁爷休要珠泪掉， 为臣把本奏当朝： 曾记得当年怀王诏， 楚汉分兵路两条； 我主爷洪福真不小， 天降真龙坐汉朝； 先到咸阳为国主， 后到咸阳为臣僚； 霸王不遵怀王诏， 强霸称雄坐九朝； 范增屡次生计巧， 要害我主赴阴曹； 鸿门宴会设圈套， 主上洪福与天高； 封在蜀中断了道， 为臣背剑访英豪； 也曾力把韩信保， 可算擎天柱一条； 明明修得是栈道， 暗度陈仓把兵消； 夺来三秦功不小， 谁敢与他逞英豪； 霸王垓下兵败了， 臣也曾驱散众儿曹。 逼死项羽乌江道， 才得一统归汉朝； 干戈息狼烟尽皆扫， 五谷丰登乐逍遥； 臣今看透其中妙， 怕学韩信赴阴曹。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "先生不必性情傲， 有一辈古圣贤细听根苗： 昔日里姜子牙渭水垂钓， 周文王访贤臣去到荒郊。 齐景公访晏平江山崩掉， 晋文公逃难时保驾群僚。 回朝来承父业忠臣多少？ 忘了那介子推隐住山巢。 到后来重耳才知晓， 亲自访贤到荒郊。 介子推不把那重耳保， 绵山一旦被火烧。 后来修下忠臣庙， 每年春秋把香烧。 卿比那介子推功劳不小， 孤王难比圣贤高。 再三再四好言告， 先生与孤转回朝。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "我主爷叫臣转回朝， 不由张良心内焦。 低下头来生计巧，"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "有了！"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "想起拐杖独木桥。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "且住！主公叫我一同回朝，如何是好？有了！恩师所赐独木拐杖化一小桥，指 引万岁回朝便了。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "哪知修行仙法妙， 拐杖化一独木桥。 回头再把话来表， 尊声万岁请过桥。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "孤王登的阳关道， 霎时现出独木桥。 先生已然登仙道， 怎叫孤王过此桥？"
        },
        {
          "character": "张良",
