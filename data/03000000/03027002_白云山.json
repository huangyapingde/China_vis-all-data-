{
  "script_id": "03027002",
  "title": "白云山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张良",
      "hangdang": "老生"
    },
    {
      "name": "刘邦",
      "hangdang": "老生"
    }
  ],
  "plot": "汉刘邦得天下后，大杀功臣。张良师黄石道人劝徒退隐林泉。张良从之，上辞表，刘邦不准。张良乃偷入山\n林。刘邦率群臣追至白云山，虽百般婉留，张良终托言而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄石道人上。"
        },
        {
          "character": "黄石道人",
          "type": "引子",
          "text": "叹人生，光阴易过；无常到，如之奈何！"
        },
        {
          "character": "黄石道人",
          "type": "念",
          "text": "仙山修炼未完成，三卷天书定乾坤。子房不舍官爵禄，难免全家丧残生。"
        },
        {
          "character": "黄石道人",
          "type": "白",
          "text": "我乃黄石道人是也。只因张良仙根固厚，盖世奇才，赠他天书三卷，扶保汉室 天下。今江山已定，张良理应归山悟修。不免前去点化与他便了。"
        },
        {
          "character": "黄石道人",
          "type": "唱",
          "text": "在仙山取下了独木拐杖， 点化那忠良臣军师张良。 将身儿来至在大街之上， 到相府用言语点化子房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄石道人下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引张良同上。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "在朝中理刑曹军务执掌， 回府来赦罪凶散放军粮。 临大敌到边廷曾为大将， 回朝来蒙圣恩爕理阴阳。 见一人好似那师傅模样， 朝夕想时刻念谨记心旁。 回府去我命人明察暗访， 恩师到表一表盼望心肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "老夫，张良。适才街市之上，见一黄衣老丈，好似师傅模样。 来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子应。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "府门外有一穿黄衣之人，速速请进府来，不可轻慢。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄石道人上."
        },
        {
          "character": "黄石道人",
          "type": "念",
          "text": "来引迷津路，点化有缘人。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "黄石道人",
          "type": "白",
          "text": "你老爷可在府中？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "特来相请。"
        },
        {
          "character": "黄石道人",
          "type": "白",
          "text": "前去通报。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请少站。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子进门。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启老爷：黄衣之人现在府外。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "吩咐大开正门，有请！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "大开正门，有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "师傅请进！"
        },
        {
          "character": "黄石道人",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "师傅请上，弟子参拜！"
        },
        {
          "character": "黄石道人",
          "type": "白",
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "师傅在此，弟子理当站立侍奉。"
        },
        {
          "character": "黄石道人",
          "type": "白",
          "text": "有话叙谈，哪有不坐之理？"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "谢师傅！弟子愿闻训教。"
        },
        {
          "character": "黄石道人",
          "type": "念",
          "text": "曾记当年事，难道你不知？贪图富贵乐，怕的后悔迟！"
        },
        {
          "character": "黄石道人",
          "type": "唱",
          "text": "传你天书共三卷， 其中妙法有万千。 行兵布阵随机变， 斗引埋伏在其间。 功名富贵休贪恋， 即早回头去修仙。 独木拐杖将桥变， 君王那时才回还。 你我若要重相见， 松山顶下白云间。 话至此间抽身转， 违背我言后悔难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄石道人下。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "送师傅！"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "一见恩师他去了， 倒叫子房心内焦。 臣受君恩理当报， 怎能一旦把君抛？ 这是张良命不好， 难受皇家爵禄高。 辞王别驾去修道， 不染红尘半分豪。 若是不遵师训教， 眼前大祸难脱逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "念",
          "text": "有事忙来报，无事不乱言。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启老爷：大事不好了！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "今有吕太后将三齐王诳入未央宫斩首了！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "三齐王盖世功劳广， 未央宫一旦把命伤。 恩师命上辞表速逃罗网， 贪恋富贵不久长。 心灰万念皆空想， 明日五鼓上朝堂、面辞君王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈平、曹参、周勃、隋何同上。〖点绛唇〗。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "陈平。"
        },
        {
          "character": "曹参",
          "type": "白",
          "text": "曹参。"
        },
        {
          "character": "周勃",
          "type": "白",
          "text": "周勃。"
        },
        {
          "character": "隋何",
          "type": "白",
          "text": "隋何。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "请了！圣上临朝，分班伺候。"
        },
        {
          "character": "曹参、周勃、隋何",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、曹参、周勃、隋何同下。四太监、大太监、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "引子",
          "text": "汉室基业定，山河万代春。"
        },
        {
          "character": "刘邦",
          "type": "念",
          "text": "剑斩白蛇姓名扬，逼死项羽在乌江。咸阳一战争天下，才定汉室锦家邦。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤，大汉天子刘邦。自从项羽乌江自刎，才得大汉一统。又因陈豨闻风自灭， 众将班师还朝，国家安宁。今当驾坐早朝。 内侍，晓瑜文武两班：有本早奏，无本退班。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "万岁有旨：有本早奏，无本退班哪！"
        },
        {
          "character": "张良",
          "type": "内白",
          "text": "张良有本启奏！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "随旨上殿哪！"
        },
        {
          "character": "张良",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良上。"
        },
        {
          "character": "张良",
          "type": "念",
          "text": "韩信未央把命丧，汉马功劳付汪洋。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "臣，张良见驾，吾皇万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "先生平身。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "先生上殿，有何本奏？"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "臣启万岁：老臣血气衰微，难以奉君。臣要告职去往仙山学道，望吾主降旨。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "先生此言差矣！前者国乱，今方幸太平，正好与孤乐享。怎么要辞孤而去？此 本不准。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "张子房在金殿把本奏上， 尊万岁细听臣冒奏本章： 想当年保我主山河来创， 哪一日哪一夜不在战场？ 楚霸王自称雄把君王来抗， 各领兵分两路去到咸阳； 先到者为皇帝大位执掌， 后到者为臣宰立于庙廊。 楚项羽不遵约心怀狂妄， 将我主贬蜀中不能还乡。 臣也曾暗地里把韩信来访， 九里山灭霸王自刎乌江。 到今日狼烟息干戈扫荡， 好一比尧舜日乐享安康。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "有孤王听先生一番话讲， 回忆起当年事甚是惨伤！ 贬汉中仗先生暗地里把贤来访， 灭霸王孤才得一统家邦。 到如今孤与卿同把国掌， 弃寡人去修道所为哪桩？ 朝中的大小事任卿执掌， 辞孤王好一似斩断金梁。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "臣年迈听不见朝房鼓响， 臣年迈观不见阵前的儿郎。 我朝中有多少忠臣良将， 文臣精武将勇俱比臣强。 愿吾皇兴大业山河执掌， 愿吾皇似尧舜福寿绵长。 但愿得那各国齐把贡上， 但愿得海外臣俱来朝王。 非是臣忘君恩天良灭丧， 怕的是为臣我落一个为臣不忠、为将不勇、为官不清、到后来命不久长。 没奈何跪金殿悲声大放， 求万岁施天恩放臣还乡。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "张子房在金殿泪如雨降， 只哭得孤心中好不凄凉！ 低下头孤这里龙心暗想，"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "有了！"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "待孤王与众卿细作商量。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "我主爷在金殿把旨来降， 哭啼啼下龙廷自己思量。 贪禄位再保主深山不往， 怕难免学韩信身丧未央。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良下。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "内侍臣与孤王把旨传降， 宣众卿上金殿有话商量。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "众位大人上殿哪！"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "内同白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、曹参、周勃、隋何同上。"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同唱",
          "text": "忽听得万岁爷把旨来降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、曹参、周勃、隋何同进殿。"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同唱",
          "text": "问吾主因何事泪洒胸膛？"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "适才间张子房本章奏上， 辞孤王去修道所为哪桩？ 命卿等过府去挽留拦挡， 就说孤不能够释放忠良。"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "陈平、曹参、周勃、隋何",
          "type": "同唱",
          "text": "辞王驾下龙廷相府前往， 看众面念同僚赏脸赐光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、曹参、周勃、隋何同下。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "孤只说狼烟息快乐安享， 又谁知张子房来辞孤王！ 吾本当准了本任他自往， 倘若是烟尘起谁保朝堂？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "内侍与孤传旨，吩咐御林军摆驾相府！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "御林军走上啊！"
        },
        {
          "character": "四御林军",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "摆驾相府哇！"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张夫人上。"
        },
        {
          "character": "张夫人",
          "type": "念",
          "text": "日月轮流旋转，光阴似箭催人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良上。"
        },
        {
          "character": "张良",
          "type": "念",
          "text": "别却红尘路，一心入仙山。"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "啊，相公请坐！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "夫人请坐。"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "相公上殿辞朝，圣上可准？"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "圣上恩准，特地回府辞别夫人。"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "相公一旦他往，相府之事何人料理？"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "相府之事，有夫人掌管，我有一言，你且听了！"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "张良也曾吹玉箫， 八百儿郎走荒郊； 项羽自刎乌江道， 只惜当年怕今朝。 在朝为官有什么好？ 一事不周祸先招！ 别人只嫌官职小， 惟我只怕禄位高。 倘有一点不周到， 富贵功名一旦抛。 我今看透其中妙， 男耕女织要勤劳。 远游仙山去修道， 无忧无虑免心焦。"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "听罢言来珠泪掉， 尊声相公听根苗： 一双儿女年纪小， 你如何忍心把家抛？ 奴本女流全不晓， 怎比相公见识高？ 男婚女嫁事办了， 那时修道再辞朝。"
        },
        {
          "character": "张良",
          "type": "唱",
          "text": "夫人把话讲差了， 我今言来听根苗： 昨日恩师驾来到， 留下独木杖一条。 寻找师傅去修道， 贪恋红尘祸难逃。 夫妻本是同林鸟， 大限来时各离巢。"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "抛去妾身奴不恼，"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "我的夫啊！"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "忍将儿女一旦抛！"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "贤妻不必泪嚎啕， 生离死别在今朝。 鳌鱼脱去金钩钓， 四海云游走一遭。 辞别夫人出门道，"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "夫人哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。张良、张夫人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、门子、陈平、曹参、周勃、隋何同上。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "列位大人请了！"
