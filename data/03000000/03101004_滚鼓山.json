{
  "script_id": "03101004",
  "title": "滚鼓山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘封",
      "hangdang": "丑"
    }
  ],
  "plot": "关羽被困麦城时，曾遣廖化向刘封求援。刘封、孟达按兵不动，致关羽败绩身死。廖化遥奔阆中，张飞疾往\n上庸刘封处，用计赚取印、剑，并假意怂恿篡弑，将刘封诓入铜鼓内，中途，投掷山下，将刘封处死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、旗牌、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "点绛唇",
          "text": "执掌兵权，威风八面，统雄兵，扶保江山，指日扫中原！"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "忆昔结义在桃园，扶保大哥锦江山。二哥坐守荆州地，我镇阆中美名传。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺，姓张名飞字翼德。自从桃园结义以来，大破黄巾，扫灭吕布。三顾茅庐， 请来诸葛先生，攻无不取，战无不胜。可恨孙、曹累累与我弟兄作对，但愿早 灭孙、曹，江山一统，方称俺老张之意。 三军的，伺候了！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀三千岁：廖化将军到！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖化到此，必有所为。有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖吹打〗。廖化上。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖将军请坐！"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "谢座！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将军不在荆州，来到阆中做甚？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁，大事不好了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二千岁中了东吴吕蒙之计，败走麦城，被吴、魏两军围困，受害身死，归天去 了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "归天去了！"
        },
        {
          "character": "张飞",
          "type": "三叫头",
          "text": "二哥，兄长，哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞昏。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁醒来！"
        },
        {
          "character": "张飞",
          "type": "西皮导板",
          "text": "听一言不由人三魂不再，"
        },
        {
          "character": "张飞",
          "type": "三叫头",
          "text": "二哥，兄长，二哥呀！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "点点珠泪洒下来。 不幸二哥归天界， 再问何故致祸灾。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖将军，我家二哥，素与东吴交好，那孙权为何下此毒手？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "三千岁有所不知，只因孙权曾命诸葛瑾来到荆州求亲，二千岁不允，是他言道： “虎女焉能匹配犬子！”将诸葛瑾赶出帐去，故尔孙权设此毒计！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "原来如此！想俺二哥，既然败至麦城，为何不到上庸借兵呢？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "哎呀三千岁呀！二千岁也曾命末将去到上庸，搬兵求救，怎奈刘封坐观成败， 不肯发兵，并将末将赶出帐外！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "就是他！"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "正是！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "小奴才呀！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "听一言来气难平， 大骂刘封小畜生。 俺二哥麦城遭围困， 你竟胆敢不发兵。 尔手摸胸膛自思忖， 他是你的什么人？ 越思越想心头恨， 我不杀小奴才怒气怎平！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "刘封这小奴才，如此丧心昧良，俺老张岂肯与他干休！ 来，起兵前往！"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖将军为何阻拦？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "想那刘封，有我主赐他尚方宝剑，又有九头狮子鱼耳印，三千岁此番前去，只 怕画虎不成，反类其犬也！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将军但放宽心，俺老张自有道理！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化暗下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四文堂、四上手、旗牌",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "兵发上庸！"
        },
        {
          "character": "四文堂、四上手、旗牌",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、刘封同上。"
        },
        {
          "character": "刘封",
          "type": "念",
          "text": "营门战鼓响，军士赛虎狼！"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "三千岁到！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四文堂、四上手、旗牌、张飞同上。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "参见三叔父！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "罢了。一旁坐下！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "谢座！三叔父，多日不见，身体可好？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "为叔的倒好。你可好？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "侄儿好。但不知叔父打从何处而来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱老子打从成都而来！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "既从成都而来，我父王身体可好？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你父甚是安泰。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "我那二叔父，现在荆州，不知身体可安泰否？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞背供。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "这个小奴才，他倒同我装起傻来了。 刘封，你是不知呢？还是故问！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "小侄只有不知，哪有故问之理！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你那二叔父兵败麦城，已在玉泉山归天去了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封故作惊骇。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "啊，怎么，二叔父归天了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "只因孙权遣诸葛瑾前来提亲，你二叔父不允，将他赶出营外。不想那诸葛瑾在 孙权面前，搬弄是非，联合曹操，故而全军覆没了！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "既然如此，待侄儿发兵前去，与二叔父报仇！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "三叔父为何阻拦？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我且问你：你这上庸城有多少人马？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "现有十万雄兵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "既有十万雄兵，却也不少，今日为叔的要帮助于你。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "三叔父帮助，必定成功。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "但有一件！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "必须将尚方宝剑、九头狮子鱼耳印交付俺老张，方可前去。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "倘若杀退孙、曹两路兵将，三叔父还要交还侄儿。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "那是自然。看印拜过！ （〖吹打〗。刘封抱剑举印，张飞拜剑、印，刘封拔剑欲杀张飞，将剑入鞘。张飞接剑、印，刘封拜，张飞 拔剑欲杀刘封，将剑入鞘。）"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "印、剑已交三叔，请三叔传令发兵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "慢来慢来！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "为叔的还有一言，要同侄儿言讲。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "叔父有何金言，当面请讲。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱老张打从成都而来，见你父年迈，只恐不久于人世，倘若你父晏驾，这汉室 江山，不知何人承袭？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "倘若我父王晏驾，这江山定是阿斗的了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "不能不能！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "为何不能？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "想那阿斗，年轻幼小，怎能坐得江山，他怎能得够！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "阿斗年幼，不能执掌江山，只怕就要让与关兴坐了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "关兴正在孝服之中，不能登极即位。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "关兴不能，还有三叔父的儿子张苞也坐得！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "只怕这江山，就是侄儿你的了！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "小侄若坐，只恐满朝文武不服。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "说什么满朝文武不服，你今既有十万雄兵，待为叔的帮助与你。倘有不服者， 即按军法从事！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "若得叔父保驾，侄儿登了大宝，定封叔父一字并肩王。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好好好，依俺老张看来，事不宜迟，倒不如点动人马，先到成都，将你父刺死， 侄儿就可身登大宝。你看如何？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "此事可以做得么？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "做得的！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "如此即刻起兵前往！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且慢！为叔的有一计在此。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "为叔的有一铜鼓，将你装在鼓内，就说是外国进来之宝。你父那时定要观看， 为叔在旁，一鞭将鼓打开，你就一刀，将你父刺死了！"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "此计甚好。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四文堂、四上手、旗牌",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "起兵蝎子山！"
        },
        {
          "character": "四文堂、四上手、旗牌",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水龙吟〗。众人同走大圆场。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来，将铜鼓抬了上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同下，同抬鼓上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我儿藏在鼓内。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封脱袍、去盔，四上手同推刘封入鼓。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将鼓与我掷于山下！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同抛鼓。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "刘封尸骨碎如齑粉！"
        },
        {
          "character": "张飞",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "刘封已死，方解俺老张心头之恨！待俺去至成都，报与大哥知道便了！ 众将官！"
        },
        {
          "character": "四文堂、四上手、旗牌",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "成都去者！"
        },
        {
          "character": "四文堂、四上手、旗牌",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}