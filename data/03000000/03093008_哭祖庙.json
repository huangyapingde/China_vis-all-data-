{
  "script_id": "03093008",
  "title": "哭祖庙",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘谌",
      "hangdang": "老生"
    },
    {
      "name": "刘禅",
      "hangdang": "老生"
    },
    {
      "name": "崔夫人",
      "hangdang": "正旦"
    },
    {
      "name": "黄皓",
      "hangdang": "丑"
    }
  ],
  "plot": "邓艾暗渡阴平后，直逼成都。刘禅欲迎降，刘禅子刘谌苦谏不听。刘谌痛国破家亡，遂杀妻及三子哭告于太\n庙，亦自刎死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，刘谌骑马上。门官上，跪迎。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "启禀千岁：今有邓艾，围困都城，圣上明日就要开城投降，特来报知。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "知道了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官下。"
        },
        {
          "character": "刘谌",
          "type": "念",
          "text": "凤子龙孙须尽忠，孝当竭力祖光荣。腰挎龙泉诛奸佞，夜做龙吟虎啸声。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "本爵，北地王刘谌。打从校场回府，门官报道：邓艾贼子暗渡阴平，围困都城， 父皇听信谯周、黄皓之言，明日就要开城纳降！国家存亡，只在今日，势已 危急，亡在旦夕，我不免进宫谏阻。两厢退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。"
        },
        {
          "character": "刘谌",
          "type": "唱",
          "text": "邓艾暗中渡阴平， 重兵围困我都城。 进宫劝谏奏一本， 背城一战退贼兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "西皮散板",
          "text": "暗渡阴平困都城， 吓得孤王胆战惊。 黄皓去把神师请， 为何不见到宫廷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄皓上。"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "叩见万岁！神师请到，宫门候旨。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "有请神师！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫附神上，刘禅起，让女巫坐。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "我乃西川土神是也！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "参见上神！"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "请来吾神，为了何事？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "只因邓艾暗渡阴平，袭了绵竹，围困都城，满朝文武降战不一。是孤毫无主见， 请上神下界，赐一明示。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "依吾神之见，若肯投降，管保你天下太平。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "谨遵上神之命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫做醒。"
        },
        {
          "character": "女巫",
          "type": "白",
          "text": "哎呀，原来圣驾在此！参见万岁爷！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "罢了。 来！"
        },
        {
          "character": "黄皓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "赏她白银千两，送她出宫去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女巫、黄皓同出门，刘谌上，相遇，刘谌怒目视女巫、黄皓，女巫、黄皓同慌张下。"
        },
        {
          "character": "刘谌",
          "type": "西皮散板",
          "text": "父听女巫胡言论， 只怕江山难保存。 迈步且把金殿进， 父皇驾前把本呈。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "儿臣见驾，父皇万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "皇儿进宫，有何本奏？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "邓艾贼子兵困成都，父皇因何坐视不理？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "只因满朝文武议论纷纷，并无决策。孤想若动干戈，恐难取胜。不如投降，可 免生灵涂炭。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "自古以来，江山只有争斗，哪有禅让之理！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤也曾问过神师，还是投降的好！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "父皇莫信妖巫之言。想那邓艾，孤军入险，利在速战，如今只可固守成都，待 儿臣率领众将，背城一战，何愁敌人不灭！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "唗！动不动就要去战，胜了还好，若是败了，岂不送了你老子的性命嘛！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "父王啊！"
        },
        {
          "character": "刘谌",
          "type": "西皮散板",
          "text": "刘谌殿上把话论， 父皇在位仔细听。 巫婆之言何足信， 儿愿上阵退敌人！"
        },
        {
          "character": "刘禅",
          "type": "西皮散板",
          "text": "皇儿休得胡言论， 神师指引敢不遵！"
        },
        {
          "character": "刘谌",
          "type": "西皮散板",
          "text": "千言万语父不信， 倒做进退两难人。 走向前来忙跪定， 抱住父皇放悲声。"
        },
        {
          "character": "刘谌",
          "type": "西皮二六板",
          "text": "未曾开言泪难忍， 父皇听我把话明： 邓艾孤军把城困， 尽是谗臣哄圣君。 可叹姜维为国来效命， 累死英雄费尽心。 如今咱父子君臣背城一战战必胜， 杀他个片甲不回走无门。 非是儿臣抗君命， 祖宗的基业莫看轻！"
        },
        {
          "character": "刘禅",
          "type": "西皮散板",
          "text": "为父心意业已定， 午时三刻便开城。"
        },
        {
          "character": "刘谌",
          "type": "西皮散板",
          "text": "堂堂天子坐龙庭， 为何甘当亡国君？ 此事留与后世论， 辱骂父皇是无道人！"
        },
        {
          "character": "刘禅",
          "type": "西皮散板",
          "text": "奴才出言敢不逊， 竟然金殿来欺君。 恨不得一足要儿的命， 不杀你念在父子情！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "父皇啊！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "不必多言，出宫去吧！"
        },
        {
          "character": "刘谌",
          "type": "西皮散板",
          "text": "父皇不听儿奏本， 一足踢我出宫门。 国破家亡心何忍？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "先祖哇！罢！"
        },
        {
          "character": "刘谌",
          "type": "西皮散板",
          "text": "回府去杀妻儿然后杀身！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌下。"
        },
        {
          "character": "刘禅",
          "type": "西皮散板",
          "text": "神师与孤安排定， 投魏之后享太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅、四太监同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "董敏带二王子同上。"
        },
        {
          "character": "董敏",
          "type": "唱",
          "text": "自幼净身入宫院， 侍奉先王有数年。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "咱家，董敏。领着二位殿下御花园游玩，天气不早，回宫去者！"
        },
        {
          "character": "董敏",
          "type": "唱",
          "text": "手领世子忙回转， 但愿国家早平安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏、二王子同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人抱婴孩上。"
        },
        {
          "character": "崔夫人",
          "type": "二黄慢三眼板",
          "text": "恨贼人困成都十分危险， 一旦间国事衰黎民不安。 我夫王领人马校场操练， 为什么这时候不见回还！"
        },
        {
          "character": "刘谌",
          "type": "内二黄导板",
          "text": "怒冲冲离了皇宫院，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌上。"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "不由本爵咬牙关。 未曾进宫先拔剑，"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "王爷！"
        },
        {
          "character": "刘谌",
          "type": "二黄摇板",
          "text": "这才是儿女情长英雄气短、我的两手酸！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "王爷呀，进得宫来，一语不发，为何仗剑就杀？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "妇道人家，不问也罢！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "王爷说哪里话来！有道是：国家有事，君臣商议；家中有事，夫妻商量。哪有 丈夫有事，妻子不问的道理！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "既是一定要问，对你实说了罢！只因邓艾兵困成都，父皇听信谗言，明日就要 开城投降，本爵欲殉国一死！"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "如此说来，妾请先死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人将婴孩放桌上。"
        },
        {
          "character": "崔夫人",
          "type": "唱",
          "text": "将娇儿放在御书案， 心中好似滚油煎。 人生百岁死难免， 恩爱夫妻不团圆。"
        },
        {
          "character": "崔夫人",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔夫人碰死。"
        },
        {
          "character": "刘谌",
          "type": "唱",
          "text": "一见夫人染黄泉， 点点珠泪洒胸前。 可叹你为夫殉国难， 夫人哪……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌割崔夫人头。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "剑斩三岁小儿男！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌杀婴孩。"
        },
        {
          "character": "刘谌",
          "type": "唱",
          "text": "手提人头出宫院，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏带二王子同上，与刘谌相遇。"
        },
        {
          "character": "刘谌",
          "type": "唱",
          "text": "一见二子眼睁圆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌拔剑砍二王子。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "哎呀王爷呀！为何一语不发，要杀二位殿下？"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "国破家亡，死了倒也干净！"
        },
        {
          "character": "二王子",
          "type": "同白",
          "text": "父王要杀孩儿，容我们见母一面哪！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "你们要见母一面么！儿来看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌手举人头，董敏、二王子同惊，同走圆场。刘谌杀王子甲。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "哎呀王爷呀！杀一位留一位，日后也好接续刘氏香烟！"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "好，出宫去吧！"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏拉起王子乙同急出门，刘谌赶上，杀王子乙。"
        },
        {
          "character": "董敏",
          "type": "白",
          "text": "国破家亡，二位殿下已死，咱家也撞死了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董敏碰死。"
        },
        {
          "character": "刘谌",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘谌",
          "type": "唱",
          "text": "好一个忠心董太监， 同殉国难美名传。 忙将人头齐割断，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌割人头。"
        },
        {
          "character": "刘谌",
          "type": "唱",
          "text": "祖庙之内祭祖先！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌提人头下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、黄皓、刘禅同上，同出城迎接，邓艾领四龙套同上。"
        },
        {
          "character": "邓艾",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓艾、四龙套同进城，同下。刘禅、四太监、黄皓同随进城，同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘谌提人头、持宝剑上，入祖庙。"
        },
        {
          "character": "刘谌",
          "type": "二黄导板",
          "text": "进祖庙不由人伤心凄惨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘谌插剑，做三次供四人头，拜，立起。"
        },
        {
          "character": "刘谌",
          "type": "三叫头",
          "text": "先祖，昭烈帝，皇祖哇……"
        },
        {
          "character": "刘谌",
          "type": "二黄回龙腔",
          "text": "将人头供神案祭奠祖先。"
        },
        {
          "character": "刘谌",
          "type": "反二黄三眼板",
          "text": "高皇祖手提着三尺宝剑， 灭强秦诛暴楚才定江山。 至孝平国运败王莽谋篡， 毒药酒鸩先帝龙驾归天。 光武帝走南阳迁都为东汉， 全仗着云台将二十八员。 传位到桓灵帝信用太监， 十常侍乱朝纲惹起狼烟。 吾皇祖灭黄巾威名振显， 宴桃园三结义牛马祭天。 遭不幸在徐州弟兄失散， 到后来在古城又得团圆。"
        },
        {
          "character": "刘谌",
          "type": "反二黄原板",
          "text": "走荆州依刘表重兴炎汉， 不料想蔡夫人为人不贤。 跳檀溪吾皇祖身遭大难， 水镜庄夤夜里得遇名贤。 隔墙壁皇祖爷龙耳听见， 他言道卧龙、凤雏得一人天下可安。 徐元直走马回把诸葛亮荐， 卧龙岗三顾请才得出山。 博望坡新野县两次大战， 火攻计烧曹兵魂胆皆寒。 携良民不忍抛来至长坂， 实可怜皇祖母丧在井泉。 好一个赵子龙他浑身皆胆， 百万军中七进七出救主还。 闯重围解铠甲低头来看， 那时节我父皇睡梦中昏昏沉沉到如今数十余年。 曹阿瞒领大兵八十三万， 玄武池练水军吞并江南。 东吴臣武将官都要征战， 文部官愿投降归顺中原。 鲁子敬过江来把诸葛亮见， 卧龙公一帆舟去往江南。 他也曾说群儒全凭舌战， 他也曾草船借箭在大雾之间。 他也曾借东风七星台上面， 他也曾赤壁鏖兵火烧战船。 得荆州气死那周郎命断， 张永年献地图才得西川。 报弟仇与东吴两下开战， 七百里烧连营火焰满天。 兵败在白帝城身逢大限，"
