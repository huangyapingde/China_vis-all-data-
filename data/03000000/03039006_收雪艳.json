          "type": "白",
          "text": "随我进来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成、莫怀古、雪艳同进。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老爷！"
