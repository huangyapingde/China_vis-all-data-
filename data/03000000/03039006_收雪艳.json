{
  "script_id": "03039006",
  "title": "收雪艳",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "莫怀古",
      "hangdang": "老生"
    },
    {
      "name": "雪艳",
      "hangdang": "旦"
    },
    {
      "name": "莫成",
      "hangdang": "老生"
    },
    {
      "name": "戚继光",
      "hangdang": "老生"
    }
  ],
  "plot": "雪艳原系宦门女，家遭兵变，误入勾栏。莫怀古见怜，赎为侧室。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番臣、四番将同上。〖点绛唇〗。"
        },
        {
          "character": "番臣甲",
          "type": "白",
          "text": "众位平章请了！"
        },
        {
          "character": "三番臣、四番将",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "番臣甲",
          "type": "白",
          "text": "我主传谕，齐集我等。不知有何军情。今日早朝，你我前去伺候。"
        },
        {
          "character": "三番臣、四番将",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵引柯蜜同上。"
        },
        {
          "character": "柯蜜",
          "type": "引子",
          "text": "生长土番，慕中华，山河堪羡。"
        },
        {
          "character": "柯蜜",
          "type": "念",
          "text": "地居偏僻意不舒，称孤道寡心弗足。常怀谋夺中华土，两国一统定王都。"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "某、土蛮国王柯蜜。生于边僻，常羡中华风景，每怀觊觎之心。如今孤兵强将 勇，正好兴师。 众卿，孤要夺取大明江山，众卿以为如何？"
        },
        {
          "character": "四番臣、四番将",
          "type": "同白",
          "text": "吾主欲夺取大明疆土，就该打去战表，约期会战。"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "言之有理。 启开文房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "番兵甲启文房，柯蜜修表。"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "就命卿等将此表下到中原，孤家择日兴师！"
        },
        {
          "character": "四番臣、四番将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "严嵩、张居正、徐贵宾、徐宁同上。〖点绛唇〗。"
        },
        {
          "character": "严嵩",
          "type": "白",
          "text": "严嵩。"
        },
        {
          "character": "张居正",
          "type": "白",
          "text": "张居正。"
        },
        {
          "character": "徐贵宾",
          "type": "白",
          "text": "徐贵宾。"
        },
        {
          "character": "徐宁",
          "type": "白",
          "text": "徐宁。"
        },
        {
          "character": "严嵩",
          "type": "白",
          "text": "众位大人请了！"
        },
        {
          "character": "张居正、徐贵宾、徐宁",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "严嵩",
          "type": "白",
          "text": "今有土蛮国柯蜜打来战表，要夺我主江山。万岁登殿，一同启奏。看香烟缭绕， 圣驾临朝，你我金殿伺候！"
        },
        {
          "character": "张居正、徐贵宾、徐宁",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引嘉靖同上。"
        },
        {
          "character": "嘉靖",
          "type": "引子",
          "text": "稳居龙楼，但愿得，寿享千秋。"
        },
        {
          "character": "严嵩、张居正、徐贵宾、徐宁",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严嵩、张居正、徐贵宾、徐宁同跪。"
        },
        {
          "character": "嘉靖",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "严嵩、张居正、徐贵宾、徐宁",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严嵩、张居正、徐贵宾、徐宁同起。"
        },
        {
          "character": "嘉靖",
          "type": "念",
          "text": "安居紫禁享天年，龙飞凤舞绕金銮。金井梧桐锁上苑，黄鹂声歌鸣君前。"
        },
        {
          "character": "嘉靖",
          "type": "白",
          "text": "孤、大明天子嘉靖在位。承先王基业，以继正统。诸英辅佐，武将用命，以致 狼烟尽息，方得太平景象。今临早朝。 众卿，有本早奏。"
        },
        {
          "character": "严嵩",
          "type": "白",
          "text": "臣启万岁：今有土蛮柯蜜国打来战表，要夺我主山河。请旨定夺！"
        },
        {
          "character": "嘉靖",
          "type": "白",
          "text": "将表呈上，待孤一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严嵩呈表，嘉靖观。"
        },
        {
          "character": "嘉靖",
          "type": "白",
          "text": "卿家，不知命何人前去征剿？"
        },
        {
          "character": "严嵩",
          "type": "白",
          "text": "臣启万岁：想那戚继光文韬武略，抱负不凡，足智多谋，颇有惊天动地之才。 命他前去征讨，必然一战成功。"
        },
        {
          "character": "嘉靖",
          "type": "白",
          "text": "依卿所奏。这有圣旨一道，就命戚继光前去征剿，得胜回来，另有升赏。领旨 下殿！"
        },
        {
          "character": "严嵩、张居正、徐贵宾、徐宁",
          "type": "同白",
          "text": "请驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八将官同上，同起霸。"
        },
        {
          "character": "将官甲",
          "type": "白",
          "text": "诸位将军请了！"
        },
        {
          "character": "七将官",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "将官甲",
          "type": "白",
          "text": "主帅升帐，两厢伺候！"
        },
        {
          "character": "七将官",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖发点〗。四龙套、四上手引戚继光同上。〖点绛唇〗。"
        },
        {
          "character": "八将官",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "八将官",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "戚继光",
          "type": "念",
          "text": "大将威风凛，临阵气吐云。虎穴何足惧，身先士卒兵！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "本帅、戚继光。今有土蛮国柯蜜兴兵犯境，是我奉了主上之命，前去征剿。 众将官！"
        },
        {
          "character": "八将官",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "八将官",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": "八将官",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、柯蜜同上。"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "孤、柯蜜。统领大兵，夺取明室天下。 众兵将！"
        },
        {
          "character": "四番兵、四番将",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "杀上前去！"
        },
        {
          "character": "四番兵、四番将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、柯蜜同走圆场。四龙套、四上手、八将官、戚继光同上，同会阵。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "马前来的敢是土蛮柯蜜？"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "然！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "我主未曾亏负尔等，无故兴兵，是何道理？"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "孤家夺取明室天下，你是何人，竟敢领兵阻路？"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "大将戚继光！"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "戚继光！孤家兴兵前来，你若归顺孤家，少不得封侯之位。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "一派胡言！杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光、柯蜜同起打。四番兵、四番将、柯蜜同败下，四龙套、四上手、八将官、戚继光同追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、柯蜜同上。"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "戚继光杀法骁勇。众兵将，速进山口！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、柯蜜同下。设碑碣。四龙套、四上手、八将官、戚继光同上。"
        },
        {
          "character": "四龙套、四上手、八将官",
          "type": "同白",
          "text": "贼兵败进山口。路旁现有碑碣。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光看，念。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "“此处无人到——诸葛武侯题”。 唔呼呀，前贤武侯，领兵到此。难道说我戚继光就不能南征？ 众将官！"
        },
        {
          "character": "四龙套、四上手、八将官",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "杀进山口！"
        },
        {
          "character": "四龙套、四上手、八将官",
          "type": "同白",
          "text": "山路崎岖，不能前进。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "身为武将，不入虎穴，焉得虎子？众将官，努力向前杀进山口！"
        },
        {
          "character": "四龙套、四上手、八将官",
          "type": "同白",
          "text": "啊！ （四龙套、四上手、八将官、戚继光同走圆场，四番兵、四番将、柯蜜同上，同起打。四番兵、四番将、柯 蜜同败下，四龙套、四上手、八将官、戚继光同追下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、柯蜜同上。"
        },
        {
          "character": "柯蜜",
          "type": "白",
          "text": "戚继光杀法骁勇，兵撤荒草泥塘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、四番将、柯蜜同下。四龙套、四上手、八将官、戚继光同上。"
        },
        {
          "character": "四龙套、四上手、八将官",
          "type": "同白",
          "text": "贼兵败进荒草泥塘。我兵实难前进。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光看。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "路旁又有碑碣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光念。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "“此处无人到。孤军轻入四十里——诸葛武侯题。” 哎呀武侯啊，你可算神人也！待我望碑一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光拜。"
        },
        {
          "character": "戚继光",
          "type": "白",
          "text": "荒草泥塘，我兵实不能前进。打了得胜鼓。奏凯还朝！"
        },
        {
          "character": "四龙套、四上手、八将官",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "引子",
          "text": "才华出众辈，经纶满腹中。"
        },
        {
          "character": "莫怀古",
          "type": "念",
          "text": "才高班马贯古今，生花妙笔论诗文。先父在朝为宰辅，钦赐翰林第二名。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "卑人、莫怀古。乃钱塘人氏。先父在世，曾为宰辅。配妻傅氏。所生一子，名 唤莫豪，现在学中攻读。今日只觉心头闷倦，不免去到外边游玩一番。 莫成哪里？"
        },
        {
          "character": "莫成",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成上。"
        },
        {
          "character": "莫成",
          "type": "念",
          "text": "常思程婴报主义，美名佳话万古提。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "参见主人！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "将小人唤出，有何吩咐？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "今日心头闷倦，欲到外面游玩一番。你在家中，不要远离。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "是。倘若有人来访，小人何处寻找？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "在勾栏院内寻找。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "想那勾栏院乃是杂乱之地，老爷如何去得？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "偶尔遣兴，有何不可。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "请老爷早去早回。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "知道了。你且退下。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成下。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "就此走走！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "残春绿柳风翻浪， 野花灿烂遍地香。 意懒心摇增触想， 穿花逐柳去寻芳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "严世蕃上。"
        },
        {
          "character": "严世蕃",
          "type": "引子",
          "text": "位列三台，君见我，喜笑颜开。"
        },
        {
          "character": "严世蕃",
          "type": "念",
          "text": "生成眉横一字，衬就两眼炯明。上殿君王害怕，父子武西文东。"
        },
        {
          "character": "严世蕃",
          "type": "白",
          "text": "老夫、严世蕃，字东楼。在嘉靖驾前为臣。我父官拜首相。某为兵部侍郎。嘉 靖爷与我同年同月同日同时生，只是不同刻。他有九五之尊，我还是小小的兵 部侍郎。这且不言，钱塘我有一好友，名叫莫怀古，与我两世故交。如今我父 子官居显爵；他还在家，困守田园。我不免修书一封，叫他进京补官。 来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官上。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "严世蕃",
          "type": "白",
          "text": "启开文房！"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官启文房，严世蕃修书。"
        },
        {
          "character": "严世蕃",
          "type": "白",
          "text": "唤旗牌来见！"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "旗牌来见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "兵部门下听传唤，出入朝臣第一家。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见大人！有何差遣？"
        },
        {
          "character": "严世蕃",
          "type": "白",
          "text": "这有书信一封，下到钱塘莫怀古那里，不得有误！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "严世蕃",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "严世蕃",
          "type": "念",
          "text": "但得一步地，何须不为人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严世蕃、门官同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鸨儿上。"
        },
        {
          "character": "鸨儿",
          "type": "念",
          "text": "终日缠头似锦，对镜铅华细匀。巧梳云鬓点绛唇，坐等公侯迎聘。 专蓄吴姬越女，迎送客旅经商。虽然不似家公馆，也算温柔之乡。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "我、鸨儿褚氏。在这钱塘县地方，开了一个窑子。这个买卖，倒是我祖辈传留 的旧业。今已传留十八辈儿。我又继承我母之业，生意颇称不坏。每日车马如 龙，踵接于门，十分拥挤。是我新近买了一个小姑娘，乃是宦门之女，读书识 字。只因她随父母逃反，父母被乱军所杀。她被歹人拐来卖给我啦。长得非常 标致。只是我叫她接客，她誓死不从。我有心打她几下，打轻了吧，她不怕： 打重了，又怕她寻死，我落个人财两空。今天我起了个早儿，游客还没来哪。 我把她叫出来，问问她，是打着什么主意。 雪艳哪，快来！"
        },
        {
          "character": "雪艳",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳上。"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "叹命薄遭不幸身落妓馆， 昼夜间泪潜流眉锁春山。 但不知何日里脱离魔难？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "快来呀！"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "听呼唤不由我胆怯心寒。 心忐忑意彷徨实是懒见， 换笑脸展愁眉裣衽问安。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "参见妈妈！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "罢啦。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "妈妈，将我唤了出来，有何吩咐？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "你到我这儿日子也不少啦，连吃带穿，铺盖褥子，你说我在你身上花了多少钱 的本钱吧？我一叫你迎宾接客，你就誓死不从。我有心打你几下吧，我又疼的 慌——我虽说是开窑子的，可与别人不同，我这人是心慈面善，不然，我这营 业也不能流传十八辈儿。你得想个主意，别叫我赔钱哪！"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "妈妈，想我乃是良家儿女、宦门之后，世代书香，岂可将我祖上清白家声败坏？ 想这皮肉生涯，实难从命。除此而外，无不听从妈妈教导。望求妈妈多施恻 隐，开方便之门，拯救难女于水火之中，做福积德，好保妈妈旧业。漫说我死 去的父母；就是难女，也感恩非浅！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "对呀，我积点儿德，好保佑我祖祖辈辈开窑子。你说除了这一样，什么都行？"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "无一不从。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "那么叫你抬煤去？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳摇头。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "不行吧。那么叫你拉车去？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳摇头。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "又不行吧。你呀，好比这么一坛子没打封的醋——早晚也得打封，你为什么不 早点儿打？大家都痛快！你要是等我楞给你扯开，那可就没有面子啦！"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "听她言不由奴心惊胆战， 大谅我不能够逃出勾栏。 自幼儿在闺中习学经典， 怎能够败家风辱没祖先？ 到如今无法解风尘魔难， 这也是命里造就难怨老天。 默无言暗沉吟心内盘算， 想良策好出这苦海深渊。 秉节操在教坊抛去腼腆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳想。"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "卖颜面不卖身暂且从权。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "哎呀且住！想我身落勾栏，怎能逃出虎口？不免对她说明：只能陪酒，不能伴 宿。如遇乐善好施之人，将奴救出苦海，也未可知。 啊妈妈，要我依从，却也不难，我只能陪酒，不能伴宿。若能依得，方可应允； 如不依我，纵然一死，也不从命。遇有良善之人，还望妈妈许我自行择配！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "孩子，只要陪酒就行啦。难道说你不愿卖身，我还非叫你做这个缺德事不可吗？ 只要有人与你赎身，不叫我赔钱，你就走。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "多谢妈妈！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "不用谢啦。你去换换衣裳伺候着。要有好客，我就叫你。要是戛杂子、琉璃球 来了，咱们不见。你歇着去吧！"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "可叹我命运乖遭此恹蹇， 只落得宦门女身坠勾栏。 叹红颜多薄命增人凄怨， 但愿那苦海中早现青莲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳下。"
        },
        {
          "character": "鸨儿",
          "type": "唱",
          "text": "只见她锁双眉粉面惨淡， 受这些风尘苦确也堪怜。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "看她这个样儿，也怪可怜的。倘有人看上了她，只要不叫我赔钱，我叫她跟人 走，那不也是行好吗？哟！天不早啦，该叫孩子们起来洗脸啦。 头子快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "忘八上。"
        },
        {
          "character": "忘八",
          "type": "念",
          "text": "当头带扛叉，长把茶叶抓。脖子长脑袋，绰号叫忘八。"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "老板嘛事？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "嘛事，你怎么这时候才起呀？你昨儿晚上干什么来着，怎么睡不醒啦？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "昨儿晚上我不是在你床上——"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "给你捶腿来着吗！我不困哪？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "你要是贪睡，咱们这个买卖可就不用做啦！"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "有嘛事，你说啊！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "你看天什么时候啦？该叫孩子们起来洗脸，伺候着啊！"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "是。我喊叫一声。 姑娘们哪，该起啦！"
        },
        {
          "character": "忘八",
          "type": "念",
          "text": "漱口搭洗脸，先把住客赶。随后就开饭，送旧迎新鲜。"
        },
        {
          "character": "众妓女",
          "type": "内同白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古上。"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "闷无聊到勾栏解烦消遣， 见一家花名牌挂在门前。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "院主哪里？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "莫老爷，您来啦？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "哟！莫老爷，您有一年多没上我们这儿来啦。今儿个您怎么这么高兴啊？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "偶尔遣兴，信步而游，不觉就到这里来了。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "我说我昨儿晚上作了好梦了哪！叫孩子们来见见吧！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "不要唤她们。我坐坐就走。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "叫她们陪着您玩会儿吧。叫她们来！"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "是啦。 孩子们，见客啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众妓女同上，同见莫怀古。"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "嫒媛，红春，艳芳，翠绿。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "叫哪个伺候您？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "都不堪入目。我要告辞了。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "您别走，我这儿有一个姑娘，是个宦门之后，我叫她来陪您。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "好，唤她前来。"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "那行吗？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "我跟她说好啦。"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "雪艳姑娘快来呀！"
        },
        {
          "character": "雪艳",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳上。"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "辜负了父母亲劬劳恩典， 生下我薄命女身遭沛颠。 无奈何迎宾客抛羞露面， 慢移步羞答答趦趄不前。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "孩子，见见莫老爷！"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "参见莫老爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳泣。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "只见她泪淋淋愁眉惨淡， 必是个良家女误入勾栏。 想世人理应当多施德善， 昧天理实可畏报应循还。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "您看这个怎么样啊？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "倒也不错。她叫何名？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "叫雪艳。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "噢，雪艳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古看雪艳，雪艳羞。"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "您这儿来！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "干什么？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "您没看见莫老爷很喜欢她吗？咱们躲躲，叫他俩痛痛快快地说两句，倘若爱上 她，咱们就来了财啦。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "对呀！ 孩子，你陪莫老爷这儿坐着，我给你们沏茶去。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "妈妈你不要走！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "不要紧！他是规矩人。"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "别说啦，走吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "忘八下。鸨儿对雪艳。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "走啦。你好好伺候着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸨儿下。莫怀古看雪艳，雪艳羞，擦泪。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "雪艳，我看你眉锁春山，芙蓉惨淡，面带泪痕，必是误落烟花。有什么委屈之 事，对我言讲，若能效力，也好救你脱离苦海。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "老爷不嫌耳烦，听我薄命之人一言告禀！"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "奴本是书香后父为官宦， 因年迈辞士禄归隐家园。 遭不幸偶遇那贼兵变乱， 我一家逃性命远奔关山。 叹父母遭杀害死别分散， 被歹人拐卖我误落勾栏。 望老爷拯救我脱离此难， 奴情愿供使唤婢妾相甘。"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "你本是良家女误入妓馆， 触起我怜香意惜玉心田。 我收你作妾室——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳羞。"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "你可情愿？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "我救你脱离乐籍，逃出苦海，纳你以为侧室，你可愿否？"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "这！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你可愿否？"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "你可愿否？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雪艳不语。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "愿意与否，请道其详啊！"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "老爷呀！"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "救奴家出苦海恩重如山。 保清白全家声不辱乡宦， 我情愿侍奉你——"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "床笫之间。"
        },
        {
          "character": "莫怀古",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "一句话说得我心花开展， 用千金救你出苦海波澜。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "好好好，待我救你出去，唤鸨儿前来。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "是。 妈妈快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸨儿、忘八同上。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "什么事？"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "莫老爷唤你。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "我瞧瞧去。 莫老爷，您叫我有什么事呀？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "我看雪艳，清白之身，不宜久在烟花。我有心替她赎身，不知身价银子多少？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "您要替她赎身哪？要是别人，我得多要钱；您要是讨她，您看着给就得啦。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "我付你一千两银子如何？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "还讲什么多少啊？我谢谢您吧！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "不用谢了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成上。"
        },
        {
          "character": "莫成",
          "type": "唱",
          "text": "残春闷人难消遣， 赏心乐事久留连。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "哪位？"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "是我呀！"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "莫掌家什么事？"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "我家主人可在这里？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "不错，在这儿哪。您进来吧！"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成进。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "参见老爷！"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "罢了。你做什么来了？"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "奉了我家夫人之命，请老爷回去用饭。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "这就是了。 雪艳，随我回去。"
        },
        {
          "character": "雪艳",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "莫成，明日与他们这一千两银子过来。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "几时送来都行，忙什么？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "我们告辞了。"
        },
        {
          "character": "忘八、鸨儿",
          "type": "同白",
          "text": "不远送啦。"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "喜笑颜开出妓馆，"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "多谢厚待恩义宽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古、雪艳、莫成同下。"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "人可是走啦，明天钱可别来不了啊！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "钱塘谁不知道莫老爷呀！家里有的是钱，人家还在乎这点儿钱！哪能像你这个 穷小子啊？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "您这是嘛话呀？我要不穷，每天晚上怪累的慌的，还伺候你吗？"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "你这个累的慌，怎么总在晚上哪？"
        },
        {
          "character": "忘八",
          "type": "白",
          "text": "我不是老在晚上给你捶腿吗！"
        },
        {
          "character": "鸨儿",
          "type": "白",
          "text": "别挨骂啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鸨儿、忘八同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "傅氏上。"
        },
        {
          "character": "傅氏",
          "type": "唱",
          "text": "艳阳天春光好良辰美景， 满院中百花开芳香袭人。 我夫妻琴瑟调儿知孝敬， 胜似那登仕路一品朝臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成、莫怀古、雪艳同上。"
        },
        {
          "character": "莫怀古",
          "type": "唱",
          "text": "一片心我将你救出陷阱，"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "怜惜奴苦命人感君盛情。"
        },
        {
          "character": "莫成",
          "type": "唱",
          "text": "我老爷性侠义扶危救困，"
