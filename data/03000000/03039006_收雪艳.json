        {
          "character": "莫怀古",
          "type": "白",
          "text": "你们回避了。"
        },
        {
          "character": "傅氏、雪艳",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "儿呀，随娘来呀！"
        },
