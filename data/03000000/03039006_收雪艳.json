          "text": "严爷所差。有书信呈上。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "呈上来。 莫成，领到书房款待。"
        },
        {
          "character": "莫成",
          "type": "白",
          "text": "是。 随我来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫成领旗牌同下。"
        },
        {
          "character": "莫怀古",
          "type": "白",
