        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老爷，这是何人？"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "她名雪艳，乃是良家女子，只因父母已死，被歹人拐卖，误落烟花，虽在勾栏， 仍为处女，每日被鸨母逼迫，实为可怜。我将她救回家来，为婢为妾，听从 夫人的——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莫怀古笑。"
        },
        {
          "character": "莫怀古",
          "type": "白",
          "text": "吩咐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅氏笑。"
        },
        {
          "character": "傅氏",
          "type": "白",
          "text": "老爷救人于水火之中，乃是大大的功德。若令其为婢，岂不有负于她？老爷就 纳为侧室，有何不可？"
        },
        {
          "character": "莫怀古",
          "type": "白",
