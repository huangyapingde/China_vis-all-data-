        {
          "character": "傅氏",
          "type": "唱",
          "text": "叫贤妹快请起免礼平身。 来来来随愚姐并肩坐定，"
        },
        {
          "character": "雪艳",
          "type": "唱",
          "text": "奴这里谢老爷再谢夫人。"
        },
        {
          "character": "莫怀古",
          "type": "白",
