{
  "script_id": "03054004",
  "title": "水镜庄",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "司马徽",
      "hangdang": "老生"
    },
    {
      "name": "徐庶",
      "hangdang": "老生"
    },
    {
      "name": "刘表",
      "hangdang": "老生"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    }
  ],
  "plot": "刘备马过潭溪，路遇牧童，拜谒水镜先生。次日，赵云觅至，迎归新野。刘备遣孙乾致书刘表，说明蔡瑁意\n欲加害。刘表大怒，拟斩蔡瑁，因孙乾求情始免。刘表即派刘琦往新野谢罪。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内唱",
          "text": "马跳潭溪受危困，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "紧抖丝缰往前行。 似醉如痴心思忖， 千层浪里又复生。 过溪犹如在睡梦， 波翻浪阔过溪滨。 今日不亏这匹马， 难免身遭蔡瑁擒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤，刘备。也是我命不该绝，如此阔溪，马竟一跃而过。但一时不能奔回新野， 如何是好？咳，少不得信马而行。唉，看天色将晚，日已西沉，远远望见一 个小小牧童，跨在牛背之上，口吹短笛而来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牧童上，吹笛。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咳，我刘某东奔西驰，反不如这牧童逍遥快乐。待我勒马观之。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牧童观看刘备。"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "啊将军，莫非是大破黄巾的玄德公吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备楞。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，莫非我又逢绝地也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "定是蔡瑁安排定， 此处又有埋伏兵。 不然怎知我名姓， 叫人难猜其中情。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "待我向前将他问， 便知其中就里情。 勒马近前把话论， 开言叫声小牧童： 小小年纪在村野， 怎能知道我姓名？"
        },
        {
          "character": "牧童",
          "type": "唱",
          "text": "将军不必心着慌， 且听牧童说端详： 常听师傅对我讲， 大破黄巾姓名扬。 相貌生来君王相， 身高七尺精神强。 当今皇叔人尊仰， 汉室宗亲四海扬。 今看将军这模样， 想起当初事一桩。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请问令师姓甚名谁？"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "我师傅复姓司马名徽字德操，道号水镜先生，颍州人氏。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，令师与何人为友？"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "我师傅与襄阳庞德公、庞统为友。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "庞德公是庞统何人？"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "乃是叔侄。庞德公字山民，长俺师傅十岁。庞统字士元，小俺师傅五岁。那一 天我师傅树上采桑，偶遇庞统前来相访，坐在树下，共相议论，终日不倦。我 师傅甚是爱他，因呼庞统为弟。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请问牧童，令师今在何处？"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "将军你看前面树林之中，有一庄院，就是我师傅居住的所在。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "烦你引我前去，我正要拜访，"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "如此，将军随我来呀！"
        },
        {
          "character": "牧童",
          "type": "唱",
          "text": "待我牵牛把路引，"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "玄德今要访高人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牧童、刘备同走小圆场。"
        },
        {
          "character": "牧童",
          "type": "唱",
          "text": "尊声将军且站定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "幕后抚琴声。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "忽听里面有琴音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马徽上。"
        },
        {
          "character": "司马徽",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "琴韵清幽音中起， 必有英雄暗窃听。 出得门来用目睁，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马徽四下看。"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "我师傅来啦！"
        },
        {
          "character": "牧童",
          "type": "唱",
          "text": "水镜先生出柴门。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "我见此人非凡品， 松形鹤骨有仙根。 走向前来礼恭敬，"
        },
        {
          "character": "司马徽",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公啊！"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "今日大难已脱身。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "听他言来眼发愣， 他怎知我腹内情？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "水镜先生，备这里奉揖了！"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "有礼相还。明公今日得免大难，皆赖坐骑之功。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备背供。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我经大难，他何以知之？"
        },
        {
          "character": "牧童",
          "type": "白",
          "text": "这位将军就是师傅素日常提的刘皇叔。"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "哦，有失迎接，多有得罪。请驾屈入寒舍待茶，叙叙素日渴望之殷。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "多承先生见爱。"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请！"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公请坐！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牧童献茶。"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公请茶！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请！"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，我刘备偶至贵地，多承令徒指教。今朝见面，真乃是三生有幸。"
        },
        {
          "character": "司马徽",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "尊公今朝灾消难满。从今以后，步步登高，重整事业，大称其心。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生果然高明。襄阳赴会，蔡瑁暗设机关害我。多亏伊籍先生泄机，才得马跳 潭溪，险些丧于水内。不想巧遇令徒，故尔前来拜访。"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公被难，我一一尽知。但不知今居何职？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生啊！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "现在新野威声震， 宜城亭侯左将军。"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "久已闻名少亲近， 冢宰之职可称心？ 因何不寻存身地， 奔走流落为何情？"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "先生既然殷勤问， 听我刘备说分明： 命小福薄难称意， 运未通来怎能行！"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "明公说话见聪明， 有个缘故在其中。 皆因无有人辅佐， 焉能创立事业兴！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "手下之人却甚众， 又有孙乾同简雍。 糜竺、糜芳人忠正， 赵云可称将英雄。 关、张二人也英勇， 桃园结义二弟兄。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，这些人倾心吐胆辅佐于我，奈我命运不通！"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公不是这样讲法。关、张、赵云，虽是万人之敌，却非权变之才；简雍不过 白面书生，章句小儒，岂是经纶济世之人哉！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呀！备欲求高贤，奈因未遇其人耳！"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "古人云：识时务者方为俊杰。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请问先生，何等人物才是俊杰？我刘备倒要领教领教。"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公，俊杰人物古今皆有哇！"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "若论起这俊杰古今钦敬， 却往往成事业各有相同。 在周朝有吕望汤室伊尹， 在齐国有管仲大显才能。 在越国有范蠡功成退隐， 在西楚有范增韬略颇精。 汉高祖驾下有治国将相， 张子房小韩信萧何三卿。 光武爷驾前的军师邓禹， 这些人可称得杰俊豪英。 此等人得一位可谓侥幸， 建帝基成伟业千秋留名。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "此前朝俊人物哪里去请？ 有一人扶刘备方称我心。"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "古人云十室邑必有忠信， 天下人到处有奇才高明。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "最可恨备肉眼不曾识认， 不晓得当今世俊杰何人？ 备惟愿领高教将我指引， 顿开了备茅塞感你深恩。"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "我这里闻此言暗自高兴， 尊一声玄德公贵耳细听： 近年来荆襄的刘表不正， 听后妻废长子却欠聪明。 叹景升寿不久将归海境， 那天命自然是归于明公。 这如今世奇才倒有两位， 一凤雏一卧龙都有奇能。 玄德公如能够亲自聘请， 我保你汉基业重又复兴。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "这凤雏与卧龙何地居隐？ 望先生快与备细讲分明。"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "此时间日坠落黄昏时分， 暂安歇明日里再诉衷情。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "备今晚多打搅欠身从命，"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "叫小童摆水酒以待嘉宾。 玄德公请相随草厅坐定，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "莫性急自有我与你调停。"
        },
        {
          "character": "刘备、司马徽",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "明公请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马徽、刘备同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。童儿上，打扫房，下。〖小吹打〗。童儿执灯引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "听庄中打罢了三更时分， 汉刘备思想起坐卧不宁。 那水镜半吐言不肯指引， 有凤雏和卧龙又不说明。 想起了赵子龙吉凶未定， 新野县二兄弟未知信音。 夜静深好叫我心中烦闷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿出门，倒带门，下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "今夜晚守孤灯甚为惨情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备睡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "可笑那刘景升太也愚蠢， 他道我乃草芥无有才能。 因此上连夜里急赶路径， 不觉得来到了司马家门。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "童子，开门来！"
        },
        {
          "character": "童儿",
          "type": "内白",
          "text": "来啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿上。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "是哪一位？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "是我来了。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "哦，待我开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿开门。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "请进！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "你师傅可曾安歇？"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "未曾安歇！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请你师傅前来，说我来了。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "是。 有请师傅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿下。司马徽上。"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "哦，原来是元直！这夜静更深，从何而来？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "小弟从荆州而来。"
        },
        {
          "character": "司马徽",
          "type": "白",
          "text": "你到那里，有何贵干？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "只为“功名”二字，始终不得称心，小弟才往荆州而去呀！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "进取功名心忒盛， 投奔荆州刘景升。 藐视小弟如草芥， 留一小柬不辞行。 许久未见兄长面， 特来到此叙离情。"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "贤弟行事忒急性， 投主不辨假和真。 汉室将倾无人整， 龙蛇混杂不安宁。 贤弟胸怀忠义胆， 待时而动显俊英。 景升虽然承天运， 蔡瑁专权是小人。 岂肯容你把身稳， 往返徒劳走一程。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "仁兄之言弟遵命， 承蒙指教我知闻。"
        },
        {
          "character": "司马徽",
          "type": "唱",
          "text": "贤弟随兄去安寝， 抵足而眠共谈心。"
        },
        {
          "character": "司马徽",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶、司马徽同下。"
