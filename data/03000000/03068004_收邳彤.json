{
  "script_id": "03068004",
  "title": "收邳彤",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "王莽",
      "hangdang": "老生"
    },
    {
      "name": "邳彤",
      "hangdang": "生"
    },
    {
      "name": "刘秀",
      "hangdang": "小生"
    },
    {
      "name": "邓禹",
      "hangdang": "老生"
    },
    {
      "name": "姚期",
      "hangdang": "净"
    },
    {
      "name": "马武",
      "hangdang": "净"
    },
    {
      "name": "岑彭",
      "hangdang": "武生"
    }
  ],
  "plot": "巨毋霸死后，王莽遣邳彤拒刘秀。不意邳彤降刘秀。王莽情急，遂携玉玺隐藏白蟒台。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引巨毋霸、丽花公主同上。"
        },
        {
          "character": "巨毋霸",
          "type": "念",
          "text": "家住蓬莱靠海滨，身长力大貌惊人。"
        },
        {
          "character": "丽花公主",
          "type": "念",
          "text": "全凭聚兽铜牌妙，今日出兵助新君。"
        },
        {
          "character": "巨毋霸、丽花公主",
          "type": "同白",
          "text": "某、（巨毋霸）（丽花公主）。"
        },
        {
          "character": "巨毋霸",
          "type": "白",
          "text": "只因王寻被汉军杀得大败，莽主有旨，请我夫妻前去助阵，灭却妖人刘秀。 众兵丁，起兵前往！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巨毋霸以刀敲聚兽牌，亮相，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "王寻",
          "type": "内西皮导板",
          "text": "汉营兵将杀法妙，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乱锤。王寻上。"
        },
        {
          "character": "王寻",
          "type": "唱",
          "text": "杀得儿郎四散逃。 岑彭、马武不得了， 救兵不到要糟糕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！巨毋霸救兵已到。"
        },
        {
          "character": "王寻",
          "type": "白",
          "text": "快快有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。四龙套引巨毋霸、丽花公主同上，同进门，巨毋霸坐。"
        },
        {
          "character": "王寻",
          "type": "白",
          "text": "哎呀将军哪！汉兵将我围得水泄不通，粮草已尽。你再若不来，不用说战，饿 也就把我饿死了！"
        },
        {
          "character": "巨毋霸",
          "type": "白",
          "text": "将军但放宽心，待某出兵，管叫汉军全军俱没！"
        },
        {
          "character": "王寻",
          "type": "白",
          "text": "全仗将军！"
        },
        {
          "character": "巨毋霸",
          "type": "白",
          "text": "众兵丁，带马阵前去者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四马童、四上手、岑彭、马武同上。〖点绛唇〗。"
        },
        {
          "character": "岑彭",
          "type": "念",
          "text": "身穿铠甲透玲珑，跨下走兽快如风。我主白水曾起义，恢复汉室锦江洪。"
        },
        {
          "character": "岑彭、马武",
          "type": "同白",
          "text": "俺、（岑彭）（马武）。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "将军请了！"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "只因王寻搬来了长人巨毋霸前来助阵，你我奉了军师将令，前去攻打。请问将 军怎样破敌？"
        },
        {
          "character": "马武",
          "type": "白",
          "text": "依某之见，将军前去骂阵，某家断贼后路，两地夹攻，一鼓而擒。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "将军言之有理。 众将官，就此分兵前往！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖急急风〗。巨毋霸、丽花公主、四龙套、岑彭、四马童同上，二龙出水，会阵。岑彭、四马童同败下，"
        },
        {
          "character": null,
          "type": "text",
          "text": "巨毋霸、丽花公主、四龙套同追下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、马武同上，站门。岑彭上，巨毋霸上，起打，巨毋霸败下，马武追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "巨毋霸、丽花公主、四龙套同上，同挖门。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "汉兵来得厉害，如何是好？"
        },
        {
          "character": "巨毋霸",
          "type": "白",
          "text": "聚兽铜牌拿他便了！ （岑彭、马武、四马童、四上手同上，同开打，岑彭、马武、四马童、四上手同败下，巨毋霸、丽花公主、 四龙套同追下。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴汉、姚期同上，同站门。四马童、岑彭、马武同上。"
        },
        {
          "character": "岑彭",
          "type": "白",
          "text": "妖人巨毋霸来得厉害。"
        },
        {
          "character": "姚期",
          "type": "白",
          "text": "火攻擒他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巨毋霸、丽花公主、四龙套同上，火彩，巨毋霸被烧死，众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "纽丝。臧洪上。"
        },
        {
          "character": "臧洪",
          "type": "唱",
          "text": "大将王寻丧了命， 巨毋霸一命丧残生。 宫门叩谒军情紧， 为此进宫奏明君。"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "来此宫门，待我叩环。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王洪上。"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "禁漏已深，何人叩环？"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "烦劳公公启奏：臧洪有紧急军情面奏龙颜。"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "候着。 有请万岁爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监引王莽同上。"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "启禀万岁：臧洪进宫有紧要军情面奏。"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "宣他进宫。"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "万岁有旨：宣臧洪进宫啊！"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "臣、臧洪见驾，吾皇万岁！"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "卿家夤夜进宫，有何要事？"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "启奏万岁：适才接得廉丹飞报，巨毋霸误中火攻之计，丧命阵前；王寻全军尽 没；刘秀人马杀奔长安来了！"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "啊，不好了！"
        },
        {
          "character": "王莽",
          "type": "唱",
          "text": "孤王闻言心内惊， 看来刘氏要重兴。 心腹良将俱丧尽， 事到危急谁能退贼兵？ 低下头来暗思忖，"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "有了！"
        },
        {
          "character": "王莽",
          "type": "唱",
          "text": "倒不如假托神道去叩天庭。"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "哎呀臧卿啊！王寻此败，乃朕之过也。想昔日成汤曾有七载荒旱，禹王也有洪 水之灾，周公摄政而管蔡挟武康以叛。今刘秀冒充汉裔，领兵作乱。自古圣王 尚且难免危难，今朕承天命受神禅，上荷天之宠眷，代汉以兴。量此小丑，何 足为论？若不遭此变乱，不能彰朕之德。待孤明日亲率文武恭谒南郊，告天求 示，将众将之名，均书表上，请示灭寇之人。卿家替孤传旨，晓谕文武：明日 清晨在南郊预备郊天仪礼，天色不早，出宫去吧。"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "臧洪下。"
        },
        {
          "character": "王莽",
          "type": "唱",
          "text": "假托神命遣兵将， 管叫刘秀一命亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "臧洪、万修、邳彤、四文朝官、四武朝官同上。〖点绛唇〗。"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "列位大人请了！"
        },
        {
          "character": "万修、邳彤、四文朝官、四武朝官",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "臧洪",
          "type": "白",
          "text": "今有圣上郊天求示，你我在此伺候！"
        },
        {
          "character": "万修、邳彤、四文朝官、四武朝官",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖朝天子〗。四太监、四大铠、常福、常寿、王洪、王禄、二赞礼官引王莽同上。"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "维、新朝嗣天子臣莽，秋八月癸未朔，特昭告于上帝之前：臣既膺天命，恭代 汉刘，天人同应，昭然甚明。今因盗寇四起，妖氛扰乱，应派良将，以申天讨。 谨将众将之名敬列神前，祈天垂示。跪叩坛前！"
        },
        {
          "character": "王莽",
          "type": "唱",
          "text": "臣王莽奉馨香恭谨奏上， 受天眷膺符命叩求上苍。 受神禅代汉室天人应响， 承金匮领万民坐镇朝纲。 刘秀等乱中原无端狂妄， 求默佑示名将共保家邦。 拜尘埃苦哀告叩求显相，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王莽抽签。"
        },
        {
          "character": "王莽",
          "type": "唱",
          "text": "解倒悬擎宇宙衽席安康。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王洪看签。"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "现承上苍垂示，抽出万修、邳彤二将。请我主龙目御览。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王洪呈签。"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "待孤看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王莽看签。"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "唔呼呀！果然上天垂示。 万、邳二卿！"
        },
        {
          "character": "万修、邳彤",
          "type": "同白",
          "text": "臣！"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "既承上天默佑，二卿此番出兵，非比往日，孤的江山存亡，全仗二卿一战也。"
        },
        {
          "character": "万修、邳彤",
          "type": "同白",
          "text": "万岁但放宽心。一来上天指示，二来我主洪福，若不扫除妖人，誓不见陛下也！"
        },
        {
          "character": "王莽",
          "type": "白",
          "text": "二卿真乃忠义之臣。明日点齐人马，孤王亲自饯行。"
        },
        {
          "character": "万修、邳彤",
          "type": "同白",
          "text": "臣等不敢。"
        },
        {
          "character": "万修、邳彤、四文朝官、四武朝官",
          "type": "同白",
          "text": "请驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、刘秀、邓禹同上。"
        },
        {
          "character": "刘秀",
          "type": "唱",
          "text": "白水起义军威振， 要复汉室锦乾坤。 将身且把宝帐进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岑彭、马武、姚期、吴汉同上。"
        },
        {
          "character": "岑彭、马武、姚期、吴汉",
          "type": "同唱",
          "text": "见了主公报好音。"
        },
        {
          "character": "岑彭、马武、姚期、吴汉",
          "type": "同白",
          "text": "启禀主公：我等杀死王寻，灭了巨毋霸，特来交令。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "众将之功也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！王莽又差万修、邳彤领兵前来。特此报知。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "先生，此二将何许人也？"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "万修乃是无谋之辈，何足为患！惟有邳彤智勇双全，若得归顺主公，王莽可擒 也。"
        },
        {
          "character": "刘秀",
          "type": "白",
          "text": "就请先生传令。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "吴汉、姚期听令！"
        },
        {
          "character": "吴汉、姚期",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "命你二人带领人马，攻打头阵，本帅随后接应。"
        },
        {
          "character": "吴汉、姚期",
          "type": "同白",
          "text": "得令！带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴汉、姚期同下。"
        },
        {
          "character": "邓禹",
          "type": "白",
          "text": "众将官，迎敌去者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
