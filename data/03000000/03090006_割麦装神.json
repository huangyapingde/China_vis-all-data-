        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启都督：四轮车上端坐孔明。前后多少天兵天将，披发仗剑，杀到我营来了！ 请令定夺！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "啊！俱是天兵天将，披发仗剑，护着孔明，杀进我营来了？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "嗯！这是孔明兴妖作怪。岂有天兵天将下界之理！ 众将官！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "一齐出营，连人带马与我抢回。不要放走孔明！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "哎呀元帅呀！那些护车天将，形容古怪。慢说兵丁前去，就是都督出营，也要 吓得失魂。快快逃走，可保性命！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "胡说！下去！"
        },
