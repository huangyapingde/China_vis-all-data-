{
  "script_id": "03090006",
  "title": "割麦装神",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "司马懿",
      "hangdang": "净"
    }
  ],
  "plot": "诸葛亮与司马懿会战于祁山，诸葛亮军缺粮，欲抢割陇上之麦以充军用，不料司马懿早有防备，遂使部下兵\n将伪扮天兵天将，并在军中觅与与己面貌相似者，乔装坐车上以惑魏军。司马懿果中计，不敢交战。陇上之\n小麦尽为蜀军抢割。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "撤兵增灶，败司马，乘胜还朝。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "奉命伐曹魏，钦承御诏回。天若遂人愿，汉室一统归。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫，诸葛亮。北伐中原，奉命还朝。兵撤祁山，增灶而退。可恨司马懿带兵 随后追赶。曾命姜维等前去截杀，料可获胜。且候回令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、魏延、马岱、关兴、王平、姜维同上。"
        },
        {
          "character": "姜维、魏延、马岱、关兴、王平",
          "type": "同白",
          "text": "末将等交令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "姜维、魏延、马岱、关兴、王平",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "胜负如何？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "司马懿败走。特来交令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "记上功劳簿。"
        },
        {
          "character": "姜维、魏延、马岱、关兴、王平",
          "type": "同白",
          "text": "谢丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "姜维、魏延、马岱、关兴、王平",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "兵回成都！"
        },
        {
          "character": "姜维、魏延、马岱、关兴、王平",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "引子",
          "text": "鼎峙三雄，灭吴魏，方成一统。"
        },
        {
          "character": "刘禅",
          "type": "念",
          "text": "蜀中立帝称王号，地利天时孙与曹。先君深得仁和义，南征北战半世劳。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤，刘禅。立帝成都。父王晏驾白帝城，众卿辅孤继位。只因诸葛丞相兵出祁 山，征伐中原。前者群臣奏道：“相父兵屯箕谷，有称帝之意。”曾下旨召他 全军回朝，未见交旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬、费袆同上。"
        },
        {
          "character": "蒋琬",
          "type": "念",
          "text": "丞相秉忠征曹魏，"
        },
        {
          "character": "费袆",
          "type": "念",
          "text": "主听谗言反召归。"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "启主公：诸葛丞相全军回朝，已在午门候旨。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "传朕旨意：宣丞相上殿。"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "领旨！ 主公有旨：“宣诸葛丞相上殿。”"
        },
        {
          "character": "诸葛亮",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "陛下万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "老相父平身。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮向蒋琬、费袆。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊二公！"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "启陛下：老臣兵出祁山，欲取长安。陛下忽然降诏，不知有何大事？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "这……啊，孤久不见相父之面，心甚思念，故召相父回朝。别无他事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此非陛下之心。必有奸臣谗陷，言臣有异志也！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "这、这、这……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唉！老臣受先帝厚恩，誓以死报。今若内有奸邪，老臣安能讨贼乎！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "这……嗐！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "相父言如金石星明月朗， 问得孤自沉吟满面惭惶。 父晏驾军国事全仗丞相， 平南蛮又扫北扶保孤王。 久不见老相父朝思暮想， 食同餐行相伴国事相商。 今回朝享清福富贵安享， 朕不舍年迈人亲临战场，力竭神伤！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "三顾恩铭肺腑时刻难忘， 臣怎能怀异志辜负先王！ 用火攻烧藤甲兵亡马丧， 东西战南北剿保定家邦。 这几件些小功可对主上， 又请旨伐中原报答先王。 秉忠心尽劳瘁曹魏扫荡， 王降旨召臣回所为哪桩？ 臣不是前朝的篡位王莽， 这一片竭诚心，兴王霸业定国安邦，可对上苍！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "孤自恨听谗言无有度量， 错疑了老相父为国忠良！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "咳，朕因误听宦官之言，一时召回相父。今日茅塞顿开，悔不及矣！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "龙心宽放。 蒋、费二公！"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二公在朝，何以不能觉察奸邪，规谏天子？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮稍停。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "速去将奸佞查明，待我发落。"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬、费祎同下。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "老相父，魏国兵势如何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "魏曹睿虽然是兵多将广， 我国兵破数关虎赶群羊。 指日里取长安陛下执掌， 扫烟尘归一统国祚无疆。 倚仗着得胜兵臣要复往， 错过了此机会枉费心肠。 臣回朝司马懿必起风浪， 不收服空费了数载风霜，请我主仔细参详！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "奏之有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬、费袆同上。"
        },
        {
          "character": "蒋琬",
          "type": "念",
          "text": "奸佞险误国，"
        },
        {
          "character": "费袆",
          "type": "念",
          "text": "主幼听谗言。"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "启丞相：此等流言，乃是李严部将苟安回朝散布。今已查明。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "噢！是苟安散布的么？"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "只为押粮误期，责打八十军棍，以致如此！苟安何在？"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "投魏去了！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "便宜了他！ 启陛下：请将妄奏的宦官诛戮，其余废出宫外。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "丞相替孤代劳。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "领旨！ 蒋、费二公！"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将妄奏的奸佞查明正法！"
        },
        {
          "character": "蒋琬、费袆",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬、费祎同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "启陛下：臣请以得胜之兵，复出祁山。不敢久停，就此辞别陛下。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "咳，相父哇！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "出祁山取中原多感丞相， 为社稷不辞劳饱受风霜。 狼烟尽奏凯归富贵同享，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老臣不敢。"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "孤赐你得胜酒即入陈仓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂、四大铠、四上手、姜维、魏延、马岱、关兴、王平、马忠、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "姜维、魏延、马岱、关兴、王平、马忠",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "兵发祁山！"
        },
        {
          "character": "姜维、魏延、马岱、关兴、王平、马忠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "日行千里走西川，披星戴月哪得闲。魏蜀几番争社稷，孔明五次伐中原。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "俺，司马都督帐下能行探子是也。打听那孔明又出祁山，马上飞报都督得知便 了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "点绛唇",
          "text": "魏蜀争强，统领兵将。大权掌，拓土开疆，韬略胸中藏。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "运筹帷幄制敌军，又承君恩领雄兵。诸葛逞强扶汉鼎，人力岂能扭天心！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本督，司马懿。多亏苟安散布流言，孔明全军撤回成都。我料他必然再出祁山。 主公命我领兵御敌。为此大会各路兵将，共议破蜀之策。曾命探子打探，未 见回报！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启都督：孔明人马又出祁山！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "噢！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "前部王平、张嶷径出陈仓，过剑阁，由散关往斜谷而来。特来报知。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "左右！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "传张郃、郭淮进帐！"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "张郃、郭淮进帐！"
        },
        {
          "character": "张郃、郭淮",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、郭淮同上。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "豪杰冲锋无人当，"
        },
        {
          "character": "郭淮",
          "type": "念",
          "text": "文韬武略腹内藏。"
        },
        {
          "character": "张郃、郭淮",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张郃。"
        },
        {
          "character": "郭淮",
          "type": "白",
          "text": "郭淮。 都督有令，一同进帐。参见都督！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "将军少礼。"
        },
        {
          "character": "张郃、郭淮",
          "type": "同白",
          "text": "唤末将进帐，有何差遣？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "适才探子报道：孔明人马从斜谷而来。特与二位将军商议破蜀之计。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "某愿亲领兵将，去守雍、郿，以拒蜀兵。"
        },
        {
          "character": "郭淮",
          "type": "白",
          "text": "某愿听指挥。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "我前军既不能独挡孔明之众，分兵前后，亦非胜算。不如留下兵将以守上邽， 余众悉往祁山。张将军可为先锋否？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "某素怀忠义，尽心报国，只是未遇知己。都督肯委重任，万死不辞。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "好。就命将军以为先锋，总督大军。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "谢都督！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "孔明长驱大进，必割陇上小麦，以资军粮。张将军领兵四万去守祁山，郭将军 巡瞭天水诸郡。本督亲领大兵，保守陇上，以防贼兵割麦。"
        },
        {
          "character": "张郃、郭淮",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "就此分兵而行！"
        },
        {
          "character": "张郃、郭淮",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、郭淮同下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "陇上去者！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四上手、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "五伐中原，神妙策，辅汉顺天。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我到卤城日久。屡遣军人催粮，只是一去不见回音。据当地太守言道，陇上麦 熟。我不免带领兵丁，前往陇上割麦，以充军粮。 众将官！陇上去者！"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "我五次伐中原一呼百应， 自古道兵未动粮草先行。 今割麦助我军绝他军命， 军无粮必自散如鸟失林。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启丞相：司马懿已在陇上扎营。特来报知。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔呼呀，司马懿已知我前来割麦！这、这、这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮想。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哦、哦，我自有道理。 众将官！"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "撤兵回营！"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "司马懿是将才甚是聪敏， 猜透我诸葛亮肺腑之情。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "左右！"
        },
        {
          "character": "四上手、四大铠",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传我将令：命王平、张嶷、吴班、吴懿四将，去守祁山营寨！"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再推三辆车来，皆要与我乘坐的车一样装设。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传姜维、魏延、马岱、关兴进帐！"
        },
        {
          "character": "上手甲",
          "type": "白",
          "text": "姜维、魏延、马岱、关兴进帐！"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延、马岱、关兴同上。"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "同白",
          "text": "参见丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "列位将军少礼。"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "同白",
          "text": "谢丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "姜维！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领一千雄兵，保护车辆。五百人擂鼓，埋伏在上邽之后。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马岱在左，魏延在右，各带领雄兵一千，保护车辆。五百人擂鼓。"
        },
        {
          "character": "魏延、马岱",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "每辆车上要二十四人，身穿皂衣，披发仗剑。手执七星幡，左右护车。"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吩咐三万精兵，各执镰刀，拿了绳索，准备割麦。"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再选二十四个精壮军士，各穿皂衣，披发仗剑，护拥车之前后，以为推车使者。"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "关兴！"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你可扮做天篷星模样，手执七星皂幡，步行于吾车之前。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "查看营内将士，与山人相貌相似者，挑选三人。须要与我一般装束，坐在四轮 车上，吓退魏军。我军兵丁好在陇上割麦。"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "丞相精通奇门遁甲之法，何须要营中军人扮做丞相？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今日之计，所用者虽是奇门遁甲之术，但与司马懿交兵之时，扮我之人须要对 阵讲话，方好哄那司马懿出营。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我今日吩咐之事，众将速速安排停当。听我令下！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "军无粮兵无将怎能临阵， 我安排神妙计吩咐众军。 各扮做天神将须要谨慎， 吓退了司马懿大功告成。"
        },
        {
          "character": "姜维、魏延、马岱、关兴",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "马岱、关兴",
          "type": "同唱",
          "text": "奉将令将军务安顿齐整，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱、关兴同下。"
        },
        {
          "character": "姜维、魏延",
          "type": "同唱",
          "text": "要割麦教你我扮鬼装神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、魏延同下。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "出祁山取关口收复数郡， 骂王朗死阵前吓坏曹真。 四辆车四孔明谅他难认， 要惊吓司马懿割麦装神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、乐綝、张虎引司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "在陇上扎大营差人打听， 此一战我要擒诸葛孔明。"
