{
  "script_id": "03109003",
  "title": "回荆州",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "孙尚香",
      "hangdang": "旦"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    }
  ],
  "plot": "刘备入赘东吴后，每日歌舞宴乐，不思荆州，随去的赵云遵诸葛亮锦囊妙计，诈称曹操发兵攻荆州，刘备非\n常焦急，在取得了孙夫人支持后，借口到江边祭祖，携孙夫人偷回荆州。周瑜闻迅，几次派吴将追赶，均被\n孙夫人叱退；后周瑜亲自追赶，刘备为诸葛亮事先所派将领接应，安全地回到了荆州。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引孙权同上。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "谋不如意眉头皱， 事不遂心更加愁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤、孙权。因刘备借了荆州不还，周公谨定下调虎离山之计，骗那刘备过江， 要还荆州，不料母后做主，将我妹招赘刘备。唉！不想画虎不成，反类其犬！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂领丁奉同上。"
        },
        {
          "character": "丁奉",
          "type": "念",
          "text": "安排打虎牢笼计，焉知鸡羊被虎吃。"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "宫门有人么？"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "请禀主公：丁奉求见。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "候着。 启禀主公：丁奉宫门求见。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "传！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "领旨。 丁将军，主公传你！"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "是。 丁奉参见主公。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "将军平身！"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "谢主公！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "将军进宫何事？"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "臣在柴桑郡奉了都督之命，有书一封，主公请看。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。孙权看。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "好公谨！一计不成，二计又来。刘备出身微贱，用美女歌舞悦其耳目，山珍海 味悦其口，锦衣绣服悦其身，他必然贪图声色富贵，忘却荆州，那时大事可图。"
        },
        {
          "character": "孙权",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "丁奉听旨！"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "臣在！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "传令下去，命吕范安置东房书院，办就奇花异草，美女班头，好玩之物，多多 办些。"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丁奉下。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "刘备啊刘备！"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "江东设下迷魂阵，纵有双翅难飞腾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引关羽、张飞同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "忽然又见鸿雁至，更逢枝头梅尽开。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "但见江南杀气动，不见东吴有人来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥请坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟请坐。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥过江，不觉年尽，并无音信，愚弟放心不下。有心前去打听，二哥意下如 何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟要去，须要与先生商议。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥原是不去的，被他坑入陷阱，问他什么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮暗上，听。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "这个牛鼻子又来了！"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "檐前喜鹊不住叫，庭外必有客人到。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人有礼！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "见什么礼，坐下就是。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生来了，请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁为何怒气不息？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺大哥不去招亲，你非要他去，今已年终，不见回来，果然中了东吴美人之计， 叫我怎么不恼！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁且免烦恼，现有主公书信回来，一同观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞、诸葛亮同看信，诸葛亮念，张飞听。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "“自过江之后，闯入南徐，蒙锦囊指教，谒见乔老，国太做主，已结丝罗，不 久携郡主同归。三弟，先生，谨守荆州，勿误！”"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吾大哥不久带嫂嫂同归，岂不喜煞我也！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "先生妙算已奏效， 我家二哥将英才。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "杀猪宰羊一齐摆， 庆贺筵席快安排。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "三弟且慢酒宴摆， 孙权并非小婴孩。 我与东吴仇如海， 岂肯放大哥转回来！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "二公不必愁眉带， 山人心中有安排。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二公不要性急，山人早已算就主公安然无恙，自有日期回来。 二将军，元旦之日，你带领黄忠、魏延及三千人马，埋伏在黄州界口，吴兵登 岸，劫杀一阵，不许追赶。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将军安排战船四十艘，迎接主公。城门挂彩，孙乾备酒宴侍候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂自两边分下。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "龙凤得配天降彩， 满堂瑞气福自来。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "美人之计今何在？"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "姻缘得就天安排。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、关羽、张飞同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引赵云同上。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "远望荆州水茫茫， 主公安居在他乡。 暖阁不知冬已往， 野外桃花报春光。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺，赵云。保主江东招亲，看看年冬将尽，主公并无有回去之意，如之奈何？ 哦，有了！不免将先生二道锦囊打开一看，便知妙计。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云打开锦囊看。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "“如主公不思故乡，可假报一信，言说曹操带领人马，要报那赤壁之仇。” 啊哈哈哈！妙计啊妙计！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "二道锦囊藏妙计， 果然先生八卦强。 神机妙算诸葛亮， 年冬月尽回荆襄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "将军请了！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "禀知皇叔：赵云求见。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "少站。 有请皇叔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "每日阳台梦，终朝思故乡。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "赵云求见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "命他进来！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "皇叔命赵将军进见！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公在哪里？ 呀！主公啊！大事不好了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "曹操带领人马，报赤壁之仇来了！先生差人下书前来，请主公速速回去！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公，快快想个良计方好！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你且退下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公不可迟延，若是荆州有失，你我君臣将无容身之处了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你且退下！我自有道理。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、旗牌自两边分下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓煞我也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "适才四弟军情讲： 奸雄领兵出许昌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香暗上，听。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "现今不得出罗网， 刘备怎得回荆襄。"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "皇叔何事心不爽， 暗地惆怅泪汪汪？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "郡主！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "卑人尽把良心丧， 不仁不义不孝郎。 祖父先人皆祭享， 如今无人来上香。 终朝不安深思量， 有恐旁人道短长！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "皇叔的心事，妾身明白了！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "非是你把爹娘想， 亦非坟前去烧香。 要回荆襄恐阻挡， 思念故乡泪汪汪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "既然郡主识破卑人的心事，卑人焉敢隐瞒。适才赵云报到：曹操带领人马，杀 奔荆襄，要报赤壁之仇。欲待回去，难舍郡主；欲待不回，诚恐荆州有失，事 出两难，如之奈何？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "皇叔若回荆州，妾身自当相随。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "诚恐国太难舍郡主，也是枉然！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "待我禀知国太，就说：元旦之日，我夫妻要到江边祭祖，谅无阻拦。那时，你 我同回荆州便了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "多谢郡主！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "妾身虽是女流，颇知大体，若有二意，神天不佑！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "郡主言重了！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "皇叔！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "来日祭奠江边往， 只把巧言哄老娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "郡主贤德胸怀广， 同归荆襄解愁肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引吴国太同上。"
        },
        {
          "character": "吴国太",
          "type": "唱",
          "text": "皇叔东吴来入赘， 喜琴瑟调和乐唱随。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "未进宫先滴腮边泪， 假陪笑脸拜慈帏。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后千岁！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "一旁坐下！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿啊。不在东宫陪伴皇叔，进宫何事？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "明日，乃是元旦之期，女儿要陪皇叔江边祭祖，故尔进宫禀知母后。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "江边祭祖，不过半日，何必又来禀我。早去早回，只管前去便了。"
