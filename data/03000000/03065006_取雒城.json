{
  "script_id": "03065006",
  "title": "取雒城",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张任",
      "hangdang": "武生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "刘备得张松献图后，领兵夺西川。雒城守将张任，于落凤坡前射死庞统。刘备率黄忠、魏延出战，复大败。\n诸葛亮自荆州引军至，乃合兵攻雒城，定计诱张任出战，诈败，引之追过金雁桥，赵云将桥拆断，张任后退\n无路，为张飞所擒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、刘封同上，同站门。刘备上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "统领雄兵，何日里，西川扫平！"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "桃园结义聚英雄，转战征杀屡奏功。苍天若得遂人意，扫灭西川整江洪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤、刘备。自荆州兴兵前来夺取西川，不料庞统先生命丧落凤坡前，也曾命关 平去往荆州搬兵，一去许久，并无音信。可恨张任屡次兴兵前来讨战，不免宣 黄忠、魏延进帐，商议退兵之策。 来！"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "传黄忠、魏延进帐！"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "黄忠、魏延进帐！"
        },
        {
          "character": "黄忠、魏延",
          "type": "同内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同上。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "自幼生来志气昂，"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "练就百步箭穿杨。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "上阵全凭刀和马，"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "保定吾主锦家邦。"
        },
        {
          "character": "魏延、黄忠",
          "type": "同白",
          "text": "臣等见驾，吾主千岁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "魏延、黄忠",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赐坐！"
        },
        {
          "character": "魏延、黄忠",
          "type": "同白",
          "text": "谢坐！宣臣等进帐，有何军情议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "只因庞统先生命丧落凤坡前，可恨张任累次兴兵前来讨战，宣二位将军进帐， 商议退兵之策。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "臣启主公：关平去往荆州搬兵未回，候孔明先生到来，再发人马与他对敌，也 还不迟。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "若等关平回来，此城恐难保矣！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "主公可赐臣一支人马，前往他营，打一下马阵势，探听那贼兵势如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好，就命老将军带领一支人马，前往他营，打一下马阵势，探听那贼兵势如何。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "且慢！臣启主公：老将军年迈，只恐误了军情大事，可赐为臣一支人马，前去 探听那贼兵势如何。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "魏将军，你此言差矣！想俺黄忠上有廉颇之勇，下有马援之威，胸中韬略却还 不老！"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "将军说话言太差， 老夫言来听根芽： 人老只老头上发， 杀人宝刀如切瓜。 此番带领人和马， 要把雒城一马踏。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "老将军哪！有道是："
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "少年英雄将，奋勇谁敢当？慢说擒张任，金刚又何妨！"
        },
        {
          "character": "魏延",
          "type": "唱",
          "text": "老将军不必逞刚强， 某今言来听端详： 你今倒有六十上， 怎能比得少年郎？ 耳聋难听战鼓响， 眼花难观阵头枪。 张任非比等闲将， 提兵上阵鬼神忙。 倘若前去打败仗， 反被张任笑一场。 非是俺夸口大话讲， 要将贼子一扫光！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "魏将军，你休夸大口，曾记得主公在荆州兴兵前来夺取涪城，主公传令二更造 饭，三更起马，攻打邓、冷二寨。谁知你要抢头功，私自前去偷营。哪知邓、 冷二人早有准备，将人马四下埋伏，留下空营一座。你一马杀进贼营，指望成 功，不想贼营信炮一响，四下贼兵齐上，将你围困垓心，看看性命难保。若不 是俺黄忠杀进贼营将你救出，你的性命休矣！"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "曾记得荆州兴人马， 夺取西川定邦家。 主公宝帐令传下， 要将二寨一马踏。 哪知你的心太大， 二更起马去寻他。 将你困在垓心下， 邓、冷二人将你拿。 若不是黄忠领人马， 你的性命染黄沙！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "魏延",
          "type": "唱",
          "text": "听一言来怒气发， 不由魏延咬钢牙。 三军与爷备战马，"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "黄忠",
          "type": "唱",
          "text": "你敢与俺比刀法？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "某家何惧！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "二位将军休争斗， 细听孤穷说从头： 曹操欺君谋汉胄， 各路诸侯统貔貅。 但愿西川归孤手， 一统山河保龙楼。 你二人先锋分左右， 攻取雒城莫记仇。"
        },
        {
          "character": "魏延、黄忠",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "刘封随驾在左右， 灭却张任方罢休。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "炮响三军齐争斗，"
        },
        {
          "character": "四红文堂、四红大铠",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起鼓〗。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "要擒张任返荆州。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": "四红文堂、四红大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴懿上，起霸。"
        },
        {
          "character": "吴懿",
          "type": "念",
          "text": "大将威风勇，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卓膺上，起霸。"
        },
        {
          "character": "卓膺",
          "type": "念",
          "text": "杀气贯长虹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘璝、吴兰同上，双起霸。"
        },
        {
          "character": "刘璝、吴兰",
          "type": "同念",
          "text": "马踏敌人境，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张翼、雷同同上，双起霸。"
        },
        {
          "character": "张翼、雷同",
          "type": "同念",
          "text": "保主坐九重。"
        },
        {
          "character": "吴懿",
          "type": "白",
          "text": "俺，吴懿。"
        },
        {
          "character": "卓膺",
          "type": "白",
          "text": "卓膺。"
        },
        {
          "character": "刘璝",
          "type": "白",
          "text": "刘璝。"
        },
        {
          "character": "吴兰",
          "type": "白",
          "text": "吴兰。"
        },
        {
          "character": "张翼",
          "type": "白",
          "text": "张翼。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "雷同。"
        },
        {
          "character": "吴兰",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "吴懿、卓膺、刘璝、张翼、雷同",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "吴兰",
          "type": "白",
          "text": "元帅升帐，你我两厢伺候！"
        },
        {
          "character": "吴懿、卓膺、刘璝、张翼、雷同",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴兰、吴懿、卓膺、刘璝、张翼、雷同分归两边，四文堂、四下手、八大刀手引张任同上。"
        },
        {
          "character": "张任",
          "type": "点绛唇",
          "text": "将士英豪，儿郎虎豹，军威浩，地动山摇，要把狼烟扫！"
        },
        {
          "character": "吴懿、卓膺、刘璝、吴兰、张翼、雷同",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "众位将军少礼！"
        },
        {
          "character": "吴懿、卓膺、刘璝、吴兰、张翼、雷同",
          "type": "同白",
          "text": "谢元帅！"
        },
        {
          "character": "张任",
          "type": "念",
          "text": "奉王旨意镇雒城，统领貔貅百万兵。今日点动兵和将，要把刘备一鼓擒。"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "本帅、张任。奉王旨意镇守雒城。可恨刘备带领人马来取我城，是本帅心生一 计，在落凤坡前将庞统乱箭射死，又恐他兴兵前来与庞统报仇，也曾命探子前 去打探，未见回报！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：刘备带领人马，前来攻取雒城！"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "且住，刘备今日兴兵，必为庞统雪恨而来。 众将官！"
        },
        {
          "character": "吴懿、卓膺、刘璝、吴兰、张翼、雷同",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "准备了！"
        },
        {
          "character": "吴懿、卓膺、刘璝、吴兰、张翼、雷同",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "众将官！开关迎敌者！"
        },
        {
          "character": "吴懿、卓膺、刘璝、吴兰、张翼、雷同",
          "type": "同白",
          "text": "啊！ （张任、吴懿、卓膺、刘璝、吴兰、张翼、雷同、四文堂、四下手、八大刀手同走圆场，同出城。刘备、魏 延、黄忠、刘封、四红文堂、四红大铠同上，同会阵。）"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "呔，刘备！想吾主与你乃是宗兄宗弟，你为何兴兵前来攻取雒城？劝你好好收 兵回去，如若不然，枪下作鬼！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唗，大胆张任！你不该设计，在落凤坡前射死孤的庞统先生，孤今到此就要与 庞统先生报仇，尔即早投降，免丧疆场！"
        },
        {
          "character": "张任",
          "type": "白",
          "text": "休得胡言，看枪！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "黄、魏二将！"
        },
        {
          "character": "魏延、黄忠",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "迎敌者！"
        },
        {
          "character": "魏延、黄忠",
          "type": "同白",
          "text": "得令！ （刘备下。黄忠、魏延与张任、吴懿、卓膺、刘璝、吴兰、张翼、雷同杀，黄忠、魏延、刘封、四红文堂、 四红大铠同败下。张任、吴懿、卓膺、刘璝、吴兰、张翼、雷同、四文堂、四下手、八大刀手同追下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。八马夫、严颜、张飞同上。〖内喊杀声〗。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "老将军！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "三千岁！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱兵行至此间，那里人马呐喊，想是咱大哥与贼兵交战，你我去到阵前助阵便 了！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "三千岁言之有理。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军的，阵前去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。八马夫同抄下，张飞、严颜同收下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内唱",
          "text": "四下人马难敌挡， （刘备上。张任、吴懿、卓膺、刘璝、吴兰、张翼、雷同、四文堂、四下手、八大刀手同上，与刘备起打。 张任、吴懿、卓膺、刘璝、吴兰、张翼、雷同、四文堂、四下手、八大刀手分两边站，作包围。）"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "倒叫孤穷着了忙。 拼着生死往外闯， （刘备、张任杀过合。张任、吴懿、卓膺、刘璝、吴兰、张翼、雷同、四文堂、四下手、八大刀手同归小边 站一字，刘备架住。）"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "要出重围须逞强。 层层俱是蜀兵将， 一人怎挡百万郎！ 奋勇杀不出天罗网，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备冲杀。四马夫引张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
