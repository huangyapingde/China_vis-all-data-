      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马超上。"
        },
        {
          "character": "马超",
          "type": "引子",
          "text": "剑气冲霄汉，英名震西羌。"
        },
        {
          "character": "马超",
          "type": "念",
          "text": "韬略兵机历代传，文修武备在心间。父授战策威名显，压服西凉半壁天。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "俺，姓马名超字孟起。我父马腾，献帝驾前为臣，奉命镇守西凉一带。前日圣 旨到来，召我父进京议事。只因昨夜偶得一梦，是我身卧雪地。醒来不觉心惊 肉跳，不知是何吉凶？正是："
        },
        {
          "character": "马超",
          "type": "念",
          "text": "心中怀念血带诏，何日才能报君王。"
        },
        {
          "character": "马岱",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱上。"
