        {
          "character": "许褚",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "赫赫威名镇许昌，文韬武略世无双。但愿狼烟齐扫荡，统领貔貅灭西羌。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫，曹操。日前用计斩了马腾，他子马超必要倒反西凉。我也曾命徐晃镇守 潼关，以防不测。老夫有令在先，只宜坚守，不可出战，俟老夫大兵一到，方 可开城对敌。 许褚！"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吩咐大小三军，齐往潼关去者！"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "啊！ 兵发潼关。"
