{
  "script_id": "03017001",
  "title": "反西凉",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "马超",
      "hangdang": "武生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "许褚",
      "hangdang": "净"
    },
    {
      "name": "曹洪",
      "hangdang": "净"
    }
  ],
  "plot": "曹操挟天子令诸侯，马腾不服，曹操以伪旨召马腾入京受爵，中途伏甲兵刺死马腾。马腾子马超闻耗，率西\n羌兵攻中原，西凉太守韩遂往助之。曹操闻报驰书潼关守将徐晃，令坚守勿战，曹操领兵往救。马超军攻潼\n关甚急，曹操将曹洪违命出战，致败失潼关。曹操闻报驰援，适马超兵骤至，曹兵败溃，马超军扬言欲活捉\n曹操，曹操弃袍割须而逃，败至渭水渡口，马超军追至，幸许褚护曹操登舟，乃得幸免。",
  "notes": "本剧经苏连汉先生校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引夏侯惇同上。"
        },
        {
          "character": "夏侯惇",
          "type": "念",
          "text": "朝中天子宣，阃外法度严。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "俺、夏侯惇。曹丞相密令传唤，不知为了何事。 来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同应。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "辕门去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引董平同上。"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "俺、董平。丞相传唤，不知为了何事。 来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同应。"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "辕门去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董平、四文堂同走圆场，夏侯惇、四文堂同上。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "董将军挡道。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同应。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "啊，董将军！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "夏侯将军！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "今欲何往？"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "丞相密令传唤，不知为了何事，因此起兵而来。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "俺也为此而来，你我合兵一处。 众将官！带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同应，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、二旗牌引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "代理山河，藐群雄，独霸朝阁。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "老夫亲领南征，袁绍抗吾之兵。群雄皆已服顺，孙、刘只在掌中。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫，曹操。自除董卓之后，诸侯皆已服顺。唯有西凉马腾，依仗他子英勇， 有抗我之意。若不早除，必为后患。我也曾命人去唤夏侯惇、董平二将议事， 还不见到来。 左右！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同应。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": "四文堂",
          "type": "内同白",
          "text": "二位将军到！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引夏侯惇、董平同上。"
        },
        {
          "character": "夏侯惇、董平",
          "type": "同白",
          "text": "丞相在上，末将等大礼参拜。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "只行常礼，请坐。"
        },
        {
          "character": "夏侯惇、董平",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二位将军征伐边庭，诸侯丧胆，真乃国家之支柱也。"
        },
        {
          "character": "夏侯惇、董平",
          "type": "白",
          "text": "末将等全仗军威，何劳丞相美赞！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军虎威！"
        },
        {
          "character": "夏侯惇、董平",
          "type": "同白",
          "text": "丞相相约，有何见谕？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二位将军哪里知道。只因除却董卓之后，诸侯皆已服顺，唯有马腾倚仗他子英 勇，有抗我之意，必为后患。故请二位将军前来，共议此事。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "听丞相之言，莫非有吞汉之意么？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哈哈哈……未知天意可遂？"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "末将有计献上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "丞相假传圣旨一道，召马腾进京，加官进爵。再命董平将军执金牌一面，带领 一支人马，埋伏中途。等候马腾到来，一齐杀之，何愁大事不成！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "倘若他子马超倒反西凉，如何是好？"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "丞相可命徐晃、曹洪驻扎潼关，紧守不战。候丞相大兵一到，开关一战，前后 夹击，哪怕马超不灭！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哈哈哈……全仗二位将军。老夫备得有酒，与二位将军痛饮！"
        },
        {
          "character": "夏侯惇、董平",
          "type": "同白",
          "text": "末将等把盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "摆筵。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二位将军请！"
        },
        {
          "character": "夏侯惇、董平",
          "type": "同白",
          "text": "丞相请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。曹操、夏侯惇、董平同饮酒。"
        },
        {
          "character": "夏侯惇、董平",
          "type": "同白",
          "text": "啊丞相，此事宜早不宜迟。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "夏侯将军听令！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你假传圣旨一道，去至边关，召马腾父子进京，不得有误！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "董平听令！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你执金牌一面，带领一千刀斧手，扎在中途，见了马腾父子，一齐杀之，不 得有误！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董平下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，传我将令！命徐晃、曹洪紧守潼关，不得有误！"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌甲下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "但愿苍天遂人意，杀却马腾称心机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四车旗引马岱同上。"
        },
        {
          "character": "马岱",
          "type": "唱",
          "text": "帐中奉了父帅令， 解押粮草要小心。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "俺，马岱。奉了父帅将令，催押粮草。粮草催齐不免回营交令。 众将官！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "回营去者！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "马岱",
          "type": "唱",
          "text": "三军与爷把路引， 见了父帅把功擎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、旗牌引马腾同上。"
        },
        {
          "character": "马腾",
          "type": "引子",
          "text": "镇守西羌，秉忠心，扶保朝堂。"
        },
        {
          "character": "马腾",
          "type": "念",
          "text": "炎汉社稷如丝悬，曹操竟比董卓奸。许田射鹿欺天子，血诏不密枉徒然。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "本都，姓马名腾字寿成。献帝驾前为臣，奉了万岁之命，镇守西凉一带。只因 曹操在朝专政，欺君妄上，是献帝修下血诏，命董承约请众诸侯共灭曹操。也 是董承作事不密，将大事泄露，全家被害。为此本都回至西凉，每日操演人马， 誓灭国贼。这且不言，我命马岱前去催粮，这般时候，还不见到来。"
        },
        {
          "character": "马岱",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四车旗引马岱同上。"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "将相本无种，男儿当自强。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "参见父帅，孩儿交令。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "罢了，粮草可曾催齐？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "粮草催齐，请父帅查点。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "不必查点，我儿之功也！"
        },
        {
          "character": "夏侯惇",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启元帅圣旨下。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "香案接旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引夏侯惇同上。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "圣旨下，跪。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "听宣读，诏曰：马腾父子镇守边关，受尽风霜之苦。朕思念功臣，召卿进京， 加官进爵，议论朝事。旨意读罢，望诏谢恩！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "请过圣旨。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "香案供奉。有劳将军，捧旨前来，后帐摆宴！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "朝命在身，不敢久停，告辞。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "奉送！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇带四文堂同下。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "圣旨到此，召我进京，议论国事。就命马超、庞德镇守西凉，操练人马，听候 调用，不得有误。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "就此起马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同应，众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引董平同上。"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "俺，董平。奉了丞相将令，密发金牌，中途路上刺杀马腾。 军士们！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同应。"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "马腾",
          "type": "内唱",
          "text": "圣旨一到奔京城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、马岱引马腾同上。"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "带领大小众三军。 人来与爷往前进！"
        },
        {
          "character": "董平",
          "type": "内白",
          "text": "金牌下！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "马腾",
          "type": "唱",
          "text": "金牌到此为何情？"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "儿啊，哪里来的金牌啊？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "想必曹操定下诡计，须要提防一二。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "我儿不必多言，闪在一旁。 有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引董平同上。"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "金牌下。"
        },
        {
          "character": "马腾、马岱",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "朕言：朝中有紧要军情，命马腾父子，不分昼夜，火速进京，误负朕命！"
        },
        {
          "character": "马腾、马岱",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "董平",
          "type": "白",
          "text": "看剑！"
        },
