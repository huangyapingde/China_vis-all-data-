        {
          "character": "报子",
          "type": "白",
          "text": "马超倒反西凉！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "徐晃",
