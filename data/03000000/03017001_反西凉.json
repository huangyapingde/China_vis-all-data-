    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引徐晃同上。"
        },
        {
          "character": "徐晃",
          "type": "点绛唇",
          "text": "镇守潼关，威风浩荡，统兵将，四海名扬，军权我执掌。"
        },
        {
          "character": "徐晃",
          "type": "念",
          "text": "辕门以外月儿高，马配雕鞍将挂袍。男儿若掌封侯印，斩将回来血染刀。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "某，姓徐名晃字公明。奉了丞相之命，镇守潼关。昨日丞相有密令到来，言说： 倘若马超倒反西凉，教我谨守。为此今日升帐，先传一令。 众将官！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "传我将令，只可谨守，不可出战，违令者斩！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊。"
