        {
          "character": "马岱",
          "type": "白",
          "text": "参见兄长，大事不好了！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "曹操使用奸计，假传圣旨一道，中途将我叔父杀死！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "将我叔父杀死！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超昏。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "兄长醒来！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "听说严亲把命丧，"
        },
        {
          "character": "马超",
          "type": "三叫头",
          "text": "爹爹，我父，哎，爹爹呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "点点珠泪洒胸膛。 开言大骂贼奸党，"
        },
        {
          "character": "马超",
