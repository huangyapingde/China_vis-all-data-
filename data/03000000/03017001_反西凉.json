        {
          "character": "曹洪",
          "type": "念",
          "text": "赤发红须胆气粗，赫赫威名盖世无。站立阵前人皆怕，宝刀一举鬼神服。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "某，姓曹名洪字子廉。正在后帐饮酒，忽听元帅免战高悬，不免进帐问过。 报，曹洪告进！参见元帅。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "少礼，请坐。"
