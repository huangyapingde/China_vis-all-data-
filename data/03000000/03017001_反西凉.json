          "type": "白",
          "text": "催军！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "老夫兴兵谁敢挡， 赫赫威名天下扬。 沟渠之水难起浪， 何惧马超小儿郎。 大队人马往前闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐晃上。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "前道不行为哪桩。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "徐晃挡道！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "马前回话！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "参见丞相！"
        },
        {
