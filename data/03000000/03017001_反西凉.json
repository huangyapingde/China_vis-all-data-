        {
          "character": "马超",
          "type": "唱",
          "text": "杀却国贼反西凉。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "马岱听令！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "命庞德带领大小三军，齐穿孝服，校场听点。"
