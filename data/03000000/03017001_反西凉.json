        {
          "character": null,
          "type": "stage",
          "text": "马超下。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令。 下面听者：大小三军，齐穿孝服，校场听点！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱下。"
        }
      ]
    },
    {
