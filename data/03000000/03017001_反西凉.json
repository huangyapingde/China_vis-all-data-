        {
          "character": "徐晃",
          "type": "白",
          "text": "将军，无令进帐何事？"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "元帅免战高悬，是何理也？"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "丞相有令，且候大兵一到，方可出城对敌。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "啊呵，元帅！末将不才，愿讨一令，生擒马超进帐。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "那马超为父报仇而来，锐气方盛，况他英勇无敌，只恐将军不是马超的对手。"
        },
        {
          "character": "曹洪",
