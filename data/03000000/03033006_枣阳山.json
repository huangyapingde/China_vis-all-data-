{
  "script_id": "03033006",
  "title": "枣阳山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "单雄信",
      "hangdang": "净"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    }
  ],
  "plot": "隋末，历城县捕快秦琼，奉命护送钦差黄大人回京。路过枣阳山，为单雄信所阻。秦琼以“撒手锏”击单雄\n信下马。单雄信乃服秦琼，拜见黄大人。黄大人欲问斩，经秦琼求情得免。遂嘱焚山归农。单雄信应允，各\n自别去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "太爷堂上发了签， 护送皇家钦命官。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺，秦琼。在历城县当了一名捕快手。奉了太爷之命，护送钦差黄大人。钦差 见喜，赐俺黄骠马一骑。俺得此马，犹如胁生双翅。昨日过了金顶太行山，平 安无事。看前面已是枣阳山，闻昕此地，惯出响马，俺不免先往前途探路，就 此马上加鞭！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "此马生来好威严， 登山越岭如虎蹿。 豪杰催马朝前趱， 舍死忘生保清官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、院子、丫鬟、黄夫人、黄大人同上。"
        },
        {
          "character": "黄大人",
          "type": "唱",
          "text": "天下荒荒烟尘乱， 当今无道信用权奸。 可叹我十载寒窗磨穿铁砚， 一举成名不想为官。 都只为天堂潞州民遭涂炭， 此一番放我去为把民安。 那一日路过历城县， 年兄对我把话谈： 他道此去多凶险， 有两座高山把路拦。 怕的是中途遭磨难， 亲派马步与三班。 一路行来三、四站， 金顶太行保平安。 三班引路往前趱， 又见山峰甚威严。"
        },
        {
          "character": "黄大人",
          "type": "白",
          "text": "且住！看此山高大，必有凶险之处。候秦快班到来，一同过山便了！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "单雄信",
          "type": "内白",
          "text": "众喽兵，将旗扯起！"
        },
        {
          "character": "单雄信",
          "type": "内唱",
          "text": "枣阳山前旌旗展，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、大纛旗引单雄信同上。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "山冈下又来了过路的官员。 见许多轿马人夫在山下站， 我看他好一似钦命官员。 叫一声过路的人真个大胆！ 你擅敢闯过爷的枣阳山？ 我劝你早把那珠宝来献， 有金银早献出好做爷的买路钱！"
        },
        {
          "character": "黄大人",
          "type": "唱",
          "text": "坐在轿中心惊战， 见许多强人站在山前。 为首的赤发红须蓝靛面， 喊一声如霹雳震破了天。 我看他也是条英雄好汉， 相劝他必须要以礼当先。 出轿来走向前躬身立站， 尊一声好汉细听我言： 天下荒荒刀兵乱， 朝内无人掌兵权。 若听本官来相劝， 落个美名在万古传。"
        },
        {
          "character": "单雄信",
          "type": "西皮二六板",
          "text": "雄信闻言自思叹， 你又何须相劝咱？ 某祖父在朝为官宦， 河南一带有某的庄田。 自幼儿习学弓马箭， 原为出头在朝班。 昏王无道皇宫乱， 信用了奸佞掌兵权。 父忠无用反遭斩， 英雄出头就实实难。 因此上扯起了大纛旗一面， 混天大王扫狼烟。 招聚喽兵做好汉， 不日打破天成关。 满朝文武俱问斩， 推倒炀帝坐江山！"
        },
        {
          "character": "黄大人",
          "type": "唱",
          "text": "下官好言来相劝， 口口声声出反言。 你若不听良言劝， 船到江心补漏难！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "听一言来怒气冲冠， 你敢恶言回复咱！ 俺本是顶天立地英雄汉， 雄信聚众枣阳山。 谁敢与某来交战！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "秦叔宝催马到山前。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呔！大胆贼寇，擅敢阻挡皇家命官，尔敢是造反？"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "啊！你来在山前，口出大话，必有本领。也罢！你我比比雌雄，你若胜得过俺， 俺便马前归顺；你若不胜，便怎么样？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺若不胜，愿将车辆奉送。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "丈夫一言？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "岂能反悔！ 三班的，松林保护大人！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "啊！ （四青袍、院子、丫鬟、黄夫人、黄大人同下。四喽兵、大纛旗同下。秦琼、单雄信同起打。秦琼败下。单 雄信追下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "且住！山寇来得厉害。他若追来，撒手锏伤他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。单雄信上。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "哪里走？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上，打单雄信坠马。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "我这里暗发撒手锏， 只见山寇落马前。 不看你是英雄汉， 这一锏叫你尸骨不全。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "我这里被他打一锏， 好汉坠落马雕鞍。 跌跪尘埃求好汉， 尊一声英雄听我言： 你若放我活命转， 来生结草报衔环。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "听罢言来心暗转， 看他也非无义男。 下得马来用手搀，"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "你把名姓对咱言。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "家住山东历城县， 姓秦名琼当快班。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "你是山东好汉秦叔宝、秦二哥？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "不敢！就是在下。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "久仰了！"
        },
        {
          "character": "单雄信",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "久闻二哥今相见， 为何事故到此山？"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "我今奉了太爷签， 护送皇家钦命官。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "有劳二哥把大人见， 施礼赔罪到台前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、单雄信同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、院子、丫鬟、黄夫人、黄大人同上。"
        },
        {
          "character": "黄大人",
          "type": "唱",
          "text": "壮士秦琼把贼战， 一去半日不见还。 三班谨慎保家眷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、单雄信同上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "带来雄信见恩官。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "参见大人！死罪呀死罪！"
        },
        {
          "character": "黄大人",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "黄大人",
          "type": "唱",
          "text": "山寇做事理不端， 擅敢拦路劫官员？ 按律就该来问斩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼跪。黄大人搀。"
        },
        {
          "character": "黄大人",
          "type": "唱",
          "text": "看在壮士且放宽。 从今以后要行善， 早早归乡种庄田。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "谢大人！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "大人释放恩匪浅，"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "今日相逢天凑缘。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "待草民护送大人一程。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "且慢！过了枣阳山，前面一带，平安无事。请大人前行！"
        },
        {
          "character": "黄大人",
          "type": "白",
          "text": "引路！"
        },
        {
          "character": "黄大人",
          "type": "唱",
          "text": "山寨必须火焚散， 勿得再犯扰民间。 待等皇家开恩选， 壮士在家候招安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、院子、丫鬟、黄夫人、黄大人同下。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "秦仁兄请转！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "将大人送至任所。小弟在河南二贤庄等候仁兄便了。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟，你我分别之后，必须火焚山寨，归家务农才是！"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "那个自然。仁兄请上，受小弟一拜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。单雄信拜。秦琼搀。秦琼下。四喽兵、大纛旗暗同上。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "众喽兵，回山去者！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}