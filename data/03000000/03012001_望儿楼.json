{
  "script_id": "03012001",
  "title": "望儿楼",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "窦太真",
      "hangdang": "老旦"
    },
    {
      "name": "李渊",
      "hangdang": "老生"
    }
  ],
  "plot": "唐高祖李渊派次子李世民出征，多年未回。窦后思子，梦寐不安；特建望儿楼一座，不时登楼眺望。",
  "notes": "与《背楼》情节相连，故事比较简单，在表演艺术上着重唱工。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫娥各掌灯引窦太真同上。"
        },
        {
          "character": "窦太真",
          "type": "引子",
          "text": "闷坐昭阳，思皇儿，泪洒胸膛。"
        },
        {
          "character": "窦太真",
          "type": "念",
          "text": "世民领兵伐洛阳，一去数载未还乡。但愿姣儿早回转，也免为娘挂心肠！"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "本后窦氏太真。可恨洛阳兴兵犯界，圣上命世民儿带兵前去征剿，一去数载， 杳无音信。是哀家放心不下，在五凤楼前，起造望儿楼一座，每日黄昏时候， 登楼盼望。今当黄昏时候，正好遥望姣儿一番。 宫娥们掌灯！"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "窦太真在昭阳前思后想， 想起了隋炀帝无道昏王。 欺了兄灭了母以小犯上， 将胞妹立正宫败坏纲常。 陆地里行龙舟万民怨望， 怒恼了塞北地众家番王。 同兴师问罪行把昏王扫荡， 逼死了狗奸王命丧无常。 我的夫成大业把江山执掌， 可恨那洛阳贼兴兵反唐。 宫娥女掌银灯望儿楼上， 到楼台望姣儿早回朝堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真、四宫娥同下。"
        },
        {
          "character": "李渊",
          "type": "内唱",
          "text": "思皇儿不由孤龙心裂碎，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍掌红灯引李渊同上。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "下江南十余载得胜回归。 恨只恨小杨广与孤作对， 修下了辞王本告职回归。 实指望转家园平安度岁， 行在那临潼山又遇贼围； 多亏了秦叔宝将贼杀退， 原来是贼杨广奸计未遂。 内侍臣掌红灯望儿楼内，"
        },
        {
          "character": "窦太真",
          "type": "内白",
          "text": "儿啊！"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "又听得后宫院哭咽声悲！"
        },
        {
          "character": "窦太真",
          "type": "内唱",
          "text": "凄凉凄凉真凄凉， 不见我儿转回乡。 叫声世民回来吧， 免得为娘挂心肠。"
        },
        {
          "character": "窦太真",
          "type": "哭头",
          "text": "啊，我的儿啊！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "我道是宫娥女宫中悲泪， 却原来窦太真哭出宫闱。 内侍臣熄红灯望儿楼退，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍熄灯，下。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "君臣们躲一旁且免伤悲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。四宫娥各掌灯引窦太真同上。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "深宫院打罢了初更时分， 楼台下又来了窦氏太真。 恨只恨洛阳贼兴兵犯境， 他要夺我主爷锦绣龙庭。 宫娥女掌银灯望儿楼进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真上楼。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "上楼来望姣儿早回朝廷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真远望听。〖起二更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "深宫院打罢了二更时分， 想起了孝道儿李世民。 建成、元吉缺孝顺， 惟有那世民有孝心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起三鼓更。窦太真望、听、落泪。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "深宫院打罢了三更时分，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍执灯暗上，巡查宫院。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "楼台下又来了我儿世民。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "儿啊，你回来了！快快上楼，为娘在此盼望于你！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "奴婢是穿宫太监，不是殿下回朝。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "呕，你不是殿下回朝！"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真挥手，内侍下。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "窦太真",
          "type": "哭头",
          "text": "啊……我的儿呀！"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "哀家盼望姣生子， 错把内侍当儿身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真望、听。〖起四更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "深宫院打罢了四更时分， 又听得半空中鸟雀声鸣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真看。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "宫娥们！"
        },
        {
          "character": "四宫娥",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "半空中什么叫？"
        },
        {
          "character": "四宫娥",
          "type": "同白",
          "text": "乃是燕子入巢。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "呕，燕子入巢！"
        },
        {
          "character": "四宫娥",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "窦太真",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "窦太真",
          "type": "哭头",
          "text": "啊……我的儿呀！"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "哀家盼望姣生子， 却原来宾鸿失伴又离群！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真作定想。〖起五更鼓〗。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "深宫院打罢了五更鼓尽， 移星转斗要天明。 恨的是卖国刘文静， 单差我儿李世民。 儿去了有数载无有音信， 望儿楼盼得娘两眼昏。 宫娥们下楼台后宫院进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真下楼。"
        },
        {
          "character": "窦太真",
          "type": "唱",
          "text": "明早朝奏吾皇快发救兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窦太真拭泪，窦太真、四宫娥同下。内侍引李渊同上。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "楼台上哭坏了窦氏昭阳， 楼台下叹坏了武德君王。 内侍臣前引路回宫往， 待孤王修草诏召儿还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、内侍同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}