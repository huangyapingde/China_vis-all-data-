    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内唱",
          "text": "送先生出新野珠泪滚滚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、张飞、孙乾、徐庶、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "君臣们面对面难舍难分。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "实指望保主公大事安定， 我徐庶倒作了短性之人！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "这是我汉刘备身欠福份， 眼见得新野城付与他人！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "劝主公你把那宽心放定， 不久间就将要得遇高人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云暗上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "纵有能人终何用？ 要比先生万不能。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公，酒宴备齐。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "叫四弟看过来酒一樽， 我与先生来饯行。 此番见了伯母面， 你就说桃园弟兄问安宁。 长亭无有别的敬， 一杯水酒来饯行。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "谢过主公酒一樽， 我主恩情似海深。 日后必要成大业， 我徐庶知情必报恩！"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": "孙乾",
          "type": "唱",
          "text": "人来看过酒一樽， 我与先生来饯行。 但愿此去多安静， 但愿此去享太平。 今日长亭把酒敬， 略表孙乾一点心。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "孙乾敬酒不敢饮， 我将此酒谢神明。 将军恭敬我谢定， 知你情义感你恩！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "人来看过酒一樽， 张翼德撩衣跪埃尘。 上跪天，下跪地， 跪父母不跪别人！ 今日跪在先生面， 为了大哥锦乾坤。 先生到了曹营地， 莫把真心献他人。 倘若先生回营转， 老张头顶香炉、迎接先生、一步一步进大营！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "张将军说的肺腑情， 你本是粗中有细人。 只要老母见一面， 岂肯设计与他人！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "不敬酒来不践行， 赵云带过马银鬃。 请上马来足踏镫， 先生急速奔曹营。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "山人在帐下有何能， 怎敢劳动四将军。"
