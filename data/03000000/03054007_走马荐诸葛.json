        {
          "character": "诸葛亮",
          "type": "白",
          "text": "贤弟请坐！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "贤弟此来必有缘故？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "是小弟近来辅佐玄德，因老母被曹所困，持书相唤，只得舍主。临行将兄长荐 与玄德，望施展平生大才，不负昔日所学也。弟特到此处，与兄长送信来了。"
        },
        {
          "character": "徐庶",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唉，贤弟你此言差矣！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "你辅玄德名义正， 不料孟德巧计行。 令堂诓入许昌郡， 唤你之书假非真。 多蒙把我荐刘姓， 卧龙岗上住不成。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "曹营见母心拿稳， 恕兄不能送出门。 后会有期再叙论，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮笑，下。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "自觉无颜往外行。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用上，带马。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "含羞带愧足踏镫， 元直马上自思忖： 若为玄德出谋策，"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "唉！"
        },
        {
