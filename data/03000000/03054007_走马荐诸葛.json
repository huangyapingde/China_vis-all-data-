        },
        {
          "character": "童儿",
          "type": "白",
          "text": "啊，原来是徐先生。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "正是。卧龙先生可在家中？"
        },
        {
          "character": "童儿",
