{
  "script_id": "03054007",
  "title": "走马荐诸葛",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "徐庶",
      "hangdang": "老生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "程昱",
      "hangdang": "老生"
    },
    {
      "name": "徐母",
      "hangdang": "老旦"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "徐母被禁，程昱时有馈送，赚得回帖，遂仿徐母笔迹，致书诓徐庶。徐庶得书，即辞刘备往许昌。刘备兄弟\n依依送别，徐庶感甚，乃荐卧龙、凤雏，并至隆中亲见诸葛亮，备述举荐始末。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、曹用、徐母同上，旗牌自下场门上，迎接。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "恼恨曹操行奸狡， 离间之计设笼牢。 老身只望命丧了， 落个节烈把名标。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "旗牌，唤你再来，下面歇息。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。程昱上。"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "我与丞相来计较， 假意殷勤奉年高。 人来与我忙通报， 说我前来话根苗。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "是。 启徐老太太：程谋士来到馆驿，求见老太太。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "说我有请！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "徐老太太有请！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "有劳了！参见伯母！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程谋士请坐！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "适才蒙你救护，老身这里致谢！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "岂敢！晚生来见伯母，望请宽慰。且忍耐数日，小侄得便在丞相面前婉转相谏， 老伯母早早回家，母子团圆，方显小侄与元直同盟之义。伯母休得忧思！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "全仗先生了！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "理所当然。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "但不知先生在许昌官居何职？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "晚生在曹公麾下充为谏言谋士。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身看看已归地府，蒙先生相救，感恩非浅！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母说哪里话来？我与元直同盟结义，伯母何出此言？本当将伯母请在我家住 上几日，犹恐丞相闻之见疑，暂且委屈伯母几日，就可回转颍州。少时自有我 家使女、丫鬟前来伺候伯母。所用之物，俱有家人送到。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "唉，先生啊！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "多谢先生礼恭敬， 原为元直好宾朋。 不是先生险丧命， 我母子日后感恩情。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "小侄怎敢。晚生告辞了！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "先生请回。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "是。 尔等好好伺候徐老太太！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "小侄去也！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身不送了！"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "伯母在此多安静， 少时使女到馆中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱下。"
        },
        {
          "character": "徐母",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "好个程昱多忠正， 他与老身礼貌恭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子、二丫鬟抬礼物同上。"
        },
        {
          "character": "二院子",
          "type": "同念",
          "text": "奉了老爷命，送礼到馆中。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "来此已是。里面有人吗？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "我们奉了我家程老爷之命，与徐老太太送食盒礼物，前来伺候。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "稍待。 启禀徐老太太：程老爷命家下丫鬟等，送了食盒礼物，前来伺候。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "叫他们进来！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "是。 叫你们进去，小心了！"
        },
        {
          "character": "二院子、二丫鬟",
          "type": "同白",
          "text": "奴婢们与徐老夫人叩头。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "罢了。你们都起来。"
        },
        {
          "character": "二院子、二丫鬟",
          "type": "同白",
          "text": "多谢老夫人！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你们都是程老爷家里的人么？"
        },
        {
          "character": "二院子、二丫鬟",
          "type": "同白",
          "text": "是。我们奉了我家老爷之命，前来伺候老夫人来了。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "好。看文房四宝，待我与程老爷写收礼拜帖。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "是，遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用取笔砚。徐母写拜帖。〖牌子〗。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "有丫鬟在此伺候，倒也安静。 曹用，你们回去歇息去吧！"
        },
        {
          "character": "四文堂、曹用",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、曹用同下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "二位家院，老身现有收礼拜帖，即速回去，多多拜上你家老爷，说我愧领了！"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子同下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你两个叫什么名字？"
        },
        {
          "character": "丫鬟甲",
          "type": "白",
          "text": "我叫春兰。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你呢？"
        },
        {
          "character": "丫鬟乙",
          "type": "白",
          "text": "我叫梅香。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "好。你二人早晚要多辛苦了！"
        },
        {
          "character": "二丫鬟",
          "type": "同白",
          "text": "理当伺候老夫人。"
        },
        {
          "character": "徐母",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "心中只恨贼奸佞， 诓骗老身设牢笼。 反间之计我早省， 曹贼痴迷魂梦中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠同上，同站门。曹操上。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "徐母年迈性情暴， 辱骂老夫舌如刀。 我与程昱安排好， 套写笔迹设计条。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱上。"
        },
        {
          "character": "程昱",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "徐母入了我圈套， 套写笔迹记心梢。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生少礼，请坐！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生套写笔迹怎么样了？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "下官这几日时常命人与徐母送去礼物，已有收礼拜帖。是我留心套写笔迹，已 然套好。我今即要写一封书信，诓那徐庶，定入圈套之中。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好。浓墨伺候，先生写来！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱写书信。〖牌子〗。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "下官带来收礼拜帖，丞相请看与下官写的笔迹如何？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待老夫对来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操看书信与拜帖。〖牌子〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这拜帖与先生写的这封书信分毫不差，老夫即差曹用前往新野下书。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "请丞相即速命人前去。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，曹用进见。"
        },
        {
          "character": "四红文堂",
          "type": "同白",
          "text": "曹用进见！"
        },
        {
          "character": "曹用",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用上。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "参见丞相！有何吩咐？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫有书信一封，命你去往新野刘玄德那里投递，就说奉了徐母所差，由许昌 而来，面交元直开拆。诸事留心，不可泄漏诓取徐母之事，记下了！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "信去人也去！"
        },
        {
          "character": "曹用",
          "type": "念",
          "text": "信回人也回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用下。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "套写笔迹已成就， 何愁徐庶不上钩。 你我府中且等候， 曹用回来再计谋。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "引子",
          "text": "袖内阴阳，乾坤反掌！"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "自幼生来性情刚，只为不平将人伤。逃亡在外投刘主，思想老母在高堂。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "山人，姓徐名庶字元直。只因在家为不平之事，将人打伤，是我逃亡在外，改 名单福，辅保刘皇叔占了新野、樊城地界。唉！思想家中老母，好不伤感也！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "自幼儿在家中将人打坏， 因此上别老母逃出门来。 多蒙那刘皇叔仁义相待， 收留我在帐中治国安排。 大丈夫建奇功名扬四海， 方显得我胸中将相大才。 愿只愿我老母身体安泰， 满炉内焚清香答谢天台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶叹气，下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂同上，同站门。刘备上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "桃园结义，聚英雄，江山一统。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "大树楼桑有我家，幼年贩履做生涯。曾破黄巾兵百万，灭却孙曹定中华。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤，刘备。马跳潭溪之后，得来单福先生，赖他设计夺取樊城。曹仁失利，曹 操必不干休。不免请先生、三位将军进帐，商量破曹之计。 来，有请先生、三位将军进帐！"
        },
        {
          "character": "四红文堂",
          "type": "同白",
          "text": "有请先生、三位将军进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶、孙乾、张飞、赵云同上。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "执掌丝纶凭计谋，"
        },
        {
          "character": "孙乾",
          "type": "念",
          "text": "辅佐明主献略韬。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "曾破黄巾兵百万，"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "东灭孙权北战曹。"
        },
        {
          "character": "徐庶、孙乾、张飞、赵云",
          "type": "同白",
          "text": "参见主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生、三位将军少礼，请坐！"
        },
        {
          "character": "徐庶、孙乾、张飞、赵云",
          "type": "同白",
          "text": "谢坐！传臣等进帐，有何军情议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "只因夺取樊城，曹仁失利，曹操必不甘休。请先生、三位将军进帐，商议破曹 之事。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公但放宽心，倘若曹操兴兵前来，山人略用小计，管叫他不战自退。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "全仗先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "启主公：许昌有人到此下书，特来回禀。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将呈书。刘备看书。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "“不孝男徐庶开拆”。啊！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "启主公：乃是臣的家书到了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请看。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公、众位将军请看！"
        },
        {
          "character": "孙乾、张飞、赵云",
          "type": "同白",
          "text": "还是先生请看！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "老母在上，恕儿不孝之罪了！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "对曹营施一礼拆书观看： “徐庶儿见书信仔细参详。 自从儿在家中将人打丧， 抛下了为娘的哪在心旁？ 多亏了徐康儿将娘奉养， 朝夕间侍为娘不离高堂。 可惜这行孝子一命早丧，”"
        },
        {
          "character": "徐庶",
          "type": "哭头",
          "text": "兄弟呀！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "“丢为娘孤身人好不惨伤！ 好一个仁义主曹公丞相， 接为娘到他营乐享安康。 娘为儿每日间茶饭不想， 娘为儿昼夜里哭断肝肠。 娘为儿向南方倚门悬望， 娘为儿得下了疾病在床。 我的儿早来到还有话讲， 迟来时母子们空望一场。” 看罢了娘书信心中暗想， 这件事倒叫我无有主张。 我本当辞刘主把母看望， 刘主爷待我的情义难当； 我本当在此间不把母望， 落下了不孝名万古传扬。 左也难又也难无计可想，"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "有了！"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "我只得口不言闷坐一旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶哭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生为何两眼落泪？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "启主公：曹操闻知小人在主公帐下，将臣老母接至曹营，逼母修书，叫臣回去。 臣本当去至许昌救母，怎奈作了短性之人！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生书信上面写定“徐庶”，备却不明！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣本姓徐名庶字元直。只因在家为不平之事，将人打坏，逃亡在外，改名单福。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "伯母有难，本当前去打救，只恐樊城、新野就是他人的了！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公但放宽心。臣回去就了老母，再来侍奉主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生真乃忠孝之士也！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公夸奖！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "长亭备宴与先生饯行！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "老母修书实惨伤，"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "幸遇高人不久长！"
        },
        {
          "character": "孙乾、赵云",
          "type": "同念",
          "text": "樊城、新野势难让，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "准备人马破荆襄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
