      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂引赵云同上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "奉了主公之命，备宴与先生饯行。 左右，打道长亭！"
        },
        {
          "character": "四白文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、赵云同走小圆场。"
        },
        {
          "character": "四白文堂",
          "type": "同白",
          "text": "来此长亭。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公到来，报我知道！"
        },
        {
          "character": "四白文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
