        {
          "character": "徐庶",
          "type": "白",
          "text": "啊兄长！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊贤弟！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "仁兄！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "贤弟一向可好？"
        },
        {
          "character": "徐庶",
          "type": "白",
