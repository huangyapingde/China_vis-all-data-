        {
          "character": "院子",
          "type": "白",
          "text": "小人领命。"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "婆母请到后堂安寝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨氏、姜妻、院子同下。"
        }
      ]
    },
    {
