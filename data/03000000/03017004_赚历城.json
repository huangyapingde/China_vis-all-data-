      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四马童、庞德、马岱引马超同上。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "前面乃是历城了。"
        },
        {
          "character": "马上",
          "type": "白",
          "text": "啊，可是杨阜借兵的历城么？"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "马超",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "（公子）（大哥）为何发笑？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "你等哪里知道！杨阜匹夫搬兵于历城，里应外合，杀俺全家。谅那姜叙未回， 俺趁此机会，打破历城，杀他个鸡犬不留！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "依某只见，趁此黑夜之间，假称姜叙得胜回来，赚开城门，不用张弓之力，此 城可破也！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "好。照计而行！ 众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手同应。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "速往历城去者！"
        },
        {
          "character": "马超、庞德、马岱",
          "type": "同收江南",
          "text": "恨奸贼不良， 恨奸贼不良， 顷刻间，割腹剜心与肚肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "杨氏",
          "type": "内白",
          "text": "掌灯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、姜妻引杨氏同上。"
        },
        {
          "character": "杨氏",
          "type": "唱",
          "text": "吾儿孝道为根本， 富贵荣华似庆云。 但愿扫得狼烟净， 不愧臣子报君恩。"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "你们回房歇息去吧！"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "是。"
