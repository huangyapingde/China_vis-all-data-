{
  "script_id": "03017004",
  "title": "赚历城",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "马超",
      "hangdang": "武生"
    }
  ],
  "plot": "马超于冀州大败后，欲投汉中张鲁，经历城。因怀恨姜叙前援救冀州，乘夜冒姜叙名赚入城中杀死姜叙全家\n泄愤。姜叙、夏侯渊已料其事，率兵追至，马超始奔往汉中。",
  "notes": "本剧中，杨氏口述马腾被杀与《反西凉》一剧中马腾被杀情况、地点各有差异，为了存真，这里不打算做任\n何改动。特此附志。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大刀手、四下手引夏侯渊同上。"
        },
        {
          "character": "夏侯渊",
          "type": "点绛唇",
          "text": "云掩长空，旌旗飘动，长安镇，屏障帝京，保主归一统。"
        },
        {
          "character": "夏侯渊",
          "type": "念",
          "text": "红日照盔缨，英雄胆气横。双眉斜入鬓，塞外上将军。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "某，夏侯渊。奉丞相之命，镇守长安。可恨马超兵犯冀州，韦康无谋，开城降 顺。马超提起借兵之仇，将韦康斩首辕门。参谋杨阜假意归降，告假葬妻，暗 往历城，求救于姜叙。会合我兵，三路夹攻。将马超杀得大败，逃回陇西去了。 料他也不敢攻打冀州。 众将！"
        },
        {
          "character": "四龙套、四大刀手、四下手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "姜叙、杨阜进帐！"
        },
        {
          "character": "四龙套、四大刀手、四下手",
          "type": "同白",
          "text": "姜叙、杨阜进帐！"
        },
        {
          "character": "姜叙、杨阜",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜叙、杨阜同上。"
        },
        {
          "character": "姜叙",
          "type": "念",
          "text": "妙用机关人难想，"
        },
        {
          "character": "杨阜",
          "type": "念",
          "text": "龙泉三尺剑收藏。"
        },
        {
          "character": "姜叙、杨阜",
          "type": "同白",
          "text": "元帅在上，末将参见。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "二位将军少礼。请坐。"
        },
        {
          "character": "杨阜",
          "type": "白",
          "text": "谢坐。有劳元帅，领兵前来，杀退马超，我等备得有酒，与元帅贺功。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "多谢二位将军。"
        },
        {
          "character": "姜叙、杨阜",
          "type": "同白",
          "text": "看酒！我等把盏。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "不敢。摆下就是。"
        },
        {
          "character": "姜叙、杨阜",
          "type": "同白",
          "text": "遵命。元帅请酒！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "二位将军哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖画眉序〗。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "二位将军，本帅镇守长安，乃国家之要路，不可一日无主。本帅要兵回长安， 就烦杨参谋镇守此地，姜将军兵回历城，以防马超后患。二公意下如何？"
        },
        {
          "character": "姜叙、杨阜",
          "type": "同白",
          "text": "元帅高见，我等遵命。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "禀元帅：小人四路探事，马超兵败汉中去了。特来报知。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "姜叙",
          "type": "白",
          "text": "哎呀，元帅呀！想马超投奔汉中，必从历城经过，恐诈开城池，满城百姓，老 母妻子，必遭其害。请元帅定夺。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "将军所虑不差。 众将全身披挂，校场听点。"
        },
        {
          "character": "四龙套、四大刀手、四下手",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "六将同上，同起霸。杨阜上。"
        },
        {
          "character": "六将",
          "type": "同白",
          "text": "参见兄长！"
        },
        {
          "character": "杨阜",
          "type": "白",
          "text": "有劳众位兄弟，领兵前来相助。愚兄不胜之喜也！"
        },
        {
          "character": "六将",
          "type": "同白",
          "text": "提调我等，有何事议？"
        },
        {
          "character": "杨阜",
          "type": "白",
          "text": "元帅升帐，你我两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大刀手、四下手、姜叙、夏侯渊同上。"
        },
        {
          "character": "六将、杨阜",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "众位将军少礼！"
        },
        {
          "character": "六将、杨阜",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "夏侯渊",
          "type": "念",
          "text": "兵似狼牙将似熊，堂堂气概果威风。提兵调将英雄量，保定我主建奇功。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "本帅、夏侯渊。只因马超投奔汉中，恐结连张鲁，复起干戈，乃国家之大患。 杨参谋听令！"
        },
        {
          "character": "杨阜",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "命你弟兄七人，带领三千人马，追赶马超。听我吩咐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。"
        },
        {
          "character": "杨阜",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、杨阜、六将同下。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "姜将军听令！"
        },
        {
          "character": "姜叙",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "命你二队接应！"
        },
        {
          "character": "姜叙",
          "type": "白",
          "text": "得令。 带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大刀手、姜叙同下。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "众将此去，马超可擒矣。正是："
        },
        {
          "character": "夏侯渊",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "马超",
          "type": "内白",
          "text": "众将官，趱行者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四马童、庞德、马岱引马超同上。"
        },
        {
          "character": "马超",
          "type": "新水令",
          "text": "雄师威震在西凉， 报父仇，兴兵遣将。"
        },
        {
          "character": "庞德、马岱",
          "type": "同新水令",
          "text": "杀气冲牛斗， 旌旗映斜阳。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "俺、马超。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "庞德。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "自潼关战败，回转陇西，命庞德借兵数万。惟有冀州韦康不肯借兵，反结连曹 操。俺只得统领羌兵，攻打冀州，将韦康斩首。不想杨阜假意归降，私往历城， 搬来姜叙，会合长安夏侯渊，里应外合，将俺妻子孩儿斩首城楼，三路兵马 将我等围困垓心，且喜杀出重围。 庞德、马岱！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、马岱同应。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "查我军还有多少人马？"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "还有三百馀骑。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "还有三百馀骑！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "苍天哪，苍天！俺马超统领数万之众，今日冀州一战，只剩三百馀骑，使俺有 家难奔，有国难投。好不痛煞我也！"
        },
        {
          "character": "马超",
          "type": "新水令",
          "text": "血染杀场， 洒泪满胸膛。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "兄长两次领兵失败，羌中人皆怨恨。若回转西凉，恐人暗算。不如投奔汉中张 鲁那里，暂且安身，自有报仇之日。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "贤弟言得极是。 众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手同应。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "往汉中去者！"
        },
        {
          "character": "马超",
          "type": "折桂令",
          "text": "杀曹贼弃袍奔忙， 逃亡地马乱惊慌。 俺呵，得意扬扬， 自逞豪强。 马孟起好似天将， 杀曹兵难备难防。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上，同站门。〖江儿水〗。六将、杨阜同上。"
        },
        {
          "character": "杨阜",
          "type": "白",
          "text": "俺、杨阜。奉夏侯渊将军之命，带领众家弟兄，追赶马超。 众位弟兄，速速追杀前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、院子引杨氏同上。"
        },
        {
          "character": "杨氏",
          "type": "唱",
          "text": "日落关山掩苍暝， 寒烟霭霭笼荒村。 阵阵鸦鸣归宿境， 沙场征客未回音。 只为强徒斩忠正， 督命吾儿统雄兵。 金樽不洗心头恨， 梨花暮雨近黄昏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜妻上。"
        },
        {
          "character": "姜妻",
          "type": "念",
          "text": "兰房剪烛悲成阵，白发闷坐翠黛颦。"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "婆婆万福！"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "老身杨氏。我儿姜叙，官拜扶彝将军，镇守历城。可恨马超兵反冀州，将韦康 斩首。我侄儿杨阜到此求兵，与韦使君报仇。我儿统领合郡人马，前往冀州， 剿灭马超。一去数日，未见捷报。叫老身如何放心得下！"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "婆母但放宽心。想我夫智勇双全，又有杨参军弟兄七人，皆是武艺超群。那马 超虽勇，亦难抵挡也！"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "媳妇言虽如此，只是我夜间朦胧睡去，偶得一梦，甚是不祥！"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "婆婆所得何梦？"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "梦见合家人等，出城游玩，忽见一蛇一龙相斗。一时惊醒，眼跳不止。不知主 何吉凶？"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "此乃婆母思儿心切，偶得此梦，何足为怪。梦中之事，不可相信。"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "院子可曾命人打听少老爷胜负么？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "也曾命人打听，未见回报。"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "请问婆母：马超两次领兵报仇，不知此事从何而起？"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "只为江东孙权，屡犯中原。马腾父子奉诏南征，兵至许昌，屯扎城外。曹操命 侍郎黄奎到马腾营中採其动静。那黄奎反与马腾同谋，欲害曹操。被人闻风出 首，将马腾擒去，与黄奎一并斩首许昌也！"
        },
        {
          "character": "杨氏",
          "type": "唱",
          "text": "马腾怕曹自谨慎， 屯兵城外不见君。 曹操多谋计藏隐， 假意出城犒三军。 人马早已安排定， 首尾不能挡曹兵。 只杀得人从马鞍滚， 只杀得力弱少精神， 只杀得羌兵俱逃奔， 只杀得红日已西沉。 父子三人俱被捆， 并斩黄奎在都门。 只杀得马岱逃性命， 马超闻报似火焚。 他与韩遂统羌众， 残暴生灵不堪闻。 潼关一战天地震， 吓得曹操落魄销魂。 计用反间败了阵， 二次攻打冀州城。 韦康素常行仁政， 爱惜百姓与子民。 马超怒气冲天恨， 怪其降曹斩营门。"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "旗指山河外，人从关山来。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "太夫人在上，小人叩头。"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "起来！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "奉老爷之命，有书信一封，请太夫人观看。"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "呈上来。下面歇息！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "多谢太夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "待我拆开一观。“不孝子姜叙，叩禀慈亲台前：儿自领兵冀州，与夏侯将军三 兵会合，战败马超。且喜得胜，不日兵回历城，归来定省。省城风闻不确，难 免忧疑。专修寸楮，预为禀明。”好哇！谢天谢地，幸喜我儿杀败马超，复得 冀州。韦使君冤仇，可湔雪矣！"
        },
        {
