        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马超领四文堂、四上手、四马童、庞德、马岱同上。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "马超",
          "type": "收江南",
          "text": "但见那四野苍苍， 月昏黄。 俺今番，奔他乡； 猛想起， 父弟含冤泪千行， 可怜你， 忠魂渺渺在何方！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，同站门，姜叙上。"
        },
        {
          "character": "姜叙",
          "type": "白",
          "text": "俺、姜叙。因为马超投奔汉中张鲁，必要打我历城经过。恐被赚开城池，为此 带领人马赶回防守。 众将官，赶上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二更夫、四下手同上。"
        },
        {
          "character": "更夫甲",
          "type": "念",
          "text": "一个将军出了兵，我等日夜守孤城。但愿旗开得了胜，满城百姓享太平。"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "我乃历城夜巡军便是。日前杨参谋到此搬兵，俺主帅统领人马，征战马超去了。 今日闻报，大获全胜。太夫人吩咐我等谨守城池，等老爷回来，均各有赏。 众弟兄们：小心巡更者！"
        },
        {
          "character": "更夫甲",
          "type": "水底鱼",
          "text": "奉命巡更守夜不消停， 主将得胜不日转历城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二更夫同上城。四文堂、四上手、四马童、庞德、马岱、马超同上。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "马超",
          "type": "沽美酒",
          "text": "赚历城，休要慌。 喜东方，天未光。 鸡鸣狗盗出咸阳， 听历城鼓角更长。 暗夜里，旌旗飘扬，"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "俺呵！"
        },
        {
          "character": "马超",
          "type": "沽美酒",
          "text": "也是俺胸藏心壮胆壮气昂昂。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "呔！开城！"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "姜将军得胜回来，速速开城！"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "原来是将军得胜回来。开城！"
        },
        {
          "character": "马超",
          "type": "沽美酒",
          "text": "威凛凛兵归虎帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四马童、庞德、马岱、马超同进城下，同上。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "呔！城中还有多少人马？"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "五百守城军。我等情愿归降！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "庞德、马岱！"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "吩咐把守四门！"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、马岱同下。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "军士们，杀往帅府去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖园林好〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "院子、丫鬟、姜妻、杨氏同上。"
        },
        {
          "character": "杨氏",
          "type": "唱",
          "text": "忽听关外喊声震， 想是我儿回历城。 杀退贼臣方泄恨， 此番不愧领雄兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "更夫甲领四文堂、四上手、四马童、庞德、马岱、马超同上。"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "来到帅府！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "打进去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超正坐。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "将他们绑了！"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "你是何人，将我等捆绑？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "老贱婢！你枉受朝廷之禄，吾父与董承有衣带之诏。汝不思君臣之大义，助奸 为恶，阻住大兵，杀俺妻儿。俺马超今日杀尔全家，以消俺心头之恨也！"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "贼子呀，贼子！"
        },
        {
          "character": "杨氏",
          "type": "唱",
          "text": "不思报国统羌人， 扰乱汉室锦乾坤。 尔父子不遵天子命， 枉食朝廷爵禄恩。 狼心贼子扰州郡，"
        },
        {
          "character": "杨氏",
          "type": "白",
          "text": "逆贼！"
        },
        {
          "character": "杨氏",
          "type": "唱",
          "text": "千秋万载落骂名。"
        },
        {
          "character": "姜妻",
          "type": "白",
          "text": "贼子呀！"
        },
        {
          "character": "姜妻",
          "type": "唱",
          "text": "不向曹家雪冤情， 兵犯冀州斩韦君。 西凉与我有何恨？ 绳捆索绑无罪人。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "贱婢呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "俺父子威震西凉郡， 歃血定盟共同心。 两次交锋尔不问， 里应外合助仇人。 杀尔全家难消恨，"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "推出帐外斩满门。"
        },
        {
          "character": "杨氏、姜妻",
          "type": "同白",
          "text": "贼子呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手押杨氏、姜妻同下。四上手同上。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "斩首已毕。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "起过了！"
        },
        {
          "character": "马超",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "满腔怨恨今消尽， 妻儿冤仇报分明。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "军士们，什么时候了？"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "三更时分了。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "但此孤城难守，尔等饱餐战饭，待等天明，投往汉中去者！"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四马童、庞德、马岱自两边分下。〖起四更鼓〗。"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "一片愁云月暗隐， 风吹刁斗冷无声。 辕门鼓打四更尽， 忧忧切切不安神。 苦苦征战却为甚？ 皆因父弟冤难伸。 可恨杨阜暗合应， 一军怎挡三路兵！ 冲锋破敌败了阵， 征袍银盔染血腥。 不能够回转西羌郡， 不能够亲自斩仇人。 血泪心事愁烦甚， 今夜为何天不明！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、马岱同上。"
        },
        {
          "character": "庞德",
          "type": "唱",
          "text": "谯楼鼓打四更尽，"
        },
        {
          "character": "马岱",
          "type": "唱",
          "text": "龙泉宝剑紧随身。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "公子，谯楼将近五鼓，待到天明，恐有追兵，须要小心方好。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "将军言之有理。请啊！"
        },
        {
          "character": "庞德",
          "type": "唱",
          "text": "朦胧月色云暗隐，"
        },
        {
          "character": "马岱",
          "type": "唱",
          "text": "提防奸细要小心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、马岱同下。〖起五更鼓〗。"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "一夜辗转悲愁紧， 不闻金鸡报晓声。 江水难洗心头恨， 看看月明照愁人。 越思越想心伤痛， 父仇未报难对云！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖乌鸦叫声〗。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "只见鸦鸣飞阵阵， 不觉东方辗转明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喊“拿马超”声〗。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "忽听关外喊声近， 想是姜叙发来兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、马岱同上。"
        },
        {
          "character": "庞德、马岱",
          "type": "同唱",
          "text": "战鼓不住咚咚震， 看是谁弱与谁能！"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "（公子）（大哥），杨阜兄弟七人，已到城下。请令定夺！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "杨阜匹夫，自来送死！若是擒住此贼，将他千刀万剐，方除俺胸中之恨。 众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四马童同上，同应。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "就此开城迎敌者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四马童同带马出城，同倒领下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、六将引杨阜同上。马超、庞德、马岱、四文堂、四上手、四马童同上，同会阵。"
