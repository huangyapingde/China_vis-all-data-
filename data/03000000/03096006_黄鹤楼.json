{
  "script_id": "03096006",
  "title": "黄鹤楼",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    }
  ],
  "plot": "周瑜欲讨荆州，请刘备过江饮宴，于黄鹤楼四围，密布伏兵，如刘备不还荆州，不准下楼。刘备与赵云临行\n时，诸葛亮曾给赵云竹节一枝，并嘱危急时始可开视。刘备等知已中计，即将诸葛亮所赠之竹节劈开，得周\n瑜令箭一枝，君臣遂持令下楼，安然脱险。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四大铠引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "义得人和，灭孙曹，孤心安乐。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "日月重明照英雄，全仗卧龙建奇功。虽得地土归王化，依然未遂高祖风。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤、刘备。乃大树楼桑人氏。自从桃园结拜以来，弟兄三人也曾共破黄巾；三 顾茅庐，请来诸葛先生，共扶社稷。只因荆州之事，东吴屡屡催讨，使孤常怀 忧虑。正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "苍天遂人意，重整汉帝基。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封上。"
        },
        {
          "character": "刘封",
          "type": "念",
          "text": "忙将东吴事，报与父王知。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "参见父王！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "罢了，进帐何事？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "东吴有书信到来，父王请看。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呈上来，待孤一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。刘备看信。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，有请诸葛先生。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封下。"
        },
        {
          "character": "诸葛亮",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "东吴摆下杀人场，狸猫焉能胜虎狼。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生少礼，请坐！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢坐。宣臣进帐，有何军情议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "东吴有书信到来，先生请看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人不必观看，也曾打发甘宁回复他主，说主公即刻过江。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊先生，此番过江，那东吴是好意呀，还是奸计呢？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那周瑜诡计多端，焉有好意！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "既无好意，孤就不去了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公不去，荆州岂不是他人的了？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤去便去，必须多带人马才是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人自有调遣。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "全仗先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，四将军进帐！"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "忆昔长坂建奇功，冲锋对垒气概雄。曹兵闻名皆丧胆，谁人不知赵子龙！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云告进！参见主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟少礼，见过先生。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "参见先生！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "四将军少礼，一旁坐下！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "谢坐。唤为臣进帐，有何差遣？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生有差。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "先生有何差遣？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "东吴有书信到来，请主公过江饮宴，命将军保驾前往。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "但不知赐我君臣多少人马？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不带人马，就是你君臣二人。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "且慢！前番临江会上就是一君一臣，险些儿命丧东吴；此番过江又是君臣二人， 要去你去，孤是不去的了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公啊！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮原板",
          "text": "自古道吉人有天相， 主公何必挂愁肠？ 忆昔当年临江上， 二千岁保驾过长江。 此一番大胆东吴闯， 四将军保驾料无妨。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "先生把话错来讲， 休提起当年赴会在临江。 孙、刘结仇山海样， 孤岂肯把性命送与周郎！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "千言万语主不往， 倒叫山人无主张。 用言激动常山将，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "难道你也怕周郎？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "先生哪！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "百万军中曾独闯， 当阳救主姓名扬。 出入曹营无人档， 常山将军天下扬。 主公但把宽心放， 为臣保主过长江，料也无妨。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "他二人把话一样讲， 倒叫孤王无主张。 孤王若在东吴丧，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生哪！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "招孤的灵魂入庙堂。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，孤去便去，还是多带人马才是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "方才言过，就是你君臣二人。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "先生！我君臣此番黄鹤楼赴宴，不带人马，倘若伏兵四起，难道叫俺拳打足踢 不成？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "着哇！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "四将军莫非是要退兵之策么？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来来来，这有竹节一根，带在身旁，倘若黄鹤楼下伏兵四起，打开竹节一观， 能退周郎千员上将，百万雄兵！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云接竹节。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "慢来，慢来！四弟，你打开竹节，看看里面有多少人马？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "待臣看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云欲看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且慢，看过就不灵了！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "是呀！看过就不灵了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哪里是看过不灵，分明是孤的“引魂幡”喏！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公啊！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "小小竹节三尺长， 妙算神机个中藏。 将军且自好执掌， 自有妙计退周郎。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "先生妙计无虚谎， 君臣何日转还乡？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "本月十六日迎接你君臣还朝就是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哼哼！到那时你接孤的灵魂吧！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公，不要多虑，为臣自有安排！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "看衣更换！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "好一个大胆诸葛亮， 立逼孤王过长江。 龙潭虎穴孤去闯，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二红文堂同带马，刘备、赵云同上马。四红文堂、四大铠、赵云同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "送主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "你分明送孤王去见阎王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "主公难把宽心放， 面带忧愁过长江。"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哇呀呀呀……"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "心中恼恨诸葛亮， 做事不与某商量！ 怒气不息宝帐闯！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "快快还俺大兄王！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "可恼哇可恼！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁怒气不息，为着谁来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "某就为你来！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "为山人何来呢？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我且问你，俺大哥过江赴宴，怎不叫俺老张知道？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "叫你知道，也要前去；不叫你知道，也要前去。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我且问你，俺大哥过江赴宴，带领多少人马，大将几员？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不带人马，就是子龙一人。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊！四弟一人，焉能成功？待俺老张赶他回来！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且慢！赶他回来，也要前去；不赶他回来，也要前去。此事用你不着，出帐去 吧！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "诸葛亮啊，诸葛孔明！想俺大哥三顾茅庐，请你下山，实指望辅保汉室基业， 谁想你一事未成，反将俺大哥送入了虎口！诸葛亮啊，诸葛孔明！你好狠毒也！"
        },
        {
          "character": "张飞",
          "type": "西皮快板",
          "text": "东吴摆下杀人场， 你叫俺大哥过长江。 手摸胸膛想一想， 你是个人面兽心肠。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "主公过江把宴上， 本月十六转还乡。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你算得准？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "算得准。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "量得就？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "量得就。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "本月十六日若不回来呢？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "山人妙计有虚谎， 首级送到你营房。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好先生哪！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "先生妙计无虚谎， 休怪俺老张语癫狂， 不辞诸葛出宝帐，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": "张飞",
          "type": "西皮快板",
          "text": "背转身来自参详： 小周郎他的韬略广， 他不该一封书信将咱的大哥诓过江。 随带着常山子龙四弟一员将， 单单就不差涿州翼德俺老张。 先生的八卦无虚谎， 他算就了，俺的大哥，本月十六，驾定小舟，子龙保驾，一齐转还乡。 东吴地，摆战场， 俺老张带领人马杀长江。 俺大哥若在东吴丧： 我与那周郎刀对刀来枪对枪； 俺兄王若有那好和歹，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "周郎啊，咱的儿呀！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "难逃咱老张的丈八枪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞亮相，下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "东吴纵有千员将， 霜雪怎能见太阳。"
        },
        {
          "character": null,
