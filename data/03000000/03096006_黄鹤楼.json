          "character": "周瑜",
          "type": "西皮摇板",
          "text": "楼下兵多早围困，"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "猛虎何惧你犬一群！"
        },
        {
          "character": "周瑜",
          "type": "西皮摇板",
          "text": "谅你一人难取胜，"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "子龙将军胆包身。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "还俺的荆州来！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "还俺的东风来！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "周瑜",
          "type": "西皮摇板",
          "text": "赵云说话惹人恨，"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "刘备呀，刘备！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜扯衣。"
        },
        {
          "character": "周瑜",
          "type": "西皮摇板",
          "text": "不还荆州难逃生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备惊坐。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "你要荆州俺应允，"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "拿来！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "周郎！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "你东吴还有几美人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜气极，下楼。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众将官，尔等高声喊叫：叫那刘备写下腾国文约。有本督令箭，放他君臣回转 荆州，无有本督令箭，不许放他君臣下楼，违令者斩！"
        },
        {
          "character": "周瑜",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜下。刘备昏。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公醒来！主公醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备醒，惊，两望。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "诸葛亮啊！你害死我君臣也！"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "勒逼孤王把宴饮， 黄鹤楼上遇灾星， 周郎今日要孤的命！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟呀！"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "快想良策救孤身！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，四弟呀，周郎叫孤写下腾国文约，这便如何是好？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公可记得在那长坂坡——"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "嘿嘿！又是他那长坂坡！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "马踏曹营七进七出，何惧这小小的黄鹤楼上啊。"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "长坂坡前逞英勇， 何惧东吴百万兵！ 周郎虽然有本领， 为臣赤手也要斗蛟龙！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀四弟呀！想当年你在那长坂坡前掌中有枪，胯下有马，今日在这黄鹤楼上， 难道叫你拳打足踢不成？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哎呀！这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乱锤。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公啊，临行之时，先生赐俺竹节一根，言道：你我君臣在黄鹤楼有难，打开 竹节，能退周郎千员猛将。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，此乃是那妖道的谣言哪。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "待臣看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云望竹节自语。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "竹节呀竹节！先生道你能退周郎千员猛将，事到如今，我君臣在黄鹤楼上有难， 你是怎的不言，怎的不语？"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "先生道你能退兵， 此时怎不现真形？ 打破竹节观动静，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云破竹节。"
        },
        {
          "character": "赵云",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "内藏周郎令一根。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公醒来，你我君臣有救了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "救在哪里？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "是臣打破竹节，内藏周郎令箭一支。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我却不信。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备看。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "水军都督周。嘿嘿，这才是孤的好先生！ 四弟快快搀孤下楼。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云搀刘备同下楼。甘宁、鲁肃同上。"
        },
        {
          "character": "鲁肃、甘宁",
          "type": "同白",
          "text": "你君臣为何私自下楼？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "现有你家都督令箭在此。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "我却不信？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "拿去看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云递令箭。鲁肃接令箭看。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有请都督！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "念",
          "text": "子龙性命在我手，刘备难下黄鹤楼。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊大夫，那刘备可曾写下腾国文约？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他君臣下楼走了。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊！何人放他君臣下楼？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是都督放他君臣下楼的呀。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "我何曾放他君臣下楼啊？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "现有都督令箭在此。都督请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃交令箭。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "拿来我看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜接令箭看。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜气。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊都督，既放他君臣下楼，为何又生气呀？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "呃！我岂肯放他君臣下楼？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "都督不肯，这支令箭又是哪里来的？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀大夫啊，想当年赤壁鏖兵，火烧战船，我命那孔明，在南屏山祭借东风， 赐他这支令箭，谁想东风一起，他带箭逃走！不料如今它、它、它、它还在！ 诸葛亮啊，诸葛孔明！我不杀你，誓不为人也！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊，都督，谅他君臣走之不远，何不驾舟追赶？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "言得极是。 众将官，快快驾舟追赶刘备去者！"
        },
        {
          "character": "四白文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜前行，背身亮住。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊都督，你小心令箭哪！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "这！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜气。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜掏翎子、亮相，下。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}