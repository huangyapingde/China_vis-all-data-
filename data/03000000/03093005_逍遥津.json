        {
          "character": "二王子",
          "type": "同二黄摇板",
          "text": "弟兄们跪宫廷珠泪滚滚， 尊一声曹外公细听详情： 我二人虽不是曹母生养， 却犹如亲生母不差毫分！"
        },
        {
          "character": "二王子",
          "type": "同哭头",
          "text": "大丞相！曹外公！我的老外公啊！"
