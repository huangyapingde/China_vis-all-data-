          "character": "汉献帝",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "向前哀告老外公！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "儿呀，向前哀告去吧！"
        },
        {
          "character": "二王子",
          "type": "同白",
          "text": "待我二人向前。 曹丞相！曹外公！我二人虽非曹母养，犹如曹母所生，哀求老外公放我二人一 条生路，纵死九泉，也是瞑目甘心的呀……"
