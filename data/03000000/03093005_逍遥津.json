{
  "script_id": "03093005",
  "title": "逍遥津",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "汉献帝",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "穆顺",
      "hangdang": "老生"
    },
    {
      "name": "伏后",
      "hangdang": "旦"
    },
    {
      "name": "华歆",
      "hangdang": "丑"
    }
  ],
  "plot": "汉献帝惧曹操权势，欲除之，密诏诸侯，剪灭曹操，遣内侍穆顺带诏出宫。曹操知，从穆顺发髻内搜出密诏，\n杀穆顺、伏后及伏完全家，又进宫以药酒毒杀二皇子。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌、张辽同上。"
        },
        {
          "character": "张辽",
          "type": "引子",
          "text": "腰挂昆吾剑，身披虎将衣。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "堂堂英雄将，热血染沙场。辅佐曹丞相，定国安家邦。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "俺，张辽。汉室为臣。只因献帝懦弱，不能治国安邦。我今相请文武两班，欲 将龙床推倒，扶保曹丞相登极，方称我心头之愿。 来！"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "众位大人到此，速报我知！"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、二旗牌同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘同上。"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同点绛唇",
          "text": "懦弱之君，社稷将倾；干戈兴，国不安宁，诸侯相吞并！"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "下官——"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "司马懿。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "华歆。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "贾诩。"
        },
        {
          "character": "郄虑",
          "type": "白",
          "text": "郄虑。"
        },
        {
          "character": "王粲",
          "type": "白",
          "text": "王粲。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "曹植。"
        },
        {
          "character": "文聘",
          "type": "白",
          "text": "文聘。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "众位大人请了！"
        },
        {
          "character": "司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "张将军有帖相邀，不知为了何事？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "我等也为此事而来，你我一同前往。"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘同走圆场。二旗牌、张辽同上。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "柳营春试马，虎帐夜谈兵。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "众位大人到！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘同进门，同坐。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "不知众位大人驾到，有失远迎，当面恕罪！"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "来得鲁莽，将军海涵。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "将军相约，为了何事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "众位有所不知，只因当今万岁懦弱，不能治国安邦，以致烟尘四起，生灵涂炭！ 故而相请商议，将龙床推倒，扶保曹丞相登极，不知众位大人意下如何？"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "张将军高见，我等皆服。就请依此而行！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "你我转至朝房。"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘同走圆场。"
        },
        {
          "character": "院子",
          "type": "内白",
          "text": "荀尚书到！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、荀攸同上。"
        },
        {
          "character": "荀攸",
          "type": "念",
          "text": "忧国常带病，何日称我心。"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "荀尚书！"
        },
        {
          "character": "荀攸",
          "type": "白",
          "text": "列公请坐！"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "荀攸",
          "type": "白",
          "text": "列位大人，为何来得甚早？"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "张将军相邀我等。"
        },
        {
          "character": "荀攸",
          "type": "白",
          "text": "张将军相邀，所为何事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "只因献帝懦弱，不能治国安邦，以致烟尘四起，生灵涂炭，故而相邀众位大人， 欲将龙床推倒，扶保曹丞相登极！如今众位大人皆服此议。"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "我等皆服。"
        },
        {
          "character": "荀攸",
          "type": "白",
          "text": "你们将龙床推倒，扶保曹丞相登极，不知欲将吾主置于何地？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "众位大人！自古道：老而不死是为贼！"
        },
        {
          "character": "荀攸",
          "type": "白",
          "text": "华歆，你好生无礼也！"
        },
        {
          "character": "荀攸",
          "type": "唱",
          "text": "华歆出言无君臣， 枉受我主爵禄恩。 有口难说心头恨， 昏昏沉沉回府门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子扶荀攸同下。四校尉、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位大人，为何来得甚早？"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "张将军相邀我等。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "但不知为了何事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "只因献帝懦弱，不能治国安邦，故而特请众位大人到此，欲将龙床推倒，扶保 丞相登极，如今众位大人皆服愚见。"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "我等皆服此高见。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "休得胡言！自盘古以来，哪有臣坐君位之理！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "这！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "适才何人到此？"
        },
        {
          "character": "夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "荀攸尚书。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嘿嘿，这老儿欲效荀彧之故耳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "报！荀攸尚书回府，口吐鲜血而亡！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嘿，可叹哪，可叹！这老儿跟随老夫多年，如今口吐鲜血而亡，少时上殿，待 老夫奏明天子，赐他金井玉葬！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "谢丞相！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位大人：吏部之缺，不可一日无人掌管，老夫欲将我儿子建拜在贾大人名下 学习，权受吏部之职。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "贾大人请上，受晚生一拜！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位大人：我死之后，奉托列公立一碑文，镌上“汉大将军曹公之墓”数字， 也就够了！"
        },
        {
          "character": "张辽、夏侯渊、司马懿、华歆、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "我等记下了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "还有两处烟尘未扫！"
        },
        {
          "character": "张辽、夏侯渊、司马懿、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "哪两处？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "东吴孙权，虎踞江东；西蜀刘备，稳坐西川。两寇不除，乃是我朝心腹大患！ 少时上殿，一同启奏。正是："
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "父母仁慈子行孝，君王有道社稷牢。"
        },
        {
          "character": "张辽、夏侯渊、司马懿、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同念",
          "text": "但愿狼烟尽皆扫，"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "华歆",
          "type": "念",
          "text": "脱去红袍换黄袍！"
        },
        {
          "character": "张辽、夏侯渊、司马懿、贾诩、郄虑、王粲、曹植、文聘",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、穆顺、汉献帝同上。"
        },
        {
          "character": "汉献帝",
          "type": "引子",
          "text": "海晏河清，社稷宁，四海升平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、华歆、贾诩、夏侯渊、曹操自两边分上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "臣，曹操见驾，吾皇万岁！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "大丞相平身。赐坐！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "汉献帝",
          "type": "念",
          "text": "孤王立帝在许昌，文臣武将保家邦。南征北剿曹丞相，忠心耿耿保孤王。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "孤，汉室献帝。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗯呵！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "大丞相上殿，有何本奏？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "臣启万岁：外面有两处烟尘未扫，乃是我朝之后患！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "但不知是哪两处？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "东吴孙权，虎踞江东；西蜀刘备，稳坐西川。两寇不除，乃是后患！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "大丞相说哪里话来！自朕登极以来，诸事全仗丞相掌握，这些小事，可由丞相 自裁，何必问朕！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "何必问朕！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "昏王啊，昏王！今日上殿，好意奏明与你。你反说诸事全在俺曹操掌握之中， 倘被外邦闻知，岂不疑我是篡位的奸臣！也罢，待我就结果了你这昏王罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "昏王啊，昏王！今日当着众位大人在此，将某所作所为细表一番：想当年董卓 专权，李傕、郭汜等欺君叛逆，不是老夫颁请各路诸侯杀却董卓，剿除李傕、 郭汜，哪个保你这昏王许昌接位？老夫为你这江山，受尽千辛万苦，方为人上 之人！昔日宛城遇张绣，可怜我长子曹昂命丧马前；濮阳遇吕布，烧得老夫火 内逃生！赤壁遇周郎，华容遇关羽。潼关遇马超，杀得老夫割须弃袍，被那马 超一眼看准，提枪就刺，真乃天不灭曹，这一枪刺于柳树之上，马超一时拔枪 不出，老夫才得活命！我为你这江山——可怜哪，可怜！渴饮刀头血，倦在马 上眠，桩桩费辛劳，件件受熬煎。我为你这江山，受尽千辛万苦，如今反说老 夫掌握大权，如被外邦闻知，老夫岂不是个大大的奸臣？今当众位大人在此， 不如将你这昏王结果了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、华歆、贾诩、夏侯渊同拦，曹操亮相，下，司马懿、华歆、贾诩、夏侯渊同随下。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "汉献帝",
          "type": "唱",
          "text": "奸贼做事太不仁， 带剑上殿刺寡人。 内侍摆驾后宫进， 安排妙计除奸臣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝、穆顺、四太监同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、伏后、曹妃同上。"
        },
        {
          "character": "伏后",
          "type": "念",
          "text": "风吹玉珮响，"
        },
        {
          "character": "曹妃",
          "type": "念",
          "text": "明月照纱窗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、穆顺、汉献帝同上。"
        },
        {
          "character": "汉献帝",
          "type": "唱",
          "text": "内侍摆驾回宫廷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同下。"
        },
        {
          "character": "汉献帝",
          "type": "唱",
          "text": "见了梓童说分明。"
        },
        {
          "character": "伏后",
          "type": "白",
          "text": "妾身见驾，吾皇万岁！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "平身。赐坐！"
        },
        {
          "character": "伏后",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "可恼哇，可恼！"
        },
        {
          "character": "伏后",
          "type": "白",
          "text": "万岁为何这样烦恼？"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "梓童有所不知，今日早朝只因曹——"
        },
        {
          "character": "曹妃",
          "type": "白",
          "text": "万岁，曹什么？"
        },
        {
          "character": "伏后",
          "type": "白",
          "text": "御妹，去至光禄寺，安排早膳去吧！"
        },
        {
          "character": "曹妃",
          "type": "白",
          "text": "是。适才万岁说个“曹”字，皇姐命我出宫，必有隐情！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹妃想。"
        },
        {
          "character": "曹妃",
          "type": "白",
          "text": "嗳，且自由他。正是："
        },
        {
          "character": "曹妃",
          "type": "念",
          "text": "闭户懒观窗外月，一任梅花自主张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹妃下。"
        },
        {
          "character": "伏后",
          "type": "白",
          "text": "万岁，“曹”什么？"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "适才曹操带剑上殿，欲刺寡人，不是众卿保驾，险遭不测！"
        },
        {
          "character": "伏后",
          "type": "白",
          "text": "既然如此，万岁何不写下血诏，搬请各路诸侯，共灭逆贼，以安社稷。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "只好如此，看白绫伺候！"
        },
        {
          "character": "汉献帝",
          "type": "西皮导板",
          "text": "奸贼金殿行霸道，"
        },
        {
          "character": "汉献帝",
          "type": "西皮原板",
          "text": "刺杀孤王为哪条？ 含悲忍泪把指咬， 鲜血淋淋写根苗。 上写谕示众卿晓， 各路诸侯把血诏瞧： 朝中出了——"
        },
        {
          "character": "汉献帝",
          "type": "西皮快板",
          "text": "奸曹操， 上欺天子下压群僚。 众卿领兵速来到， 共灭奸贼保皇朝。 一封血诏忙修好，"
        },
        {
          "character": "汉献帝",
          "type": "西皮散板",
          "text": "无有忠良走一遭！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "只是无人有此胆量，去往各路搬请救兵，也是枉然！"
        },
        {
          "character": "伏后",
          "type": "白",
          "text": "我看穆顺，忠心耿耿，何不命他前去。"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "穆顺！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "只因曹操带剑上殿，欲刺孤王，多亏众卿保驾，才得回宫。如今修下血诏，命 卿搬取各路诸侯，共灭曹贼，卿家可有此胆量？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "曹操欺君，奴婢万死不辞！"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "如此，请上受孤一拜！"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "穆爱卿请上孤拜定， 搬兵事儿你担承。 血诏交与梓童手，"
        },
        {
          "character": "伏后",
          "type": "二黄摇板",
          "text": "双手付与穆爱卿。"
        },
        {
          "character": "穆顺",
          "type": "二黄导板",
          "text": "君臣们只哭得珠泪滚滚，"
        },
        {
          "character": "穆顺",
          "type": "叫头",
          "text": "万岁，娘娘！"
        },
        {
          "character": "穆顺",
          "type": "哭",
          "text": "万岁呀……"
        },
        {
          "character": "穆顺",
          "type": "回龙",
          "text": "我朝中出奸佞谋篡龙庭。"
        },
        {
          "character": "穆顺",
          "type": "二黄原板",
          "text": "将皇诏藏至在袍袖内， 泄露机密功难成。 将皇诏藏至在靴筒内， 恐怕欺了圣明君。 左难右难难坏了我，"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "有了！"
        },
        {
          "character": "穆顺",
          "type": "二黄摇板",
          "text": "忽然心内巧计生。 将皇诏藏至在发髻内， 大罗神仙难知情。 辞别万岁出宫廷，"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "穆卿转来！"
        },
        {
          "character": "穆顺",
          "type": "二黄摇板",
          "text": "万岁有话快说明！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "奴婢去得好好，万岁唤我为了何事？"
        },
        {
          "character": "汉献帝",
          "type": "白",
          "text": "此番出宫须要小心，若遇曹贼，你我君臣就不能见面了！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "穆顺",
          "type": "二黄摇板",
          "text": "万岁一言错出唇， 只恐出宫遇仇人。 含悲忍泪出宫廷， 舍死忘生走一程！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆顺下。"
        },
        {
          "character": "汉献帝",
          "type": "二黄摇板",
          "text": "但愿救兵早来到， 灭却奸贼整吾朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉献帝、伏后同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、夏侯渊同上。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "俺，夏侯渊。今奉丞相之命，巡查御街。 来，掌灯前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆顺上，过场，下。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "啊，适才何人打此经过？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "穆公公！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "他往哪道而去？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "往伏相府而去！"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "且住！穆顺出宫，竟往伏相府而去，其中定有奸诈！ 来，打道相府，报与曹丞相知道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "穆顺上。"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "来此已是伏相府，门上哪位在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "烦劳通禀：穆顺求见相爷。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请相爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伏完上。"
        },
        {
          "character": "伏完",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "穆公公求见。"
        },
        {
          "character": "伏完",
          "type": "白",
          "text": "说我出迎！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "家爷出迎！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "啊相爷！"
        },
        {
          "character": "伏完",
          "type": "白",
          "text": "穆公公到此何事？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "今有奸贼曹操，在金殿之上，带剑欲刺吾皇，万岁有血诏在此，相爷请看！"
        },
        {
          "character": "伏完",
          "type": "白",
          "text": "待我看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。伏完看血诏。"
        },
        {
          "character": "伏完",
          "type": "白",
          "text": "原来如此！一路之上须要小心！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "告辞啦！"
        },
        {
          "character": "伏完",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆顺、伏完自两边分下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、司马懿、华歆、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "适才夏侯渊报道：穆顺出宫，慌慌张张往伏相府而去，其中定有别情！ 校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "打道午门！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。"
        },
        {
          "character": "四校尉",
          "type": "白",
          "text": "来到午门！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "穆顺到此，速报我知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆顺上。"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "适才在伏相府将我主之事，告诉一番，朝内之事托他照应，谅必无妨。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "哎呀！午门以外，这等喧哗，定是曹贼在此！咳，真真不凑巧！不免转去！"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "丞相，那旁穆顺来了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "叫他回来！"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "是。 穆公公请转，曹丞相在此！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "被他们看见了，待我上前说几句话，再做道理。咳！"
        },
        {
          "character": "穆顺",
          "type": "念",
          "text": "恼人记在心，相见又何妨！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "原来是曹丞相，曹国丈，曹外公！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "穆公公，清早出宫，有何贵干？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "这个……哦，娘娘有病，命咱家出宫去请太医，与娘娘调治病症。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "娘娘得何病症？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "娘娘得了气闷不和之症。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "医生为何不到？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "他是问病而下药。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "用的是什么药？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "乃是君臣父子礼义汤。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗳，药内还有什么君臣？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "大丞相，我朝没有君臣，难道连药也没有君臣了吗？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我朝是谁无有君臣？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "就是李傕、郭汜、董卓之辈。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "如今何在？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "都被大丞相剑下诛之！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嘿嘿！好个剑下诛之！何药为君？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "香附子为君。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "何药为臣？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "藕节莲子为臣。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "何药为凑？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "东吴当归，西蜀橘红，吃在腹内，也好杀虫！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "当归就说当归，橘红就说橘红，说什么东吴当归，西蜀橘红？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "这个，丞相不知，东吴出的当归，西蜀出的橘红，这岂不是东吴当归，西蜀橘 红吗？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "如此，老夫多问了。请便！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "告辞啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆顺疾走，跌绊，下。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "丞相，穆顺临行之时，绊了一跤！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "叫他回来！"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "是。 穆公公请转！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆顺上。"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "大丞相，咱家去得好好，唤我回来何事？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你为何绊了一跤？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "这个！只因万岁赐我一件蟒袍，长了三寸，走路有些不便，故而绊了一跤！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "就该用刀割去！"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "有道是：成物不可损坏！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你今此来，有奸？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "无奸。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有诈？"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "无诈。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "既无奸诈，老夫我要——"
        },
        {
          "character": "穆顺",
          "type": "白",
          "text": "要怎么样？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "要盘！"
