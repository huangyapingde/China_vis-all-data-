      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "史可法上。"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "恨多铎他把那扬州围困， 兵又单粮又缺怎样守城？ 怕只怕早晚间清兵攻进， 万岁爷到那时怎样逃生！ 将身儿来至在宝帐坐定， 且听那各城门来报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启禀元帅：众百姓前来捐助军饷。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "哎，难得呀难得！百姓尚有如此忠义之心。我史可法虽死疆场，也瞑目矣。 来，传他等进见！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众百姓进见！"
