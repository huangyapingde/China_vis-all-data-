          "text": "众将官！"
        },
        {
          "character": "四文堂、四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "绊马索伺候！"
        },
        {
          "character": "四文堂、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同撒绊马索。史可法上，落马，被擒。四下手押史可法同下。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "听说福王在总镇衙内。 巴图鲁！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "搜查总督衙门！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "豫亲王、四文堂同走小圆场。阿隆武上。"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "启禀王爷：衙内并无一人。只有辕门号令、妇人人头一颗，并有晓谕军民的一 张手谕。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "但不知是何人的人头？"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "此乃史可法因捐助军饷，将他爱妾杀死。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "好一个史可法，真是千秋万古，青史名标，后人可以为法，真不愧“史可法” 三字。这样的将官，怎忍将他杀了。不免用好言劝他投降。 来呀！把史可法给我押上帐来！"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "王爷有谕：将史可法押上帐来！"
        },
        {
          "character": "四下手",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "史可法",
          "type": "内唱",
          "text": "被获遭擒上了绑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手押史可法同上。"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "为国家怎顾那生死存亡？ 最可怜崇祯爷煤山命丧， 有福王出京城投奔他乡。 那清兵追赶他如鱼漏网， 实指望到扬州重整家邦。 那多铎带人马追赶不放， 清兵将一个个胜过虎狼。 扬州城人马少又缺粮饷， 人又乏马又困怎样提防？ 遭暗算绊下马被贼捆绑， 到如今只落得有翅难张。 挺身躯来在了牛皮大帐， 愿一死尽忠节万古流芳。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "见了本爵，为何不跪？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "俺乃明室忠臣，岂肯跪你！"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "岂不闻“昔为坐上客，今为阶下囚”之说乎？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "兵家胜负，大将存亡，自古有之。你今一旦侥幸成功，便来自尊自大。看将起 来，你真有愧将帅之位，倒叫我好笑哇哈哈……"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "本爵倒被他取笑啦。 来来来，待本爵亲自与你解去枷锁。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "且慢！我乃被擒之将，你又何必如此！为何前倨而后恭也？"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "不是呀，将军忠义，命人钦佩。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "我忠于明朝，与你何于？"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "忠臣孝子，人人钦敬。如今明室已亡，天命归清。将军若肯归顺，有本爵保奏， 不失封王之位。将军你要再思呀再想！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "多铎把话错来讲， 苦苦劝我为哪桩？ 自古忠臣不怕死，"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "将军怎么样？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "多铎！"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "要我投降梦一场。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "要杀便杀，何必多言？"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "将军还是归降了吧！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "多铎不必存妄想， 史可法言来听端详： 杀身成仁古人讲， 舍生取义我应当。 史可法本是明朝将， 视死如归又何妨？ 倘若你再多言讲， 休怪骂你禽兽与豺狼！"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "豫亲王",
          "type": "唱",
          "text": "好心对你来言讲， 不该开口把人伤。 人来看过无情棒， 打折你筋骨痛肝肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "豫亲王三打史可法。史可法三摔屁股座子。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "史可法你俱也不惧？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "多铎呀多铎！你家史元帅天生钢胆，粉身碎骨，某何惧也！"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "我叫、叫、叫一声小多铎休得狂妄！ 我骂、骂、骂一声恶贼人猪狗心肠！ 史可法心与志铁石一样， 就是那赴汤火又待何妨？"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "王爷暂息雷霆之怒，不如将他斩首，倒成至了他的名节。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "如此将他推出斩首！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "推出斩首！"
        },
        {
          "character": "史可法",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈……"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "多铎那里传将命， 将我推出问斩刑。 手捧长枷礼恭敬，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法拱手。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "本爵将你斩首，反抱拳恭敬，莫非你悔过味儿来啦？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "非也！"
        },
        {
          "character": "史可法",
          "type": "唱",
          "text": "史可法言来听分明： 今日尽节丧了命， 谢你成全我万古名。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "走！ （史可法欲走。豫亲王犹豫，最后决意；示二下手押下介。二下手押史可法同下。〖内鼓声〗。二下手拿头 同上，同献。）"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "可惜一员大将！用上好棺木成殓起来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二下手拿头同下。"
        },
        {
          "character": "豫亲王",
          "type": "白",
          "text": "来，红旗报捷！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}