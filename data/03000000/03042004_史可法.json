{
  "script_id": "03042004",
  "title": "史可法",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "史可法",
      "hangdang": "老生"
    }
  ],
  "plot": "明末，史可法扶福王，任兵部尚书，督师扬州。值扬州荒旱，军饷不支。史可法乃尽捐家产，并斩吝惜首饰\n之二夫人示众。扬州军民，莫不感动，悉献金银，全力以赴。清致书劝降，史可法诈从之，调虎离山大败豫\n亲王前锋阿隆武。豫亲王大怒，举兵夹攻。史可法集军民，浴血苦守。终以寡不敌众，城破被执，不屈而死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "福王",
          "type": "内白",
          "text": "内侍！"
        },
        {
          "character": "李立",
          "type": "内白",
          "text": "有！"
        },
        {
          "character": "福王",
          "type": "内白",
          "text": "带路！"
        },
        {
          "character": "李立",
          "type": "内白",
          "text": "遵旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李立引福王同上。"
        },
        {
          "character": "福王",
          "type": "唱",
          "text": "国破家亡山河变， 蒙尘急走下江南。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "小王、福王朱由崧。可恨吴三桂迎清兵入关，引狼入室，取了北京，虽把那李 闯王赶走；只是大清顺治皇帝却在北京登基。小王逃奔在外。本欲传谕江南数 省，兴兵恢复明朝天下；怎奈清兵猛勇难敌，各省统兵大员，不是望风投降， 便是被清兵战败。因此小王落得无有立足之地。又兼清营追拿甚急，只得逃奔 江南，再图恢复。来此已是江苏地面。那扬州城内，现有总兵史可法带兵把守， 你我君臣投奔那里再作计较。"
        },
        {
          "character": "李立",
          "type": "白",
          "text": "奴婢也是这么想，主公只好先到扬州，传谕江南各省，带兵前来，与那清营决 一雌雄。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "如此，李立带路！"
        },
        {
          "character": "福王",
          "type": "唱",
          "text": "李立头前把路引， 君臣去到扬州城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "福王、李立同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八清兵同上，同站门。阿隆武上。"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "俺、豫亲王前部前锋阿隆武。奉王爷将令，兵发江南，追赶那明朝的福王。豫 亲王的人马随在后面。我不免催动人马，往江南进发，逢州取州，遇县夺县。 巴图鲁！"
        },
        {
          "character": "八清兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "兵发江南！"
        },
        {
          "character": "八清兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阿隆武、八清兵同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、中军、院子引史可法同上。"
        },
        {
          "character": "史可法",
          "type": "引子",
          "text": "镇守扬州，统貔貅，足智多謀。"
        },
        {
          "character": "史可法",
          "type": "念",
          "text": "皇恩浩荡重如山，官居一品镇江南。帐下儿郎有数万，赏别分明纪律严。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "本帅、史可法。大明驾下为臣。职授扬州总镇，统领江南人马。只因天下刀兵 乱起，李自成攻陷京都，不幸我主崇祯皇帝驾崩煤山。幸有福王逃出，在沿海 一带招聚明室旧臣，图谋恢复大明天下。只是大清已然登基，与我朝誓不两立， 派兵与我主福王在安徽大战，那清兵猛勇，听说明兵大败，我主福王不知生 死存亡。也曾派出远探前去打探，至今未见回报。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀元帅：福王万岁驾到营门。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "随我接驾去者！"
        },
        {
          "character": "四文堂、四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、中军、院子、史可法同走小圆场。李立引福王同上，史可法迎接。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "福王哭。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法甩帅盔、甩发、撮步跪走向前。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁！臣、史可法接驾来迟，罪该万死！"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家何罪之有，平身。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁请到帅府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、中军、院子、史可法、李立、福王同走小圆场，福王坐。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁为何落得这等模样？"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "一言难尽哪！"
        },
        {
          "character": "福王",
          "type": "唱",
          "text": "清兵杀绝又赶尽， 小王逃出安徽城。 急急忙忙神难定， 披星戴月赶途程。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁受惊，一路辛苦，此乃臣史可法之罪。万岁坐定，受臣呼礼参拜！"
        },
        {
          "character": "史可法",
          "type": "西皮散板",
          "text": "万岁坐上受臣拜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法拜。"
        },
        {
          "character": "史可法",
          "type": "西皮二六板",
          "text": "千拜万拜也是折不过臣的罪来。 臣带兵镇守在朝外， 不能北上解兵灾。 恨闯王倾兵把京城坏， 崇祯帝归天实可哀。 清兵虽把李闯败， 北面登基大不该。 万岁蒙尘逃京外， 倒叫为臣挂心怀。 清兵人马来得快， 势如潮水赶下来。 也是万岁事出无奈， 投奔扬州避祸灾。 但有为臣性命在， 誓与那清兵把阵排、死也应该。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家呀！"
        },
        {
          "character": "福王",
          "type": "唱",
          "text": "明朝江山气数尽， 卿家只恐枉劳心。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "史可法",
          "type": "西皮快板",
          "text": "说什么明朝江山气数尽？ 史可法言来听分明： 发动人马施号令， 誓保大明锦乾坤。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家有此忠心，孤王甚慰。只是这小小孤城，怎能抵挡那清朝虎狼之兵？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁不必忧心。可即传旨，命江南各省即日带兵，前来扬州，扶保万岁，与清 兵决一雌雄。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "如此待小王修旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。福王修旨。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "中军过来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "伺候元帅！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "你可差人不分昼夜，将万岁旨意分发江南各省！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "内衙排宴，与万岁压惊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "我乃清营远探是也。明朝福王逃奔扬州城内。不免回营报与先锋知道，就此马 上加鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八清兵引阿隆武同上。"
        },
        {
          "character": "阿隆武",
          "type": "唱",
          "text": "催动人马传将命， 兵发江南不稍停。 三军奋勇往前进！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": "阿隆武",
          "type": "唱",
          "text": "又听有人报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启先锋：明朝福王逃在杨州城内。"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "但不知扬州城何人镇守？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "总镇史可法镇守。"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "有多少人马？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "约有数万之众。"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "原来如此。本先行出兵以来，战无不胜，攻无不取。小小扬州，何足道哉？赏 你金牌一面，回营报与豫亲王知道！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "多谢先锋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "八清兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "阿隆武",
          "type": "白",
          "text": "兵发扬州！"
        },
        {
          "character": "八清兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阿隆武、八清兵同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘燮喜、毛旭、伍德、王启同上。"
        },
        {
          "character": "刘燮喜、毛旭、伍德、王启",
          "type": "同白",
          "text": "下官——"
        },
        {
          "character": "刘燮喜",
          "type": "白",
          "text": "刘燮喜。"
        },
        {
          "character": "毛旭",
          "type": "白",
          "text": "毛旭。"
        },
        {
          "character": "伍德",
          "type": "白",
          "text": "伍德。"
        },
        {
          "character": "王启",
          "type": "白",
          "text": "王启。"
        },
        {
          "character": "刘燮喜",
          "type": "白",
          "text": "诸位大人请了！"
        },
        {
          "character": "毛旭、伍德、王启",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "刘燮喜",
          "type": "白",
          "text": "接到福王谕旨，圣驾现在扬州总镇衙內。你我前去保驾！"
        },
        {
          "character": "毛旭、伍德、王启",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "刘燮喜",
          "type": "白",
          "text": "来此已是扬州总镇帅府。 门上有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "刘燮喜、伍德、王启、毛旭",
          "type": "同白",
          "text": "我等俱是地方官吏，特来见驾。现有手本在此，烦劳回禀史元帅代为转奏。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着。 有请元帅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法上。"
        },
        {
          "character": "史可法",
          "type": "念",
          "text": "军中传飞羽，再听好消息。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启禀元帅：现有扬州府一带地方官吏前来见驾。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "手本呈上！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "手本在此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军呈本。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法看本。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "有请圣驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李立引福王同上。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家何事？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "今有扬州一带地方官吏前来见驾。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "宣他等进来。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁有旨：扬州地方官吏见驾！"
        },
        {
          "character": "刘燮喜、毛旭、伍德、王启",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘燮喜、毛旭、伍德、王启同入。"
        },
        {
          "character": "刘燮喜、毛旭、伍德、王启",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "刘燮喜、毛旭、伍德、王启",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "孤今由安徽被清兵追赶，逃到此地。全仗众卿同心协力，共同恢复明朝天下。"
        },
        {
          "character": "刘燮喜、伍德、毛旭、王启",
          "type": "同白",
          "text": "臣等自当竭尽忠心！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：清营先锋，差人前来下书，元帅请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子呈书。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "莫非是清营下的战书？待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。史可法看书，扔书。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "可恼！"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家为何发怒？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁哪里知道。这封书信乃是劝降。为臣故尔发怒。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "原来如此。但不知上面是何言语？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁不看也罢！"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "内侍，将书信捡起，呈与孤看。"
        },
        {
          "character": "李立",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李立呈书与福王，福王念。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "“字启史元帅麾下：清朝定鼎，天命所归。大兵所到，战无不胜，攻无不取。 料扬州弹丸之地，决难保守。将军若知天命，将福王献出，归顺清朝，不失封 侯之位。望将革裁知！阿隆武。” 哦，原来如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "福王向史可法。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家，扬州孤城，可能保守？如若不能，倒不如将小王献出，富贵荣华，封侯 之位，岂不唾手而得？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁说哪里话来？臣闻：忠则尽命，誓死报国。臣愿意率三军人马，与清兵决 一雌雄。如上苍保佑，一战成功；如若不胜，臣有死以报君恩！"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "卿家计将安在？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "臣与那阿隆武修下书信，就说三日之后，开城投降。约他带兵城外接应。臣暗 中派人绕道放火烧了他的营寨，贼兵必然大乱，便可一战成功。"
        },
        {
          "character": "福王",
          "type": "白",
          "text": "此计甚好。卿家修书。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "遵旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法修书。〖牌子〗。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "中军过来！将这封书信交与来人，呈与阿隆武观看。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "众位大人，计策已定，三日之后，便要与清兵大战。这对敌之事，自有下官一 马当先；军中粮饷，向请各位大人尽心筹划。"
        },
        {
          "character": "刘燮喜、毛旭、伍德、王启",
          "type": "同白",
          "text": "扬州地方连年荒旱，怎样筹划？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "既然如此，我等身受国恩，自当以身作则，将我等家财捐作军饷，然后劝募民 捐。也就是了。"
        },
        {
          "character": "刘燮喜、毛旭、伍德、王启",
          "type": "同白",
          "text": "我等遵命。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "万岁，请到后衙歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李立引福王同下。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "众位大人，也请各自回衙料理军务！"
        },
        {
          "character": "刘燮喜、毛旭、伍德、王启",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "家院，去到花园传话与二夫人，叫他将金银珠宝、簪环首饰，一并拿出，捐助 军饷！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "军卒们走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同上。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "带马！巡查去者！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法、四文堂同下。"
        }
      ]
    },
