{
  "script_id": "03009001",
  "title": "黄一刀",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "姚刚",
      "hangdang": "净"
    },
    {
      "name": "黄飞刚",
      "hangdang": "武丑"
    },
    {
      "name": "马清",
      "hangdang": "副净"
    },
    {
      "name": "杜明",
      "hangdang": "武生"
    },
    {
      "name": "黄妻",
      "hangdang": "武旦"
    },
    {
      "name": "愣儿",
      "hangdang": "丑"
    },
    {
      "name": "刘老头",
      "hangdang": "外"
    }
  ],
  "plot": "东汉，姚期之子姚刚与马清、杜明殴杀奸臣郭荣，因被发配湖北。在解送途中，经过黄土冈地方。当地有恶\n霸黄飞刚夫妇，开设肉肆，欺压乡里。姚刚闻知其事，亲至肉肆，借端寻殴，终将恶霸除灭。",
  "notes": "这个剧本经苏连汉先生协助校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二解差同上。"
        },
        {
          "character": "解差甲",
          "type": "念",
          "text": "奉命差遣，槪不由己。"
        },
        {
          "character": "解差甲",
          "type": "白",
          "text": "伙计请啦！"
        },
        {
          "character": "解差乙",
          "type": "白",
          "text": "请啦！"
        },
        {
          "character": "解差甲",
          "type": "白",
          "text": "你我奉了上司之命，解押三位王爷，发配湖北。天不早啦，请出三位王爷，咱 们该趱路啦。 有请三位王爷！"
        },
        {
          "character": "姚刚",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚刚、马清、杜明同上。"
        },
        {
          "character": "马清、杜明、",
          "type": "同念",
          "text": "御街闯下祸，"
        },
        {
          "character": "姚刚",
          "type": "念",
          "text": "发配受折磨。"
        },
        {
          "character": "解差甲、解差乙",
          "type": "同白",
          "text": "参见三位王爷！"
        },
        {
          "character": "姚刚、马清、杜明",
          "type": "同白",
          "text": "罢了。请出三位王爷何事？"
        },
        {
          "character": "解差甲",
          "type": "白",
          "text": "天不早啦，请三位王爷趱路。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "天早住在哪里？天晚住在哪里？"
        },
        {
          "character": "解差甲",
          "type": "白",
          "text": "天早住在十里堡，天晚住在黄土冈。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "店钱呢？"
        },
        {
          "character": "解差甲",
          "type": "白",
          "text": "开付过了。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "好。趱行！"
        },
        {
          "character": "马清、杜明",
          "type": "同唱",
          "text": "昏王无道江山掌， 信宠奸佞乱朝纲。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "二位贤弟！"
        },
        {
          "character": "姚刚",
          "type": "唱",
          "text": "咱父保汉忠良将， 怎奈围困在番邦。 豪杰领兵把贼挡， 只杀得番王拱手降。 万岁皇爷龙恩降， 封俺一字平南王。 跨马游街精神爽， 偶遇见郭荣老贼站道旁。 他拿恶言来冲撞， 剑劈老贼一命亡。 西宫娘娘本奏上， 万岁传旨宣姚刚。 遵旨就把金殿上， 抬头见父泪汪狂。 忍痛吿别把马上， 宛子城保定了殿下刘庄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孟强、薛霸同上。"
        },
        {
          "character": "孟强",
          "type": "唱",
          "text": "京中奉了老王命，"
        },
        {
          "character": "薛霸",
          "type": "唱",
          "text": "保护少主走一程。"
        },
        {
          "character": "孟强",
          "type": "白",
          "text": "俺、孟强。"
        },
        {
          "character": "薛霸",
          "type": "白",
          "text": "薛霸。"
        },
        {
          "character": "孟强",
          "type": "白",
          "text": "你我奉了老王之命，保护三位少王爷。就此马上加鞭！"
        },
        {
          "character": "孟强",
          "type": "唱",
          "text": "催马加鞭往前进，"
        },
        {
          "character": "薛霸",
          "type": "唱",
          "text": "见了少王说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟强、薛霸同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄飞刚上，愣儿暗上。"
        },
        {
          "character": "黄飞刚",
          "type": "数板",
          "text": "学习拳棒手段高，横行乡里逞英豪；四两半斤凭我给，谁人不知黄一刀！"
        },
        {
          "character": "黄飞刚",
          "type": "念",
          "text": "英雄无人比，两膀千斤力。霸占房粮地，抢夺美貌妻。"
        },
        {
          "character": "黄飞刚",
          "type": "白",
          "text": "俺、黄飞刚。大哥飞龙，二哥飞信，俱做绿林中的买卖。我夫妻二人就在这黄 士冈开了一座肉铺。我一家养猪，大家轮流送食供养。哪家送食不到，我妻子 找上门去，轻者是打，重者放火烧房。"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "那也不是吹。"
        },
        {
          "character": "黄飞刚",
          "type": "白",
          "text": "这且不言。我大哥、二哥在万全山，许久无有音信。我有意前去寻找，只是铺 中之事无人照管，不免将妻子唤出商议商议。 愣儿，有请大奶奶！"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "有请大奶奶！"
        },
        {
          "character": "黄妻",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄妻上。"
        },
        {
          "character": "黄妻",
          "type": "念",
          "text": "夫妻霸占黄土冈，谁人不知母阎王！"
        },
        {
          "character": "黄飞刚",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "有坐。将为妻唤出，有何话讲？"
        },
        {
          "character": "黄飞刚",
          "type": "白",
          "text": "二位兄长许久无有音信，我意欲前去寻找，只是铺中之事无人照管。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "大郞但放宽心，家中之事，有为妻照管，料也无妨。但不知几时起程？"
        },
        {
          "character": "黄飞刚",
          "type": "白",
          "text": "我这就走。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "愣儿，备马去。"
        },
        {
          "character": "黄飞刚",
          "type": "白",
          "text": "带马。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄飞刚下。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "愣儿，咱们猪食今儿该谁送啦？"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "待我算算：张家、李家、赵家……唉，今天是开店的刘老头儿。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "他怎不给送来呀？"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "大奶奶不去，他不给。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "找他去！"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "好，找找这个刘老头去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄妻、愣儿同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "姚刚",
          "type": "内唱",
          "text": "暑热炎天似火烧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚刚、马清、社明、解差甲、解差乙同上。"
        },
        {
          "character": "姚刚",
          "type": "唱",
          "text": "浑身上下汗滔滔。"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "天不早啦，三位王爷，咱们该打店啦。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "向前打店！"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "是。 店家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘老头上。"
        },
        {
          "character": "刘老头",
          "type": "念",
          "text": "开的是店，卖的是饭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘老头开门。"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "原来是二位上差。敢是投宿么？"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "可有上房？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "有上房。"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "回禀三位王爷，有上房。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "打进去！"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "二位上差，敢莫是三个强盗？"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "不要胡说，此乃三位王爷，还不向前见礼！"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "参见三位王爷！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "罢了，起过一旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟强、薜霸同上。"
        },
        {
          "character": "孟强",
          "type": "白",
          "text": "店家！"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "敢是投宿的？"
        },
        {
          "character": "孟强",
          "type": "白",
          "text": "可有上房？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "上房被三位王爷占去了。"
        },
        {
          "character": "孟强",
          "type": "白",
          "text": "王爷在此。将马带过。 参见三位王爷！"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "罢了。你二人到此何事？"
        },
        {
          "character": "孟强",
          "type": "白",
          "text": "奉了老王爷之命，保护三位少王爷。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "二位贤弟，还是你我老爹爹惦念你我。"
        },
        {
          "character": "马清、杜明",
          "type": "同白",
          "text": "惦念你我。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "家将叫他们把刑具去掉！"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二解差同去锁链。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "店家，你们这里可有什么吃食？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "我们这里有小米饭、窝窝头、拌豇豆加香油。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "俱都不好。可有上等饭食？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "我们这里有米星巴拉疙疸汤。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "咦，二位贤弟，你我弟兄每日在朝，未曾吃过什么米星巴拉疙疸汤。"
        },
        {
          "character": "马清、杜明",
          "type": "同白",
          "text": "倒要尝上一尝。 店家，多做疙疸汤！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄妻、愣儿同上。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "叫他去！"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "刘老头儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘老头上。"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "参见大奶奶！"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "罢了。我问你买卖好不好？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "倒也不错。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "真个的猪食该谁送啦？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "待我想一想。该小老儿送了。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "为什么还不送去？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "只因店中来了三位王爷，把此事忘怀了。"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "大奶奶，他拿王爷吓唬咱们。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "拿王爷吓唬我？愣儿，噍噍他们后头有什么没有？"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "我看看去。 大奶奶，他们后头有热气腾腾的一锅疙疸汤。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "喂猪肥不肥？"
        },
        {
          "character": "愣儿",
          "type": "白",
          "text": "肥。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "好，都拿了走。"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "使不得。"
        },
        {
          "character": "黄妻",
          "type": "白",
          "text": "给脸不要脸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄妻、愣儿同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二解差同上。"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "店家，王爷问你哪，疙疸汤作熟了没有哪？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘老头上。"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "疙疸汤将将做熟，又被我们这里恶霸抢了去了。"
        },
        {
          "character": "二解差",
          "type": "同白",
          "text": "你瞧，你这乱儿闹得可不小。"
        },
        {
          "character": "姚刚",
          "type": "内白",
          "text": "店家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姚刚、马清、杜明、薛霸、盂强同上。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "店家，这般时候疙疸汤还未曾做熟，敢是轻慢你三位王爷不成么！"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "哎呀王爷呀！疙疸汤将将作熟，又被我们这里恶霸抢了去了。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "啊！那恶霸姓字名谁？"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "王爷请坐在椅儿上，细听小老儿说端详。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "慢慢讲来！"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "我们这里名叫黄土冈，有一个恶霸名叫黄飞刚。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "呕，黄飞刚！"
        },
        {
          "character": "刘老头",
          "type": "白",
          "text": "他有两个兄长：一名黄飞龙，一名黄飞信。弟兄三人惯作绿林打抢。"
        },
        {
          "character": "姚刚",
          "type": "白",
          "text": "是个强盗。"
        },
