{
  "script_id": "03003002",
  "title": "李广催贡",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "李广",
      "hangdang": "老生"
    }
  ],
  "plot": "周赧王即位，李广仍回朝奉君。时北海国三年未进贡赋，李广奉旨催征。入境后，纵观田园荒芜，岁歉不收，\n即不忍苛责；而国王更竭诚恳求，李广乃允许缓贡而归。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、李虎引李广同上。"
        },
        {
          "character": "李广",
          "type": "引子",
          "text": "奉旨代天，扫灭狼烟。"
        },
        {
          "character": "李广",
          "type": "念",
          "text": "剑气冲霄汉，文光射斗牛。略展经纶手，斩将觅封侯。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "本爵李广。周室驾前为臣，官拜奉命侯之职。只因北海三载未曾进贡，今奉圣 旨，北海催讨。今乃黄道吉日。 李虎，人马可齐？"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "齐备多时。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "吩咐外厢开道！"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "东方亮海水潮日出东海， 文武臣整朝衣齐拜金阶。 奉王命去至在北海地界， 但愿得此一去奏凯回来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四北兵引辽太同上。"
        },
        {
          "character": "辽太",
          "type": "引子",
          "text": "国乱民荒，奈天心，归向他邦。"
        },
        {
          "character": "辽太",
          "type": "念",
          "text": "孤本北海一国王，人祸天灾痛断肠。深忧周室兴风浪，孤王日夜不安康。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "孤，辽太在位。周室为上，我国为下。原许年年进贡，岁岁往朝。至今三载， 无宝奉上。他国必有良将，前来催贡，教孤何言答对？正是："
        },
        {
          "character": "辽太",
          "type": "念",
          "text": "忧从心上起，愁锁两眉尖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "匡罢上。"
        },
        {
          "character": "匡罢",
          "type": "念",
          "text": "忙将李广催贡事，奏与我国大王知。"
        },
        {
          "character": "匡罢",
          "type": "白",
          "text": "臣匡罢见驾，大王千岁！"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "平身赐坐。"
        },
        {
          "character": "匡罢",
          "type": "白",
          "text": "臣谢坐！"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "匡罢",
          "type": "白",
          "text": "臣启奏大王：闻得天朝李广前来催贡。大王作何准备？"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "孤王为此事忧虑在心，卿家有何良计？"
        },
        {
          "character": "匡罢",
          "type": "白",
          "text": "启奏大王：依臣之见，将李广打入天牢；然后兴动人马，杀上他邦，夺取他国 花花世界，有何难哉？"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "卿家此言差也！从前原许年年进贡，岁岁往朝。至今三载，无宝奉上；又要兴 兵杀上他邦，情理难容。"
        },
        {
          "character": "匡罢",
          "type": "白",
          "text": "大王啊！"
        },
        {
          "character": "匡罢",
          "type": "唱",
          "text": "大王说话懦无刚， 匡罢言来听端详： 将李广打入天牢内， 打一封战表到他邦。 他国纵有千员将， 难当为臣化龙枪。"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "卿家错把本奏上， 孤王言来听端详： 纣王无道乾坤丧， 人心归附周文王。 武王伐纣乾坤掌， 封孤北海为帝王。 军中无粮箭怎放？ 饥饿焉能手提枪？ 宁做一个太平犬， 不做一国丧乱王。"
        },
        {
          "character": "匡罢",
          "type": "唱",
          "text": "军中无粮去放抢， 打劫民间自有粮。 争下江山大王掌， 挂榜安民免钱粮。"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "卿家奏本性情犟， 细听孤王说端详： 从前邓虎兴兵将， 大战他国彩云庄。 久战不胜把命丧， 降书降表到他邦。 劝卿家休要性情犟， 怕的是马到临崖难收缰。"
        },
        {
          "character": "匡罢",
          "type": "唱",
          "text": "一言提起邓虎将， 背转身来自思量： 邓虎老将不能抗， 何况今日少栋梁！ 回头我把二本上， 再与大王作商量。"
        },
        {
          "character": "匡罢",
          "type": "白",
          "text": "依大王之见？"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "且听探马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "忙将李广催贡事，报与我国大王知。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启奏大王：天朝李广前来催贡，已到十里长亭。请旨定夺！"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "众卿站立两厢，听孤令下！"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "孤王忙把旨传降， 两班文武听端详： 大摆队伍接李广， 顺者昌来逆者亡。 吩咐人役往前上， 情理相待比杀砍强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、李广、李虎同上。"
        },
        {
          "character": "李广",
          "type": "西皮导板",
          "text": "李广打马出皇朝，"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "对对旌旗空中飘。 曾记北海打战表， 要夺我主九龙朝。 本爵领兵把贼剿， 只杀得他国无处逃。 原许下年年来进宝， 每岁进在我国朝。 至今三载无宝到， 龙颜大怒将我召。 金殿奉王旨一道， 命本爵催贡到他朝。 一路观看事不好， 黎民百姓远脱逃。 怨不得他国未进宝， 树无枝叶草无苗。 坐在马上传令号， 大小三军听根苗： 此番来至北海道， 恩威并用去服辽。 他要好言来哀告， 宽限几载转回朝； 他要言语行霸道， 就在他国动枪刀。 三军与爷前拥道， 我看辽太怎开消！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "辽太、匡罢、四朝官率四北兵摆对子同上。李广、李虎率四龙套同上。相见行礼。众人同下，同上。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "国主请上，李广参拜！"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "焉有不拜之理？"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "这就不敢！大人请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "辽太、李广同坐。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "不知大人驾到，未曾远迎，望乞恕罪！"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "岂敢！少来问候国主金安，望乞海涵。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "我主龙驾可安？"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "我主安泰。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "满朝文武可好？"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "俱有书信手本问候国主金安。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "有劳他们。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "宴齐！"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "看宴来！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "两厢摆宴，款待天使。 大人请！"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "国主请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同坐。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "请问国主，从前原许年年进贡，岁岁来朝，至今三载无宝奉上，是何理也？"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "大人哪！"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "未曾开言珠泪涌， 尊一声大人听详情： 大旱三载灾荒重， 黎民百姓受苦穷。 望大人回朝把本动， 宽限几载朝见主公。"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "国主说话理不通， 李广言来听分明： 从前不该刀兵动， 要夺我主锦疆洪。 我国兵多将又勇， 只杀得你国计皆穷。 原许下年年把宝奉， 每岁来朝见主公。 到如今三载未进贡， 情理二字实难容。"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "大人说话言语重， 羞得孤王脸通红。 下位来我把好言奉， 尊声大人听心中： 有劳你千里迢迢来催贡， 一路之上受霜风。 避毒仙帕来相送， 能解百毒妙无穷。 此宝并非将王送， 全仗大人多宽容。 自古道礼轻人意重， 望大人笑纳饮几盅。"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "谢过国主把宝赠， 李广言来听分明： 非是我李广不肯应， 圣命在身难依从。"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "孤王传旨山岳动， 两班文武听心中： 天朝大人来催贡， 每人奉敬酒一盅。"
        },
        {
          "character": "匡罢",
          "type": "唱",
          "text": "匡罢进前好言奉，"
        },
        {
          "character": "朝官甲",
          "type": "唱",
          "text": "尊声大人听详情："
        },
        {
          "character": "朝官乙",
          "type": "唱",
          "text": "我国无有别的奉，"
        },
        {
          "character": "朝官丙",
          "type": "唱",
          "text": "每人奉敬酒一盅。"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "他君臣全是好言奉， 个个脸上带笑容。 只要他不把刀兵动， 宽限几载也可容。 下位来我把好言奉， 国主宽怀免愁容。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "国主！宽你三年，以后年年进贡，岁岁来朝。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "大人开了天地之恩，俺君臣感恩不浅。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "俺、告辞了！"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "且慢！就在我国宽住几日，这有何妨？"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "圣命在身，难以久停。"
        },
        {
          "character": "辽太",
          "type": "白",
          "text": "大人留步！孤有一言，转奉天朝。"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "深感天朝恩泽广， 三呼万岁口称王。 但愿各国宝进上， 但愿主亚赛尧舜王。 倘若哪国敢犯上， 愿效犬马报君王。"
        },
        {
          "character": "李广",
          "type": "唱",
          "text": "国主但把宽心放， 你本是北海有道王。 本爵回朝把本上， 宽限几载见君王。 辞别国主把马上， 我主降罪俺李广承当。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李广率李虎、四龙套同下。"
        },
        {
          "character": "辽太",
          "type": "唱",
          "text": "天朝来了李广将， 仪貌堂堂杀气昂。 他本是天朝忠良将， 忠心耿耿世无双。 回头我对众卿讲， 孤王言来听端详： 自今以后休犯上， 各守疆界乐安康。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}