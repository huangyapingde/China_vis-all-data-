{
  "script_id": "03046006",
  "title": "飞虎山",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "安敬思",
      "hangdang": "小生"
    },
    {
      "name": "李克用",
      "hangdang": "净"
    },
    {
      "name": "周德威",
      "hangdang": "老生"
    },
    {
      "name": "李嗣源",
      "hangdang": "小生"
    },
    {
      "name": "李存信",
      "hangdang": "净"
    },
    {
      "name": "康君利",
      "hangdang": "丑"
    }
  ],
  "plot": "唐末，李克用夜梦飞虎入帐，知为得将之兆，遂出射猎。遇壮士安敬思打虎，李克用大喜，试以武艺，俱各\n精通，因收为“十三太保”，易名李存孝，且付先行大印。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引李克用同上。"
        },
        {
          "character": "李克用",
          "type": "引子",
          "text": "剑气光射高千丈，夜宿貔貅百万郎。"
        },
        {
          "character": "李克用",
          "type": "念",
          "text": "白发苍苍领雄兵，众家太保逞奇能。居庸关前收大将，扫尽狼烟定太平。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "孤，李克用。只因黄巢起兵，将唐主驾逼西秦，程贤弟来到沙陀搬兵，请孤王 兴唐勤王，是孤带领众家太保，行在居庸关前，收了周德威，此人文武双全， 正好做一臂膀。一路而来，犹如马走平川一般，看天色已晚，且到虎帐安歇。 来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "掌灯伺候！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同掌灯。〖起初更鼓〗。"
        },
        {
          "character": "李克用",
          "type": "二黄导板",
          "text": "听觱篥响一声初更已定，"
        },
        {
          "character": "李克用",
          "type": "二黄原板",
          "text": "想起了某当年在朝奉君。 唐天子掌朝纲风调雨顺， 有老夫保唐室东荡西除、南战北征。 得胜回在雅观楼恩赐御筵， 满朝中文武臣庆贺功勋， 段文楚他笑孤坐席不正， 孤一怒将国舅摔死埃尘。 唐天子要斩孤百官保命， 将孤王贬至在沙陀为民。 那黄巢兴人马江山不稳， 程敬思奉圣命到沙陀搬兵。 因此上统雄师奔赴王命， 为国家昼夜里哪得安宁。 叫人来掌红灯虎帐来进， 看几部圣贤书解闷散心。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "回避了！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同下。〖起二更鼓〗。"
        },
        {
          "character": "李克用",
          "type": "二黄原板",
          "text": "前三皇后五帝尧王传舜， 舜传禹夏商周屡代明君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "李克用",
          "type": "二黄原板",
          "text": "看古书已到了三更时分， 在虎帐只觉得困睡沉沉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用入帐睡。〖起四更鼓〗。虎形上，扑帐。"
        },
        {
          "character": "李克用",
          "type": "内二黄导板",
          "text": "孤王正在睡朦胧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用揭帐看。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "李克用",
          "type": "二黄摇板",
          "text": "只见飞虎入帐中。 手执宝剑将虎斩，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用拔剑斩虎形。虎形下。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李克用",
          "type": "二黄摇板",
          "text": "一阵清风影无踪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用入帐。〖起五更鼓〗。四文堂同上。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "千岁醒来！"
        },
        {
          "character": "李克用",
          "type": "二黄导板",
          "text": "适才帐中得一梦，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用出帐。"
        },
        {
          "character": "李克用",
          "type": "二黄摇板",
          "text": "不知此兆吉和凶？"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "传周德威进帐！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "周德威进帐！"
        },
        {
          "character": "周德威",
          "type": "内白",
          "text": "嗯嚇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德威上。"
        },
        {
          "character": "周德威",
          "type": "念",
          "text": "斩将擒王如反掌，文韬武略胸中藏。 儿臣参见父王！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "谢坐！唤儿臣进帐，有何军情议论？"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "昨晚偶得一梦，只见飞虎入帐。不知主何吉凶？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "此乃大吉之兆。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "想当年文王飞熊入梦，渭水访贤，得了姜尚。请父王传下将令：郊外射猎，或 者得遇贤臣良将，亦未可知。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "好。吩咐众家儿郎，各带本部人马，郊外射猎！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同下。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "李克用",
          "type": "念",
          "text": "夜梦飞虎入帐中，"
        },
        {
          "character": "周德威",
          "type": "念",
          "text": "郊外射猎访英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用、周德威同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安敬思上。"
        },
        {
          "character": "安敬思",
          "type": "引子",
          "text": "思亲泣流泪，愁锁皱双眉。"
        },
        {
          "character": "安敬思",
          "type": "念",
          "text": "小子生来命不强，自幼无父只有娘。多蒙员外恩抚养，每日南山去牧羊。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "小子、安敬思，自幼有母无父，不幸母又早亡。多蒙南村邓员外，将我抚养成 人。看今日天气晴和，不免往南山牧羊便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "羊形暗上。"
        },
        {
          "character": "安敬思",
          "type": "西皮导板",
          "text": "安敬思生来命不强，"
        },
        {
          "character": "安敬思",
          "type": "西皮慢板",
          "text": "朝朝暮暮在山岗。 遭不幸我母命早丧， 撇下了安敬思无奈何来牧羊。 那一日牧羊飞虎岗上， 偶遇道长叙衷肠。 他道我生来真贵相，"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "后来必定是皇家栋梁。 虽然话是这样讲， 富贵由命何在忙？ 将羊赶在南山岗，"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "怕风怕雨不怕虎狼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思赶羊形，同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、周德威、李存信、李嗣源、康君利引李克用同上。"
        },
        {
          "character": "李克用",
          "type": "念",
          "text": "旌旗遮日月，战鼓震乾坤。"
        },
        {
          "character": "周德威、李存信、李嗣源、康君利",
          "type": "同白",
          "text": "参见父王！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "周德威、李存信、李嗣源、康君利",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "兵发郊外！"
        },
        {
          "character": "周德威、李存信、李嗣源、康君利",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "风入松牌后半段。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "念",
          "text": "白云本是无根物，反被清风引出来。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "吾乃当方土地是也。今有铁石星君，命中要与李晋王见面。我奉玉帝勅旨，变 作樵夫模样，等李晋王到来，引他去到飞虎岗父子见面。一变两变——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地换装。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "樵夫出现。远远望见李晋王人马来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、周德威、李存信、李嗣源、康君利引李克用同上。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "来在山口。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "看山岗之上有一樵夫，听他讲些什么？"
        },
        {
          "character": "土地",
          "type": "樵歌",
          "text": "我本山中一尊神， 霎时变做砍樵人。 待等晋王来到此， 领他去见铁石星。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "砍樵噢，砍樵噢！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "将他唤了下来！"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "樵夫近前回话！"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "来了！ 叩见千岁！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "你在此砍柴，难道不怕豺狼虎豹么？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "此处并无豺狼虎豹。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "哪里有？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "前面有座飞虎岗，那里惯出豺狼虎豹。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "噢，飞虎岗？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "应孤梦兆也。樵夫！"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "引孤前去！"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "带路！"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "樵夫把话对我讲， 他言道前面有座飞虎岗。 但愿此去收良将，"
        },
        {
          "character": "李克用",
          "type": "西皮散板",
          "text": "收得良将保大唐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "羊形上，安敬思上。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "清晨起来雀噪嚷， 青山绿水紫气扬。 将羊赶在南山放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思上山。"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "苍松翠柏百花香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思睡。土地引四文堂、四大铠、周德威、李存信、李嗣源、康君利、李克用同上。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "夜梦飞虎入宝帐， 周德威进帐说端详。 他教孤王行围场， 去到郊外访栋梁。 大队人马朝前往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。土地暗下。"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "樵夫不见。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "樵夫不见为哪桩？ 下得马来山岗上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用下马，上山。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "青山绿水好清凉。 耳边听得风声响， 想必大虫下山岗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "弓箭伺候！"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "开弓便把雕翎放， 只见猛虎赶群羊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形扑羊形，同下。"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "猛虎吃羊。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "将娃娃唤醒！"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "娃娃醒来！"
        },
        {
          "character": "安敬思",
          "type": "西皮导板",
          "text": "耳边厢又听得人声喧嚷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思醒。"
        },
        {
          "character": "四文堂、四大铠",
          "type": "同白",
          "text": "猛虎吃羊。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "大胆猛虎吃咱羊。 手持大棍忙赶上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思赶下，赶虎形同上，打死虎形。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "娃娃无礼！"
        },
        {
          "character": "李克用",
          "type": "西皮二六板",
          "text": "娃娃做事太莽撞， 你不该把孤的家虎伤。 猛虎本是孤王养， 打死了猛虎要你抵偿。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "安敬思",
          "type": "西皮二六板",
          "text": "虎命羊命俱一样， 说什么懦弱论什么刚强？ 你的家虎吃咱羊， 豪杰打死又何妨？ 打死了你虎赔你虎， 叫你赔羊也应当！"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "娃娃说话有志量， 亚赛过当年楚霸王。 回头便对太保讲， 说几句大话吓儿郎。"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "李嗣源",
          "type": "西皮快板",
          "text": "父王山岗将令降， 命我大话吓儿郎。 将身跳过小溪涧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源作跳过溪涧，拍安敬思肩，安敬思作身段。"
        },
        {
          "character": "李嗣源",
          "type": "西皮快板",
          "text": "他的武艺果然强。 父王山头把话讲， 叫你前去作商量。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "俺亦不犯萧何律， 前去见他又何妨！ 翻身跳过小溪涧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思跳过溪涧。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "千岁有何话商量？"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "哪里生来哪里养？ 可有父来可有娘？"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "千岁爷不必问其详， 自幼无父只有娘。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "人生天地按阴阳， 哪有个无父只有娘？"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "千岁爷若问我的娘， 提起事儿话也长—— 我母自幼闺门长， 姐妹们闲游在山岗， 行走来在荒郊外， 见几个石人站立两旁。 姐妹抛篮作戏耍， 要将石人许配我的娘。 回家来不觉黄昏后， 只见石人进娘房。 十月怀胎将我养， 无衣无食来牧羊。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "你母今日何处往？ 叫她前来作商量。"
        },
        {
          "character": "安敬思",
          "type": "西皮散板",
          "text": "千岁爷休提起我的娘，"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "十一年前早已亡。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "娃娃休要泪悲伤， 哪有个人死又还阳？ 孤有太保十二个， 个个在朝伴孤王。 你若真心把孤降， 孤封你太保十三郎。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "早有此心来归降， 无人引荐拜君王。 多蒙千岁恩抚养， 躬身施礼拜父王。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "改名就叫李存孝， 从今后不离孤身旁。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "多蒙父王改名姓， 存孝二字永不忘。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "打虎的武艺孤见过， 不知你韬略强不强？"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "那一日打从山前往， 偶遇道长叙衷肠。 十八般武艺俱学好， 文韬武略胸中藏。"
        },
        {
          "character": "李克用",
          "type": "西皮快板",
          "text": "周军师说话不虚谎， 亚赛当年张子房。 李淳风，袁天罡， 鬼谷子王禅，孤好比周文王。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "将虎皮剥下，造成虎皮盔甲，与你十三王爷穿戴。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂抬虎形同下，同上。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "将暴烈乌骓马牵上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文堂甲下，牵马上。安敬思作按马。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "马力不佳，不称儿骑，"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "牵了下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文堂甲牵马下，上。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "军师，我营无有存孝的坐骑，如何是好？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "天生良将，必有良马。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "好，好一个“天生良将，必有良马”。 来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "将大太保的丈八蛇矛抬上来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二文堂同下，抬枪同上。安敬思舞枪。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "不称儿手。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "也罢！将孤家九九八十一斤定唐宝刀抬上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二文堂抬枪同下，抬刀同上。安敬思舞刀，舞毕，二文堂抬刀同下。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "也不称儿手。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "如此说来，唐营中无有儿的兵刃了。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "儿臣自有兵刃。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "现在何处？"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "后山土地祠内。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "取来我看！"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思下。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "军师，我看存孝，真乃是一员虎将。"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "可算一员虎将。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思拿笔捻抓上，放台中。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "启父王：兵刃到。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "尔等认来！"
        },
        {
          "character": "李嗣源",
          "type": "白",
          "text": "儿臣不知。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "嘿！身为大将，连兵器都不认得。"
        },
        {
          "character": "康君利",
          "type": "白",
          "text": "启父王：儿臣认得此物。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "叫什么？"
        },
        {
          "character": "康君利",
          "type": "白",
          "text": "乃是大块儿的鸡爪黄连。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "呸！待孤看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用看。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "哎呀，孤也不认得。 军师，此是何物？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "此乃“笔捻抓”，又名“混唐槊”，乃禹王治水所遗之物。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "儿可会耍？"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "儿臣会耍。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "耍来我看！"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思耍，下。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "军师，孤有意将先锋大印，付与存孝执掌，你意如何？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "恐众将不服。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "百步之外，立一高竿，悬挂金钱，有人射中金钱，方可挂得先锋大印。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "好。 众家太保！"
        },
        {
          "character": "周德威、李存信、李嗣源、康君利",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "站立两厢，听孤一令！"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "坐在山岗传令号， 大小儿郎听根苗： 今日收了李存孝， 众家太保夺红袍。"
        },
        {
          "character": "周德威、李存信、李嗣源、康君利",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军暗上，作擂鼓势。李嗣源上。"
        },
        {
          "character": "李嗣源",
          "type": "西皮摇板",
          "text": "父王山岗传令号， 众家太保夺红袍。 下马开弓箭放了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源射，中二箭。"
        },
        {
          "character": "李嗣源",
          "type": "西皮摇板",
          "text": "三枝中了箭二条。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李嗣源下。李存信上。"
        },
        {
          "character": "李存信",
          "type": "西皮摇板",
          "text": "军中来了李存信， 今日必要显奇能。 翻身下了马能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李存信射，中一箭。"
        },
        {
          "character": "李存信",
          "type": "西皮摇板",
          "text": "三枝中了箭一根。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李存信下。康君利上。"
        },
        {
          "character": "康君利",
          "type": "西皮摇板",
          "text": "父王命我射红袍， 今日必要闹糟糕。 下得马来箭放了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康君利与老军诨，射，三箭均不中。"
        },
        {
          "character": "康君利",
          "type": "白",
          "text": "咳嘿！"
        },
        {
          "character": "康君利",
          "type": "西皮摇板",
          "text": "三枝箭一枝没射着。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "斗大金钱射不着， 枉在唐营逞英豪。 不看兴兵事重要， 一捆四十定不饶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康君利下。"
        },
        {
          "character": "安敬思",
          "type": "内西皮导板",
          "text": "校场来了李存孝，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思上。"
        },
        {
          "character": "安敬思",
          "type": "西皮快板",
          "text": "争名夺利在今朝。 开弓便把箭射了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思射，中三箭。"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "射中红心箭三条。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "呔！唐营大小将官听者：哪一个敢与你十三王爷比箭哪？"
        },
        {
          "character": "周德威",
          "type": "内白",
          "text": "住口！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德威上。"
        },
        {
          "character": "周德威",
          "type": "西皮摇板",
          "text": "娃娃说话太张狂， 不由豪杰怒满膛。 人来看过弓和箭，"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "不看存孝看父王。 军师大印你执掌，"
        },
        {
          "character": "周德威",
          "type": "白",
          "text": "谢父王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德威下。"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "存孝休要逞刚强。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "启父王：儿臣一箭上去，能射红袍坠地。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "我儿不射也罢。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "儿臣一定要射！"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "好，射来我看。"
        },
        {
          "character": "安敬思",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "休道孩儿年纪小， 比箭哪放某心梢。 满满搭上箭一条，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安敬思射，红袍落地。老军暗下。"
        },
        {
          "character": "安敬思",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": "安敬思",
          "type": "西皮摇板",
          "text": "箭射柳枝坠红袍。"
        },
        {
          "character": "李克用",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "射得好来射得妙， 箭箭不差半分毫。 昔日孤王把唐保， 沙陀也曾射双雕。 麒麟阁摆酒筵不分大小，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李克用下山。"
        },
        {
          "character": "李克用",
          "type": "西皮摇板",
          "text": "父子们吃一个醉酕醄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}