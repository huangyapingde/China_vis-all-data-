{
  "script_id": "03034006",
  "title": "太君辞朝",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "宋仁宗",
      "hangdang": "老生"
    }
  ],
  "plot": "佘太君平定黄花国后，因惜杨氏后代，辞王别驾，告归林泉。宋仁宗君臣于十里长亭辞别。",
  "notes": "故事源出小说《杨家将》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨排风引佘太君同上。"
        },
        {
          "character": "佘太君",
          "type": "引子",
          "text": "杨家为国秉忠心，食王爵禄报君恩。"
        },
        {
          "character": "佘太君",
          "type": "念",
          "text": "天波府内众英雄，个个为国建奇功。可叹忠良今何在？到头只落一场空。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "老身，佘氏。配夫继业。投宋以来，世代尽忠。只因黄花国作乱，圣上命老身 带兵前去征剿。且喜大兵一到，那贼不战自降，写来降书降表，年年进贡，每 岁来朝。想起杨家将帅，个个为国丧命，只剩下杨藩一门后代。倘哪国造反， 若有差池，岂不断绝了杨门的后代？昨晚合家商议，不如上殿辞王别驾，告归 林泉。本章早已写就。 排风！"
        },
        {
          "character": "杨排风",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "带了本章，随我上朝！"
        },
        {
          "character": "杨排风",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "佘太君",
          "type": "二黄慢板",
          "text": "宋王爷坐汴梁风调雨顺， 征服了黄花国四海扬名。 夫继业为国家两狼命尽， 可怜我八个子四子捐身！ 昨夜晚修下了辞王表本， 上金殿奏明君告职归林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君、杨排风同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "包拯、岳士奎、姜洪顺、王恩慕同上。"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "type": "同点绛唇",
          "text": "凤阁龙楼，群臣齐辏，英明佑，文物集筹，分班朝廊候。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老夫包拯。"
        },
        {
          "character": "岳士奎",
          "type": "白",
          "text": "下官岳士奎。"
        },
        {
          "character": "姜洪顺",
          "type": "白",
          "text": "下官姜洪顺。"
        },
        {
          "character": "王恩慕",
          "type": "白",
          "text": "下官王恩慕。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "列位大人请了！"
        },
        {
          "character": "岳士奎、姜洪顺、王恩慕",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "今有佘太君征剿黄花国，得胜还朝，已在午门候旨。少时万岁登殿，把本启奏。"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "type": "同白",
          "text": "看香烟缭绕，圣驾临朝，你我分班伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "引子",
          "text": "龙门展放，众文武，齐保孤王。"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "黄花国内起风波，黎民涂炭受折磨。多蒙太君来扶助，孤王才得坐山河。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤，大宋天子至和在位。自登基以来，风调雨顺，国泰民安。只因黄花国作乱， 孤命佘太君带兵征剿。前三日有火牌到来，太君今日还朝。 众卿！"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "type": "同白",
          "text": "臣！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "有本早奏，无本退班。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣启万岁：今有太君征剿黄花国得胜还朝，已在午门候旨。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "替孤传旨：宣太君上殿！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "领旨！ 万岁有旨：太君上殿！"
        },
        {
          "character": "佘太君",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨排风捧表引佘太君同上。"
        },
        {
          "character": "佘太君",
          "type": "念",
          "text": "写就辞王表，上殿奏当朝。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "臣佘氏女见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君平身。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "谢坐！ 啊列位大人！"
        },
        {
          "character": "包拯、岳士奎、姜洪顺、王恩慕",
          "type": "同白",
          "text": "太君！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君将征剿黄花之事，一一奏来！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "臣妾奉命征剿黄花，且喜大兵一到，那贼不战自降，写来降书降表，年年进贡， 每岁来朝。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君之功！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "万岁洪福！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "内侍！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "吩咐光禄寺大摆筵宴，与太君贺功！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君为何拦阻？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "臣妾有本启奏。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "有本当殿奏来！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "排风！"
        },
        {
          "character": "杨排风",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "将本呈上！"
        },
        {
          "character": "杨排风",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨排风呈表。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗看表。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "唔呼呀！才得干戈宁静，太君就要辞朝，叫孤心下何忍？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "佘太君",
          "type": "二黄快三眼",
          "text": "佘氏女在金殿把本启奏， 尊一声万岁爷细听从头： 我杨家祖居在磁州山后， 太祖爷下河东才把宋投。 圣天子待杨家恩比天厚， 赐臣门一个个官封公侯。 我儿夫命丧在两狼山口， 实可怜七郎儿乱箭命休！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君！"
        },
        {
          "character": "宋仁宗",
          "type": "二黄原板",
          "text": "劝太君休得要把本启奏， 龙书案听孤王细说从头： 好容易征黄花扫荡贼寇， 叫孤王怎能够顺水流舟！"
        },
        {
          "character": "佘太君",
          "type": "二黄原板",
          "text": "万岁爷不准辞王表， 臣妾二本奏当朝： 杨家将帅俱丧了， 并无一个将英豪。 佘氏女在金殿急忙跪倒， 望我主准了本臣好离朝。"
        },
        {
          "character": "宋仁宗",
          "type": "二黄散板",
          "text": "见太君在金殿双膝跪倒， 倒叫孤王心内焦。 两班中文武臣齐把泪掉， 再与包卿说根苗。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "太君辞朝，孤是准与不准？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "太君辞朝，焉有不准之理？问明太君居住何地，日后我主思念功臣，也好差人 前去问安！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "是呀，太君辞朝，孤哪有不准之理？请问太君居住何地，孤王思念功臣，也好 差人前去问安。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "臣妾闻得沟西番黄河套内，俱是淤泥之地。臣妾意欲那里居住。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "想那沟西番乃是杨文广征服之地。就将那一省钱粮换与太君，以为养老之费。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "隆恩太重了！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "不知太君何日启程？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "万岁准本，明日启程。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "明日长亭备宴，与太君饯行。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "好个明君真有道， 开了龙恩出赦条。 今日准了辞王表， 从今后再不上九龙朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君、杨排风同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "岳卿，明日长亭预备酒宴！"
        },
        {
          "character": "岳士奎",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引岳士奎同上。"
        },
        {
          "character": "岳士奎",
          "type": "白",
          "text": "俺，岳士奎。奉了圣上旨意，准备酒宴，与太君长亭饯行。 来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "岳士奎",
          "type": "白",
          "text": "长亭去者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "宋仁宗",
          "type": "内西皮导板",
          "text": "龙车凤辇出皇城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、包拯、姜洪顺、王恩慕、宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮原板",
          "text": "论功劳买动了帝王心。 黄花国内贼犯境， 太君领兵挡贼人。 来在长亭下车轮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗坐。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮原板",
          "text": "太君到此禀寡人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳士奎上，见宋仁宗。穆桂英、车夫同上，穆桂英下车。"
        },
        {
          "character": "穆桂英",
          "type": "西皮散板",
          "text": "来在长亭下车轮， 万岁驾前臣见君。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮散板",
          "text": "内侍看过酒一樽， 孤与皇嫂来饯行。"
        },
        {
          "character": "穆桂英",
          "type": "西皮散板",
          "text": "谢罢万岁下车轮， 回到家乡乐安宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆桂英、车夫同下。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮散板",
          "text": "长亭去了穆桂英， 江山去了八九分。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阿红女、车夫同上，阿红女下车。"
        },
        {
          "character": "阿红女",
          "type": "西皮散板",
          "text": "迈步且把长亭进， 万岁驾前问安宁。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮散板",
          "text": "内侍看过彩缎金， 千两黄金表寸心。"
        },
        {
          "character": "阿红女",
          "type": "西皮散板",
          "text": "急急忙忙上车行， 万岁赐我彩缎金。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阿红女、车夫同下。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮散板",
          "text": "长亭去了阿红女， 不知何日转回程。"
        },
        {
          "character": "佘太君",
          "type": "内西皮导板",
          "text": "佘氏女哭出了帅府门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫、杨排风、佘太君同上。"
        },
        {
          "character": "佘太君",
          "type": "西皮流水板",
          "text": "珠泪滚滚洒衣襟。 我夫继业投大宋， 父子们九人保乾坤。 令公李陵碑下尽， 可怜他为国丧残生！ 八个孩儿俱丧命， 并无一子随着娘亲。 来到长亭下车轮， 御街之上臣见君。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮散板",
          "text": "一见太君到长亭， 倒叫孤王两泪淋。 今日告职归原郡， 不知何日转回程？"
        },
        {
          "character": "佘太君",
          "type": "西皮散板",
          "text": "一朝君王一朝心， 一朝天子一朝臣。 无功受禄心不忍， 因此告职归故林。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮散板",
          "text": "内侍看过酒一樽， 孤与太君来饯行。 倘若哪国刀兵起， 还望太君发救兵。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "佘太君",
          "type": "西皮散板",
          "text": "用手接过酒一樽， 背转身来敬神灵。 但愿四海狼烟尽， 君臣同享太平春。"
        },
