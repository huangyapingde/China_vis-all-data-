{
  "script_id": "03016001",
  "title": "大回朝",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "闻仲",
      "hangdang": "净"
    }
  ],
  "plot": "殷末，纣王暴虐无道，宠幸妲己。奸臣费仲、尤浑助纣为虐，造摘星楼与炮烙柱、虿盆等酷刑，供纣王与妲\n己残害臣民取乐。当时比干丞相、姜后及众百姓，惨遭杀戮。适太师闻仲征北得胜还朝，闻知此事，怒打费\n仲、尤浑，并责问纣王，纣王逃入内宫以避之。",
  "notes": "故事见《封神演义》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、中军引闻仲同上。"
        },
        {
          "character": "闻仲",
          "type": "引子",
          "text": "锦战袍玉带围腰，征北海得胜还朝。"
        },
        {
          "character": "闻仲",
          "type": "念",
          "text": "吾本商朝一大臣，跨下神行墨麒麟。金鞭扫荡花世界，保定我主驾乾坤。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老夫，太宰闻。在殷纣驾前为臣。只因北海金鳌作乱，圣上命老夫领兵征讨。 且喜大兵一到，那贼不战自降，写下降书顺表，愿年年进贡，岁岁来朝。今当 黄道吉日，正好班师回朝。 中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "吩咐大小三军，人不卸甲，马不离鞍，班师回朝。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。 众将官！"
        },
        {
          "character": "八龙套",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "太师有令：吩咐大小三军，人不卸甲，马不离鞍，班师回朝。"
        },
        {
          "character": "八龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同倒脱靴掏下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "费仲、尤浑同上。"
        },
        {
          "character": "费仲",
          "type": "念",
          "text": "待漏五更寒，"
        },
        {
          "character": "尤浑",
          "type": "念",
          "text": "陪王上金銮。"
        },
        {
          "character": "费仲",
          "type": "念",
          "text": "鸡鸣天未晓，"
        },
        {
          "character": "尤浑",
          "type": "念",
          "text": "明月满栏杆。"
        },
        {
          "character": "费仲",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "尤浑",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "费仲",
          "type": "白",
          "text": "香烟缭绕，圣驾临朝。你我分班伺候。请！"
        },
        {
          "character": "尤浑",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引纣王同上。"
        },
        {
          "character": "纣王",
          "type": "引子",
          "text": "文武双全，恃祖业，朝歌承欢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纣王入正座。"
        },
        {
          "character": "费仲、尤浑",
          "type": "同白",
          "text": "小臣参见，吾皇万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "平身！"
        },
        {
          "character": "费仲、尤浑",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "纣王",
          "type": "念",
          "text": "朝歌城中摘星楼，金钟一响文武愁。宠幸妲己贪酒色，虿盆炮烙臣民忧！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "孤，大殷太子辛在位。只因北海金鳌作乱。我命太宰，带领人马前去征剿。昨 日报道，太宰今日班师回朝。 费、尤二卿！"
        },
        {
          "character": "费仲、尤浑",
          "type": "同白",
          "text": "臣！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "太宰还朝，你等各要小心。"
        },
        {
          "character": "费仲、尤浑",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "闻仲",
          "type": "内白",
          "text": "众将官！"
        },
        {
          "character": "八龙套",
          "type": "内同白",
          "text": "有！"
        },
        {
          "character": "闻仲",
          "type": "内白",
          "text": "将人马扎在皇城。"
        },
        {
          "character": "八龙套",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "闻仲",
          "type": "内二黄导板",
          "text": "将人马扎皇城休要罗唣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲上。"
        },
        {
          "character": "闻仲",
          "type": "二黄碰板",
          "text": "奉王命征北海得胜还朝。"
        },
        {
          "character": "闻仲",
          "type": "二黄原板",
          "text": "在午门下麒麟忙登御道， 见凤阁与龙楼甚是萧条。 文班中不见了比干元老， 武班中不见了黄家英豪。 撩蟒袍端玉带品级台到， 三呼万岁参见当朝。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "臣，太宰闻仲见驾，吾皇万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "太宰平身。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "赐绣墩。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "太宰将征讨金鳌之事，一一奏来。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "臣启万岁：臣奉命征讨金鳌，大兵一到，那贼不战自降，写下降书顺表，年年 进贡，岁岁来朝。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "此乃太宰虎威。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "我主洪福。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "费、尤二卿！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "光禄寺大摆御宴，与太宰贺功。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "为何拦阻？"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老臣进得朝来，为何不见比干丞相？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "太宰有所不知，只因新宫娘娘身染重病。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "但不知是新病旧病？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "乃是旧病新犯。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "就该请太医调治。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "寡人已传太医调治，但是缺少一味药引。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "但不知缺何药引？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "缺少玲珑透剔心为药引。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老臣幼年，也曾读过药书，未见有玲珑透剔心，是何药引？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "寡人亦是这样言讲，那新宫娘娘言道：满朝文武俱是血心，惟有比干丞相，乃 是玲珑透剔心，寡人将他宣上金殿，赐他宝剑一口，乃是一句戏言，不想老太 宰忠心耿耿，他竟剖心而亡了。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "万岁怎讲？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "剖心而亡了。"
        },
        {
          "character": "闻仲",
          "type": "哭",
          "text": "太宰呀！"
        },
        {
          "character": "闻仲",
          "type": "二黄原板",
          "text": "听说是老太宰剖心而丧， 我朝中又去了架海金梁。 下殿角哭一声比干丞相，比干丞相， 老太宰呀！ 可怜他忠心耿耿一命身亡。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "臣启万岁：正宫国母，挖目烙手，因何而起？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "太宰哪里知道，姜娘娘使她弟文焕，身藏短刀，在五凤楼前行刺，有心谋害寡 人，因此将她挖目烙手。"
        },
        {
          "character": "闻仲",
          "type": "哭",
          "text": "国母呀！"
        },
        {
          "character": "闻仲",
          "type": "二黄原板",
          "text": "姜国母坐昭阳万民敬仰， 最可叹受惨刑命丧无常。 下金殿哭一声国母娘娘，国母娘娘， 国母啊！ 可叹她身为国母受刑而亡。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "臣启万岁：贾氏夫人坠楼而死，黄家父子反出五关，此事又从何而起？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "只因孤闻听贾氏夫人生得美貌，将她宣上摘星楼，奉陪孤王饮酒，谁之她羞愧 难当，竟自坠楼而亡。那黄家父子叛反孤家，保定太子，杀出朝歌。似这等不 忠不孝之人，提他作甚？"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "我主江山一旦休矣！"
        },
        {
          "character": "闻仲",
          "type": "西皮快板",
          "text": "贾氏夫人坠楼前， 黄家父子反五关。 在金殿问昏君无言答辩， 下殿来再问那文武两班。"
        },
        {
          "character": "费仲",
          "type": "白",
          "text": "参见老太宰。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "下站何人？"
        },
        {
          "character": "费仲",
          "type": "白",
          "text": "上大夫费仲。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "摘星楼可是尔所造？"
        },
        {
          "character": "费仲",
          "type": "白",
          "text": "圣上旨意，喏、喏、喏，小臣监造。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "闻仲",
          "type": "西皮快板",
          "text": "摘星楼乃是尔造定， 害了多少栋梁臣。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "鞭来！"
        },
        {
          "character": "闻仲",
          "type": "西皮摇板",
          "text": "金鞭一举追尔命， 打死费仲再问来臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费仲下。"
        },
        {
          "character": "尤浑",
          "type": "白",
          "text": "参见老太宰。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "尤浑",
          "type": "白",
          "text": "下大夫尤浑。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "炮烙、虿盆是尔监造？"
        },
        {
          "character": "尤浑",
          "type": "白",
          "text": "圣上旨意，喏、喏、喏，小臣监造。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "闻仲",
          "type": "西皮快板",
          "text": "炮烙、虿盆尔监造， 害了无数女多娇。 金鞭一举命丧了， 打死谗臣问当朝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤浑下。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "臣启万岁：新宫国母，为臣要见。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "天色已晚，明日再见。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老臣一定要见！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "纣王",
          "type": "西皮摇板",
          "text": "好一个胆大的太宰闻仲， 敢在午门打大臣。 内侍带路回宫廷， 要见妲己万不能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纣王下，四太监随下。"
        },
        {
          "character": "闻仲",
          "type": "西皮摇板",
          "text": "本当打进皇宫院， 他是君来某是臣。 人来带过墨麒麟， 明日早朝再问当今。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}