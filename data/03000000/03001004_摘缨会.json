        {
          "character": "楚庄王",
          "type": "白",
          "text": "罢了啊，罢了！先蔑实在厉害，杀得我兵五零四散，剩孤一人找寻路径，正所 谓寡人也。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "先蔑威风真不小， 杀得孤王无处逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王下。"
        }
