{
  "script_id": "03001004",
  "title": "摘缨会",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "唐狡",
      "hangdang": "武生"
    },
    {
      "name": "襄老",
      "hangdang": "丑"
    },
    {
      "name": "许姬",
      "hangdang": "旦"
    },
    {
      "name": "先蔑",
      "hangdang": "净"
    }
  ],
  "plot": "楚庄王平了斗越椒叛乱，在渐台设宴庆功，命许姬敬酒。风吹灯灭，裨将唐狡暗中戏许姬；被许姬摘去盔缨，\n密告楚庄王。楚庄王急命众将，一律摘去盔缨，然后张灯。唐狡心感楚庄王，心存报答。晋国伐楚，唐狡\n请为前锋，被襄老斥责不用。楚庄王阵前落马，危急之中，唐狡奋勇来救，杀退晋兵，得胜受封。",
  "notes": "故事源出《东周列国志》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基同上。〖点绛唇〗。"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "申无畏",
          "type": "白",
          "text": "大司马申无畏。"
        },
        {
          "character": "熊负羁",
          "type": "白",
          "text": "上将军熊负羁。"
        },
        {
          "character": "潘尪",
          "type": "白",
          "text": "车左将军潘尪。"
        },
        {
          "character": "乐伯",
          "type": "白",
          "text": "车右将军乐伯。"
        },
        {
          "character": "公子婴齐",
          "type": "白",
          "text": "左殿将公子婴齐。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "右殿将公子侧。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "左队先锋襄老。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "右队先锋养由基，"
        },
        {
          "character": "申无畏",
          "type": "白",
          "text": "列位将军请了！大王设宴渐台，庆贺功臣，各自分班伺候。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四小太监、四值殿、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "引子",
          "text": "征战戎夷，仗功勋，席卷旌旗。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "朝参！"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "臣等见驾，大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身！"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "千岁，千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "为征陆浑动兵机，越椒凭空把孤欺。幸有众卿皆勇战，才得凯歌马停蹄。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤，楚庄王。为征陆浑，不想越椒起叛，亏得养由基除灭反贼，为此渐台设宴， 庆贺功臣。 内侍传孤旨意，大小将官，齐到渐台饮宴。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "大王有旨，大小将官齐到渐台饮宴！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。三校尉、唐狡自两边分上，同朝参。两边坐。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "上宴！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众卿赏乐一回。"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "千岁请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牌子.吹打。"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "臣等谢宴。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "内侍！宣西宫许姬上渐台。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "宣西宫许娘娘上渐台！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。四宫女引许姬同上。"
        },
        {
          "character": "许姬",
          "type": "念",
          "text": "感恩君宠锡，缓步上渐台。"
        },
        {
          "character": "许姬",
          "type": "白",
          "text": "妾妃见驾，大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "许姬",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤王庆贺功臣，梓童与孤行酒一樽，以敬功臣。"
        },
        {
          "character": "许姬",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "臣等叨沐恩宠，何敢劳娘娘赐酒！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众卿不必过谦，一同坐下畅饮。哈哈哈…… 梓童与孤行酒。 啊，众卿同饮一巡。"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "谢大王、娘娘千岁！"
        },
        {
          "character": "许姬",
          "type": "唱",
          "text": "勋臣勤劳君心念， 隆恩宽宏大如天。 手捧香醪献王面， 愿主安乐福绵绵。 功臣个个生欢忭， 忠心辅国标凌烟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二风旗同上，同冲，同下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "顿然一时天作变，"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "唔唔唔……"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王用目看阶檐。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "快些张灯！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "传旨张灯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡抱许姬。许姬折盔缨，向楚庄王耳语。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "慢些张灯！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "喳！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "啊众卿！今日之乐原不禁忌，孤行一令，卿等各摘盔缨，然后张灯宴乐，做个 绝缨会。不遵令者，罚酒三巨觥。"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "臣等遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基、三校尉同摘缨。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "吩咐张灯。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "呔！张灯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哈哈哈……梓童回避！"
        },
        {
          "character": "许姬",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "过门。许姬、宫女同下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哈哈哈……众卿再饮一回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "申无畏、潘尪、公子婴齐、襄老、熊负羁、乐伯、公子侧、养由基",
          "type": "同白",
          "text": "臣等谢恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "啊，醉了，醉了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "公子宋",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "干牌子。公子宋上。"
        },
        {
          "character": "公子宋",
          "type": "白",
          "text": "某，郑国大夫公子宋是也。只因楚庄屡与众不和，横行天下。某奉襄公钧旨， 去往晋国借兵，共敌楚庄。事不宜迟，火速趱行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子宋下。四小太监、四大太监引晋成公同上。"
        },
        {
          "character": "晋成公",
          "type": "引子",
          "text": "列国纷争，恨楚王，独霸横行。"
        },
        {
          "character": "晋成公",
          "type": "念",
          "text": "楚国干戈不肯休，黎民涂炭令人忧。欲图基业归一统，君臣畅叙贺千秋。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "孤，晋成公。坐镇绛州，国号大晋。喜得边邦平静，惟有楚庄欲霸中原，孤王 每日操兵演习，与楚庄相斗雌雄。今当接报之期，设朝御览。 内待，展放龙棚！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "展放龙棚！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "先蔑上。"
        },
        {
          "character": "先蔑",
          "type": "念",
          "text": "郑国请兵将，把本奏丹墀。"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "臣先蔑见驾，大王千岁！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "今有郑国大夫公子宋，前来请兵征战楚庄，朝门候旨。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "哎呀妙哇！孤正欲伐楚，郑国使臣到来，合孤意也。宣来见孤！"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "领旨。 宣郑国大夫上殿！"
        },
        {
          "character": "公子宋",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子宋上。"
        },
        {
          "character": "公子宋",
          "type": "念",
          "text": "为救倒悬厄，求请上国兵。"
        },
        {
          "character": "公子宋",
          "type": "白",
          "text": "臣，公子宋见驾，大王千岁！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "大夫平身。"
        },
        {
          "character": "公子宋",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "看座。"
        },
        {
          "character": "公子宋",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "来到我邦有何见谕？"
        },
        {
          "character": "公子宋",
          "type": "白",
          "text": "只为楚庄王图霸，要灭晋、郑二国，臣奉襄公之命，恳请大王起兵伐楚，小国 愿为后应。未知大王尊意如何？"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "孤久有伐楚之心，晋郑二国同体相关。大夫回去上复你主，孤王提兵对敌楚庄， 倘有不胜，再来接应便了。"
        },
        {
          "character": "公子宋",
          "type": "念",
          "text": "感谢君金诺，同心伐楚邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子宋下。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "先卿！孤命你为上军元帅，公子凯、公子有，全军人马共敌楚庄，即日兴师。 下殿！"
        },
        {
          "character": "先蔑",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": "先蔑",
          "type": "念",
          "text": "统领虎豹士，扫荡楚强兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "先蔑下。"
        },
        {
          "character": "晋成公",
          "type": "白",
          "text": "内侍！传孤旨意，令荀林父解押粮草，军前使用，不得有误！正是："
        },
        {
          "character": "晋成公",
          "type": "念",
          "text": "两国同心争社稷，何愁海鳌不吞钩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、许姬、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "宴罢回宫静安养， 梓童缘何带愁肠？"
        },
        {
          "character": "许姬",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "许姬",
          "type": "唱",
          "text": "妾妃蒙恩圣德广， 肚量宽宏福绵长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王、许姬同坐。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "梓童！前日宴贺功臣，那小将酒醉失仪，何足道论。若是查明治罪，一者众臣 寒心；二来外邦耻笑，道孤有意设计陷害公卿。只好摘缨遮掩，这小将必报孤 恩也！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "明知小将行无状， 岂可秽污败纲常！ 自悔不该设杯畅， 梓童酌酒意彷徨。 霎时天变狂风降， 小将无知发颠狂。 若是问罪市曹上， 文武功勋心胆伤。 从此一言宽怀放， 免得遗笑道短长。"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "念",
          "text": "军情如雷电，即奏大王知。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启大王：适才接报，有郑国公子宋，去往晋国合兵；晋成公命先蔑为上军元帅， 统领全军征伐我邦。请旨定夺！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀，有这等事！ 梓童你可安养宫中，孤王亲自出兵，扫荡二国。 内侍摆驾！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "正欲出师去扫荡， 两国凑合来逞强。 孤王亲征调兵将， 直教郑晋拱手降。"
