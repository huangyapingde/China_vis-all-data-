    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四将官引楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "旌旗对舞空中飘， 各国相争动枪刀。 亲领雄师把贼扫， 儿郎个个逞英豪。 耀武扬威放号炮， 准备金钩钓海鳌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四大铠、襄老同上。"
        },
        {
          "character": "襄老",
          "type": "唱",
          "text": "先蔑武艺果真好！ 一战未交我就逃。 年纪衰迈精神老， 奔回大营奏分毫。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "老臣交令。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "可曾会过阵来？晋国将官是谁？"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "晋国元帅名叫先蔑，领兵前来，老臣出马，就被他一枪，呵呀……"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "敢是带伤了？"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "哎！我就跑回来了。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "败了？"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "败了。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "念在老臣，不来加罪。随营保驾！"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众将官！先蔑有万夫莫挡之勇，孤王亲自会阵，尔等护驾须要留心在意。带马！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "为王出兵凭天保， 临阵输赢在今朝。 齐心奋勇排阵道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王上马。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "且看先蔑将英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、四下手引先蔑同冲上。"
