          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏从、潘尪、公子侧、养由基、申无畏、熊负羁同下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "襄老传旨，启驾前往！"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "呔！大小三军启驾前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
