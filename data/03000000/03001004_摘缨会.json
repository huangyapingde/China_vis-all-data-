    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "唐狡上。"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "感受君恩未曾报， 不该渐台醉陶陶。 庄王宽宏量非小， 摘缨罪名一笔消。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "俺，唐狡，棠邑人也。父母早逝，家业凋零。投在庄王驾下，当名裨将。前日 渐台大宴功卿，俺唐狡并无寸箭之功，蒙恩犒赏有名。不想酒醉失仪，掠抱君 妃，暗摘盔缨，自忖性命不保；岂知君王肚量宽宏，传令众臣都将盔缨摘去， 名为摘缨会。想我知恩不报，非丈夫也。如今晋国前来犯界，庄王御驾亲征， 命襄老为前部先锋。俺不免奔往楚营，讨一差使，与晋兵对敌，以报君恩也！"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "庄王恩德真非小， 不把国法斩儿曹。 如此宽宏古来少， 不辞劳碌报当朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四大铠、襄老同上。"
        },
        {
          "character": "襄老",
          "type": "引子",
          "text": "先锋是我，领兵将，相斗干戈。"
        },
        {
          "character": "襄老",
          "type": "念",
          "text": "老将生来不可挡，全凭精气逞豪强。忠心耿耿扶楚室，凯歌何时转还乡？"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "某，襄老是也。大王征伐晋国，命我为前站先锋。今日黄道，正好发兵。 众将官，起兵前往！"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "唐狡",
          "type": "内白",
          "text": "住着！"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "有人阻令。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "唔！何人竟敢阻令，传他进帐！"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "阻令者进帐！"
        },
        {
          "character": "唐狡",
          "type": "内白",
          "text": "俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡上。"
        },
        {
          "character": "唐狡",
          "type": "念",
          "text": "欲为世上奇男子，须建人间未有功。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "卑将唐狡参见。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "噢！原来是你。大兵正欲起行，你为何阻令？"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "小将相投麾下，并未建功；今主将领兵伐晋，小将原为前站，立功报国！"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "啊！楚营多少大将，尚且钳口束身；你一随使将校，胆敢大言阻令！本欲取斩， 恐出兵不利。下去！"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "主将差矣！"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "唐狡虽然裨将校， 胸怀韬略胆气豪。 食君粮饷当恩报，"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "主将！"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "要与君王扫贼巢。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "襄老",
          "type": "唱",
          "text": "我国大将有多少， 遵令钳口不逞豪。 小小裨将胡乱道， 抗吾军令绑市曹。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "主将何以见量小， 欺压英雄忒无聊。 年老出令语颠倒， 焉能对垒枪对刀。 交锋岂可论大小，"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "主将！"
        },
        {
          "character": "唐狡",
          "type": "唱",
          "text": "定把晋国化海潮。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "胡说！无知小卒，杀之无益。 来呀！将唐狡重打四十军棍，扯下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手带唐狡同下，打，同上。"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "谢主将的责！"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "念你帐下多年，留一线之情，发往后队，收拾锣锅帐房。下去！"
        },
        {
          "character": "唐狡",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐狡下。"
        },
        {
          "character": "襄老",
          "type": "白",
          "text": "众将官，启兵前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
