{
  "script_id": "03100001",
  "title": "虹霓关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "秦秀英",
      "hangdang": "旦"
    },
    {
      "name": "王伯当",
      "hangdang": "小生"
    },
    {
      "name": "辛文礼",
      "hangdang": "净"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    }
  ],
  "plot": "瓦岗秦琼挂帅，攻打虹霓关。守将辛文礼拒战，为秦琼先锋王伯当射死。辛文礼妻秦秀英，替夫报仇，生擒\n王伯当。因慕其英俊，遂改嫁王伯当归顺瓦岗。",
  "notes": "此本系清朝咸丰七年钞本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "齐国远、尤俊达、程咬金、单雄信同上，同起霸。"
        },
        {
          "character": "齐国远",
          "type": "念",
          "text": "齐心协力聚瓦岗，"
        },
        {
          "character": "尤俊达",
          "type": "念",
          "text": "打劫皇纲惹祸殃。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "上阵全凭宣花斧，"
        },
        {
          "character": "单雄信",
          "type": "念",
          "text": "扶保李密西魏王，"
        },
        {
          "character": "齐国远、尤俊达、程咬金、单雄信",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "齐国远",
          "type": "白",
          "text": "齐国远。"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "尤俊达。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "程咬金。"
        },
        {
          "character": "卑雄信",
          "type": "白",
          "text": "单雄信。"
        },
        {
          "character": "齐国远",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "尤俊达、程咬金、单雄信",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "齐国远",
          "type": "白",
          "text": "元帅升帐，两厢伺候。"
        },
        {
          "character": "尤俊达、程咬金、单雄信",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠引秦琼同上。〖点绛唇〗。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "威风凛凛镇瓦岗，马壮兵精个个强！将令一出山摇动，扶保李密西魏王。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "本帅、秦琼。李密驾下为臣。可恨辛文礼，每日操兵练将，要剿灭瓦岗。西魏 王拜我为帅，领兵对敌。今乃黄道吉日，正好兴兵。 众位贤弟，人马可齐？"
        },
        {
          "character": "齐国远、尤俊达、程咬金、单雄信",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "人马发往虹霓关！"
        },
        {
          "character": "齐国远、尤俊达、程咬金、单雄信",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖玉芙蓉〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "打探军情事，名为夜不收。日间藏草内，晚来过荒丘。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "俺、能行探子是也。打听瓦岗拜秦琼为帅，攻打虹霓关。就此回关报与元帅知 道！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手引辛文礼同上。〖粉蝶儿〗。"
        },
        {
          "character": "辛文礼",
          "type": "念",
          "text": "镇守虹霓威四方，贼寇不敢犯边疆。隋主驾前为上将，率领精兵定家邦。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "本帅、辛文礼。隋朝炀帝驾前为臣，官拜虹霓关总镇。可恨瓦岗作乱，本帅日 夜操练兵马，定要剿灭贼寇，保我隋朝天下。这且不言。昨晚三更时分，偶得 一梦，只见斗大红星，从东南角而起，忽喇喇落向西北海底。某家醒来，浑身 是汗，不知主何吉凶。为此今日全身披挂，升坐大帐，看看有何军情。 来，伺候了！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "上马銮铃响，下马报军情。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报：探子吿进！帅爷在上，探子叩头！"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "打听哪路军情？一一报来！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "帅爷容禀："
        },
        {
          "character": "报子",
          "type": "念",
          "text": "探子领将令，四路探军情。打听瓦岗事，贼寇发来兵。 秦琼拜帅印，伯当为先行。帅爷发人马，开关退贼兵。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "他的兵势如何？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "帅爷容禀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖江儿水〗。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "赏你银牌一面，再去打探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "谢帅爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "且住！瓦岗拜秦琼为帅。我想此人攻无不取，战无不胜，只恐此关有失。 来，转堂！"
        },
        {
          "character": "四龙套、四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手同下。院子暗上。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "来，请夫人！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。秦秀英上，丫鬟随上。"
        },
        {
          "character": "秦秀英",
          "type": "念",
          "text": "夫主镇边疆，皇家一栋梁。"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "王爷！"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "夫人！"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "妾身有礼！"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "夫人少礼，请坐！"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦秀英坐。"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "王爷为何愁眉不展？"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "夫人有所不知，今有瓦岗拜秦琼为帅，攻打虹霓关。我想此人攻无不取，战无 不胜，因此烦闷。"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "王爷，妾身颇知兵法，何惧小小瓦岗！"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "夫人言得极是。我想此番出兵，胜负未定。倘若战死沙场，为国尽忠，理所当 然；只恐夫人效那贾氏之故耳！"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "秦秀英",
          "type": "唱",
          "text": "听一言来心自惊， 尊声王爷听详情： 我若有三心并二意， 愿对苍天把誓盟。"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "但凭夫人！"
        },
        {
          "character": "秦秀英",
          "type": "唱",
          "text": "秦秀英下跪把誓盟， 祝吿空中过往神： 我若有三心并二意， 三尺青锋丧奴身！"
        },
        {
          "character": "辛文礼",
          "type": "白",
          "text": "夫人请起！"
        },
        {
          "character": "辛文礼",
          "type": "唱",
          "text": "听一言来自思忖， 不由本帅喜在心。 夫人且把二堂进——"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦秀英下，丫鬟随下。四龙套、四下手同暗上。"
        },
        {
          "character": "辛文礼",
          "type": "唱",
          "text": "回言叫声众三军。 本帅今日把兵进， 各个争先显奇能。 传令已毕跨金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下手甲带马，辛文礼上马。"
        },
        {
          "character": "辛文礼",
          "type": "唱",
          "text": "要把那瓦岗一扫平！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、齐国远、尤俊达、程咬金、单雄信、秦琼同上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "历城曾为英雄首， 赫赫威名冠九州。 我与杨林结仇扣， 夜打登州血水流。 众家英雄将我救， 豪杰一怒上山头。 扶保李密自为首， 虹霓关前统貔貅。 将身且坐宝帐口， 且听探马报从头。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "辛文礼讨战！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "且住！辛文礼讨战，岂肯容他猖狂？ 众位贤弟，杀向前去！"
        },
        {
          "character": "齐国远、尤俊达、程咬金、单雄信",
          "type": "同白",
          "text": "啊！ （秦琼下，四龙套、四大铠、齐国远、尤俊达、程咬金、单雄信同走圆场。辛文礼、四龙套、四下手同上， 会阵，同起打。齐国远、尤俊达、程咬金、单雄信、四龙套、四大铠同败下。辛文礼、四龙套、四下手同追 下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手推车同上，同站斜门。王伯当上。"
        },
        {
          "character": "王伯当",
          "type": "唱",
          "text": "山寨领了魏王令， 解押粮草回大营。"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "俺、王伯当。奉了魏王将令，解押粮草，军前应用。 众将官，趱行者！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "王伯当",
          "type": "唱",
          "text": "豪杰催马往前进——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内呐喊声〗。"
        },
        {
          "character": "王伯当",
          "type": "唱",
          "text": "何处人马乱纷纷！"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "且住！何处人马呐喊？ 众将官，高坡一望！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！ （齐国远、尤俊达、程咬金、单雄信同败上，辛文礼、四龙套、四大铠同追上，同起打。齐国远、尤俊达、 程咬金、单雄信同败下，辛文礼、四龙套、四大铠同追下。）"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "啊！前面败的众家英雄，后面追的辛文礼。俺今不救，等待谁来！ 众将官，将粮草搭过一边！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！ （齐国远、尤俊达、程咬金、单雄信同上，辛文礼、四龙套、四下手同上，同起打。齐国远、尤俊达、程咬 金、单雄信同败下。王伯当接打。王伯当、四上手同败下，辛文礼、四龙套、四下手同追下。王伯当、四上 手同上。）"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "辛文礼来得厉害。 众将官把粮草转在中途，挡他去路！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！ （四上手同推车挡路。齐国远、尤俊达、程咬金、单雄信引辛文礼同上，同起打。齐国远、尤俊达、程咬金、 单雄信同下。王伯当上，接打，败下。辛文礼挑粮车，杀四上手死，追下。齐国远、尤俊达、程咬金、单 雄信同败上，王伯当随上。）"
        },
        {
          "character": "齐国远、尤俊达、程咬金、单雄信",
          "type": "同白",
          "text": "王贤弟，辛文礼杀法厉害，如何是好？"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "众位仁兄不必惊慌。他若追来，小弟用神箭伤他便了！"
        },
        {
          "character": "辛文礼",
          "type": "内白",
          "text": "哪里走！ （辛文礼上，起打。齐国远、尤俊达、程咬金、单雄信同败，王伯当射箭，辛文礼带箭。四龙套同上，搀辛 文礼同下。）"
        },
        {
          "character": "齐国远、尤俊达、程咬金、单雄信、王伯当",
          "type": "同三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟引秦秀英同上。"
        },
        {
          "character": "秦秀英",
          "type": "念",
          "text": "王爷去出兵，未见转回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子急上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启夫人：王爷被王伯当一箭射死了！"
        },
        {
          "character": "秦秀英",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦秀英昏倒。"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "夫人醒来！"
        },
        {
          "character": "秦秀英",
          "type": "西皮导板",
          "text": "听说王爷丧了命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦秀英醒。"
        },
        {
          "character": "秦秀英",
          "type": "三叫头",
          "text": "王爷！我夫！喂呀夫啊！"
        },
        {
          "character": "秦秀英",
          "type": "唱",
          "text": "不由奴家两泪倾。 王爷英灵归天境，"
        },
        {
          "character": "秦秀英",
          "type": "哭头",
          "text": "喂呀王爷呀！"
        },
        {
          "character": "秦秀英",
          "type": "唱",
          "text": "定把贼子一扫平！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗下。"
        },
        {
          "character": "秦秀英",
