  "plot": "徐达攻打采石矶，当地守将铁木耳拒之。矶高水险，众莫能破。徐达部将常遇春潜身桅斗内，趁潮涨时跃登\n矶头，夺得太平城。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李文忠上，起霸。"
        },
        {
          "character": "李文忠",
          "type": "念",
          "text": "大将威风勇，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭英上，起霸。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "长枪快如风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡大海上，起霸。"
        },
        {
          "character": "胡大海",
          "type": "念",
          "text": "马踏花世界，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春上，起霸。"
        },
        {
          "character": "常遇春",
          "type": "念",
          "text": "保主锦江洪。"
        },
        {
          "character": "李文忠、郭英、胡大海、常遇春",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "李文忠。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "郭英。"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "胡大海。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "常遇春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手暗同上。"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "郭英、胡大海、常遇春",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "主上挂徐达为帅，攻打采石矶。你我辕门候令。"
        },
        {
          "character": "郭英、胡大海、常遇春",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "李文忠、郭英、胡大海、常遇春",
          "type": "同白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同带马，李文忠、郭英、胡大海、常遇春同上马，同走圆场，同下马。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "来到辕门。"
        },
        {
          "character": "李文忠、郭英、胡大海、常遇春",
          "type": "同白",
          "text": "打了几鼓？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起二鼓。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "辕门二鼓。"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "元帅尚未升帐，你我在此伺候。"
        },
        {
          "character": "郭英、胡大海、常遇春",
          "type": "同白",
          "text": "请！ （李文忠、郭英、胡大海、常遇春同八字坐。四文堂同上，同送茶，李文忠、郭英、胡大海、常遇春同饮。 四文堂同下。四上手同送剑，李文忠、郭英、胡大海、常遇春同佩剑。）"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "听画角声响，元帅升帐，你我进帐参见。"
        },
        {
          "character": "郭英、胡大海、常遇春",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点。四文堂、四大铠、四长枪手、四弓箭手、四藤牌手、四火炮手引徐达同上，大纛旗随上。"
        },
        {
          "character": "徐达",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，军威浩，地动山摇，要把大元扫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达上高台。"
        },
        {
          "character": "李文忠、郭英、胡大海、常遇春",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "李文忠、郭英、胡大海、常遇春",
          "type": "同白",
          "text": "谢元帅！"
        },
        {
          "character": "徐达",
          "type": "念",
          "text": "昔日茅庐曾学艺，如今拜帅挂紫衣。六韬三略人难识，一战管取采石矶。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "本帅，姓徐名达字天德。蒙主重用，挂我为帅，先破牛渚渡，后破采石矶。 众位将军！"
        },
        {
          "character": "李文忠、郭英、胡大海、常遇春",
          "type": "同白",
          "text": "元帅！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "此番出兵，全仗诸位奋勇当先。功成之日，自然凌烟阁标名也。"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "元帅天生威武，智胜孙吴。"
        },
        {
          "character": "郭英运",
          "type": "白",
          "text": "筹帷幄，决胜千里。"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "大兵一到，哪怕郡城不克！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "元帅传令，末将等愿听指挥。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "好！难得众位将军协力同心。 李文忠听令！"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你带领三千长枪手，五百战船，先破牛渚渡，后破采石矶。听吾令下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。"
        },
        {
          "character": "李文忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "长枪手甲带马，李文忠上马，下。四长枪手随同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "郭英听令！"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你带领三千弓箭手，五百战船，先破牛渚渡，后破采石矶。听吾令下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "弓箭手甲带马，郭英上马，下。四弓箭手随同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "胡大海听令！"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你带领三千藤牌手，五百战船，先破牛渚渡，后破采石矶。听吾令下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "藤牌手甲带马，胡大海上马，下。四藤牌手随同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "常遇春听令！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你带领三千火炮手，五百战船，先破牛渚渡，后破采石矶。听吾令下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火炮手甲带马，常遇春上马，下。四火炮手随同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "分派已毕。众将官！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "人马往采石矶去者！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "泣颜回牌合头。众人同领起，同下。"
        }
      ]
    },
