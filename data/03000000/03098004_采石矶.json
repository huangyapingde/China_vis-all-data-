      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。四番兵引童章关同上。"
        },
        {
          "character": "童章关",
          "type": "白",
          "text": "某，童章关。今有朱蛮兴兵前来，夺取牛渚渡。奉命攻打头阵。 众将官，迎敌者！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！ （众人同走圆场。船夫暗上，众人同上船。李文忠、郭英、胡大海、常遇春、四长枪手、四弓箭手、四藤牌 手、四火炮手乘船同上。二龙出水会阵，起打。胡大海杀童章关，童章关落水死。四番兵同逃下，众人同收 下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。八番兵、四番将引铁木耳同上。〖快点绛唇〗。铁木耳登高台。"
        },
        {
          "character": "铁木耳",
          "type": "念",
          "text": "登坛传将令，炮响出营门。将士威风凛，一战定太平。"
        },
        {
