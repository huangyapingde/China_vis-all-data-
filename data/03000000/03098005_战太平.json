{
  "script_id": "03098005",
  "title": "战太平",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "花云",
      "hangdang": "老生"
    },
    {
      "name": "孙夫人",
      "hangdang": "旦"
    },
    {
      "name": "陈友谅",
      "hangdang": "净"
    },
    {
      "name": "朱文逊",
      "hangdang": "小生"
    },
    {
      "name": "花安",
      "hangdang": "丑"
    },
    {
      "name": "郜夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "花云辅朱元璋侄朱文逊驻守太平城。北汉王陈友谅来攻，花云奋勇抗御。不幸采石矶被陈部陈友杰偷袭，太\n平城因遭围困。花云突围，朱文逊眷恋家眷，贻误戎机，君臣被执。朱文逊屈降，反被陈友谅杀掉；花云志\n坚，陈友谅敬之，屡劝不降，乃缚高杆，扣弦威胁。花云挣脱绑索，力杀多人，终因箭创颇重，乃自刎死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引朱文逊同上。"
        },
        {
          "character": "朱文逊",
          "type": "引子",
          "text": "钦奉王旨意，镇守采石矶。"
        },
        {
          "character": "朱文逊",
          "type": "念",
          "text": "我本金枝玉叶根，特遣阃外做将军。虽非九重金阙地，皇恩加锡藩爵增。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "小王，朱文逊。奉了叔王旨意，同花云将军镇守太平城一带等处。只因陈友谅 兴兵前来夺取城池，为此与花将军商议破敌之策。 内侍，宣花将军进宫！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲向内。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "花将军进宫啊！"
        },
        {
          "character": "花云",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上。"
        },
        {
          "character": "花云",
          "type": "念",
          "text": "奉命守要城，日夜哪得宁？"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "臣，花云见驾，愿千岁千千岁！"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "将军平身，赐坐！"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "谢坐。宣臣进宫，有何国事议论？"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "将军哪！陈友谅兴兵前来，当如何破敌，特请将军商议！"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "待臣回府，点动人马，把守闸子口，再命人守住矶头。臣带兵抵贼，主公打本 去到金陵，请兵救应，何惧逆贼不退？"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "既然如此，将军回府披挂，守住要地，小王打本去至金陵便了。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "朱文逊",
          "type": "念",
          "text": "太平本是将军定，"
        },
        {
          "character": "花云",
          "type": "念",
          "text": "还须将军定太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。朱文逊、四太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郜夫人、孙夫人同上。"
        },
        {
          "character": "郜夫人",
          "type": "念",
          "text": "夫受皇家爵，"
        },
        {
          "character": "孙夫人",
          "type": "念",
          "text": "妻沾雨露恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引花云同上，四文堂同下。花云进门。"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同白",
          "text": "老爷！"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "夫人！请坐！"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花安暗上。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "可恼啊可恼！"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同白",
          "text": "啊！老爷今日回府，为何如此烦恼？"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "夫人有所不知，只因陈友谅兴兵前来，小千岁命我领兵抵贼。可恨贼寇，无端 又起风波，你道恼是不恼？"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同白",
          "text": "既是千岁有命，老爷请至将房披挂，待妾等点动人马，与老爷壮行。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "有劳二位夫人！正是："
        },
        {
          "character": "花云",
          "type": "念",
          "text": "青龙背上屯军马，"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同念",
          "text": "白虎当头休扎营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同白",
          "text": "花安，"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同白",
          "text": "传令众将，大堂伺候！"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花安向内。"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "下面听者：夫人有令，众将大堂伺候！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同唱",
          "text": "替夫君传将令士卒齐整！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠自两边分上。"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "参见夫人！"
        },
        {
          "character": "郜夫人、孙夫人",
          "type": "同白",
          "text": "站立两厢！"
        },
        {
          "character": "四龙套、四大铠",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "五营兵四哨将听令施行。"
        },
        {
          "character": "郜夫人",
          "type": "唱",
          "text": "陈友谅众贼寇抢州夺郡，"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "伤人命劫财帛扰乱乾坤。"
        },
        {
          "character": "郜夫人",
          "type": "唱",
          "text": "元帅爷遵奉了千岁命令，"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "镇闸口守矶头防贼攻城。"
        },
        {
          "character": "郜夫人",
          "type": "唱",
          "text": "必须要齐奋勇努力杀进，"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "畏惧贼退后者插箭游营。"
        },
        {
          "character": "郜夫人",
          "type": "唱",
          "text": "功成日官加职妻封子荫，"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "传后人振家声显耀门庭。"
        },
        {
          "character": "郜夫人",
          "type": "唱",
          "text": "自古道食君禄捐身舍命，"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "五凤楼标名姓图画麒麟。"
        },
        {
          "character": "花云",
          "type": "内唱",
          "text": "受君恩当报答臣把忠尽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上。"
        },
        {
          "character": "花云",
          "type": "唱",
          "text": "扫烟尘开疆土定主乾坤。 古至今多少人不惜性命， 君依礼臣尽忠哪顾宗亲。"
        },
        {
          "character": "郜夫人",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "郜夫人",
          "type": "唱",
          "text": "与老爷得胜酒开怀畅饮，"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "愿此去旗开展马到成功。"
        },
        {
          "character": "花云",
          "type": "唱",
          "text": "接过了得胜酒心中自忖， 转身来祭虚空过往尊神。 若能够扫逆贼苍生之幸， 方显得安邦将盖国俊英。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。四龙套、四大铠随同下。"
        },
        {
          "character": "郜夫人",
          "type": "唱",
          "text": "见老爷出府门威风凛凛，"
        },
        {
          "character": "孙夫人",
          "type": "唱",
          "text": "得胜时满炉香答谢天神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郜夫人、孙夫人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈友杰上。"
        },
        {
          "character": "陈友杰",
          "type": "念",
          "text": "两眼明星朗朗，熊腰虎背昂昂。单人匹马渡长江，个个闻名胆丧！"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "俺，陈友杰。兄王发兵，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点。四军士、四将官、军师引陈友谅同上。〖点绛唇〗。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "参见兄王！"
        },
        {
          "character": "陈友谅",
          "type": "白",
          "text": "御弟少礼，请坐！"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "陈友谅",
          "type": "念",
          "text": "幼年举子中皇榜，汉阳兴兵到武昌。药酒毒死徐寿辉，孤称一字北汉王。"
        },
        {
          "character": "陈友谅",
          "type": "白",
          "text": "孤，陈友谅。自汉阳起义以来，抢州夺郡，无所不克。朱元璋在金陵已登大宝， 是孤心怀不忿，为此兴兵夺取金陵。前面已是太平城。 大元帅！"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "兄王！"
        },
        {
          "character": "陈友谅",
          "type": "白",
          "text": "你同先行先抢太平城，孤同军师大兵随后。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "得令！ 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "军士甲带马，陈友杰上马。四军士、陈友杰同下。"
        },
        {
          "character": "陈友谅",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "陈友谅",
          "type": "白",
          "text": "人马缓缓而行！"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、陈友杰同上。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "俺，陈友杰。奉了兄王之命，攻打采石矶。 众将官，杀上前去！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。四龙套、四大铠引花云同上，会阵。"
        },
        {
          "character": "花云",
          "type": "唱",
          "text": "二马冲锋在沙场， 气得花云怒满膛。 无知贼子敢犯上， 狐群狗党一扫光。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "陈友杰",
          "type": "唱",
          "text": "花云小儿休逞强， 某家言来听端详。 劝你早把城池让， 不然尸首两分张！"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "花云",
          "type": "唱",
          "text": "贼子言语忒无状，"
        },
        {
          "character": "陈友杰",
          "type": "唱",
          "text": "违拗某家命不长。"
        },
        {
          "character": "花云",
          "type": "唱",
          "text": "金枪叫尔狗命丧， 翻江搅海战一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云、陈友杰同起打，陈友杰、四军士同败下，四龙套、四大铠同下，花云耍下场下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、陈英豹同上。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "俺，陈英豹。元帅出兵未归，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈友杰、四军士同败上。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "参见元帅，胜负如何？"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "大败而回，采石矶不能得破，如何是好？"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "元帅，当年朱蛮如何取得采石矶？"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "乃是常遇春见船上有桅，桅上有斗，将身藏在斗内，纵上矶头呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "元帅何不学他一学？"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "好，准备船只伺候！"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈英豹下。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "众将官，采石矶去者！"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场设采石矶头。四龙套、胡虎同上。"
        },
        {
          "character": "胡虎",
          "type": "白",
          "text": "俺，胡虎。奉了元帅将令，把守采石矶头。 众将官，小心把守！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！ （胡虎登城。水手甲摇船、陈英豹同上，攻，败下。水手乙摇船、陈友杰同上，攻，不成，攻，陈友杰扯住 胡虎枪头，趁势登矶头。陈友杰、胡虎同拉下，陈英豹、四军士同上，同登矶头，同下。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈友杰、胡虎同拉上，同起打。陈英豹、四军士同上，助战，杀胡虎死。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "得了采石矶头。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "迎接主公进城！"
        },
