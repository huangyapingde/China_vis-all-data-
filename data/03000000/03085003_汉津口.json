        {
          "character": "刘备",
          "type": "白",
          "text": "唉！刘玄德好生命苦，只望困守新野，缓图功业，谁知兵败当阳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四老军、简雍、糜竺、甘夫人同哭。"
