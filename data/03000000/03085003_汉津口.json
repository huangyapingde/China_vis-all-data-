{
  "script_id": "03085003",
  "title": "汉津口",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "刘琦",
      "hangdang": "小生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "许褚",
      "hangdang": "净"
    },
    {
      "name": "张辽",
      "hangdang": "老生"
    }
  ],
  "plot": "赵云突围，交阿斗于刘备，刘备掷地以慰赵云。时曹操领兵追至，幸得关羽搬来刘琦之兵抵御，终得脱险。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四刀手引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "威震乾坤，扶汉室，一点丹忱。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "忠义一腔冠古今，补天扶日志平生。英雄几见称天子？豪杰如斯乃圣人。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某、汉寿亭侯关羽。可恨曹操诓哄孺子，刘琮献了荆襄，反遭其害。刘皇叔弃 了新野，欲取荆州；曹兵百万，追赶甚紧。因此，诸葛军师命某前来江夏，向 大公子刘琦搬兵求救。无奈他连日染病未痊，不能发兵。某今在此，心悬两地， 好不焦烦人也！"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "想国家气运衰合人悲悼， 叹不尽创业难英雄功高。 刘皇叔帝室后欲将国保， 时不至空使人忧虑焦劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家将扶刘琦同上。"
        },
        {
          "character": "刘琦",
          "type": "西皮摇板",
          "text": "这几日染病疴今觉略好， 特来见汉寿侯发兵破曹。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "关二叔！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大公子！"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "小侄染病，有失奉陪，迟误国家大事，深感有罪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "公子贵恙既已痊愈，可即发兵，与某前去接应。恐刘皇叔悬望之至。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "发兵之事，小侄急如星火。适才我已传示大小将校府堂伺候。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "即可点将发兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "禀公子：孔明军师到。"
        },
        {
          "character": "刘琦、关羽",
          "type": "同白",
          "text": "啊！军师为何来此？ 快快有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请军师！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。诸葛亮上，刘琦、关羽同迎。"
        },
        {
          "character": "刘琦、关羽",
          "type": "同白",
          "text": "啊，军师到了，请！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、关羽、刘琦同进。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "不知军师驾到，未曾远迎，当面恕罪！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唉！此刻闲言也不及叙了。主公兵败当阳，久望关二将军搬兵不到，故此山人 亲自前来。望公子念昔日之情，即速发兵才是。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "刘琦一闻叔父兵败，恨不能插翅飞去接应。无奈患病数日，有误大事。此刻正 待发兵，不意军师到来。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "如此，可快快传点兵将！"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "是。 众将上堂听令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四将官自两边分上。"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "末将等参见军师！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "列位少礼，两旁听调！"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "就请军师发令！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有僭了。 关二将军可领兵一万，从汉津陆地前往当阳，接应主公，不得有误！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "某正在心悬急军师驾到， 好一似风云会波浪腾蛟。 府堂上领雄兵论令军校， 斩曹贼准备某偃月钢刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四刀手、关羽同下。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "汉寿侯此一去吓煞曹操， 还需要刘公子水路相邀。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "公子，你可领兵一万、从荆州水路接应。我自往夏口料理，亦来会合。舟船之 上，需要小心。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "刘琦",
          "type": "西皮摇板",
          "text": "感谢得军师到将兵提调， 去水路接皇叔不辞辛劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、刘琦同下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "这二路安排定谅来可保， 只因是时未至故尔奔劳。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "关羽、刘琦水陆二路已去，谅无可虑。我今去往夏口，收拾旧日军马，前往会 合。 左右，随我夏口去者！"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "曾学得黄石公兵机玄妙， 秉忠心保皇叔辅佐汉朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "曹操",
          "type": "内西皮导板",
          "text": "张翼德长坂坡天神模样！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四红大铠同上，同挖门。曹操冠带不正上，大纛旗倒举随上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "吓坏了曹丞相马蹄奔忙。 怕的他吼一声有如雷响， 怕的他多勇力丈八钢枪， 怕的他万军中斩取上将， 怕的他诸葛亮埋伏桥梁。 逃性命哪顾得人马瞎闯——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四红大铠、大纛旗、曹操同走圆场。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "任凭他刘玄德称帝为王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊同上。"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同西皮摇板",
          "text": "又不曾打败仗丞相何往？ 飞马来夹玉鞍挽住丝疆。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "丞相勿惊，谅那张飞一人，何足为惧？今我军急速回头杀去，刘玄德可擒也。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "刘玄德这三字切休再讲， 怕的是豹子头环眼老张。"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "何至如此！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "幸喜得我首级还在项上， 且退兵息争战免得恐慌。"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "丞相放心，我等俱都在此，何惧之有？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你等俱逃回来了么？"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "我等回来了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓煞我也。那张飞没有杀来么？"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "何会杀来！不知丞相为何如此惊慌逃走？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将不知，非是孤不战而退，只因昔日关羽曾与我言：张翼德在万马军中取上 将首级，如探囊取物。今若是大意，又恐众将有伤，故尔逃之。"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "啊！若依丞相之言，我等为无用之人矣。"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同西皮摇板",
          "text": "自幼儿随丞相无人敌挡，"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "长坂桥遇张飞未见弱强。"
        },
        {
          "character": "曹仁",
          "type": "西皮摇板",
          "text": "今日里见张飞分个上下，"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同西皮摇板",
          "text": "捉玄德保丞相驾坐朝纲。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "住了！你等俱要去战张飞，待我差人打听长坂坡消息，再战不迟。"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张辽，许褚听令！"
        },
        {
          "character": "张辽、许褚",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你二人前去长坂桥，探听张飞消息如何，速即回报！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "你二人探消息小心前往，"
        },
        {
          "character": "张辽、许褚",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "遇张飞即跑回迟误有伤。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "说一派丧气话令人沮丧，"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "许褚",
          "type": "西皮摇板",
          "text": "且去看真和假便知端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、许褚同下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "我本是惊弓鸟无处躲藏， 他二人初生犊不畏虎狼。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将！"
        },
        {
          "character": "张郃、李典、乐进、曹仁、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你等休逞血气之勇，藐视张飞，听我说与你们知道！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "只看他那胡须长得异样， 便可知战吕布天下名扬。 我和你保性命岂可孟浪， 何况他还有个兄长云长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚上。"
        },
        {
          "character": "许褚",
          "type": "西皮摇板",
          "text": "探知他缺兵计回复丞相，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "霎时间无踪影拆断桥梁。"
        },
        {
          "character": "许褚、张辽",
          "type": "同白",
          "text": "曹丞相：张飞已拆断桥梁而去！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊！拆断桥梁而去？"
        },
        {
          "character": "许褚、张辽",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "听此言不由我大笑拍掌， 那张飞也怕我兵勇将强。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "许褚",
          "type": "西皮摇板",
          "text": "适才间欲退兵多少惆怅，"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "问丞相为何事喜气洋洋？"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "请问丞相：为何发此大笑？"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我不笑别人，只笑张飞，真怕了我也，故尔拆桥而去。众将传令，速搭浮桥而 过，今夜必要将刘玄德擒拿！"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "且慢！启禀丞相：只恐怕是诸葛之诡计，我兵不可轻进！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀李典，你好胆小！岂不知张飞一勇之夫，哪有诈谋？我们搭桥，只恐传令 不齐。 众将，各取大石一块，填平溪河，违令者斩首！"
        },
        {
          "character": "许褚、张郃、李典、乐进、曹仁、张辽、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
