        {
          "character": null,
          "type": "stage",
          "text": "刘备哭。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "云便怀抱太子，力突重围，赖主公洪福，幸而得脱。适才公子尚在怀内啼哭， 此一会才不见动静，多则是不能保了！"
        },
        {
          "character": null,
