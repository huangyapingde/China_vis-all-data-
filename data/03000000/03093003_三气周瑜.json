{
  "script_id": "03093003",
  "title": "三气周瑜",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "周瑜以假途灭虢之计，暗取荆州，被诸葛亮识破。诸葛亮遣赵云、黄忠、魏延、张飞等各路截杀，周瑜惨败。\n周瑜盛怒之下，呕血而死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四马夫、四上手、四龙套、魏延、黄忠、赵云、张飞、糜竺、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "三顾茅庐出山林，保汉家，鼎足三分。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "地为阴来天为阳，九宫八卦腹内藏。周郎点动兵和将，要夺荆州梦一场！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人，诸葛亮。周郎意欲夺取荆州，不免点动人马，抵挡于他。 糜竺听令！"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这有书信一封，下到周郎那里，不得有误！"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜竺下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "四将军听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领一哨人马，镇守南城，周郎兵到，说破与他！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "黄老将军听令！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领一哨人马，埋伏公安，周郎兵到，截杀一阵，不得有误！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏延听令！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领一哨人马，埋伏江陵，周郎兵到，截杀一阵，不得有误！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三将军听令！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领一哨人马，埋伏芦花荡口！附耳上来！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "喳、喳、喳……得令！ 马来，马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上马。四马夫、张飞同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、四龙套、四上手同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丁奉、徐盛同上，双起霸。"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "俺，丁奉。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "俺，徐盛。"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "将军请了！"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "都督升帐，你我两厢伺候！"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、周瑜同上。〖点绛唇〗。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "参见都督！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "二位将军少礼。站立两厢！"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "周瑜",
          "type": "念",
          "text": "白马银枪配玉鞍，手持令箭登将坛。吴侯驾前保社稷，斩将夺旗用机关。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "本都，姓周名瑜字公瑾，吴侯驾前为臣。今奉旨意，催讨荆州。 丁、徐二将！"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "吩咐带马登舟去者！"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "带马登舟！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜、丁奉、徐盛同上马。众人同走圆场，二水手同上，周瑜、丁奉、徐盛同下马。众人同上船。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "开船！"
        },
        {
          "character": "二水手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "糜竺上。"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "奉了军师之命，与周郎下书。远远望见周郎来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、丁奉、徐盛、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "糜竺当道！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "参见都督！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "先生到此何事？"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "奉了主公之命，前来下书。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "有劳了！刘皇叔有书信到来，待我拆开一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二三锣。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "上写：“汉室宗亲刘玄德，拜上东吴水军大都督周公瑾：前者鲁肃过江催讨荆 州，备因无有存身之地，暂借荆州容身。望求都督与备二兵合一，攻打东西两 川，若得一川，定将荆州奉还，绝不食言。话不多叙，后会有期。刘备顿首拜。” 先生禀报皇叔，就说本督照书行事。"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "告辞！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "回来！依我一件！"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "本督人马到了南城，要皇叔迎接本督进城！"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "先生请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜竺下。"
        },
        {
          "character": "周瑜",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "都督为何发笑？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "刘备这封书信，叫本督二兵合一，攻打东西两川，我军人马到了南城，他必然 开城相迎，那时本督乘虚而入，杀他个措手不及，这岂不是明取西川，暗取荆 州！"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "都督高才！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "南城去者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、丁奉、徐盛同下。周瑜亮相，下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四白龙套、赵云同上，同上城。〖风入松〗。四龙套、丁奉、徐盛、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "来此已是南城。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "来在南城，为何不见刘备迎接于我！看城上插有白旗，难道又中了那诸葛亮之 计！待我打马向前。 呔，守城儿郎听者！禀报你家主帅：就说本督大兵到了！"
        },
        {
          "character": "四白龙套",
          "type": "同白",
          "text": "候着！ 启将军：周都督到！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "忽听儿郎一声报， 再与周郎说根苗。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "城下可是周都督？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "周都督，带兵何往？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "刘皇叔有书信与我，要本督二兵合一，共取西川。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哪里是攻打西川，分明是暗夺荆州，你道是与不是？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "四将军此言差矣！孙、刘两家和好，岂能如此！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "瞒得了你营众将，瞒不了诸葛先生。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "听一言来心头恼， 两目圆睁似火烧。 本督把计错用了， 反中诸葛计笼牢。 勒住丝缰把话表，"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "子龙！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "叫声子龙听根苗： 本督今日大兵到， 不夺荆州我不还朝！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "三军与爷开城道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扫头。开城，赵云、四白龙套同出城，会阵，同起打，周瑜、四龙套、丁奉、徐盛同败下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "收兵回城！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、四白龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖急急风〗。四红龙套、黄忠同上，过场，同下。周瑜、四龙套、丁奉、徐盛同上，黄忠、四红龙套同上，"
        },
        {
          "character": null,
          "type": "text",
          "text": "会阵，同起打。周瑜、四龙套、丁奉、徐盛同败下。黄忠、四红龙套同收下。〖急急风〗。四蓝龙套、魏"
        },
        {
          "character": null,
          "type": "text",
          "text": "延同上，过场，同下。周瑜、四龙套、丁奉、徐盛同上，魏延、四蓝龙套同上，会阵，同起打。周瑜、四龙"
        },
        {
          "character": null,
          "type": "text",
          "text": "套、丁奉、徐盛同败下。魏延、四蓝龙套同收下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四马夫、张飞同上，张飞两望门，埋伏，四马夫、张飞同虚下。"
        },
        {
          "character": "周瑜",
          "type": "内西皮导板",
          "text": "在南城与赵云打一仗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。周瑜、四龙套、丁奉、徐盛同上，周瑜摔吊毛。乱锤。周瑜拉马，上马。〖四击头〗。"
        },
        {
          "character": "周瑜",
          "type": "西皮二六板",
          "text": "口吐鲜血冒红光。 人马来在南城下， 遇见赵云摆战场。 我二人在南城打一仗，"
        },
        {
          "character": "周瑜",
          "type": "西皮快板",
          "text": "杀得我丢盔卸甲败回营房。 耳边厢又听得銮铃响， 两国人马到战场。 不顾生死往前闯， （周瑜勒马，滚头。周瑜下马，上高。黄忠、四红龙套、魏延、四蓝龙套同上，与四龙套、丁奉、徐盛同起 打，黄忠、魏延、丁奉、徐盛同打四股档，丁奉、徐盛同败下。黄忠、魏延同收下。周瑜下高台，拉马，上 马。）"
        },
        {
          "character": "周瑜",
          "type": "西皮快板",
          "text": "两国人马到战场； 他国人马打胜仗， 我国人马刀下亡。 不顾生死往前闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马夫自下场门同上，同倒脱靴，张飞上。"
        },
        {
          "character": "张飞",
          "type": "西皮散板",
          "text": "芦花荡闪出翼德张！ 披头散发一员将， 想必他是小周郎。 周郎我儿你是不是？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "张飞",
          "type": "西皮散板",
          "text": "通上名来好动刀枪！"
        },
        {
          "character": "周瑜",
          "type": "白",
