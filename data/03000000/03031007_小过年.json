        {
          "character": "白瞎子",
          "type": "白",
          "text": "得啦！没那讲究儿。您戴吧！"
        },
        {
          "character": "王小",
          "type": "白",
          "text": "您真是好人。"
        },
        {
          "character": "白瞎子",
          "type": "白",
          "text": "我是热心肠的人，就见不得这个。我刚要了一笔钱，我也用不着，给您垫办着 花吧！"
        },
        {
          "character": "王小",
          "type": "白",
          "text": "哟！穿您衣裳，还花您的钱？"
        },
        {
          "character": "白瞎子",
          "type": "白",
          "text": "没关系。"
        },
        {
          "character": "王小",
          "type": "白",
          "text": "您真好。"
        },
        {
          "character": "白瞎子",
          "type": "白",
          "text": "我好倒是好，就是没有眼睛啦！"
        },
        {
          "character": "王小",
          "type": "白",
          "text": "这么好人，怎么没有眼睛啊？"
        },
        {
          "character": "白瞎子",
          "type": "白",
          "text": "不单没眼睛，连个媳妇儿都没有。"
