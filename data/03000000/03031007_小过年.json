          "text": "王小、丁氏同站起来表示欢迎。"
        },
        {
          "character": "小孩",
          "type": "白",
          "text": "您请坐，我给您拜年。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小孩磕头。"
        },
        {
          "character": "小孩",
          "type": "白",
          "text": "您过年过得好哇？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王小、丁氏同点头。"
        },
        {
          "character": "小孩",
          "type": "白",
          "text": "您过年买了几斤肉哇？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王小伸出双手，张开十指。"
        },
        {
          "character": "小孩",
          "type": "白",
          "text": "十斤。买了几斤酱啊？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王小伸出双手，张开十指。"
        },
        {
          "character": "小孩",
          "type": "白",
          "text": "十斤。买了几斤醋啊？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王小伸出双手，张开十指。"
