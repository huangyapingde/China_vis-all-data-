          "character": "孝子",
          "type": "白",
          "text": "王小儿啊，我爸爸死啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孝子磕头，跑下。王小、丁氏同进门，王小、丁氏同坐生气。"
        },
        {
          "character": "小孩",
          "type": "内白",
          "text": "啊哈！"
