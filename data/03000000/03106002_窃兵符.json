        {
          "character": null,
          "type": "stage",
          "text": "大太监为赵夫人松绑。"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "孤不罪责谁敢欺。 请自平身休忧虑，"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "谢主隆恩！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "王恩浩荡实无极！ 臣妾有言向君启， 俯乞允臣把话提： 臣家计虽然不为富， 资财也有十万余。 非是沽名和钓誉， 愿散与军兵作生计。 来朝全数造册籍， 按户按名恤孤遗。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "老夫人如此明大义， 军兵自必诵德懿。 孤自当取重夫人意， 分金恤孤断无欺。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "相国！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "仗你运筹安社稷──"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "臣立作手书不迟疑。 邀求魏邦将兵起， 同心协力驱强敌。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "好哇！"
