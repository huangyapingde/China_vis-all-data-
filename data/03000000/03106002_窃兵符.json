        {
          "character": "白起",
          "type": "黄龙滚",
          "text": "某自来性烈刚坚， 某自来性烈刚坚， 不似那寻常懦汉。 恨范雎秉政持权， 恨范雎秉政持权， 把栋梁无端倾陷。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "范雎呀，范雎！"
        },
        {
          "character": "白起",
          "type": "黄龙滚",
          "text": "有一朝使某起复见天颜， 那时节前嫌后怨合伊算。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "白起",
          "type": "黄龙滚",
          "text": "恼得俺睡魔鼾鼾， 恼得俺睡魔鼾鼾， 气得咱神疲倦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起睡介。〖起四更鼓〗。白起精神恍惚。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "白起",
          "type": "上小楼",
          "text": "耳边厢似闻不住喧， 是何人肆无忌惮， 胆敢将名姓胡提， 胆敢将名姓胡提， 试问人人孰敢擅犯？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起四望。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起猛坐。"
        },
        {
          "character": "白起",
          "type": "上小楼",
          "text": "尔魑魅魍魉没个贵贱，"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起执剑乱劈。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "有鬼！有鬼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家将同上。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "老爷！老爷！"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "有鬼！有鬼！"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "是小人们在此。哪里有鬼？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。白起揉眼、左右看。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "白起",
          "type": "上小楼",
          "text": "不信这时衰双目昏乱。"
        },
        {
          "character": "郑安平",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠持枪、四校尉引郑安平同上。"
        },
        {
          "character": "郑安平",
          "type": "红绣鞋",
          "text": "星夜不离雕鞍，雕鞍， 君命煌煌难延，难延， 闻说道去不远， 已宿在杜邮间。"
        },
        {
          "character": "四大铠、四校尉",
          "type": "同白",
          "text": "来此杜邮驿。"
        },
        {
          "character": "郑安平",
          "type": "白",
          "text": "打了进去！"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "谁敢擅闯驿门！"
        },
        {
          "character": "郑安平",
          "type": "白",
          "text": "奉有君命，白起接旨！ 中国京剧戏考 《窃兵符》【二本】 14"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "啊！千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起跪。"
        },
        {
          "character": "郑安平",
          "type": "白",
          "text": "君上有旨：“道尔白起不能悔过自新，反行诽镑君相，逆罪难宽，赐上方宝剑 沿途追赶，令其自裁。如敢违抗，家属同斩不贷。”"
        },
        {
          "character": "郑安平",
          "type": "红绣鞋",
          "text": "早自裁免株连。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起接剑。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "天哪天！诚如范蠡所言：“狡兔死，走狗烹。”某白起今日固当烹矣！"
        },
        {
          "character": "白起",
          "type": "叠字犯",
          "text": "呵呵！ 君王奈何偏见， 君恩全无一线。 唯佞臣言是听， 干城命如草菅。 呼地号天却向谁分辩？"
        },
        {
          "character": "郑安平",
          "type": "白",
          "text": "白起，你今一命犹惜，那降卒何罪，你便杀其四十余万。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "啊，啊，是了！某死固其宜也！"
        },
        {
          "character": "白起",
          "type": "叠字犯",
          "text": "自悔前忒煞伤残， 到而今理应偿还！ 到而今理应偿还！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起拔剑。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白起自刎。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家将同扶白起坐椅，白起死。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "哎呀！老爷呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家将抬白起同下。"
        },
        {
          "character": "郑安平",
          "type": "白",
          "text": "白起已死，交旨去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四校尉、郑安平同上马。"
        },
        {
          "character": "郑安平",
          "type": "叠字犯",
          "text": "须知君命严不容缓， 管叫你身消名灭顷刻间！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑安平、四大铠、四校尉同下。"
        },
        {
