        {
          "character": "赵胜、赵夫人",
          "type": "同白",
          "text": "遵旨！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "治国安邦费尽心思！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵丹下，四太监、大太监同随下。"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "未审太平是何时？"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "思想娇儿心惨凄！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "老夫人，那众军性命又当如何呢？"
