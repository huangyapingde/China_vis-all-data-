{
  "script_id": "03106002",
  "title": "窃兵符",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "白起",
      "hangdang": "武生"
    }
  ],
  "plot": "秦王疑白起有异志，令其自裁。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四牢子、二家将引赵胜同上。"
        },
        {
          "character": "赵胜",
          "type": "念",
          "text": "功高名重不足言，行深德重可格天。当权若果行方便，儿孙代代禄绵绵。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "某，平原君赵胜。前者误受冯亭上党之地，致使秦邦构怨兴兵。喜得廉颇持重， 足能抗拒强秦。岂料大王听信郭开之言，竟以赵括去代廉颇为将。吾知那赵 括虽读父书，奈他言过其实，恐难掌此大权。前曰接得捷报，说我军已将秦兵 杀退数十余里，大王十分喜悦，道郭开举荐得人，晋封他为上大夫。昨又接得 飞报，说我军反被秦兵困在长平关，特地飞奔而来，请兵相救。大王一闻此言， 犹疑不信，欲命廉颇去探虚实。无奈廉老将军染病在床，不能承旨，因此命 我前来探望。果实病沉难起，只好以此回奏，且看大王如何区处？ 来，上朝去者！"
        },
        {
          "character": "四牢子",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "忆前番那冯亭来献上党， 我主爷大张筵庆贺开疆。 满朝中君与臣谁不欢畅， 独我兄平阳君他道不祥。 譬如那务农事耕田一样， 人出力我收谷怎能安康？ 且秦家掌中物岂甘相让， 他定然起雄兵相见沙场。 到而今始信他前言不爽， 到此时进退难如何主张！"
        },
        {
          "character": "四军士",
          "type": "内同白",
          "text": "走啊！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "遥望处那群人惊号喧嚷，"
        },
        {
          "character": "四军士",
          "type": "内同哭",
          "text": "喂呀！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "待其来须止住问个端详。"
        },
        {
          "character": "四牢子",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同上。"
        },
        {
          "character": "四牢子",
          "type": "同白",
          "text": "相爷在此，叫你们向前答话，"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "是是是。 哎呀相爷呀！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "尔等从何而来？如何这般奔走号哭？"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "我等打从长平而来。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "打从长平而来！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "我军毕竟胜负如何？"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "不不不……好了！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "起来讲话！ 中国京剧戏考 《窃兵符》【二本】 2"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "相爷容禀！"
        },
        {
          "character": "四军士",
          "type": "同八声甘州",
          "text": "提起伤心！ 那秦家军兵个个虎狼， 我赵大将军不从谏自作主张！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "有谁谏来？赵大将军怎生自作主张？"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "大将军上任之后，把廉大将军约束全行更改。头阵杀得秦军倒退十数余里，是 他哈哈大笑，自道秦将不是对手，喝令全军紧紧追赶。冯亭谏道：秦军奸诈， 此必诱哄之计，万万不可追赶。大将军不听，催军紧往前追，岂知东边大将胡 伤、王龁杀出，西边蒙骜、王翦杀来，后面被司马错、司马梗二将绝了粮道， 顶头又遇着秦国大将白起冲来。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！那那秦将白起竟在军中么？"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "哎！怎么不在？我赵大将军起初也以为白起不在军中，自谓天下无敌，此时见 了白起，吓得他心胆俱裂。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "四军士",
          "type": "同八声甘州",
          "text": "顿时吓得魂飞扬， 马失前蹄自丧亡！ 我等兵将无主张， 或降或死难躲藏。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！有、有、有这等事！那、那、那苏射、傅豹、王容诸将于今安在？"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "傅豹死于王翦刀下，王容丧于蒙骜枪尖，冯亭拔剑自刎，苏射奔往他方。所有 兵卒，除阵亡不计，其余未伤者，全被秦军勒降。谁知狠心的白起，将我降卒， 分为十个营头，配他秦军二十万，其夜，明以犒劳牛酒，暗地将我兵开刀杀 死。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "可怜哪！我军前后降者，共有四十余万，被他一夜坑杀，只存我们二百四十余 人，放归故里，好扬他秦国之威。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "哎呀呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵胜哭。"
        },
        {
          "character": "四军士",
          "type": "同八声甘州",
          "text": "此实言毫不妄， 特地赶回报君相。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "知道了。你们暂且各自回家，安慰老小。我立时进朝，奏与大王，自有恤典。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "哎！苦啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同下。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "哎呀！我赵邦从此休矣！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "听报说吓得我魂飞魄丧， 亘古来何曾闻这般惨伤！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "快引导进朝堂去见君上，"
        },
        {
          "character": "四牢子",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "君上听只怕他胆落心慌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵胜、四牢子、二家将同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵夫人上，丫鬟暗上。"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "前闻报我的儿大获胜仗， 军与民似觉得喜气洋洋。 昨又传困长平请救急往， 我逆料前捷非后报是无庸参详。 赵括儿虽知兵无甚度量， 又兼他执己见秉性忒刚。 同父谈兵便便言尚且不让， 何况是今为将谁敢与商？ 中国京剧戏考 《窃兵符》【二本】 3 胜和败固然是兵家难量， 也须要人力施策划周详。 但愿得秦与赵把和来讲， 庶免我未亡人愁挂心肠。"
        },
        {
          "character": "院子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "念",
          "text": "忙将惊天事，报与主母知。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哎呀太夫人，大事不好了！"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "为何如此慌张，敢是少老爷有甚不利么？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "老奴呵！"
        },
        {
          "character": "院子",
          "type": "唱",
          "text": "正行去到市口上， 军民哭得好凄凉。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "他们因何而哭？"
        },
        {
          "character": "院子",
          "type": "唱",
          "text": "多道主上错遣将， 以致丧师辱家邦。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "于今少爷安在？"
        },
        {
          "character": "院子",
          "type": "唱",
          "text": "他身死头悬高杆上， 赵卒全被秦招降。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "院子",
          "type": "唱",
          "text": "不道白起良心丧， 一夜坑杀赵卒亡。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "太夫人哪！"
        },
        {
          "character": "院子",
          "type": "唱",
          "text": "邯郸瓦全空指望， 不日定归虎狼邦。 收拾行装备妥当， 好向他国把身藏。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "咳嘿！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "此祸不待今日讲， 老身早知有此殃！"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "老相公啊！老相公！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "你先见之明丝毫不爽，"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "哎，老相公啊！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "偏偏君王他不推详。 大难既成我何往， 藏则臭名更难当。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "快快与我上了绑，"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "太夫人，绑哪个呀？"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "我要自绑衔刀去见君王。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哎呀，太夫人哪！"
        },
        {
          "character": "院子",
          "type": "唱",
          "text": "当初少爷去为将， 主母也曾谏君王。 今日之败是他自己闯， 岂能移祸将夫人伤。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "国有常典刑与赏， 不遵愈觉名不扬。 你们若不将我绑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、丫鬟同跪。"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "哎呀！奴婢们不敢！ 中国京剧戏考 《窃兵符》【二本】 4"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "取我宝剑过来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "夫人要宝剑何用？"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "快快取来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是，宝剑在此。"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "你们真不与我上绑么？"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "哎呀，这万万不敢哪！"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "倒不如拔宝剑我自己裁戕。"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "哎呀！愿绑，愿绑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、丫鬟同綁赵夫人。"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "哎！太夫人哪！"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "不用车马人役往，"
        },
        {
          "character": "赵夫人",
          "type": "白",
          "text": "就是你们二人随我去者。"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "赵夫人",
          "type": "唱",
          "text": "莫管我步履艰难进朝堂。"
        },
        {
          "character": "院子、丫鬟",
          "type": "同白",
          "text": "哎呀呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、丫鬟扶赵夫人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "赵胜",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵胜上。"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "我胸中犹如鹿头撞， 心痛好似万箭伤， 今日难免将主谤，"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "有请大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引赵丹同上。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "你面带惆怅为哪桩？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "不、不、不好了！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "此话从何说起？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "臣奉旨去探廉颇病症，岂知他病势沉重，不能起床。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "原来如此。廉颇既不能起床，另选别将前去探取，也就是了，何必这般慌张！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "哎！我军全已丧尽，还去探取谁来，探取谁来？"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "啊！我军全已丧尽了么？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "全已丧尽了！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "你何以知晓？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "臣廉府探病而归，行至市口呵！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "探病方出廉府第， 一马来在大通衝。 遥闻人声似鼎沸， 问来才知是败军归。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哦，可曾问他们是怎样败回来的？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "皆因是大王失主意， 将大权错付赵括失军机。 到如今方信赵母语， 中国京剧戏考 《窃兵符》【二本】 5 果然他一旦偾事悔不及。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "呃！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "寡人自来有眼力， 赵括才智谁及伊？"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "是了！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "这多是嫉贤妒能的把他毁， 将无作有把人欺！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "他死沙场不足惜，"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "只可怜随军将士死得屈！ 眼见我赵邦的山河一旦俱抛去， 还有谁闲暇毁谤伊。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "他句句讽孤全无忌， 莫非那赵括果失机？"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "你快说真情与实底， 从头一一奏孤知。"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "那赵括初得符和敕， 将廉颇约束全改移。 初战秦兵败数里， 原来他不是真输是诱敌。 赵括无谋令全军尽行追去， 冯亭苦谏反被欺。 人马追到长平地， 不见秦军他不疑。 顿时大笑增骄气， 自夸英勇名不虚。 话犹未了炮声起， 四面八方人马嘶。 那东边胡伤、王龁杀上去， 西边蒙骜、王翦来得奇。 后面司马弟兄断了我国的囤粮地， 军中命脉一旦失。 前驱刚刚遇着秦白起， 吓得他胆落魄散魂又飞， 偏偏坐骑打前失， 人头早已在那白起手中提。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "血淋淋将他竿头系， 招取我军把秦归。 更可恨白起施毒计， 可怜那四十余万赵卒被他一夜坑杀无剩余。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "啊！竟有、有、有……这等事？"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "放回的儿郎向臣启， 似此大事他怎敢胡乱提。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "大王看仔细！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "吓得孤手足无措身战栗，"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "魄散魂消眼昏迷。 中国京剧戏考 《窃兵符》【二本】 6"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "追思赵母的言和语，"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "教孤追悔悔也悔不及！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "前事已往难追悔， 眼前便有大灾危。 那虎狼既已长其势，"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "臣怕呀！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "怕只怕赵邦将倾在须臾。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "若果如此怎样处？ 天地虽宽孤靠谁！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "这、这、这……"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "抓耳烧脆无主意，"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "也只好待他来或早或迟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启大王：大事不好了。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "谍人飞马来报，说我国兵将尽丧长平关。秦将白起着人归国，请旨进兵，不日 就要围我邯郸来了。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "如何！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "对那探事儿郎去说，叫他再去详细打探，白起毕竟几时进兵，速速回报。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "罢了啊，罢了！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "孤自错固当死社稷，"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "相国！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "只是累你全家向何处依？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵丹泣。"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "君臣哀痛如刀刺，"
        },
        {
          "character": "郭开",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭开上。"
        },
        {
          "character": "郭开",
          "type": "唱",
          "text": "丑媳终难把姑嫜离。"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "臣，郭开参见大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵胜扭郭开衣领。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "过来！"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "啊啊相国！相国！你为何如此？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "郭开！"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "相、相、相……国！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "尔所举的好将啊！所举的好将啊！ 武士们，速将此佞贼拿下了！"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "哎呀，大王明鉴哪！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "且慢！赵括才能，人人皆知，且用与不用，自在寡人，郭开何罪之有。"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "大王圣明！大王圣明！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "大王啊，今日若不罪他，何以安慰军民？秦兵不日将到，却教何人护国？"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "相国若虑秦兵前来攻我邯郸，下官有个撤退白起之计。白起不在，则秦家无能 为力矣。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "大王不要轻信，他有何能撤退那白起呀？"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "郭开固然无能，特来荐举髙士，能撤退白起，也未可知呀！ 中国京剧戏考 《窃兵符》【二本】 7"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "你、你、你又来混行举荐么？"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "不敢混荐。这位髙士不是别人，就是贵门下，苏秦之弟苏代。"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "哦哦哦！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "你怎能晓得苏代能退白起呢？讲！"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "是。适才白起进兵的消息传到我国，军民吓得呼天号地，唯见苏代掀髯大笑。 臣便问他为何发笑。他说：“大王若能用我，便能使白起撤退，则邯郸管保无 恙也。”"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "相国，苏代毕竟如何？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "此人果有经济之才，主公合当一问。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "今在哪里？"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "现在朝房，"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "宣他进见。"
        },
        {
          "character": "郭开",
          "type": "白",
          "text": "领旨！ 啊苏先生！大王请你上殿相见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏代上。"
        },
        {
          "character": "苏代",
          "type": "念",
          "text": "人情固如是，舌辩运机谋。"
        },
        {
          "character": "苏代",
          "type": "白",
          "text": "大王在上，山人苏代朝参！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "哎呀，先生是客，只行常礼！"
        },
        {
          "character": "苏代",
          "type": "白",
          "text": "遵命！大王！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "苏代",
          "type": "白",
          "text": "相国！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "苏代",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "吾邦不幸，遭秦欺侮，闻先生有退白起之谋，果是真否？"
        },
        {
          "character": "苏代",
          "type": "白",
          "text": "窃闻士者谁不贪谷，臣者最忌失权，此皆人情也。秦国大权，全属范雎独掌。 今者白起之功，如汤之伊尹，周之吕望，若再围下邯郸，则赵邦必亡，嬴秦必 成帝业，则白起为佐命之元勋。白起既为元勋，则范雎之大权将为白起所夺矣。"
        },
        {
          "character": "赵丹、赵胜",
          "type": "同白",
          "text": "哦哦哦！"
        },
        {
          "character": "苏代",
          "type": "白",
          "text": "苏代今欲去见范雎，将此番言语一说，不怕那范雎不起恋栈贪谷之心。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "话虽如此，只是他怎生撤退白起呢？"
        },
        {
          "character": "苏代",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "苏代",
          "type": "唱",
          "text": "那范雎听代言必生妒忌， 料着他定向我求策画机。 我叫他立许那韩赵割地， 得了地他君臣欢喜不疑。 说范雎用巧计调回白起， 不怕那武安君不即驰归。 既驰归那白起谤言必起， 臣谤君岂能逃市曹诛夷？ 此是我预定的自戕之计， 请君相且深思以为何如？"
        },
        {
          "character": "赵丹、赵胜",
          "type": "同白",
          "text": "好妙计也！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "果能遂得先生语， 诚是孤赵邦再造时。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "吩咐度支！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "那黄金准准要万镒， 车马人役要整齐。 即请先生你快往从事，"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "寡人呵！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "日夜望你好音回。 中国京剧戏考 《窃兵符》【二本】 8"
        },
        {
          "character": "苏代",
          "type": "唱",
          "text": "躬身辞王下殿去，"
        },
        {
          "character": "赵丹、赵胜",
          "type": "同白",
          "text": "奉送先生！"
        },
        {
          "character": "苏代",
          "type": "白",
          "text": "哎呀不敢。大王！相国！"
        },
        {
          "character": "赵丹、赵胜",
          "type": "同白",
          "text": "先生！"
        },
        {
          "character": "苏代",
          "type": "唱",
          "text": "这消息切莫教外人得知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏代、郭开同下。"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "不由孤家愁变喜，"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "苦啊！"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "大王你听啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "听四面哭得好惨凄！"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "我的儿呀！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "呀！ （唱〉　　　　　这边厢父哭子来自何处？"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "我的夫啊！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "那边厢妻哭夫无有见期。"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "我那兄弟呀！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "那一旁明明是兄哭其弟，"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "我那孙儿呀！"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "这一旁祖哭孙愈觉伤悲？"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "孤今朝始信将军语，"
        },
        {
          "character": "赵胜",
          "type": "唱",
          "text": "恰似那大限来时各自飞。"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "快偿命来呀！快偿命来呀！"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵丹",
          "type": "唱",
          "text": "猛然又听声鼎沸，"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启大王：赵括之母，自缚衔刀，见君请命，被一般阵亡的家属团团围住，向赵 母索命，请大王裁处。"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "有这等事？"
        },
        {
          "character": "赵胜",
          "type": "白",
          "text": "这兵败之事与赵母无干，怎能要她偿命？"
        },
        {
          "character": "赵丹",
          "type": "白",
          "text": "来，快去传旨：长平之败，是孤用人之差，不与赵母相干，叫他们速行散去， 寡人自有赐恤典章颁下。速宣赵母进见。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨！ 众百姓听着！大王言道：长平之败，是圣上用人之错，不与赵母相干，叫尔等 速行散去。大王自有赐恤典章颁发。旨传赵母进见哪！"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "千岁！千岁！千千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。赵夫人上。"
        },
        {
          "character": "赵夫人",
