        },
        {
          "character": "李刚",
          "type": "白",
          "text": "李虎！传我将令，吩咐大小三军，与爷反！反！反！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李刚下。"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "下面听者：三千岁有令，大小三军，与爷反！反！反！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李虎下。"
        }
      ]
    },
