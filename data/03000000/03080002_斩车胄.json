        },
        {
          "character": "四马童",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、关羽同一翻、两翻。关羽下马，进大营，坐。"
        },
        {
          "character": "张飞",
          "type": "内白",
