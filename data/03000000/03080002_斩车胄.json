        },
        {
          "character": "关羽",
          "type": "白",
          "text": "适才有人送信前来，那车胄定下毒计，在城内埋伏五百削刀手，要暗害你我弟 兄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞背供。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我当为了什么大事，原来是一桩小事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞对关羽。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥但放宽心，那车胄无有埋伏便罢——"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "若有埋伏呢？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "若有埋伏，小弟的跨下马、掌中枪，要杀他个干干净净！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呃！休要鲁莽，必须定计而行。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥有何妙计？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我营现有曹营的盔甲，叫三军更换；你我弟兄假充张辽、许褚，趁着黑夜，诈 开城门，一拥而进，杀他个片甲不留。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "真乃好计！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "照计而行。众三军！"
        },
        {
          "character": "四上手、四马童",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "今晚饱餐战饭，改换曹军盔甲，随某赚城去者！"
