{
  "script_id": "03051006",
  "title": "马陵道",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "孙膑",
      "hangdang": "老生"
    },
    {
      "name": "庞涓",
      "hangdang": "净"
    },
    {
      "name": "魏阳公主",
