{
  "script_id": "03092002",
  "title": "湘江会",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "钟无盐",
      "hangdang": "刀马旦"
    },
    {
      "name": "吴起",
      "hangdang": "老生"
    },
    {
      "name": "齐宣王",
      "hangdang": "丑"
    }
  ],
  "plot": "战国时，魏灵公欲加害齐宣王，因设湘江大会。吴起献计，与齐王较射。齐后钟无盐随齐宣王赴会，射死魏\n灵公，战败吴起，保齐宣王出险。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴起上，起霸。"
        },
        {
          "character": "吴起",
          "type": "念",
          "text": "忆昔当年摆战场，盖国山前自为王。心中只恨钟无盐，豪杰一怒反齐邦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "俺，吴起。鲁侯驾前为臣。只因魏侯摆下湘江大会，有书信前来，请某赴会。 众将官！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "带马魏邦去者！"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴起、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手引孙操、姬颜骑马同上。"
        },
        {
          "character": "姬颜",
          "type": "白",
          "text": "姬颜。"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "孙操。"
        },
        {
          "character": "姬颜",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "姬颜",
          "type": "白",
          "text": "只因魏侯请我等赴湘江大会，你我一同前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬颜、孙操同遥看。"
        },
        {
          "character": "姬颜",
          "type": "白",
          "text": "一言未尽，吴驸马来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、吴起同上。"
        },
        {
          "character": "姬颜、孙操",
          "type": "同白",
          "text": "原来是吴驸马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬颜、孙操、吴起同下马。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "二公今欲何往？"
        },
        {
          "character": "姬颜、孙操",
          "type": "同白",
          "text": "只因魏侯摆下湘江大会，请我等前去赴会。"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "某也为此事而来，你我一同前往。"
        },
        {
          "character": "姬颜、孙操",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "姬颜、孙操、吴起",
          "type": "同白",
          "text": "来，带马魏邦去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬颜、孙操、吴起同上马。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、魏灵公同上。"
        },
        {
          "character": "魏灵公",
          "type": "引子",
          "text": "心中恼恨齐宣王，不该起意灭各邦。"
        },
        {
          "character": "魏灵公",
          "type": "念",
          "text": "忆昔当年摆战场，临潼聚会把名扬。心中只把齐王恨，不该恃强欺各邦。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "孤，魏侯见公在位。可恨齐王，得了钟无盐，恃强凌弱，压服各邦。是我设摆 湘江大会，邀请各路诸侯前来商议，共灭齐邦。 来！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "吴驸马同各路诸侯到！"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。吴起、孙操、姬颜同上。"
        },
        {
          "character": "吴起、孙操、姬颜",
          "type": "同白",
          "text": "魏侯千岁！"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "列位到此，未曾远迎，当面恕罪！"
        },
        {
          "character": "吴起、孙操、姬颜",
          "type": "同白",
          "text": "岂敢！我等来得鲁莽。千岁恕罪！"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "岂敢！如今摆下湘江大会，共灭齐邦，众位有何妙计？"
        },
        {
          "character": "吴起",
          "type": "白",
          "text": "就在校场，百步之外，立一高杆，上悬金钱一枚，马鞭一条，哪家箭射金钱响 亮，马鞭落地，就扶哪家为上。"
        },
        {
          "character": "魏灵公",
          "type": "白",
          "text": "真乃好计。等候他君、妃到此，照计而行。请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、齐宣王同上。"
        },
        {
          "character": "齐宣王",
          "type": "引子",
          "text": "风阁龙楼，万古千秋。"
        },
        {
          "character": "齐宣王",
          "type": "念",
          "text": "忆昔当年居越边，箭射白兔在桑园。孤王收下钟无盐，稳坐宫中乐安然。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "孤，齐宣王在位。自登基以来，风调雨顺，国泰民安。今当设立早朝。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "展放龙门哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晏婴上。"
        },
        {
          "character": "晏婴",
          "type": "念",
          "text": "忙将魏邦事，奏与大王知。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "参见大王！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "卿家有何本奏？"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "启奏大王：魏邦有书信到来，请我主龙目御览。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "呈上龙书案。"
        },
        {
          "character": "晏婴",
          "type": "白",
          "text": "遵旨！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "魏侯有书信来到，待孤一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。齐宣王看书。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "唔呼呀！我当为了何事，原来魏侯请孤赴湘江大会。我想那老儿与孤无有什么 情面。不免将无盐娘娘宣上殿来，商议明白，再作道理。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "替孤传旨：宣无盐娘娘上上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！ 万岁有旨：无盐娘娘上殿哪！"
        },
        {
          "character": "钟无盐",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟无盐上。"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "胸藏智谋韬略广，全凭枪马世无双。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "妾妃见驾，大王千岁！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "梓童平身。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "谢千岁！宣妾妃上殿，有何国事议论？"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "今有魏灵公书信到来，请孤赴湘江大会，宣梓童上殿商议，孤是去与不去？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "大王不必犹豫，待妾妃八卦之中查看一番便了。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "就依梓童。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "香案伺候！"
        },
        {
          "character": "钟无盐",
          "type": "西皮原板",
          "text": "无盐女在金殿八卦查看， 看一看湘江会是何机关。 原来是小吴起巧计来献， 他要害我的主命丧黄泉。"
        },
        {
          "character": "钟无盐",
          "type": "西皮流水板",
          "text": "一炷清香叩上苍， 八卦之中看端详。 祝告神圣俱在上， 只见凶多少吉祥。 迈步且把金殿上， 龙书案前奏大王。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "梓童查看，吉凶如何？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "启奏大王：妾妃查看八卦之中，凶多吉少！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "既然凶多吉少，孤王不去也罢！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "大王若是不去，岂不被他国人等耻笑！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "依梓童之见？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "大王此去，妾妃保驾，料然无事。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "梓童替孤传旨：就命田能、关素真也随孤赴会。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "齐宣王",
          "type": "念",
          "text": "袍袖一抖君臣散，"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "竹帘卷起驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐宣王、钟无盐同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "田能、关素真同上，同起霸。"
        },
        {
          "character": "田能",
          "type": "念",
          "text": "头戴金盔凤翅飘，胸怀韬略逞英豪。"
        },
        {
          "character": "关素真",
          "type": "念",
          "text": "校场点动兵和将，湘江大会走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手自两边分上。"
        },
        {
          "character": "田能、关素真",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "田能",
          "type": "白",
          "text": "田能。"
        },
        {
          "character": "关素贞",
          "type": "白",
          "text": "关素真。"
        },
        {
          "character": "田能",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "关素真",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "田能",
          "type": "白",
          "text": "奉了大王之命，校场点动人马，随驾赴会。人马齐备，等候大王发兵。"
        },
        {
          "character": "关素真",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监、钟无盐、齐宣王同上。"
        },
        {
          "character": "齐宣王",
          "type": "念",
          "text": "孤王到校场，"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "保主赴湘江。"
        },
        {
          "character": "田能、关素真",
          "type": "同白",
          "text": "参见大王！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "田能、关素真",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "田能、关素真",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "替孤传旨，兵发桑园。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "兵发桑园！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "来到桑园。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同挖开。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "启大王：来到桑园。"
        },
        {
          "character": "齐宣王",
          "type": "白",
          "text": "替孤传旨：一半人马扎住桑园，一半人马随孤赴会。就此兵发魏邦！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "领旨！ 众将官！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "一半人马扎住桑园，一半人马随大王前去赴会。就此兵发魏邦！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四校尉、魏灵公同上。"
        },
        {
          "character": "魏灵公",
          "type": "念",
          "text": "摆下湘江会，捉拿燕雀归！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
