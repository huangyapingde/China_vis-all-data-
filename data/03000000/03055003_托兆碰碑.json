{
  "script_id": "03055003",
  "title": "托兆碰碑",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "杨继业",
      "hangdang": "老生"
    },
    {
      "name": "杨延嗣",
      "hangdang": "净"
    },
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "韩延寿",
      "hangdang": "净"
    },
    {
      "name": "苏武",
      "hangdang": "老生"
    }
  ],
  "plot": "杨继业被困两狼山，命杨七郎突围搬兵。潘洪为报子仇，用酒将杨七郎灌醉，乱箭射死。杨七郎鬼魂与杨继\n业托兆。杨继业复命杨六郎回朝求救。援兵不至，人马冻饿，杨继业碰死李陵碑前。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四鬼卒引杨延嗣同上。"
        },
        {
          "character": "杨延嗣",
          "type": "念",
          "text": "在生前拳打潘豹，赴阴曹恶气难消！"
        },
        {
          "character": "杨延嗣",
          "type": "白",
          "text": "我乃七郎延嗣鬼魂是也。只因我父子被困两狼山，奉了爹爹之命，回到雁门搬 兵求救。不想潘洪老贼心怀旧恨，将俺诓下马来，用酒劝醉，绑在芭蕉树上， 射了俺一百单三箭，将俺射死。俺不免回到两狼山，与我父托上一兆。 众鬼卒！"
        },
        {
          "character": "四鬼卒",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "杨延嗣",
          "type": "白",
          "text": "驾起阴风，两狼山去者！"
        },
        {
          "character": "四鬼卒",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "杨延嗣",
          "type": "唱",
          "text": "我杨家保宋君忠心秉正， 可叹我老爹尊困大营、里无粮草、外无救兵、好叫人泪洒埃尘。 都只为天庆王把巧计定， 设下了双龙会惹动刀兵。 我大哥替宋王把忠来尽， 我二哥短剑下命赴幽冥； 我三哥被马踏尸无踪影， 我四哥和八弟失落番营； 我五哥他把那五台山进， 弃红尘拜师尊学道法，每日里在禅堂，时时刻刻念经文，他就成了僧人。 我六哥在三关身挂帅印， 最可叹我七郎乱箭攒身。 叫鬼卒驾阴风把两狼山进， 见了那老爹爹细说分明，我大放悲声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延嗣、四鬼卒同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "杨继业",
          "type": "內二黄导板",
          "text": "金乌坠玉兔升黄昏时候，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "二黄回龙",
          "text": "盼娇儿不由人珠泪双流。我的儿啊！"
        },
        {
          "character": "杨继业",
          "type": "二黄原板",
          "text": "七郎儿回雁门搬兵求救， 为什么此一去不见回头？ 怕只怕潘仁美前仇依旧， 怕只怕我的儿一命罢休。 含悲泪进大营双眉紧皱， 腹内肌身寒冷遍体飕飕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业睡。〖起二更鼓〗。杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "听谯楼打罢了二更时分， 杨延昭倒做了巡更之人。 迈虎步我且把宝帐来进， 又只见老爹爹瞌睡沉沉。 我这里脱衣衫急忙盖定， 困沉沉坐一旁不敢高声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭坐，睡。〖起三更鼓〗。四鬼卒引杨延嗣同上。"
        },
        {
          "character": "杨延嗣",
          "type": "唱",
          "text": "听谯楼打罢了三更时分， 半空中又来了七郎鬼魂。 叫鬼卒驾阴风宋营来进， 又只见老爹爹瞌睡沉沉。 我这里将他的梦魂惊醒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延嗣拂杨继业。"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "猛抬头又只见七郎娇生。 我命儿回雁门搬兵求救， 儿为何哭啼啼身带雕翎？ 我这里下位去将儿抱定！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业睡。"
        },
        {
          "character": "杨延嗣",
          "type": "唱",
          "text": "老爹爹休贪睡儿有话云。 都只为两狼山父子被困， 老爹爹命孩儿搬取救兵。 潘洪贼想起了打子仇恨， 将孩儿绑芭蕉乱箭攒身。 回头来我再与六兄来论， 小弟言来听分明： 高堂母还要你多多侍奉， 休得要学小弟不孝之人。 我本当与六兄多谈多论， 怕的是天明亮难回天庭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延嗣、四鬼卒同下。"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "方才朦胧刚睡定， 梦见七郎回大营。 睁开了昏花眼用目观定， 又只见六郎儿瞌睡沉沉。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "我儿醒来！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "适才间与七弟把话来论， 猛抬头又只见年迈爹尊。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哎呀爹爹呀！适才见七弟浑身是血，头带雕翎，不知是何缘故？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "唔呼呀！为父也得此梦。我想梦梦相同，必有应验。哎呀儿呀！快快回去，探 听你七弟下落！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿不去。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "为何不去？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹年迈，孩儿放心不下。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "为父虽然年迈，身体倒还健康。我儿不必忧虑，快快前去才是！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿还是不去！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀儿呀！为父倒有父子之情，难道我儿你就无有手足之义么？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹不必如此，孩儿前去就是。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这便才是。快快上马去吧！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿去也！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "倘若胡儿来骂阵， 稳坐大营莫出兵。 辞别爹爹跨鞍镫， 探得消息即回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "六郎！延昭！唉，我的儿呀！"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "见娇儿上了马能行， 手指潘洪发恨声。 我儿若有好和歹， 我把老命与尔拼。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵引韩延寿同上。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "俺，韩延寿。奉了太后之命，把守虎口交牙峪。 来呀！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "就此前往！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "韩延寿在此。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "前番饶你不死，又来送命！"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "一派胡言！放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、韩延寿同起打，过合。杨延昭败下。杨延嗣上。韩延寿退，杨延嗣下。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "且住！正要擒那六郎下马，忽然七郎显圣。 巴图鲁！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩延寿、四番兵同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "休赶哪休赶！ 且住！且喜逃出虎口。不免回朝搬兵便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四老军扛刀、抬弓引杨继业同上。"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "叹杨家秉忠心大宋扶保， 到如今只落得兵败荒郊。 恨北国萧银宗打来战表， 擅敢夺我主爷锦绣龙朝。 贼潘洪在金殿帅印挂了， 我父子倒做了马前英豪。 金沙滩双龙会一阵败了， 只杀得血成河鬼哭神嚎。 大郎儿替宋主把忠尽了， 二郎儿短剑下命赴阴曹； 杨三郎被马踏尸骨难找， 四、八郎失番邦无有下梢； 杨五郎在五台削发修道， 七郎儿被潘洪射死芭蕉。 只剩下六郎儿随营征讨， 可叹他尽得忠又尽孝、身披铠甲、南征北剿、昼夜杀砍、马不停蹄、为国勤劳。 可叹我八个子四子丧了，把四子丧了， 我的儿呀！ 一家人只落得无有下梢。 方良臣与潘洪又生计巧， 请我主到五台快乐逍遥。 又谁知中了那奸贼圈套， 四下里众番奴有如海潮。 多亏了杨延昭一马来到， 一杆枪保圣驾闯出笼牢。 有老夫领人马夜来战道， 那时我东杀西砍、左冲右撞、虎撞羊群、被困在两狼山，内无有粮、外无有草、 盼兵不到、盼子不归、眼见得我这老残生就难以还朝。 我的儿呀！"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "饿呀！"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "饥饿了就该把战马砍倒！"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "冷啊！"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "身寒冷就该把帐棚焚烧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "空中雁鸣。"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "雁来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业打雁，弓折弦断。"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "宝雕弓打不着空中飞鸟， 弓又折弦又断为的哪条？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！战马被石虎咬倒。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "恨石虎把我的战马咬倒， 为大将无良骑怎把兵交？ 看过了青铜刀前把路找， 找一个避风所再作计较。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、四老军同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苏武上。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "吾乃汉世苏武是也。今当令公归位之期，不免在此点化于他。待我点化一座庙 宇，一座碑牌，再变一只老羊。远远望见令公来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "当年路过五台山， 智空长老对我言。 他道我在两狼山前遭围困， 到如今果应了智空言。"
        },
        {
          "character": "老丈",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "请问老丈，此地是什么所在？"
        },
        {
          "character": "苏武",
          "type": "念",
          "text": "此地是我庄，庄前是两狼。虎口交牙峪，犯者一命亡！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "老丈在此做些什么？"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "在此牧羊。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这样兵荒马乱，你还牧的什么羊啊？"
        },
        {
          "character": "苏武",
          "type": "念",
          "text": "兵荒不兵荒，与我却无妨。老汉无别干，在此牧老羊。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这老羊有什么贵处呢？"
        },
        {
          "character": "苏武",
          "type": "念",
          "text": "慢道老羊无贵样，提起老羊甚惨伤。生下几个羊羔子，轰轰烈烈在世上。 今日几个死，明日几个亡。老汉掐指算，今日死老羊。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "老羊！老羊！还不与我死！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "老丈说话理不通， 句句说的杨令公。 手执宝刀将你砍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏武接刀下。"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "狂风一阵影无踪。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "且住！一阵狂风，老丈不见，又将我的宝刀收去。有道是：为大将者，能舍千 军，不舍寸铁。待我找上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业走小圆场。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "来此已是苏武庙，待我进去看来。那旁有一碑碣，待我看来。“李陵碑”，呀 呀呸！想这李陵乃是背主求荣之人，是何人与他立这碑碣在此？上面还有几行 小字，待我看来。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "“庙是苏武庙，碑是李陵碑。令公来到此，卸甲又丢盔。”"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "且住！这诗句分明是指点于我。想我被困在两狼山——"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "白日受饥饿，夜晚受风吹。盼兵兵不到，盼子子不归。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "我何必等到冻饿而死，也罢！不免拜谢宋王爵禄之恩，就碰死在这李陵碑下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业碰壁，死。四番兵、韩延寿同上。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "呜呼呀！原来是老令公碰死李陵碑下。 巴图鲁，将他尸体搭了下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵搭杨继业同下。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "待我报与太后知道便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩延寿下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}