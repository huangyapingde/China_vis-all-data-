{
  "script_id": "03048006",
  "title": "定计化缘",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "段一仁",
      "hangdang": "丑"
    },
    {
      "name": "张年有",
      "hangdang": "丑"
    }
  ],
  "plot": "傅罗卜为母还愿，沿途施舍。骗子张年有与友段一仁设谋定计，骗走银两。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "张年有",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有上。"
        },
        {
          "character": "张年有",
          "type": "数板",
          "text": "平生手段与天齐，拐骗人间总不知。善者我便欺，恶者我便离。任他聪明多伶 俐，难逃我的圈套里、圈套里。"
        },
        {
          "character": "张年有",
          "type": "念",
          "text": "不种桑麻不养蚕，全凭拐骗过流年。任他修成神仙体，入我套儿该我的钱。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "在下、张年有。自幼拐骗为生。今有傅罗卜大官人，为母还愿，广带金银，沿 路施舍。一路之上，修桥盖庙。我想骗他几个钱，怎奈我单丝不能成线，孤木 不能成林。忽然想起来一个兄弟，名叫段一仁，他是做假银子的，我们俩人是 旧伙伴儿。待我找他去，同做这号买卖，回来就是无穷富贵。嘿，就是这个主 意。待我带上门儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有走圆场。"
        },
        {
          "character": "张年有",
          "type": "念",
          "text": "行行去去，去去行行。拐弯抹角，抹角拐弯。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "到啦。兄弟在家吗？兄弟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有高叫。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟！"
        },
        {
          "character": "段一仁",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁上。"
        },
        {
          "character": "段一仁",
          "type": "念",
          "text": "昨宵饮酒醉如泥，日出三竿还未起。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哟！"
        },
        {
          "character": "段一仁",
          "type": "念",
          "text": "忽听叫兄弟，急忙披上衣。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "不知何人来到此地？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哥哥！"
        },
        {
          "character": "张年有、段一仁",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哥哥！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟，走走走！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哪儿去？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "上小茶馆，有两句话跟你说。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哥哥您怎么啦！既然来到兄弟我的家里啦，有什么话家里说，上哪门子茶馆呀？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "啊，上您家里去？就您那两间茅房，我一进去，叫弟妹没处藏、没处躲的。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哟！您当像以前哪？住的那两间茅房！如今晚兄弟我发财啦，我盖了高楼大瓦 房啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "啊哟，留神鼻子。说话怎么带架子呀？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "武戏嘛，不带架子！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "哟，这会儿你发了财啦，盖了高楼大瓦房啦？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "好，立刻还绷子啊。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "咱们到哪儿去？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "您上我待客厅。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "您都有待客厅啦？瞻仰瞻仰您这个待客厅。走哇！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "别忙！我有这心，还没砸地脚哪。您上我的外书房得啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "外书房。走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁、张年有同走圆场。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "到啦。开房门。唏啦哗啦本儿，进去吧！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这就是您的外书房啊？我一进来，直仿佛——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "仿佛什么呀，左不过是这个戏台。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "好！说话尽刨根儿。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "坐下。哥哥您好哇！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "好什么？拳头打盹儿。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "手困。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "巧咧！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟你好哇？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "好什么呀？磨扇儿压着手啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "倒不过扁儿来啦。您是咭里咕噜不来。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "哎！什么呀？“几工儿不来”。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "滋毛儿来了？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "滋毛儿你又不给我肉吃。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "您干什么来啦？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟你知道傅罗卜哇？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "大萝卜？不糠不辣。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "哎！他是个人。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "人便怎么样？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "为母还愿，广带金银，沿路施舍。一路之上，修桥盖庙。我想骗他几个钱，怎 奈我单丝不能成线，孤木不能成林。忽然想起兄弟你来啦。咱们俩人是旧日的 伙伴儿，你帮哥哥我做这号买卖，回来是无穷的富贵呀！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "您说这话，我明白啦。今有傅罗卜大官人，为母还愿，广带金银，沿路施舍。 一路之上，修桥盖庙。您打算骗他俩钱儿，怎奈您单丝不能成线，孤木不能成 林。忽然想起兄弟我来啦，叫我帮您做这号买卖。您怎么不找别人，想必是咱 们哥俩有交情。无奈一样，我洗手多年，不干这个啦。请您另请高明吧！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟，别人来啦，你说不干这个啦：今天哥哥我来啦，好歹你得帮哥哥我这一 趟！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "人家不干这个，你怎么死乞白赖的哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "死乞白赖的，显见得——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "显见得，卖多钱一斤哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你发了财啦？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "你亏心不亏心？咱们俩人一样的打扮，我怎会发财哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你还认得我这苦哈哈吗？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "谁又是甜丝丝哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你不去，我一个人儿去。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "对啦，您一个人儿发财去吧！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "我把银子骗到手里，我吃、我喝、我玩、我乐，不犯事便罢；要是犯了事，我 就拉兄弟你一把。有道是：贼咬一口，入骨三分。把你带到公堂，打板子，拶 拶子，上脑箍——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "箍哇！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "箍哇！箍出油来炸豆腐！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哥哥，油豆腐可不好吃啊！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你不去，我可去啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁背供。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "他们这号人，说的出来，就行的出来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁向张年有。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "嗐，哥哥你回来！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "讲的一送儿，不管来回儿。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "谁跟你耍皮壳儿？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "皮壳儿？还千层板儿哪！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "您回来，咱们商量商量。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "怎么商量？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "我帮您啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你帮我啦？嘿嘿嘿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有跺脚。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "好兄弟！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "帮他啦，他还跺我三脚。 里头说，里头说！哥哥咱们怎么个取法？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "他是个善人，咱们必须由善中所取。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "善中怎么取呀？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "咱们俩人扮做一僧一道，骗他点儿。把你的假银子带上，再换他点儿。回来咱 们俩人就是无穷的富贵啦。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "咱们哪儿见面哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "坡儿底下小茶馆。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "不见不散！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "死约会儿。正是："
        },
        {
          "character": "张年有",
          "type": "念",
          "text": "二人定计起歹心，"
        },
        {
          "character": "段一仁",
          "type": "念",
          "text": "世上宜假不宜真。"
        },
        {
          "character": "张年有",
          "type": "念",
          "text": "不必再三多嘱咐，"
        },
        {
          "character": "段一仁",
          "type": "念",
          "text": "你我俱是一路人。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "哎，“一会人”。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "对啦，“一会人”。哥哥，咱们哪儿见来着？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "坡儿底下小茶馆。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "不见不散！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "死约会儿。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哥哥来了半天啦，连碗茶都没喝。我后头有的是绿豆水饭，您来他两碗怎么样？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "绿豆水饭哪，巧咧，我不吃绿豆。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哟，您不吃绿豆哇？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "张年有、段一仁",
          "type": "同白",
          "text": "哈哈，想必是鹌鹑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有、段一仁自两边分下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "傅罗卜",
          "type": "内白",
          "text": "伊立带路！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伊立引傅罗卜同上。"
        },
        {
          "character": "傅罗卜",
          "type": "吹腔",
          "text": "只因老母身染病， 许下心愿舍黄金。"
        },
        {
          "character": "傅罗卜",
          "type": "白",
          "text": "小生、傅罗卜。为母许下心愿，修造长桥一座。广带金银，沿路施舍。 伊立带路！"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "喳！"
        },
        {
          "character": "傅罗卜",
          "type": "吹腔",
          "text": "但愿老母病痊愈， 满斗焚香谢神灵。"
        },
        {
          "character": "傅罗卜",
          "type": "白",
          "text": "天气炎热。伊立，你我在此歇息歇息再走。"
        },
        {
          "character": "伊立",
          "type": "白",
          "text": "是啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有上。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "我说兄弟，跟着我来，别发毛咕，我怎么着，你怎么着。唉，兄弟哪？兄弟！"
        },
        {
          "character": "段一仁",
          "type": "内白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁上。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你快来呀。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "别忙，我还没扮好哪。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你快来吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁耍像。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "嗐！我说兄弟，你干么这么贼眉鼠眼的？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "贼眉鼠眼的？遇见熟人，能满街上装老道吗？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "碰见熟人，就给他个一抹脸儿：六亲不认。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "六亲不认？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "为我，为饭。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "噢！这儿有饭？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "别发毛咕，我怎么样，你怎么样。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "错不了。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "南无阿弥陀佛！化缘的来喽！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "南无阿弥陀佛！化缘的来喽！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "南无阿弥陀佛！化缘的来喽！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "南无阿弥陀佛！化缘的来喽！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "我说兄弟，帮哥哥帮到了儿，搅我可合不着！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "我没错儿啊。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "还没错儿哪？这都使不得，给我端回去。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "端不回去啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "搁上醋啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "又搁上醋啦！你瞧我是谁？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "拐子手哇！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你别嚷啊！你看我头上戴的什么，身上穿的是什么，这会儿我像个什么人，我 的爹！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "唉。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "玩笑哇！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "你蒙事。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "我也不算蒙爹。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "啊，我也不像啊。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "又不像啦！这阵儿我是什么人？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "和尚。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这不结啦！你哪？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "做假银子的。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "别嚷！这会你头上戴的是什么，身上穿的是什么？我的——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "唉！我罚你，你空我一膆儿。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这会儿你像什么人？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "老道。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这不结啦！僧有僧腔，道有道韵。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "够我倒运的啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这南无阿弥陀佛是我的，你听着，这就来啦：南无阿弥陀佛！南无阿弥陀佛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有叨念。段一仁背供。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "难得他有味儿没字儿。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "又有味儿没字啦！这是我的。你有你的！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哪是我的？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你有你的词儿。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哪是我的词儿？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "哎呀，敢情你不会呀！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哎呀，谁又说会哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这事由可就多啦。像你们这老道，弄两根折铁钉，弄点儿荞麦面，往手上一糊， 噗！一口松木水。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "这干什么？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这叫“哄不尽的愚人”。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "噢！人家都是愚人？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "啊，要手打法器，脚踢佛爷。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "脚底下踢佛爷，好行为！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你瞧着，这就来啦——"
        },
        {
          "character": "张年有",
          "type": "念",
          "text": "不化你们的东啊，不化你们的西呀，单化你们善人施舍盖庙宇啊。 古庙无僧难修补哇，佛前无烟少光辉。白马银枪往东征，不觉得善人要相逢。 施舍不拘多和少，无量功德万事成。 啊啊啊哈无哇，啊哈无哇，啊哈无量佛呀。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这又算得了什么？哎，这么热闹，他睡着啦！ 醍醒，醒醒！吃面啦！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "好咸滷。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "我说你扣着食哪？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "什么扣着食，你倒是念哪！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "完啦。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "多少句？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "八百多句。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "啊，这八百多句，都是我们怯老道的？我不来吧，你死乞白赖——"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "你凑合点儿吧！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "来了吧，搅您又合不着。这八百多句，都是我们怯老道的，这这这，啊啊哈无 哇！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "还行。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "啊啊哈无哇！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "有点边儿。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "啊啊哈无，你叫我诬谁？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁跑。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟，你回来，回来！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "我不成。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "干脆！咱们不要啦。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "谢谢您！您一个人儿发财去吧。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "回来回来。道词不要啦，老道还要。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "噢，老道还要？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "干脆简练：无量寿佛。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "无量秤砣？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "无量寿佛。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "无量不得？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "无量寿佛。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "不成，我记不住。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "干脆写上。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "写哪儿？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "写手上。一边走，一边写。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有与段一仁手上写字。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "头一个字是什么？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "是“无”。“无”字是“门”字头——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "屋里头有门。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "三点水，一血堆，一个走之。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "这念什么？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "“无”。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "又该什么啦？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "“量”啦，“量”字是“日”字头——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "日头一出来就亮啦。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "三点水，一血堆，一个走之。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "这念什么？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "“量”。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "又该什么啦？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "该“寿”啦。“寿”字是“肉”字头——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "瘦肉好吃。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "三点水，一血堆，一个走之。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "这念什么？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这念“寿”。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "又该什么啦？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "“佛”啦。“佛”字是耳朵旁——"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "对啦，佛爷有耳朵嘛。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "三点水，一血堆。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "呃！写呀！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "完啦。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "呃！那三个有“走之”，这怎么没“走之”？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这个字原来就没走之。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "那不成啊！那仨字有走之。这个没走之，等人家挑眼哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "他是没走之啊。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "不行。你给添上吧，我不认识。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "好，别嚷，我给你添上。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "这是哪国字啊？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "别乱啦，到啦。你瞧，那边儿坐着的就是傅罗卜。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "旁边那个哪？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "伊立。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "戈什哈儿。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "院子。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "过道。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "嗐！他们家的底下人。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "咱们俩谁过去？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "我过去，你在这儿立着。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "可别闹出原故来！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "没原故。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "我就怕原故。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "没有哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张年有向傅罗卜。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "啊施主，小僧稽首！"
        },
        {
          "character": "傅罗卜",
          "type": "白",
          "text": "你们是哪里来的？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "远方来的。修座长桥，工程浩大，请施主布施布施！"
        },
        {
          "character": "傅罗卜",
          "type": "白",
          "text": "看缘簿过来。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "是。 老道，看缘簿过来。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "我说什么？闹出原故来了不是？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "段一仁欲下。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "兄弟你回来！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "我怕原故。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "不是原故。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "是什么呀？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "是“缘簿”。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "什么叫“缘簿”？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "就是我在小茶馆交你的那个折子，上头还有红纸条儿。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "哎呀！你瞧，这你还阴我哪？ 啊施主，缘簿在此。"
        },
        {
          "character": "傅罗卜",
          "type": "白",
          "text": "纹银十两。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "多谢施主！啊施主，小僧在前面化来元宝一个，工程上难以使用，求施主换些 散碎银两。"
        },
        {
          "character": "傅罗卜",
          "type": "白",
          "text": "看整宝过来。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "是。 老道，拿我的银子来。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "你穷疯啦？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "谁穷疯啦？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "你讹我呀？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "谁讹你呀？"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "你哪有银子？"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "就是你那个。"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "假的！"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "别嚷！"
        },
        {
          "character": "段一仁",
          "type": "白",
          "text": "给你。告诉他六十天还原儿。"
        },
        {
          "character": "张年有",
          "type": "白",
          "text": "这你也说出来！ 元宝在此。"
        },
        {
