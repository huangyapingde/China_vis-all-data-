          "character": "旗牌",
          "type": "白",
          "text": "来此已是。 门上有人么？"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "曹营下书人求见。"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "候着。 启爷：曹营下书人求见。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "啊！方才请我阵前一叙，何故又有人前来下书？其中必有缘故。 吩咐书信进，人落后。"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "来人呢？韩将军有令：书信进，人落后。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文堂甲接书。四龙套、四上手、庞德、马岱、马超同上。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "呔！作什么的？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "曹营下书的。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "呕！"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "马将军回来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。韩遂迎马超进。"
        },
        {
          "character": "韩遂、马超",
          "type": "同白",
          "text": "请坐！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "贤侄今日出战，胜负如何？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "侄男出战，杀得曹兵，望风而逃。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "贤侄真乃能战也！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "啊，叔父，闻听曹操请叔父阵前搭话，不知所言何事？"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "只说同朝旧日之好。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "可言军务之事？"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "曹操不言，我何言之？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "适才曹操差人前来下书，叔父为何瞒我？"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "不错，有书信前来，我拆开还未曾过目。贤侄请看。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超接书看。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "啊！这书信上面，为何改抹涂糊呢？"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "待我看来。 呕，是了，想是曹操将草稿封错来了。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "想那曹操乃精细之人，焉有错封草稿之理？啊呵，是了，想是叔父有害俺马超 之意，怕俺马超知晓，因此将书信改抹涂糊，是也不是？"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "哎呀，贤侄啊！他原书至此我还未看，何言改之？哎，岂有此理！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "俺马超只为杀父之仇，统领西凉之众，并力同心，誓杀国贼，奈何忽生异心？"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "哎呀，贤侄啊！你疑心太甚，我也难辩了。也罢！你我去到阵前，赚曹操出营 搭话，你从阵内突出，一枪将曹操刺死，以表我心。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "唔，若得如此，方见叔父真心。"
        },
        {
          "character": "韩遂、马超",
          "type": "同白",
          "text": "众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手同应。"
        },
        {
          "character": "韩遂、马超",
          "type": "同白",
          "text": "往阵前去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、四文堂、庞德、马岱、马超、韩遂、杨秋同走圆场。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "请曹丞相阵前搭话！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "请曹丞相阵前搭话！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引曹洪自下场门同上。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "啊，韩将军请了。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "我家丞相拜上将军，务必照书行事，事成之后，以西凉侯赐之。请了请了！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "呸，呸，呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪下。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "闻言心头火难按， 怒气填胸发冲冠。 金枪一抖除后患！"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "贤侄休得自相残！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "贤侄呀，我并无此心，休要多疑！"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "韩将军并无此心，请自三思。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "是呀，恐是反间之计，兄长不可妄信。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "唗！他与曹操同谋，里应外合，说什么反间之计！也罢，俺且回营，我看你怎 生擒我！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "勒马临崖收缰晚， 江心补漏后悔难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、庞德、马岱、马超同下。"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "马超无谋一莽汉， 教人心中胆战寒。 坐在雕安空自叹， 回想马腾泪涟涟。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "两厢退下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同下。"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "啊，主公。马超倚仗英勇，并无仁德之心，我等便灭了曹操，他也不能感报主 公。依末将愚见，不如暗投曹……"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "啊，曹什么？"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "不如暗投曹操，不失封侯之位。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "住了！我与他父，结为兄弟，安忍背之！"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "啊，今日阵前一枪若是刺死主公，也是结为兄弟，安忍背之么？这是他不仁， 我们就不义了！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "是啊，方才若不是众将解劝，险遭毒手。唉！马腾兄啊，马寿成！这是你子不 仁，休怪为弟不义了！话虽如此，谁往曹营一走？"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "末将愿往。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "待我修书。"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "多多拜上曹丞相， 恕我助他反西凉。 望乞收录为偏将， 愿效犬马执鞭缰。 将军此去休慌张， 即速回营作商量。"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "杨秋",
          "type": "唱",
          "text": "遵行机密出宝帐， 弃暗投明灭强梁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨秋下。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "哎，我好悔也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "悔不该与马超同为一党， 悔不该统雄师离却了西凉。 数年来才得了太平安享， 奉圣命和马腾共镇西羌。 在许田射鹿时曹操犯上， 马寿成与刘备私下商量。 又谁知泄机密董承命丧， 因此上众诸侯各霸一方。 曹孟德使巧计心如王莽， 假命诏赚马腾去到洛阳。 可怜他是一个忠臣良将， 可怜他父子们同受冤枉。 马孟起自持勇全不思想， 今日里使长枪要把我伤。 我本当将此事对他细讲， 怎奈他是一个莽撞儿郎。 闷恹恹好叫我心中惆怅， 行不安坐不宁待等天光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。马超上。"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "军营二更月初上， 辗转心焦意彷徨。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "嗐！可恨韩遂，暗结曹操，苟图富贵。俺一时愤怒，提枪就刺，竟被众将解劝， 道他无有此心，为此俺悄悄到他营中探其动静。他果真心降曹，俺今晚便结 果他的性命也！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "悄步轻行且进帐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖铃响〗。"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "马走铃声响叮当。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "哎呀且住！那旁来了一人，想必是韩遂耳目，俺且躲在一旁，看是何人也。"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "他果真心把曹降， 难逃在俺剑下亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超下。杨秋上。"
        },
        {
          "character": "杨秋",
          "type": "唱",
          "text": "好个仁义曹丞相， 官封侯爵镇西羌。"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "啊，主公。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "将军回来了。曹操讲些什么？"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "曹丞相见了书信，心中大悦，若能擒得马超，封主公西凉侯之位。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超暗上。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "奈马超勇猛难擒，需要设计擒之，献与曹丞相方好。"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "丞相大兵随后就到，约定放火为号，里应外合，哪怕马超飞上天去！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "此计甚好。众将可知？"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "也曾晓谕过了。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "好，速速行之！"
        },
        {
          "character": "杨秋",
          "type": "白",
          "text": "众将官，放起火来！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "哎呀！ （众将同乱下。马超急，砍韩遂膀。杨秋扯马超臂，同下。四龙套、四上手、庞德、马岱、马超同上。四文 堂自两边分抄过放火下。）"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "营中为何自乱？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "可恨韩遂暗结曹操，被俺看破，砍断他的左膀，他们降曹去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火。"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "看，营中火起，你我杀出重围！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四文堂、四大铠、四藤牌、四火牌、徐晃、于禁、夏侯渊、许褚、曹洪、夏侯惇、曹仁、朱灵、曹操同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "韩遂、杨秋同上，同跪。）"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你为老夫吃了苦了。众将奋勇当先！ （曹操扯韩遂、杨秋同下。四龙套、四上手、庞德、马岱、马超同上，徐晃、于禁、夏侯渊、许褚、曹洪、 夏侯惇、曹仁、朱灵同大战，杀马超败，同追下。许褚追杀，马超打许褚下。庞德、马岱同上，同架住。）"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "（公子）（大哥）醒来！（庞德）（马岱）在此。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "看看还有多少人马？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "三百馀骑。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "天哪，天！俺马超，只为父仇，统领三十六万之众，如今一战，只剩三百馀骑！ 怎不气……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超气。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "兄长不必如此，你我投奔东川张鲁那里借兵，再来与叔父报仇。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "走！ （马超领四龙套、四上手、庞德、马岱同下。四文堂、四大铠、四藤牌、四火牌、徐晃、于禁、夏侯渊、许 褚、曹洪、夏侯惇、曹仁、朱灵同上。）"
        },
        {
          "character": "四文堂、四大铠、四藤牌、四火牌",
          "type": "同白",
          "text": "马超败走。"
        },
        {
          "character": "徐晃、于禁、夏侯渊、许褚、曹洪、夏侯惇、曹仁、朱灵",
          "type": "同白",
          "text": "回营交令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
