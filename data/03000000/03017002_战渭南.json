{
  "script_id": "03017002",
  "title": "战渭南",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "马超",
      "hangdang": "武生"
    },
    {
      "name": "韩遂",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "曹操被马超战败后，整顿人马复过河对敌。因韩遂之谋，马超之勇，难于取胜。曹操用贾诩计：致书韩遂，\n故将重要之处涂抹；临阵时，曹操复与韩遂寒暄。马超果疑韩遂，韩遂为剖示无二，约曹操临阵答话，使马\n超伏马后伺机刺曹操，讵知曹操先料及，命部将代言，嘱韩遂照书行事。马超益疑，欲杀韩遂，众将劝阻乃\n免。韩遂部将杨秋怨马超威猛寡恩，劝韩遂降曹操。韩遂与曹操暗通款曲。曹操亦约韩遂为内应。事泄，马\n超怒斩韩遂一臂，众将救韩遂出投曹营。韩军既叛，曹军乘势击西凉兵。马超无奈乃退归陇西。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵同上。"
        },
        {
          "character": "徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同念",
          "text": "戈戟森严拥虎帐，旌旗招展遮日光。"
        },
        {
          "character": "徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "徐晃。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "曹仁。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "夏侯惇。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "于禁。"
        },
        {
          "character": "朱灵",
          "type": "白",
          "text": "朱灵。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "奉丞相之命，谨守大营，丞相亲自领兵与马超交战，未知胜负如何。也曾命人 打探，未见回报。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "丞相回营。"
        },
        {
          "character": "徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！（下）"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "丞相回营，你我出帐迎接。 （四文堂、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵同下。曹洪、许褚、曹操同上，过场，同下。四文堂、 徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵自下场门同上。曹操、许褚自上场门同上。徐晃、曹仁、夏侯 渊、夏侯惇、于禁、朱灵同迎曹操进，同下。曹操、曹洪、许褚、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱 灵同上，同挖门。）"
        },
        {
          "character": "徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "丞相醒来！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "连破关隘失了计， 马超英勇果称奇。"
        },
        {
          "character": "徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "丞相因何这等模样？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫自破黄巾以来，扫灭群雄，身经百战，未料马超英勇非常。昨日一战，杀 得老夫割须弃袍；若非曹洪相救，险丧马超之手！"
        },
        {
          "character": "徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "丞相受此惊恐，我等之罪也！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "起来。军家胜负，古之常理。"
        },
        {
          "character": "徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "谢丞相！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "马超讨战。"
        },
        {
          "character": "曹洪、许褚、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀，马超啊，马超！你若不死，老夫不得安也！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "才离龙潭虎穴地， 又闻马超把兵提。 西羌人马如潮水， 杀得我兵将血染衣。"
        },
        {
          "character": "曹洪、许褚、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "丞相不必惊慌，某等奋力迎战。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你等稍安勿躁，老夫自有主张。 许褚听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚应。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命尔速办船只，将人马渡过北岸，不得有误！"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚带四下手同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵同应。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "人马一齐渡过北岸去者！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "三声号炮把营起， 齐奔北岸莫延迟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "马岱",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、马岱同上。"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "俺、（庞德）（马岱）。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "请了。闻得曹操渡过北岸，不免回去报与公子知道便了。请！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、马岱同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、许褚同上。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "俺、许褚。奉了丞相之命，准备船只，将人马渡过北岸。 来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同应。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "北岸去者！ （四下手、许褚同下。〖急急风〗。四龙套、四上手、庞德、马岱引马超同上，同站门，同领起来，同下。 曹操、曹洪、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵同上。）"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "万马营前军对垒， 晨时战到日坠西。 马超英勇无人敌， 好似大鹏展翅飞。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启丞相：马超人马，追赶甚紧！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹洪、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵",
          "type": "同白",
          "text": "马超追兵来到，请丞相急速登舟。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "贼兵追来，我何惧哉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "马超追兵，离此一里之遥！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀，速速登舟！ （二船夫同上。曹洪、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵同上马，同走圆场，许褚带四下手自下场 马超同上。）"
        },
        {
          "character": "门同上，曹操、曹洪、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵同上船。四龙套、四上手、庞德、马岱、马超",
          "type": "白",
          "text": "放箭！ （许褚挡箭，曹操、曹洪、许褚、徐晃、曹仁、夏侯渊、夏侯惇、于禁、朱灵、四下手、二船夫同下。报子 上。）"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "曹操渡过北岸。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "正要擒那老贼，忽见一将把老贼救上船去。暂且回营与韩叔父商议破曹之策。 庞德、马岱听令！"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "命你二人，各带兵三千，将山中树木伐倒，造成排筏，候大兵一到，渡过北岸， 不得有误！"
        },
        {
          "character": "庞德、马岱",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、庞德、马岱、马超同倒领下，四文堂引韩遂同上。"
        },
        {
          "character": "韩遂",
          "type": "唱",
          "text": "一战惊破曹操胆， 威风凛凛下城关。 只杀得曹兵纷纷散， 马超追贼未回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、庞德、马岱、马超同上。韩遂迎进。马超、韩遂同坐。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "胜负如何？"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "贼兵渡河，只离一箭之地，未将曹贼擒住。忽有一将，将曹贼救上船去，不知 此将何人也？"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "我闻曹操选精壮之将为帐前护卫军，乃大将典韦、许褚领之。那典韦已死，今 救曹操者，必许褚也。此人英勇过人，人皆称为虎痴将军。若遇此将，休得大 意，千万不可轻敌！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "叔父你好小量人也！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "叔父休把许褚赞， 不怕他是虎斑斓。 好歹明日会一战， 杀他个丢盔卸甲还！"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "贤侄有此英勇，谅那许褚也不是你的对手。今曹兵渡过北岸，我兵宜急速攻之。 待他树立营寨，既难剿除。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "也曾命庞德、马岱伐树造筏，请叔父大兵一齐渡过北岸，曹操可擒也。"
        },
        {
          "character": "韩遂",
          "type": "白",
          "text": "言之有理。 大小三军：拔营起寨，直抵渭南！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手同应。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（徐晃、于禁自两边分上，同起霸。夏侯渊、许褚自两边分上，同起霸。曹洪、夏侯惇自两边分上，同起霸。"
        },
        {
          "character": null,
          "type": "text",
          "text": "曹仁、朱灵自两边分上，同起霸。〖点绛唇〗。）"
        },
        {
          "character": "徐晃、于禁",
          "type": "同念",
          "text": "威风凛凛胆气高，"
        },
        {
          "character": "夏侯渊、许褚",
          "type": "同念",
          "text": "煞气腾腾披战袍。"
        },
        {
          "character": "曹洪、夏侯惇",
          "type": "同念",
          "text": "食王爵禄当报效，"
        },
        {
          "character": "曹仁、朱灵",
          "type": "同念",
          "text": "凌烟阁上美名标。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "俺、徐晃。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "于禁。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "许褚。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "曹洪。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "夏侯惇。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "曹仁。"
        },
        {
          "character": "朱灵",
          "type": "白",
          "text": "朱灵。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "于禁、夏侯渊、许褚、曹洪、夏侯惇、曹仁、朱灵",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "丞相升帐，你我两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四火牌、四藤牌引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "塞风阵阵冲霄汉，将士纷纷筑城关。假命诏马腾灭翦，灭孺子顷刻之间。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "数十年来统貔貅，南征北剿动戈矛。天意若能遂人愿，朔风吹冻立营头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫、曹操。可恨马超小儿，统领雄兵，连日讨战，使老夫营寨难立。昨夜北 风大作，命军士担土泼水，一夜而成大寨。此乃天助我也！ 众将！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、于禁、夏侯渊、许褚、曹洪、夏侯惇、曹仁、朱灵同应。"
        },
        {
          "character": "曹操",
          "type": "白",
