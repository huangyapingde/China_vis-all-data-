{
  "script_id": "03009004",
  "title": "取帅印",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    },
    {
      "name": "秦怀玉",
      "hangdang": "小生"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    }
  ],
  "plot": "唐初，辽东盖苏文犯边。唐主李世民因元帅秦琼正患重病，欲派尉迟恭为帅。程咬金素与尉迟恭不睦，假称\n秦琼不肯交出帅印，希图阻止。嗣李世民亲至秦府取印，程咬金唆使秦琼刁难。李世民许以公主下嫁秦子秦\n怀玉，程咬金又挑唆秦怀玉与尉迟恭寻殴，反诬尉迟恭欺辱驸马，迫使赔罪。最后，秦琼始将帅印付出，尉\n迟恭乃得率部东征。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、尉迟恭、程咬金同上。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "朝鼓咚咚月坠西，"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "文臣武将整朝衣。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "忽听金钟三下响，"
        },
        {
          "character": "徐勣、尉迟恭、程咬金",
          "type": "同念",
          "text": "个个低头拜丹墀。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "山人徐勣。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "鄂国公敬德。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "鲁国公程咬金。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "列公请了！"
        },
        {
          "character": "尉迟恭、程咬金",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "今有张士贵，在绛州龙门，招军已满，有本回朝。少时万岁登殿，一同启奏。"
        },
        {
          "character": "徐勣、尉迟恭、程咬金",
          "type": "同白",
          "text": "看香烟缭绕，圣驾临朝。分班伺候。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，同站门。李世民上。"
        },
        {
          "character": "李世民",
          "type": "引子",
          "text": "海宴河淸，且喜得，四海升平。"
        },
        {
          "character": "徐勣、威迟恭、程咬金",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "徐勣、尉迟恭、程咬金",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "父王宴驾命归天，孤王接位掌江山。征扫北国回朝转，不想辽东起狼烟。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤、李世民。国号贞观在位。父王宴驾，众卿保孤登基。可恨辽东盖苏文，打 来连环战表，教寡人御驾亲征。是寡人命张士贵，在绛州龙门，招军集将，王 君可监造战船。二人出京，数月有余，并无本章回朝，寡人日夜忧虑。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "臣启万岁：今有张士贵有本还朝，请我主龙目御览！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "呈上来！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "日出辽东万道霞， 群臣歌颂帝王家。 张环有本奏陛下， 请主龙目细详查： 奉王旨意招人马， 英雄投効到王家。 并无仁贵投帐下， 十万人马候旨发。 看罢本章孤自叹， 再与先生把话答。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生，张士贵绛州龙门招军，为查访应梦贤臣。这本章上面，并无“仁贵”二 字，张环莫非有欺君之意？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "张环焉敢欺君。万岁此番征东，若无贤臣保驾，臣之罪也。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "秦恩公染病在床，先生保奏何人？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "臣保尉迟恭挂帅，征伐辽东，一战成功。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "万岁，休听军师之言，尉迟恭挂不得帅印。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "程将军，军师保我挂帅，你为何拦阻？想我开国元勋不挂，谁人敢挂？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "动不动你就是开国元勋，难道我老程就不是开国元勋？军师保你，他怎不保我？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你不能。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我不能，你也不能。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "且慢！二卿不必争论，帅印现在秦府，就命程皇兄前去取印回来，再作定夺。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "转来！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣在。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "他乃有病之人，必须见机而行。听孤旨下！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "恩公投唐功劳大， 东挡西征定邦家。 虽然卧病在床榻， 雄心依然保唐家。 卿家要说温柔话， 随机应变把印拿。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "万岁叮咛一些话， 为臣一一转秦家。 辞王别驾把殿下， 背转身来自咂牙。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎呀且住。我想这颗帅印，乃是秦二哥执掌多年；我若取回，岂不白白送与黑 贼之手？呕呕，有了！我不免午门闲游一番，急回谎奏，就说二哥染病在床， 昏迷不醒，不肯交印。也免得那黑贼痴心妄想也！"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "背转身来高声骂， 骂声黑贼欺压咱。 急回谎奏君王驾， 痴心妄想不归他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。黄门官上。"
        },
        {
          "character": "黄门官",
          "type": "唱",
          "text": "春城无处不飞花， 随王并无半日暇。"
        },
        {
          "character": "黄门官",
          "type": "白",
          "text": "臣黄门官见驾，吾皇万岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "黄门官",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "黄门官",
          "type": "白",
          "text": "今有王君可，有本回朝。我主龙目御览！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "呈上来，待孤观看！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "奉王旨意到海下， 王君可修本奏皇家。 请主旨意发人马， 扫平辽东定中华。 看罢本章搁心下， 黄门官进前听根芽： 吩咐众将免见驾， 三日之内候旨发。"
        },
        {
          "character": "黄门官",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "黄门官",
          "type": "唱",
          "text": "辞王别驾把殿下， 晓谕文武百官家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄门官下。程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "胸藏妙计说假话， 急忙上殿骗皇家。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣交旨。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "秦恩公病体如何？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "照常一样，呕吐不止。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "恩公啊！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "恩公病势不转佳， 不由孤王泪如麻。 东挡西征功劳大， 病体缠身难挣扎。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "他乃久病之人，万岁何必忧虑。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "他乃有功之臣，倘有不测，孤心不忍。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "万岁真乃有道明君。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "取印之事如何？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "万岁休提取印之事。为臣走进了病房之间，言道二哥病体如何，他说照常一样， 呕吐不止。是臣言道，万岁因你染病在床，万岁龙心悬挂，命我前来探望于 你。他说真乃有道明君。他又问起为臣征东一事如何，臣言万岁今日设立早朝， 张士贵有本回朝，招军已满。万岁因你染病在床，龙心未定。军师立保尉迟 恭挂帅。他听说尉迟恭挂帅，是一派的好瞒怨。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "瞒怨何来？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "他言道，想我秦琼，自投唐以来，攻无不取，战无不胜，才挣下这颗帅印。如 今染病在床，倘有不测，还有我儿怀玉呀。再一说，还有咬金兄弟，也是文武 全才，可以挂得帅印。想那尉迟恭，与我秦琼，并无半点瓜葛之情。况且目不 识丁，何能决胜千里之外？一派好瞒怨！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "一派说谎。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你又不曾听见，你怎么知道是谎言？臣见他那般光景，嗐！"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "气力不接难讲话， 病势未减只有加。 为臣一见心骇怕， 万岁龙心细详查。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "孤王闻言头低下， 心中辗转泪如麻。 辽东若不去征伐， 反说孤王惧怕他。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生，秦恩公昏迷不醍，不肯交印，如何是好？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "万岁明日过府，一来探病，二来取印。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "万岁休听军师之言，取印乃是一桩小事，不论差哪部大臣前去就成了，何劳御 驾亲往！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "程将军，君入臣门，蓬荜生辉，你为何阻驾？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "真乃多口！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎哟！你二人打了合同啦。 臣启万岁：臣好有一比。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "掌上乌鸦，开不得口啦！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "开口便怎样？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "开口就是祸。方才说了一句话，一个道臣阻驾，一个道臣多口。明日过府，必 有几句言语讲，不讲反倒得罪他们，总是不去的为妙。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "你与秦恩公昔年结拜好友，只管大胆，保孤前去。有什么祸事，寡人与你担待。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "三哥，这可是万岁叫我去的。我这可是奉旨啊！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "真乃一张油口。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我又油口啦。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "听孤旨下！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "昔日恩公走天涯， 锏打杨广救全家。 明日文武齐保驾， 孤王亲自去看他。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "黑贼金殿夸大话， 军师一旁暗保他。 就是帅印归他挂， 也教他口念活菩萨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "军师金殿抬爱咱， 咬金一旁把话答。 若得帅印归我挂， 寻一良计要摆布他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "适才咬金一席话， 蒙哄万岁弄巧牙。 辞王别驾把殿下， 明日保主到秦家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣下。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "龙楼凤阁紫雾霞， 金殿祥光绕瑞华。 惟有先生好八卦， 众家国公扶保咱。 内侍与孤摆銮驾， 探望功臣到秦家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程院子、程咬金同上。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "无事关心心不乱， 有事关心心不安。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老夫程咬金。适才在金殿用花言巧语，蒙哄万岁。可恨那牛鼻子老道，奏了一 本，请万岁明日过府，一来探病，二来取印。我想这事，二哥一概不知。倘若 万岁明日过府，问起情由，二哥一概不知，岂不是有蒙君之罪。我不免连夜过 府，与二哥送上一信。倘若明日万岁问起情由，也免得二哥临时失于机变。 家院，掌灯秦府！"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "成事在人谋事天， 心中恼恨黑炭丸。 一心要放暗中箭， 摆布黑贼有何难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金、程院子同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦院子、秦怀玉、秦琼同上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "投唐保国扶江山， 东挡西征马上眠。 自从扫北回朝转， 得下病症整一年。 红日西落天色晚， 心中焦躁不耐烦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程院子、程咬金同上。"
        },
        {
