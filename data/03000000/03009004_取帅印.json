          "text": "秦院子、秦琼同上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "昨日咬金报一信， 果然圣驾到来临。 假作昏迷睡不醒， 且看万岁怎样行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、尉迟恭、程咬金、秦怀玉引李世民同上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "孤王亲自来探病， 功劳打动帝王心。 君臣且把病房进， 只见恩公睡沉沉。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "一觉睡来方才醒， 耳旁听得有人声。 猛然睁开昏花眼， 抬头只见圣明君。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "怀玉，圣驾到此，为何不来通报？"
