{
  "script_id": "03074004",
  "title": "钟子期听琴",
  "alias": [
    "知音会"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "钟子期",
      "hangdang": "生"
    },
    {
      "name": "俞伯牙",
      "hangdang": "生"
    }
  ],
  "plot": "战国时，晋大夫俞伯牙使楚，回朝复旨，行船至马鞍山，忽遇大风，停舟岸边，操琴自娱。适钟子期进山砍\n柴，闻声窃听。二人相见，互谈琴律，两相爱慕，遂结为异姓兄弟。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "俞伯牙上。"
        },
        {
          "character": "俞伯牙",
          "type": "引子",
          "text": "只为寻胜观奇景，不顾登山涉水难。"
        },
        {
          "character": "俞伯牙",
          "type": "念",
          "text": "青溪流过碧山头，云水澄清一色秋。隔断红尘三十里，白云红叶两悠悠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "琴童暗上。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "下官，姓俞名瑞字伯牙，在晋国为臣，官居上大夫之职。奉旨去楚修聘。修聘 已满，回朝缴旨复命。 来！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "吩咐鸣锣开舟！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "众人役，鸣锣开舟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水手同上。"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "开舟！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "波浪滚滚，秋风飒飒，好一派江景也！"
        },
        {
          "character": "俞伯牙",
          "type": "西皮原板",
          "text": "旷野奇峰山外山， 夕阳光映水连天。 波浪滚滚秋波样， 一阵风来波浪颠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水手同喊叫。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "水手为何这等罗唣？"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "水手为何这等罗唣？"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "风狂浪大，难以行舟。"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "启老爷：风狂浪大，难以行舟。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "靠山停舟！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "伙计们，靠山湾船！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "叫他们下舱歇息。"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "我家大人叫你们下舱歇息去吧！"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "多谢大人！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "风狂浪大，遇岸停舟，山水相逢，又是一派光景也！"
        },
        {
          "character": "俞伯牙",
          "type": "西皮原板",
          "text": "游山玩水过山川， 狂风吹动树枝颠。 抬头忽见明星现， 玉兔东升照青天。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "你看风雨已住，月明如昼。 来！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "焚香取琴过来！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "琴童焚香，取琴。"
        },
        {
          "character": "钟子期",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期上。"
        },
        {
          "character": "钟子期",
          "type": "西皮摇板",
          "text": "从早离家上山巅， 狂风骤雨两相连。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "在下，钟子期。乃楚国人氏。我父钟元圃，母亲张氏。父母年迈，是我每日进 山砍樵，易钱度日。今朝进山砍樵，不料被狂风骤雨所阻，幸喜雨住，急速归 家，免得双亲悬念。我就此归家便了！"
        },
        {
          "character": "钟子期",
          "type": "西皮原板",
          "text": "幸喜老天随人愿， 明月如同白昼天。 山路崎岖步迟慢， 秋景清幽甚可观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "俞伯牙抚琴。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "呀！行至此处，哪有琴声嘹亮，待我细听一番便了！"
        },
        {
          "character": "俞伯牙",
          "type": "西皮原板",
          "text": "净手抚琴琴不乱， 客中无事自心宽。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "俞伯牙",
          "type": "西皮原板",
          "text": "用手拨动颜回谱， 一曲悠悠忽断弦！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "一曲未终，忽然弦断，想必有人窃听。 来！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "问水手，来此什么所在？"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "来此什么所在？"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "靠山湾舟，不知地名。"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "启老爷：靠山湾舟，不知地名。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "我看此处，离村庄不远，必有人前来窃听吾琴呀！"
        },
        {
          "character": "俞伯牙",
          "type": "西皮二六板",
          "text": "必是歹人来窥望， 恐有盗贼起不良。 荒山野岸无人管， 不可大意要提防！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "来，吩咐水手，上岸搜寻！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "众水手！上岸搜寻！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水手同上岸搜。"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "有一男子在此。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "唔！你这人在此，莫非有偷盗之意？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "船上长官休得见怪。我非盗贼之流，乃是樵子。听得琴音幽雅，节操甚高，故 而在此窃听。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "哈哈哈……山野村夫，也会听琴？吾不见罪于他，叫他去吧！"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "我家老爷，并不怪罪于你，叫你去吧！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "官长此言差矣！岂不闻“十室之邑，必有忠信”？站内有君子，门外君子至。 官长若欺旷野之中无人识琴知音，这荒川岸下，也就无有抚琴之人了。"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "不要多言。去吧！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "唔！不要罗唣！此人出言不俗，必有学问。打坐船头。 岸上君子，方才听琴者，可是尊驾？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "正是小人。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "方才所抚，可知是何曲名？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "官长抚的是仲尼叹颜回之谱。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "其诗怎念？"
        },
        {
          "character": "钟子期",
          "type": "念",
          "text": "可叹颜回命早亡，叫人思想鬓如霜。只因花香早来落……"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "官长抚至此句，琴弦断了，下句未终，是与不是？"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "下句怎道？"
        },
        {
          "character": "钟子期",
          "type": "念",
          "text": "留得芳名万古扬。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "先生真乃名士！请上船来一叙。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "小子来也！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "搭上扶手！"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "是。 请上船来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期上船。"
        },
        {
          "character": "钟子期",
          "type": "西皮摇板",
          "text": "上得船来把礼见， 看他对答有何言？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "小子有礼！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "看座！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "谢座！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "足下既知琴音，必知琴之来源，何人所造，抚它有何益处？"
        },
        {
          "character": "四水手",
          "type": "同白",
          "text": "启老爷：雨过月明，正好行舟。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "承蒙大人下问，小人若是絮烦，恐耽误大人行船。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "只要足下谈论得是，漫说行船，就是辞官，这又何妨？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "如此，小子放肆狂言了！琴乃伏羲氏所造，见五星之精气，飞坠梧桐，并有凤 凰来仪。凤凰乃百鸟之王，非竹实不食，非梧桐不栖，非清泉不饮。伏羲视之， 乃知梧桐为树中之纯材，夺造化之精气，令人砍伐，制成雅乐。其树高三丈 三尺，按三十三天之数，截为三段，分天、地、人三才：取其上段扣之，其声 太清，以过轻而废之；取其下段而扣之，其声太浊，以其过重而废之；取其中 段而扣之，清浊得济，轻重相宜，送之长流水中，浸了七十二日，按七十二候 之音，择选吉辰召高手匠人刘子奇，造成雅乐。此琴三尺六寸五分，按周天三 百六十五度：前阔八寸，按八节；后阔四寸，按四时；厚二寸，按两仪。有金 童头，玉女腰，仙人背，龙池，凤沼，玉轸，金徽。那徽有十二，按十二月； 又有一中徽，按润月。先是五条弦在上，外按五行：金木水火土。内按五音： 宫商角徵羽。尧舜时操五弦琴，歌南风，天下大治。其后周文王被囚羑里，吊 子伯邑考，添弦一根，清幽哀怨，谓之“文弦”。后武王伐纣，前歌后舞，添 弦一根，激烈发扬，谓之“武弦”。先有宫商角徵羽，后加二弦称为“文武七 弦”。琴有六忌、七不弹、八不绝。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "请问足下，何谓六忌？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "大人请听！"
        },
        {
          "character": "钟子期",
          "type": "西皮原板",
          "text": "一忌大寒指不捻， 二忌大暑莫弄弦， 三忌大风琴音乱， 四忌大雨宫商颤， 五忌迅雷心要缓， 六忌枯霜大雪天。 此是抚琴名六忌， 还有平时七不弹。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "请问足下，哪七不弹？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "大人听了！"
        },
        {
          "character": "钟子期",
          "type": "西皮原板",
          "text": "闻丧不忍整桐弦， 奏乐之中韵不传， 事在忙中心多乱， 不净身体秽圣贤， 衣冠不整音不正， 不焚清香莫向前， 此琴雅韵非凡品， 不遇知音不与弹。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "请问足下，何谓八不绝？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "清、奇、幽、雅、悲、壮、悠、长。"
        },
        {
          "character": "钟子期",
          "type": "西皮二六板",
          "text": "抚到美哉是清闲， 对对仙鹤飞满天。 虎啸闻耳声不吼， 猿猴闭口不声喧。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "足下既知琴历，可知昔日孔圣抚琴，颜回自外而入，那琴忽然不悲伤之音，疑 有贪杀之意，怪而问之，果然房中有猫捕鼠。倘然下官抚琴，心有所思，足下 能知否？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "诗云：“他人有心，予忖度之。”大人可以抚弄一曲，小子续之，若续不着， 大人休罪，哈哈哈……"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "哈哈哈……如此说来，请听！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "俞伯牙抚琴。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "美哉，洋洋乎！"
        },
        {
          "character": "钟子期",
          "type": "西皮二六板",
          "text": "洋洋盈耳琴韵间， 闲情雅致在高山。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "再听！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "俞伯牙抚琴。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "美哉，荡荡乎！"
        },
        {
          "character": "钟子期",
          "type": "西皮二六板",
          "text": "荡荡流水真堪羡， 悠悠千里去不还。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "俞伯牙",
          "type": "西皮二六板",
          "text": "对答如流非等闲， 此人可以细交谈。 忙整衣冠礼重见， 方才失敬望海涵！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "先生真乃明师，请上坐！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "告坐！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "请问先生尊姓大名？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "小子姓钟名徽，字子期。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "原来是子期先生，失敬了！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "岂敢！请问大人上姓尊名，荣任何所？"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "下官姓俞名瑞字伯牙，乃楚国人氏，在晋国为臣，官拜上大夫之职。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "原来是伯牙大人，小子失敬，有罪了！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "来，看酒！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "怎敢打搅？"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "有酒无肴。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "子期请！"
        },
        {
          "character": "俞伯牙",
          "type": "西皮原板",
          "text": "开怀畅饮共登船， 幸遇高贤亦前缘。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "钟子期",
          "type": "西皮原板",
          "text": "大人不嫌才学浅， 只为知音两相谈。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "请问先生府住何所？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "离此不远，马鞍山集贤村，便是荒居。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "贵干何业？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "砍柴度日。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "先生饱学，何不入朝为官，免得隐居山前，渔樵混俗，不知以为然否？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "实不相瞒，曾授郑州知州，失了印信，故而避此偷生，以采樵为活。上有年迈 双亲，下无手足，只可独自攀樵，苦度光阴，供养双亲之余年。虽位列三公之 尊，也无非度日孝敬双亲也！"
        },
        {
          "character": "钟子期",
          "type": "西皮二六板",
          "text": "父母恩深真比天， 岂为功名别膝前？ 富贵功名非我愿， 愿孝双亲在家园。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "孝道可羡。请问尊庚几何？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "今年三七。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "下官意欲与先生结为金兰之好，不知尊意如何？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "大人乃朝廷命官，小子乃山野村夫，焉敢妄攀？"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "下官碌碌风尘，偶遇高贤，真乃三生有幸。若论富贵，吾俞瑞何足道哉！子期 不必推辞，你我就在船头焚香一拜。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "兄长请！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "贤弟请！"
        },
        {
          "character": "钟子期",
          "type": "西皮摇板",
          "text": "山村俗子蒙青眼，"
        },
        {
          "character": "俞伯牙",
          "type": "西皮摇板",
          "text": "欲觅知音难上难！"
        },
        {
          "character": "钟子期",
          "type": "西皮摇板",
          "text": "你我知己今见面，"
        },
        {
          "character": "俞伯牙",
          "type": "西皮摇板",
          "text": "月落星稀已明天。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "兄长，天色已明，小弟就要告辞了！"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "怎么说就要分离？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "小弟恐双亲悬望。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "唉！贤弟呀！"
        },
        {
          "character": "俞伯牙",
          "type": "二黄摇板",
          "text": "我和你只恨相见晚， 怎忍分离在眼前？ 贤弟同行我心愿， 了却三生石上缘！"
        },
        {
          "character": "钟子期",
          "type": "二黄原板",
          "text": "三生有幸今见面， 蒙兄相爱感心间。 本当随兄同为伴， 双亲倚门望眼穿。 恕弟一时情义短， 望兄你把海量宽。"
        },
        {
          "character": "俞伯牙",
          "type": "二黄原板",
          "text": "贤弟到家辞椿萱， 同到晋阳过几年。 游必有方何挂念， 也落得朝夕得清闲。"
        },
        {
          "character": "钟子期",
          "type": "二黄原板",
          "text": "辞亲不允恐兄怨， 从今远隔山与川。 云水渺渺音信断， 失信朋友禽兽般。"
        },
        {
          "character": "俞伯牙",
          "type": "二黄原板",
          "text": "孝顺父母真堪羡， 古今可算你为先。 弟来必当作书柬， 愚兄等你在坡前。 叫童儿速把黄金献， 携手相对泪涟涟。 赠金略表心一片， 知己相交莫弃嫌。"
        },
        {
          "character": "钟子期",
          "type": "二黄原板",
          "text": "蒙兄相待恩非浅， 顷刻相离泪不干。 仁兄归家路途远， 常怀相思隔一天。 忍泪辞兄下舟船， 兄长呀！ 只恐相逢难上难！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期哭，依依不舍，下。"
        },
        {
          "character": "俞伯牙",
          "type": "白",
          "text": "哎呀贤弟呀！"
        },
        {
          "character": "俞伯牙",
          "type": "二黄摇板",
          "text": "谈论一宵嫌夜短， 难舍难分泪不干。 玉兔坠落金乌现， 听得满江闹声喧。 琴童速把水手唤， 叫他们起来快开船。"
        },
        {
          "character": "琴童",
          "type": "白",
          "text": "是。 水手们，快开船！"
        },
        {
          "character": "四水手",
          "type": "内同白",
          "text": "开船喽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "俞伯牙、琴童同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "钟元圃、钟婆同上。"
        },
        {
          "character": "钟元圃",
          "type": "二黄原板",
          "text": "昨夜晚未安眠夫妻同坐，"
        },
        {
          "character": "钟婆",
          "type": "二黄原板",
          "text": "我的儿不见回却是为何？"
        },
        {
          "character": "钟元圃",
          "type": "二黄原板",
          "text": "儿昨日出门后风雨大作，"
        },
        {
          "character": "钟婆",
          "type": "二黄原板",
          "text": "心暗想怕的是吉少凶多！"
        },
        {
          "character": "钟元圃",
          "type": "二黄原板",
          "text": "常言道人生有旦夕之祸，"
        },
        {
          "character": "钟婆",
          "type": "二黄原板",
          "text": "怕的是山林中猛兽忒多。"
        },
        {
          "character": "钟元圃",
          "type": "二黄原板",
          "text": "恨只恨事临头无法差测，"
        },
        {
          "character": "钟婆",
          "type": "二黄原板",
          "text": "但愿得我的儿不受风波。"
        },
        {
          "character": "钟元圃",
          "type": "二黄原板",
          "text": "出门来盼姣儿心急如火，"
        },
        {
          "character": "钟婆",
          "type": "二黄原板",
          "text": "那前面有一人奔下山坡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期上。"
        },
        {
          "character": "钟子期",
          "type": "二黄摇板",
          "text": "好一个俞伯牙仁义待我， 一路上实难舍心如刀割。 虽然是五伦中离亲有过， 见爹娘倚门望两泪如梭。"
        },
        {
          "character": "钟元圃、钟婆",
          "type": "同白",
          "text": "我儿回来了！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "孩儿回来了！"
        },
        {
          "character": "钟元圃",
          "type": "白",
          "text": "将柴担放下，随父进来。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期进门。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "爹娘在上，孩儿拜见！"
        },
        {
          "character": "钟婆",
          "type": "白",
          "text": "罢了。坐下。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "孩儿告坐。一夜未回，少奉甘旨，恕孩儿不孝之罪！"
        },
        {
          "character": "钟元圃、钟婆",
          "type": "同白",
          "text": "我儿一夜未回，哪里去了？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "启禀爹娘：清早进山砍樵，不料大雨阻隔，至晚方归。偶遇晋国大夫俞伯牙， 相谈琴律，与孩儿结拜手足。临行分别，难以割舍，赠孩儿黄金二笏，望爹娘 收下。"
        },
        {
          "character": "钟元圃、钟婆",
          "type": "同白",
          "text": "果然黄金，真正难得呀！"
        },
        {
          "character": "钟元圃",
          "type": "二黄原板",
          "text": "想那人他待你情高义厚，"
        },
        {
          "character": "钟婆",
          "type": "二黄原板",
          "text": "谈一夜赠多金儿怎报酬？"
        },
        {
          "character": "钟元圃",
          "type": "二黄原板",
          "text": "儿不请他到家实在荒谬，"
        },
        {
          "character": "钟婆",
          "type": "二黄原板",
          "text": "细思想我的儿忒无理由。"
        },
        {
          "character": "钟子期",
          "type": "二黄原板",
          "text": "儿有意未曾言他已解透， 怎奈他奉王命不敢停留。 临行时他与儿叮咛分手， 相约会到来年八月中秋。"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "哎呀！哎呀！"
        },
        {
          "character": "钟子期",
          "type": "二黄摇板",
          "text": "为什么身恍惚难以立坐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期吐血。"
        },
        {
          "character": "钟元圃、钟婆",
          "type": "同白",
          "text": "我儿怎么样了？"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "钟子期",
          "type": "二黄摇板",
          "text": "浑身上如冰雪口内焦浊。 会伯牙怕的是今生无着， 我这里辜负他情义过多！ 强挣扎进房内倚榻而卧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期吐血。"
        },
        {
          "character": "钟子期",
          "type": "二黄摇板",
          "text": "要相逢除非是梦里南柯！"
        },
        {
          "character": "钟子期",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟子期下。"
        },
        {
          "character": "钟元圃",
          "type": "二黄摇板",
          "text": "见姣儿身染病双眉愁锁，"
        },
        {
          "character": "钟婆",
          "type": "二黄摇板",
          "text": "因家贫苦劳力无计奈何！"
        },
        {
          "character": "钟元圃",
          "type": "二黄摇板",
          "text": "想是他白日间受了饥饿，"
        },
        {
          "character": "钟婆",
          "type": "二黄摇板",
          "text": "你快去请良医急早调和。"
        },
        {
          "character": "钟元圃",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "钟婆",
          "type": "白",
          "text": "如何得了呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟元圃、钟婆自两边分下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}