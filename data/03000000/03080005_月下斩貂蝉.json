{
  "script_id": "03080005",
  "title": "月下斩貂蝉",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "貂蝉",
      "hangdang": "旦"
    }
  ],
  "plot": "曹操欲以美色迷关羽，特遣貂蝉供驱使，关羽为全貂蝉美名，月下斩之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四月华旗、四飞虎旗同上，大马童引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "忠心赤胆，扶汉室，锦绣江山。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "青龙偃月武艺高，万马营中逞英豪。温酒未寒华雄斩，桃园美名万古标。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，关羽。弟兄三人桃园结义，白马祭天，乌牛祭地，一在三在，一亡三亡。 只因水淹下邳，吕布被擒；吕布之家属，均落于相府。那曹操将貂蝉送与某家， 以侍枕席。不过欲使某迷恋美色，消磨英雄志气。某想貂蝉牺牲一身，匡扶 社稷，使董卓父子自相残害，有功于汉朝。当此离乱之时，只有一死，方能保 其名节。 马童！"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看看今晚有月无月？"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大马童看。"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "启爷：明月当空，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "将窗儿挂起。两厢退下！"
        },
        {
          "character": "四月华旗、四飞虎旗",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四月华旗、四飞虎旗同下。大马童支窗。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "明月当空照窗前， 风吹云散星斗全。 对孤灯我把春秋看， 看春秋想起了事一端。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想那董卓专权，蓄意谋篡，吕布小儿助纣为虐，若不是那貂蝉呵！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "若不是貂蝉女连环计献， 怎能够使奸佞父子相残。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马童！"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "传貂蝉进帐！"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大马童向外。"
        },
        {
          "character": "大马童",
          "type": "白",
          "text": "貂蝉进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大马童下。"
        },
        {
          "character": "貂蝉",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉上。"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "听呼唤移步奔虎帐， 十指尖尖捧茶汤。 走向前，用目望， 杀气森森貌堂堂。 低头不语双膝跪，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉跪。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "慢睁凤眼看端详。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "下跪可是貂蝉？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "为何不抬起头来？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "多谢二将军！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "灯光下见貂蝉十分美俊， 好似那嫦蛾降下凡尘。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂蝉！"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你既是司徒王允之女，可知历代褒贬之事，"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子不知。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "知道什么？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "知道三杰。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哪三杰?"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "周三杰、汉三杰。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "何为“周三杰”？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "周公、太公、召公。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "“汉三杰”呢？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "张良、韩信、萧何。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "自周朝以来，古今出了多少名将？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子才疏学浅，倘有差错，望二将军指教。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你且讲来！"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "二将军容禀！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "前三皇后五帝道德为上， 有尧舜和禹汤四大明王。 周文王梦飞熊夜入虎帐， 渭水河访贤臣定国安邦。 十八国伍子胥盟辅上将， 十二国钟无盐女中豪强。 前七国有孙庞二人斗智， 后七国有乐毅兵伐齐邦。 前汉朝至平帝出了王莽， 光武帝整乾坤迁都洛阳。 小女子说不尽古今良将， 一朝君一朝臣犬吠尧王。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "有关某闻言心中高兴， 好一个貂婵女与众不同。 我不问前朝的兴和废， 单问你虎牢关谁是英雄？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "我闻言吃一惊心中暗想， 口问心心问口自己思量： 战沙场论英雄可算吕布， 但是难比刘、关、张。 走向前屈膝跪， 尊一声二将军细听端详: 论英雄三将军天下无双，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你丈夫吕布呢？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "那吕布三姓奴臭名远扬。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你可曾见过我那三弟？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "虎牢关摆战场， 金鼓声喧鬼神忙！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我那三弟他头戴？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "头戴着乌金盔盔缨灿亮，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "他身穿？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "身穿着乌油甲甲放毫光。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "胯下？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "胯下一骑乌骓马，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "手使何物？"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "手使一杆丈八枪。 在阵前吼一声犹如雷响， 好一似黑煞神下了天堂。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "好一个貂蝉女能言善讲， 言来语去有文章。 成全她名扬世间上， 青锋剑斩她一命亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽拔剑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂蝉！"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你可识此剑？"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "小女子不知。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此剑乃周文王所造，传到关某手中，遇有不平之事，它便做响！"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "但不知响过几次了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "响过三次。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "第一次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斩颜良、诛文丑。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "第二次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "白门楼斩吕布。"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "这第三次呢？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这第三次么！帐前无人，恐怕要应在你的身上！"
        },
        {
          "character": "貂蝉",
          "type": "白",
          "text": "二将军哪！"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "听一言来心惊战， 尊一声二将军听我言： 你往日斩的是英雄汉， 要斩我弱女子所为哪般？"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "我爱你怀揣忠义胆， 匡扶社稷你计献连环。 功高盖世人称赞， 人虽亡美名儿留在世间。"
        },
        {
          "character": "貂蝉",
          "type": "吹腔",
          "text": "风儿吹得烛光闪， 云敛晴空月正圆。 人生在世间上时光有限， 死得其所我心也甘。 二将军请你快把我来斩，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂蝉引头就刃。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "关云长月下斩貂蝉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽斩貂蝉死。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "弟兄结拜在桃园，三战吕布虎牢关。杀死颜良诛文丑，明月之下斩貂蝉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、貂蝉同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}