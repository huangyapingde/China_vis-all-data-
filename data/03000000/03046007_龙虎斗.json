{
  "script_id": "03046007",
  "title": "龙虎斗",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "呼延赞",
      "hangdang": "净"
    }
  ],
  "plot": "宋初，呼延寿廷被欧阳方所杀；其子呼延赞闻讯，举兵至河东报仇，宋军皆非其敌。赵匡胤亲自出阵，顺说\n不服，击呼延赞下马，正欲杀之，见呼延赞头上现虎形，赵匡胤乃惊倒；呼延赞举鞭欲打，见赵匡胤头上现\n龙形，呼延赞因降宋，后杀欧阳方。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖发点〗。四大铠、四太监、大太监引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "引子",
          "text": "龙争虎斗，这干戈，何日罢休！"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "蛟龙无水困沙滩，失却明珠寻觅难。中了奸贼牢笼计，汴梁何日得回还。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "孤、乾德王赵。可恨欧阳方，将孤诓下河东七载，内无粮草，外无救兵。也曾 命黄信四路打探，未见回报。"
        },
        {
          "character": "黄信",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄信上。"
        },
        {
          "character": "黄信",
          "type": "念",
          "text": "探听军事情，奏与万岁知。"
        },
        {
          "character": "黄信",
          "type": "白",
          "text": "报！黄信告进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄信进门。"
        },
        {
          "character": "黄信",
          "type": "白",
          "text": "臣、黄信见驾，吾皇万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "黄信",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "命你打探军情，一一奏来！"
        },
        {
          "character": "黄信",
          "type": "白",
          "text": "臣打探罗家山发来一哨人马，昨日鞭坠白龙，今日马踏御营。特来报知！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "再探再报！"
        },
        {
          "character": "黄信",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄信下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "且住！适才黄信报道：罗家山发来一哨人马，昨日鞭坠白龙，今日马踏御营。 若是我国人马，就不该马踏御营；若是他国人马，就不该鞭坠白龙。此事叫孤 好难解也！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄原板",
          "text": "探马儿不住的飞来报， 他报道罗家山兵发一标。 杏黄旗不住在空中飘绕， 吓坏了御营中大小英豪。 恨河东刘崇贼打来战表， 他要夺孤王的锦绣龙朝。 欧阳方在金殿帅印挂了， 呼寿亭倒作了先行英豪。 一文一武把孤保， 白龙关前枪对刀。 下河东困七载把孤的胡须白了， 为社稷昼夜里哪顾辛劳？ 在头上取下了飞龙帽， 身上—— 在身上脱下了衮龙袍。 孤的玲珑—— 玲珑铠甲落丝绦， 杀人的妙策计一条。 御林军与孤巡营了哨， 把守御营要勤劳。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监、大太监同下。马夫暗上。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄原板",
          "text": "叫曹头将孤的龙驹鞍辔备好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。马夫洗马。赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄原板",
          "text": "这是孤无良将自把兵交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、马夫同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套引呼延赞同上。"
        },
        {
          "character": "呼延赞",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖四击头〗。呼延赞、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "催马来在战场道， 看一看来的是哪家儿曹。"
        },
        {
          "character": "呼延赞",
          "type": "内唢呐二黄导板",
          "text": "乌骓马不住的连声吼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延赞上。"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄原板",
          "text": "打将鞭一举鬼神愁。 催马儿来至在御营口，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "哦喝，呔！"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄原板",
          "text": "叫一声乾德王早出龙楼！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄原板",
          "text": "只见他乌油盔来乌油甲， 皂罗袍上绣团花。 跨下了一骑乌骓马， 打将钢鞭手中拿。 问一声小将名和姓， 通上名来尔是哪家？"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "听者！"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄原板",
          "text": "家住在河南胡迈境， 我的父名叫呼延寿亭。 若问少爷的名和姓，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "呼延赞就是少爷的名。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "只说呼延绝了后， 谁知还有这条根！ 不通名姓打马走——"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "钢鞭不打无名少姓人。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "乾德王驾坐黄罗帐， 我是他驾前一小军。"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "丹凤眼来卧蚕眉， 五柳胡须飘胸膛。 看你不像小军样， 定是御营乾德王。 拳打五虎把名扬， 岂肯失信小儿郎！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "若问孤王名和姓， 少打关西赵玄郎。"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "看鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、呼延赞同起打，赵匡胤、呼延赞双收下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "龙形、虎形同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "小将生来武艺大， 手使钢鞭似铁塔。 一鞭打下千斤重，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "唔呼呀！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "震得孤王虎口麻。 催马来在战场下， 小将到此顺说他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延赞上。"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "我的父犯了何条罪， 为何斩首在御营？"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄导板",
          "text": "小将军暂且珠泪停，"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄原板",
          "text": "细听孤王说分明： 恨河东刘崇贼打来战本， 他要夺孤王的锦绣龙廷。 欧阳方在金殿挂了帅印， 尔的父倒做下了马前先行。 三更时贼胡儿前来偷营， 只说是反了个呼延寿亭。 孤王斩字未出唇， 欧阳方拔宝剑斩尔的天伦。"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "君不开口谁敢斩， 哪有臣子乱杀人？"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "兵权落在奸贼手， 为王也要听令行。"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "不会为君死了罢， 天宫再降紫微星。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "你若保孤回朝转， 孤封你前殿王，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "不要！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "后殿王，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "也不要！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "一十八家总殿王。"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "不做官来不受害， 不食爵禄不耽心。 封我官职我不要， 一心要报杀父冤。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "小将不必逞刚强，"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "罗家山前自为王。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "孤王与你分上下？"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "少爷与你斗输赢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、呼延赞同起打，赵匡胤、呼延赞双收下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "龙形、虎形同上，同战斗，龙形败下，虎形追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、呼延赞同上。龙形、虎形同暗上。"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "人困马乏难交战，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "只见小将睡雕鞍。 手执金棍朝下打，"
        },
        {
          "character": "赵匡胤",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": "赵匡胤",
          "type": "唢呐二黄散板",
          "text": "只见猛虎护着他。"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "梦儿里只见我父到，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "只见昏王睡鞍桥。 手执钢鞭朝下打，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙形阻。"
        },
        {
          "character": "呼延赞",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈……"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "只见火龙上九霄。 甩镫离鞍下虎豹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延赞下马。"
        },
        {
          "character": "呼延赞",
          "type": "唢呐二黄散板",
          "text": "山呼万岁将臣饶。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "耳边厢又听得山呼万岁，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮原板",
          "text": "想必是孤国中发来救兵。 猛然间睁开了丹凤眼，"
        },
        {
          "character": "呼延赞",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "又只见小将跪至在马前。 在马上擒王擒不住， 诓孤下马难上难。"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "万岁爷不必心害怕， 呼延赞保你坐中华。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "你若是保孤坐中华， 何不对天把誓发？"
        },
        {
          "character": "呼延赞",
          "type": "西皮快板",
          "text": "万岁爷命我把誓发， 日月三光照着咱。 呼延赞保主有假意， 死在千军万马踏！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "一见小将把誓发， 不由孤王笑哈哈。 左思右想不下马，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "金棍挑起小冤家。"
        },
        {
          "character": "呼延赞",
          "type": "西皮摇板",
          "text": "走向前来参王驾，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "孤王传旨且平身。"
        },
        {
          "character": "呼延赞",
          "type": "西皮摇板",
          "text": "杀父仇人哪一个？"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "欧阳方是尔的对头人。"
        },
        {
          "character": "呼延赞",
          "type": "西皮摇板",
          "text": "奸贼营盘在何处？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "随我来！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "不在前营在后营。"
        },
        {
          "character": "呼延赞",
          "type": "西皮摇板",
          "text": "辞别万岁把马跨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。"
        },
        {
          "character": "呼延赞",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延赞下。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "喜哈哈来笑呵呵， 孤王收了活阎罗。 今日收了这员将， 哪怕胡儿动干戈！"
        },
        {
