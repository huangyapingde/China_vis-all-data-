{
  "script_id": "03054006",
  "title": "徐母骂曹",
  "alias": [
    "击曹砚"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "徐母",
      "hangdang": "老旦"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "程昱",
      "hangdang": "老生"
    }
  ],
  "plot": "曹仁败归许昌，曹操知徐庶之谋，乃用程昱计，诓来徐母，并令修书招徐庶。徐母大怒，痛骂之，且以砚击\n曹操。曹操怒欲斩，经程昱劝免，囚居别室。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、曹用同上。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "俺，曹用。奉了丞相之命，去往颍州诓请徐母。 大家趱行者！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "引子",
          "text": "闷坐草堂，自凄凉，好不惨伤！"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "大儿四海访良朋，次子一命赴幽冥。可叹老身缺侍奉，凄凉孤苦在家中。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身，徐庶之母，所生两个孩儿：长子徐庶，在外寻朋访道，久未归家；次子 徐康，身得重病，一命身亡。撇下老身伶仃孤苦，独守家中。思想起来，好不 伤感也！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "老身生来命不强， 不幸中年居了孀。 长子在外宾朋访， 次子徐康一命亡。 不盼徐庶归家往， 但盼我儿早把名扬。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "唉，儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、曹用同上。"
        },
        {
          "character": "曹用",
          "type": "唱",
          "text": "丞相差我颍州往， 迎接徐母进许昌。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "俺，曹府家将曹用是也。奉了丞相之命，迎接徐母进京。此番前去，必须见机 而行。看离颍州不远，马上加鞭！"
        },
        {
          "character": "曹用",
          "type": "唱",
          "text": "扬鞭打马朝前闯， 转眼来到一村庄。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "邻人",
          "type": "内同白",
          "text": "请了！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "借问一声，此处有位徐老太太，她在哪里？"
        },
        {
          "character": "邻人",
          "type": "内同白",
          "text": "哪位徐老太太？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "徐庶、徐康之母。"
        },
        {
          "character": "邻人",
          "type": "内同白",
          "text": "前面黑漆门楼就是。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "多谢了！ 徐老太太，开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "门外有人把话讲， 莫非徐庶转回乡。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "外面击户之人是哪里来的？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母开门。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "京都来的。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "到此作甚？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "迎接徐老太太进京。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身就是。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "原来是徐老太太，小人叩头。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "不消。起来。里面讲话。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "是。 你们随我进来，大家见过，这是徐老太太。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "参见徐老太太！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "罢了。起来。"
        },
        {
          "character": "四文堂",
          "type": "白",
          "text": "谢过徐老太太！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "他们都是甚等之人？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "他们都是一路上伺候老太太的。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "好，大家坐下！"
        },
        {
          "character": "四文堂",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你奉何人所差？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "小人奉家主程大老爷与徐庶大老爷所差。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程大老爷他是何人？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "姓程名昱，与徐老爷同殿为官，结拜弟兄。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "他二人身居何职？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "俱是议郎之职。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我儿官居议郎，待老身谢天谢地！"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "当谢天地。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "他二人因何接我进京？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "二位老爷闻听二老爷现已亡故——"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母哭。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "恐怕老太太无人奉养，特差小人前来迎接老太太进京，同享荣华。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "可有书信？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "这个！并无书信。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "为何无有书信？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "二位老爷官差繁忙，修书不及。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "既然如此，老身后面收拾收拾，你去准备车辆。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "小人遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用、四文堂同下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "这就好了！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "我儿在京官议郎， 迎接老身进许昌。 母子会面喜天降， 可叹徐康一命亡。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "唉，儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、车夫、曹用同上。"
        },
        {
          "character": "曹用",
          "type": "唱",
          "text": "门前备下车一辆， 有请太太赴京堂。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "有请老太太！"
        },
        {
          "character": "徐母",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "安排行李皆停当， 母子相逢梦一场。 家将引路把车上， 想起徐康好心伤。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "唉！儿呀，你大哥接为娘进京同享荣华，你是怎的不来，怎的不往？"
        },
        {
          "character": "徐母",
          "type": "三叫头",
          "text": "徐康！吾儿！我那苦命的儿呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母哭。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第六场",
      "utterances": [
        {
          "character": "曹操",
          "type": "内唱",
          "text": "汉业衰微天地荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四朝臣、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "各路烟尘起四方。 东吴孙权声势壮， 西蜀有个小刘璋。 刘备新野招兵将， 景升坐镇在荆襄。 吕布白门楼下丧， 袁氏兄弟自残伤。 众诸侯不在我心上， 单防刘备与孙郎。 老夫时刻把名士访， 搜罗天下众贤良。 程昱曾把徐庶讲， 赛过当年的张子房。 因此差人颍州往， 迎接徐母进许昌。 撩袍端带二堂上， 这就是我为国求贤日夜忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹用上。"
        },
        {
          "character": "曹用",
          "type": "唱",
          "text": "相府门外住车辆， 见了丞相说端详。"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "丞相在上，小人叩头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "曹用你回来了？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "迎接徐母，可曾接到？"
        },
        {
          "character": "曹用",
          "type": "白",
          "text": "现已接到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你同众位将军前去迎接。"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁、曹用同下。"
        },
        {
          "character": "徐母",
          "type": "內唱",
          "text": "来在府门下车辆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁、曹用、徐母同上。"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "太夫人一路安泰？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身安泰！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "众位官员列两旁。"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "我等奉丞相钧旨，前来迎接。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "有劳了！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "丞相与我无来往，"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "丞相与徐老爷同殿为官。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "迎接老身为哪桩？"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "丞相有大事相商。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "就里根由难猜想，"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "太夫人见了丞相便知。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "我儿徐庶在哪厢？"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "往新野公干未回。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "迈步且把二堂上，"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "徐太夫人到！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "曹用、曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "丞相有请！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "见了丞相问端详。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "丞相在上，老身万福！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人少礼。请坐！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人一路风尘，身体可好？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "承问。请问丞相，我儿徐庶他往哪里去了？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人有所不知，元直现在新野，请太夫人修书一封，招他回来。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "未知我儿在新野依附何人？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "现在新野帮助逆臣刘备，正如美玉陷在淤泥，明珠埋于尘垢。太夫人将他招回， 老夫奏知天子，必有封赠也！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "元直本是一英豪， 帮助刘备为哪条！ 美玉埋没淤泥泡， 一颗明珠在沟濠。 太夫人作书把他招， 管保位列在群僚。 人来看过文房宝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文堂甲捧文房四宝放徐母面前。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "这事其中有蹊跷。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "请问丞相，老身闻家将言道，我儿现在京都，官居议郎。如今丞相又命我修书， 保他官职，是何道理？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫差家将奉请，恐怕太夫人不肯前来，托言元直在京为官，以安老夫人之心。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "原来是尔等诡计！曹丞相，你可知刘备他是何等人物？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "他乃是涿县小辈，妄称皇叔，全无信义，外君子而内小人者也！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "刘备家住在楼桑， 结拜弟兄关与张。 共灭董卓随军往， 袁术与他事参商。 老夫暗把美言讲， 送他斗酒表心肠。 如今两相无来往， 反把恩人当祸殃！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "听他言来怒满腔， 才知就里与行藏。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹丞相此言差矣！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身闻刘玄德乃是中山靖王之后，孝景皇帝玄孙。屈身下士，恭己待人，义气 行于四方，仁声著于天下，虽牧子、樵夫、黄童、白叟，谁不称他为仁义君子？ 真乃当世的英雄，超群的豪杰！吾儿若果辅之，正是如鱼得水。既遇贤良， 我徐门三代宗亲千万之幸。汝虽名为汉相，实为汉贼。内怀谋朝篡位之心，外 达挟主专权之技，新都移驾，致使百姓流离；许田打围，众官无不切齿。用祢 衡为鼓吏，名士寒心，杀太医于市朝，忠臣眦裂。甚而贵妃斩于宫掖，甄氏霸 为儿媳，种种奸谋，彰明昭著。世之三尺童子，未有不想杀尔之头，割尔之心， 碎尔之骨！今又欲离间吾儿的知遇，拆散刘备的肱骨，曹操哇曹操！你乃名 教之罪人，衣冠之禽兽也！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "刘备本是英雄将， 义气仁义著四方。 吾儿辅他如臂膀， 英明之主遇贤良。 尔本曹嵩来抱养， 夏侯族中弃儿郎。 明在朝中为宰相， 内怀篡逆乱朝纲。 许田射猎欺主上， 无故迁都赴许昌。 借刀杀人祢衡丧， 可叹吉平刑下亡。 带剑常把宫闱闯， 勒死贵妃实可伤。 尔比当年贼王莽， 尔比董卓更猖狂。 无故差人我家往， 诓骗老身来许昌。 欲使我儿归你掌， 除非是日起在西方！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "我本堂堂朝中相， 恶言恶语将我伤。 相府如同虎口样， 你命若悬丝敢逞强！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "听他言来气上撞， 大骂曹操听端详： 老身既来不思往， 休拿虎口吓老娘！ 我有心替主除奸党， 手中缺少刀与枪。 文房四宝桌上放， 击死奸贼赴无常。 这砚台就是你对头样， 送你一命见阎王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母用砚台打曹操。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "反了哇反了！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "人来与我上了绑， 推出斩首在云阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "胆大的恶妇，竟敢用砚击打老夫？武士手，推出斩了！"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士押徐母同下。程昱上。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "听说徐母上了绑， 程昱慌忙上二堂。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相因何要斩徐母？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这恶妇进得帐来，百般辱骂，又用砚台击打老夫。故尔将她斩首。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "如今正当用人之际，斩了徐母，恐与丞相不利。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "徐母触犯丞相，正欲求死，以全名节。若果杀之，丞相落不义之名，反成徐母 之德。况徐母既死，徐庶必然尽心竭力帮助玄德，借报杀母之恨。卑人愚见， 不如赦了徐母，留在我营，使徐庶心悬两地，纵然帮助刘备，断不能尽心竭力 也！"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "丞相将她来斩首， 不义名儿天下留。 徐庶本是经纶手， 借帮刘备报冤仇。 赦却徐母休放走， 卑人自有巧机谋。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相赦回徐母，养之别室。昱自有妙计，将徐庶赚来，以辅丞相。不知丞相意 下如何？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生有何妙计？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "卑人自称与徐庶有八拜之交，日往徐母住处问候，待将她笔迹套出，仿其字体， 诈修家书一封，差一心腹之人，持书前往新野，投递单福。那徐庶乃大孝之 人，见了家书，必然星夜前来。丞相得一谋臣，何惜赦一徐母？望丞相思之！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生之言，正合老夫之意。 来，将徐母赦回！"
        },
        {
          "character": "曹洪、许褚、张郃、夏侯惇、夏侯渊、于禁、乐进、曹仁",
          "type": "同白",
          "text": "将徐母赦回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "欲借曹贼帐下刀， 使我半世美名标。 忽然堂上传赦诏， 倒叫老身心内焦。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹贼！要斩开刀，为何又将老身解下？真正岂有此理！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "非是某不斩于你，程先生言道，他与你子有八拜之交，斩你如斩他母。故尔赦 回。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "啊，程先生，你好多事啊！"
        },
        {
          "character": "徐母",
          "type": "唱",
          "text": "先生只顾将我保， 吾儿在新野住不牢。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母！"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "侄与元直曾交好， 怎忍伯母吃一刀！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "程先生，将徐老太太安置别室，小心侍奉。哪个如敢轻慢，军法从事！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "遵命。 伯母请！"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "唉，儿呀！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母来呀，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱、徐母同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "只爱单福才似锦，且将怒恼忍心头。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "真真的岂有此理！咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}