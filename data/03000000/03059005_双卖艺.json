{
  "script_id": "03059005",
  "title": "双卖艺",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "花逢春",
      "hangdang": "武生"
    },
    {
      "name": "萧桂英",
      "hangdang": "旦"
    },
    {
      "name": "阮三",
      "hangdang": "丑"
    },
    {
      "name": "李俊",
      "hangdang": "老生"
    },
    {
      "name": "倪荣",
      "hangdang": "净"
    }
  ],
  "plot": "宋江受招安后，被蔡京、童贯药酒毒害，众兄弟四散逃亡。梁山后裔花逢春，流落江湖，卖艺平王镇，值萧\n桂英杀家后，亦卖艺来此，遇李俊、倪荣、阮三，夫妻得团圆。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李俊、倪荣同上。"
        },
        {
          "character": "李俊",
          "type": "念",
          "text": "忆昔水泊显英豪，如今隐居在蓬蒿。"
        },
        {
          "character": "倪荣",
          "type": "念",
          "text": "名标不及埋名好，可叹英雄无下梢。"
        },
        {
          "character": "李俊、倪荣",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "混江龙李俊。"
        },
        {
          "character": "倪荣",
          "type": "白",
          "text": "卷毛虎倪荣。"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "倪荣",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "想昔日在梁山，众英雄除暴安良，名扬天下。谁知宋大哥一念之差，受了天子 荣封。讨平三寇有功，宋王见喜，赐下御酒贺功，被蔡京、童贯换了药酒，毒 害英雄。可怜众弟兄亡其大半，我等逃散四方，一些后世儿女未知存亡。追思 前仇未报，咳，好不闷煞人！"
        },
        {
          "character": "倪荣",
          "type": "白",
          "text": "大哥，此乃以往之事，提他作甚！只好访觅一些小英雄，齐聚兴师，再报前仇 便了！"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "言得极是。看天气晴和，同去游玩一回，聊解愁闷。"
        },
        {
          "character": "倪荣",
          "type": "白",
          "text": "小弟奉陪。"
        },
        {
          "character": "李俊、倪荣",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "李俊",
          "type": "唱",
          "text": "禹开九州汤伐桀， 秦吞六国汉登基。"
        },
        {
          "character": "倪荣",
          "type": "唱",
          "text": "古来多少英雄将， 南北山丘卧土泥。"
        },
        {
          "character": "李俊、倪荣",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李俊、倪荣同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花逢春上。"
        },
        {
          "character": "花逢春",
          "type": "念",
          "text": "隐姓埋名困英雄，只恨时乖运未通。何日才展平生志，再造山河上九重。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "俺、花逢春。我父花荣，征讨方腊有功，圣上恩赐太平宴，被蔡京、童贯换了 药酒，将我父毒死。是俺埋名隐姓，逃往江湖，每日卖艺为生，来此已是平王 镇，好一所大镇也！ 啊列位请了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四百姓同上。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "请了，请了！哪里来了个卖艺的，请把刀枪演来，我等领教。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "俺乃远方人氏，路过贵镇，不能登门拜访，耍几路拳棒，当场作礼。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "请教！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三上。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "众位弟兄们，为什么这等热闹？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "阮三爷，来了个卖艺的。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "待我看来。 小兄弟，你是个卖艺的？"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "愚下前来出丑。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "好，不管什么武艺，你拿出点来，我们看看。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "待俺耍拳如何？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "你就打几路看看。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "得罪了！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "请教！"
        },
        {
          "character": "花逢春",
          "type": "唱",
          "text": "太祖红拳出关东， 惯走江湖称英雄。 上打黄龙来出顶， 下打凤凰展翅腾。 一来一往多英勇， 董家桥前逞威风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春打拳。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "好拳，好拳。我们来拿钱。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "慢点儿，慢点儿。这样的拳也给钱，你们要是看见了好拳，你们还不给银子呀？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "还有哪个高过他的？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "你们说没人高过他，我们赵二哥的拳就能高过他。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "你有什么赵二哥？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "赵匡胤二哥。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "他是前辈的帝王，怎么是你的赵二哥？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "他是耍拳棒的人，我也是耍拳棒的人。常言道：斯文同骨肉。我们英雄也同骨 肉，拉扯起来，我们是兄弟。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "不要多讲，我们是要给钱的。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "慢点儿。他拳打广东，脚踢广西，在五虎打董家桥，那才是拳哪！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "错了。他拳打关东，脚踢关西，在董家桥打五虎，那才是拳。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "不错，那才是拳。 这位小兄弟还有什么武艺再拿点儿出来我们看看。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "还有枪。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "你有枪？你枪起来！"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "得罪了！"
        },
        {
          "character": "花逢春",
          "type": "唱",
          "text": "此枪名曰梅花枪， 出手三枪谁敢当。 今日落在豪杰手， 平王镇上耍几行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春耍枪。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "好枪，好枪。我们来给钱。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "慢点儿，慢点儿。你们有多少钱花不了，这个枪也给钱！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "还有哪个的枪，高过了他？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "说起来又有一人。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "哪一人？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "昔日赵子龙，手使一杆枪，在曹营杀退百万雄兵，那才是枪。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "你只在此讲今比古，你可会？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "我也会。我要玩起来，他就要领教。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "那位壮士拿枪过来。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "接枪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春掷枪，阮三接枪。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "呀，这是铁的，戳个洞是你赔还是我赔？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三耍枪。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "你们看看，这几下可好？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "好。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "好的还在后头哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三耍枪。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "看这锁喉三枪可好？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "好。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "啊小兄弟，我问你，你是初出门，还是久出门？"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "初出门怎样，久出门又便怎样？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "常言道，一方一个人，一方一位神。到了我们这儿难道就不知道我阮三爷的大 名吗。到我家拜望拜望，我不送一千，也送你八百。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "老者有钱无钱原是小事，为何这等唠唠叨叨！"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "这也罢啦，想你来到此地，把场子一摆，就应开口说话。说道公门中先生，武 营中的将爷，四路的好汉：我在这儿卖武，玩得好你们也不要喝采，玩得不好 你们也不要见笑。自古道，光棍光棍，到处帮衬。城墙高万丈，内外要人扶， 牡丹虽好，还要绿叶扶持。你把这些盘子一开，谁人不来花几文钱？照你这样 走江湖，只好走夜壶！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "阮三爷，这是什么话。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "老者为何这等唠唠叨叨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春挥手不耐。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "啊，你在我面前动手动脚的，敢是要打两下吗？"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "领教！"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "说得好。我走啦！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "啊！阮三爷，你走啦？我们这地方上丢了人，他要说大话的。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "他说领教，怕了我，我还不走？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "领教是要与你会会。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "他怕了我，也就是啦。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "你走了，岂不使我们这个地方丢了人？是要打的。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "要打的？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "要打的。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "咳，不见棺材不掉泪，不见黄河不死心。那一位，来吧来吧！"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春、阮三同起打，花逢春打阮三跌。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "这不算，要照门路来。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "要照门路来。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "我的衣服长了，脱了衣服，再来打！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "脱了衣服再来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三脱衣。花逢春、阮三同打。李俊、倪荣同上。"
        },
        {
          "character": "李俊、倪荣",
          "type": "同白",
          "text": "不要动手，放下来！"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "二位叔父，侄儿拜揖。"
        },
        {
          "character": "李俊、倪荣",
          "type": "同白",
          "text": "罢了。这就是你阮三叔，向前见礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李俊、倪荣同向阮三。"
        },
        {
          "character": "李俊、倪荣",
          "type": "同白",
          "text": "这是花逢春侄儿。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "哪个？他就是花逢春侄儿，真乃好武艺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春、阮三同见礼。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "侄男不知，叔父休怪。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "这才是：拳头无眼睛，单打自己人。一同转到我家吃饭去。"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "李俊",
          "type": "念",
          "text": "世间多是陌路人，"
        },
        {
          "character": "倪荣",
          "type": "念",
          "text": "如今相逢两相称。"
        },
        {
          "character": "花逢春",
          "type": "念",
          "text": "千里迢迢投知己，"
        },
        {
          "character": "阮三",
          "type": "念",
          "text": "转到我家去安身。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "李俊、倪荣、花逢春",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "萧桂英",
          "type": "内西皮导板",
          "text": "自幼儿同父江湖走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧桂英、桂英弟背枪刀棒锏同上。"
        },
        {
          "character": "萧桂英",
          "type": "唱",
          "text": "只为渔税起祸由。 杀了贼子私逃走， 可叹我父一命丢。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "奴家、萧桂英，乃三江人氏。爹爹萧恩，每日打渔营生。只因恶霸丁子夑催讨 渔税，爹爹与他廝闹一场，送到官衙责打四十。爹爹一怒，身带短刀将他杀死， 不想被官兵拿下，秋后就要处决。可恨官府还要锁拿家属，是奴一闻此言， 带了二弟埋名隐姓，逃出在外，每日卖艺为生。一路行来，此地已是平王镇。 真好一所大镇也！ 二弟，将场子摆开！"
        },
        {
          "character": "桂英弟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "桂英弟敲锣。"
        },
        {
          "character": "桂英弟",
          "type": "念",
          "text": "锣儿敲得叮当响，五湖四海把名扬。"
        },
        {
          "character": "萧桂英",
          "type": "念",
          "text": "前汉后汉我不讲，单说唐宋英雄将。"
        },
        {
          "character": "桂英弟",
          "type": "念",
          "text": "罗成夜打登州府，秦琼三挡潼关闯。"
        },
        {
          "character": "萧桂英",
          "type": "念",
          "text": "飞虎山前收存孝，惯使铁镐王彦章。"
        },
        {
          "character": "桂英弟",
          "type": "念",
          "text": "马上斩将杨宗保，镇守三关杨六郎。"
        },
        {
          "character": "萧桂英、桂英弟",
          "type": "同白",
          "text": "我们是三江人氏，去往下江投亲，路过贵镇，在此卖艺，求助银两。"
        },
        {
          "character": "桂英弟",
          "type": "念",
          "text": "会者请勿当面识破，"
        },
        {
          "character": "萧桂英",
          "type": "念",
          "text": "知者请勿嘻笑扬扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四百姓同上。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "那里又来了一个卖武的，大家前去看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三上。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "众位兄弟们，前面为什么这样热闹？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "阮三爷，又来了一个卖武的。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "啊，又来了一个卖武的，待我去看看。 啊，那位女子，哪儿来的，往哪儿去的？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "苏州来的，往杭州去。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "清水货。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "怎么是清水货？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "下江出绸缎，所以说是清水货。 那一位姑娘，你可是卖武的？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "卖武的。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "啊姑娘，你是卖武的，这可说得明白？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "说得明白。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "哪样当先？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "雁翎刀。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "刀，你就刀起来咱们看看。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "献丑了！"
        },
        {
          "character": "萧桂英",
          "type": "唱",
          "text": "此刀名曰雁翎刀， 昔日圣贤保刘朝。 宝刀落在奴家手， 耍刀九路逞英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧桂英耍刀。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "好刀，好刀。我们来给钱。"
        },
        {
          "character": "桂英弟、萧桂英",
          "type": "同白",
          "text": "多谢，多谢。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "慢点儿，慢点儿。这个刀也要钱？"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "还有哪个的刀，胜似她的？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "昔日关爷，过六关，斩五将，过黄河斩蔡阳，到古城劈秦琪，弟兄相会，古城 团圆，那才是刀。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "错了，错了。昔日关爷，过五关斩六将，过黄河劈秦琪，在古城斩蔡阳，后来 古城相会，弟兄团圆。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "不错，不错。弟兄相会，夫妻团圆。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "我们来给钱。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "不用给钱。 啊姑娘，还有什么武艺，拿出来我们再瞧瞧！"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "还有双锏。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "还有双锏？你就锏起来。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "得罪了！"
        },
        {
          "character": "萧桂英",
          "type": "唱",
          "text": "山东有个秦叔宝， 全凭双锏逞英豪。 昔日历城为快手， 后来忠心保唐朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧桂英耍锏。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "好锏，好锏。我们给钱。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "你们简直没有见过好锏，她学也没有学得全，这也叫好！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "你只说她的不好，不知还有哪个高似她的？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "我们秦二哥就高似她的。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "我且问你，秦琼出在哪一朝？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "出在汉朝。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "错了，错了。出在唐朝。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "唐三千，宋八百。我也记不得许多！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "我们给钱。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "不用给钱，我去说她几句。 啊姑娘，你是初走江湖，还是久走江湖？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "初走江湖怎么说，久走江湖又怎么讲？"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "初走江湖也就罢了。若是久走江湖，你的眼睛就不亮，来到我们这儿，就没听 见人说我阮三爷的威名。到这儿拜望拜望，多少不也要送你几十串钱。你不拜 望我，就在此地卖武，像你这样的武艺，也要卖钱？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "不知你的贵处。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "啊，你骂我，不知我的龟处。反啦，反啦，我阮三爷也不晓得会过多少江湖好 汉，都要叫我一声阮三爷。你骂我不知道我的龟处，你虽是个卖武的，能晓得 几下武艺？引得我的火气上冒，只怕要打你几下！"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "来吧！"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "早有这句话，我也不动气啦。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "阮三爷，她说的是来吧！"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "我走啦！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "来吧，是要与你比试。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "要打？她怕了我也就是啦，不打啦！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "阮三爷，你怕了她了！"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "不是怕她，她是个女流之辈，我是个男子汉。常言道：男不和女斗，刀不与斧 斗，还是不打啦！"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "阮三爷，她夸了大话去了。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "啊，她夸了大话，管他娘的！咱们打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三欲打。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "阮三爷衣服长了。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "脱了衣服打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三脱衣。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "来打啊！"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "领教！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧桂英、阮三同起打，阮三被打倒。"
        },
        {
          "character": "阮三",
          "type": "白",
          "text": "哎呀好打呀，好打，我去叫我侄儿去。你可别走，你要走了，就是个王八羔子。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阮三下。"
        },
        {
          "character": "四百姓",
          "type": "同白",
          "text": "那一女子，阮三爷去了，还不快走！"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "列位，奴家既在此卖艺，难道怕人不成？ 二弟，收了场子，待俺赶上前去。"
        },
        {
          "character": "桂英弟",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
