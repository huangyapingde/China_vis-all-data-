        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "圣旨下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戚继光、莫怀古、傅氏、莫豪、莫文禄同上。"
        },
        {
          "character": "陆炳",
