          "type": "二黄原板",
          "text": "你好比贤孟姜全节自尽， 你好比徐夫人手刃仇人。"
        },
        {
          "character": "莫怀古",
          "type": "二黄原板",
          "text": "凄凉凉只落得香消玉殒， 悲切切一霎时容逝音沉。"
        },
        {
          "character": "莫豪",
          "type": "二黄原板",
          "text": "二爹娘少悲伤保重要紧， 她虽死落一个彤管标名。"
        },
        {
          "character": "莫怀古",
          "type": "二黄原板",
          "text": "但愿得你真魂早登仙境，"
        },
        {
          "character": "戚继光",
          "type": "二黄原板",
          "text": "天色晚仁兄嫂请驾回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引陆炳捧圣旨同上。"
        },
        {
          "character": "陆炳",
          "type": "白",
          "text": "老夫、陆炳。奉了圣旨，前去蓟州赐封莫怀古等。 左右，趱行者！"
        },
        {
          "character": "四文堂",
