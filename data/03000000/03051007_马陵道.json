        {
          "character": "孙操、张奢、廉颇、白起、黄歇",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "场设城。〖吹打〗。四上手、四大铠、田忌同上，同出城。"
        },
        {
          "character": "田忌",
          "type": "白",
          "text": "列公驾至，特来奉迎！"
        },
        {
          "character": "朱亥、孙操、张奢、廉颇、白起、黄歇",
          "type": "同白",
          "text": "岂敢！"
        },
        {
          "character": null,
