      ]
    },
    {
      "scene_id": 21,
      "name": "第二十一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖吹打〗。摆台。袁达、苏夫人、卜商、田文、田忌、苏代同上，孙操、张奢、廉颇、白起、黄歇、朱亥"
        },
        {
          "character": null,
          "type": "text",
          "text": "同上。）"
        },
        {
          "character": "田忌",
          "type": "白",
          "text": "安排接驾！"
        },
        {
          "character": "齐威王",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖出队子〗。四太监、大太监、齐威王同上。"
        },
        {
          "character": "齐威王",
          "type": "白",
          "text": "先生在世，也曾与各国分忧，今不幸身故，敢劳列位功勋前来奠祭！"
        },
        {
          "character": "朱亥、孙操、张奢、廉颇、白起、黄歇",
          "type": "同白",
          "text": "臣等皆奉主命，应当叩祭！"
        },
        {
          "character": "齐威王",
          "type": "白",
          "text": "寡人先行奠礼，然后六国次序进吊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。齐威王换衣。"
        },
        {
          "character": "齐威王",
          "type": "念",
          "text": "挂印三年国免忧，仗卿谋略压王侯。何日再见名贤面，永佐江山到白头。"
        },
        {
          "character": "齐威王",
          "type": "唱",
          "text": "金门峻险蚊螭畏， 玉殿峥嵘虎豹愁。 架海金梁何处访？ 擎天玉柱等闲休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "白起",
          "type": "白",
          "text": "孙先生，某，秦国白起，奉旨奠祭，挽诗一首："
        },
        {
          "character": "白起",
          "type": "念",
          "text": "结义投师已数年，为国失义起烽烟。齐邦战斗皆因汝，魏国争杀为庞涓。"
        },
        {
          "character": "白起",
          "type": "唱",
          "text": "战马含冤埋野地， 征人饮恨丧黄泉。 休兵敛甲今朝始， 中国京剧戏考 《马陵道》【七本】 13 各保江山过几年。"
        },
        {
          "character": "黄歇",
          "type": "白",
          "text": "孙先生，某，楚国黄歇，奉旨祭奠，挽诗一首："
        },
        {
          "character": "黄歇",
          "type": "念",
          "text": "楚国君臣慕大贤，欲求辅弼恨无缘。今朝神位归天后，不见龙争虎斗年。"
        },
        {
          "character": "黄歇",
          "type": "唱",
          "text": "名闻海宇犹山重， 袖遁乾坤不世传。 不料风霜凋玉树， 却将遁甲秘黄泉。"
        },
        {
          "character": "廉颇",
          "type": "白",
          "text": "指望先生为孩儿报断腰之仇，不意先生早升天界，廉颇不幸也！"
        },
        {
          "character": "廉颇",
          "type": "念",
          "text": "燕国生贤士，齐国得巨臣。结交逢逆贼，刖足遇奸人。"
        },
        {
          "character": "廉颇",
          "type": "唱",
          "text": "只望积怨常谋战， 恩义成仇永不亲。 可叹六国俱没祸， 但愿英俊早为神。"
        },
        {
          "character": "张奢",
          "type": "白",
          "text": "孙先生，某，韩国张奢，奉旨奠祭，只望先生替韩主娘娘报仇，不意早升仙界， 奉献挽诗一首："
        },
        {
          "character": "张奢",
          "type": "念",
          "text": "午夜长星坠，贤人值此灾。韩国魏阳死，齐邦孙膑埋。"
        },
        {
          "character": "张奢",
          "type": "唱",
          "text": "重兴干戈何日定， 满天云雾几时开。 谁来解救生民危， 哪见清平得遂怀！"
        },
        {
          "character": "孙操",
          "type": "白",
          "text": "三郎！孙膑哪！汝生颖异，死必为神。我是汝父孙操，奉燕王之命，特来祭奠， 挽诗一首："
        },
        {
          "character": "孙操",
          "type": "念",
          "text": "父子睽违已数年，谁知天意丧英贤。齐邦失却干城将，燕国分离父母缘。"
        },
        {
          "character": "孙操",
          "type": "唱",
          "text": "父苦亲儿儿寿夭， 母悲爱子子身捐。 晓钟凉月思儿处， 不见亲儿涕泪涟。"
        },
        {
          "character": "朱亥",
          "type": "白",
          "text": "孙先生，下官，魏国朱亥，奉主之命，特来祭奠，挽诗呈奠："
        },
        {
          "character": "朱亥",
          "type": "念",
          "text": "神通天地产英贤，何事先生寿不全？侥幸奸邪常在世，忠诚正直丧黄泉。"
        },
        {
          "character": "朱亥",
          "type": "唱",
          "text": "齐邦失却擎天柱， 列国难留鲁仲连。 我已幸叨知己辈， 唯将束帛献灵前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "齐威王",
          "type": "白",
          "text": "袁达，与你师父情同父子，免朝三年，送葬归土，孤另有旌奖。"
        },
        {
          "character": "袁达",
          "type": "白",
          "text": "谢主隆恩！"
        },
        {
          "character": "齐威王",
          "type": "白",
          "text": "有劳众位设祭，回朝多拜汝主，孤容日面谢！"
        },
        {
          "character": "孙操、张奢、廉颇、白起、黄歇、朱亥",
          "type": "同白",
          "text": "臣等还要送葬入土！"
        },
        {
          "character": "齐威王",
          "type": "白",
          "text": "不敢劳动了！朱大夫来路甚远，请回去吧！"
        },
        {
          "character": "朱亥",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "朱亥",
          "type": "念",
          "text": "两意正期驱猛兽，一灵何事驾飞鸾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱亥下。"
        },
        {
          "character": "齐威王",
          "type": "白",
          "text": "列位将军，朱亥已去，孤有一言重叙：孙先生死后，庞涓必定起兵征战，倘若 伐秦，共同助秦。若是伐楚，共同助楚。六国联合，同心协力，不可失信！ 中国京剧戏考 《马陵道》【七本】 14"
        },
        {
          "character": "孙操、张奢、廉颇、白起、黄歇",
          "type": "同白",
          "text": "大王高见极是，臣等敢不协力相助！"
        },
        {
          "character": "齐威王",
          "type": "白",
          "text": "田忌、田文，命光禄寺排宴于金亭馆，与诸公饯饮！"
        },
        {
          "character": "孙操、张奢、廉颇、白起、黄歇",
          "type": "同白",
          "text": "谢大王隆恩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
