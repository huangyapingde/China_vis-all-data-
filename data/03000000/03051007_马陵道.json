{
  "script_id": "03051007",
  "title": "马陵道",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "孙膑",
      "hangdang": "老生"
    },
    {
      "name": "庞涓",
      "hangdang": "净"
    },
    {
      "name": "袁达",
      "hangdang": "净"
    }
  ],
  "plot": "孟尝君田文奉旨送彩缎、锦帛、山羊御酒到营犒军，见孙膑病重，乃问解救之法，孙膑告以遣人往宜梁城中，\n将草人盗回烧化，病可立愈。孟尝君因门客冯驩能驾云，使入宜梁，盗来草人，当面焚化，孙膑果立愈。\n孙膑攻城急，魏王惧，修表求和，献上避尘珠。齐王见降表与避尘珠，乃许和，令孙膑班师回朝。路经韩国，\n见昭王为王妃治丧，孙膑前往祭之，韩昭王甚喜。临行，孙膑赠韩王柬帖一封，嘱于危急时拆之。孙膑回\n朝，欲诱庞涓伐齐，乃诈死。齐王闻讯，率文武前来祭奠。燕、韩、赵、秦、楚各国俱遣使前来吊唁。齐王\n恐庞涓乘机伐齐，约各国相助。各国使臣均允共拒庞涓。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、田文同上。"
        },
        {
          "character": "田文",
          "type": "念",
          "text": "权衡贯斗牛，列臣匡锦绣。丹心留千古，荫垂永不休。"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "本御，孟尝君田文。孙先生统兵伐魏，多受辛苦，我主特命本御解送金银缎帛， 山羊御酒，庆贺先生。 军士们！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。庞涓上，拜。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "孙膑哪孙膑！不想你也有今日也！"
        },
        {
          "character": "庞涓",
          "type": "唱",
          "text": "下山先摆三才阵， 把我庞涓不在心。 仗着你六甲灵文天书透， 定咽七箭丧残生。 谁敢轻犯宜梁境？ 祸福无门你自来寻！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞涓射箭，下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "田忌扶孙膑同上。"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "如痴如醉昏不醒， 只怪我亵渎天书冒犯天神。 宜梁受满千日难， 吾师解罪施再生。 刖足之仇未得报， 魇镇奇术目不明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鬼魂上，箭射孙膑右眼，下。"
        },
        {
          "character": "孙膑",
          "type": "stage",
          "text": "中国京剧戏考 《马陵道》【七本】 2"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "右目疼痛实难忍，"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "空在阳世等时辰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、田文同上。"
        },
        {
          "character": "田文",
          "type": "念",
          "text": "忽闻惊天事，特来问安宁。"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "啊孙先生，本御奉旨解送彩缎锦帛，山羊御酒，特来贺功。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "田忌",
          "type": "白",
          "text": "御弟，孟尝君特来看你。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "殿下来了！"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "钦赐山羊御酒，与先生贺功。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "千岁！千岁！啊，殿下在哪里？ 请坐！"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "先生，飞来祸殃，可知来历？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "那庞涓暗使魇魔之法，用定咽七箭书，七日之内取我性命！"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "今日几天？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "今已两天，还有五日在生了！"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "先生惯习天书灵文，岂无解救之法？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "解救虽有，要一腾云之人。"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "腾云之人，先生帐下无有么？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "俱是凡夫，哪有腾云之人！"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "腾云之人有何用处？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "高架云头，去到庞涓后花园，将定咽七箭书盗来，即能生也。"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "驾席云之人可以去得么？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "驾席云？去得。但不知高矮如何？"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "本御帐下有一人，姓冯名驩，会驾席云，但不知髙矮。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "现在何处？"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "来，唤冯驩前来！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "冯驩进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯驩上。"
        },
        {
          "character": "冯驩",
          "type": "念",
          "text": "自恨不得志，低头且相依。"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "千岁在上，冯驩叩头！"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "上面是孙先生！"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "元帅在上，冯骧叩头。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "你叫冯驩？"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "殿下方才道你会驾席云？"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "小人习学多年，未尝用过。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "云头高起多少？"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "三十余丈。"
        },
        {
          "character": "田忌",
          "type": "白",
          "text": "去得去不得？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "去得。"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "先生，他既去得，就请发令差遣。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "今夜三更之时，高驾席云，去到庞涓后花园，内有草人一个、法书—本。将草 人眼中之箭拔出，将灯点明，所有用物，尽行烧毁。只将法书盗来，在我眼前 烧化，双目自明。不可泄露！"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "田忌",
          "type": "白",
          "text": "后营饱餐战饭。"
        },
        {
          "character": "冯驩",
          "type": "念",
          "text": "数年未吐凌霞气，今日足踏登云梯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯驩下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "二位殿下，吩咐紧守营寨！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "殿下幕养奇烈士， 今日登天第一名。 中国京剧戏考 《马陵道》【七本】 3 谋事在人件件就， 只恐天错事不成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑、田忌、田文同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。冯驩上。"
        },
        {
          "character": "冯驩",
          "type": "念",
          "text": "少游江湖访俊英，炼就异术风送云。庞涓不解从空手，要救擎天柱一根。"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "俺，冯驩，乃楚国人氏。流落于齐，蒙殿下孟尝君幕养数年。俺自幼学得小小 的法儿，未有进献。今日国师孙元帅遭魇魔之术，命在旦夕。多感恩主举荐， 高驾席云，盗出法书，返本回原。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "冯骥",
          "type": "白",
          "text": "谯楼二鼓，就此走遭也！"
        },
        {
          "character": "冯骥",
          "type": "醉花阴",
          "text": "貔貅帐夜更鼓发， 幸得恩主举荐咱。 俺今日大展云霄， 且做个紫棼飞霞。 早来到宜城脚下。"
        },
        {
          "character": "冯骥",
          "type": "白",
          "text": "来此已是城下，待俺驾云上去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二兵卒同上。"
        },
        {
          "character": "二兵卒",
          "type": "同白",
          "text": "看着，瞧着点儿！"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "看那守城军好不厉害，哪知俺冯驩另有妙术！"
        },
        {
          "character": "冯驩",
          "type": "水龙吟",
          "text": "月影西斜， 念咒与作法， 他两人异姓相投，云梦山下。 同师学道，魏庞涓昧心藏奸诈， 他刖足负义，千秋恁唾骂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯驩上席云，进城，下。二兵卒暗同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。庞涓上。"
        },
        {
          "character": "庞涓",
          "type": "水龙吟又一体",
          "text": "忧心常挂， 怕的是有错差， 暗取他三魂七魄，谁来救拔？ 枉学六甲，天书灵文作虚话。 七日内主灯不放光， 方信宝无价。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞涓下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。冯驩上。"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "来此已是花园，果有草人在此。孙先生之言，一些不差，俺照计而行！"
        },
        {
          "character": "冯驩",
          "type": "水龙吟",
          "text": "人声静哑， 怎知俺从天来坠下。 且将这灯光照明，眼箭儿拔，耳箭儿拉， 再将这草人儿烧化。 定咽书怀藏魇魔法， 依将席云跨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。冯驩下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《马陵道》【七本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑、田忌、田文同上。"
        },
        {
          "character": "孙膑",
          "type": "水龙吟又一体",
          "text": "天崩地塌， 众士卒谁不惊讶？ 急声声梆锡震耳，更鼓儿煞，拼敕勒加， 冯驩一去不回家。 怕的是机关儿泄露， 反被贼人拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯驩上。"
        },
        {
          "character": "冯骧",
          "type": "白",
          "text": "冯驩交令。"
        },
        {
          "character": "田文",
          "type": "白",
          "text": "可曾成功？"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "草人烧化，定咽书呈上！"
        },
        {
          "character": "田忌、田文",
          "type": "同白",
          "text": "快快取火过来！"
        },
        {
          "character": "孙膑",
          "type": "尾声",
          "text": "叹庞涓巧计用奸诈， 天罗地网去寻瓜。 且将恁美名留， 留传在凌烟阁下！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "哈哈哈……多谢二位殿下费心！冯驩暂授飞虎骁骑，圣上钦赐本帅山羊酒缎， 尽行赏汝。本营领旗参队，庆功三日。"
        },
        {
          "character": "冯驩",
          "type": "白",
          "text": "叩谢元帅！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "袁达，吩咐众军：饱食战饭，高架云梯，攻打宜梁！"
        },
        {
          "character": "袁达",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁达下。"
        },
        {
          "character": "田忌、田文",
          "type": "同念",
          "text": "但愿男儿多才艺，"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "可叹王侯不幕英。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田忌、田文、孙膑同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、魏惠王同上。"
        },
        {
          "character": "魏惠王",
          "type": "念",
          "text": "定咽七箭干戈静，驸马真是扶国勋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞涓上。"
        },
        {
          "character": "庞涓",
          "type": "念",
          "text": "丈夫由命不由人，今日庞涓不再生。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "臣该万死！昨夜四更时分，不知何人轻入花园，将定咽书盗去，草人用物，尽 行烧毁！"
        },
        {
          "character": "魏惠王",
          "type": "白",
          "text": "是尔自不小心，岂是栋梁之才？若不念用兵之际，立斩汝首！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "孙膑高架云梯，攻城甚急！"
        },
        {
          "character": "魏惠王",
          "type": "白",
          "text": "晓谕各门：严加防守。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "魏惠王",
          "type": "白",
          "text": "驸马，看看孤城不保，计将安出？"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "臣启千岁：今日这刀兵都是主公自招其祸！"
        },
        {
          "character": "魏惠王",
          "type": "白",
          "text": "怎么是孤家惹来的刀兵？"
        },
        {
          "character": "庞涓",
