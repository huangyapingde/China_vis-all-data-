          "character": "孙膑",
          "type": "白",
          "text": "叫袁达在府效劳三年。"
        },
        {
          "character": "苏夫人",
          "type": "白",
          "text": "须要叫他当面说过。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "来，唤袁达进内堂伺候。"
        },
        {
          "character": "院子",
          "type": "白",
