{
  "script_id": "03090005",
  "title": "天水关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "姜维",
      "hangdang": "净"
    },
    {
      "name": "刘禅",
      "hangdang": "小生"
    }
  ],
  "plot": "诸葛亮攻取天水关，魏国守将马遵不敢出战，高悬免战牌。遵部将姜维请令出城迎战，击败蜀将赵云。诸葛\n亮深爱姜维之才，乃命魏延假扮姜维至关前，扬言已降蜀军。马遵于黑夜中不辨真假，果中计，大骂姜维。\n俟姜维至，闭门不纳。姜维进退无路，而降蜀。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "刘禅",
          "type": "念",
          "text": "三国纷纷屡战争，昼夜杀砍马不停。文凭相父安天下，武凭皇叔定乾坤。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "小王，刘禅。国号建兴在位。自登基以来，风调雨顺，国泰民安。今当早朝。 内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "展放龙门！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨。 展放龙门哪！"
        },
        {
          "character": "诸葛亮",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "带砺山河，掌丝纶，运筹帷幄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣，诸葛亮见驾。我主万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "相父平身。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "相父手捧何物？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣有出师表章，请我主龙目御览。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "唔呼呀！才得干戈宁静，相父又要领兵扫灭中原，叫孤心何忍！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄慢三眼板",
          "text": "先帝爷白帝城龙归海境， 传口诏命老臣常挂在心。 叫老臣保我主社稷重整， 命老臣把孙、曹一扫平。 臣上本并非为别事议论， 望我主准本章臣好发兵。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "老相父上条陈孤心难忍， 你本是先帝爷托孤老臣。 待等到明早朝文武议论， 待等到明日里长亭饯行。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "食君禄报主恩忠心秉正， 臣怎敢劳我主长亭饯行！"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "内侍臣摆銮驾——"
        },
        {
          "character": "刘禅",
          "type": "二黄摇板",
          "text": "后宫来进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同下。"
        },
        {
          "character": "刘禅",
          "type": "二黄摇板",
          "text": "老相父回府去调动三军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、刘禅自两边分下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "魏延、马岱、关兴、张苞同上。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "大将生来盖世雄，"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "万马营中逞威风。"
        },
        {
          "character": "关兴",
          "type": "念",
          "text": "耀武扬威英雄将，"
        },
        {
          "character": "张苞",
          "type": "念",
          "text": "斩将夺旗立大功。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "魏延。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "关兴。"
        },
        {
          "character": "张苞",
          "type": "白",
          "text": "张苞。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "列位将军请了！"
        },
        {
          "character": "马岱、关兴、张苞",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "丞相发兵，在此伺候！"
        },
        {
          "character": "马岱、关兴、张苞",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、赵云同上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "白发苍苍似银条，东战孙权北灭曹。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "参见老将军！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "圣驾到此，速报我知。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "圣驾到！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "一同接驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四太监、大太监、诸葛亮、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "手挽手与相父长亭来进，"
        },
        {
          "character": "赵云、魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "臣等见驾！"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "众将官一个个杀气腾腾。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "看香案！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监同摆香案。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "内侍臣看香案当中供定， 待小王祭过了旗纛尊神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅跪，诸葛亮、赵云、魏延、马岱、关兴、张苞同随跪。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "但愿得此一去旗开得胜， 但愿得此一去马到功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅起，诸葛亮、赵云、魏延、马岱、关兴、张苞同随起。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲斟酒。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "内侍臣看过了皇封御饮， 我与相父来饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅递酒与诸葛亮，诸葛亮接。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "我主爷赐为臣皇封御饮， 背转身谢过了旗纛尊神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮以酒祭天地。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲斟酒。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "四皇叔近前来孤王赐饮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅递酒与赵云，赵云接。"
        },
        {
          "character": "刘禅",
          "type": "二簧原板",
          "text": "但愿得把狼烟一扫而平。"
        },
        {
          "character": "赵云",
          "type": "二黄原板",
          "text": "臣年迈仗我主洪福天定， 臣怎敢劳我主长亭饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云以酒祭天地。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "我朝中有二臣忠心秉正， 蒋公琰、费文伟二大贤臣。 主临朝大小事和他们议论， 常言道军国事依理而行！"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "老相父奏的事——"
        },
        {
          "character": "刘禅",
          "type": "二黄摇板",
          "text": "孤当从命，"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "臣择就午时后就要发兵。"
        },
        {
          "character": "刘禅",
          "type": "二黄摇板",
          "text": "御林军摆銮驾皇城来进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同下。"
        },
        {
          "character": "刘禅",
          "type": "二黄摇板",
          "text": "得胜回孤迎接十里长亭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅下。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "传将令众三军齐跨金镫， 文武官齐免送响炮拔营！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "赵云、魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "兵出祁山！"
        },
        {
          "character": "赵云、魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、马遵同上。"
        },
        {
          "character": "马遵",
          "type": "念",
          "text": "镇守天水关，儿郎心胆寒！"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "韩德父子五人落马！"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "免战高悬！"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "啊！ 免战高悬！"
        },
        {
          "character": "姜维",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维上。"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "一颗明珠土内藏，数载未曾放豪光！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "某，姓姜名维字伯约。正在后帐观看兵书，忽听太守免战高悬，不免进帐问个 明白。 报，姜维告进！太守在上，末将参见！"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "将军少礼。请坐！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "无令进帐何事？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "太守为何免战高悬？"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "只因韩德父子五人落马，故而免战高悬。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "太守赐某一支人马，生擒赵云进帐！"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "将军有此胆量？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "有此胆量！"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "如此，姜维听令！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "命你大战赵云，不得有误！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "马遵",
          "type": "念",
          "text": "令出山摇动，"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "言发鬼神惊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、马遵同下。四绿龙套同上。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "站立两厢，听某令下！"
        },
        {
          "character": "四绿龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "姜维",
          "type": "西皮导板",
          "text": "姜伯约在校场忙传令号，"
        },
        {
          "character": "姜维",
          "type": "西皮原板",
          "text": "叫一声众三军细听根苗： 刘玄德坐西川人称有道， 全凭着五虎将立下功劳。 他二弟关美髯谁人不晓， 他三弟张翼德喝断了当阳桥。 西凉将小马超英雄年少， 还有个老黄忠惯使大刀。 这一班五虎将——"
        },
        {
          "character": "姜维",
          "type": "西皮快板",
          "text": "俱已丧了， 只剩下赵子龙老迈年高。 刘阿斗坐西川年纪幼小， 有关兴和张苞哪在心梢。 三军与爷带马战场到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维上马，四绿龙套同下。"
        },
        {
          "character": "姜维",
          "type": "西皮散板",
          "text": "擒子龙灭孔明就在今朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮快板",
          "text": "韩德父子打败仗， 不由老夫喜洋洋。 催马来在战场上， 那旁来了送死郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维上。"
        },
        {
          "character": "姜维",
          "type": "西皮摇板",
