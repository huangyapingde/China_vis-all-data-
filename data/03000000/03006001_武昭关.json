{
  "script_id": "03006001",
  "title": "武昭关",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "国太",
      "hangdang": "旦"
    }
  ],
  "plot": "楚平王无道，纳媳逐子。伍员保护马昭仪与幼主逃出，困居禅宇寺；追兵甚急，伍员护主拒敌势难兼顾。马\n昭仪因将幼子付托与伍员，投井自杀。伍员抱幼主突围而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、卞庄同上。"
        },
        {
          "character": "卞庄",
          "type": "白",
          "text": "某、卞庄。奉了平王之命，捉拿伍子胥。 众将官，起兵前往！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上，起霸。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "拜将封侯印，盖世保乾坤。扶保平王主，四路扫烟尘。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺，姓伍名员字子胥，乃楚国监利人也。可恨平王无道，父纳子妻为妾。那时 怒恼某家，保定皇家四口，我就杀——杀出重围。似淤泥挡住轮车，沙滩围困 蛟龙。"
        },
        {
          "character": "伍员",
          "type": "叫头",
          "text": "天哪，天！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺伍员好似一轮明月又被浮云遮。"
        },
        {
          "character": "伍员",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "耳边厢又听得人马呐喊，想是卞庄追兵甚紧，不免请出国太龙驾登程。 臣有请国太！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "国太上。"
        },
        {
          "character": "国太",
          "type": "念",
          "text": "泪似湘江水，点点不断流。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "臣伍员见驾，国太、幼主千岁！"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "卿家将哀家请了出来，为了何事？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "卞庄追兵甚紧，请国太龙驾登程！"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "如此将军带马！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "臣领旨！"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "马昭仪上龙驹珠泪滚滚， 骂一声狗奸贼卖国的奸臣。 楚平王坐江山朝纲不正， 把一个亲生子赶出了午门。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "耳边厢又听得人马喊， 想是卞庄发来兵。 眼望着松林一寺院， 请国太下马躲贼兵。"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "兵困禅宇……"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "马后悲！ 君臣们被困在重围。 葵花树上拴战马， 虎头银枪插土堆。 将身儿来站在廊檐内， 且听国太发纶徽。"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "楚兵纷纷扎了队， 君臣逃命好不伤悲。 将军快把雄兵退， 救我母子出重围。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "子胥向前本奏启， 尊声国太听端的： 那卞庄好似得胜的猫儿强似虎， 为臣似虎落平川被犬欺。 幼主爷龙困沙滩难翻转， 龙国太背时凤凰不如鸡。 臣要保只保小千岁， 难保国太杀出重围。"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "将军你呢！"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "斗宝曾在临潼会， 万马营中逞雄威。 保皇家四口丧两口， 不怨将军怨着谁。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "子胥闻说忙屈膝，"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "谢国太。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "尊声国太驾听知： 龙国太今年三十二， 为臣的四十少二春。 知道的自说臣保主， 不知者反说臣的……"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "哽！"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "一个“妻”字未出唇， 国太面上怒气生。 子胥若有欺天意， 苍天岂容我伍员。"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "被他一言来提醒， 提醒南柯梦里人。 将军暂退廊檐下， 容我母子暗思忖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "独坐在大佛殿自思自恨， 怀抱着年幼儿大放悲声。 恨只恨儿祖父纲常丧尽， 父纳了子的妻败坏人伦。 连累了儿的父东逃西奔， 连累了伍将军丧胆游魂。 到如今母子们无方寄命， 奔天涯走地角凄凄惨惨无处安身。 回头便把将军请，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "后面来了保驾臣。 迈步且把禅堂进， 国太快快设计行！"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "人言子胥是好将， 今日果然不虚名。 太子付与将军抱，"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "扬尘舞蹈接王身。 解开甲胄藏幼主， 辞别国太便登程。 手拿金枪踏金蹬，"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "将军请转。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "国太有话快说明！"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "不当将军保太子， 直当将军你自己生。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "国太不必细叮咛， 君是君来臣是臣。 国太快把良谋定， 放我君臣早逃生。"
        },
        {
          "character": "国太",
          "type": "唱",
          "text": "苍天降下无情剑， 斩断母子两离分。 将身跳在葵花井！"
        },
        {
          "character": "国太",
          "type": "白",
          "text": "将军，那旁有人来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "国太跳井，下。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "一见国太丧了命， 子胥倒做不忠臣。 推倒土墙忙掩井，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卞庄上，卞庄、伍员同开打，伍员败下。四龙套同上。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "那贼大败！"
        },
        {
          "character": "卞庄",
          "type": "白",
          "text": "紧紧追赶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员换白髯口上。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "杀败了，杀败了！"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "子胥离家有数年，不报冤仇誓不还。解开甲胄观幼主，"
        },
        {
          "character": "伍员",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "一夜髯白过昭关。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唗！卞庄休赶，伍老爷去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}