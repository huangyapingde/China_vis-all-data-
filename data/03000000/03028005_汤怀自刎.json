{
  "script_id": "03028005",
  "title": "汤怀自刎",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "汤怀",
      "hangdang": "武生"
    },
    {
      "name": "岳飞",
      "hangdang": "老生"
    },
    {
      "name": "金兀术",
      "hangdang": "净"
    }
  ],
  "plot": "状元张久成，奉命赴金邦探望徽、钦二帝。岳飞麾下大将汤怀领命护送，沿途杀金邦二平章。及见金兀术，\n许言放行，绑走状元，逼令汤怀投降。汤怀寡不敌众，连劈二平章，最后自刎。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "汤怀",
          "type": "内白",
          "text": "军士们，趱行者！"
        },
        {
          "character": "四军士",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士押粮车同上，汤怀上。"
        },
        {
          "character": "汤怀",
          "type": "西皮散板",
          "text": "帐中领了元帅令，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同挖门。"
        },
        {
          "character": "汤怀",
          "type": "西皮散板",
          "text": "押运粮草走一程。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "俺，汤怀。宋王驾前为臣。奉了元帅将令，催押粮草，朱仙镇交纳。 军士们！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "汤怀",
          "type": "西皮快板",
          "text": "坐至在雕鞍把话论， 大小三军听分明： 食王爵禄当把忠尽， 报效国家舍死忘生； 两军阵，动刀兵， 纵死阵前也有名。 三军与爷往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士押粮车同下。"
        },
        {
          "character": "汤怀",
          "type": "西皮散板",
          "text": "扫灭金人方称心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军同上，站门。岳飞上。"
        },
        {
          "character": "岳飞",
          "type": "引子",
          "text": "一点忠心，保我主，锦绣华夷。"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "旌旗日月高三丈，兀术领兵犯边疆。黎明涂炭有日尽，迎接二圣转还乡。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅，姓岳名飞字鹏举。宋室为臣。可恨兀术屡进中原，侵犯我国疆界，人马 扎在朱仙镇。我命汤怀押运粮草，未见到来。"
        },
        {
          "character": "汤怀",
          "type": "内白",
          "text": "回营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士引汤怀同上，四军士接马同下。汤怀进帐。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "罢了。我命你催押粮草，怎么样了？"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "粮草催齐，元帅查点。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "不必查点。将军下面歇息。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "谢元帅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀下。"
        },
        {
          "character": "张久成",
          "type": "内白",
          "text": "状元到。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张久成上。岳飞出帐迎接，同入帐分宾主坐。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "不知状元公到此，未曾远迎，当面恕罪！"
        },
        {
          "character": "张久成",
          "type": "白",
          "text": "岂敢！下官来得鲁莽，元帅海涵！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "岂敢！状元公今日到此，必有所为？"
        },
        {
          "character": "张久成",
          "type": "白",
          "text": "是我奉了万岁之命，去到北国探望二圣，请元帅差派一将，保护前往。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "请状元公下面歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军领张久成同下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "升帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军暗上，岳飞入大座。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "中军听令！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "传我将令：满营将官，若有胆壮之人，保定状元公张久成去到北国探望二圣， 当帐请令！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军出帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "下面听者：元帅有令，我营将官，哪位将军愿保定状元公张久成去往北国探望 二圣，当帐请令！"
        },
        {
          "character": "汤怀",
          "type": "内白",
          "text": "汤怀愿往！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "随令进帐！"
        },
        {
          "character": "汤怀",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀上。"
        },
        {
          "character": "汤怀",
          "type": "西皮快板",
          "text": "将令一出如山倒， 帐下儿郎杀气高。 文官出朝武将保， 无有能将走这遭。 我只得进帐把令讨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀进帐。"
        },
        {
          "character": "汤怀",
          "type": "西皮散板",
          "text": "见元帅打一躬细说根苗。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "将军免礼！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "谢元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "方才调将，可是将军愿往？"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "小弟不才，愿保状元公前去北国探望二圣。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "想北国人马，犹如潮水一般，不可轻视。还望将军三思！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "想小弟跟随元帅出兵多年，南征北剿，东挡西杀，渴饮刀头血，倦在马上眠， 日日受劳苦，夜夜受熬煎。大丈夫生在世上，生而何欢，死而何惧也！"
        },
        {
          "character": "汤怀",
          "type": "西皮快板",
          "text": "汤怀宝帐把话表， 尊声元帅听根苗： 生而何欢死而何足道， 纵然一死万古美名标。 不让我把状元保， 碰死帐前在今朝。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "岳飞",
          "type": "西皮散板",
          "text": "将军可算胆量好， 真算将中一英豪。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "贤弟既要前去，汤怀听令！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "校场准备战马，不得有误！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "准备酒宴，校场去者！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞下，四龙套、中军随下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵、撒里金、撒里银、六平章同上，同站门。金兀术上。"
        },
        {
          "character": "金兀术",
          "type": "点绛唇",
          "text": "将士英豪，儿郎虎豹，军威浩，地动山摇，要把狼烟扫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金兀术上高台。"
        },
        {
          "character": "金兀术",
          "type": "念",
          "text": "忆昔当年反宋朝，南征北战费心劳。早把中原一起扫，万里江山归我朝。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "孤，大金邦四太子、昌平王、完颜宗弼、皇号兀术。是孤奉了父王之命，屡进 中原，夺取宋室天下。人马扎在朱仙镇。我命探马打探，未见到来。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "岳飞人马离我营不远！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "大平章撒里金听令！"
        },
        {
          "character": "撒里金",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "命你带领人马，抵挡头阵！"
        },
        {
          "character": "撒里金",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "撒里金下。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "二平章撒里银听令！"
        },
        {
          "character": "撒里银",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "命你二路截杀！"
        },
        {
          "character": "撒里银",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "撒里银下。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "巴图鲁！"
        },
        {
          "character": "六平章",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "随孤迎敌者！"
        },
        {
          "character": "六平章",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵与金兀术递权，四番兵、六平章引金兀术同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "汤怀抱枪拉马上。"
        },
        {
          "character": "汤怀",
          "type": "念",
          "text": "要学堂堂奇男子，须立人间稀有功。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "奉了元帅之命，准备战马，保定状元探望二圣。 看，远远望见，元帅大兵来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军同上，同挖门。张久成、岳飞同上，同下马。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "战马可曾备齐？"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "俱以备齐。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "看酒伺候！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "岳飞",
          "type": "二黄导板",
          "text": "食君禄报王恩忠心秉正，"
        },
        {
          "character": "岳飞",
          "type": "回龙",
          "text": "为国家秉忠心报效朝廷。"
        },
        {
          "character": "岳飞",
          "type": "二黄原板",
          "text": "叫人来看过就一樽， 我与状元来饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞递酒。"
        },
        {
          "character": "张久成",
          "type": "二黄原板",
          "text": "用手接过酒一樽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张久成接酒敬天地。"
        },
        {
          "character": "张久成",
          "type": "二黄原板",
          "text": "怎敢劳元帅来饯行！"
        },
        {
          "character": "岳飞",
          "type": "二黄原板",
          "text": "人来看过酒二樽， 我与贤弟来饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞递酒。"
        },
        {
          "character": "汤怀",
          "type": "二黄原板",
          "text": "用手儿接过酒一樽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀接酒敬天地。"
        },
        {
          "character": "汤怀",
          "type": "二黄原板",
          "text": "小弟言来听分明： 弟兄们结拜在汤阴， 枪挑梁王谁不闻？ 此一番保状元把五国城进， 番贼闻名谁不担惊！ 此一番保状元无有伤损， 凌烟阁上万古留名。 此一番小弟我若是丧命， 望求那岳大哥，朱仙镇上领大兵、杀进番营与小弟我大报冤恨！"
        },
        {
          "character": "岳飞",
          "type": "二黄原板",
          "text": "叫贤弟你把那宽心放定， 此一番进番营须要小心。"
        },
        {
          "character": "汤怀",
          "type": "二黄原板",
          "text": "说不尽衷肠话足跨金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀与张久成带马，张久成上马，下。汤怀持枪上马，岳飞拉汤怀枪哭。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "贤弟呀！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "大哥呀！"
        },
        {
          "character": "汤怀",
          "type": "二黄摇板",
          "text": "再与那岳大哥细说分明： 倘若是小弟丧了命， 望求那岳大哥把冤伸！"
        },
        {
          "character": "岳飞",
          "type": "二黄摇板",
          "text": "弟兄们只哭得心酸痛！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "大哥！"
        },
        {
          "character": "岳飞、汤怀",
          "type": "同白",
          "text": "（贤弟）（大哥）呀！"
        },
        {
          "character": "岳飞",
          "type": "二黄摇板",
          "text": "贤弟你要放宽心。"
        },
        {
          "character": "汤怀",
          "type": "二黄摇板",
          "text": "辞别了岳大哥足踏金镫， 闯龙潭入虎穴奔走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀下。"
        },
        {
          "character": "岳飞",
          "type": "二黄摇板",
          "text": "本帅大事安排定，"
