        {
          "character": "金兀术",
          "type": "白",
          "text": "呔！你是何人，马踏孤营？通上名来！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "听者！我乃岳元帅帐下汤怀是也！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "哦！岳飞帐下有一员大将汤怀，就是你么？"
