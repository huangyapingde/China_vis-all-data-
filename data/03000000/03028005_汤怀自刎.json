        {
          "character": "岳飞",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同带马，岳飞上马，四龙套、中军倒卷帘同下。"
        },
        {
          "character": "岳飞",
          "type": "二黄摇板",
          "text": "但愿得贤弟早回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞下。"
        }
      ]
