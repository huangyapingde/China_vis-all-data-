        {
          "character": "汤怀",
          "type": "白",
          "text": "久闻狼主乃是大仁大义，就该放我二人过去。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "哪有不放之理。那状元公何在？"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "现在身后。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "叫他见过孤家，就放你二人过去。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "多谢狼主！ 状元公，向前见过狼主，我二人一同过去。"
        },
        {
          "character": "张久成",
          "type": "白",
          "text": "参见狼主！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "免礼。请状元先行！"
        },
        {
          "character": "张久成",
          "type": "白",
          "text": "多谢狼主！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张久成三打马进营。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "巴图鲁，绑了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵同绑张久成。汤怀一冲、两冲、三冲，六平章同拦，四番兵押张久成同下。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "兀术！为何将状元绑走？"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "汤将军，身为大将，知进知退，方为俊杰。劝你归顺孤家，免得一死！"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "兀术！作出此事，人面兽心，恨不能食尔之肉，喝尔之血，挖尔之心，碎尔之 骨，方消我心头之恨！看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀打，金兀术以权封上下。金兀术下，六平章、汤怀接打七股荡同下。"
        }
      ]
