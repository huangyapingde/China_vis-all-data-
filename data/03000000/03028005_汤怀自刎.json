      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四番兵同上，同站门。撒里银上，过场，众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "汤怀拉张久成马同上。"
        },
        {
          "character": "张久成",
          "type": "二黄摇板",
          "text": "枪挑番奴丧了命，"
        },
        {
          "character": "汤怀",
          "type": "二黄摇板",
          "text": "状元公不必胆怕惊。 二人一同番营进！ （汤怀、张久成同跑圆场。撒里银追上，刀砍张久成，汤怀回身枪刺撒里银，张久成上高台。汤怀、撒里银 打双刀枪。汤怀打撒里银抢背，撒里银起，用刀砍汤怀，汤怀背后抽枪刺死撒里银。）"
        },
        {
          "character": "汤怀",
          "type": "二黄摇板",
          "text": "大胆的小番奴前来逞能！ 拉定了状元公番营来进， 看看尔等还有何能？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀、张久成同下。"
        }
      ]
