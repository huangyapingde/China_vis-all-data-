        },
        {
          "character": "杨滚",
          "type": "西皮散板",
          "text": "有人再提为父老， 准备项上吃一刀！ 怀亮杀开千条道， 父子们杀一个浪里蛟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚、高怀亮同下。"
        }
