{
  "script_id": "03006007",
  "title": "锤换带",
  "alias": [
    "汜水关"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "杨滚",
      "hangdang": "净"
    },
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "高怀亮",
      "hangdang": "小生"
    },
    {
      "name": "杨继业",
      "hangdang": "小生"
    }
  ],
  "plot": "后汉时，老将杨滚与赵匡胤作战，杨滚之义子高怀亮父子均在赵营，杨滚命其归宗；中途被崔子建劫杀，高\n怀亮用杨家梅花枪法取胜。崔子建奏知汉帝，降罪于杨滚；杨滚率部追捕高怀亮。高怀亮投营辩诬。杨滚反\n借交战之际，将全部枪法尽行传授。嗣赵匡胤亲战杨滚，被杨滚锤击落马。杨滚不忍伤害，并愿助成帝业。\n赵匡胤许以封王，当时解紫金带作为信物。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠、杨继慷、杨继慨、杨继业引杨滚同上。"
        },
        {
          "character": "杨滚",
          "type": "点绛唇",
          "text": "威风飘荡，年迈刚强，列刀枪，捉拿怀亮，功成转还乡。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "家住磁州在火塘，祖先铜锤保刘王。心中恼恨杨怀亮，不该临阵使花枪。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "老夫、杨滚。刘主驾前为臣，官居火山王。日前命怀亮去高平关认姓归宗，谁 知这奴才在两军阵前使出我杨家的梅花枪法。可恨崔龙上殿启奏一本，道老夫 有卖国之心。圣上恼怒，将我推出问斩；多亏满朝文武保奏，才得活命。因此 全身披挂，捉拿怀亮进京问罪。 众家儿郎！"
        },
        {
          "character": "杨继慷、杨继慨、杨继业",
          "type": "同白",
          "text": "爹爹！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "杨继慷、杨继慨、杨继业",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "兵发高平关！"
        },
        {
          "character": "杨继慷、杨继慨、杨继业",
          "type": "同白",
          "text": "众将官，兵发高平关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上。〖牌子〗。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "俺、怀亮。奉爹爹之命，去往高平，认姓归宗，行至半路之中，偶遇崔子建， 将俺杀得大败。是俺想起杨家梅花枪法，将他杀退。不免回营，爹爹面前请罪 便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠引杨滚同上。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "兵扎高平关，捉拿无义男。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "孩儿叩头。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿是怀亮？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "是怀亮。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "奴才！"
        },
        {
          "character": "杨滚",
          "type": "二黄摇板",
          "text": "骂声奴才太猖狂， 儿不该临阵使花枪。 不是为父的功劳大， 险些一命丧无常。 叫人来与爷推出斩！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "冤枉！"
        },
        {
          "character": "四白大铠",
          "type": "同白",
          "text": "口喊冤枉。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "放回。"
        },
        {
          "character": "杨滚",
          "type": "二黄摇板",
          "text": "放转奴才问端详。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿还有何话讲？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "啊哈，爹爹，孩儿奉命去往高平，认姓归宗，偶遇崔龙，将孩儿杀得大败啊！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "呸！那崔子建有多大本领，难道儿就战他不过！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "啊哈，爹爹，那贼人马犹如潮水一般，孩儿杀前不能顾后，杀左不能顾右。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿身为大将，杀前不能顾后，杀左不能顾右，在两军阵前，就该使我杨家的花……"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "枪啊！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "着，着，着！"
        },
        {
          "character": "高怀亮",
          "type": "二黄摇板",
          "text": "不是花枪来抵挡， 险些一命丧无常。"
        },
        {
          "character": "杨滚",
          "type": "二黄摇板",
          "text": "听罢言来问其详， 险些错把爱子伤。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "崔龙贼，老夫回朝，岂肯与你干休！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮哭。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "我儿不要啼哭，为父命你三位兄长，每人让你一阵，助儿成功，出帐去罢！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "谢爹爹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "来，传三位少爷进帐。"
        },
        {
          "character": "四白文堂",
          "type": "同白",
          "text": "请三位少爷进帐。"
        },
        {
          "character": "杨继慷、杨继慨、杨继业",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继慷、杨继慨、杨继业同上。"
        },
        {
          "character": "杨继慷、杨继慨、杨继业",
          "type": "同念",
          "text": "辕门战鼓声平，想是干戈宁靖。"
        },
        {
          "character": "杨继慷、杨继慨、杨继业",
          "type": "同白",
          "text": "参见爹爹！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "杨继慷、杨继慨、杨继业",
          "type": "同白",
          "text": "四弟进营，讲些什么？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "你四弟进得营来，为父问其情由，乃是崔龙之过，不与你四弟相干。为父命你 弟兄三人，每人让他一阵，助他成功。出帐去罢！"
        },
        {
          "character": "杨继慷、杨继慨",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继慷、杨继慨同下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "继业，难道儿就不遵父命么？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这个……得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨继慷上。"
        },
        {
          "character": "杨继慷",
          "type": "白",
          "text": "俺、杨继慷。奉爹爹将令，前去让四弟一阵。就此前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "大哥敢是前来让阵？"
        },
        {
          "character": "杨继慷",
          "type": "白",
          "text": "奉爹爹之命，让你一阵。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "有劳大哥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继慷、高怀亮同杀，杨继慷败下。杨继慨上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "二哥敢是让小弟一阵？"
        },
        {
          "character": "杨继慨",
          "type": "白",
          "text": "奉爹爹将令，前来让你一阵。须要小心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继慨、高怀亮同杀，杨继慨败下。杨继业上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "三哥敢是前来让阵？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "两军阵前，谁肯让谁？看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、高怀亮同杀，杨继业败下。高怀亮追下。杨继业急上。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "且住！看怀亮杀法厉害，这便怎么处？有了，俺不免用铜锤击破护心镜，在爹 爹面前，搬动是非便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上，杨继业下。高怀亮追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白大铠、四白文堂引杨滚同上。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "啊，为父命你让你四弟一阵，为何这等模样？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "爹爹，孩儿奉了爹爹将令，让我四弟一阵。谁知他不肯相让，提枪就刺，不是 护心镜挡住，险遭不测啊！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "为父不信。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "爹爹不信，请看！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "退下。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "怀亮啊，奴才！你好生无理。为父好意命你三位兄长，每人让你一阵，助尔成 功。谁知你这奴才不念手足之义，提枪就刺，若不是护心镜挡住，险遭不测。 也罢！你无有手足之义，为父哪有父子之情。 众将官，抬枪带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂同下。高怀亮上，杀过合。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "奴才，为父好意命你三位兄长，每人让你一阵，助你成功；谁知你不念手足之 义，提枪就刺，若不是护心镜挡住，险遭不测。也罢，儿无有手足之义，为父 哪有父子之情。上得马来，与为父见三两个回合。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "哎呀，爹爹！大哥、二哥俱已让孩儿一阵；惟有三哥不肯相让，自己用铜锤击 破护心镜，要害孩儿一死。话已说明，爹爹要杀请杀。"
        },
        {
          "character": "高怀亮",
          "type": "二黄摇板",
          "text": "他自己击破护心镜， 要害孩儿命残生。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "杨滚",
          "type": "二黄原板",
          "text": "听罢言来查其情， 险些错伤小姣生。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "继业啊，奴才！尔想在为父眼前搬动是非，要害你四弟一死，那就万万不能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮哭。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "我儿不要啼哭，上得马来，与为父假战三合，也好回营交令。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "爹爹！自盘古以来，哪有父子交战之理？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "着哇！倒是这冤家言得极是。自盘古以来，哪有父子交战之理？ 也罢，儿啊，杨家花枪，儿可全记？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "孩儿不能全记。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "好，上得马来，待为父教导于你。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "多谢爹爹。"
        },
        {
          "character": "杨滚",
          "type": "西皮导板",
          "text": "叫三军与爷战鼓起，"
        },
        {
          "character": "杨滚",
          "type": "西皮原板",
          "text": "大睁虎目观端的。 高怀亮打扮世无比， 赛得过临潼伍子胥， 赛韦驮缺少降魔杵， 赛吕布缺少画杆戟。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "杨滚",
          "type": "西皮快板",
          "text": "为父命里该四子， 惟有冤家我心喜。 杨家花枪教与你， 只要儿眼尖手快躲得疾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚、高怀亮同开打。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿吓！这一枪杀得好，照为父这厢来！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "随我来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚、高怀亮同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、高怀德同上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "号炮连天震，"
        },
        {
          "character": "高怀德",
          "type": "念",
          "text": "干戈何日宁？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "御妹夫，哪里人马呐喊？你我高坡一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚、高怀亮同上。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿啊，这一枪儿可知道？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "孩儿不知。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "此乃是杨家五马落地梅花点钢枪，在两军阵前，取上将的咽喉，全凭此枪。儿 不要在你三哥面上使用，牢牢谨记。上马去罢！"
        },
        {
          "character": "高怀亮",
