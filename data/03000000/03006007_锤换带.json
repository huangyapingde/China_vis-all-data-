    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "孤王闷坐中军帐， 探马不住报端详。 五王七侯打败仗， 一个个败阵回营房。 催马来在阵头上， 又见老将到战场。"
        },
        {
          "character": "杨滚",
          "type": "内西皮导板",
          "text": "连杀四营无敌将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚上。"
        },
        {
          "character": "杨滚",
          "type": "西皮快板",
          "text": "不知昏王在哪厢？ 阵前闪出一员将， 他的打扮非寻常。 头戴金盔明珠亮， 五绺胡须飘胸膛； 打扮好似关公样， 缺少关平和周仓。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "杨滚",
          "type": "西皮快板",
          "text": "在哪里会过这员将？ 阵前难坏火山王。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "啊，是了！"
        },
        {
          "character": "杨滚",
          "type": "西皮快板",
          "text": "曾记得当年保刘王， 认得冤家赵玄郎。 尔是玄郎是不是？ 通上名来在某的刀下亡。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "勒住丝缰把他望， 老将打扮非寻常。 头戴银盔明珠亮， 身穿铠甲似雪霜， 跨下一骑白龙马， 手中钢刀放毫光。 在哪里会过这员将？ 阵前难坏赵玄郎。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，是了！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "记得当年刺刘王， 认得老儿火山王。 午门之外打一仗， 慌不慌来忙不忙。 若不是老将开恩放， 十个玄郎死五双。 你若问我的名和姓， 少游关西赵玄郎。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        },
        {
          "character": "杨滚",
          "type": "西皮摇板",
          "text": "听说来的赵匡胤， 杨滚打马随后跟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚下。赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "粉红马驼的赵匡胤，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚上。"
        },
        {
          "character": "杨滚",
          "type": "西皮摇板",
          "text": "白龙马驼的老寿星。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮摇板",
          "text": "铜金刚遇着铁罗汉，"
        },
        {
          "character": "杨滚",
          "type": "西皮摇板",
          "text": "冤家遇着对头人。 按住宝刀用锤打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙形上。"
        },
        {
          "character": "杨滚",
          "type": "西皮快板",
          "text": "火光照得两眼花。 人说赵家有天下， 莫非应在这冤家？ 翻身离镫下了马，"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "老了！"
        },
        {
          "character": "杨滚",
          "type": "西皮快板",
          "text": "老杨滚屈膝降顺他。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "铜锤打下如雷炸，"
        },
        {
          "character": "赵匡胤",
          "type": "西皮快板",
          "text": "打得孤王膀背麻。 猛然睁开昏花眼，"
