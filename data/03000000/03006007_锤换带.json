        {
          "character": "赵匡胤",
          "type": "白",
          "text": "御妹夫，看老将一枪将你兄弟挑下马来。吩咐五王七侯，大战老将。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、赵匡胤同下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！五王七侯讨战！"
