{
  "script_id": "03091001",
  "title": "功臣泪",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "文种",
      "hangdang": "老生"
    },
    {
      "name": "勾践",
      "hangdang": "净"
    }
  ],
  "plot": "越王勾践灭吴后，范蠡引退，并致书文种，劝其亦辞官他去。文种不听，并劝勾践封赏灭吴功臣，被勾践当\n殿指责。文种托病不朝。勾践探文种之病，以剑遗府内，意令其自裁，文种遂自刎死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "文种上。"
        },
        {
          "character": "文种",
          "type": "引子",
          "text": "相国怀去志，教人费愁思。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "老夫、上大夫文种。我与相国范蠡，共扶越王，报仇复国。实想回朝以后，同 享安乐，不料他起意告老，大王再三挽留，执意不从，究竟是何居心，好教我 莫名其故。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "差人持书上。"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "门上哪位在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子出门。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "范相国有书信到来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "少候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子进门。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "禀爷：范相国差人送书到来。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "叫他里边来见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子出门。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "叫你里边去见。"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "如此，有劳了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "差人随院子同进门。"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "参见上大夫！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "免了。"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "我家相爷送来书札一封，请上大夫收阅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种接书。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "你家相爷，可曾在府？"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "我家相爷，出外未归，不知现到何处。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "书信收下，你且回去。"
        },
        {
          "character": "差人",
          "type": "白",
          "text": "是。小人告退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "差人下。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "范相国有书到来，待我拆书一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种拆书看。"
        },
        {
          "character": "文种",
          "type": "二黄原板",
          "text": "打开了书札用目望， 字字行行看端详： 上写着大王回国不行赏， 昧功忌贤毒暗藏。 长颈鸟喙奸雄样， 安乐患难两分张。 劝兄及早脱罗网， 自古道飞鸟尽良弓藏，敌国破谋臣亡，再莫留恋身受祸殃。 我今一去五湖上， 还要兄台你仔细思量！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "哦，我当是所为何事，原来是相国挂冠出走，劝我及早脱离大王，以免后患。 我想大王，乃是英明仁义之主，万万做不出这等负义背恩之事。我不免明日早 朝，奏与大王便了！"
        },
        {
          "character": "文种",
          "type": "二黄摇板",
          "text": "说什么行赏不行赏， 为臣表功理不当。 但等明早金殿上， 见了大王奏端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种、院子同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "文种、计倪、诸稽郢、曳庸同上。"
        },
        {
          "character": "文种",
          "type": "念",
          "text": "脱去戎装换锦袍，"
        },
        {
          "character": "计倪",
          "type": "念",
          "text": "心机费尽枉徒劳。"
        },
        {
          "character": "诸稽郢",
          "type": "念",
          "text": "二十年前大仇报，"
        },
        {
          "character": "曳庸",
          "type": "念",
          "text": "汗马功劳一旦抛。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "老夫、上大夫文种。"
        },
        {
          "character": "计倪",
          "type": "白",
          "text": "大将军计倪。"
        },
        {
          "character": "诸稽郢",
          "type": "白",
          "text": "中大夫诸稽郢。"
        },
        {
          "character": "曳庸",
          "type": "白",
          "text": "下大夫曳庸。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "众位请了！"
        },
        {
          "character": "计倪、诸稽郢、曳庸",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "今日乃是大王得胜回国早朝吉日，你我在此恭候！"
        },
        {
          "character": "计倪、诸稽郢、曳庸",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、勾践同上。"
        },
        {
          "character": "勾践",
          "type": "引子",
          "text": "独霸东方，展雄威，拓土开疆。"
        },
        {
          "character": "勾践",
          "type": "念",
          "text": "孤王生来志气高，对头冤家是吴朝。十年生聚十年教，今日才得把恨消。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "孤、越王勾践。带领人马，伐吴复仇，幸喜吴国灭亡，夫差身死，周天子封孤 为东方之伯。今乃班师回朝升殿吉日。 众卿，有事出班启奏！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "启奏大王：相国范蠡，弃家远离，不知去向。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "呜呼呀！孤王灭吴报仇，全赖相国，幸喜得有今日，孤王正想报他的大功，不 料他执意引退。文大夫，快请将他追回！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "启奏大王：相国既然不知去向，想是去志已决，况且相国平日有鬼神不测的机 算，老臣纵然去追，只怕寻他不得。依臣所见，不如让他去了就是。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "咳，文大夫！"
        },
        {
          "character": "勾践",
          "type": "二黄原板",
          "text": "范相国保孤二十秋， 苦心焦虑报吴仇。 今日执意离朝走， 怎不教孤挂心头！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "相国既然决心去了，就依上大夫所奏，不必追寻。唤取巧匠，照范相国模样， 铸个金人，香灯供养，表孤记念之意罢了！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "启奏大王：臣闻治国大计，首在赏罚分明。伐吴起兵时节，大王曾降谕旨，得 胜还朝，不论文武大小官员，一齐论功行赏。现在吴国已灭，百官朝贺，大王 就该实践前旨，一律颁赏才是。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "呔，大夫说话，好生冒昧！孤王二十年来，卧薪尝胆，受尽千辛万苦，报仇复 国，得有今日。慢说满朝大小群臣，就是孤王，也不过是应尽职分，却论的什 么功劳！你今金殿争功，莫非想要平分孤王的国土不成？"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "老臣不敢。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "哼……打量你也不敢！要你说与文武群臣，从今以后，再不要争论功劳，孤王 自有发落！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "遵旨！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "内侍，退朝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "文种上。"
        },
        {
          "character": "文种",
          "type": "二黄原板",
          "text": "回府来不由我心中纳闷， 大王爷果然是忌妒贤能。 金殿上悔不该出言失忖， 众文武他到来再把话云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "众位大人到！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请众位大人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "计倪、诸稽郢、曳庸同上，文种岀迎。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "众位大人到来，老夫未能远迎，多多得罪。"
        },
        {
          "character": "计倪、诸稽郢、曳庸",
          "type": "同白",
          "text": "岂敢！上大夫，适才金殿以上，观大王面带骄横，欺侮群臣，把这灭吴的功劳， 全归他一人之手，这便怎处？"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "众位大人高见？"
        },
        {
          "character": "曳庸",
          "type": "白",
          "text": "像这忘恩负义的君王，保他做甚！依下官看来，不如反了就是！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "且慢！大王纵然忘恩负义，但你我身为臣子，宁使他不仁，莫教我不义。此事 万万做不得！"
        },
        {
          "character": "诸稽郢",
          "type": "白",
          "text": "依末将之见，到了明天，众大臣一齐上殿，请大王查明功劳大小，即刻行赏如 何？"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "大人，你看金殿以上，那大王早露出不肯行赏之意，倘若大家再去奏求，惹恼 大王，如何是好？"
        },
        {
          "character": "计倪",
          "type": "白",
          "text": "众位大人！既然大王妒忌群臣，不如挂冠封印，各自四散去吧！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "大人之言，倒还有理。众大人以为如何？"
        },
        {
          "character": "计倪、诸稽郢、曳庸",
          "type": "同白",
          "text": "就依大夫所言，各自四散了吧！我们就此告辞！"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "奉送！"
        },
        {
          "character": "计倪",
          "type": "二黄摇板",
          "text": "大王做事理不周，"
        },
        {
          "character": "诸稽郢",
          "type": "二黄摇板",
          "text": "挂冠封印莫停留。"
        },
        {
          "character": "曳庸",
          "type": "二黄摇板",
          "text": "辞别大夫出府走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "计倪、诸稽郢、曳庸同下，文种揖送。"
        },
        {
          "character": "文种",
          "type": "二黄摇板",
          "text": "回转身来自思筹。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "他们既然四散，老夫只有闭门谢客，称病不朝了！ 家院！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "文种",
          "type": "白",
          "text": "有人问我，就说老夫有病在身，不能出门。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文种、院子同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、勾践、王妃同上。"
        },
        {
          "character": "勾践",
          "type": "念",
          "text": "二十年来仇恨消，"
        },
        {
          "character": "王妃",
          "type": "念",
          "text": "民安国泰在今朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "勾践、王妃同坐，大太监上。"
        },
        {
          "character": "大太",
          "type": "白",
          "text": "监启奏大王：大将计倪、曳庸等，连同许多文武大臣，疯魔的疯魔，离朝的离 朝，大半挂冠封印，不知去向！"
        },
        {
          "character": "王妃",
          "type": "白",
          "text": "大王，他们这是为何？"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "他们一般逆臣，仗凭各人的功劳，想要平分孤的国土，未如他们的心意，他们 便一同去了。难道说无有他们，孤王的江山就保不住了么！且宣文大夫进宫， 再作计较。 内侍，宣文大夫进宫！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！ 上大夫文种进宫朝驾！"
        },
        {
          "character": "院子",
          "type": "内白",
          "text": "文大夫身得重病，不能进宫。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏大王：文大夫身得重病，不能朝驾。"
        },
        {
          "character": "勾践哼",
          "type": "白",
          "text": "哼！他也病了！宣掌殿官庞须弥进宫！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨！ 掌殿官庞须弥进宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞须弥上。"
        },
        {
          "character": "庞须弥",
          "type": "念",
          "text": "忽听得大王宣召，进宫去细问分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞须弥进见。"
        },
        {
          "character": "庞须弥",
          "type": "白",
          "text": "臣、掌殿官庞须弥见驾，大王万岁！娘娘千岁！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "庞须弥",
          "type": "白",
          "text": "谢大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞须弥起。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "掌殿官，上大夫文种，身有何病，不能入宫，你可知晓？"
        },
        {
          "character": "庞须弥",
          "type": "白",
          "text": "启奏大王：文大夫并无疾病，那是他自以功大无赏，心怀怨愤，所以不肯入宫。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "这事当真？"
        },
        {
          "character": "庞须弥",
          "type": "白",
          "text": "臣焉敢欺君！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "这就是了。你且退出！"
        },
        {
          "character": "庞须弥",
          "type": "白",
          "text": "遵旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞须弥下。"
        },
        {
          "character": "王妃",
          "type": "白",
          "text": "大王，我想文种，才智过人，他今心怀怨愤，若不将他早除，日后发生不测， 何人是他敌手！"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "这便怎处？"
        },
        {
          "character": "王妃",
          "type": "白",
          "text": "以臣妾之见，大王亲去他府，假意探病，将属镂宝剑带去，暗地遗在他府，看 他如何行事，再作定夺。"
        },
        {
          "character": "勾践",
          "type": "白",
          "text": "就依王妃所奏，就此前去。正是："
        },
        {
          "character": "勾践",
          "type": "念",
          "text": "宫中定巧计，宫外安得知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
