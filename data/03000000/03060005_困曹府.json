{
  "script_id": "03060005",
  "title": "困曹府",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "曹彬",
      "hangdang": "小生"
    },
    {
      "name": "张氏",
      "hangdang": "旦"
    },
    {
      "name": "华佗",
      "hangdang": "老生"
    }
  ],
  "plot": "赵匡胤领郭威命往刺刘化王，行至刘地，几为关卒识破，幸曹彬之嫂假呼为丈夫，始免于难。曹嫂归，闻赵\n匡胤酒后背语，羞愧自缢。赵匡胤于梦中遇华佗来割瘤，封为神仙。继梦曹嫂讨封，乃封为华山插花圣母。\n醒来，语及曹彬，冒称其兄曹仁，乃得出关。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、曹彬同上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "逃出天罗地网，"
        },
        {
          "character": "曹彬",
          "type": "念",
          "text": "好似雀鸟腾空。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "恩人请坐！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟请！多蒙贤弟搭救，我这里当面谢过。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "岂敢！小弟当报前恩。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "备得有酒，与恩人压惊。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如此，叨扰了。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "恩人请！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "曹彬",
          "type": "唱",
          "text": "得恩不报非君子， 忘恩负义是小人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、曹彬同饮酒，曹彬醉，睡。〖起初更鼓〗。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "二相公醒来，再吃一杯……啊，他竟然睡熟了。 唉！想我赵匡胤今宿曹府，好不焦躁人也！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "有豪杰坐书房精神不爽， 二相公心无事困睡一旁。 无奈何推纱窗仰观天象， 果然是中秋月分外明光。 我本是宦门后娇生惯养， 打关东闯关西自称豪强。 思爹娘想妹弟终朝盼望， 山又高路又远阻隔两厢。 洒金桥遇苗顺曾把命讲， 他算我到后来南面称王。 到如今坐江山全然不想， 登九五比南柯大梦一场。 周文王得江山全凭吕望， 拉八百单八步地久天长。 汉刘秀全凭着二十八将， 文邓禹、武姚期、岑彭、子章。 小唐王全凭着瓦岗诸将， 我玄郎并无有架海金梁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "恨金鸡不报晓天还未亮， 谯楼上睡熟了打更儿郎。 恨不能用长枪高挑万丈， 用金钩将红日钩出扶桑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏上。"
        },
        {
          "character": "张氏",
          "type": "唱",
          "text": "轻移莲步到书房， 且听恩人说其详。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "奴家，张氏。赵恩人在书房饮酒，不免去到窗下，听他说些什么。正是："
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "若知心腹事，且听口中言。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "且住！想我在西门外被崔龙拿住，多亏二相公举家将我救下，好一个张氏嫂嫂， 在大街以上，叫俺一声“丈夫”，这样贤人，真是难得呀难得！呀呸！讲什 么贤人，道什么难得？他是曹仁之妻，叫俺玄郎一声“丈夫”。若是我那贺氏 妻子，叫别人一声“丈夫”，玄郎不知便罢；我若知道，就是这一刀。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "错了！错了！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "一句话儿出了唇， 倒作忘恩负义人。 不饮酒来假装醉，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "醉了！醉了！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "窗外休听醉汉云。"
        },
        {
          "character": "张氏",
          "type": "唱",
          "text": "听一言来吃一惊， 羞得奴家面通红。 腰间解下丝罗带， 不如一死丧残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏下。〖起三更鼓〗。华佗上。"
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "闷坐松林下，修道数百年。三国我为首，自称华佗仙。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "我乃三国华佗是也。只因赤须龙有难，特地前来搭救，讨一封号。来此已是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华佗进门，与赵匡胤割治肉瘤。"
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "不用忧来不用愁，宝剑割去肉龙瘤。阳世之间无用处，抛在长江顺水流。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何方妖道？摆来摆去！"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "三国华佗。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "到此作甚？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "修炼多少年了？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "一千余年。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "算得一洞老神仙！"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "谢主隆恩！"
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "不是真龙开金口，焉得蓬莱一洞仙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华佗下。〖起四更鼓〗。张氏上。"
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "人死如灯灭，犹如汤泼雪。若要还阳转，海底捞明月。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "奴乃张氏鬼魂是也。身死之后，方知赵恩人后有九五之尊，不免前去讨一封号。 来至书房，待奴进去。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何处鬼魂，在此打搅？"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "奴乃张氏鬼魂是也。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "到此何事？"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "前来讨封。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "前日打华山经过，少一圣母，就封你为插花圣母，复位去吧！ 金童、玉女，送她归位！"
        },
        {
          "character": "金童、玉女",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金童、玉女捧衣同上，张氏换衣。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "谢主隆恩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏、金童、玉女同下。〖起五更鼓〗。"
        },
        {
          "character": "曹小姐",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹小姐上。"
        },
        {
          "character": "曹小姐",
          "type": "念",
          "text": "忙将嫂嫂事，报与哥哥知。"
        },
        {
          "character": "曹小姐",
          "type": "白",
          "text": "二哥开门！"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "贤妹何事？"
        },
        {
          "character": "曹小姐",
          "type": "白",
          "text": "嫂嫂悬梁自缢了！"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "你且退下！"
        },
        {
          "character": "曹小姐",
          "type": "白",
          "text": "嫂嫂啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹小姐哭下。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "恩人醒来！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "插花圣母归了位， 三国华佗讨了封。 猛然睁开愁眉眼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬哭。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "贤弟落泪为何情？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "嫂嫂自缢了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "嫂嫂啊！ 贤弟不必如此，嫂嫂必然成仙去了。今日八月十几了？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "八月十四。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "明日？"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "八月十五。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "八月十五，就是俺光棍家出头之日了。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "像你们光棍家，还讲什么根本不成？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟呀！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "休道俺光棍家根本不讲， 坐一旁听玄郎细说端详： 家住在西罗县双龙街上， 本姓赵名匡胤表字玄郎。 头辈祖名赵高家财甚广， 二辈祖名怀庆四海名扬。 三辈祖名赵霸残唐为将， 子不言父的名四品黄堂。 生下了俺玄郎面带奇相， 酒醉后杀御乐惹下祸殃。 二双亲修书信四路探望， 遇柴荣和郑恩关西路旁。 我三人尧王庙同把香降， 要学那三国中刘备、关、张。 董家桥打五虎兄弟各往， 柴大哥到怀庆受爵封王。 柴仁兄身荣贵不把友忘， 差旗牌带书信迎接玄郎。 弟兄们同饮酒花亭以上， 自分手又相会畅叙情肠。 顷刻间鱼池内抖起波浪， 吓坏了王府人俱各惊慌。 大哥说鱼戏水常来常往， 俺玄郎见妖怪甚是猖狂。 左挽弓右搭箭对妖撒放， 又听得谯楼上鼓打三梆。 次日里兄带我金殿来上， 郭王爷要报那梦中箭伤。 一霎时传旨意将我上绑， 柴大哥奏一本刺杀刘王。 最不该在金殿海口夸讲， 不用兵不带将独下燕邦。 走西门遇见了崔龙老将， 多亏你举家人搭救玄郎。 昨夜晚摆酒宴桌案以上， 俺玄郎得二梦记在心旁。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "头一梦？"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "头一梦见华佗三国道长， 用宝剑割肉瘤丢入长江。 二贤弟若不信观看左膀，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬看。"
        },
        {
          "character": "曹彬",
          "type": "唱",
          "text": "果然是去肉瘤并无损伤。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "第二梦？"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "第二梦见张氏嫂嫂形象， 项带绳见玄郎两泪汪汪。 我封她为圣母华山以上， 有金童和玉女送上山岗。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "多谢恩人！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "劝贤弟在此处少要来往， 搬至在怀庆府可作家乡。 柴大哥他是我结义兄长， 大小事必然要看在玄郎。 监牢内二双亲劳你看望， 就说我得了功免挂愁肠。 叫贤弟将手铐与我带上， 此一去上金殿刺杀刘王。 施一礼出门来四下观望，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤出门望，曹彬下。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "见崔龙人共马各逞豪强。 真和假是不是见尔主上， 我曹仁不犯法又待何妨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}