{
  "script_id": "03021011",
  "title": "算军粮",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "薛平贵",
      "hangdang": "老生"
    },
    {
      "name": "王允",
      "hangdang": "老生"
    },
    {
      "name": "魏虎",
      "hangdang": "净"
    },
    {
      "name": "苏龙",
      "hangdang": "老生"
    },
    {
      "name": "王夫人",
      "hangdang": "老旦"
    }
  ],
  "plot": "薛平贵乘王允寿辰，与妻王宝钏偕赴相府，向王允、魏虎讨算十八年军粮。互相争辩，一同面君。",
  "notes": "为全部《王宝钏》之第十一折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部\n均不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。\n本集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "王允",
          "type": "内白",
          "text": "嗯哽！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允上。"
        },
        {
          "character": "王允",
          "type": "引子",
          "text": "调和鼎鼐，位列三台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允坐。"
        },
        {
          "character": "王允",
          "type": "念",
          "text": "头戴乌纱色色新，身穿红袍带围身。老夫在朝为首相，膝下无子甚惨情！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院甲暗上。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "老夫，王允。蒙圣恩官拜当朝首相。今当老夫寿诞之期。满朝文武，必定前来 拜寿。 来！"
        },
        {
          "character": "家院甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": "家院甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院乙上。"
        },
        {
          "character": "家院乙",
          "type": "白",
          "text": "三姑娘到！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "噢！那宝钏来了？"
        },
        {
          "character": "家院乙",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "唤她进来！"
        },
        {
          "character": "家院乙",
          "type": "白",
          "text": "是。 有请三姑娘！"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "听得家院一声请， 寒窑来了受苦人。 迈步我把——"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "相府进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏进门。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "见了爹爹说分明。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "谢坐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏坐。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿呀，想你一十八载，未曾进过相府。今日到此何事？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿与爹爹拜寿来了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "为父的寿诞儿还记得？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "焉有不记得的道理！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "记得就好。后堂见过你那母亲去吧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏离座，出门。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "前堂领了爹爹命， 后堂去见儿的老娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "内同白",
          "text": "二位姑老爷到！"
        },
        {
          "character": "家院甲、家院乙",
          "type": "同白",
          "text": "二位姑老爷到！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "家院甲、家院乙",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙、魏虎同上。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "参见岳父大人！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "贤婿少礼。请坐。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙、魏虎两旁分坐。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "啊二位贤婿！"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "岳父大人！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "老夫今年寿诞与往年大不相同了。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "怎么大不相同？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "那宝钏也来了。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "想是借贷而来？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "唉！哪里是借贷而来，想是守节不住了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "休得胡言！ 啊二位贤婿，老夫有意在酒席宴前劝解宝钏，还劳二位贤婿帮助。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "那个自然。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "家院，请夫人、小姐出堂！"
        },
        {
          "character": "家院甲、家院乙",
          "type": "同白",
          "text": "请夫人、小姐出堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟扶王夫人同上，王金钏、王银钏、王宝钏同上。"
        },
        {
          "character": "王夫人",
          "type": "念",
          "text": "九月菊花放，"
        },
        {
          "character": "王金钏",
          "type": "念",
          "text": "花开满院香。"
        },
        {
          "character": "王银钏",
          "type": "念",
          "text": "人前显富贵，"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "盼想儿夫郎。 （王允、苏龙、魏虎同离座。王夫人、王金钏、王银钏、王宝钏、丫鬟同进门。王允、王夫人同上站，苏龙、 王金钏、魏虎、王银钏、王宝钏、家院甲、家院乙、丫鬟相继拜寿。王允、王夫人同归正座。苏龙、魏虎 同坐大边，王金钏、王银钏、王宝钏同坐小边。）"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "寿堂之上摆酒宴，"
        },
        {
          "character": "王夫人",
          "type": "西皮原板",
          "text": "合家团聚乐安然。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "一家人华堂上庆祝寿诞， 魏虎贼他那里心不安然。 他怎知薛郎夫早已回转， 老爹爹问一声答他一言。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "啊宝钏，你今前来是专为拜寿，是还有别事？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "儿今此来，一来与爹爹拜寿，二来与魏虎算算一十八载的粮饷！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "你住了吧！那薛平贵死在西凉，哪有粮饷算还与你？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏虎离座。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "他若不曾死呢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏离座。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "那平贵若在，就将粮饷算还与你！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "敢与你三姑娘击掌？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "好，击掌！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人离座。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "且慢！儿呀，听你之言，莫非那平贵还在？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "娘啊！"
        },
        {
          "character": "王宝钏",
          "type": "西皮流水板",
          "text": "母亲不必来相劝， 女儿言来听根源： 只因魏虎将人陷， 丈夫薛郎丧外边。 辞别爹娘——"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "寒窑转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏出门，王夫人、魏虎同归座。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "寒窑去把薛郎搬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "二位贤婿！"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "岳父大人！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "方才听宝钏之言，莫非那平贵他还在？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "唉！他早就死啦。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "还是在的好！"
        },
        {
          "character": "王允、魏虎",
          "type": "同白",
          "text": "唉，死了的好！"
        },
        {
          "character": "王夫人、苏龙",
          "type": "同白",
          "text": "唉，还是在的好！"
        },
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "为见王允巧改扮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏同上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "寒窑内来了平贵男。 几载不见王允面， 相府修盖好威严。 我与魏虎把粮算！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "西皮小拉子。薛平贵欲见礼，王宝钏暗示阻止。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "问我一声答一言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵坐大边，王宝钏坐小边。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "宝钏！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哼……"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "方才进来的大汉，他是何人？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "他就是征西路上，害不死的薛平贵。他、他、他……又回来了！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "噢！贤婿到了。待老夫下位。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "小婿向前！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏虎离座。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "哎呀且住！那薛平贵明明死在西凉，怎么又来到长安？莫非是活见了鬼了！待 我看来。可不是薛平贵吗？哎呀呀，这便如何是好？有了！我上前与他赔个礼 儿也就是了。 啊先行，平贵，你回得朝来，本帅未曾与你接风掸尘。我这厢有礼了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏虎作揖，王宝钏暗示薛平贵不理。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "啊，没听见。想是行路之人，受了风霜，有些耳沉了。我再来它一家伙。 啊先行，平贵，你回得朝来，本帅未曾与你接风撢尘。我这厢有礼了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏暗示薛平贵不理。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "唗！本帅好意与你深施一礼。你坐在一旁，昂然不理。她在一旁，指指戳戳。 是何道理？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵离座，王宝钏随起。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "魏虎，我今回得朝来，快将一十八载粮饷算还与我！"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "住了，你私通西凉，哪有粮饷算还与你？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "你敢与我上殿面君？"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "怕你不成？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "上前抓住袍和带， 你苦苦地害我为何来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵拉魏虎同下。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "看他二人抓袍夺带。待老夫上殿保本便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王允、王夫人、苏龙、王金钏、王银钏、王宝钏同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}