        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "这，孤家有一言，可能讲否？"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "大王有何金言，当面盼咐。"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "孤王花甲已过，并无子嗣；只生一女，名唤彩珠。意欲招将军为婿，量无推辞 的了。"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "大王，俺刘庆蒙小姐不斩，承大王错爱，只是一件，临阵招亲，有一行大罪， 使不得！"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "容臣相劝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "番官向刘庆。"
        },
        {
          "character": "番官",
          "type": "白",
          "text": "啊刘将军，我家大王将公主许配与你，乃是桩好事。况公主文武双全，也是女 中之魁首。你若执意不允，将你一刀两段，岂不可惜！为大将者，必须通权达 变，方是栋梁之才，而且临阵招亲，古之常有，将军你要自去想来。"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "哎呀且住。倒是这官儿说得有理，此时若是不允亲，谅也难逃罗网。罢！ 啊，承蒙大王厚恩，末将焉敢不从亲事。只是要先禀明无帅，然后完姻。"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "既已允将军回营禀过主帅，择选良辰，完成花烛之喜。"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "多谢大王！吿别。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘庆下。"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "妙啊！我儿终身已定，完却了二老一桩心事。 来！后营摆宴，与公主贺功！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
