{
  "script_id": "03008004",
  "title": "通海沟",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "石彩珠",
      "hangdang": "旦"
    },
    {
      "name": "刘庆",
      "hangdang": "净"
    }
  ],
  "plot": "鄯善国双阳公主归顺宋朝后，宋王封狄青、双阳夫妇为左右元帅征西，兵至通海沟与罗王之女石彩珠遇，众\n将皆不敌石彩珠。适逢飞虎刘庆押粮回，讨令出战。石彩珠曾受师命，谓婚姻应在飞虎身上，故当面向刘庆\n求婚，刘庆不允，将刘庆打下马，刘庆佯允之，途中刘庆欲剌石彩珠，被看破，刘庆逃，终为石彩珠所擒，\n带回朝去，罗王命刘庆回营禀明元帅，再来迎娶石彩珠，刘庆欣然而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "季青、刘庆、张仁、李义同上，同起霸。"
        },
        {
          "character": "季青",
          "type": "念",
          "text": "英雄志量谙略韬，"
        },
        {
          "character": "刘庆",
          "type": "念",
          "text": "将士腰挂雁翎刀，"
        },
        {
          "character": "张仁",
          "type": "念",
          "text": "冲锋对垒扬名姓，"
        },
        {
          "character": "李义",
          "type": "念",
          "text": "沙场效力汗马劳。"
        },
        {
          "character": "季青、刘庆、张仁、李义",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "季青",
          "type": "白",
          "text": "季青。"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "刘庆。"
        },
        {
          "character": "张仁",
          "type": "白",
          "text": "张仁。"
        },
        {
          "character": "李义",
          "type": "白",
          "text": "李义。"
        },
        {
          "character": "季青",
          "type": "白",
          "text": "众位贤弟请了！"
        },
        {
          "character": "刘庆、张仁、李义",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "季青",
          "type": "白",
          "text": "自从皇亲收了双阳公主，回复圣命；圣上见喜，封为顺天侯。"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "圣上拜皇亲与双阳公主，为征西左右元帅。再去上乘、印唐二国，盗取日月骕 骦马和珍珠烈火旗。命俺弟兄以为前站先行。各自准备起马。"
        },
        {
          "character": "李义",
          "type": "白",
          "text": "三位哥哥，想你我随皇亲屡战沙场，只为番邦二宝，也不知受了多少辛苦。"
        },
        {
          "character": "季青",
          "type": "白",
          "text": "不必多言。皇亲、公主升帐，小心伺候。请！"
        },
        {
          "character": "季青、刘庆、张仁、李义",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四上手、四女兵引狄青、双阳公主同上。〖点绛唇〗。"
        },
        {
          "character": "季青、刘庆、张仁、李义",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "各位将军少礼。"
        },
        {
          "character": "狄青",
          "type": "念",
          "text": "功勋荫袭得簪缨，忠君报国哪得宁。"
        },
        {
          "character": "双阳公主",
          "type": "念",
          "text": "虽然凌烟标名姓，依然还是旧门庭。 狄青　　　双阳公主　（白）　　　　　双阳公主。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "公主，你我钦承皇命，带领精兵十万，前往上乘、印唐二国，复取日月骕骦马 和珍珠烈火旗。今当黄道吉日，正好兴师。请公主发令！"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "如此，有僭了。 众将官，站立两厢，听我号令！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "刘庆听令！"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "命你星夜飞至延安，催齐粮草，十日之内，须要解到；若误了日期，提头来见！"
        },
        {
          "character": "刘庆",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘庆下。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "季青听命！"
        },
        {
          "character": "季青",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "命你为前站，逢山开路，遇水搭桥！"
        },
        {
          "character": "季青",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "季青下。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "张仁、李义二将听令！"
        },
        {
          "character": "张仁、李义",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "吩咐众将一路之上，不许骚扰百姓、马踏田苗，违令者斩！"
        },
        {
          "character": "张仁、李义",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "众将官！响炮拔营！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引石彩珠同上。"
        },
        {
          "character": "石彩珠",
          "type": "引子",
          "text": "玉琢粉妆，傲须眉，道法无双。"
        },
        {
          "character": "石彩珠",
          "type": "念",
          "text": "仙乡学艺得师传，移山倒海道法全。虽然闺中裙钗女，威震印唐掌兵权。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "俺、石彩珠。父亲罗王，镇守通海沟，各国不敢藐视。奴家自幼曾蒙金刀圣母 教成兵法武艺。下山之时，圣母言道，我的终身，应在南将飞虎之人。这且不 言。今日父王母后寿诞之期。 官娥！"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "酒宴可曾齐备？"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "伺候了。 有请父王、母后！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监引罗王、罗妃同上。"
        },
        {
          "character": "罗王",
          "type": "念",
          "text": "天上长圆月，"
        },
        {
          "character": "罗妃",
          "type": "念",
          "text": "人如月长圆。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "父王、母后千岁！"
        },
        {
          "character": "罗王、罗妃",
          "type": "同白",
          "text": "我儿少礼，平身。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "罗王、罗妃",
          "type": "同白",
          "text": "坐下。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "罗王、罗妃",
          "type": "同白",
          "text": "儿啊，请我二老出来，莫非为了庆寿？"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "正是。孩儿备得筵席，与父王、母后上寿。"
        },
        {
          "character": "罗王、罗妃",
          "type": "同白",
          "text": "承受我儿。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "父王、母后请上，待儿拜寿。"
        },
        {
          "character": "罗王、罗妃",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。安席。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "罗妃",
          "type": "白",
          "text": "大王请！"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "父王、母后请！"
        },
        {
          "character": "罗王",
          "type": "唱",
          "text": "银烛光辉对金樽， 画阁雕梁高入云。 山川常有月常在， 但愿人寿天地同。"
        },
        {
          "character": "罗妃",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "罗妃",
          "type": "唱",
          "text": "珠帘半卷晚香送， 可叹人生如梦中。 富贵荣华终无用， 愿夫寿比东王公。"
        },
        {
          "character": "石彩珠",
          "type": "唱",
          "text": "白玉堂上笙歌动， 双亲寿比北斗翁。 旭日当空星月拱， 瑶台宫阙种青松； 青松翠柏年年绿， 爹娘寿与松柏同。"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "罗王",
          "type": "唱",
          "text": "畅饮中间心酸痛， 堪叹无子能送终。"
        },
        {
          "character": "罗妃、石彩珠",
          "type": "同白",
          "text": "停杯不饮为了何事？"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "儿啊！为父年过花甲，无有子嗣，就是我儿一人，还终身未定；所以为父忧闷 在心。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "孩儿终身，自有天定，何须忧虑！"
        },
        {
          "character": "罗妃",
          "type": "白",
          "text": "儿啊！言虽如此，我二老只有儿一人，何言不虑！"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "爹娘啊！"
        },
        {
          "character": "石彩珠",
          "type": "唱",
          "text": "自古道姻缘有前定， 父王母后放宽心。 待儿敬酒请畅饮， 多福多寿永康宁。"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "罗王",
          "type": "唱",
          "text": "我儿贤孝情意重，"
        },
        {
          "character": "罗妃",
          "type": "唱",
          "text": "展去愁眉换笑容。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "念",
          "text": "忙将边关事，报与大王知。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启奏大王：守关将士来报，南蛮狄青领兵前来，复取二宝；守关将士不敢迎敌？ 请大王定夺！"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "呕，有这等事！我儿有何良计？"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "既是南兵直抵我关，岂能容他猖厥！待孩儿出马，管教他片甲不回！"
        },
        {
          "character": "罗王",
          "type": "白",
          "text": "好，须要小心。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "罗王",
          "type": "念",
          "text": "屡次取宝战不休，"
        },
        {
          "character": "石彩珠、罗妃",
          "type": "同念",
          "text": "防守关口费计谋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗王、罗妃、石彩珠同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四上手、季青、张仁、李义、狄青、四女兵、双阳公主同上。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "来此交界之地。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "公主，来此交界之地，须要安营，也好稍息众军之力。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "且慢。我兵到此，想番营必来讨战，还须占先才是。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "全仗公主调遣。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "遵命。 三位将军听令！"
        },
        {
          "character": "张仁、李义、季青",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "命你三人攻破此关，立一头功。"
        },
        {
          "character": "张仁、李义、季青",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "季青、张仁、李义同下。"
        },
        {
          "character": "双阳公主",
          "type": "白",
          "text": "众将官！虚张声势，坚营固守，退兵二十里，安营扎寨！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四下手同上，同站门。石彩珠上，起霸。"
        },
        {
          "character": "石彩珠",
          "type": "念",
          "text": "剑气撗山岫，旌旗鬼神愁。黎山学道法，英名贯九州。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "俺、石彩珠。因南将兵临关下，十分猖獗。为此我全身披挂，与他鏖战。倘若 见飞虎之人，也好不负圣母之言。 众番兵迎敌去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "季青、张仁、李义、四上手同上。会阵。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "住了。南将少催战马，通名受死！"
        },
        {
          "character": "张仁、李义、季青",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "季青",
          "type": "白",
          "text": "季青。"
        },
        {
          "character": "张仁",
          "type": "白",
          "text": "张仁。"
        },
        {
          "character": "李义",
          "type": "白",
          "text": "李义。"
        },
        {
          "character": "石彩珠",
          "type": "白",
          "text": "原来不是主将。着枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "石彩珠杀。季青、张仁、李义同败下。石彩珠率众人同追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂引狄青同上。"
        },
        {
          "character": "狄青",
          "type": "唱",
          "text": "坐镇牙纛统貔貅， 决胜千里用计谋。 扫净狼烟凯歌奏， 卸甲归朝拜凤楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "季青、张仁、李义同上。"
        },
        {
          "character": "张仁、李义、季青",
          "type": "同白",
          "text": "末将交令。"
        },
        {
          "character": "狄青",
          "type": "白",
          "text": "胜负如何？"
        },
        {
          "character": "张仁",
          "type": "白",
