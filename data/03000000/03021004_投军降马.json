{
  "script_id": "03021004",
  "title": "投军降马",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "小生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "王夫人",
      "hangdang": "老旦"
    },
    {
      "name": "王允",
      "hangdang": "老生"
    },
    {
      "name": "苏龙",
      "hangdang": "老生"
    },
    {
      "name": "魏虎",
      "hangdang": "净"
    }
  ],
  "plot": "薛平贵降妖有功，封为后军督府。王允参奏，改为平西先行。",
  "notes": "为全部《王宝钏》之第四折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "王允做事心太狠， 将我平贵赶出门。 怒气不息寒窑奔，"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "薛郎慢走！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "又见三姐到来临。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "爹爹做事不思忖， 嫌贫爱富为何情？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐你赶来做甚？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "是我闻听人言，我父将你赶出相府。因此我与爹爹三击掌，怒出府门，前来找 你。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "想你乃是千金之体，与我这花郎成婚，岂不有累你的终身？小姐还是回相府去 吧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我也曾与我爹爹三击掌。至死也不回转相府的了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好一位烈性的三姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊薛郎，你我哪里安身？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "只好去到寒窑安身。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此，薛郎带路！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏同走圆场，同进窑。乞丐甲、乞丐乙同上。"
        },
        {
          "character": "乞丐甲、乞丐乙",
          "type": "同念",
          "text": "饱暖饱暖，饥寒饥寒。又饱又暖，胜似做官。"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "我说老二呀！好几天没见咱们老兄弟啦。咱们到寒窑瞧瞧他去，你看好不好？"
        },
        {
          "character": "乞丐乙",
          "type": "白",
          "text": "好，走着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乞丐甲、乞丐乙同走圆场。"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "到啦，到啦。 老兄弟在家吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵出窑。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵看。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊，原来是二位大哥，请进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵引乞丐甲、乞丐乙同进窑。"
        },
        {
          "character": "乞丐甲、乞丐乙",
          "type": "同白",
          "text": "这是哪位？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "乃王丞相之女。为了与我成婚，与她爹爹三击掌，情愿在此寒窑受苦。"
        },
        {
          "character": "乞丐甲、乞丐乙",
          "type": "同白",
          "text": "嘿！有志气。你们成了亲啦吗？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "只是无人赞礼。"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "不要紧，我有办法。 老二呀，你来赞礼，好话多说。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏同下。"
        },
        {
          "character": "乞丐乙",
          "type": "念",
          "text": "一块沉香木，雕刻一马鞍。新人往上跨，步步保平安。"
        },
        {
          "character": "乞丐乙",
          "type": "白",
          "text": "搀新人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏同上，同拜天地。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有劳二位大哥。"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "没说的。兄弟，你入洞房吧，我们走啦。 老二呀，走着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乞丐甲、乞丐乙同出窑，同下。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "啊三姐，寒窑之中一无所有，你我怎样度日？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你可去到相府后花园，见了我家母亲，借些银两，也好度日。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐，你在寒窑等候，我就此去也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵出窑，自上场门下。王宝钏自下场门下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王夫人上。"
        },
        {
          "character": "王夫人",
          "type": "念",
          "text": "宝钏招亲事，时刻挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人坐。薛平贵上。家院自下场门暗上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "急急忙忙往前进， 不觉来到花园门。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "老夫人可在里面？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "现在里面。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "烦劳通禀，薛平贵求见。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "候着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院进门。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启禀老夫人：薛平贵求见。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "叫他进来。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院出门。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "随我进来。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院引薛平贵同进门。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "参见岳母大人！"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "罢了。到此何事？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "寒窑一无所有，难以度日，向岳母大人借银来了。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "家院！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院允。"
        },
        {
          "character": "王夫人",
          "type": "白",
          "text": "取纹银百两、白米一斗，交与平贵，回转寒窑去吧！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院取银、米，持布袋交与薛平贵。家院下。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "多谢岳母。小婿拜别了！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "辞别岳母出园门， 有了银两好度光阴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王夫人下。薛平贵走圆场。"
        },
        {
          "character": "王允",
          "type": "内白",
          "text": "回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、家院引王允同上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "花郎打此经过。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "抓了回来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同允。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "拿的什么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "来，上前搜查。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院搜薛平贵，搜出银子。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "你哪里来的银两？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "乃是老夫人赠予我的。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "胡说！一定是偷盗来的。 来，与我打！ （四校尉打。薛平贵死。王允、家院、四校尉同下。二神将同暗上，同唤醒薛平贵，教授枪法。二神将同暗 下。薛平贵仍躺原处。乞丐甲、乞丐乙同上。）"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "呦！咱们老兄弟怎么叫人给打死了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乞丐甲想。"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "我明白了，你猜是谁打死的？"
        },
        {
          "character": "乞丐乙",
          "type": "白",
          "text": "是谁打死的？"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "这一定是王丞相给打死的。我在这儿看着，你快到寒窑给弟妹送信去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乞丐乙下，乞丐乙引王宝钏同上。"
        },
        {
          "character": "王宝钏",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "一见薛郎倒埃尘， 怎不叫人两泪淋！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎醒来！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "霎时一阵魂不定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵坐起。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎！喂呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "只见三姐面前存。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊薛郎，你、你、你……为何这等模样啊？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐有所不知。是我去至相府后花园，见了岳母大人，蒙她赠我银两。不料行 在大街之上，遇见你父，将我饱打一顿，故而如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "乞丐甲",
          "type": "白",
          "text": "既然缓醒过来了，就快回去吧！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "只是我行走不动了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待我搀扶于你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏扶薛平贵同走圆场，同进窑。"
        },
        {
          "character": "乞丐甲、乞丐乙",
          "type": "同白",
          "text": "我们出去要点儿吃的来，拿回来好给你吃呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乞丐甲、乞丐乙同下。薛平贵亮相。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这做什么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "是我方才昏迷不醒之时，蒙神人教我武艺。我有意前去投军，不知三姐意下如 何？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "既会武艺，理应前去投军。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如此，俺去也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎此去，倘若得中，也不枉我寒窑受苦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军引苏龙、魏虎同上。"
        },
        {
          "character": "苏龙",
          "type": "念",
          "text": "国家不幸，"
        },
        {
          "character": "魏虎",
          "type": "念",
          "text": "妖魔纵横。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏龙、魏虎同坐。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "苏龙。"
        },
        {
          "character": "魏虎",
          "type": "白",
          "text": "魏虎。"
        },
        {
          "character": "苏龙",
          "type": "白",
          "text": "红沙涧内妖魔作乱。圣上有旨：“挂榜招贤。”有人降了妖魔，加官授职。 中军，将榜文挂在辕门！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军挂榜。薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "来此已是。待我揭榜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵揭榜。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "揭榜人求见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军进门。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启禀元帅：揭榜人求见。"
        },
        {
          "character": "苏龙、魏虎",
          "type": "同白",
          "text": "传他进来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军出门。"
        },
        {
