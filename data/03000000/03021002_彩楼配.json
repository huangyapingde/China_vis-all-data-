{
  "script_id": "03021002",
  "title": "彩楼配",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "薛平贵",
      "hangdang": "小生"
    },
    {
      "name": "公子丁",
      "hangdang": "丑"
    }
  ],
  "plot": "二月二日，王丞相府高搭彩楼，抛球招婿，无数王孙公子前往接彩。王宝钏高立彩楼，既见薛平贵，即将球\n抛下。薛平贵获得彩球，王宝钏乃下楼回报。",
  "notes": "为全部《王宝钏》之第二折。全部《王宝钏》共十三个剧目，除《武家坡》、《大登殿》两折，其余大部均\n不常见于舞台。有些单出戏经过历次舞台实践得到发展。经串连后，不免有词句重复、情节欠统一之处。本\n集为了存真，一律未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "公子甲、公子乙、公子丙、公子丁同上。"
        },
        {
          "character": "公子甲",
          "type": "念",
          "text": "春游芳草地，"
        },
        {
          "character": "公子乙",
          "type": "念",
          "text": "夏赏荷花池。"
        },
        {
          "character": "公子丙",
          "type": "念",
          "text": "秋饮菊花酒，"
        },
        {
          "character": "公子丁",
          "type": "念",
          "text": "冬吟白雪诗。"
        },
        {
          "character": "公子甲",
          "type": "白",
          "text": "列位请了！"
        },
        {
          "character": "公子乙、公子丙、公子丁",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "公子甲",
          "type": "白",
          "text": "今有王相府，高搭彩楼，抛球招婿。你我前去接彩。"
        },
        {
          "character": "公子乙、公子丙、公子丁",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子甲、公子乙、公子丙、公子丁同走圆场。门官暗上。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你们都是接彩的吗？往里边儿请吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子甲、公子乙、公子丙同下。门官拦公子丁。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "咳，咳！你这老头儿，是干什么的？"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "我也是接彩的。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "你年纪这么大啦，不能进去。"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "我是人老心不老。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "不行，不能进去。"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "我跟你商量商量：没有胡子，能进去吗？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "等你没有胡子的时候，再商量吧！去，去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子丁转身摘胡子。月老持云帚引薛平贵同暗上，同进门，同下。"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "现在胡子没了，能进去了吧？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "还是不能进去。"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "为什么哪？"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "到底你是年纪大了。"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "我这个人有个脾气：你不让我进去，我偏要进去。你叫我进去，我倒不进去了！"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "啊！那么我来试验试验。 老头儿，我不让你进去！"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "我偏要进去。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "我让你进去了！"
        },
        {
          "character": "公子丁",
          "type": "白",
          "text": "那我就进去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子丁下。"
        },
        {
          "character": "门官",
          "type": "白",
          "text": "好！我上了他当了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "王宝钏",
          "type": "内西皮导板",
          "text": "梳妆打扮出绣房，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟引王宝钏同上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "后堂内辞别了二老爹娘。 老天爷若称了奴的愿望， 早与那平贵配成双。 叫丫鬟带路彩楼上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟引王宝钏同上楼，四丫鬟分站两旁。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "手扶着栏杆——"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "看端详： 也有王孙公子样， 也有客旅与经商。 举目抬头——"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "四下望，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏望。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "因何不见那花郎？ 花园赠金对他讲， 看来他是无义郎！ 不打彩球回府往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子甲、公子乙、公子丙、公子丁同暗上，月老引薛平贵同上。"
        },
        {
          "character": "公子甲、公子乙、公子丙、公子丁",
          "type": "同白",
          "text": "别回去！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "回府去怎对二爹娘？ 姻缘本是月老掌， 哪有个自己做主张！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "看彩球！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "彩球撇下任人抢，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏抛彩球。公子甲、公子乙、公子丙、公子丁同抢。薛平贵得球。"
        },
        {
          "character": "月老",
          "type": "西皮散板",
          "text": "彩球打中讨饭郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子甲、公子乙、公子丙、公子丁、薛平贵、月老自两边分下。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "耳边厢又听得人喧嚷： 彩球打中讨饭的郎。 想必就是薛平贵？ 不由奴家意彷徨。 丫鬟带路——"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "回府往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟扶王宝钏同下楼。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "回府去禀告二老爹娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟随王宝钏同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}