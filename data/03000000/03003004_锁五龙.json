{
  "script_id": "03003004",
  "title": "锁五龙",
  "alias": [
    "斩雄信"
  ],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "单雄信",
      "hangdang": "净"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "徐茂公",
      "hangdang": "老生"
    },
    {
      "name": "罗成",
      "hangdang": "小生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    }
  ],
  "plot": "唐王李世民击灭王世充时，俘获王世充部将单雄信，劝降不从，绑出处斩。在刑场上李世民和单雄信盟友徐\n茂公、罗成、程咬金等先后向单雄信敬酒后，单雄信即慷慨就义。",
  "notes": "这个剧本经苏连汉先生协助校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，同站门。秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "西皮散板",
          "text": "帐中奉了先生命， 押运粮草走一程。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺，秦琼。奉了先生将令，催押粮草，军前听用。 军士们，趱行者！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "秦琼",
          "type": "西皮散板",
          "text": "押定车辆朝前进， 一路之上要小心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "单雄信",
          "type": "内西皮导板",
          "text": "号令一声绑帐外，"
        },
        {
          "character": "二刽子手",
          "type": "内同白",
          "text": "嘿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二刽子手、单雄信同上。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "哼……"
        },
        {
          "character": "单雄信",
          "type": "西皮原板",
          "text": "不由得豪杰笑开怀。 单人独骑我把唐营踹， 只杀得众儿郎叫苦悲哀。 遍野荒郊血成海， 尸骨堆山无处葬埋。 小唐童被某，"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "胆吓坏， 某二次被擒也应该。 他劝某降唐某不爱， 一心想坐九龙台。 今生不能冤仇解， 二十年投胎某再来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上一字儿，程咬金、罗成、徐茂公、李世民同上。"
        },
        {
          "character": "李世民",
          "type": "西皮散板",
          "text": "将身来在营门外， 只见雄信绑法台。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "李世民",
          "type": "西皮流水板",
          "text": "一斗酒儿满满筛， 尊声将军听开怀： 你今饮了这斗酒， 你我冤仇两丢开。"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "见唐童把我牙咬坏， 大骂无耻小奴才。 我兄被你箭射坏， 兵发洛阳为何来！ 今生不能够把仇解， 你坐江山某再来。"
        },
        {
          "character": "徐茂公",
          "type": "西皮散板",
          "text": "主公且坐营门外， 为臣自有巧安排。"
        },
        {
          "character": "徐茂公",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "徐茂公",
          "type": "西皮流水板",
          "text": "一斗酒儿满满筛， 尊声五弟听开怀： 三十六人曾结拜， 散了瓦岗又分开。 非是愚兄将你害， 各为其主把兵排。 你今饮了这斗酒， 切莫埋怨愚兄来。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "休要提起来结拜， 提起结拜怒满怀。 你在唐营为元帅， 某在洛阳为将才。 叔宝、咬金被你拐， 点手又唤罗成来。 锦绣江山被你卖， 你是个人面兽投胎。"
        },
        {
          "character": "罗成",
          "type": "西皮散板",
          "text": "三哥且站营门外， 小弟向前说开怀。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "罗成",
          "type": "西皮流水板",
          "text": "一斗酒儿满满筛， 我与五哥解愁怀。 你今饮了这斗酒， 生死之事莫悲哀。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "见罗成怒气冲天界， 大骂忘恩负义小奴才。 曾记得打散了瓦岗寨， 曾记得一家大小洛阳来。 我为你三贤府来盖， 我为你花费许多财。 我为你东床招驸马， 我为你造下拜将台。 忘恩负义投唐寨， 花言巧语哄谁来。 雄信一死英名在，"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "罗成哪！奴才！"
        },
        {
          "character": "单雄信",
          "type": "西皮散板",
          "text": "怕只怕乱箭攒身你死无葬埋。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呸！着打。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "别打，别打，瞧我喽。别打，别打，瞧我喽。别打，别打，瞧着我啵！"
        },
        {
          "character": "程咬金",
          "type": "西皮散板",
          "text": "贤弟且站营门外， 愚兄上前说开怀。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "程咬金",
          "type": "西皮流水板",
          "text": "一斗酒儿满满筛， 尊声我的哥细听开怀： 你今饮了头斗酒， 管你的灵魂赴蓬莱。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "怎么，赴蓬莱？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "赴蓬莱。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "好啊，看酒来！干哪！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "程咬金",
          "type": "西皮流水板",
          "text": "二斗酒儿满满筛， 点点珠泪洒下来。 你今饮了这斗酒， 管你的灵魂上天台。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "怎么，上天台？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "上天台。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "好，看酒来！干哪！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好海量，好海量！斟酒！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "程咬金",
          "type": "西皮流水板",
          "text": "三斗酒儿满满筛， 尊声我的哥细听明白： 贾家楼曾结拜， 惟有你我同心怀。 我的哥一死威名在， 且把美酒饮开怀。 你今饮了这斗酒， 拿住他们一刀一个把刀开，把我丢开。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "怎么，把你丢开？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "对喽，把我丢开。"
        },
        {
          "character": "单雄信",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "这句话儿真爽快，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我就好说直话吗！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "贤弟把酒斟上来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好，您喝嗻！"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "贾家楼曾结拜，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不错，咱们拜过把子。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "惟有你我同心怀。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "就是咱们哥俩好。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "满营将官俱都在，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我们都在这儿伺候您哪。"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "为何不见栋梁才？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "您找谁哪？"
        },
        {
          "character": "单雄信",
          "type": "唱",
          "text": "问一声秦二哥今何在？"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "二哥解粮未回来。"
        },
        {
          "character": "单雄信",
          "type": "哭头",
          "text": "啊啊啊……好汉哥呀！"
        },
        {
          "character": "单雄信",
          "type": "西皮快板",
          "text": "好汉押粮未回来。 等候二哥回营寨， 把某的心事说开怀。 某今饮干了三斗酒， 快教唐童把刀开。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "尉迟恭听令！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "在呀！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "将单雄信开刀！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。尉迟恭、二刽子手押单雄信同下。龙形上，四龙套锁龙形同下。尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "斩首已毕。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "回营帐中摆宴，与众位将军贺功。"
        },
        {
          "character": "徐茂公、尉迟恭、罗成、程咬金",
          "type": "同白",
          "text": "谢主公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}