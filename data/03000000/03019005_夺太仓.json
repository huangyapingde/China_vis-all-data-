      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四红文堂、四红大铠、沐英、曹良臣、郭英、朱亮祖、俞通海、孙兴祖、徐达上。常遇春上"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "末将奉命前锋迎敌，得遇吕珍、赵玠，是俺箭射画戟，心服来降。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "今在何处？"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "现在帐外。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "传他二人进见！"
