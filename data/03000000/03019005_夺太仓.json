{
  "script_id": "03019005",
  "title": "夺太仓",
  "alias": [],
  "source": "《京剧汇编》",
  "characters": [
    {
      "name": "张秀莲",
      "hangdang": "武旦"
    },
    {
      "name": "张虬",
      "hangdang": "老生"
    },
    {
      "name": "徐达",
      "hangdang": "老生"
    }
  ],
  "plot": "元末，徐达奉朱元璋命剿吴越，进兵姑苏，太仓为咽喉要路，故先取之。常遇春奉命为先行，敌将赵玠、吕\n珍不敌归降。太仓守将张虬亲自出征，亦为常遇春击败。张虬女张秀莲颇娴武艺，代父出征，徐达之部将皆\n不能敌。徐达亲自出战，用绊马绳使张秀莲落马而擒之，始夺下太仓。",
  "notes": "《夺太仓》故事出于《明英烈》。\n此本为阎岚秋（九阵风）先生生前演出本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "常遇春、华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英双上，双起霸。〖点绛唇〗。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "常遇春。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "华云龙。"
        },
        {
          "character": "曹良臣",
          "type": "白",
          "text": "曹良臣。"
        },
        {
          "character": "俞通海",
          "type": "白",
          "text": "俞通海。"
        },
        {
          "character": "孙兴祖",
          "type": "白",
          "text": "孙兴祖。"
        },
        {
          "character": "朱亮祖",
          "type": "白",
          "text": "朱亮祖。"
        },
        {
          "character": "郭英",
          "type": "白",
          "text": "郭英。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "沐英。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "列位将军请了！"
        },
        {
          "character": "华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "前者徐元帅用连环计败走张士诚，斩了金镇远。主上遣使到此，要夺取姑苏。 徐元帅升帐，你我两厢伺候！"
        },
        {
          "character": "华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。四红文堂、四红大铠、中军引徐达同上。"
        },
        {
          "character": "徐达",
          "type": "引子",
          "text": "驰骋沙场，保皇家，雨露苍生。"
        },
        {
          "character": "徐达",
          "type": "念",
          "text": "征马长嘶吴苑风，还怜平子思徒穷。悬知往古经行处，好问当年李牧功。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "本帅，徐达。奉圣上之命，剿灭吴越。前者从京口欲直下姑苏。主上来旨催兵 前进，为此升帐与众将商议。 中军，传众将进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春、华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英自两边分上。"
        },
        {
          "character": "常遇春、华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英",
          "type": "同白",
          "text": "报！诸将告进！参见元帅！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "常遇春、华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英",
          "type": "同白",
          "text": "元帅召集我等有何军情议论？"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "圣上要夺取姑苏，因此与众位将军商议如何进兵？"
        },
        {
          "character": "常遇春、华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英",
          "type": "同白",
          "text": "启元帅：要夺姑苏必须先取太仓，方可进兵。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "本帅亦是此见。太仓乃张虬镇守，此人智比班超。策比孙武，不可轻敌。"
        },
        {
          "character": "常遇春、华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英",
          "type": "同白",
          "text": "我兵五十万之多，顺江而下，那张士诚亲自领兵尚且败走，何况那小小郡城也。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "郡城虽小，不可轻敌，还是小心为是。如今计议已定，就此兴兵。 常遇春听令！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "你可领兵三千作为先锋，本帅大兵随后接应。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "得令。 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠引常遇春同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "曹良臣、俞通海、朱亮祖，命你等领兵三千二队接杀！"
        },
        {
          "character": "曹良臣、俞通海、朱亮祖",
          "type": "同白",
          "text": "得令。 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手自两边分上，领曹良臣、俞通海、朱亮祖同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "众将官，兵发太仓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "探子",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "人行千里路，马走万重山。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "俺，太仓张元帅帐下能行探子是也。打听徐达人马来取太仓，军情紧急，就此 马上加鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二院子引张虬同上。"
        },
        {
          "character": "张虬",
          "type": "引子",
          "text": "职任藩篱，仗智谋，所向无敌。"
        },
        {
          "character": "张虬",
          "type": "念",
          "text": "膂力过人胆气雄，貔貅百万肃军容。还将三镇幽燕地，乘胜都归掌握中。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "老夫，张虬。在吴王张士诚驾下为臣，奉命镇守太仓。我年已花甲，膝下无嗣。 所生一女，名唤秀莲，年已二八，尚未择配。只是她不习针黹，偏喜武艺。 这且不言，时当三秋，堂下菊花盛开，且请夫人一同赏玩。 来，请夫人、小姐出堂！"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "有请夫人、小姐出堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟引张氏、张秀莲同上。"
        },
        {
          "character": "张氏",
          "type": "引子",
          "text": "梧桐叶落，帘外秋风冷，"
        },
        {
          "character": "张秀莲",
          "type": "引子",
          "text": "翡翠屏开，堂前玳瑁寒。"
        },
        {
          "character": "张秀莲",
          "type": "白",
          "text": "爹娘万福！"
        },
        {
          "character": "张虬、张氏",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "唤妾身出来，为了何事？"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "园中菊花盛开，请夫人同女儿玩赏。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "妾身奉陪。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "来，去到花园。 夫人请！"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "老爷请！"
        },
        {
          "character": "张虬",
          "type": "唱",
          "text": "当此秋高清凉景， 紫艳菊花满园亭， 人生一世如春梦， 老来无嗣独伤情！"
        },
        {
          "character": "张氏",
          "type": "唱",
          "text": "世上万般都是命， 看来由命不由人。"
        },
        {
          "character": "张秀莲",
          "type": "唱",
          "text": "玩赏园亭为遣兴， 爹娘为何珠泪淋？ 儿虽女流晓经纶， 要学曹娥女钗裙。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "张虬",
          "type": "唱",
          "text": "我儿伶俐多聪敏， 说什么曹娥女钗裙。 我儿从来多孝顺， 承欢色笑在家门。 将今比古对我论， 破啼为笑散愁云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "念",
          "text": "飞报辕门军情紧，后堂说与老元戎。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启老爷：吕将军同众将有紧急军情，请老爷升堂。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "吩咐众将伺候！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "请夫人、我儿暂退！"
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "何处风云紧，"
        },
        {
          "character": "张秀莲",
          "type": "念",
          "text": "恐是有军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吕珍上。"
        },
        {
          "character": "吕珍",
          "type": "念",
          "text": "风吹旌旗动，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵玠上。"
        },
        {
          "character": "赵玠",
          "type": "念",
          "text": "燕山月照营。"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "吕珍",
          "type": "白",
          "text": "吕珍。"
        },
        {
          "character": "赵玠",
          "type": "白",
          "text": "赵玠。"
        },
        {
          "character": "吕珍",
          "type": "白",
          "text": "请了！探子报道，徐达领兵来取太仓，如何是好？"
        },
        {
          "character": "赵玠",
          "type": "白",
          "text": "看此光景，吴主当灭，朱蛮当兴，你我须要见机而行！"
        },
        {
          "character": "吕珍",
          "type": "白",
          "text": "不必多言，且候主帅升帐，看他如何破敌。"
        },
        {
          "character": "赵玠",
          "type": "白",
          "text": "有理。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠引张虬同上。"
        },
        {
          "character": "张虬",
          "type": "念",
          "text": "日督千军坚壁垒，夜坐甲帐守城池。"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "将军少礼。有何军情？"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "边报求见。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "传！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "探子叩头！"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "所报何事？"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "哎呀老爷，大事不好了！今有主公兵败，金将军阵亡。徐达统兵五十余万，直 奔太仓而来，好不威严也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "再去打探！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "吕珍、赵玠听令！命你二人带兵一千，攻打头阵！"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "元帅，朱蛮领兵五十余万之众，命我二人带一千人马，如何抵挡？"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "不必多言，某大兵随后接应。听俺一令！"
        },
        {
          "character": "张虬",
          "type": "唱",
          "text": "一令传谕二将晓， 养军千日用一朝。 平日说你本领好， 今朝正好立功劳。 凯旋归来功不小， 失机败阵不轻饶。"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "吕珍",
          "type": "唱",
          "text": "将令一出如山倒，"
        },
        {
          "character": "赵玠",
          "type": "唱",
          "text": "好歹只得走一遭。"
        },
        {
          "character": "吕珍",
          "type": "唱",
          "text": "要得显功须及早，"
        },
        {
          "character": "赵玠",
          "type": "唱",
          "text": "只怕丧命在今朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕珍、赵玠同下。"
        },
        {
          "character": "张虬",
          "type": "唱",
          "text": "徐达谋略难逆料， 吕珍、赵玠把贼剿。 后帐且听探马报， 还须本帅自勤劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四大铠引常遇春同上。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "奉了元帅将令攻打头阵。众将官，奋勇当先！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四蓝马甲引吕珍、赵玠同上。会阵。"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "呔！来将通名受死！"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "扫东大将军常遇春是也！尔等无能之辈，敢来交战？快叫张虬出马，饶你二人 不死！"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "常遇春休要夸口，着我们的家伙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕珍、赵玠同杀，众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吕珍、赵玠同上。"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "杀败了哇，杀败了！"
        },
        {
          "character": "赵玠",
          "type": "白",
          "text": "吕将军，常遇春十分厉害，你我不能取胜，如何是好？"
        },
        {
          "character": "吕珍",
          "type": "白",
          "text": "未出兵之时，张虬言道，若不取胜，罪不轻饶。如今果然败阵，只好归降的为 是。"
        },
        {
          "character": "赵玠",
          "type": "白",
