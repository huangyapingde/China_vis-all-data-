    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝大铠、四女兵引张秀莲同上。"
        },
        {
          "character": "张秀莲",
          "type": "念",
          "text": "威风凛凛独当关，跃马提刀赴阵前。千古英雄谁不羡，芳名遗入简编看。"
        },
        {
          "character": "张秀莲",
          "type": "白",
          "text": "俺，张秀莲。可恨朱兵甚是猖狂，我要代父出征。 众将官，国家危难，须尽其忠。今日必要努力当先杀贼，听俺吩咐！"
        },
        {
          "character": "张秀莲",
          "type": "八声甘州",
          "text": "扬威奋勇， 看长江波浪水平风静。 盔甲鲜明，战马如飞， 旌旗飘绕，俺秀莲保定洪。 哪怕兵多将勇， 我境休使他人逞！ 人如虎，马如龙， 顷刻之间邦家定。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张秀莲领四蓝大铠、四女兵同出城。四上手引沐英同上。"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "呔！马前女将通名上来！"
        },
        {
          "character": "张秀莲",
          "type": "白",
          "text": "听了！俺乃张元帅之女秀莲是也。贼将何名？"
        },
        {
          "character": "沐英",
          "type": "白",
          "text": "俺乃扫东大将军沐英是也。"
        },
        {
          "character": "张秀莲",
          "type": "白",
          "text": "贼子呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。张秀莲战沐英。沐英败下。张秀莲、四蓝大铠、四女兵同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红大铠引朱亮祖、常遇春同上。"
        },
        {
          "character": "朱亮祖",
          "type": "白",
          "text": "请了！沐英前去讨战，未知胜败如何。奉元帅将令，前去助战，就此前往。 众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "沐英上，张秀莲上，战沐英，沐英败下，张秀莲下。"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四上手、四女兵同上，同打单对子下。张秀莲、沐英同上，同起打。朱亮祖上，接，常遇春上，接，同败"
        },
        {
          "character": null,
          "type": "text",
          "text": "下。）"
        }
      ]
    },
    {
      "scene_id": 17,
      "name": "第十七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹良臣、吕珍、郭英、孙兴祖、俞通海、吕珍、赵玠、华云龙、徐达同上。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "身为元帅掌兵机， 统领三军征淮西。 张虬坚守弹丸地， 不识天命抗王师。 眼看太仓夷平地， 他蝼蚁怎把泰山欺！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：有一女将勇不可当，诸将不能取胜。特来报知！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "啊！一女将竟有如此厉害么！"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "元帅不知，此乃张虬之女，武艺高强。待我二人出马，将她擒来，以为进身之 功。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "须要小心！"
        },
        {
          "character": "吕珍、赵玠",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕珍、赵玠同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "他二人未必便能取胜。华云龙！你可带兵三千前去接应，本帅大兵即至！"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同上，领华云龙同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "众将官，随本帅接应者！"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "听说女将勇无敌， 巾帼英雄属第一。 一人怎能把万军抵？ 且到阵前看端的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 18,
      "name": "第十八场",
      "utterances": [
        {
          "character": "张虬",
          "type": "内西皮导板",
          "text": "皂雕旗不住空中飘，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、张虬同上。"
        },
        {
          "character": "张虬",
          "type": "唱",
          "text": "越杀越勇女英豪。 探马不住纷纷报， 他说我儿立功劳。 这等奇闻从来少， 大将不及女多娇。 转危为安城池保， 徐达怎敢入虎巢？ 三军擂鼓响火炮， 壮威呐喊把旗摇。 （四蓝文堂、四蓝大铠同下。张虬上高台。张秀莲上，四上手同接攒。沐英、常遇春同上，同打三股荡，沐 英、常遇春同败下。赵玠上。）"
        },
        {
          "character": "赵玠",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": "张秀莲",
          "type": "白",
          "text": "啊！赵玠你背主投降，是何理也！"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "儿呀！与我将此贼擒来！"
        },
        {
          "character": "赵玠",
          "type": "白",
          "text": "小姐女流，身体娇弱，如何交战？依我相劝归降徐元帅的好。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "放屁！儿呀，将此贼拿住，方消我心头之恨。"
        },
        {
          "character": "张秀莲",
          "type": "白",
          "text": "贼子呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。张秀莲杀死赵玠。吕珍上，战张秀莲。"
        },
        {
          "character": "张秀莲",
          "type": "白",
          "text": "贼子！哪里走！"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "儿呀！杀呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张秀莲杀死吕珍，下。"
        },
        {
          "character": "张虬",
          "type": "白",
          "text": "杀得好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。四上手、华云龙同上。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "奉元帅将令，前去接战。 众将官，杀上前去！ （华云龙、四上手同下。张秀莲引常遇春、沐英同上，同走圆场，同下。华云龙上，四女兵同上。华云龙、 张秀莲同杀。华云龙败，张秀莲追下。）"
        },
        {
          "character": "张虬",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "张虬",
          "type": "唱",
          "text": "战鼓不住咚咚敲， 敌营杀出一英豪。 人高马大年纪小， 杀气腾腾上九霄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四女兵同上，同起打。华云龙上，张秀莲追上，打。众人同下。"
        },
        {
          "character": "张虬",
          "type": "唱",
          "text": "大刀摆动如龙搅， 亚似当年小马超。 我儿虽勇力总小， 久战犹恐落下梢。 （张虬下。众人同打上。华云龙上，张秀莲上，对刀下。众认同上，同打下。徐达、张虬二龙出水会阵。徐 俞通海、孙兴祖、朱亮祖、郭英、沐英、四上手、徐达同上。）"
        },
        {
          "character": "达杀张虬败下。张秀莲上，杀沐英、常遇春、华云龙、徐达同败下。张秀莲退下。常遇春、华云龙、曹良臣、徐达",
          "type": "白",
          "text": "女将厉害。 众将官，绊马索擒她！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张秀莲上，接杀，众人同擒张秀莲、张虬。徐达进城。挖门。众人同上。"
        },
        {
          "character": "常遇春、华云龙、曹良臣、俞通海、孙兴祖、朱亮祖、郭英、沐英",
          "type": "同白",
          "text": "张虬父女被擒，得了太仓！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "后帐摆宴，与众位将军贺功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扯斜门。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}