        {
          "character": "徐达",
          "type": "白",
          "text": "众将官，起兵前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。众人同走圆场，四蓝大铠、四蓝文堂、张虬同上，会阵。"
