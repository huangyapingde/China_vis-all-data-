{
  "script_id": "70903102",
  "title": "单刀会·刀会",
  "alias": [],
  "source": "侯少奎剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "净"
    },
    {
      "name": "周仓",
      "hangdang": "丑"
    },
    {
      "name": "鲁肃",
      "hangdang": "末"
    }
  ],
  "plot": "刘备向孙权借驻荆州，历久未还。鲁肃设宴，邀请守将关羽。关羽仅带周仓一人，持单刀赴会。鲁肃在筵前，\n索取荆州。关羽斥责鲁肃不应埋设伏兵，反而将鲁肃执住，鲁肃只得作罢。关羽遂鼓帆而去。",
  "notes": "《单刀会》是元代伟大剧作家关汉卿的名著。全剧曲词写得雄壮豪迈，慷慨激昂。至今已有五百多年的历史，\n但传唱不衰，并为其他剧种所移植改编。在北方昆曲舞台上是优秀传统剧目之一。此剧很受观众喜爱和赞\n赏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四将、二旗牌、四文堂引鲁肃同上。"
        },
        {
          "character": "鲁肃",
          "type": "引子",
          "text": "三国鼎立，保东吴，社稷安康。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "群雄纷纷摆战场，各为其主保家邦。收回荆州归吴地，吴侯基业万年长。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "本督鲁肃，自从公瑾归天之后，吴侯命我执掌水军都督之职，只因刘备久借荆 州不还，吴侯与我定下一计，约请关羽过江赴会，席前与他讨还荆州，他若不 允，将他囚在东吴再作计较。 啊，众位将军！"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "都督。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "少时关羽过江赴会，你等埋伏两厢，听我摔杯为号，将他拿住，不得有误。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "安排酒宴请关羽。为讨荆州费心计！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、四将、二旗牌、四文堂同下。"
        },
        {
          "character": "周仓",
          "type": "内白",
          "text": "啊哩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓上。"
        },
        {
          "character": "周仓",
          "type": "念",
          "text": "志气凌云出九霄，周仓随驾显英豪。父王独赴单刀会，全凭青龙偃月刀。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "今日东吴鲁大夫请俺父王过江赴宴，只得在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽内嗽。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "道言未了，俺父王出舱来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四水手、四飞虎旗、大纛、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "浪涛滚滚渡江东，独赴单刀孰与同。片帆瞬息西风力，鲁肃今日认关公。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "船行至哪里？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "启父王来此已是大江了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吩咐艄手，风帆不要拉满，将船缓缓而行，某要观江景。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓！ 得，艄手听着，父王有令，风帆不要扯满，将船缓缓而行！俺父王要观看江景。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同允。关羽观江景。曲牌收。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好一派江景也！"
        },
        {
          "character": "关羽",
          "type": "新水令",
          "text": "大江东去浪千叠， 趁西风驾着小舟一叶。 才离了九重龙凤阙， 早来探千丈虎狼穴。 大丈夫心烈，大丈夫心烈， 觑着那单刀会西村社。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看这壁厢山连着水，那壁厢水连着山，我想二十年前隔江斗智，曹兵八十三万 人马，屯在赤壁之间，也是这般山水，到今日……"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "依旧的水涌山叠， 依旧的水涌山叠， 好一个年少的周郎， 恁在何处也？ 不觉的灰飞烟灭。 可怜黄盖暗伤嗟， 破曹樯橹，恰又早一时绝， 只这鏖兵江水犹然热， 好教俺心惨切。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "好水呀！好水！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这不是水。"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "这是那二十年流不尽的英雄血。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌甲上。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "有请都督。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "水军当大任，为国秉忠诚。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "关羽过江。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "噢！说我出迎。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "都督出迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌甲下。鲁肃上船与关羽、周仓相见。鲁肃下船登岸。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "早知君侯驾到，理当远迎，接待不周，望勿见罪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢，某有何德能，敢劳大夫置酒张筵。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "酒非洞府之长春，肴乃人间之非意。敢劳君侯屈高就下，降尊临卑，实乃东吴 之万幸也。一路江风寒冷，请君侯先饮三杯御寒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "来，看酒！ 头杯奉敬君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，主不吃。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "客不饮。"
        },
        {
          "character": "关羽",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "鲁肃",
          "type": "笑",
          "text": "啊！"
        },
        {
          "character": "关羽、鲁肃",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "照杯。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "二杯奉敬君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "酒不饮单。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "笑",
          "text": "哈哈哈哈。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "三杯奉敬君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫可知某家刀，也会饮酒？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "名将必有宝刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀来！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀吓！刀！想你在万马军中取上将首级能如探囊取物一般，今日鲁大夫请俺过 江赴会，席前若有不平之事也少不得劳你一劳，先饮一杯！ 大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上，同搜场，同埋伏两厢。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "请上酒。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "呔！哈哈，啊！哇呀呀呀……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！大夫！大夫！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯请！君侯请！君侯我们还在哪里一别直至如今！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你我当阳一别直至如今！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "噢，当阳，咳，想光阴似骏马加鞭，日月如落花流水去得好疾也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "果然去得好疾也！"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "想古今立勋业，"
        },
        {
          "character": "鲁肃",
          "type": "夹白",
          "text": "舜有五人。"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "哪里有舜五人，"
        },
        {
          "character": "鲁肃",
          "type": "夹白",
          "text": "汉有三杰。"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "汉三杰， 两朝相隔只这数年别， 不复能够会也， 恰又早这般老也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯不老，下官倒也苍了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "皆然。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "一样。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "鲁肃",
          "type": "笑",
          "text": "啊，哈哈哈……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "使得！"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "开怀来饮数杯，"
        },
        {
          "character": "鲁肃",
          "type": "夹白",
          "text": "君侯！"
        },
        {
          "character": "鲁肃",
          "type": "胡十八",
          "text": "请开怀饮数杯，"
        },
        {
          "character": "关羽",
          "type": "夹白",
          "text": "大夫！"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "某只待要尽心儿可便醉也！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问君侯，当日辞曹归汉，弃印封金，过关斩将，千里独行，这些事儿，下官 只是耳闻，未曾目睹，请君侯试说一遍，下官洗耳恭听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，想某这些事，闻者倒也平常，见者却也惊人。大夫若不嫌絮烦，待某出 得席去，手舞足蹈，说与大夫听。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "领闻。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "卸袍。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、周仓同下。关羽上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那日辞曹归汉，弃印封金，出得城去，那日色刚刚乍午！"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "只听得韵悠悠画角绝，韵悠悠画角绝， 昏惨惨日得这西斜， 曹丞相满捧着香醪， 他自将来某只待在马上接。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "曹丞相，赶来赠君侯何物？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "红锦战袍，要赚某下马。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯可曾下马？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某在马上一躬说道：“丞相！恕关某不下马者！”"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "某就卒律律刀挑了锦征袍，某只待去也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯，挑了征袍，又行至哪里？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "古城。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "古城是令兄令弟所居之处，弟兄自然相会了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥，三弟，俱在城楼之上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "令弟三将军呢？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟乃是一员虎将，他就说道：“呀呔！我把你这红脸的！你既降曹又来则 甚？”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯如何分说？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某百般样的分说，他只是不信！他只是不信哪！"
        },
        {
          "character": "关羽",
          "type": "太平令",
          "text": "啊呀大夫好教某浑身是口怎样分说， 脑背后将军猛烈， 那素白旗上他就明明得这标写。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "标写什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "蔡阳。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯与蔡阳无仇吓！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "只因在东陵关斩了他外甥秦琪，故而前来报仇。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯说些什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某说道：“三弟快将城门打开，将二位皇嫂车辆接进城区，助俺一支人马， 待俺立斩蔡阳。”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时三弟可曾应允，将军说些什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟说道：俺今开了城门，岂不被你杀个里应外合！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯如何分说？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那是某将二位皇嫂车辆，就撵在一旁，说道三弟擂鼓者！"
        },
        {
          "character": "关羽",
          "type": "太平令",
          "text": "只听得扑通通鼓声儿未绝，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓上。"
        },
        {
          "character": "关羽",
          "type": "太平令",
          "text": "忽喇喇——"
        },
        {
          "character": "关羽",
          "type": "夹白",
          "text": "郎头——"
        },
        {
          "character": "关羽",
          "type": "太平令",
          "text": "征鞍上骤也， 卒律律刀过处以雪——"
        },
        {
          "character": "关羽",
          "type": "夹白",
          "text": "喀嚓——"
        },
        {
          "character": "关羽",
          "type": "太平令",
          "text": "人头儿落也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "斩了蔡阳，令兄令弟自然相会了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时三弟将城门大开，将二位皇嫂车辆接进城去，俺弟兄三人挽手而行，大夫！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯！"
        },
        {
          "character": "鲁肃",
          "type": "太平令",
          "text": "才能够兄弟哥哥每欢悦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、鲁肃同笑。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问君侯这节事叫做什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "以德报德，以直报怨。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是吓，好个以德报德，以直报怨。我想借物不还，谓之怨也。想君侯熟读《春 秋》、《左传》，通晓兵书匡扶社稷，济困扶危，谓之仁也；待令兄玄德公亲 如骨肉，视曹操如寇仇，谓之义也；辞曹归汉，弃印封金，过关斩将千里独行， 谓之礼也；缚于禁擒庞德水淹七军，谓之智也。想君侯仁义礼智四字俱全， 咳，可惜吓，可惜！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "可惜什么？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "可惜么，单单缺少一个“信”字啊！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫！想关某从未失信于人。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯虽未失信，令兄玄德公曾失信于下官来。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥乃仁德之君，岂肯失信于汝？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯你忘了，昔日贤昆仲兵败当阳，身无所归，那时孔明只与下官同见吾主， 暂借荆州，以为养军之地，至今数载不还，是何理也？为此今日，下官低情屈 意，暂恳荆州归还吾主，待等仓库丰盈，再献于君侯掌管，鲁肃也不敢自专， 伏乞君侯台鉴。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，今日请某饮酒，还是索取荆州？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这酒是要饮，荆州也要还。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "周仓",
          "type": "庆东元",
          "text": "我把你真心儿待， 恁将这筵宴来设， 攀今吊古分什么枝叶。 在某跟前使不得之乎者也，诗云和那子曰。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "荆州乃是东吴之地。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "少讲！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "关羽",
          "type": "庆东元",
          "text": "但开言管教恁剜口绝舌。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孙刘结亲，原为两家和好。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "却又来。"
        },
        {
          "character": "关羽",
          "type": "庆东元",
          "text": "有义孙刘——"
        },
        {
          "character": "关羽",
          "type": "夹白",
          "text": "目下——"
        },
        {
          "character": "关羽",
          "type": "庆东元",
          "text": "反成作吴越，"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问君侯什么响？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "剑响。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "主何吉凶？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "人头落地。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "响过几次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三次。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第一？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "熊虎。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第二？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "卞喜。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第三？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这第三？莫非轮着大夫你了！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊呀，言重吓，言重！下官与他无仇吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "听着！"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "此剑神威不可挡，庙堂之上岂寻常！筵前提起荆州事，一剑管教你子敬亡！"
        },
        {
          "character": "关羽",
          "type": "雁儿落",
          "text": "凭着恁三寸不烂舌， 休恼俺三尺无情铁，"
        },
        {
          "character": "关羽",
          "type": "夹白",
          "text": "此剑——"
        },
        {
          "character": "关羽",
          "type": "雁儿落",
          "text": "饮餐上将头， 渴饮那仇人血， 龙在鞘中蛰， 虎向座间歇。 今日个故友们重相见， 休教俺弟兄们相间别， 子敬听者：心下休惊怯， 畅好日西斜。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯莫非醉了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "雁儿落",
          "text": "吾当酒醉也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯果然醉了。 军士们！"
        },
        {
          "character": "四文堂",
          "type": "内同白",
          "text": "有。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "依计而行。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "可有埋伏？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "并无埋伏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "并无埋伏你看哪！"
        },
        {
          "character": "关羽",
          "type": "雁儿落",
          "text": "恰怎生闹吵吵三军列， 有谁人把俺挡拦者， 挡着俺呵管叫你剑下身亡目前见血， 恁便有张仪口蒯通舌。"
        },
        {
          "character": "关羽",
          "type": "夹白",
          "text": "哪里去躲藏者？"
        },
        {
          "character": "关羽",
          "type": "雁儿落",
          "text": "你且来来来—— （关羽拉鲁同下，周仓随下。四文堂、四将同上，同追过，同下。〖急急风〗。关平、四水手同上，关羽携 鲁肃同上，周仓随上。）"
        },
        {
          "character": "关羽",
          "type": "雁儿落",
          "text": "好好送某到船上和你慢慢别。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请大夫过船，谢宴。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "请大夫过船谢宴。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "匆匆拜上君侯，说我再也不敢过船去了。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "谅你不敢，待俺斩断船缆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "受惊了！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "好说，好说。"
        },
        {
          "character": "关羽",
          "type": "尾声",
          "text": "承款待多多谢， 某有两句话儿，恁可也牢牢记者： 百忙里称不得老兄心， 急切里夺不得汉家的基业。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是是是"
        },
        {
          "character": "关羽",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "开船。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}