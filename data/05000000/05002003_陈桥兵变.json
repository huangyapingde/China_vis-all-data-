        {
          "character": "韩通",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "韩通",
          "type": "唱",
          "text": "精忠报国心一点， 定灭逆贼息狼烟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩通下。"
        },
        {
          "character": "范质",
          "type": "唱",
          "text": "威勇无敌赵检点，"
        },
        {
          "character": "王溥",
          "type": "唱",
          "text": "只恐韩通难保全。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引罗彦威同上。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "二相国请了。"
        },
        {
          "character": "范质、王溥",
          "type": "同白",
          "text": "罗将军怎么回朝来了？"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "陈桥兵变，已立赵检点为天子，特命俺先回，奉请二位相国，伺候金殿朝见。"
        },
        {
          "character": "范质、王溥",
          "type": "同白",
          "text": "啊，赵检点自立，岂不是篡夺吗？"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "黄袍加身，郭威得天下先有例样，况且赵家，应天顺人。不必多言。 众将官，扶了前行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗彦威、四下手扶范质、王溥同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陶谷上。"
        },
        {
          "character": "陶谷",
          "type": "唱",
          "text": "纷纷传说陈桥变， 吉凶只在眼面前。"
        },
        {
          "character": "陶谷",
          "type": "白",
          "text": "下官，翰林承旨陶谷。适才闻得陈桥兵变，赵检点已为天子，人马回京，这柴 王孤儿寡母，如何抵御？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陶谷笑。"
        },
        {
          "character": "陶谷",
          "type": "白",
          "text": "我想翊戴之功，岂让他人独占，我不免趁此草下受禅诏书，候他到来，当殿赞 读，册立天子。开国之初，岂不是我大大的功劳？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陶谷笑。"
        },
        {
          "character": "陶谷",
          "type": "白",
          "text": "就是这个主意。"
        },
        {
          "character": "陶谷",
          "type": "唱",
          "text": "富贵功名该应显， 草写诏书我抢先。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陶谷下。"
        }
      ]
    },
    {
