{
  "script_id": "05002003",
  "title": "陈桥兵变",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    }
  ],
  "plot": "北汉刘祟辽国联军入寇后周，殿前都点检赵匡胤奉命挂帅出征。途中，民谣四起，天空又复出一红日。苗训\n观天兆有变，知赵匡胤将受禅，行至陈桥，诸将遂为赵匡胤黄袍加身，拥之为帝。赵匡胤向众将约三事，并\n遣王彦升先行回京，晓喻军民。韩通不服，兴兵反抗，为王彦升所杀。赵匡胤以王彦升违约，欲斩之。经众\n将保奏，始得赦免。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四纛旗、高怀德、石守信、罗彦威、王彦升同上。"
        },
        {
          "character": "高怀德",
          "type": "念",
          "text": "四海九州多变更，"
        },
        {
          "character": "石守信",
          "type": "念",
          "text": "常将功业叹韩彭。"
        },
        {
          "character": "罗彦威",
          "type": "念",
          "text": "何年卸甲天河洗，"
        },
        {
          "character": "王彦升",
          "type": "念",
          "text": "一举干戈定太平。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "俺，高怀德。"
        },
        {
          "character": "石守信",
          "type": "白",
          "text": "俺，石守信。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "俺，罗彦威。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "俺，王彦升。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "北汉刘崇与辽国结连入寇，太后懿旨，命殿前都检点赵为元帅，统领六军，前 往征讨。你我披挂，伺候起行。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "正是："
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同念",
          "text": "三军征战千年恨，一功成就万骨枯。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "话言之间，二位先生来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普、苗训同上。"
        },
        {
          "character": "赵普",
          "type": "念",
          "text": "虎啸龙吟舒壮志，"
        },
        {
          "character": "苗训",
          "type": "念",
          "text": "经文纬武定皇图。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "下官，掌行营书记赵普。"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "下官，掌行营司马苗训。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "二位先生请了。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "列位将军请了。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "元帅未到，天色尚早，请二位先生坐谈片时，以广见闻。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "如此，请坐，请。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "请问先生，近来汴京城中，大小军民人等，说话答应之声，必曰赵，不知是何 意见，主何凶吉？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "此似童谣之类，只恐必有其人应破。"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "列位不知，此乃人民口谣，还有天象变动之兆。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "请教天象有何变兆？"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "现在日光之下，复有一日，黑光迷漫，此乃天变之兆。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "啊。有这等事。"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "来，取净水一盆，放在地下，列位请看，便知分晓。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "大家同看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。高怀德、石守信、罗彦威、王彦升同看。"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "将盆拿开了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、石守信、罗彦威、王彦升同坐。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "哎呀，奇呀，果然日下复有一日，不知主何吉兆？"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "此乃天命也，即应人间口语赵字。"
        },
        {
          "character": "石守信",
          "type": "白",
          "text": "天象既然如此，现今主上幼弱，我等死命征战，谁人得知劳苦，不免立赵检点 为天子，然后北征。二位先生以为如何？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "自唐末以来，朱梁、石晋，分争篡夺，堂堂天位，竟是朝秦暮楚。如今虽有两 日之兆，检点应命之谣，但是我等同为周朝臣宰，岂可忍心推戴，此事还是静 以待之。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "哎呀先生，五代以来，僭号称尊，十有余国，天下荒荒，谁为真主？赵检点聪 明仁孝，豁达大度，远过汉高。我等立之为君，救生民于水火，焉能缓待？"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "好哇！罗将军此言甚是，有不遵者，俺先斩之。"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "列位将军，不必罗唣，此事亦非等闲。若在此言语，赵检点不从，我等全家性 命休矣。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "依先生之见如何？"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "依我之言，且候检点来到，不动声色，发兵起行，到了陈桥驿中。传令兵将一 齐鼓噪，黄袍加身，不愁检点不从。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "好哇，此计甚妙。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "照计而行，我等若有外意者，以此旗为誓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王彦升斩断旗顶。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "众心已定，就烦二位先生即速备办冲天冠、赭黄袍。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "我等自有理会。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "看旌旗招展，检点来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "引子",
          "text": "武略文韬，为将帅，未平边辽；奋志往征剿，救黎民免避差徭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、石守信、罗彦威、王彦升、赵普、苗训同参拜。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "旌旗摇指定天吴，万马军中几丈夫？莫道威名能退敌，还凭智勇往前驱。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "本帅，赵匡胤，官拜太尉，殿前都检点，奉旨统兵征剿北汉。 众将官。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你我在朝为臣，同寅协恭；出师为将，军权为重。立功定赏，犯法必诛，各宜 凛遵，休得藐视。传令起马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "已到陈桥。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "已到陈桥。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "安营住宿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人分站，高怀德、石守信、罗彦威、王彦升同附耳。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众将为何交头接耳，喜笑欢呼？"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同",
          "text": "我等见太尉红光满面，此番出征必能破敌。故此军中欢喜，不免彼此交言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤笑。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "愿此去旗开得胜，马到成功，各自歇息去吧。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四纛旗、高怀德、石守信、罗彦威、王彦升同下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "二位先生如何不去安息？"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "请发口号。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "昔日曹操用“鸡肋”二字，以至退军失利。我今用以“龙角”二字，议为必胜 之意也。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "“龙角”二字，甚为吉兆。遵命而行。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "好吉兆之象。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普、苗训同下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "尔等伺候暖酒一瓶，明烛一支，帐外歇息。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同下。〖起初更鼓〗。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "可叹这些将士，谁不功名心切，正是："
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "朝夕思悬黄金印，阵前谁惧白剑锋？"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "营门外起初更提枪发号， 灯烛下慢饮酒观看六韬。 为大将必须要智勇忠孝， 食君禄报君恩尽心保朝。 昔日里姜子牙虽然年老， 保武王伐商纣招聚英豪。 赵廉颇战渑池威风浩浩， 秦白起坑降卒命赴阴曹。 伍明辅在临潼随主斗宝， 汉朝中投笔汉定远班超。 周亚夫细柳营军规虽好， 执兵权威震主法律欠昭。 有英布和彭越立功不小， 未央宫韩元帅一命轻抛。 诸葛亮比管、乐智略还妙， 保炎汉谈笑中破了孙、曹。 到如今众英雄何处去了？ 不由我心痛切泪洒征袍。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "看至此不由我心中悲悼， 人去也国更改大数难逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤睡。赵普、苗训、高怀德、石守信、罗彦威、王彦升同上。〖起二更鼓〗。"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同唱",
          "text": "立天子传谕了六军知晓！"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同唱",
          "text": "应大势顺人心一定不摇。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "列位将军不必性急，此刻方交二鼓，且待五更，吉日吉时行事方好。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "事已泄漏，迟恐有变。"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "人心已定。天意有昭，决无更变。只等五鼓，不必着忙。"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "如此且进里营，静候起事。请！"
        },
        {
          "character": "赵普、苗训",
          "type": "同唱",
          "text": "且进营等候着吉时来到，"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同唱",
          "text": "进黄袍附骥尾龙入云霄。 （高怀德、石守信、罗彦威、王彦升、赵普、苗训同下。〖起三更鼓〗。〖吹打〗。城隍神、土地神、龙袍 王同上，同拜，同下。〖起四更鼓〗。高怀德、石守信、罗彦威、王彦升、赵普、苗训同上。）"
        },
        {
          "character": "高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "二位先生，四更已过，营中红光闪灼，吉时已到，就此进内请驾。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "列位将军，把住帐口，待我二人进内，悄悄更换黄袍。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、石守信、罗彦威、王彦升同下。〖起五更鼓〗。赵普、苗训同与赵匡胤换衣帽。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "黄袍加身，众将进内。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、石守信、罗彦威、王彦升同上。"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "啊，万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "耳边厢忽听得万岁高叫！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "莫不是有旨意召我还朝。 朦胧中睁睡眼见些将校，"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": "赵匡胤",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "众文武呼万岁所为哪条？"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "众将无主，愿立太尉为天子。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "住了，你等敢莫造反么？"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "非敢造反，乃是应天顺人。贺喜陛下，已经黄袍加身，臣等拜祝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普、苗训、高怀德、石守信、罗彦威、王彦升同跪。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎呀，此事从何而起？"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "凭空事儿实难料， 红袍换了赭黄袍。 本当推辞别计较， 又恐激变祸难逃。 华山陈抟曾言道， 说我形容胜汉高。 应命之期在癸卯， 岂知今日在陈桥。 应天顺人虽然好， 欺孤灭寡愧怎消？ 只恐日后难逃报， 子孙不知降哪朝？ 回头便把先生叫， 列位将军请听着： 弟兄三人何等好， 同经患难苦奔逃。 柴兄之情未得报， 誓愿同死胜同胞。 兄承姑业称帝号， 他命该当坐九朝。 幼主虽然年纪小， 臣篡君位骂名标。 此事不但惹人笑， 天地神明也未必饶，"
        },
        {
          "character": "赵普、苗训",
          "type": "同唱",
          "text": "天显双日空中照，"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同唱",
          "text": "人愿赵家替周朝。"
        },
        {
          "character": "苗训",
          "type": "白",
          "text": "唐室至今不及百年，天下五易。朱温，盗贼也。石敬塘，叛逆也。李存勗，沙 陀也。刘智远，匹夫也。郭彦威，点卒也。此等失德匪类，尚且谬承天命，何 况上悬天日之象，下应民赵之谣，正当践位九五，混合六一。"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "我等也好攀龙附凤，立功建国，救黎民于水火，显姓氏于丹青。即请圣驾，上 马回銮，入登大宝。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "住了！你们贪图富贵，立我以为天子，今日能从我之言语，庶乎可行。若不从 命，请别立贤人；我不能为此威逼之君也。"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "臣等情愿受命，乞请宣示。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "第一件：周朝太后、幼主，我曾北面侍奉，不得惊动；第二件：公卿大臣，皆 我比肩同寅，不得欺凌；第三件：朝市府库，百姓妇女，不得掳抢。遵命则行， 不可则止。"
        },
        {
          "character": "赵普、苗训、高怀德、石守信、罗彦威、王彦升",
          "type": "同白",
          "text": "天命已定，我等敢不凛遵。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如此，罗彦威听令。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "臣在！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "先行回京，请范质、王溥二相国，朝堂相会，不得有误。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗彦威下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "王彦升听令，你可带本部人马，先行回京晓谕文武大臣、军民人等，各安职业， 不可骚动。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王彦升下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "石守信听令。即去奏知柴太后、幼主。保护宫闱，不得误事。"
        },
        {
          "character": "石守信",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "石守信下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "高怀德听令。即去收拾宫殿，安慰家眷，不得迟误。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "二位先生吩咐人马整肃，不许惊扰百姓，按辔缓行。"
        },
        {
          "character": "赵普、苗训",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "整肃队伍，不许惊扰百姓，按辔缓行回京。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "天意虽如此，我心总不安。欲因宁宇宙，回马上金銮。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "未曾出征将鼓躁， 黄袍加身在陈桥。 飞龙在天事非小， 为君须要比唐尧。 金勒马嘶踏芳草， 人马悄悄过平桥。 看此光景是喜兆， 但愿黎民顺我朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、四下手、赵普、苗训同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "范质、王溥同上。"
        },
        {
          "character": "范质",
          "type": "唱",
          "text": "临朝几度惭伊尹，"
        },
        {
          "character": "王溥",
          "type": "唱",
          "text": "调羹不复梦周公。"
        },
        {
          "character": "范质",
          "type": "白",
          "text": "老夫，周柱国范质。"
        },
        {
          "character": "王溥",
          "type": "白",
          "text": "大平章王溥。"
        },
        {
          "character": "范质",
          "type": "白",
          "text": "人言纷纷，赵匡胤陈桥兵变，特此入朝启奏太后，老相国可知此事？"
