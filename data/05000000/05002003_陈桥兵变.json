        },
        {
          "character": "高怀德",
          "type": "哭头",
          "text": "王彦升！"
        },
        {
          "character": "石守信",
          "type": "哭头",
          "text": "王将军！"
        },
        {
          "character": "高怀德、石守信",
          "type": "同唱",
          "text": "我等作了昧心人。 可叹为国反丧命！"
        },
        {
          "character": "陶谷",
          "type": "哭头",
          "text": "我那难得见的兄啊！"
        },
        {
          "character": "范质、王溥",
          "type": "同哭头",
          "text": "我那屈死的韩将军！"
        },
        {
          "character": "赵匡胤",
          "type": "哭头",
          "text": "王彦升啊韩令公！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同哭。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "二人送命都为朕， 不伤心处也伤心。 本待饶恕恐议论， 国法无私赦难行。 马谡之才只任性， 斩他何能怨孔明？ 况且杀命来抵命， 此心也可对鬼神。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "王彦升汗马功劳成画饼，"
        },
        {
          "character": "石守信",
          "type": "唱",
          "text": "王将军莫想凌烟标姓名。"
        },
        {
          "character": "罗彦威",
          "type": "哭头",
          "text": "我那难得见的王兄啊！"
        },
        {
          "character": "罗彦威",
          "type": "唱",
          "text": "看来我们难救命，"
        },
        {
          "character": "范质、王溥",
          "type": "同哭头",
          "text": "韩元帅，韩将军！"
        },
        {
          "character": "范质、王溥",
          "type": "唱",
          "text": "忠勇何处去招魂！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "叫朕好难哪！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "斩者应斩理当应， 死者已死又难生。 代天执法无私病， 哭坏当殿君与臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陶谷笑。"
        },
        {
          "character": "陶谷",
          "type": "唱",
          "text": "哭死哭活哭混沌， 有理未曾说分明。"
        },
        {
          "character": "陶谷",
          "type": "白",
          "text": "臣陶谷启奏。韩通不服朝命，起兵抗拒，王彦升若不将他扑灭，必致朝野滋漫。 不但陛下不能安然登基，抑且六军性命不保。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "好哇。"
        },
        {
          "character": "陶谷",
          "type": "白",
          "text": "交战之际，我不杀人，人必杀我，生死相关，岂能忍让？王彦升所杀韩通，实 乃不得已而为之。"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥",
          "type": "同白",
          "text": "着啊！"
        },
        {
          "character": "陶谷",
          "type": "白",
          "text": "陛下睿智聪明，岂可学那汉高祖含泪斩丁公，遗讥后世？乞赦王彦升，方是正 理。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "好说，得明白，真好口才。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎呀，如此说来，王彦升有了生路了。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "陶谷之言高凡论， 两厢斗杀可原情。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "陶谷所奏，甚是明白，朕今赦却王彦升，众官以为如何？"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、范质、王溥",
          "type": "同白",
          "text": "陛下尧舜之心，臣等感恩不尽。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "将王彦升放转。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "呔！圣旨下，将王彦升放转。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王彦升上。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "谢恩，谢恩。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "谢万岁不斩之恩。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众臣保奏，暂且饶恕。各官俱有封赏，唯尔终身不得节铖，不加重用。"
        },
        {
          "character": "罗彦威",
          "type": "白",
          "text": "够了，够了。"
        },
        {
          "character": "王彦升",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "几载干戈，今见太平。光禄寺大摆筵宴，庆贺厥功。罚令王彦升值席谢罪。"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、范质、王溥、陶谷",
          "type": "同白",
          "text": "臣等把盏，庆贺国家，圣寿无疆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同坐，赵匡胤首坐。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "欲将杯酒酬勋策，"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷",
          "type": "同念",
          "text": "从此山河见太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "画眉序牌。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众卿听着，朕非卿等，贵不及此。然为天子，亦大艰难。坐于其上，兢兢业业， 殊不若为节度使快乐。然居此位者，谁不欲之？卿等何以教我？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷同惊跪"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷",
          "type": "同白",
          "text": "陛下何出此言？今天命已定，谁敢异心？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "卿等固然忠心扶朕，其如麾下兵将，欲图富贵，一日又将黄袍加卿之身，你们 虽然不为天子，岂能免也？"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷",
          "type": "同白",
          "text": "哎呀！臣等愚不及此，乞求陛下哀怜，指示全身之路。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "卿等平身，听朕指示。"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "人生世上心难尽， 白驹过隙快光阴。 贪图富贵却为甚， 不过金银留子孙。 不如趁此卸帅印， 解卸兵权做纯臣。 官封极品为藩镇， 歌童舞女乐天真。 大家欢乐为媒证， 朝廷世代结婚姻。 上下相安无疑病， 君君臣臣享太平。 国家必然风雨顺， 尧天舜日锦乾坤。"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷",
          "type": "同唱",
          "text": "陛下仁至又义尽， 保全功臣得重生。"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷",
          "type": "同白",
          "text": "感蒙陛下深恩，念及臣等至此，所谓生死而肉骨也。臣等即罢兵权，各就藩镇。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "卿等既愿解卸兵权，真乃国家之福。俱各加封侯爵，与国同休。"
        },
        {
          "character": "赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "从来开基聚英贤， 汉家三杰尽含冤。 光禄寺大摆功臣宴， 今朝杯酒释兵权。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。赵匡胤、赵普、苗训、高怀德、罗彦威、石守信、王彦升、范质、王溥、陶谷同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
