{
  "script_id": "05014006",
  "title": "柴桑关",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "黄忠",
      "hangdang": "老生"
    },
    {
      "name": "魏延",
      "hangdang": "净"
    }
  ],
  "plot": "诸葛亮知周瑜以收川为名，意在夺取荆州，修书付糜竺，假意前往道劳。一面点动人马，四处埋伏。周瑜得\n信，请糜竺转告刘备出城犒军。不意直到南郡城下，不见刘备踪迹。赵云揭破周瑜诡计，出城杀退吴兵。黄\n忠、魏延复迎头截杀。周瑜败走，行至芦花荡，与张飞交战，被打落马下。诸葛亮因周瑜兵败，修书相劝，\n请以联合为重。周瑜读信，自知不久于人世，修本荐鲁肃接替都督职务，连呼：“既生瑜，何生亮！”吐血\n而死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张飞、赵云、黄忠、魏延同上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "豹头环眼气轩昂。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "长坂坡前救主皇。"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "百步穿杨无人挡。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "扶保汉室锦家邦。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "赵云、黄忠、魏延",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "军师升帐，在此伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、糜竺、诸葛亮同上。〖点绛唇〗。"
        },
        {
          "character": "张飞、赵云、黄忠、魏延",
          "type": "同白",
          "text": "参见师爷！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "三顾茅庐义气深，忠心保国定乾坤。六韬三略机谋远，定把狼烟一扫平。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人诸葛亮。汉室驾前为臣。只因周郎定下假途灭虢之计，明取西川，暗夺荆 州，山人与他，计上加计。 糜子仲听令！"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这有书信一封，去到中途路上，下与周郎，不得有误！"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜竺下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "四将军听令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云应。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领人马，埋伏南城之上，高挂白旗二杆，周郎到此，接杀一阵，附耳上 来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮咬耳，赵云应下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "黄老将军听令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠应。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带领人马埋伏公安。周郎到此接杀一阵，不得有误。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠应下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏将军听令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延应。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带领人马，埋伏江陵。周郎到此，接杀一阵，不得有误！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延应下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三将军听令！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领人马，埋伏芦花荡，周郎到此，挡住他的去路，不可拿他！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "军师不拿周郎，这是为何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三将军不要暴躁，山人自有用兵之计。速速带领人马前去，不得有误！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞应下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "满江撒下钩和线，哪怕鱼儿不上钩？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丁奉、徐盛同上，双起霸。"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "丁奉。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "徐盛。"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "将军请了，都督升帐，两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点。四文堂、八马夫、周瑜同上。〖点绛唇〗。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "参见都督！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "二位将军少礼！"
        },
        {
          "character": "周瑜",
          "type": "念",
          "text": "肥马轻装白玉鞍，手执令箭攻云坛。领兵调将扶社稷，图王定霸保江南。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "本督姓周，名瑜，字公瑾。吴侯驾前为臣，官拜水军都督之职。只因领了吴侯 旨意，带领人马，替刘备代取西川。黄道吉日，正好兴兵。 二位将军，人马可齐？"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "带马，登舟去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、八马夫、丁奉、徐盛、周瑜同走圆场。船夫上。"
        },
        {
          "character": "船夫",
          "type": "白",
          "text": "参见都督！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、八马夫、丁奉、徐盛、周瑜同上船。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "拔锚开船！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖石榴花〗。"
        },
        {
          "character": "船夫",
          "type": "白",
          "text": "禀都督：大江已过。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "将船拢岸，拔锚下船！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、糜竺同上。"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "奉了军师将令，前来下书，远远望见都督大兵来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、八马夫、丁奉、徐盛、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "丁奉",
          "type": "白",
          "text": "糜子仲挡道。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "参见都督！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "罢了。糜大夫到此何事？"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "奉了军师将令，与都督下书。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "呈上来。待本帅观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜看。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "“上写大汉宗亲刘备，拜上水军都督”。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜叫头，三笑。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "果中本帅之计也。 大夫，修书不及，照书行事！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜竺、四军士同下。"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "都督为何发笑？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "二位将军，你道本督带兵，今欲何往？"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "替刘备代取西川。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "非也。哪里是替刘备代取西川，乃是暗夺荆州。你我人马到他境内，离城进处 扎营，刘备君臣为我好意，必犒赏三军，那时一伙全拿，岂不垂手而得！"
        },
        {
          "character": "丁奉、徐盛",
          "type": "同白",
          "text": "都督高才！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众将官，兵发南城！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八马夫同上，同站门，赵云上城。四文堂、八马夫、丁奉、徐盛、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "四文堂、八马夫",
          "type": "同白",
          "text": "来此南城。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "周瑜",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "见南城以上，高挂白旗二竿，城门紧闭，为了何事？莫非反中妖道的诡计不成！ 待本帅打马上前。 呔！城上儿郎听者！本督大兵到此，不开城门，是何道理？"
        },
        {
          "character": "八马夫",
          "type": "同白",
          "text": "有请四将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "忽听儿郎一声请， 原来周郎发来兵。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "城下来的敢是周都督？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "城上敢是四将军？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "正是。周都督带兵，意欲何往？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "替刘皇叔代取西川。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "住口！哪里是代取西川，分明是暗夺荆州，你道是与不是？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "住了！孙、刘两家结亲，乃是一家。言讲此话，岂有此理！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "周郎！你定下假途灭虢之计，此计只好瞒哄你东吴将士，至于诸葛先生啊！周 郎，恐怕你瞒他不了！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "周瑜",
          "type": "西皮摇板",
          "text": "听他言来心好恼， 二目圆睁似火烧。 本督错把计用了， 又中妖道计笼牢。 催马提枪南城叫， 城上的子龙听根苗： 本督大兵今已到， 要夺荆州气方消！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "人来与爷城开了……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。赵云出城，起打，周瑜败下，赵云追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、黄忠同上，同站门，同下。周瑜、赵云同上，同打，黄忠上，接杀，周瑜败下，黄忠追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、魏延同上，同站门，同下。周瑜、赵云同上，同打，魏延上，接杀，周瑜败下，魏延追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四马夫、四龙套、张飞同上，同站门。照《芦花荡》摆式。众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": "周瑜",
          "type": "内西皮导板",
          "text": "这一阵杀得我魂飞胆丧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜上。"
        },
        {
          "character": "周瑜",
          "type": "西皮二六板",
          "text": "口口鲜血吐红光， 人马行到南城上， 我与子龙摆战场。 我二人关前交一仗， 杀得我卸甲丢盔败回营房。 耳边又听得銮铃响——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延、丁奉、徐盛同上，同打四股挡。"
        },
        {
          "character": "周瑜",
          "type": "西皮快板",
          "text": "两下人马摆战场。 他国人马战场丧， 我国儿郎刀下亡！ 前面乃是芦花荡， 许多人马芦苇藏。 催战马闯过芦花荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马夫、四龙套引张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "又来汉将翼德张！ 披头散发一员将， 看他好像小周郎， 你是周郎是不是？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "通上名来好动刀枪！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "实实服了诸葛亮， 神机妙算比我强！ 公安埋伏黄老将； 江陵埋伏魏文长； 三将军埋伏芦花荡； 赵子龙杀法果然强！"
        },
        {
          "character": "周瑜",
          "type": "西皮快板",
          "text": "催马提枪把话讲， 叫声翼德听端详： 孙、刘结亲俱一样， 休把好意付汪洋！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "听一言来怒满腔， 开言大骂小周郎： 当年摆下临江会， 我大哥被你诓过江。 不是二哥保驾往， 险些一命付汪洋！ 今日来在芦花荡， 要想活命梦一场！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "翼德休要逞刚强， 刚强怎比楚霸王！ 你国军师韬略广， 我水军都督天下扬！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "周郎说话不思想， 活活气死俺老张， 你要逃走休妄想， 除非是认母投胎再造爹娘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜、张飞同起打，周瑜败下。"
        },
        {
          "character": "张飞",
          "type": "三笑",
          "text": "啊哈，啊哈，啊哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        }
      ]
    },
    {
