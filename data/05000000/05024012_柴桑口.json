{
  "script_id": "05024012",
  "title": "柴桑口",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "周循",
      "hangdang": "小生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    }
  ],
  "plot": "周瑜定假途灭虢之计，扬言代刘备取西川，实欲暗袭荆州。计为诸葛亮识破；假称犒军，诱至关前，以预伏\n之四路军马夹攻，周瑜大败，诸葛亮又以书讽之，周瑜气死。诸葛亮至柴桑口吊祭，东吴部将始欲杀之，后\n为诸葛亮哀哭所动。诸葛亮又劝庞统投刘备，安然回荆州。周瑜子周循追之，又被张飞射死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "周瑜",
          "type": "内西皮导板",
          "text": "机谋不成反折兵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、徐盛、三吴将、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "叫头",
          "text": "诸葛亮！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "我把你这村夫，气死我也。"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "咬牙切齿恨孔明。 可叹心血俱用尽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜吐。"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "失志败阵又劳神。"
        },
        {
          "character": "周瑜",
          "type": "叫头",
          "text": "且住。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "想我周瑜，几番用计，俱被孔明识破。孔明啊孔明，你道我不能取川，俺定要 夺取与你观看。也罢，不免将人马撤回南徐。 众将官，人马撤回江边，上船去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军、刘封、糜竺同上。"
        },
        {
          "character": "刘封、糜竺",
          "type": "同白",
          "text": "呔，周瑜，我们奉了军师将令，在此等候多时，还不下马受缚。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀，孔明使人挡住去路。 众将官，一齐上船。"
        },
        {
          "character": "刘封、糜竺",
          "type": "同白",
          "text": "众将放箭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、关羽、黄忠、魏延同上。"
        },
        {
          "character": "关羽、张飞、黄忠、魏延",
          "type": "同白",
          "text": "周瑜哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞、黄忠、魏延同杀，周瑜、徐盛、三吴将、四下手同下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众位将军请了。军师有令，不放他们回去，你我就在江边埋伏者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周瑜、徐盛、三吴将、四下手同上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀且住。俺本要回转南徐，可恨孔明命人挡住去路，这便怎么处？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜看。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众将官，前面什么所在？"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "巴丘。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "将人马撤回巴丘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐盛、三吴将同允，徐盛、三吴将、四下手、周瑜同走圆场。周瑜下马，坐。甘宁上。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "启都督：末将打听孔明、刘备在山头饮酒取乐。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "孔明啊孔明，你好妙计也！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "屡次兴兵龙虎斗， 损兵折将带含羞。 诸葛比俺才高妙， 枉费徒劳统貔貅。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "启都督：孔明差人下书至此。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "待我观看。 “汉军师中郎将诸葛亮致书于东吴大都督公瑾先生麾下：自柴桑一别至今，恋 恋不忘。闻足下欲取西川，亮窃以为不可。益州民强地险，刘璋虽暗弱，足以 自守。今劳师远征，转运万里，欲收全功，虽吴起不能定其规，孙武不能善其 后也。曹操失利于赤壁，志岂须臾忘报仇哉！今足下兴兵远征，倘乘虚而至， 江南虀粉矣。亮不忍坐视，特此告知，幸垂照鉴。”"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜掷书。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀气死我也。"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "气满胸膛阻咽喉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜吐血。"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "鲜血不住往上浮。 大骂孔明将我诱，"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "一片丹心付水流。"
        },
        {
          "character": "甘宁、徐盛、三吴将",
          "type": "同白",
          "text": "啊都督息怒，保重要紧。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众位将军，今番我命休矣！待我上书吴侯，说瑜不能保主，可将兵机印信付与 鲁肃执掌。众将协力报效，不失封妻荫子之日，共成大业，就烦甘将军与我带 书，叩见吴侯。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "浓墨伺候。"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "上写周瑜三叩首， 诚惶诚恐奏吴侯： 倘若为臣身死后， 鲁肃可能统貔貅。 周瑜修书顿首叩， 甘宁转达奏龙楼。"
        },
        {
          "character": "甘宁",
          "type": "唱",
          "text": "辞别都督出帐口， 披星戴月不停留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘宁下。"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "红光难忍涌出口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜吐。"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "不由虎目血泪流。 对着苍天忙叩首， 拜谢主恩谢吴侯。 五脏俱裂心血呕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜吐。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "苍天苍天！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "既生周瑜何生亮，"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "周瑜",
          "type": "唱",
          "text": "无常到万事休气绝咽喉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜死，下。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同哭",
          "text": "都督啊！"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同唱",
          "text": "都督气绝阴曹走， 可叹英雄万事休。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "众位将军，都督已死，我等好好看守，等候吴侯旨下。"
        },
        {
          "character": "三吴将",
          "type": "同白",
          "text": "有理。 众将官，紧守营门。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "争强弱动干戈烽烟未定， 多亏着诸葛亮保定乾坤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮原板",
          "text": "小周郎陪夫人行计不正， 学荀息灭虞虢又把计生。 明取那西川地暗取南郡， 我岂肯在掌握中反让他人。 想周郎见书信难遮羞忿， 管叫他丧巴丘断送残生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "免礼。赐坐。啊先生，想周郎此番见了书信，定然大怒，先生计安在哉？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公不必忧虑，山人昨晚夜观天象，见将星坠落西方，周郎必然亡故，主公不 信，少时便知明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "奉命下书到吴营，貔貅帐内报军情。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启主公、军师：小人下书与周都督，都督见书，气呕身亡，特来报知。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生所料不差，使孤敬服。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启军事。三千岁与众将具在巴丘候军师将令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "少时自有令下。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "呵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呵先生，东吴周郎一死，但不知何人领兵？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "以山人看来，定是鲁肃。亮夜观天象，见将星聚于东方，亮当以吊丧为由，去 往江东，访寻贤士，以佐主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "只恐东吴将士加害先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不妨。周郎在世，亮犹不惧，他今已死，又何患乎！山人从巴丘经过，带领赵 云前去，料然无事。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生呵！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "先生休要自逞强， 东吴人人似虎狼。 你今去把东吴闯， 怕的失机难抵访。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "主公且把宽心放， 山人胸中有主张。 任凭东吴人马壮， 自有妙计巧提防。 辞别主公出宝帐， 何惧东吴百万郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "先生此去心难放， 好叫孤王自思量。 但愿此去平风浪， 赵云跟随料无妨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐盛、三吴将同上。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同唱",
          "text": "被困巴丘等旨降， 满营将士俱挂丧。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "众位将军，都督已死，甘将军去往江夏奏知吴侯，怎么还不见到来？"
        },
        {
          "character": "三吴将",
          "type": "同白",
          "text": "且等探马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启众位将军：吴侯有旨，命鲁大夫挂帅；随后将都督尸首收殓，抬于柴桑候旨。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "鲁肃",
          "type": "内白",
          "text": "鲁都督到。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊，众位将军。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "恭喜都督，贺喜都督。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "众位将军，吴侯命我执掌军机重任，全仗众位将军同心协力，以报吴侯。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "岂敢。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "周都督尸首，可曾收殓？"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "收殓了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启都督：诸葛军师前来吊孝。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "随带多少人马？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "带领赵四将军。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "都督，孔明将周都督气死，他今前来吊孝，何不将他拿下，活祭周都督，以息 我等之恨。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎呀众位将军，孔明前来吊孝，乃是正理，若是将他拿住，岂不被天下耻笑； 况且又有赵云跟随。你们不可造次，少时到来，必须以客礼相待。"
        },
        {
          "character": "徐盛、三吴将",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎呀诸葛亮呀诸葛亮，你好大胆。你我乃是敌国，众将俱在切齿之间，何能前 来吊孝？不是我再三阻挡，你命休矣！ 啊，众位将军，少时孔明至此，看我眼色行事。 来，动乐相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。赵云、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "心雄投虎穴，胆大入龙潭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "呵都督。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生驾到，未曾远迎，望乞恕罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "岂敢。今日一来恭贺都督，二来吊祭先帅，以表我心。四将军参见都督。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "参见都督。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "少礼。 何劳先生驾临。 来，将祭礼摆设灵堂。 先生请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。诸葛亮、赵云、鲁肃、徐盛、三吴将同下，同上。赵云读祭文。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "“呜呼公瑾，不幸夭亡。修短故天，人岂不伤？ 我心实痛，酹酒一觞。君其有灵，享我烝尝。 从此天下，更无知音。呜呼痛哉，伏惟尚飨。”"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "都督，公瑾！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想你英雄盖世，贯精忠于日月，秉赤胆于东方。不幸一旦身亡。哎，好不遗恨 人也！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄导板",
          "text": "见灵台不由人泪流脸上，"
