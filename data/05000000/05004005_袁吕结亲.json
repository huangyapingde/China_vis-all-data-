        },
        {
          "character": "张飞",
          "type": "白",
          "text": "不要往徐州，就丢在我沛县，也是一样。"
        },
        {
          "character": "宋清",
          "type": "白",
          "text": "那可不行。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "放马过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "双杀。宋清、卫渎同败下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将马撤回沛县。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
