{
  "script_id": "05004005",
  "title": "袁吕结亲",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "吕布",
      "hangdang": "小生"
    },
    {
      "name": "韩印",
      "hangdang": "老生"
    },
    {
      "name": "陈珪",
      "hangdang": "老生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    }
  ],
  "plot": "纪灵归见袁术，告以吕布辕门射戟一事，并将吕布书信呈上。袁术读信，问计于大夫韩印。韩印闻吕布有女，\n请为袁术子前往求婚，以离间刘备与吕布，然后次第灭之。袁术依计遣韩印前往，与吕布相见。韩印说明\n来意，吕布留韩印于馆驿，归与妻陶氏商定许婚。随即告知韩印，许以即日送亲上门。陈珪见徐州市上悬灯\n结彩，又闻袁吕二姓结亲，韩印为媒。陈珪素知韩印为人诡诈，识破阴谋，乃穿孝服带病朝见吕布，为吕布\n吊孝。吕布问故，陈珪道破袁术阴谋，吕布大悟，乃杀韩印。宋清、卫渎自辽东贩来良马数十匹，欲献与吕\n布，中途为张飞所夺。刘备因吕布辕门射戟有功于己，责张飞劫马，命次日送还。吕布得报，大怒，率部攻\n小沛。刘备、关羽请吕布息怒罢兵，吕布不允。张飞出战，刘备、关羽相助，均为吕布所败。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四龙套、袁术同上。"
        },
        {
          "character": "袁术",
          "type": "点绛唇",
          "text": "霸占一方，自立为王，兴兵将，剿灭他邦，孤把江山闯！"
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "堂堂男儿世间无，霸占淮南立帝都。登基全凭玉玺印，扫灭烟尘半国无。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "孤，姓袁名术字公路。自从得了小霸王玉玺，孤在淮南立帝。年年狼烟不息， 孤也曾命纪灵到小沛扫灭桃园弟兄，至今未回。 伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩印上。"
        },
        {
          "character": "韩印",
          "type": "念",
          "text": "袖内乾坤大，壶中日月长。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "臣韩印参见主公。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "韩大人请坐。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "进帐则甚？"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "纪将军回朝来了。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "大王有旨：纪将军上殿。"
        },
        {
          "character": "纪灵",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵上。"
        },
        {
          "character": "纪灵",
          "type": "念",
          "text": "辕门射戟事，报与主公知。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "纪灵见驾，大王千岁！"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "去往徐州一事怎么样？"
        },
        {
          "character": "纪灵",
          "type": "白",
          "text": "吕布有书信在此，主公请看。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "原来是吕布辕门射戟，与我二家解围。 纪将军，后帐歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪灵下。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "韩大夫，孤王要灭吕布，有桃园帮助；要灭桃园，有吕布护助。一时难以下手， 大夫计将安在？"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "小某倒有一计。闻听吕布生有一女，可说配与我国殿下为妻。袁吕结亲后，先 灭桃园，后灭吕布，何愁大事不成？"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "此计甚好。备定花红彩礼，就命大夫前去提亲。正是："
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "计就月中擒玉兔，"
        },
        {
          "character": "韩印",
          "type": "念",
          "text": "谋成日里捉金乌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁术、韩印同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "站立营门外，单听将令行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩印上。"
        },
        {
          "character": "韩印",
          "type": "念",
          "text": "黄公三略安天下，吕望六韬定邦家。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "来此已是，门上哪位在？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "哪里来的？"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "烦劳通禀，袁术王帐下韩印求见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "韩大夫馆驿少坐。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "是。正是："
        },
        {
          "character": "韩印",
          "type": "念",
          "text": "胸中无有安邦论，焉能出力与皇家？"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "嗯呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩印下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "升帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四龙套、吕布同上。"
        },
        {
          "character": "吕布",
          "type": "点绛唇",
          "text": "威风抖擞，镇守徐州，霸诸侯，名扬九州，江山归我手。"
        },
        {
          "character": "吕布",
          "type": "念",
          "text": "盖世英雄志量高，虎牢关前逞英豪。赤兔战马行天下，画戟一举万将逃！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "某，姓吕名布，字奉先。霸占徐州一带等地。只因前日与袁、刘二家解围，那 纪灵回去，但不知那袁术王心下如何？ 中军，何事禀报？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "今有袁术王驾前韩大夫求见。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请韩大夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。韩印上。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "韩大夫，请哪，哈哈哈……不知大夫驾到，未能相迎，当面恕罪。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "岂敢。少问温侯金安，望乞海涵。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "岂敢。大夫到此，为了何事？"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "前日在徐州，多蒙温侯与我二家解围。我家主公，命小某前来，面谢温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "区区小事，何必挂齿。大夫可有别事？"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "我主公闻听温侯生有一女，愿请许配我国殿下为婚。命小某前来提亲，不知温 侯你可应允？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "温侯你想，我主公兵精粮足，温侯盖世英雄。袁吕结亲，何愁天下大事不成？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "大夫请到馆驿用茶，容我商议。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩印下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "转堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。院子上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "请夫人出堂。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、陶氏同上。"
        },
        {
          "character": "陶氏",
          "type": "念",
          "text": "春前有雨花开早，秋后无霜叶落迟。"
        },
        {
          "character": "陶氏",
          "type": "白",
          "text": "参见温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "夫人少礼，请坐。"
        },
        {
          "character": "陶氏",
          "type": "白",
          "text": "谢坐。温侯，将妾身叫出，有何吩咐？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "现今袁术王，命韩印前来提亲，将玉莲公主许配袁术殿下为妻，夫人意下如何？"
        },
        {
          "character": "陶氏",
          "type": "白",
          "text": "家有千口，主是一人。温侯做主就是。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "将姣儿叫出，劝说一番，再作道理。"
        },
        {
          "character": "陶氏",
          "type": "白",
          "text": "丫鬟，有请公主出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、玉莲同上。"
        },
        {
          "character": "玉莲",
          "type": "念",
          "text": "路过葡萄架，荷花满池塘。"
        },
        {
          "character": "玉莲",
          "type": "白",
          "text": "参见爹娘。"
        },
        {
          "character": "吕布、陶氏",
          "type": "同白",
          "text": "我儿罢了，一旁坐下。"
        },
        {
          "character": "玉莲",
          "type": "白",
          "text": "儿谢坐。将儿唤出，有何训教？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "我儿有所不知。有意将儿的终身大事，许配袁术王殿下。我儿心下如何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉莲羞。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "儿啦，听为父教训一番。"
        },
        {
          "character": "吕布",
          "type": "西皮二六板",
          "text": "未曾开言脸带笑， 叫一声玉莲听根苗： 我的儿生来性气傲， 娇生惯养女多姣。 此番袁吕结亲好， 万般事儿忍耐高。 为父今日将儿调教， 牢牢切切记心梢。"
        },
        {
          "character": "陶氏",
          "type": "西皮二六板",
          "text": "未曾开言珠泪掉， 点点珠泪洒胸梢。 开言便把女儿叫， 为娘言来听根苗： 三从四德要行孝， 莫落骂名千古标。 到后来你丈夫登大宝， 你就是正宫掌龙朝。"
        },
        {
          "character": "玉莲",
          "type": "西皮摇板",
          "text": "走上前来忙跪倒， 尊声爹娘听根苗： 多蒙二老来调教， 点点不忘半分毫。"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "今日玉莲喜日到，"
        },
        {
          "character": "陶氏",
          "type": "白",
          "text": "温侯，"
        },
        {
          "character": "陶氏",
          "type": "西皮摇板",
          "text": "快请月老饮通宵。"
        },
        {
          "character": "吕布",
          "type": "西皮摇板",
          "text": "夫人将玉莲梳妆好，"
        },
        {
          "character": "陶氏",
          "type": "白",
          "text": "温侯，"
        },
        {
          "character": "陶氏",
          "type": "西皮摇板",
          "text": "这点小事妻代劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陶氏、玉莲、丫鬟同下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "有请韩大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩印上。"
        },
        {
          "character": "韩印",
          "type": "白",
          "text": "温侯可曾商议好了？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "就在今天送亲上门，准备花轿伺候，后帐饮酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布、韩印同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "门子扶陈珪同上。"
        },
        {
          "character": "陈珪",
          "type": "二黄原板",
          "text": "自那日回府来身得病恙， 思想起国家事好不凄凉。 吕温侯生得来性情傲强， 不听调不听宣独霸一方。 每日里进忠言全不思想， 不听谏不听劝自作主张。 叫门子搀老夫病床来上。 我死后这徐州付与汪洋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "参见家爷，大街之上，家家户户，挂灯结彩。"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "我徐州有什么喜事不成？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "闻听人言，袁吕二家结亲。"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "袁吕结亲么？你知道何人为媒？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "袁术王帐下有一谋士韩印为媒。"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "敢是那韩印！此人诡计多谋，他见吕布与刘备交好，一时难以下手。故而袁吕 结亲，先灭桃园，后灭温侯。我岂能坐视不理？ 家院，拿孝服过来，看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子允，换衣。"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "退下了！"
        },
        {
          "character": "陈珪",
          "type": "西皮摇板",
          "text": "听罢言来心头恼， 太阳头上似火烧。 韩印惯用诡计巧， 要害温侯在今朝。 头上换了麻衣帽， 身上换了白孝袍。 手拿丧棒阳关到， 中途路上阻轿回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。花轿上。四龙套、吕布、韩印同上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "大夫当道。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "列开旗门。"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "参见温侯。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "你不是大夫陈珪么？"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "正是老臣。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "你的病症如何？"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "微微的好了。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "身穿重孝，为了何事？"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "老臣吊孝来的。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "与哪一个吊孝？"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "我与温侯你来吊孝的。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "大夫何出此言？"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "温侯啊！那袁术见你与桃园交好，难以下手。听信韩印的诡计，袁吕结亲以后， 先灭桃园，后灭温侯。到那时间，你死于乱军之中，老臣吊孝就来不及了。 今天先与你吊孝来了！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布杀韩印。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "大夫忠言，岂有不听，回府修养去罢。"
        },
        {
          "character": "陈珪",
          "type": "白",
          "text": "多谢温侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈珪下。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "将花轿撤回徐州。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
