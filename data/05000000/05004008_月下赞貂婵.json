{
  "script_id": "05004008",
  "title": "月下赞貂婵",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "貂婵",
      "hangdang": "旦"
    }
  ],
  "plot": "关羽被困土山，与曹操约下三事，暂归曹营。曹操待关羽甚厚，并派美女十名侍奉二嫂，美女中有貂婵。关\n羽月下盛赞貂婵救国之功，并许日后刘备若得天下，必有封赠，貂婵乃去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军校、旗牌、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "一片丹心扶炎汉，何日里恢复中原。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "徐州一战好惨然，相约三事依曹瞒。身在曹营心在汉，兄南弟北各一天。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室关。徐州一战，被困土山。为保二嫂，暂归曹操。曹操待某，三日一 小宴，五日一大宴；上马献金，下马献银。又赠美女十名，侍奉二嫂。这美女 之中，有貂婵在内。想当年王司徒定下连环之计，诛了董卓。那貂婵女足智多 谋，她可算巾帼丈夫也。 军校，"
        },
        {
          "character": "四军校",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看看可有明月？"
        },
        {
          "character": "四军校",
          "type": "同白",
          "text": "皓月当空。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "将纱窗撑起。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "真乃是清秋天月色灿烂， 广寒宫拥出了玉兔仙颜。 照得某美英雄赤心肝胆，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "今夜晚心有事懒把书观。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住！董卓误国专权，就有貂婵耳！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "王司徒他把那连环计献， 貂婵女可算得女中魁元。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那貂婵是甚等之人，计谋多端。吾不免将她唤至帐前，问个明白。 军校，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军校同允。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "传貂婵进见。"
        },
        {
          "character": "四军校",
          "type": "同白",
          "text": "貂婵进见。"
        },
        {
          "character": "貂婵",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂婵上。"
        },
        {
          "character": "貂婵",
          "type": "西皮摇板",
          "text": "恨只恨多薄命苦从心上， 白门楼诛良人进退两难。"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "奴家貂婵。正在后楼侍奉二位主母，忽听君侯呼唤，吾只得捧茶向前便了。"
        },
        {
          "character": "貂婵",
          "type": "西皮摇板",
          "text": "奴好比花开放风再作践， 老天爷何生奴苦命貂婵？ 曹丞相造铜雀打入下贱， 貂婵女只落得声名倒悬。 站立在宝帐口偷眼观看， 见君侯坐虎帐好不威严！ 无奈何我只得捧茶进见， 唬得我战兢兢不敢开言。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "侍女貂婵。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "怎不抬头？"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "谢君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "见貂婵生来的沉鱼落雁， 好一似天仙女降下广寒。 怪不得凤仪亭父子们迷恋， 父杀子子弑父人伦倒颠。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂婵，那厢有座，你且坐下。"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "君侯在此，哪有小婢之座？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你乃司徒之女，温侯之妻，焉有不坐之理？"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "谢君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂婵，不在虎牢关，来在曹营则甚？"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "皆因水淹下邳，白门楼诛了良人吕布，曹丞相将奴打入下贱之辈。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这也难说。你父将你先许吕布，后许董卓，是何意也？"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "君侯若问此事，一言难尽。"
        },
        {
          "character": "貂婵",
          "type": "西皮导板",
          "text": "未开言不由人泪流满面，"
        },
        {
          "character": "貂婵",
          "type": "西皮二六板",
          "text": "尊君侯在上面细听奴言： 献帝爷坐江山信任阉宦， 逼反了黄巾贼抖起狼烟。 钜鹿村反张角天下大乱， 把一个圣天子坐卧不安。 吕奉先在丁府螟蛉呼唤， 刺死了丁建阳后投董奸。 董卓贼得虎子横行作乱， 一心要谋汉室锦绣江山。 满朝的文武官袖手旁站， 因此上奴父女巧献连环。 也非是小貂婵生来下贱， 为的是献帝爷锦绣江山。 到如今顾不得出头露面，"
        },
        {
          "character": "貂婵",
          "type": "哭头",
          "text": "君侯啊！"
        },
        {
          "character": "貂婵",
          "type": "西皮摇板",
          "text": "望君侯施恻隐恕奴貂婵。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "听她言不由我心中嗟叹， 她乃是有功女流落此间。 董卓贼若不是她父女盘算， 这江山到如今老贼专权。 展愁眉睁凤眼心中转念， 汉朝中论英雄谁占魁元？"
        },
        {
          "character": "貂婵",
          "type": "唱",
          "text": "汉朝中论英雄良人吕……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽瞪眼看。"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "貂婵",
          "type": "西皮流水板",
          "text": "二君侯听此言怒发威严。 吓得我战兢兢汗流粉面， 汉朝中论英雄可算桃园。 三将军如猛虎威风八面， 跨一骑乌骓马似虎吐烟。 乌油盔乌油甲天神发现， 手使着丈八矛打将钢鞭。 两军战吼一声如同电闪， 二君侯可算得义气冲天。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "好一个貂婵女口能舌辩， 一句话说的吾毛骨悚然。 曾记得虎牢关一场大战， 恼怒了某三弟奋勇当先。 吼一声吓破了吕布肝胆， 鞭打他紫金冠坠落马前。 吕奉先他本是英雄好汉， 某三弟可算得将中魁元。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂婵，"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "你本是有功女谁敢轻慢？ 好比那浣纱婆西施一般。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "貂婵，暂且侍奉二位主母。等我大哥得了天下，定有封赠。下帐去罢。"
        },
        {
          "character": "貂婵",
          "type": "白",
          "text": "谢君侯。"
        },
        {
          "character": "貂婵",
          "type": "西皮二六板",
          "text": "貂婵女听一言喜从天降， 到如今拨浮云才见青天。 但愿得刘皇叔把位来践， 也不枉为国家下贱不堪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "貂婵下。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "曹丞相他把那美色来献， 哪知道汉关某义气冲天？ 我好比柳下惠坐怀不乱， 又好比鲁男子闭户不贪。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "但愿皇叔把位参，重整汉室锦江山。平生正气冲霄汉，关某月下赞貂婵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}