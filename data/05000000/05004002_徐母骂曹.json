{
  "script_id": "05004002",
  "title": "徐母骂曹",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "徐母",
      "hangdang": "老旦"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "程昱",
      "hangdang": "老生"
    }
  ],
  "plot": "徐庶辅佐刘备，连败曹兵；曹操乃将其母劫至许昌，劝其命子弃刘归曹，徐母不允，骂之且欲用砚击曹操。\n程昱献计，礼待徐母，诓其笔迹，欲假造徐母书以诱致徐庶。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、曹操、中军同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "执掌权威，收天下文武英豪。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "汉室江山气运终，群雄四方各争锋。老夫坐镇许昌地，搜罗天下众英雄。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫——曹操。汉室为臣。只因曹仁、李典，失守樊城。闻得刘备军中，有一 单福画策。不免请程仲德进帐，问明来历。 来，请程谋士进帐。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "请程谋士进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱上。"
        },
        {
          "character": "程昱",
          "type": "念",
          "text": "胸藏五典三略理，袖屯提兵调将才。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生请坐。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "谢坐。唤卑人进帐，有何军情？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "闻说刘备军中，有一单福画策，先生可知单福何人也？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相听禀。"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "单福家住在颍州， 其中备细有根由。 字表元直徐门后， 单名徐庶有名头。 如今落在刘备手， 丞相兴兵可把神留。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "徐庶虽有擎天手， 难敌仲德用计谋。"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "程昱比他差八九， 丞相怜才早设计谋。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "既与玄德为好友， 要想收他我也无计谋。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此人既与刘备相投，叫孤无处下手，可惜呀可惜！"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相有心要用此人，却也不难。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相差人，将徐母骗至许昌，令其修书，元直谅无不来之理。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此计甚好。后堂摆宴，与先生痛饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、程昱同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "引子",
          "text": "闷坐草堂，自凄凉，好不惨伤！"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "大儿四海访良朋，次子一命赴幽冥。可叹老身缺侍奉，孤苦伶仃在家中。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身徐庶之母。所生两个孩儿，长子徐庶，在外访友；次子徐康，中年夭寿。 撇下老身，孤苦伶仃，好不伤感人也！"
        },
        {
          "character": "徐母",
          "type": "二黄慢板",
          "text": "老身生来命不强， 不幸中年居了孀。 长子徐庶良朋访， 不幸徐康一命亡。 不盼我儿归家转， 但盼我儿把名扬。 生养死葬全不讲， 怕人说我教子无义方。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "丞相差我颍川往， 迎接徐母进许昌。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "俺，曹府家将是也。奉了丞相之命，迎接徐母进京，就此马上加鞭。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "扬鞭催马朝前闯， 抬头只见一村庄。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "借问一声，可有个徐老太太？"
        },
        {
          "character": "村民",
          "type": "内白",
          "text": "哪个徐老太太？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "徐庶、徐康之母，徐老太太。"
        },
        {
          "character": "村民",
          "type": "内白",
          "text": "前面黑漆门楼就是。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "多谢多谢。 啊徐老太太开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "门外有人把话讲， 莫非我儿转还乡？ 用手开门来观望， 见一军官站道旁。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "此处可是徐老太太家？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "哪个徐老太太？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "徐庶、徐康之母徐老太太。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你可认得？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "小人不认得。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身便是。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "老太太在上，小人叩头。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "不消。你奉何人所差？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "小人奉家主程大老爷与徐大老爷所差。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程大老爷他是何人？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "我家老爷姓程名昱字仲德，与徐大老爷同殿为官，又是八拜之交。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "他二人官居何职？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "皆是议郎。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "因何前来接我？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "二位老爷闻听徐二老爷亡故，恐老太太无人侍奉，特差小人接老太太进京，同 享荣华。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "可有书信？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "荣耀差官，何必修书。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "既然如此，外厢车辆侍候。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "这就好了哇！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "我儿在京官议郎， 迎接老身进许昌。 家将准备车一辆， 老身即刻赴京堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "门前备下车一辆， 有请老太赴京堂。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "有请老太太。"
        },
        {
          "character": "徐母",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母换衣上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "家将搀扶上车辆， 想起徐康一命亡。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "哎呀，儿啦！你哥哥接为娘进京，同享荣华。你！怎么不去？我那苦命的儿啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母哭。家将、徐母同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "曹操",
          "type": "内西皮导板",
          "text": "汉室衰危天地荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四将引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "各路烟尘起四方。 老夫时刻名士访， 但愿徐母到许昌。 将身且坐大堂上， 这就是为国求贤日夜忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "唱",
          "text": "相府门前住车辆， 见了丞相说端详。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "丞相在上，小人叩头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "徐母可曾接到？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "现在府外。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命众将前去迎接。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将、四龙套同出门，同走圆场。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "远远望见徐母来也。"
        },
        {
          "character": "徐母",
          "type": "内西皮导板",
          "text": "离了颍川奔许昌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母坐车上。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "迎接太夫人。"
        },
        {
          "character": "徐母",
          "type": "西皮原板",
          "text": "众位将军站立道旁。 我与那曹丞相无有来往， 迎接老身所为哪一桩？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "丞相请太夫人，必有大事相商。"
        },
        {
          "character": "徐母",
          "type": "西皮原板",
          "text": "袖里情由难猜想， 不见我儿在哪厢。 心急意念催车辆， 见了那曹丞相我细问端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下，四将、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "程昱先生有志量， 迎接徐母到许昌。 但愿徐庶归我掌， 哪怕刘备与孙郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "徐母到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "未见姣儿面，叫人心不安。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "丞相在上，老身万福。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人少礼。请坐。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人一路之上，多受风霜之苦。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "多谢丞相一问。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母看。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人看些什么？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我儿徐庶往哪里去了？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "现在新野。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "适才差官言道：我儿在京，官居议郎；丞相言道，我儿现在新野。此事何因说 起？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恐太夫人不肯前来，以安太夫人之心也。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "哼！乃是尔等的诡计。请问丞相，我儿在新野依佐何人？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "在新野扶助刘备，如美玉陷于泥中，明珠埋于尘垢。太夫人将他召回，奏与天 子，必有封赠也。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "太夫人修书将他召， 管叫位列在群僚。 人来看过文房宝，"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "这事其中有蹊跷。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "请问丞相，刘备是何等人物？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "他乃涿县小辈，妄称皇叔。所谓外君子内小人也。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "共灭董卓随君往， 袁术与他似参商。 老夫情把美言讲， 反把恩人当祸殃。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "可恼。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "听罢言来怒满腔， 才知就里尔的鬼计藏。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹丞相，此言差矣！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身久闻刘备乃中山靖王之后，孝景皇帝阁下之玄孙。屈身下士，恭敬待人。 仁声著于天下，义气传于四方。世之牧子、黄童白叟，无不称他为仁人君子， 当世之英雄！我儿附之，如鱼得水；如蛟龙遇风云，得其主也。汝，托汉天子 之福，名为汉相，实为汉贼！内怀谋朝篡位之心，外呈欺主专权之意。迁都许 昌，流离百姓。许田打围，众官无不怨恨。辱祢衡为鼓吏，逼死贵妃。甄氏霸 为儿媳。种种忤逆，三尺童子，无有不思杀尔之头，食尔之肉，剐尔之心，碎 尔之骨！反以玄德为逆臣，欲使我儿背明投暗，不知自耻！曹操啊曹操！你真 乃名教中之罪人，衣冠中之禽兽也！"
        },
        {
          "character": "徐母",
          "type": "西皮二六板",
          "text": "刘备本是英雄将， 仁声义气传四方。 你不是那曹嵩同胞养， 夏侯族中抛却娘。 名在朝中为首相， 内怀谋朝乱纲常。 许田打围欺主上， 无故迁都到许昌。"
        },
        {
          "character": "徐母",
          "type": "西皮快板",
          "text": "你好比当年贼王莽， 你比那董卓更猖狂。 无故差人我家往， 诓骗老身到许昌。 若是我儿归你掌， 除非日出在西方，你枉费心肠！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "相府如同刑场样， 霎时叫你一命亡。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "听罢言来气上撞， 大骂曹贼听端详： 老身既来不思往， 你拿虎口吓老娘。 本当替主扫奸党， 我手内无有这刀和枪。 文房四宝桌案放， 击死奸贼一命亡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母取砚击曹操。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "反了哇！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "人来与我上了绑， 推出斩首在云阳。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大胆恶妇，敢打老夫！ 武士手，推出斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母恨笑，下。程昱上。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "将身且把二堂上， 见了丞相说端详。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相，因何将徐母斩首？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恶妇百般叫骂，故而斩首。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "斩了徐母，恐大事不利。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相若将她斩首，她子徐庶在彼，闻听此事，必然尽心相助刘备。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "将她赦回，派人每日侍奉，一俟套出笔迹，修下家书，差人送至新野。徐庶乃 大孝之子，见了书信必随前来。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此计甚妙。 来，将徐母赦回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "欲借曹操帐下刀， 全我半世美名标。 忽听前堂赦旨到， 倒叫老身心内焦。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹操啊曹操！要杀开刀，三番两次，你家老太太，好不耐烦！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "非是老夫不斩与你，程先生言道：与你子有八拜之交，斩了你如同斩他母一般， 故而赦回。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程先生，你好多事哦。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母啊。"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "我与元直曾交好， 怎忍伯母吃一刀。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "先生只顾将我保， 我儿新野住不牢。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生，将徐母小心服侍。掩门。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "久闻曹贼多奸诈，今日一见过不差。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母恨笑。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母随小侄来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
