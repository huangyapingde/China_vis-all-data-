{
  "script_id": "05011002",
  "title": "鬼断家私",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "滕大尹",
      "hangdang": "老生"
    }
  ],
  "plot": "倪守谦临终，恐长子倪善继夺产，不利其妾梅氏及次子倪善述，乃预埋金于废屋，将全部田产皆予长子，只\n畀妾一行乐图而殁。长子果不顾妾母子。次子以行乐图献滕大尹，滕大尹勘破图轴中藏有遗嘱，乃佯作拜访，\n托鬼示出藏金，判归次子。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大客堂景。〖纽丝〗。倪守谦上。"
        },
        {
          "character": "倪守谦",
          "type": "唱",
          "text": "告职归得重病已有一载， 只为那梅氏子常挂心怀。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "老夫倪守谦。为官太守，妻已早亡，续弦梅氏，所生一子尚幼，前妻长子善继， 不习正道。老夫年迈，告职归林，身得重病，只恐难久人世，我若死后，长 子必然霸占家财，梅氏、次子必受欺害，这便怎么处？哦，有了。"
        },
        {
          "character": "倪守谦",
          "type": "唱",
          "text": "我这里在病房暗暗思想， 忽然间有一计想在胸膛。 叫家院将花笺文房呈上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。〖阴锣〗。倪守谦图画。"
        },
        {
          "character": "倪守谦",
          "type": "唱",
          "text": "这件事遇清官必解其详。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "家院，将此画送与裱匠裱成，将此张吩咐工人，裱在画的夹层之中，切莫对别 人言明。快去，立时就要。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子应，下。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "倪忠快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪忠上。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "参见老爷。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "罢了。倪忠，你将老夫上等家财，装在酒坛花缸之内，埋在内厅东西廊下。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "老爷这算何意？"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "你附耳上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪守谦与倪忠耳语。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "是是是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪忠下。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "倪守谦",
          "type": "念",
          "text": "防奸难言明，日久方知情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪守谦下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "书房景。〖小锣〗。倪善继上。"
        },
        {
          "character": "倪善继",
          "type": "念",
          "text": "自幼生来心机巧，赌博场中常常跑。就望老子早死了，每日任我自逍遥。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "我乃倪善继，爹爹倪守谦，身有重病，他若一死，这家财全都是我的了。天气 不早，不免赌场上走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善继下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "房间景。梅氏上。"
        },
        {
          "character": "梅氏",
          "type": "西皮原板",
          "text": "我老爷告职回身有重恙， 怕的是年衰迈难免无常。 但愿得苍天佑早复康壮， 也免得我母子受尽凄凉。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "奴家梅氏。配夫倪守谦，身为太守，年已花甲，告职回家，身得重病。我想他 已年迈，恐有不测，我儿年幼，不能知事。前子善继，不习正道，常有恶言相 待，若是老爷去世，他必然吞谋家财，我母子何以为靠？不免将老爷请出，议 论后事。 有请老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖纽丝〗。倪善述扶倪守谦同上。"
        },
        {
          "character": "倪守谦",
          "type": "唱",
          "text": "正在卧床睡刚醒， 夫人请我为何情？"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "夫人。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "老爷病体如何？"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "咳！只恐难久于人世也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏哭。院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "禀老爷，字画裱成，老爷请看。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "你且退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子应，下。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "儿吓，你哥哥那里去了？"
        },
        {
          "character": "倪善述",
          "type": "白",
          "text": "今天早晨，我看他往前村去了。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "你去往前村，将你兄长与嫂嫂唤来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善述下。"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "啊夫人，想我这病，只怕难好，我死之后，那善继奴才，必吞谋家财也。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "叫妾身如何是好？"
        },
        {
          "character": "倪守谦",
          "type": "白",
          "text": "咳，我自有道理。我这里有此行乐图一张，你带在身旁，若是我死之后，那善 继将家财平分与你便罢，若是他欺心吞谋，你千万要忍耐，随他如何，你必须 私访清官，将此图呈上，当堂去告，你母子必有好处。我的言语，你要紧记。 夫人吓！"
        },
        {
          "character": "倪守谦",
          "type": "唱",
          "text": "我已吩咐须紧记， 霎时一阵心血迷。 眼昏花身无力不能由己， 大限到顾不得妻分子离。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪守谦死。"
        },
        {
          "character": "梅氏",
          "type": "唱",
          "text": "一见老爷归了西， 万般苦处好惨凄。 哭一声老爷呀奴的夫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善继、倪善述、李氏同上。"
        },
        {
          "character": "倪善继",
          "type": "唱",
          "text": "即忙上前问端的。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "姨娘为什么哭？"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "你爹爹下世去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏、倪善继、倪善述、李氏同哭。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "可曾留下什么言语？"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "这个，并无一言。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "如此，家院、倪忠快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、倪忠同上。"
        },
        {
          "character": "院子、倪忠",
          "type": "同白",
          "text": "参见大爷。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "老太爷已过世了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子、倪忠同哭。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "你们将尸首抬到前厅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏、院子、倪忠、倪善述搭倪守谦同下。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "这就好了，老的已死，把他娘儿两个赶出去，这家财全是我一人的了。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "只怕乡邻们不答应。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "这不要紧，待我假造老东西的遗嘱，就写上分书，给他们五亩荒地，三间草房。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "如此虽好，只有那倪忠老奴才，有点难办。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "这我有法子。 倪忠快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪忠上。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "参见大爷"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "你这么大年纪，还做得了什么事，你快到东村，那里有三间草房，几亩荒地， 你到那里去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪忠应，下。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "这就好了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善继、李氏同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "守旧景。〖水底鱼〗。倪忠上。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "咳，老爷去世，不想大爷就要吞谋家财，是我本要对二夫人说明老爷埋银之事， 怎奈老爷去世前吩咐，不可言明，这也不知何故，待我东村走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪忠下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大客堂景。倪善继、李氏同上。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "老东西已死，今已断七，这家财的事，至今尚未料理。 家院快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "参见大爷。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "你去把众邻舍请来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子应，下。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "他们来了，你随我怎样说，你千万不要多言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子引众邻人同上。"
        },
        {
          "character": "众邻人",
          "type": "同白",
          "text": "唤请我们作甚？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "列位高邻。家父去世，现已断七，我要与姨娘兄弟分家。"
        },
        {
          "character": "众邻人",
          "type": "同白",
          "text": "怎么分法？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "先人也曾留下遗嘱，东村几亩荒地，三间草房，归姨娘兄弟所有。"
        },
        {
          "character": "众邻人",
          "type": "同白",
          "text": "这叫他们如何度日？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "这是先人吩咐，现有证凭，列位请看。望列位照此行事，我必有相谢。"
        },
        {
          "character": "众邻人",
          "type": "同白",
          "text": "如此总要论公。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "家院，请二夫人与二少爷出堂。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。 有请二夫人、二少爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善述、梅氏同上。"
        },
        {
          "character": "梅氏",
          "type": "念",
          "text": "老爷下世去，母子受孤凄。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "众位高邻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众邻人同还礼。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "将我母子唤出，不知何事？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "与你们分家。"
        },
        {
          "character": "倪善述",
          "type": "白",
          "text": "分家可是不仁？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "不分总不行。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "吓大儿，你兄弟年幼，不会说话，你要让他些。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "不要多说，这家一定要分。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "但不知怎样分法？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "东村的田，草房三间归你们。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "叫我母子如何度日？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "这是先人吩咐，现有证凭遗嘱，列位高邻的见证，现有田契、草房单据在此， 你与我走。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "梅氏",
          "type": "唱",
          "text": "大儿做事心肠狠， 母子如何度残生。 含悲忍泪出门去， 去往东村走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏、倪善述同下。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "列位，明日我备酒相请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "野景，草房。〖纽丝〗。梅氏、倪善述同上。"
        },
        {
          "character": "梅氏",
          "type": "唱",
          "text": "眼见日落天色晚， 只见草屋泪不干。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪忠上。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "参见夫人、二爷。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "夫人、二爷来至东村则什？"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "我与大爷分家另住了。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "怎样分法？"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "就是草屋三间，荒田几亩。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "如此如何度日？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏哭。"
        },
        {
          "character": "倪忠",
          "type": "白",
          "text": "夫人可要用些什么？"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "不用，你且下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪忠下。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "儿吓。你父留下画图一张，言道：若遇清官，拿此图去告，你我母子定有好处， 随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏、倪善述同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "野景。"
        },
        {
          "character": "滕大尹",
          "type": "内西皮导板",
          "text": "十载寒窗一举成名，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二公差引滕大尹同上。"
        },
        {
          "character": "滕大尹",
          "type": "西皮原板",
          "text": "为县令与黎民判断冤情。 食君之禄把忠尽， 报君恩尊慈孝不负明君。 虽然为官只七品， 勤劳秉正牧良民。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "下官滕大尹，蒙圣恩放我县令，今日拈香之日。 左右，开道。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "人来开道往前进， 一柱清香拜神灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "守旧景。地保上。"
        },
        {
          "character": "地保",
          "type": "白",
          "text": "我地方是也。今有本县太爷，往府庙拈香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善述暗上。"
        },
        {
          "character": "地保",
          "type": "白",
          "text": "闲人闪开，老爷来也。"
        },
        {
          "character": "倪善述",
          "type": "白",
          "text": "大哥，你说老爷来，哪位老爷来了？"
        },
        {
          "character": "地保",
          "type": "白",
          "text": "本县滕大尹太爷往府庙拈香。"
        },
        {
          "character": "倪善述",
          "type": "白",
          "text": "可是清官？"
        },
        {
          "character": "地保",
          "type": "白",
          "text": "大大清官。 闲人站开，太爷来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "地保下。"
        },
        {
          "character": "倪善述",
          "type": "白",
          "text": "太爷来了，待我请出母亲。 孩儿有请母亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏上。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "倪善述",
          "type": "白",
          "text": "今有清官，本县太爷滕大尹在府庙拈香。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "如此待为娘带了画图前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏、倪善述同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（庙堂景。〖吹打〗。四青袍、二公差、滕大尹同上，老道自下场门上，迎四青袍、二公差、滕大尹同入门，"
        },
        {
          "character": null,
          "type": "text",
          "text": "滕大尹烧香毕，坐。梅氏、倪善述同上。）"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "冤枉！"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "左右，哪里有人叫冤？"
        },
        {
          "character": "二公差",
          "type": "同白",
          "text": "乃是一个妇女。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "带上来。"
        },
        {
          "character": "二公差",
          "type": "同白",
          "text": "是。 这个女子，老爷传见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二公差带梅氏，同推入。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "叩见老爷。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "那一妇人，姓什名谁，状告何人？"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "小妇人梅氏，配夫前任太守倪守谦，状告大儿善继，谋夺家产。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "原来是一位夫人，随在轿后。 左右，打道回衙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老道下。四青袍、二公差、滕大尹、梅氏、倪善述同走圆场。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "升堂。来，带梅氏。"
        },
        {
          "character": "二公差",
          "type": "同白",
          "text": "带梅氏。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "参见太爷。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "你将冤枉一一讲来。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "容禀："
        },
        {
          "character": "梅氏",
          "type": "唱",
          "text": "不幸老爷把命丧， 大儿谋产心不良。 儿夫在世对我讲， 留下行乐图一张。 若遇清官对他讲， 太爷与我做主张。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "如此将画呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏呈画。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "来，将倪善继提来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公差甲应，下。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "这是何人？"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "次子善述。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公差甲、倪善继同上。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "参见太爷。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "善继，你将分家之事，一一讲来。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "先人去世，留下遗嘱，叫我分给他东村田，三件草房，现有众邻人的见证，太 爷可以问他们。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "如此，善继，你且回去。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "谢太爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善继下。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "梅氏，你且回去，将画留下，我自有道理。"
        },
        {
          "character": "梅氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅氏、倪善述同下。院子暗上。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "家院，打扫书房，退堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "书房景。下场门设桌子小帐子，家院上，打扫挂画。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小过门〗。滕大尹上。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "你且退下，少时命丫鬟打茶前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子应，下。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "且住，适才梅氏状告大儿善继谋产，那梅氏言道：倪太守留下此画与她，日后 若遇清官，定能断出，想此画也不知是何意也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "有本官在书房前思后想， 那梅氏告大儿谋产一桩。 倪善继在公堂并无言谎， 梅氏女非刁妇叫我难详。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "那善继并无谎言，梅氏亦非刁妇也。看此图上面，乃倪太守自画行乐之图，他 右手抱婴儿，左手指地，面带笑容，这算何意？老先生吓，老先生，你这是何 苦吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "倪太守你本是官居黄堂， 因何故这家财无有主张。 莫不是将家财与大儿执掌， 又怎能将画图付与妻房？"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "见此图之中，并无可疑之处。真真叫我难断吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "滕大尹",
          "type": "二黄摇板",
          "text": "谯楼已打三更响， 思前想后无主张。 我这里取此图仔细观望， （滕大尹取画。〖小过门〗。丑丫鬟暗上，捧茶盘，滕大尹左右看画，丑丫鬟偷看，滕大尹转身，丑丫鬟将 茶盘翻倒。）"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫鬟跪。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "大胆的小丫鬟敢发癫狂。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "唗！大胆贱人，做事莽撞。 家院，看家法伺候。"
        },
        {
          "character": "丑丫鬟",
          "type": "白",
          "text": "老爷不要生气，小丫鬟偷看老爷手中的画，撞翻了茶，将画弄湿了，待小丫鬟 拿去洗洗就是了。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "哎哟，此乃五色之图画，焉能浆洗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "滕大尹看图惊，挂上细看。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "丫鬟取金钗来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫鬟应。滕大尹取钗破画看。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "“太守倪守谦，因年迈告职归林，先妻早亡，留下长子善继，行为不正，次妻 梅氏，所生一子，取名善述，尚幼。我病将危，恐我死后，大儿吞谋家产，梅 氏母子，后身难度，故将金银藏在酒坛与花缸之内，埋藏内厅东西廊下。恐大 儿知道，又恐妇弱难抗，故将遗嘱藏于画中，若有清官，以公将此财产断与梅 氏母子，以昭大公。事毕谢银五百两，倪守谦具。”"
        },
        {
          "character": "滕大尹",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫鬟笑。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫鬟下。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "看罢此画喜洋洋， 有此机谋在画中藏。 明日里到他家我假意判断， 管叫那倪善继如梦黄粱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "滕大尹下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大客堂景。倪善继、李氏同上。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "你说梅氏告了你，到底怎么一回事？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "今天本县太爷，亲自到此地审问此事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "大爷，太爷来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四青袍、二公差、倪善述、梅氏、滕大尹同上。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "我心中早把那巧计想， 今日特地到他庄。 来至倪府用目望。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "迎接太爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "滕大尹假对空中说话。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "哎吓哎吓，卑职怎敢有劳倪老先生迎接！老先生请！哦呵，老先生请坐！"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "有劳先生迎接门墙。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "吓老先生，昨日尊夫人，来到我的公堂，状告大令郎，此事老先生可知否？"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "昨日里在公堂未能言讲， 因此上到尊府细问端详。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "先生可是将家财付与大令郎所管么？哦哦哦。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "原来是老先生早做主意， 将家财已分明付与令郎。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "老先生既已分明，为何梅氏夫人，又告此状？哦，原来如此。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "老先生但把宽心放， 这桩事儿我承当。 我有言来忙奉上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "滕大尹故作惊异。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "哎吓！"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "不见了老先生所为哪桩？"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "老先生哪里去了？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "太爷，你找谁？"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "方才与令尊叙话，怎么不见了？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "我老人家，早已去世了。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "方才明明在此叙话。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "太爷，你看见鬼了。你看见家父，他穿的什么？戴的什么？"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "你且听了："
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "老先生慈眉善目样， 五绺白须飘在胸膛。 方面大耳童颜样， 身穿大红，足踏朝靴，腰围玉带，头戴乌纱。适才与我谈家常。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "难道说尔等就没见他？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "我怎么会看见他？"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "你问问他，他说了什么话了？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "太爷，他说的啥？"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "他说将财产必须从新分过，你可愿分？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "这家财，已请过众邻人作见证，已分得清清楚楚，还要分什么？"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "如此也罢，你要念在他母子无人奉养；本县做主，你将中厅分与她母子，你看 如何？"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "就分给他好了。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "如此，我分给他就是。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "口说无凭，必须你立下字据，请众乡邻作见证，方能算数。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "来，请众高邻来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子应，下。院子引众邻人同上。"
        },
        {
          "character": "众邻人",
          "type": "同白",
          "text": "作什么？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "现在太爷作主，将中厅分给梅氏，请你们作证人。"
        },
        {
          "character": "众邻人",
          "type": "同白",
          "text": "如此，我们作证就是。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "如此请你们画押。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众邻人同画押。"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "太爷，字据在此，太爷请看。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "你等愿意作证？"
        },
        {
          "character": "众邻人",
          "type": "同白",
          "text": "小人们愿意作证。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "好，退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众邻人同下。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "善继，你不要后悔？"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "决不后悔。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "人来转至中厅下， 我有言来听根芽。 东廊之下取银两，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖阴锣〗。二公差取酒坛同上。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "西廊下还有五缸花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二公差同下，取缸同上。"
        },
        {
          "character": "倪善继",
          "type": "唱",
          "text": "一见银子摆地下， 怪来怪去要怪他。 走上前来忙跪下，"
        },
        {
          "character": "倪善继",
          "type": "白",
          "text": "太爷！"
        },
        {
          "character": "倪善继",
          "type": "唱",
          "text": "银子归我坛子归他。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "你有何脸面再讲话， 岂不活活来羞杀。"
        },
        {
          "character": "倪善继",
          "type": "唱",
          "text": "一霎时叫我气涌上， 不如一死绝自家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "倪善继碰死。"
        },
        {
          "character": "李氏",
          "type": "唱",
          "text": "一见儿夫赴泉下， 看来万事要怪他。"
        },
        {
          "character": "滕大尹",
          "type": "唱",
          "text": "恶人自错事今发， 倪太守死后断未差。"
        },
        {
          "character": "滕大尹",
          "type": "白",
          "text": "你等好好在家度日。 开道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二公差同应。〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}