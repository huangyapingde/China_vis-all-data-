{
  "script_id": "05011001",
  "title": "游武庙",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "刘基",
      "hangdang": "老生"
    },
    {
      "name": "洪武帝",
      "hangdang": "老生"
    }
  ],
  "plot": "明太祖登基后，偕刘基同游武庙，见殿内外列有从祀之历代名将，朱元璋用己之喜怒，加以品评，升赵云、\n王伯党，而黜伍员、韩信、张良。刘基知朱元璋猜忌，恐己受祸，乃辞朝归田。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘基上。"
        },
        {
          "character": "刘基",
          "type": "引子",
          "text": "执掌朝纲，伴君王，位列三台。"
        },
        {
          "character": "刘基",
          "type": "念",
          "text": "春来杨柳正发芽，万物俱在土中发。朝中多少骏马客，一心只想帝王家。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "下官刘基。昨日圣上传旨，今日驾游武庙拈香。看香烟缭绕，圣驾登殿，在此 伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四太监引洪武帝同上。"
        },
        {
          "character": "洪武帝",
          "type": "引子",
          "text": "海晏河清，齐奏升平。"
        },
        {
          "character": "洪武帝",
          "type": "念",
          "text": "大明一统乐无忧，至尊天子坐龙楼。太平天下朝元日，万国衣冠拜冕旒。"
        },
        {
          "character": "洪武帝",
          "type": "白",
          "text": "寡人大明天子洪武在位。自从登基以来，风调雨顺，国泰民安，刀枪入库，马 放南山，真乃寡人福泽无疆。昨日传旨，今日武庙拈香。 刘先生，"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "洪武帝",
          "type": "白",
          "text": "銮驾可齐？"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "洪武帝",
          "type": "白",
          "text": "起驾武庙。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "御林军走上，起驾武庙。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "龙行虎步把殿下，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "大明朝归一统锦绣中华。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "有孤王在马上得来天下，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "文有谋武有勇保定皇家。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "文站西武列东扶保王驾，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "两旁边摆的是斧钺金瓜。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "内侍臣与孤王急忙起驾，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "君与臣到武庙去把香插。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "老道上。"
        },
        {
          "character": "老道",
          "type": "念",
          "text": "扫地恐丧蝼蚁命，爱惜飞蛾罩纱灯。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "贫道武庙住持。圣驾游幸，不免打扫清洁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左摆赵云、伍员，中设姜尚、张良，右摆王勇、韩信。"
        },
        {
          "character": "老道",
          "type": "白",
          "text": "远远望见圣驾来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四太监、大太监、四大铠、刘基、洪武帝同上。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "来此武庙。"
        },
        {
          "character": "洪武帝",
          "type": "白",
          "text": "驻辇。"
        },
        {
          "character": "洪武帝",
          "type": "西皮导板",
          "text": "武庙驻辇马停蹄，"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "保驾的将军是刘基。 孤登基未曾游此地， 看一看前朝古今奇。"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "金梁玉柱瓦琉璃， 玉石栏杆摆列在丹墀。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "站立庙外用目觑， 一位将军庙外立。 头戴白盔双凤翅， 身穿白甲似雪飞。 跨下一骑白龙马， 方天画戟手中提。 左手弯弓秋月样， 右桶狼牙箭几枝。 马前威风高万丈， 马后威风八百余。 脸面笑容真可喜， 好像哪里得胜回。 回头便把先生问， 那位将军他是谁？"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "刘基拱手忙奏启， 启奏我主圣驾知： 他家住常山真定地， 赵云名儿天下知。 长坂坡前救后主， 杀得那曹兵无对敌。 皆因糜妃自跳井， 反说忠良把君欺。 宋室王爷修武庙， 反将神像立丹墀。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "太祖闻言心中气， 史官错把忠良欺。 万马营中救后主， 单人独骑逞雄威。 曹兵暗放无情箭， 可叹糜妃投井死。 这等臣子不入庙， 还有何人保华夷？ 孤王传旨往内请， 一阵清风往内吹。 回头又见一员将， 面如枣红五绺须。 跨下一骑红鬃马， 斩将的大刀手内提。 这是哪朝安邦将， 他的功劳在哪里？ 回言便把先生问， 这位将军他是谁？"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "姓王名勇字伯党， 文武全才世间稀。 唐兵暗放无情箭， 左遮右挡护主体。 不幸李密带箭死， 断密涧下命归西。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "听奏言来皱双眉， 史官竟把忠良欺。 唐兵暗放无情箭， 保主尽忠命归西。 金牛压死娄金狗， 反说忠良把主欺。 这等臣子不入庙， 还有何人保华夷？ 孤王传旨请进庙， 一阵清风往内吹。 叫内臣与孤摆下祭奠礼，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "焚香祭奠酒三杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "洪武帝",
          "type": "西皮导板",
          "text": "上坐斩将封神姜吕望，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "下坐着箕子、微子、闻太师。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "兵吞六国名王翦，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "呼风唤雨燕孙膑。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "英布、彭越与韩信，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "岑彭、马武和姚期。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "独行千里关圣帝，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "喝断坝桥是张飞。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "跨海征东薛仁贵，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "李存孝倒有托天力。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "威镇三关杨家将，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "这都是前朝忠良将尽人皆知。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "见几个头戴双凤翅，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "见几个身穿紫罗衣。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "见几个横须赛太岁，"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "见几个怀抱令箭和令旗。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "观前观后观仔细， 问左问右问刘基。"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "刘基拱手忙奏启， 不敢隐瞒惹是非。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "回头又见一员将， 白盔白甲五绺须。 回头便把先生问， 这一位将军他是谁？"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "刘基拱手忙奏启， 启奏我主听端的： 姓伍名员字子胥， 平王驾前算第一。 临潼会上曾斗宝， 他与秦楚做过媒。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "听奏言来怒冲起， 骂声伍员不忠的。 平王虽然纳儿妇， 错斩你父命归西。 吴国借兵将仇报， 为臣反上把君欺。 自古人死仇不记， 不该鞭打主的尸。 喝骂一声赶出庙去，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "洪武帝转头。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "将身又到二殿里。 回头又见一员将， 身穿一件大红衣。 回言便把先生问， 这位神像他是谁？"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "他是汉朝的韩信， 暗度陈仓少人知。 九里山摆下埋伏阵， 逼死霸王一管笛。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "听奏言来怒火起， 骂一声不忠不孝贼。 你不该受那汉王拜， 不该埋母在秦西； 你不该问路把樵夫斩， 你不该乌江把主逼。 你不该杀那陈仓女， 你不该想夺主社稷。 报应丧在阴人手， 未央宫中命归西。 仔细思量难容你， 武庙难容你这不忠贼。 喝骂一声赶出庙去， 将身来在后殿里。 上面坐的一员将， 身穿一件八卦衣。 左边儿童捧宝剑， 右边插面令字旗。 行兵布阵如反掌， 威风凛凛透九霄。 回言便把先生问， 这位道长他是谁？"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "姓张名良字子房， 出在春秋战国时。 勒逼项羽乌江丧， 才封他天祭地祭与神祭。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "听说张良皱双眉， 反复不定把君欺。 汉王有道你就保， 汉王无道你就离。 眼前若有张良在， 割肉熬油剥他皮。 骂罢张良回头看……"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "洪武帝",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "错出一言悔不及。"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "万岁骂臣不妨骂， 指骂张良臣是谁。 自古道伴君如伴虎， 一点不到有是非。 在头上除下了乌纱帽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘基转头。"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "身上脱下紫罗衣。 把武庙当做了金銮殿， 望万岁赦臣归故里。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "说什么告老归故里， 你不言来朕心知。 孤不该今日到此地， 错出一言你心疑。 先生与孤把江山定， 同行半步也难离。 先生去了又有谁， 可与孤王保华夷。"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "老牛老马中何用， 年迈之人枉费力。 耳聋了，听不见， 眼花难把兵来提。 望万岁将臣赦了罢！"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "哎呀万岁吓！"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "臣到深山修道去。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "先生要去真要去， 留你不住枉费心机。 朕封你云游真人去访道， 逢州过府把粮支。 赐卿一把白玉扇， 先生牢牢记在心里： 哪里一旦烟尘起， 那时要与孤做主意。"
        },
        {
          "character": "刘基",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "刘基",
          "type": "唱",
          "text": "叩头谢恩辞万岁， 对着相府泪悲啼。 说什么一品三公位， 说什么朝中挂紫衣。 说什么黄金带北斗， 说什么训教子与媳。 夫妻本是同林鸟， 大限来时各自飞。 将身跳出牢笼地， 朝中大事再不提。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘基下。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "自古出言要谨慎， 今日武庙走刘基。 护国军师辞朝去，"
        },
        {
          "character": "洪武帝",
          "type": "白",
          "text": "内侍，摆驾回宫。"
        },
        {
          "character": "洪武帝",
          "type": "唱",
          "text": "去了擎天一军师。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}