{
  "script_id": "05004007",
  "title": "七步吟",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "曹植",
      "hangdang": "生"
    }
  ],
  "plot": "曹操死，曹丕继位为魏王，妒嫉其弟曹植，命许褚至临淄逮拿至邺郡，先斩丁仪、丁廙，逼曹植七步吟诗一\n首，否则杀之。曹植七步成诗，又另咏诗感动曹丕，曹丕免其死，贬为安乡侯。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "曹丕",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、王朗、陈矫、贾诩、许褚、曹丕同上。"
        },
        {
          "character": "曹丕",
          "type": "二黄原板",
          "text": "金钟响玉磬鸣王登宝殿， 未为君也有那文武两班。 可笑那汉皇帝龙身鼠胆， 由着孤改年号哪个敢拦？ 我父王人忠正性情太软， 为旁人出死力整顿江山。 可笑他秉忠心不忘炎汉， 全不想坐天下唯有强权。 虽然是众文武保孤登殿， 众兄弟未奔丧孤心不安。 黄须儿平日里能征惯战， 怕的是要学那袁尚、袁谭。 面上喜心中忧长吁短叹， 为富贵哪顾得骨肉自残。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "众位公卿，孤今嗣位，无有天子诏书，恐怕文武不服。"
        },
        {
          "character": "陈矫",
          "type": "白",
          "text": "魏王已死，天下震动，若不早立嗣王，则兄弟相争，国家危矣。何必等那木偶 皇帝的诏？文武谁敢不服，请看此袍！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈矫割袍。"
        },
        {
          "character": "王朗",
          "type": "白",
          "text": "办大事不可草率，何妨请卞皇后下一道懿旨，先立世子为王。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "名不正则言不顺，言不顺则事不成。诸君不必着急，先王必有安排。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华歆上。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "你到此何事？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "先王已死，臣恐弟兄争位，学当年袁尚、袁谭之故事。因此威逼汉帝，写下诏 书。特来献上。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "卿真社稷之臣也。封为相国。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "只怕我家兄弟们心怀不服。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "先王已死，他等不来奔丧，就该问罪。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "言之有理，殿前指挥进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "指挥上。"
        },
        {
          "character": "指挥",
          "type": "白",
          "text": "参加殿下。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "指挥",
          "type": "白",
          "text": "有何差遣？"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "孤命你去到曹植、曹熊、曹彰那里，问他个不奔丧之罪。"
        },
        {
          "character": "指挥",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "指挥下。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "臣又有本启奏。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "临淄侯曹植，天下奇才，必不遵命。指挥此去，难以成功。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "许褚过来，孤命你带定尚方宝剑，去到临淄，抓来我弟，其余之人，杀死无论。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚下。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "主公尚有手足之情乎？"
        },
        {
          "character": "曹丕",
          "type": "念",
          "text": "虽然兄弟恩情厚，占我权利变仇雠。不夺王位便罢手，免得同室操戈矛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四人役、丁仪、丁廙、曹植同上。"
        },
        {
          "character": "曹植",
          "type": "二黄原板",
          "text": "盖世聪明有学问， 眼空四海目无人。 吾父在朝官极品， 富贵荣华一满门。 我兄曹丕人凶狠， 助纣为虐是华歆。 乱臣贼子人人恨， 家不安来国不宁。 我只得以酒来解闷， 作两首新诗散一散心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、指挥同上。"
        },
        {
          "character": "指挥",
          "type": "念",
          "text": "人行千里路，马过万重山。"
        },
        {
          "character": "指挥",
          "type": "白",
          "text": "参见殿下。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "将军少礼。到此何事？"
        },
        {
          "character": "指挥",
          "type": "白",
          "text": "今奉魏王之命，因殿下不奔丧，特来问罪。"
        },
        {
          "character": "丁仪",
          "type": "白",
          "text": "谁是魏王？"
        },
        {
          "character": "指挥",
          "type": "白",
          "text": "世子曹丕，诏封魏王，难道你不知道么？"
        },
        {
          "character": "丁仪",
          "type": "白",
          "text": "可恼哇，可恼！"
        },
        {
          "character": "丁仪",
          "type": "唱",
          "text": "听一言来心头恨， 大骂曹丕不是人。 先王死后孝未尽， 何忍自残骨肉亲。"
        },
        {
          "character": "丁仪",
          "type": "白",
          "text": "匹夫！你可知当日先王欲立我主为世子，被谗臣所阻，才立曹丕。今先王孝服 未满，就来问罪于骨肉，你们于心何忍？"
        },
        {
          "character": "丁廙",
          "type": "白",
          "text": "我主出口成章，比曹丕胜强十倍，反不立他为王。你等文武大臣，一味徇私， 不识人才，令人可恨。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "着着着！"
        },
        {
          "character": "曹植",
          "type": "唱",
          "text": "我兄曹丕豺狼性， 无端问罪骨肉亲。 人来与我打乱棍， 快快将他赶出门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、指挥同下，四人役同随下。"
        },
        {
          "character": "丁仪、丁廙",
          "type": "同白",
          "text": "打得好！打得好！"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "叫人来酒宴安排定，"
        },
        {
          "character": "曹丕",
          "type": "二黄原板",
          "text": "你我饮酒把诗吟。 你好比管仲你比晏婴，"
        },
        {
          "character": "丁仪",
          "type": "二黄原板",
          "text": "你好比孔圣人又复生。"
        },
        {
          "character": "曹植",
          "type": "二黄原板",
          "text": "自古才子多薄命，"
        },
        {
          "character": "丁廙",
          "type": "二黄原板",
          "text": "可笑曹丕是庸人。"
        },
        {
          "character": "曹植",
          "type": "二黄原板",
          "text": "你可知庸人有福份？"
        },
        {
          "character": "丁仪、丁廙",
          "type": "同二黄原板",
          "text": "运败时衰他祸临身。"
        },
        {
          "character": "曹植",
          "type": "二黄原板",
          "text": "我三人饮酒多高兴， 不觉席前醉沉沉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套、许褚同上，杀丁仪、丁廙，拉曹植同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四龙套、王朗、陈矫、贾诩、华歆、曹丕同上。"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "代汉当途有先兆， 说什么三马敢同槽。 曹植文章比我好， 曹彰武艺比我高。 恐怕我王位不能保， 杀他不能念同胞。 斩草除根遵父教， 这时候顾不得母劬劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "萧怀侯曹熊听说问罪，自缢身死。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "我本无心来杀弟， 你自己一死谁来逼？ 哭一声苦命的好兄弟， 金井玉葬埋尸体。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖水底鱼〗。许褚上。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "启禀魏王：丁仪、丁廙被我杀了。曹植拿到。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "好。弓上弦，刀出鞘，将曹植押上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。曹夫人上。"
        },
        {
          "character": "曹夫人",
          "type": "唱",
          "text": "骂声曹丕儿好大胆！"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "吩咐文武且退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朗、陈矫、贾诩、许褚、华歆同下。"
        },
        {
          "character": "曹夫人",
          "type": "唱",
          "text": "奴才你稳坐银安殿， 弟兄何忍自摧残！"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "参见母亲。"
        },
        {
          "character": "曹夫人",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "母亲怒气不息，为着谁来？"
        },
        {
          "character": "曹夫人",
          "type": "白",
          "text": "就为你来。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "为儿何来？"
        },
        {
          "character": "曹夫人",
          "type": "白",
          "text": "你这冤家，才得了王位，逼死了曹熊，锁拿曹植，全不想你母生你同胞弟兄四 人。你今只贪富贵，自残骨肉。儿啦，你于心何忍？"
        },
        {
          "character": "曹夫人",
          "type": "唱",
          "text": "自残骨肉心何忍？ 全不念同胞手足情。 看起来你父无德行！"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "一句话感动了自己的良心。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "曹熊胆小，非儿逼死。曹植自恃其才，终日饮酒，狂傲无知，故而拿来警教于 他。孤也深爱，何忍杀害，母亲请回去罢。"
        },
        {
          "character": "曹夫人",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "曹夫人",
          "type": "唱",
          "text": "丈夫奸诈人人恨， 此子与父一样心。 且在殿角观动静，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹夫人下。"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "这事教我怎样行？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朗、陈矫、贾诩、许褚、华歆同上。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "适才太后上殿，莫非劝我主勿杀那曹子建么？"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "然也。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "主公，那曹子建才高八斗，终非池中之物；若不早除，必为后患。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "母命不可违。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "人言子建出口成章，请我主考试于他，若不能答对，将他杀了，以正欺君之罪。 太后亦不能怪。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "好。宣曹植上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套押曹植同上。"
        },
        {
          "character": "曹植",
          "type": "唱",
          "text": "大醉沉沉刚然醒， 银安殿上冷森森。 曹丕高坐威风凛， 狐假虎威是华歆。 眼见我曹植难保命， 他全无一点手足情。 未曾进殿哭声震， 跑倒阶前大放声。"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "见曹植只哭得珠泪滚滚， 我有心要杀他却也不能。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "大胆曹植，父死你不奔丧，我命指挥传你，竟敢乱棍打出！该当何罪？"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "兄王啊！"
        },
        {
          "character": "曹植",
          "type": "西皮二六板",
          "text": "未曾开言泪难忍， 尊声兄王龙耳听： 父王晏驾太不幸， 怕的是刘备、孙权趁此机会来进兵。 保护城池最要紧， 因此上不敢把丧奔。 丁仪、丁廙书生性， 一个个恃才傲物酒后无德乱胡行。 小弟醉后迷了性， 不该将殿前指挥乱棍赶出门。 弟焉敢违抗兄亡命？ 皆因是大醉之后无知无识糊里糊涂记也记不真。 兄王台前把罪领， 念同胞开了天地恩。"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "闻言不由心暗忖， 曹植哭得好伤心。 有心杀他传将令， 又恐母后在殿后听； 有心饶他不传令， 华歆一旁眼圆睁。 眉头一皱忙传命， 叫声曹植且平身。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "谢兄王不斩之恩。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "且慢。孤与你情虽兄弟，义属君臣。先王在日，你自恃聪明，以文章夸示于人。 我疑你有人代笔，欺骗父王。孤今出题，限你七步吟诗一首，若不能作，加 重问罪。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "请兄王出题。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "就以此画为题。诗中不许犯“二牛斗墙下，一牛坠井死”的字样。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "华歆数步。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "一、二、三、四、五、六、七。"
        },
        {
          "character": "曹植",
          "type": "念",
          "text": "两肉齐道行，头上带凹骨。相遇块山下，郯起相搪突。 二敌不俱刚，一肉卧土窟。非是力不如，盛气不泄毕。"
        },
        {
          "character": "华歆",
          "type": "唱",
          "text": "曹植七步把诗吟， 看来果然是聪明。 转面再对主公论， 子建真是不凡人。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "七步吟诗，不足为奇。你常言出口成章，我再出题，你若不能应声作诗一首， 定将你斩了。"
        },
        {
          "character": "曹植",
          "type": "白",
          "text": "哥哥你出题。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "我与你乃是兄弟，也就以兄弟为题。诗中不准犯“兄弟”字样。"
        },
        {
          "character": "曹植",
          "type": "念",
          "text": "煮豆燃豆萁，豆在釜中泣。本是同根生，相煎何太急！"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "闻此诗不由我心恸难忍， 难道说他不是一娘所生？ 为富贵我不该天良丧尽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹夫人上。"
        },
        {
          "character": "曹夫人",
          "type": "唱",
          "text": "在殿外哭坏了卞氏夫人。 我的儿逼兄弟未免太甚！"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "论国法这时候顾不得私情。 我贬你安乡侯快快上任，"
        },
        {
          "character": "曹植",
          "type": "唱",
          "text": "谢兄长开大恩再谢娘亲。"
        },
        {
          "character": "曹夫人",
          "type": "唱",
          "text": "苦命儿随娘来我有话论，"
        },
        {
          "character": "曹植",
          "type": "唱",
          "text": "儿不去怕兄王又起疑心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹植、曹夫人同下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "鄢陵侯曹彰领兵十万，来争王位。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "曹丕",
          "type": "唱",
          "text": "听说曹彰把位争， 领兵十万杀到城。 黄须儿平日有本领， 不如让位早逃生。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "主公不必惊慌，臣愿顺说于他。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "此事非大夫不可，华歆你可同去？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "臣现在有病，不能同去。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "你今日胆子太小了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾诩笑下。"
        },
        {
          "character": "曹丕",
          "type": "白",
          "text": "华歆，你亦怕我黄胡子的兄弟？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "不怕，臣不敢不怕！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹丕、华歆同笑。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}