{
  "script_id": "05014009",
  "title": "天水关",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "姜维",
      "hangdang": "净"
    },
    {
      "name": "刘禅",
      "hangdang": "小生"
    }
  ],
  "plot": "诸葛亮上表出师，兵伐中原。起兵之日，刘禅亲至长亭饯别。天水关守将马遵闻报韩德父子阵亡，大惊，命\n将免战牌高挂。姜维见状，请令出战，与赵云交锋。赵云力不能支，幸得关兴救走。姜维得胜而归。赵云回\n大寨，向诸葛亮诉说为姜维所败事。诸葛亮授魏延密计，又使马岱、关兴、张苞等诱姜维至凤凰山，轮流交\n战。魏延假扮姜维，请马遵开城一同降汉。黑夜中马遵不辨真假果中计，大骂姜维。姜维杀败马岱回城，请\n马遵开城。马遵大怒，取箭射之，逼走姜维。姜维途见诸葛亮在山岗之上，提枪上山欲杀之，为众将所阻。\n诸葛亮对姜维以好言相劝，并谓老母早已接来，姜维乃倾心归顺。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘禅、四太监同上。"
        },
        {
          "character": "刘禅",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "刘禅",
          "type": "念",
          "text": "先王晏驾白帝城，满朝文武不安宁。多亏相父来扶助，孤王才得登龙庭。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤，刘禅。国号建安在位。登基以来，风调雨顺，国泰民安。今当设立早朝。 内侍！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "闪放龙门。"
        },
        {
          "character": "诸葛亮",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "代理山河，掌丝纶，运筹帷幄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣诸葛亮见驾。陛下千岁。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "相父平身！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "相父手捧何物？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣修得出师表章，请我主龙目御览。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅看表。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "呜呼呀！如今才得干戈宁静，相父又要出兵，叫小王心下何忍？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "先帝爷白帝城龙归海境， 传口诏叫老臣时刻挂心。 命为臣保陛下社稷重整， 命老臣把孙、曹一旦扫平。 臣上本并非为别事议论， 望陛下准臣本臣要发兵。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "老相父奏的是治国经纶， 一桩桩一件件全记在心。 内侍臣替孤王忙传圣命， 文武臣随小王长亭饯行。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "食君禄报王恩理当尽命， 臣怎敢劳我主长亭饯行。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "内侍臣摆御驾后宫来进， 明日里待小王长亭饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅、四太监、诸葛亮同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、魏延、马岱、关兴、张苞同上。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "大将生来盖世雄，"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "万马军中逞威风。"
        },
        {
          "character": "关兴",
          "type": "念",
          "text": "耀武扬威英雄将，"
        },
        {
          "character": "张苞",
          "type": "念",
          "text": "斩将擒王立大功！"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "魏延。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "关兴。"
        },
        {
          "character": "张苞",
          "type": "白",
          "text": "张苞。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "马岱、关兴、张苞",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "元戎发兵，你我在此侍候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下，赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "白发苍苍似银条，东战孙权北剿曹。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "同白",
          "text": "参见老元戎！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "人马可齐？ 张苞　　　赵云　　　魏延、"
        },
        {
          "character": "魏延、马岱、关兴、马岱、关兴、张苞",
          "type": "同白",
          "text": "喳！"
        },
        {
          "character": "太监甲",
          "type": "内白",
          "text": "圣驾到！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "一同接驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、诸葛亮、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "手挽手与相父长亭来进， 众将官一个个杀气腾腾。 内侍臣看过了皇封御饮， 我与那老相父杯酒饯行。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "接过了我主爷皇封御饮， 背转身祭过了旗纛尊神。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "四皇叔年纪迈忠心耿耿， 这斗酒表一表小王之心。"
        },
        {
          "character": "赵云",
          "type": "二黄原板",
          "text": "臣年迈扶我主洪福天命， 食君禄必须要答报王恩。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "我朝中有二臣忠心秉正， 蒋公言、费文伟二大贤臣。 主临朝大小事和他们议论， 常言道军国事以理而行。"
        },
        {
          "character": "刘禅",
          "type": "二黄原板",
          "text": "君臣们在长亭叙说不尽，"
        },
        {
          "character": "诸葛亮",
          "type": "二黄散板",
          "text": "请吾主龙驾归臣要发兵。"
        },
        {
          "character": "刘禅",
          "type": "二黄散板",
          "text": "内侍臣摆御驾后宫来进， 得胜回孤迎接十里长亭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、刘禅同下。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄散板",
          "text": "传将令众将军齐跨金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云、魏延、马岱、关兴、张苞同上马，诸葛亮坐车。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄散板",
          "text": "文武官且免送响炮抬营。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官，兵出祁山！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。赵云、魏延、马岱、关兴、张苞引诸葛亮同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、马遵同上。"
        },
        {
          "character": "马遵",
          "type": "念",
          "text": "镇守天水关，儿郎心胆寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有赵云，刀劈韩德父子五人落马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "来！免战高悬。"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "免战高悬。"
        },
        {
          "character": "姜维",
          "type": "内白",
          "text": "啊哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维上。"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "一颗明珠土内藏，几载未曾放毫光。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "某，姓姜名维字伯约。正在后帐观看兵书，忽听都督免战高悬，不知为了何事？ 不免进帐问个明白。 报——姜维告进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维挖入。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "都督在上，末将参见。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "将军少礼，请坐。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "将军无令，进帐何事？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "末将正在后帐观看兵书，忽听都督免战高悬，不知为了何事？ 马遵　　　（白　　　　　　适才探马报道，今有赵云，刀劈韩德父子五人落马，故而免战高悬。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "都督赐某一支将令，生擒赵云入帐！ 马遵　　　（白　　　　　　将军有此胆量？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "有此胆量！ 马遵　　　（白　　　　　　姜维听令！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马遵",
          "type": "白",
          "text": "命你带领本部人马，大战赵云，不得有误！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "马遵",
          "type": "念",
          "text": "令出山摇动，"
        },
        {
          "character": "姜维",
          "type": "念",
          "text": "言发鬼神惊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马遵、四龙套同下。四下手自两边分上。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "参见将军！"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "站立两厢，听某令下！"
        },
        {
          "character": "姜维",
          "type": "西皮导板",
          "text": "姜伯约在教场忙传令号，"
        },
        {
          "character": "姜维",
          "type": "西皮原板",
          "text": "叫一声众三军细听根苗： 刘玄德坐西川人称有道， 全凭着五虎将立下功劳。 他二哥关美髯谁人不晓， 他三弟张翼德喝断了当阳桥。 西凉将小马超英雄年少， 还有个老黄忠会使大刀。"
        },
        {
          "character": "姜维",
          "type": "西皮快板",
          "text": "这一概五虎将俱已丧了， 只剩下赵子龙老迈年高。 小阿斗坐西川年轻幼小， 有关兴与张苞哪放心梢？ 三军与爷抬枪带马到， 杀子龙擒孔明就在今朝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮流水板",
          "text": "韩德父子命丧了， 不由老夫喜眉梢。 催马来把战场到， 那旁来了小儿曹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维上。"
        },
        {
          "character": "姜维",
          "type": "西皮散板",
          "text": "上战场见一将年迈衰老， 叫老儿通上名好把兵交。"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "你老爷常山的赵子龙谁人不晓； 黄毛贼通上名好把兵交。"
        },
        {
          "character": "姜维",
          "type": "西皮散板",
          "text": "你老爷姓姜名维伯约起号， 今日里生擒你要立功劳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维打，赵云下。关兴上，砍一刀。姜维盖。关兴下。"
        },
        {
          "character": "姜维",
          "type": "西皮散板",
          "text": "正要擒拿赵子龙， 忽然闪出一孩童。 手使大刀多勇猛， 亚赛当年美髯公！ 三军起打得胜鼓， 都督台前报头功！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "辕门战鼓响，将士立两旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "参见丞相！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军回来了？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "胜负如何？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "头一阵刀劈韩德父子五人落马，二一阵遇见一红脸大汉；不是关兴搭救，险遭 不测！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "可曾问过敌人名姓？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "此人姓姜名维字伯约。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "姜维！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮想。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "久闻此人贤孝。老将军后账息歇！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "多谢丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，传众将进帐！"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "众将进帐。"
        },
        {
          "character": "魏延、马岱、关兴、张苞",
          "type": "内同白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
