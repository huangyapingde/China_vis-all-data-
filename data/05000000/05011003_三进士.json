{
  "script_id": "05011003",
  "title": "三进士",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "孙叔林",
      "hangdang": "老旦"
    },
    {
      "name": "张文达",
      "hangdang": "老生"
    },
    {
      "name": "大媳",
      "hangdang": "花旦"
    },
    {
      "name": "二媳",
      "hangdang": "旦"
    },
    {
      "name": "常天保",
      "hangdang": "老生"
    },
    {
      "name": "周子卿",
      "hangdang": "小生"
    }
  ],
  "plot": "山西平阳书生张文达，曾借常、周二家银钱进京赶考，不幸落第，因居京都十馀年。常、周两家向张妻孙叔\n林讨债，孙叔林无力偿还，二子被抢抵债，改名常天保与周子卿。后二子均中进士。时值平阳荒旱，孙叔林\n离家寻夫，流落外乡，被迫卖身常家为仆，受尽虐待。一日，因故来到周家，周子卿探知实系生母，因与常\n天保相商，嘱来认母。讵知常天保因官居高职，竟以认仆为母，有失身份。二人言语冲突，周子卿乃往督察\n院上告。巡按乃其父张文达。父子三人原系同科进士，张文达、周子卿各述以往，常天保大窘，与其妻悔过\n认罪，全家团圆。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙叔林上。"
        },
        {
          "character": "孙叔林",
          "type": "引子",
          "text": "儿夫一去杳无音，望断肝肠裂碎心。"
        },
        {
          "character": "孙叔林",
          "type": "念",
          "text": "山西连年遭饥荒，树无枝叶草无秧。夫妻父子生离散，好似棒打两鸳鸯。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "老身——孙叔林，丈夫张文达，所生二子，长子名叫硃砂贯，次子名叫孔凤英。 乃山西平阳府人氏。只因朝廷大比之年，儿夫上京赴试缺少盘费，借得周、 常二家纹银二十两。不想儿夫一去杳无音信，周、常二家与我要债，这几年年 岁饥荒，何曾有银还给他人。周、常二家将我两个孩儿分别抱去，老身只身无 靠，只得寻找儿夫来在洛阳，住在王家店内，不幸身染重病，欠下店家饭银五 两，不能归还，想想难有出头之日，不免手拿草标自卖自身，也好还给他人。 倘若得了好处，吃碗安乐茶饭也未可知。啊，店主人看守门户，我去去就来。 正是："
        },
        {
          "character": "孙叔林",
          "type": "念",
          "text": "父去子离别，孤身自惨伤。"
        },
        {
          "character": "孙叔林",
          "type": "二黄慢板",
          "text": "孙叔林出店房自思自忖， 思家乡想骨肉好不伤情。 我儿夫他一去全无音信， 又无亲又无故又无乡邻。 到洛阳住店中身染重病， 欠下了店主人五两纹银。 无奈何才把我自身来卖， 手拿着黄草标自卖自身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙叔林下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "常丫鬟扶大媳同上。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "得药服药药不灵， 一心要想汤八珍。 将身且把二堂进， 坐不安来睡不宁。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "奴家王氏，配夫常天保为妻。老爷乃二榜进士出身，升授洛阳知府，将奴家接 上任来。一路之上感冒风寒，服药无效，求神不灵，想吃八珍汤开开口味，材 料俱已齐备，衙中无人会做，我不免命苍头去上大街买一会做八珍汤之人。 丫鬟！"
        },
        {
          "character": "常丫鬟",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "命苍头进见。"
        },
        {
          "character": "常丫鬟",
          "type": "白",
          "text": "是。 苍头，夫人唤你。"
        },
        {
          "character": "常福",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常福上。"
        },
        {
          "character": "常福",
          "type": "念",
          "text": "忽听夫人唤，上前问根源。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "夫人在上，老奴叩头。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "将老奴唤出，有何吩咐？"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "命你去到大街买一会做八珍汤之人，我今吩咐你速速前去。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "怎敢延误。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常福下。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "丫鬟，搀扶了。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "丫鬟搀扶二堂进， 去到卧房养精神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大媳、常丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "常福上。"
        },
        {
          "character": "常福",
          "type": "唱",
          "text": "衙中奉了夫人命， 去到长街买仆人。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "老汉常福，奉了夫人之命，来到长街，买一会做八珍汤之人。那旁来了一老婆 子，手拿草标，等她到来，问个明白。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "走啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙叔林上。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "走过小巷大街进， 口口声声叫卖人。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "老妈妈，手拿草标，还是人卖草？还是草卖人？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "大叔，这人卖草能值几何，我是草卖人。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "身价银子多少？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "不要身价，只求进身之地，欠下王店东饭银五两，大叔替我代还了吧。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "五两银子不多。你可会做八珍汤么？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "这八珍汤么？"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "你可会做？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "请少待。 什么叫做八珍汤？也罢。待我假意应允混进他府，吃碗安乐茶饭也未可知。 啊，大叔，这八珍汤原是我妇人家会做的。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "会做的，你居住何处？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "住在前面。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "领我前去。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "好，一同前去，走啊。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "叫声大叔忙站定， 见了店东说分明。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "来此已是。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "啊，店主东……"
        },
        {
          "character": "店东",
          "type": "内白",
          "text": "做什么？"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "老妈妈可住在你店中？"
        },
        {
          "character": "店东",
          "type": "内白",
          "text": "正是住在我的店中。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "欠你五两银子，我替她代还了罢。"
        },
        {
          "character": "店东",
          "type": "内白",
          "text": "你们是哪里来的？"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "知府大老爷那里来的。"
        },
        {
          "character": "店东",
          "type": "内白",
          "text": "纹银不要，请老爷免了我们的户口捐就是了。 老妈妈，好好跟随大叔前去。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "店主东，打扰了。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "多蒙大叔施恻隐， 府中上下你看承。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常福、孙叔林同走圆场。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "少站一时。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大媳、常丫鬟同上。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "常福一去无踪影， 这时不见转回程。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "参见夫人。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "常福，命你去买一会做八珍汤之人，可曾买来没有？"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "有一老婆婆会做八珍汤。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "今在何处？"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "现在外面。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "你下面歇息。 丫鬟，将老婆子带进来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常福下。"
        },
        {
          "character": "常丫鬟",
          "type": "白",
          "text": "是啦。 原来是老姐姐。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "啊，原来是丫鬟姐。我初进府来，不知府中的规矩，望丫鬟姐指教指教。"
        },
        {
          "character": "常丫鬟",
          "type": "白",
          "text": "我家夫人是个吃斋的。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哦，夫人是个吃斋的，这就好了。"
        },
        {
          "character": "常丫鬟",
          "type": "白",
          "text": "随我进来。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人在上，孙叔林叩头。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "罢啦。我没有问你名字，你口称孙叔林，这个名字真讨厌。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "我初进府来，不晓得府中的规矩，望夫人与我改个名字就是。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "改个什么名字呢？"
        },
        {
          "character": "常丫鬟",
          "type": "白",
          "text": "就叫她老奴罢。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "哎，就叫你老奴罢。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "多谢夫人取名。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "老奴，我来问你，你可会做八珍汤么？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "这八珍汤原是妇人家会做的。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "喔，你会做八珍汤。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "丫鬟，领老奴去到厨下，做一碗八珍汤我用。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "孙叔林",
          "type": "二黄原板",
          "text": "在二堂领了夫人命， 做一碗八珍汤来敬夫人。 我看她不过二十春， 为什么她享荣华我受贫。 丫鬟姐你与我把路来引，"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "我看她不像平常人。 将身且坐二堂等，"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "手捧着八珍汤来敬夫人。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人请用。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "唷，这是八珍汤么？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "这八珍汤，分明是碗酱糊汤。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "啊呀，夫人，我初进府来，手忙足乱，下次做好些就是。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "会做就说会做，不会做就说不会做，糊里糊涂做了一碗酱糊汤。你糟蹋我的材 料，今天不打你几下，惯了你的下次。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人息怒，下次改过就是。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "贱人哪！"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "老奴做事不思忖， 暴殄天物罪不轻。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人息怒。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "手使家法将你来打，"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人饶恕了吧！"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "活活打死你这老贱人。"
        },
        {
          "character": "常丫鬟",
          "type": "白",
          "text": "夫人！你只顾拷打老奴，忘了上香的日子了，你饶恕她吧！"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "可不是，只顾拷打老奴，忘了上香的日子了。 老奴过来，明日老爷的生日，命你到府门等候，有人前来送礼，只收礼单，不 收礼物，你要记下了。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "大媳",
          "type": "念",
          "text": "口念千声佛，早晚一炉香。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "罢罢罢，阿弥陀佛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大媳、常丫鬟同下。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "我把你这贱人哪！"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "我只说卖身有好处， 谁知落在一火坑。 哭哭啼啼仪门等， 看看来的是何人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周院子上。"
        },
        {
          "character": "周院子",
          "type": "唱",
          "text": "衙中奉了夫人命， 常府送礼走一程。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "来到常府，老妈妈请了。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你是哪里来的？"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "周府来的，前来送礼。这里有礼单在此，老妈妈收下。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "且慢，我家夫人吩咐下来，各官礼物，一概不收，只许留下礼单。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "我家老爷与你家老爷同乡故里，同年考中，同衙为官，又是八拜之交，我家的 礼物，是一定要收下的。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "既然如此，暂等一时，待我禀知我家夫人。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "我等候你就是。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你且等待片时啊！"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "你在宅门等一等， 待我禀知夫人听。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "丫鬟姐请夫人出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大媳上。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "正在佛堂念经文， 老奴请我为何因？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "启禀夫人：周府差人前来送礼，这里有礼单，夫人请看。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "我怎么吩咐你的，只许收下礼单，不许收礼物。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "老奴也是这样言讲，来人的说到：他家老爷与我家老爷同乡故里，同年考中， 同衙为官，又是八拜之交，他家的礼物是要收下的。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "啊，你倒是卖沙锅的儿子，说上这么一大套，你真会办事，真会当差，来吧， 我这椅儿你来坐下，你替我当这份家吧。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "老奴不敢。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "不敢吃称条儿的。 丫鬟，看家法过来，打这老东西。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人息怒，饶恕了吧。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "好贱人哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大媳打嘴巴。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "老奴做事不思忖， 违背我言罪非轻。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人，饶恕了吧。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "手使家法来打定，"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人饶恕了吧。"
        },
        {
          "character": "大媳",
          "type": "唱",
          "text": "活活打死你这老贱人。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人饶恕了吧。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "老贱人，我命你到周府去还礼，巳时去，午时回，莫要错过时辰。你要是错过 时辰，哈哈，我要了你的老命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大媳下。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "我把你这贱人哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙叔林哭。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "我与贱人何仇恨， 苦苦拷打我孙叔林。 哭哭啼啼到宅门， 见了来人说分明。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "老妈妈，可将我家的礼物收下？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "我家夫人说到：礼物一概不收，我将你家礼物收下，我家夫人将我饱打了一顿， 叫我去到你家退礼呀。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "啊，你家夫人怎么这么凶？快快随我走吧。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "待我转过仪门。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "随我来呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周院子、孙叔林同走圆场。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "来此已是，老妈妈稍等一时。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二媳、周丫鬟同上。"
        },
        {
          "character": "二媳",
          "type": "念",
          "text": "老爷为同判，全家受皇恩。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "参见夫人。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "罢了。我命你去到常府送礼，可曾送去？"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "奉了夫人之命，去到常府送礼，礼物不收，只收礼单。常夫人命老妈妈前来退 礼。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老妈妈现在哪里？"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "现在外面。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "你到下面歇息，叫老妈妈进来。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "唷，我来问你，那老妈妈是男的，是女的？"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "是女的。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "是女的，用不着你，你给我滚出去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周院子下。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "唷，原来是老姐姐。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "丫鬟姐姐，我是乡下人，不懂府中的规矩，望姐姐指教指教。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "你不要害怕，我家夫人是个吃斋的。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哦，又是一个吃斋的。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "我家夫人吃斋，比不得你家夫人白天吃斋，晚上开荤；我家夫人是吃长斋的， 是好说话的很。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哦，你家夫人是好说话的，罢罢罢，阿弥陀佛。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "你不要啰里啰嗦，随我进来吧。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "这就是我家夫人，上前叩头。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人在上，老奴叩头。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "丫鬟，快快将她扶起。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "多谢夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二媳背供。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "哎呀且住！别人与我叩头，我安然受礼；这位老妈妈与我叩头，我头晕眼花不 知为了何故，其中必有缘故。我不免盘问与她，问她的家乡住处。我就是这个 主意。 啊，老妈妈你家住在哪里？姓甚名谁？慢慢的讲来。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人容禀。"
        },
        {
          "character": "孙叔林",
          "type": "二黄摇板",
          "text": "家住山西平阳府， 柳川巷内有家门。 我丈夫名叫张文达，"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "哎呀，慢着！他丈夫名叫张文达，莫非他是婆婆孙叔林么？ 丫鬟，与老妈妈看座。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人在此，老奴不敢坐。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "夫人叫你坐下，你就坐下。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "多谢夫人。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老妈妈你叫何名？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人容禀。"
        },
        {
          "character": "孙叔林",
          "type": "二黄原板",
          "text": "老奴名叫孙叔林。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "你丈夫做何生意？"
        },
        {
          "character": "孙叔林",
          "type": "接唱",
          "text": "我儿夫自幼把书念， 一十五岁深入黉门。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "丫鬟，搀扶老妈妈上坐。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哎呀夫人哪，夫人赐坐，老奴大胆地坐，又将老奴搀扶正位，我越发的不敢坐 了。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "夫人叫你坐下。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "老奴不敢坐，不敢坐。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "你只管坐下吧。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "丫鬟姐你也坐下吧。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "我塑的站相，不能做。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "谢过夫人。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老妈妈可有儿女？"
        },
        {
          "character": "孙叔林",
          "type": "二黄原板",
          "text": "夫妻二人多和顺， 生下两个小姣生。 长子名叫硃砂贯， 次子名叫孔凤英。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "你的丈夫在何处做生意？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "夫人！"
        },
        {
          "character": "孙叔林",
          "type": "二黄原板",
          "text": "我儿夫上京去会进， 借得周、常二家银。 山西干旱多不顺， 树无枝叶草无根。 周、常二家来讨债， 无有银钱就抢人。 常家抢去硃砂贯， 周家抢去孔凤英。 撇下老身无投奔， 寻夫来到安阳城。 招商旅店身染病， 欠下店饭钱五两银。 无奈何才把我自身来卖， 卖了银钱还与店主人。 只望卖身有好处， 谁知落在一火坑。 常府中有位常太太， 她比阎罗狠十分。 一天将我三顿打， 三天九顿不容情。 我说此话夫人不信， 浑身上下有伤痕。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "二媳",
          "type": "二黄摇板",
          "text": "一见伤痕果是真， 背地骂声大贱人。 买母为奴该何罪， 败坏三纲并五伦。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老妈妈你且回去，等老爷回来，将你接到我府，吃一碗安乐茶饭就是了。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "多谢夫人。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "辞别夫人出府门，"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "却原来错过午时辰。 回去又是一顿打， 夫人搭救我命残生。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老妈妈不要害怕，我设法搭救于你就是。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "丫鬟。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "夫人什么事？"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "昨天常夫人前来剪花样子，可曾拿去没有？"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "没有拿去啦。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "将花样子拿来。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "是。 花样在此。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老妈妈你将花样子拿去，你家夫人不问便罢，若问，你说等我剪花样子的，她 就不会打你了。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "多谢夫人。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "多谢夫人赐恻隐， 用计搭救孙叔林。 日后若要得好处， 不忘夫人莫大恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙叔林下，"
        },
        {
          "character": "周子卿",
          "type": "内白",
          "text": "回府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子卿上。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "夫人。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老爷。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "啊，夫人，今日下官回得府来，看夫人脸上与往日不同，莫非有什么心事？"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "请问老爷，何年何月何日生辰？"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "啊，夫人，我与你数载的夫妻，今日为何问起此话？"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老爷呀！"
        },
        {
          "character": "二媳",
          "type": "唱",
          "text": "老爷有所不知情， 妾身言来听分明： 那老妈妈本是你的亲生母， 落在常府为仆人。"
        },
        {
          "character": "周子卿",
          "type": "唱",
          "text": "夫人一言来提醒， 提醒南柯梦中人。 人来与爷把轿顺，"
        },
        {
          "character": "二媳",
          "type": "唱",
          "text": "老爷息怒慢稍停。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老爷意欲何往？"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "去到常府与常天保评理。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "老爷，你与常老爷评理，他若听从于你倒还罢了，若不听从于你，倒被他羞辱 一场。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "依夫人之见？"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "依我之见，命家院前去接老妈妈前来，他若不允，再与他评理也还不迟。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "夫人的高见。 家院过来。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "拿我名帖去到常府，将那老妈妈接来，不得有误。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周院子下。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "但等家院回来便知明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周院子上。"
        },
        {
          "character": "周院子",
          "type": "白",
          "text": "启禀老爷：常老爷应允，常夫人不应允。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "可恼。"
        },
        {
          "character": "周子卿",
          "type": "唱",
          "text": "夫人且在衙中等，"
        },
        {
          "character": "二媳",
          "type": "唱",
          "text": "老爷必须见机行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子卿、二媳、周院子同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "常天保、常福同上。"
        },
        {
          "character": "常天保",
          "type": "引子",
          "text": "身受皇恩，与黎民，判断冤情。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "本府——常天保。只因昨日生辰之期，各衙前来拜寿。今日去至各衙道谢。 家院！"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "外厢顺轿。"
        },
        {
          "character": "周子卿",
          "type": "内白",
          "text": "周老爷到。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "周老爷到。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "我正要拜他，他倒来了，有请。"
        },
        {
          "character": "常福",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子卿上。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "年兄。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "年弟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子卿、常天保同坐。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "不知贤弟驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "岂敢。小弟来得卤莽，年兄海涵。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "昨日多蒙贤弟送一份厚礼，愚兄当面谢过。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "仁兄，你打发一老婆子前去退礼，你知道那老婆子她是何人？"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "她是哪一个？"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "是你我的母亲。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "住了。山西干旱三载，你我母亲早已去世。不看在年弟的份上，定讨无趣。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "常天保，你买母为奴，败坏纲常，该当何罪？"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "周子卿，底盗仓库，敢与我面见大人？"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "我怕你不成？"
        },
        {
          "character": "周子卿",
          "type": "唱",
          "text": "上前来抓住常天保， 大人台前把冤伸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子卿、常天保同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、中军、张文达同上。"
        },
        {
          "character": "张文达",
          "type": "引子",
          "text": "奉命查河南，秉忠心，保主江山。"
        },
        {
          "character": "张文达",
          "type": "念",
          "text": "河南八府水团团，南有五府北有三。彰德、卫辉并淮庆，河南开封归汝南。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "老夫——张文达。两榜进士出身，蒙圣恩，放我八府巡按。自到任以来，官清 民顺。昨日偶得一梦，只见两只小燕口角。忽然飞来一只大燕，与他二人解围， 不知是何吉兆。 站堂军，伺候了。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "何人击动堂鼓？"
        },
        {
          "character": "周子卿、常天保",
          "type": "内同白",
          "text": "知府参同判，同判告知府。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "传话出去，知府报门而进。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "知府报门而进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常天保上。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "报，知府常天保叩见大人。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "唗！胆大的知府，擅击本院的堂鼓，该当何罪？"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "启禀大人：周同判底盗仓库，大人详情。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "察院伺候。 同判跪门而进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子卿上。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "报，同判跪门参见大人。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "唗！胆大同判，为何底盗仓库，从实讲来。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "启禀大人：卑职仓库并未走漏。知府买母为奴，大人详情。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "本院不问哪家奴，谁家婢。你姓甚名谁，你慢慢地讲来。"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "大人容禀。"
        },
        {
          "character": "周子卿",
          "type": "唱",
          "text": "未曾开言我泪难忍， 尊声大人听详情： 我父名叫张文达，"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "脸朝外跪。"
        },
        {
          "character": "周子卿",
          "type": "二黄原板",
          "text": "我的母名叫孙叔林。 家住在山西省平原郡， 柳川巷内有家门。 山西干旱三年整， 不知父母哪乡存。 这顶乌纱我不戴， 望求大人把冤伸。"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "听他言来才知情， 原来两个小姣生。 这顶乌纱你戴定， 叫你母子相逢察院门。"
        },
        {
          "character": "周子卿",
          "type": "唱",
          "text": "卑职暂且察院等， 不参知府我不为人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。孙叔林上，跪。"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "一见夫人到来临， 不由老夫喜在心。 走上前来忙跪定，"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "问一声大老爷你、你是何人？"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "夫人不必胆怕惊， 我是你丈夫张文达到来临。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你是张文达？"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "夫人。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你是张秀才？"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "贤妻！"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哎，老爷呀。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "听说老爷到来临， 喜在眉头笑在心。 自分别为何无音信？ 难道说你不念夫妻情？"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "我也曾寄过了书和信， 我也曾寄过了安家银。 下书人回来报一信， 他言道：山西省干旱三载，寸草不生，无处找寻，休怨我身。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "我何曾见过你书和信， 我何曾见过你安家银。 别的话儿我不问， 丹墀下二位官长，头戴乌纱，身穿大红，足蹬朝靴，低头不语，他是何人？细 说分明。"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "这是长子硃砂贯， 那是次子孔凤英，是二个姣生。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "他二人头上把乌纱顶， 他二人何处管黎民，说与妻听。"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "长子洛阳为知府， 次子同判管黎民。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "老爷你呢？"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "老夫身受督察院， 一门三进士俱受皇恩，俱是读书之人。"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "听说是一家人俱已上进， 背转身来谢天廷。 下得丹墀把长子来认，"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "母亲。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你是常老爷。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "孩儿不敢。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "常太爷。"
        },
        {
          "character": "常天保",
          "type": "白",
          "text": "孩儿越发的不敢。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "奴才呀，"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "不孝的奴才骂一声。 买母为奴该何罪？ 败坏纲常并五伦。 骂罢了长子把次子来认，"
        },
        {
          "character": "周子卿",
          "type": "白",
          "text": "哎呀，母亲。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哦，儿啊……"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "行孝还是小姣生。"
        },
        {
          "character": "张文达",
          "type": "唱",
          "text": "夫人做事不公平， 一样儿子两看承。 怀抱次子放悲声， 为何不认大姣生，所为何情？"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "老爷有所不知情， 妾身言来听分明： 他府中有位常太太， 她比阎罗狠十分。 一天给我三顿打， 三天九顿不容情。 我说此话老爷不信，"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你来看——"
        },
        {
          "character": "孙叔林",
          "type": "唱",
          "text": "浑身上下有伤痕。"
        },
        {
          "character": "张文达",
          "type": "二黄摇板",
          "text": "一见伤痕果是真， 回头埋怨大畜生。 买母为奴该何罪， 上有青天不容情。"
        },
        {
          "character": "常天保",
          "type": "二黄摇板",
          "text": "早知母亲来到此， 头顶香盘接娘亲。"
        },
        {
          "character": "张文达",
          "type": "二黄摇板",
          "text": "一见娇儿把誓盟， 不由老夫痛在心。 走上前来忙跪定， 望夫人饶恕了大姣生。"
        },
        {
          "character": "孙叔林",
          "type": "二黄摇板",
          "text": "老爷言来妾身遵命， 背转身来自思忖： 这手心手背俱是我的肉， 哪一个孩儿不是我亲生。 走上前来把娇儿来认， 从今后把奴仆莫照娘行。"
        },
        {
          "character": "张文达、常天保、周子卿",
          "type": "同白",
          "text": "看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周丫鬟、大媳、二媳同上。常天保、大媳同拜。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "哼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周子卿、二媳同拜。孙叔林扶。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "这有家法在此，夫人教训了吧。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "妾身遵命。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "婆婆。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你是常太太。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "老太太，她常不了了，她矮了半截儿。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "常夫人。"
        },
        {
          "character": "周丫鬟",
          "type": "白",
          "text": "她连个棍儿都扶不住，她还扶人吗？"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "你要吃什么八珍汤？"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "不错的，是八珍汤。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "我今天打你一个九珍汤。"
        },
        {
          "character": "二媳",
          "type": "白",
          "text": "婆婆看在媳妇份上，饶恕她吧。"
        },
        {
          "character": "孙叔林",
          "type": "白",
          "text": "看在贤德二媳份上饶恕你这贱人，起来。"
        },
        {
          "character": "大媳",
          "type": "白",
          "text": "多谢婆婆。"
        },
        {
          "character": "常天保、周子卿",
          "type": "同白",
          "text": "孩儿要认姓归宗。"
        },
        {
          "character": "张文达",
          "type": "白",
          "text": "单等周、常二家下世，再来认姓归宗，打开祖先堂举家上香。正是："
        },
        {
          "character": "张文达",
          "type": "念",
          "text": "一门三进士，"
        },
        {
          "character": "孙叔林",
          "type": "念",
          "text": "举家受皇恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}