{
  "script_id": "05015002",
  "title": "恶虎关",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "伍星",
      "hangdang": "武净"
    },
    {
      "name": "伍通",
      "hangdang": "老生"
    }
  ],
  "plot": "伍员欲报父兄之仇，率吴国兵马灭楚。费无极聘恶虎山伍星助战。伍星系伍员之子。伍员逃吴时，伍星方三\n岁，托与恶虎山大王伍通抚养。伍星长大成人，伍通已年迈，乃将山寨大事交与执掌。伍星不知伍员为生父，\n领喽兵往战伍员，将伍员先行王龙、王虎杀死，柳展雄亦败阵。伍员与伍星交战，不分胜负。伍通在山上\n观望，见状，急鸣金收军。伍星上山，伍通说明旧事，即与伍星押费无极同往吴营认父。伍员会见伍通，方\n知伍星乃亲生之子，合兵一处，攻打昭关。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "屈蒙上。"
        },
        {
          "character": "屈蒙",
          "type": "引子",
          "text": "忠心扶圣君，协力报王恩。"
        },
        {
          "character": "屈蒙",
          "type": "念",
          "text": "我本当朝丞宰，身荣位列三台。妻贤子孝堪慰，一片忠心不改。"
        },
        {
          "character": "屈蒙",
          "type": "白",
          "text": "老夫屈蒙。在吴王驾前为臣，官居首相。只因我主得了楚国伍员，灭却王僚。 今当早朝，上殿伺候。 来，带路上朝。"
        },
        {
          "character": "屈蒙",
          "type": "唱",
          "text": "朝臣待漏正五更， 铁甲将军夜谈兵。 文官策论安天下， 武将协力定太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屈蒙下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员、屈蒙、钟离胥、孙武子同上。打朝。〖点绛唇〗。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "伍员。"
        },
        {
          "character": "屈蒙",
          "type": "白",
          "text": "屈蒙。"
        },
        {
          "character": "钟离胥",
          "type": "白",
          "text": "钟离胥。"
        },
        {
          "character": "孙武子",
          "type": "白",
          "text": "孙武子。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "屈蒙、钟离胥、孙武子",
          "type": "同白",
          "text": "亚父上朝，为何来得这早？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "列公有所不知：老朽非为别事，我主已登大宝，意欲请借一枝人马与我，伐楚 报仇，烦劳列公启奏。"
        },
        {
          "character": "屈蒙、钟离胥、孙武子",
          "type": "同白",
          "text": "大家启奏，请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、屈蒙、钟离胥、孙武子自两边分下。〖朝天子〗。四小太监、姬光同上。"
        },
        {
          "character": "姬光",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "姬光",
          "type": "念",
          "text": "鱼肠藏剑刺王僚，众卿扶保坐龙朝。深喜得了子胥将，可算当世一英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姬光归座。伍员、屈蒙、钟离胥、孙武子自两边分上，同参拜。"
        },
        {
          "character": "伍员、屈蒙、钟离胥、孙武子",
          "type": "同白",
          "text": "臣等参拜，大王千岁！"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "伍员、屈蒙、钟离胥、孙武子",
          "type": "同白",
          "text": "千千岁。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "孤姬光。今当早朝。 内侍！"
        },
        {
          "character": "小太监甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "开放龙门。"
        },
        {
          "character": "屈蒙、钟离胥、孙武子",
          "type": "同白",
          "text": "今有亚父，求千岁借一枝人马，伐楚报仇。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "不是众卿提起，险些忘怀了。 孤王赐你倾国人马，王龙、王虎为马前先行，伐楚报仇。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "内侍看宴。"
        },
        {
          "character": "姬光",
          "type": "唱",
          "text": "为王我赐与你人马数万， 有王龙和王虎奋勇当先。 内侍臣看过了皇封御宴， 待孤王与亚父亲口吉言： 孤愿你此一去得胜回转， 孤愿你此一去太平安然； 孤愿你此一去报却仇怨， 接风酒王为你备在金銮。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "谢过了千岁爷皇封御宴， 听老臣有一言细奏君前： 曾记得临潼会设下酒宴， 众王子将宝贝排列金銮。 楚平王无宝贝把脸来变， 那时臣酒席前怒发冲冠。 在临潼举宝鼎威风来显， 才压定众王子不敢多言。 称我是十八国明辅好汉， 秦公主与公子建配合姻缘。 命无极到秦邦迎亲回转， 狗奸贼中途路巧计多端。 他把那吴香女当殿来献， 那昏王纳儿媳罪有万千。 我的父在金殿忠言谏劝， 听奸言杀满门命丧黄泉。 逼我父修书信将我来赚， 为臣的解其情不入朝班。 弃樊城过昭关孤身逃难， 蒙千岁搭救恩地厚天宽。 蒙千岁赐为臣皇封御宴， 蒙千岁赐人马为报前冤。 但愿得此一去得胜回转， 那时节上金殿叩谢龙颜。"
        },
        {
          "character": "屈蒙",
          "type": "白",
          "text": "酒来。"
        },
        {
          "character": "屈蒙",
          "type": "唱",
          "text": "有老朽在筵前借酒为饯， 尊一声老明辅细听我言： 想当初刺王僚功劳不浅， 千岁爷得太平驾坐金銮。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "有劳大人。"
        },
        {
          "character": "钟离胥",
          "type": "白",
          "text": "酒来。"
        },
        {
          "character": "钟离胥",
          "type": "唱",
          "text": "喜孜孜走上前杯酒奉献， 放欢容展笑脸细听我言： 久闻你在临潼威名扬远， 到今日保我主架海擎天。"
        },
        {
          "character": "孙武子",
          "type": "白",
          "text": "明辅！"
        },
        {
          "character": "孙武子",
          "type": "唱",
          "text": "有贫道不把这杯酒来献， 尊一声伍大人细听我言： 我算你此一去定偿心愿， 兵行在恶虎山早安营盘。 恶虎山有小将威猛勇敢， 临阵上可将他收在马前。 你休要与小将斤斤较量， 过昭关报冤仇可仗此男。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "尊千岁众大人把心放宽， 臣虽然年纪迈赛过幼男。 蒙先生一派言感恩非浅， 到阵前领兵将攻破昭关。 辞千岁别列公忙下金殿， 到教场点兵将去报仇冤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "众卿，准备与明辅送行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小把同上，同站门，费无极上。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "俺，费无极。探马报道：伍员投奔吴国，借兵伐楚。我奉大王旨意，押定各样 珠宝，去至恶虎山，聘请伍星，大战伍员。 众将官，催马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王龙、王虎、柳展雄、焦义同上，同起霸。〖点绛唇〗。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "俺王龙。"
        },
        {
          "character": "王虎",
          "type": "白",
          "text": "俺王虎。"
        },
        {
          "character": "柳展雄",
          "type": "白",
          "text": "俺柳展雄。"
        },
        {
          "character": "焦义",
          "type": "白",
          "text": "俺焦义。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "请了。元帅升帐，两厢伺候！"
        },
        {
          "character": "王虎、柳展雄、焦义",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四白龙套、伍员同上。〖点绛唇〗。〖吹打〗。伍员上高台。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "白盔白甲白簪缨，临潼斗宝显奇能。吴王驾前把兵领，杀却无极灭昏君。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺，姓伍名员，字子胥。 众将官，兵发恶虎山。"
        },
        {
          "character": "王龙、王虎、柳展雄、焦义",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四白龙套、王龙、王虎、柳展雄、焦义、伍员同斜胡同。〖牌子〗。"
        },
        {
          "character": "王龙、王虎、柳展雄、焦义",
          "type": "同白",
          "text": "来在恶虎山。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "人马列开，二先行听令！"
        },
        {
          "character": "王龙、王虎",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "前途打探，速报我知。"
        },
        {
          "character": "王龙、王虎",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王龙、王虎领四上手同下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "安营扎寨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍星上，起霸。"
        },
        {
          "character": "伍星",
          "type": "念",
          "text": "某生来虎心豹胆，霸山寨执掌兵权。恶虎山前威名显，谁不闻名望影还！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上。"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "俺飞天豹伍星。爹爹伍通。今有费无极押定各样珠宝，聘我下山，大战伍员。 众喽兵。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、王龙、王虎同上，同会阵。"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "王龙、王虎",
          "type": "同白",
          "text": "（王龙）（王虎）。你是何人？"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "老子伍星，鞭下受死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星、王龙、王虎同起打。王龙、王虎被伍星打死。四上手同逃下，伍星追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、伍员同上。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "吴王驾前把兵领， 杀却无极灭昏君。 数载冤仇今消恨， 且听探子报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "二先行落马。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "那贼兵势如何？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "恶虎山小将甚是厉害，好威风也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "赏你银牌一面，再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且住。方才探子报道：恶虎山前小将奋勇，待本帅亲自出马。 众将官，听我令下！"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "适才探马报军情， 恶虎山前大交兵。 莫非此去多不幸， 皇天岂佑灭伦君？ 三军排下埋伏阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同押门下。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "两军前看一看年少之人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍通上。"
        },
        {
          "character": "伍通",
          "type": "引子",
          "text": "闷坐山林，思兄一片心。"
        },
        {
          "character": "伍通",
          "type": "念",
          "text": "曾记当年起祸端，伍员逃难离金銮。自从他去投吴国，至今无有音信还。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "老汉伍通。乃楚国人氏，在恶虎山自立为王。前者伍员逃难，他有一子，名叫 伍星，年方三岁，托付于我。老夫带在山寨，抚养成人，一十八载，执掌山寨 大事。今日闷闷不乐，山前山后游玩一番便了。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "坐至在山林地心中烦闷， 想起了伍家事世代忠臣。 恨平王他无道荒淫失政， 听谗言将忠臣灭却满门。 那伍员独一人逃了性命， 杀他父这冤仇常挂在心。 但愿得在吴国大兵来领， 杀奸贼报冤仇方称我心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四白龙套、柳展雄、焦义、伍员同上。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "催马且把战场进， 大叫山寇听分明： 有名将官来见阵， 无名之辈莫出兵！"
        },
        {
          "character": "伍星",
          "type": "内西皮导板",
          "text": "威风凛凛下山岭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星上。"
        },
        {
          "character": "伍星",
          "type": "西皮摇板",
          "text": "恶虎山前大交兵。 老将果然威风凛， 白盔白甲白簪缨。 赛天师缺少翻天印， 恰好似太公子牙，闻仲缺少黑麒麟。 老将快表名和姓， 稍若迟延命难存。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "娃娃听了！"
        },
        {
          "character": "伍员",
          "type": "西皮二六板",
          "text": "娃娃休要问爷的名， 提起了威名唬破儿的三魂。 临潼会老爷曾举鼎， 柳展雄被某也生擒。 怒发冲冠如雷震， 气吐虹霓九霄云。 只杀得各国无投奔， 一个个在马前他递过了降文。 恨平王无道行不正， 父纳子妻败坏了人伦。 我的父谏奏反送命， 绝不该杀我一家门。 三百余口刀刀斩尽， 就是那鸡犬也不留根。 伍员心中怀不平， 带领人马反出昭关城。 娘娘身坠葵花井， 铁石人闻也泪淋。 今日吴国把兵领， 杀却了无极要灭那昏君。 你若是问爷的名和姓， 临潼会上斗宝的爷叫楚伍员。"
        },
        {
          "character": "伍星",
          "type": "唱",
          "text": "听他说是楚伍员， 不由少爷咬牙根。 劝你马前来归顺， 少爷收你作先行。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "娃娃休要把能逞， 你的眼睛错认了人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、伍星同起打双下。柳展雄上，与四下手同打下。伍星上。"
        },
        {
          "character": "伍星",
          "type": "唱",
          "text": "催马且把战场进， 老将到来赌输赢。 看准伍员放一箭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星放箭下。伍员上，接箭。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "接一根，儿倒武艺精放箭能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。伍星上。"
        },
        {
          "character": "伍星",
          "type": "唱",
          "text": "老将威风接雕翎， 看二箭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星放箭下。伍员上，接箭。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "接二根。 明知深山藏虎境， 大胆且把虎山行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。伍通上。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "适才探子报一声， 恶虎山下大交兵。 下得马来山林进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通上高台。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "看是谁胜谁败哪家赢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星上。"
        },
        {
          "character": "伍星",
          "type": "唱",
          "text": "伍员本领果然精， 连接我雕翎有二根。 怒气不息放三箭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星放箭下。伍员上，接箭。"
        },
        {
          "character": "伍员",
          "type": "唱",
          "text": "射我咽喉不差分。 老爷勒马再进阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星上。"
        },
        {
          "character": "伍星",
          "type": "唱",
          "text": "观看老将哪里行？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、伍星同起打，伍星败下，伍员追下。"
        },
        {
          "character": "伍通",
          "type": "唱",
          "text": "前面败的伍星子， 后面追的楚伍员。 父子见面不相认， 吩咐鸣金收了兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通下。伍星、四下手同上，同埋里。伍员上，两望门。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "娃娃敢么惧战？"
        },
        {
          "character": "伍星",
          "type": "叫头",
          "text": "老将吓，老将！"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "山寨鸣金收兵，明日再战！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "来者？"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "君子！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "不来？"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "小人！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "暂把儿的人头，寄在项上。"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "众将官，收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星、四下手同下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍通上。"
        },
        {
          "character": "伍通",
          "type": "念",
          "text": "适才观罢阵，对儿说分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍星上。"
        },
        {
          "character": "伍星",
          "type": "念",
          "text": "战罢楚伍员，叩见老爹尊。"
