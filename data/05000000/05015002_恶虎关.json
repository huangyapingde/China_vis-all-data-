        {
          "character": "伍星",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "坐下。全身披挂，与何人交战？"
        },
        {
          "character": "伍星",
          "type": "白",
          "text": "与伍员交战。"
        },
        {
          "character": "伍通",
          "type": "白",
          "text": "我想伍员有满腹冤仇未报，你与他交战，是何道理？"
