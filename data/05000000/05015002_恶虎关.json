        {
          "character": "伍通",
          "type": "唱",
          "text": "伍星随我把父认，"
        },
        {
          "character": "伍星",
          "type": "唱",
          "text": "去到阵前认天伦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍通、伍星同下。"
        }
      ]
    },
    {
