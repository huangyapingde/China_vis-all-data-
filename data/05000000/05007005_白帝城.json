{
  "script_id": "05007005",
  "title": "白帝城",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "刘备兵败，奔白帝城，羞愤得病，自知不起，遣使至成都请丞相诸葛亮来，听受遗命；刘备托孤而死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮原板",
          "text": "我主爷坐山河未享安静， 全凭着五虎将保定乾坤。 我心中恨的是东吴陆逊， 必须要把孙曹一旦扫平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李严上。"
        },
        {
          "character": "李严",
          "type": "白",
          "text": "启先生：主公兵败白帝城！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你传文武百官，去至白帝城接驾便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李严下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "阴阳八卦早算定，主公兵败白帝城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内白",
          "text": "搀扶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞搀刘备同上。"
        },
        {
          "character": "刘备",
          "type": "二黄慢板",
          "text": "为江山把孤的心血用尽， 何日里把孙曹一旦扫平？ 二皇侄搀孤王龙床养静， 活活地把桃园两下离分。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马良、马谡、赵云、邓芝、费祎、二太子、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄摇板",
          "text": "主公兵败白帝城， 急忙进宫问分明。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣等见驾，吾皇万岁。"
        },
        {
          "character": "刘备",
          "type": "二黄导板",
          "text": "正在龙床来养静，"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "昏昏沉沉有人声。 睁开了昏花眼强自扎挣，"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "先生！"
        },
        {
          "character": "诸葛亮",
          "type": "叫头",
          "text": "主公！"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "四弟！"
        },
        {
          "character": "赵云",
          "type": "叫头",
          "text": "万岁！"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "啊，众卿哪……"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎、二太子、诸葛亮",
          "type": "同哭",
          "text": "万岁呀……"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "抬头只见众公卿。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公，自觉龙体如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生哪。孤患此疾，只恐死在旦夕。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公切须保重龙体才是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生有治国大才，比曹丕胜强十倍，当能安邦定国。嗣子懦弱，当扶则扶；如 若不才，先生你、你、你就自己消受了罢。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎呀主公啊！多蒙主公三顾之恩，臣纵肝脑涂地，鞠躬尽瘁，死而后已！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮哭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好个忠义的先生！ 二皇儿过来。尔弟兄三人，以父事丞相，不可怠慢，向前拜过先生，以为相父。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。二太子同拜。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "张苞，命你将你父的尸首搬回阆中安葬去罢。"
        },
        {
          "character": "张苞",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苞下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "关兴听令：命你带领三千人马，抵挡吴兵。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "从前不听先生言，损兵折将也枉然。马到临崖收缰晚，船到江心……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "补漏难哪……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备哭。"
        },
        {
          "character": "刘备",
          "type": "二黄慢板",
          "text": "事到临头才知悔， 自己错了埋怨谁？ 楚霸王他不听范增语， 乌江岸前把命逼。 曹孟德中原成大器， 他人的奸诈有谁知？ 阿斗年幼终何用， 还望先生费心机。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生哪。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄原板",
          "text": "主公不必泪悲啼， 为臣言来奏主知： 蒙主公三顾之恩义， 鞠躬尽瘁死而后已。"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "叹先生说此话世间稀， 二皇儿近前来细听端的： 待先生如同待父意， 他保阿斗立帝基。 二皇儿近前来搀父体，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下位。"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "手搀先生泪悲啼。 孤还有紧要事嘱咐你， 还望先生牢记心里。 头一件扫荡中原地， 第二要恢复汉室基。 哭一声懦弱的汉献帝， 四百载基业化灰泥。"
        },
        {
          "character": "赵云",
          "type": "二黄摇板",
          "text": "万岁还须保龙体， 臣等保主不敢欺。"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "回头又见赵四弟， 你的功劳王尽知。 自从患难来相聚， 又谁知今日两分离。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "众位卿家。"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎、诸葛亮",
          "type": "同白",
          "text": "万岁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "邓芝！"
        },
        {
          "character": "邓芝",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "马良！"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "众位卿家请站起， 叫声邓芝、马良和费祎。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "马谡，马谡，马谡！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "哦——"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "言过其实是马谡！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "你、你、你……用他必须要查端的。 观见二弟和三弟， 等等愚兄一路随。 霎时间难接我的咽喉气！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备三吐血。"
        },
        {
          "character": "刘备",
          "type": "二黄摇板",
          "text": "无常到万事休一命归西。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备死。"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎、诸葛亮",
          "type": "同白",
          "text": "哎呀！"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎、诸葛亮",
          "type": "同二黄摇板",
          "text": "一见龙驾归了西， 文武百官泪悲啼。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军、大人，不必悲恸，暂将龙驾移了下去。"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎",
          "type": "同白",
          "text": "呵……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军，歇兵三日，齐奉榇棺，退还成都便了。"
        },
        {
          "character": "马良、马谡、赵云、邓芝、费祎",
          "type": "同哭",
          "text": "主公啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}