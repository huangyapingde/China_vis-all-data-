{
  "script_id": "05014005",
  "title": "左慈骂曹",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "左慈",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "华歆",
      "hangdang": "丑"
    }
  ],
  "plot": "华歆奉曹操命至温州采办黄柑，途遇一道人，将车轮推动，黄柑即时中空无心。华歆乃带道人见曹操。道人\n立而不跪，不认有盗柑情事。剖柑相验，则黄柑俱复有心。道人出言讽曹操，谓其残害忠良，心肠狠毒，欺\n君叛逆，遗臭万年。曹操怒而责之。道人数骂曹操历年战败狼狈之状。曹操愈怒，责之愈毒。道人死而复苏，\n又数其杀死吕伯奢全家，带剑入宫，绞死董妃各项罪状。曹操问其姓名，答称乃是四川左慈，得异人传授\n三卷天书。曹操欲学天书。左慈劝将朝政付与刘备执掌。曹操疑为刘备所使。左慈请画龙取肝下酒，曹操许\n之。画成，左慈骑龙而去。曹操命华歆领人追赶，不料满城皆左慈化身，曹操传令尽杀之。左慈竟扬长而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "四海名扬，各路诸侯拱手降。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "忆昔争战虎牢关，朝廷将帅尽调残。顶天立地男儿汉，腰悬三尺斩苗蛮。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫姓曹名操，字孟德。沛国谯郡人氏，在献帝驾前为帝，爵封魏王，这也不 须言表。也曾命华歆前到温州采办黄柑，未见回来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华歆上。"
        },
        {
          "character": "华歆",
          "type": "念",
          "text": "采办黄柑事，报与魏王知。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "华歆打躬。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "免。命你采办黄柑一事如何？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "采来了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "呈上来，待老夫观看。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "在此。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "好黄柑，妙黄柑，青气扑鼻，味美皮黄。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待老夫剖开一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操剖柑。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "为何内面无心？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "华歆行至中途，遇一残疾道人，将车轮推了几步，故而无心。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "就该将他拿下！"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "带来了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "带上来。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "这道人，魏王传你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左慈上。"
        },
        {
          "character": "左慈",
          "type": "念",
          "text": "迈步上公廷，打动奸佞臣。"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "明公在上，贫道稽首！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "见了老夫不跪，说什么“稽首”二字！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "贫道云游天下，两跪一不跪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哪两跪一不跪？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "跪天跪地，中不跪于国家。稽首顿首，恭贺魏王，天长地久。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "跪与不跪，但凭于你。为何将老夫黄柑心盗去？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "贫道并没有见什么黄柑。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "黄柑在此，拿去观看。"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "待贫道看来！"
        },
        {
          "character": "左慈",
          "type": "念",
          "text": "好黄柑，妙黄柑，青气入骨透，皮黄肉不熟。"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "待我剖开一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左慈剖柑。"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "分明有心在内，说什么无心！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你看有心，我看无心。"
        },
        {
          "character": "左慈",
          "type": "念",
          "text": "这黄柑只见得善心，见不得你那狠心。善心一见心还在，狠心一见心不存。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫忠心为国，怎见心狠？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你道你的心不狠么？"
        },
        {
          "character": "左慈",
          "type": "唱",
          "text": "你道你心不狠， 我道你一片片蛇蝎心肠， 一人梦想吞帝邦。 起心不良势压乡党， 拔剑害忠良， 杀害许多忠良将。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "休要多讲。"
        },
        {
          "character": "左慈",
          "type": "唱",
          "text": "非贫道多讲。 仔细从头听端详： 一人做事多诈诳， 只图自王哪管他人丧。 全然不怕人谈讲。 你好比篡位王莽， 董卓专汉，兴汉刘邦； 不学萧何、韩信、张子房。 说来惭愧你不可当！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，吩咐转堂伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "原场转堂。四手下同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "少待。 这道人道数老夫过恶。讲得好，倒还则可，讲得不好，当面打死！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "魏王要我道你过恶，讲差了，休得见怪！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你讲！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你听！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你说！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你仔细听了。"
        },
        {
          "character": "左慈",
          "type": "唱",
          "text": "你自不忖量。 仔细从头听端详： 人人有个心会想， 万结灵芝无推让。 欺君叛逆，狐群狗党， 作恶之徒，装模作样， 阴曹地府怎见阎王。 举目油锅要你受享， 臭名万代何处隐藏。 贫道若得阎君做， 拿住奸贼除祸殃。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来！拿下去打！"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四手下同打左慈。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "打死了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "搀起来放下！气绝了没有？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "气绝了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "拖下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左慈活。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "又活了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这道人，打你不死，难道不知老夫的威名？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "讲起你的威名，贫道好笑得紧！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你讲！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你听！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你说！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你仔细听了。"
        },
        {
          "character": "左慈",
          "type": "唱",
          "text": "不记长安受惨伤， 吕布濮阳遇战场。 宛城张绣知你的威名大， 赤壁屯兵知你的美名扬。 黄骠马，丧战场， 火烧堕高梁， 罪在你身上。 吕布金枪搁在你肩头上， 你那里，生计巧， 问声曹操归何处， 反说曹操奔许昌。 再说兴兵下江南， 东吴闻言胆战慌。 武将怕战文官要降， 周郎隔江打一望， 不巧染病在营房， 诸葛先生过大江， 十六字神机袖里藏。 三日三夜东风降， 一火烧得曹操精打光。 华容道，遇关公， 施仁义，将你放。 潼关道，遇马超， 受惨伤，割须弃袍来逃走， 险些一命丧黄粱。 这是你声名扬， 说来惭愧不可当。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，叉下去打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四手下同打左慈。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "打死了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "搀起来放下！气绝了没有？"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "气绝了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "拖下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四手下同拖左慈下，左慈上。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "转来了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这道人，打你不死，难道不知王法？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "提起王法，贫道没有你犯得多！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你讲！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你听！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你说！"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你仔细听了。"
        },
        {
          "character": "左慈",
          "type": "唱",
          "text": "你辞董卓往他乡， 黑夜逃在吕家庄。 好一个吕伯奢， 与你父结交来往， 捆杀猪羊摆成酒浆。 哪知你，生奸巧， 你将他一家大小，老老少少， 斩尽杀绝，杀一个精打光。 许田射鹿欺君王， 三呼万岁你承当。 平白带剑入宫墙， 逼死主母绞死娘娘。 周围布下天罗网， 逼君立后在宫墙。"
        },
        {
          "character": "左慈",
          "type": "夹白",
          "text": "哎吓吓苦吓！"
        },
        {
          "character": "左慈",
          "type": "唱",
          "text": "董娘娘，一命亡， 董承死，马腾亡， 吉平无故受惨伤。"
        },
        {
          "character": "左慈",
          "type": "夹白",
          "text": "哎吓吓苦吓！"
        },
        {
          "character": "左慈",
          "type": "唱",
          "text": "提起心头泪汪汪， 君要臣死不得不死， 父要子亡不得不亡。 贫道若得阎君做， 拿住奸贼赴黄粱。 先剜你的肝胆， 后割你的肚肠， 那时方称得我心畅。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "一派胡言！叉下去打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四手下同打。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "住棍。"
        },
        {
          "character": "曹操",
          "type": "扑灯蛾",
          "text": "泼道太猖狂，言语来冲撞。 叫人看棍打，管叫一命亡， 烈烈轰轰闹一场，闹一场。"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "左慈",
          "type": "扑灯蛾",
          "text": "身梦在黄粱，耳边风声响， 任你假虎威，任你似豺狼， 只当儿童戏耍场，戏耍场！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这道人，打也打你不死，你家住哪里？姓甚名谁？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "家住四川峨嵋山，姓左名慈，石洞修道，道号乌角先生。石壁响亮，得了天书 三卷。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "上卷？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "腾云驾雾。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "中卷？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "飞砂走石。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "下卷？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "飞剑能取项上人头！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫有意与你学这三卷天书，好掌朝纲大事。"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "你怎么掌得朝纲大事？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "何人能掌？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "贫道与你举荐一人。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "举荐何人？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "西川刘使君！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "少待。 这道人开口刘使君，闭口刘使君，莫不是刘备差来细作，打听老夫消息？ 来！将这道人斩讫报来！"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "拿他不动！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "真乃有点道理。"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "少待。 你看这奸贼痴迷不醒，本待用飞剑伤他，怎奈天不灭曹，这便怎处。呵哈，有 了。 魏王，这黄柑服之无益，贫道略施小计，壁上画龙，能取龙肝下酒！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "要些什么用费？"
        },
        {
          "character": "左慈",
          "type": "白",
          "text": "只要凉水一碗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看凉水过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "手下甲取凉水上。"
        },
        {
          "character": "左慈",
          "type": "念",
          "text": "贫道玄机贯九州，五湖四海任遨游。明明指引道程路，怎奈奸贼不回头。 法水喷堂前，壁上蛟龙现。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙形上。左慈骑龙形下。"
        },
        {
          "character": "华歆",
          "type": "白",
          "text": "启禀丞相：这道人跨龙走了！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "前去追赶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华歆、四手下同追下，同上。"
        },
        {
          "character": "华歆",
