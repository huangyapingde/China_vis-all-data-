{
  "script_id": "05009002",
  "title": "雄州关",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "韩世忠",
      "hangdang": "老生"
    },
    {
      "name": "韩彦直",
      "hangdang": "武生"
    },
    {
      "name": "金兀术",
      "hangdang": "净"
    }
  ],
  "plot": "金兵犯宋，占潞安，紧逼雄州。守将韩世忠驰报进京求援，广阳王童贯为报私仇，故任孙浩为总兵率众前往。\n孙浩原为韩世忠麾下部将，因违犯军令，被韩世忠责打四十军棍革职，今大权在握，拟趁机报仇。孙浩至\n三江口，韩世忠不敢擅离，乃遣部将前往迎接。孙浩责韩世忠有意怠慢，催马闯入飞龙岭，拟先败金兵，立\n功后再擒韩世忠问罪。韩世忠恐其有失，遣子韩彦直暗中保护。后孙浩阵亡，韩世忠恐童贯见责，欲将韩彦\n直问斩。众将力阻，始准其戴罪立功。韩彦直大败金兵，金兀术乃狼狈逃走。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达同上，同起霸。"
        },
        {
          "character": "呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同念",
          "text": "百万貔貅犯中原，扰乱宋室不安然。渴时饮的刀头血，饥馁人头当饭餐。"
        },
        {
          "character": "呼延狄",
          "type": "白",
          "text": "俺金邦大将军呼延狄。"
        },
        {
          "character": "雷洪其",
          "type": "白",
          "text": "俺金邦副将军雷洪其。"
        },
        {
          "character": "达林承",
          "type": "白",
          "text": "金邦左先锋达林承。"
        },
        {
          "character": "季乐芬",
          "type": "白",
          "text": "金邦右先锋季乐芬。"
        },
        {
          "character": "萨里阿",
          "type": "白",
          "text": "前营将军萨里阿。"
        },
        {
          "character": "夜里混",
          "type": "白",
          "text": "后营骁骑大将军夜里混。"
        },
        {
          "character": "铁儿熊",
          "type": "白",
          "text": "左营押队将军铁儿熊。"
        },
        {
          "character": "土谷达",
          "type": "白",
          "text": "右营虎威大将军土谷达。"
        },
        {
          "character": "呼延狄",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "呼延狄",
          "type": "白",
          "text": "你我奉狼主之命，随四太子领兵夺取宋室江山，兵到即克，也是徽宗气数当尽 了。 中国京剧戏考 《雄州关》【头本】 2"
        },
        {
          "character": "雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同白",
          "text": "着哇。"
        },
        {
          "character": "呼延狄",
          "type": "白",
          "text": "咳，这些蛮子怎能苦争恶战，这是我狼主洪福齐天也。"
        },
        {
          "character": "雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同白",
          "text": "听，觱篥声响，太子升帐，你我两厢伺候。"
        },
        {
          "character": "呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同白",
          "text": "请。 （呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达分站。四蓝文堂、四小番、金兀术 同上。）"
        },
        {
          "character": "金兀术",
          "type": "点绛唇",
          "text": "将士英雄，军威压众，强兵勇，战马如龙，令出山摇动。"
        },
        {
          "character": "呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同白",
          "text": "参见殿下。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "金兀术",
          "type": "念",
          "text": "杀气腾腾漫乾坤，哀声处处震天庭。徽宗失政宠奸佞，锦绣江山一旦倾。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "孤、金邦四太子完颜兀术。今为徽宗无道，宠信奸臣，内监童贯，封为广阳王 之职，前有密信到父王处，约定兴兵，夺取社稷，有他以为内应，这江山岂不 唾手而得。自兴兵以来，攻无不取，战无不胜，前者破了潞安州，守将陆登自 刎身死，甚为悲惨。前面乃是雄州关，守将韩世忠，此人亦是忠勇之士，不忍 逼之，意欲招他归顺，助孤一臂之力，何愁大事不成！ 众番儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达同应。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "此番兴兵，必须人人奋勇，个个争先，兵至雄州关，不可擅杀黎民，违令者斩。 就此催动人马。 中国京剧戏考 《雄州关》【头本】 3"
        },
        {
          "character": "呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达",
          "type": "同白",
          "text": "呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖二犯江儿水〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "短甲随身衲袄齐，肩上横担令字旗。年年岁岁领皇赏，一马冲至军队里。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "俺乃韩元帅麾下能行探子是也，奉了元帅将令，着俺四路哨探。今圣上差孙浩 督兵前来剿灭金邦，已到三江口，不免飞骑报与元帅知道，就此马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂引韩世忠同上。"
        },
        {
          "character": "韩世忠",
          "type": "唱",
          "text": "为金兵急得我神魂不定， 盼救兵望眼穿昼夜不宁。 陆元帅尽忠心自刎丧命， 只一子失陷在万马军营。 好叫我忍不住腮边泪滚， 可叹他夫妻们饮恨幽冥。 急公文求圣上遣将助阵， 因何故十数日渺无信音？ 在二堂思无计心中忧闷， 我父子只恐怕难敌雄兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "探马如飞急，叩启元帅知。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启元帅，探马求见。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "吩咐开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、韩世忠同下。四红文堂、四红大铠、韩世忠同上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "呔，开门。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "传探马。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "元帅有令，探马进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报，探马告进。帅爷在上，探马叩头。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "哪路军情，起来讲。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "元帅容禀："
        },
        {
          "character": "报子",
          "type": "念",
          "text": "一马哨探似流星，朝中差来孙总兵。十万人马到疆界，报禀元帅得知情。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "朝中无有什么姓孙的吓？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "在元帅麾下当过副将的。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "敢是那孙浩？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "且住，那孙浩在某麾下，曾为步将，只因犯我军令，将他捆打四十，他逃至京 中，在广阳王府中做一随侍，今番奉旨前来，焉有不接之理？ 传众将进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋将同上。"
        },
        {
          "character": "四宋将",
          "type": "同念",
          "text": "虎帐传军令，将士共驱迎。"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "参见元帅。 中国京剧戏考 《雄州关》【头本】 4"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "列位将军少礼。"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "谢元帅。传末将进帐，有何军情？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "圣上命孙浩督兵前来，征剿金人，已到三江口，命你等前去迎接。"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "元帅，那孙浩有何德能，得授此职？倘若问及元帅，我等如何回答？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "听我令下！"
        },
        {
          "character": "韩世忠",
          "type": "唱",
          "text": "韩世忠坐宝帐传言发令， 叫一声众将官细听详情： 那孙浩平日间为人不正， 犯军令责打他不能容情。 逃到了京师地广阳府进， 童太尉听谗言蒙混圣君。 迎接他务须要言语谨慎， 那贼子寻仇隙暗地伤人。"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "四宋将",
          "type": "同唱",
          "text": "韩元帅忠义士谁人不敬？ 哪怕那孙浩贼势利小人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋将同下。"
        },
        {
          "character": "韩世忠",
          "type": "唱",
          "text": "大宋朝八代君徽宗失政， 贪酒色诬忠良宠信奸臣。 恨蔡京与童贯伤害民命， 惹得那四路里齐起刀兵。 金兀术兴人马夺取州郡， 逼元帅伤军兵黎民遭倾。 众将官退大帐各归营汛， 只等候四将回遣将调兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四将官引孙浩同上。"
        },
        {
          "character": "孙浩",
          "type": "引子",
          "text": "奉旨领雄兵，紫罗袍不愧先人。定斩世忠消吾恨，还报四十军刑。"
        },
        {
          "character": "孙浩",
          "type": "念",
          "text": "胸怀巧诈极聪明，不近贵人怎升腾。只道一生空劳力，运至时来命通亨。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "俺孙浩，塞北人也。昔在韩世忠麾下为步将，终日不安军法，专门贪花恋酒， 抢一有夫之妇作乐，不想韩世忠便要将俺斩首，是俺推在步军刘名身上，彼时 将那步军斩首号令，又道俺带领无方，捆打四十，削除头领，赶出不用。是俺 又羞又恼，一怒奔到京中，恰遇童太尉朝罢回府，闯了他的禁道，将我拿到府 中拷问，我将韩世忠打革之事，从头诉上，不料童太尉与韩世忠久有仇恨，听 了此言就道，“吓韩世忠，五爷若不找你驴头，誓不为人也”，便将俺收在府 中，我便百般奉承，是他心中欢喜，想要重用于俺。如今金兀术兴兵犯界，破 了数处城池，兵到雄州关，韩世忠本章到京求将添兵，童太尉提奏一本，命俺 领兵前来，战灭番贼。若是得胜，道韩世忠贪生怕死；若是损兵折将，道他按 兵不动。慢说一个韩世忠，就是一百个韩世忠，只好化为乌有也。前面已是三 江口。 众将官，催动人马！"
        },
        {
          "character": "孙浩",
          "type": "唱",
          "text": "见旌旗空中飘人声喧震， 抖起了万丈尘沸沸腾腾。 曾记得到京都那般光景， 岂料我今日里督领雄兵。 韩世忠好比做孩童之分， 怎知晓暗中刀要尔残生。 我料他入南柯梦魂未醒， 绑云阳一命倾才晓前情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋将同上。"
        },
        {
          "character": "孙浩",
          "type": "stage",
          "text": "中国京剧戏考 《雄州关》【头本】 5"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "雄州关总爷麾下四营将校迎接总爷。"
        },
        {
          "character": "将官甲",
          "type": "白",
          "text": "雄州关总爷麾下迎接总爷。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "传！"
        },
        {
          "character": "将官甲",
          "type": "白",
          "text": "传！"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "雄州关四营将校参见总爷。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "你家主帅有多大官儿，怎么不来迎接本镇？"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "启禀总爷：主帅因金兵临界，关内空虚，不敢擅离汛地，差末将等迎接总爷来 了。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋将同跪。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "本镇钦奉圣命，广阳王钧旨，领兵剿贼，你主帅不看在眼中，本待将你等斩首 ——"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "总爷开恩。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "也罢，待本镇破了金兵回来，再与你主帅算账。 来吓！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "乱棍打出去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同打四宋将下。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "催军！"
        },
        {
          "character": "孙浩",
          "type": "唱",
          "text": "定叫他主帅们无处逃遁， 少不得斩尔等碎尸分身。 叫众将快越过飞龙崎岭， 扫尽了金兵贼奏达捷音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠引韩世忠同上。"
        },
        {
          "character": "韩世忠",
          "type": "唱",
          "text": "命四将接孙浩渺无音信， 好叫我背地里自思自忖。 必然他要报那从前仇恨， 可惜我空费了一片精神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋将同上。"
        },
        {
          "character": "四宋将",
          "type": "同唱",
          "text": "贼孙浩忒无礼令人可恨， 全不念数年间共事同营。"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "你们回来了。"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "回来了。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "迎接孙浩，他可曾说些什么？"
        },
        {
          "character": "四宋将",
          "type": "白",
          "text": "末将等奉命迎接孙浩，那厮问我们主帅为何不来？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "你们如何回答？"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "末将等回答金兵临界，关内空虚，元帅不敢擅离汛地，故尔命末将等前来迎接。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "那厮如何言道？"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "那厮道：本镇钦奉圣命，广阳王钧旨，领兵剿贼，你主帅有多大的官儿，不来 迎接本镇，理当将尔等斩首，待等破了金兵回来，再与你主帅算账。将末将等 用乱棍打出来了。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "小人得志，一至于此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报。 启禀元帅：孙浩越过飞龙岭，迎敌金兵去了。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "报子",
          "type": "stage",
          "text": "中国京剧戏考 《雄州关》【头本】 6"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "哎吓且住，我想孙浩越过飞龙岭，与金兵对敌去了，倘有差错，连我有些不便。 来，传彦直进帐。"
        },
        {
          "character": "四宋将",
          "type": "白",
          "text": "有请少爷进帐。"
        },
        {
          "character": "韩彦直",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩彦直上。"
        },
        {
          "character": "韩彦直",
          "type": "念",
          "text": "战国英雄数直性，一忿扫平六国兵。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "唤孩儿出来，有何吩咐？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "圣上命孙浩督兵前来，征剿金人，那贼越过飞龙岭，迎敌金兵去了。命你带领 人马，暗地保护，倘有差错，提头来见。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩彦直下。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "众将官，催动人马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达、四蓝文堂、四小番、金兀术、四"
        },
        {
          "character": null,
          "type": "text",
          "text": "龙套、四将官、孙浩自两边分上，二龙出水，会阵。）"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "马上来的将官，可是韩世忠么？"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "逆贼，俺乃童太尉府中心腹之人，剿贼大将孙浩是也。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "奸贼一党，休要放走此贼。杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金兀术、孙浩同起打，孙浩败下，金兀术追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩彦直上，起霸。"
        },
        {
          "character": "韩彦直",
          "type": "念",
          "text": "杀气冲霄汉，英雄整衣冠。宝剑把贼斩，战血未曾干。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "俺，韩彦直，奉了父帅之命，暗地保护孙浩，拒敌金兵。 众将官，杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩彦直下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达、四蓝文堂、四小番、金兀术、四"
        },
        {
          "character": null,
          "type": "text",
          "text": "龙套、四将官、孙浩同上，金兀术杀死孙浩。韩彦直上，杀，金兀术败下，韩彦直追下。）"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、四宋将、韩世忠同上。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "本帅韩世忠。孙浩出马，未知胜负如何？为此领兵接应。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报。 启元帅：孙浩落马，少爷杀进番营去了。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "哎吓且住，孙浩落马，我儿杀进番营，这还了得！ 众将官，奋勇当先。杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《雄州关》【头本】 7"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金兀术、韩彦直同上。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "住了，你这小儿，二次杀进番营，倒有些胆量，饶尔不死，通名上来！"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "听者：俺乃雄州关总戎之子韩彦直是也。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "你就是韩世忠之子么？"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "然也。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "好，真乃将门之子也。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "呔，番贼通名受死！"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "孤乃大金邦四太子昌平王兀术是也。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩彦直、金兀术同起打，金兀术败下。四红文堂、四红大铠、四宋将、韩世忠同上。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "彦直！"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "孙浩何在？"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "被番兵踹为肉泥。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "好！儿吓，马向前来，为父有话讲！"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩世忠打。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "好奴才！"
        },
        {
          "character": "韩世忠",
          "type": "唱",
          "text": "畜生敢违父将令， 断送孙浩丧番营。 金枪刺儿咽喉梗，"
        },
        {
          "character": "韩彦直",
          "type": "唱",
          "text": "要杀为儿为何情？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "大胆畜生，为父怎样吩咐于你，孙浩乃圣上差来的，又是广阳王的保举，叫孩 儿小心保护，竟被番兵杀死，岂不把为父送到枉死城么？"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "哎吓爹爹吓，孩儿奉命暗护孙浩，杀进番营，并无此人，况孩儿也不认识于他。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "住了，那孙浩是个领兵的总戎，儿亦不认得么？"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "哎吓爹爹吓！孩儿奉命暗护孙浩，但是万马营中，犹如刀山剑岭，难道叫儿束 手待死不成？"
        },
        {
          "character": "四宋将",
          "type": "同白",
          "text": "元帅，公子之言甚是，还望元帅开恩。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "也罢。命儿三次杀进番营，杀退番贼便罢；如若不然，定斩尔的首级。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩彦直下。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋将同应。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "直踹番营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（韩彦直上。四小番同上，韩彦直杀四小番同下。呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁"
        },
        {
          "character": null,
          "type": "text",
          "text": "儿熊、土谷达、四蓝文堂、金兀术、四红文堂、四红大铠、四宋将、韩世忠自两边分上，二龙出水。）"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "马前敢是韩元帅？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "然。马前答话，敢是兀术？"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "唗，兀术，我主有何亏负你等，屡犯疆界，是何道理？"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "元帅且停战马，听我一言告禀：你主贪淫失政，听信奸佞，忠良遭戮，以致刀 兵四起，莫若归顺金邦，得了宋室天下，定是三台鼎鼐之位，元帅详察。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "兀术，你抢州夺县，伤害良民，恨不得食汝之肉，还敢多言么？"
        },
        {
          "character": "韩世忠",
          "type": "唱",
          "text": "兀术言语真堪恨， 气得本帅怒气生。 收兵回国保众命， 不然山川一扫平。"
        },
        {
          "character": "金兀术",
          "type": "唱",
          "text": "久闻世忠威名震， 中国京剧戏考 《雄州关》【头本】 8 今日见面果然真。 堂堂仪表非凡品， 胜似战国楚伍员。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "元帅！"
        },
        {
          "character": "金兀术",
          "type": "唱",
          "text": "你若马前来归顺， 孤家与你皇兄称。 （韩世忠、金兀术同起打，呼延狄、雷洪其、达林承、季乐芬、萨里阿、夜里混、铁儿熊、土谷达、四蓝文 堂、金兀术同败下。）"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}