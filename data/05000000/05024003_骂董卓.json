{
  "script_id": "05024003",
  "title": "骂董卓",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "皇甫夫人",
      "hangdang": "旦"
    },
    {
      "name": "董卓",
      "hangdang": "净"
    }
  ],
  "plot": "董卓欲占守寡之皇甫规夫人为妻，命李儒带聘礼、花轿迎娶。皇甫规夫人大骂董卓逆贼，董卓恼羞成怒，命\n人将皇甫夫人打死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、董卓同上。"
        },
        {
          "character": "董卓",
          "type": "唱",
          "text": "可恨那黄巾贼无故反上， 老夫我兴人马抵却四方。 今才得太平世君民同享， 挟天子迁长安执掌朝纲。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "老夫董卓，汉室为臣。自幼生长羌胡，身居前将军之职。因宦官专权，混乱朝 政，何进召俺入朝，废了少主，奉陈留王为帝，迁入长安，恐人心不服，在这 长安城外，高筑郿坞，囤粮静观天下事，老夫坐待其变，只是美中不足语难言。 咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李儒上。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "太师这几日闷闷不乐，必是想个绝妙女子，陪老太师。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "你何以知道老夫心事。哼哼哼！哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三下锣。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "就是前将军皇甫规的夫人。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "咳，她是朝廷命妇，岂肯嫁我？"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "这，小官凭三寸不烂之舌，劝说与她，她若不从，我以利害动之。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "金银与你。若能成就，必有重赏。名车一乘，彩锦百端，黄金千两，权作聘礼。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "明日就去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董卓、李儒同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "皇甫夫人上。"
        },
        {
          "character": "皇甫夫人",
          "type": "引子",
          "text": "国破家亡，恨奸雄，混乱朝纲。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "奴家，小字季贞。先夫皇甫规，汉室为臣，文武兼备，封侯拜爵，坚辞不受。 出征西域，不幸忧劳病故，因此董卓扶幼主迁长安。先夫若在，岂容豺狼满志。 咳！未亡人乃一柔弱女子，无尺寸之权。忧国忧家，好不愁闷人也！"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "痛先夫征西域中途命丧， 丢下了未亡人国破家亡。 长安城遭兵乱终日掠抢， 开门户难躲乱何日安康？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启夫人：大事不好了！"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "外面来一位官儿，带领家童、聘礼、小轿，说董卓太师差来娶夫人。请躲避躲 避。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "躲避躲避。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "皇甫夫人",
          "type": "西皮导板",
          "text": "听一言不由我动魄惊心，"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "这奸雄无故地欺压良民。 痛先夫去世早留下遗恨， 如不然寻一个玉碎金身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下，院子拦李儒同上。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "来此已是。 站住，门上哪位听事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有人到此，夫人回避。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "不必回避，看是何人，叫他进来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。 呵，李老爷。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "不错，说我要见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "夫人知道了，请你进去。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "哦，请我进去。哦，此事有个八九。 夫人哪里？夫人哪里？ 咳，小官有礼。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "少礼请坐。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "夫人恭喜。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "呵，先夫尸骨未寒，喜从何来？"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "这，董太师久闻夫人才德，命小官请夫人同享荣华。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "住口。你可知夫人甚等样人？岂肯受老贼凌辱。快快出去，免讨没趣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子推李儒。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "不用忙，不用忙，还有话说。你可知太师威严厉害么？"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "这个？好好好，我随你前去呵。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "夫人呵！"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "不必如此，我此去凶多吉少，你们逃往洛阳去罢！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "这家呢？"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "这个，我也顾不得了！"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "闭门坐不想祸从天降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "皇甫夫人上轿，下。"
        },
        {
          "character": "李儒",
          "type": "唱",
          "text": "这件事功劳簿又多一样。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "哎呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、董卓同上。"
        },
        {
          "character": "董卓",
          "type": "唱",
          "text": "闭眼杀人睁眼笑， 全凭机谋压群豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李儒、皇甫夫人同上。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "太师花轿到。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "好好，真会办事。抬上堂来，后面歇息。"
        },
        {
          "character": "李儒",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李儒下。皇甫夫人下轿。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "是呵夫人。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "呵啥。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "夫人请坐。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "呵，老太师将未亡人传来何事？"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "呵夫人，老夫久闻夫人才貌，老夫不才，要烦夫人安领诸姬，夫人谅无推辞了？"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "太师之言差了，先夫坟土未干，未亡人焉能丧节？天下美女甚多，何要我这不 祥之妇，毁人名节，太师岂不被天下人耻笑。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "这，老夫位高极品，何人敢笑。夫人说下才是。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "这，老太师，老太师与先夫也是汉家臣子，功在社稷，曾与太师并肩事主，有 先夫情份，怜念孤苦，何忍夺故臣之妻！老太师开恩释放，恩高莫大！"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "老夫威令四方，难道不能行于一妇人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "皇甫夫人立。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "老贼老贼，尔乃羌胡之继，侥幸立功，朝廷待尔不薄，不思感恩图报，狐假狼 虎之威，竟谋篡大位，劫杀人民。恨不得将你碎尸万段，为天下人报仇。我是 甚等样人，你敢行非礼！"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "你好比是我笼中之鸟，怎敢违抗。"
        },
        {
          "character": "皇甫夫人",
          "type": "笑",
          "text": "哼哼哼！"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "你为何发笑？"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "你道我不能违抗与你，可叹可叹！"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "叹者何来？"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "想汉高祖灭秦破楚，创业艰难，传二十四帝，传至桓灵，桓灵无道，宠信宦官。 咳！这也是天意为然，非人所为。可恨何进无谋，以诏引你这老贼进京，你 就该力图报效，秉正忠心，匡扶汉室，才是你为人臣之正道。怎么你废幼帝挟 少主，焚宫阙，迁百姓，荼毒生灵。咳！你这老贼，自作由你将来自受。心怀 篡位，何以为忠？挟迁百姓，何以为信？夺人妻女，何以为仁？劫杀百姓，何 以为义？似你这样不忠、不信、不仁、不义，真正是人面兽心，衣冠禽兽！何 以今日又来夺故旧之寡妇？我乃女流，还有一点烈性，今日之死，图一个节烈 流传！惜乎惜乎！"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "未看到你这老贼怎样结果， 生不能吃你肉，死后也要追你之魂。 汉桓灵任宦官弄权国丧， 容何进让袁绍私招豺狼。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "董卓",
          "type": "唱",
          "text": "若非我除宦官汉室早丧， 从了我不久要身为皇娘。"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "弘农皇何太后无辜命丧， 挟天子迁百姓心如豺狼。"
        },
        {
          "character": "董卓",
          "type": "唱",
          "text": "你哪知汉宦灭董氏兴旺， 出此言你不怕去见阎王？"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "我纵死也图个后人敬仰，"
        },
        {
          "character": "董卓",
          "type": "唱",
          "text": "我劝你顺我者生逆我者亡。"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "家凤凰怎入你乌鸦群党，"
        },
        {
          "character": "董卓",
          "type": "唱",
          "text": "你好比笼中鸟虎落平阳。"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "贼不念旧言恩禽兽一样， 放声哭日月无光。 我此刻拚一死向前去闯，"
        },
        {
          "character": "皇甫夫人",
          "type": "白",
          "text": "先夫呵！"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "你就不惜命么？"
        },
        {
          "character": "皇甫夫人",
          "type": "唱",
          "text": "纵死在九泉之下姓名皆香。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "这贱人说此言泼口狂妄， 把性命当儿戏付与汪洋。 叫人来你与我齐动杆棒， 打死她我心中才能欢畅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同打皇甫夫人。"
        },
        {
          "character": "董卓",
          "type": "白",
          "text": "咳咳！拖过去！"
        },
        {
          "character": "董卓",
          "type": "念",
          "text": "贱人作事忒猖狂，哪有福分做昭阳。明天差人去寻访，访得英凰伴爷王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董卓、四下手同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}