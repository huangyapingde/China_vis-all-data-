{
  "script_id": "05021001",
  "title": "纪母骂刘邦",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "纪母",
      "hangdang": "老旦"
    },
    {
      "name": "刘邦",
      "hangdang": "老生"
    }
  ],
  "plot": "刘邦登基。大封功臣。独漏纪信的功劳。纪母上殿责备刘邦。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张良、萧何、陈平、樊哙、随何、韩信同上，同念〖点绛唇〗。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "张良。"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "萧何。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "陈平。"
        },
        {
          "character": "樊哙",
          "type": "白",
          "text": "樊哙。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "随何。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "韩信。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "诸位公侯请了。"
        },
        {
          "character": "萧何、陈平、樊哙、随何、韩信",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "张良",
          "type": "白",
          "text": "现今天下太平，我主大贺功臣，分茅列土，加官进爵。今在未央宫赐宴，我等 躬逢其盛。远远望见圣驾来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "引子",
          "text": "破楚灭秦，幸喜得，天下太平。"
        },
        {
          "character": "刘邦",
          "type": "念",
          "text": "拔剑斩蛇起沛丰，干戈已熄灭重瞳。文臣武将真栋梁，未央赐宴庆大功。"
        },
        {
          "character": "张良、萧何、陈平、樊哙、随何、韩信",
          "type": "同白",
          "text": "臣等见驾，我主万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "张良、萧何、陈平、樊哙、随何、韩信",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "内侍摆宴。"
        },
        {
          "character": "张良、萧何、陈平、樊哙、随何、韩信",
          "type": "同白",
          "text": "谢宴。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿请酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。张良、萧何、陈平、樊哙、随何、韩信同饮酒。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿。"
        },
        {
          "character": "张良、萧何、陈平、樊哙、随何、韩信",
          "type": "同白",
          "text": "万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤自斩蛇起义以来，灭秦破楚，平定天下，虽赖众卿之功，实仗三杰之力也。"
        },
        {
          "character": "张良、萧何、陈平、樊哙、随何、韩信",
          "type": "同白",
          "text": "何谓三杰？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "运筹决胜，孤之智谋不如张良，用兵布阵，孤之韬略不如韩信，理财行政，孤 之才能不及萧何。此三人乃当世之人杰也。孤何幸得之！"
        },
        {
          "character": "陈平、樊哙、随何",
          "type": "同白",
          "text": "虽然三杰用功于国，然非万岁不能知也，非万岁不能用也。"
        },
        {
          "character": "张良、萧何、韩信",
          "type": "同白",
          "text": "臣等不过萤火之光，焉能比拟陛下当今之日月。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "内侍取酒，孤各赐三杰一大杯。"
        },
        {
          "character": "张良、萧何、韩信",
          "type": "同白",
          "text": "谢万岁。"
        },
        {
          "character": "刘邦",
          "type": "西皮原板",
          "text": "子房智略世少有， 韩元帅乌江用智谋。 萧丞相治国是好手， 众卿戮力大功收。 内侍与孤斟美酒， 君臣共饮太平瓯。"
        },
        {
          "character": "萧何",
          "type": "西皮原板",
          "text": "萧何席前正饮酒， 忽然一事记心头。 急忙忙离席来启奏， 尊一声万岁听理由： 纪信荥阳功为首， 可怜他替主一命休。 今日诸臣受厚恩， 请万岁追封到荒丘。"
        },
        {
          "character": "刘邦",
          "type": "西皮摇板",
          "text": "刘邦闻言双眉皱， 卿家奏本没来由。 当日荥阳孤逃走， 纪信登车赚楚囚。 虽然救驾功劳有， 假扮天子罪为头。 将功折罪孤不咎， 往事休提一笔勾。 丞相开怀且饮酒， 人死何必再封侯。"
        },
        {
          "character": "萧何",
          "type": "西皮摇板",
          "text": "萧何不敢再开口，"
        },
        {
          "character": "张良",
          "type": "西皮摇板",
          "text": "张良一旁暗点头。"
        },
        {
          "character": "韩信",
          "type": "西皮摇板",
          "text": "韩信座上把眉皱，"
        },
        {
          "character": "陈平",
          "type": "西皮摇板",
          "text": "陈平席前低下头。"
        },
        {
          "character": "樊哙",
          "type": "西皮摇板",
          "text": "樊哙怒气冲牛斗，"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "随何不语泪暗流。"
        },
        {
          "character": "刘邦",
          "type": "西皮摇板",
          "text": "众卿放量多饮酒， 开怀畅饮醉方休。 饮罢酒宴后宫去，"
        },
        {
          "character": "张良、萧何、陈平、樊哙、随何、韩信",
          "type": "同西皮摇板",
          "text": "臣等送驾出龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张良、萧何、陈平、樊哙、韩信同下。"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "随何此刻心难受， 腹中好一似火浇油。 他将功臣当猪狗， 救驾替死不封侯。 怒冲冲出离宫门口， 见了伯母说从头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "纪母上。"
        },
        {
          "character": "纪母",
          "type": "引子",
          "text": "两鬓白如霜，痛我儿，为国身亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪夫人、纪子同上。"
        },
        {
          "character": "纪夫人",
          "type": "引子",
          "text": "大节禀冰霜，抚我儿，奉养高堂。"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "婆婆万福。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "纪子",
          "type": "白",
          "text": "参见祖母。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "罢了。 啊，媳妇，自你丈夫在荥阳替主赴难，随何有信前来，也曾言道，汉王发下誓 愿，母受洪恩，子受厚禄。至今未受半点恩荣，想是干戈未熄，无暇及此。至 今天下已定，为何不见恩诏前来？莫非汉王食言么？"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "儿观汉王鹰头狼视，可与共患难，不可与共富贵。况且我家薄有良田，尚堪度 日。当日伤心之事，婆婆你提它做甚。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "哎，儿媳呀。"
        },
        {
          "character": "纪母",
          "type": "二黄慢三眼",
          "text": "坐草堂未开言痛心疾首， 想起了纪信儿老泪横流。 荥阳城大功劳世间稀有， 舍性命替君难楚营去投。 那项羽中巧计汉王逃走， 他临行发誓愿必有厚酬。 到如今干戈息言信无有， 因何故那恩诏不出龙楼。"
        },
        {
          "character": "纪夫人",
          "type": "二黄原板",
          "text": "老婆婆休得要双眉紧皱， 年迈人禁不住万种忧愁。 儿虽死孙已长忠臣有后， 我家中尚温饱薄有良田。 创业君哪一个恋念故旧， 到后来飞鸟尽良弓必收。"
        },
        {
          "character": "纪母",
          "type": "二黄摇板",
          "text": "但愿得老天爷多多保佑， 一家人守田园快乐无忧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何上。"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "怒气不息向前走， 见了伯母说根由。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "伯母在上，侄儿拜辑。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "贤侄，公务勤劳，何暇至此？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "侄特为一事前来。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "为何事而来？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "现今天下大定，汉王正在大封功臣，小侄等皆封侯赐爵。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "有功必赏，真乃有道明君。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "说什么有道明君，依侄儿看来，乃是无道昏君。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "何出此言？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "想当年我兄长替君赴难之后，小侄有信前来，言道汉王发下誓愿，富贵同享， 以酬救主之恩。伯母可记得否？"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "以往之事，提它则甚？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "伯母、嫂嫂有所不知，昨日汉王大宴群臣，萧何说道，追封我兄救驾之功，那 昏王反说道假扮天子忤逆不道，罪该寸斩。功不掩罪，断无封侯之理。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "断无封侯之理。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪母气椅。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "伯母醒来。"
        },
        {
          "character": "纪母",
          "type": "西皮导板",
          "text": "闻此言气得我浑身颤抖，"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "好昏王啊！"
        },
        {
          "character": "纪母",
          "type": "西皮摇板",
          "text": "大骂昏王理不周。 忘却荥阳将你救， 我儿替你一命休。 当日誓愿出你口， 反面无情恩作仇。 越思越想心难受， 我的儿呀！ 即刻上殿辩理由。"
        },
        {
          "character": "纪夫人",
          "type": "西皮摇板",
          "text": "母亲年高六十九， 莫生气来莫忧愁。 何必上殿去斗口， 争此虚名没来由。"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "汉王威权世少有， 一言不合斩人头。 我劝伯母且罢手， 怕是此去命难留。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "儿呀！"
        },
        {
          "character": "纪母",
          "type": "西皮摇板",
          "text": "人生不过百年寿， 忠孝名儿万古留。 救驾替死不封侯， 难忍我心头气一口。 拼着性命闯龙楼，"
        },
        {
          "character": "纪夫人",
          "type": "白",
          "text": "母亲，去不得！"
        },
        {
          "character": "纪母",
          "type": "西皮摇板",
          "text": "儿等不必苦相留。"
        },
        {
          "character": "纪夫人",
          "type": "西皮摇板",
          "text": "叔叔保护随娘后。"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "嫂嫂放心说无忧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何、纪母同下。"
        },
        {
          "character": "纪夫人",
          "type": "西皮散板",
          "text": "此去吉凶猜不透， 儿夫尽忠反添愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪子、纪夫人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、张良、萧何、陈平、樊哙、韩信、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "西皮流水板",
          "text": "耳边厢又听得长乐钟鸣， 内侍摆驾离宫廷。 灭秦破楚归一统， 全赖武将与文臣。 韩信有谋樊哙勇， 还仗萧何张良与陈平。 数年转战真侥幸， 永息干戈定太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "随何上。"
        },
        {
          "character": "随何",
          "type": "西皮摇板",
          "text": "纪母已在午门等， 求见汉王诉不平。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "臣，随何见驾，我皇万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "万万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "随何",
          "type": "白",
          "text": "臣启万岁：今有亡臣纪信之母有本扣奏，在朝门侯旨。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "金殿非等闲之地，岂是妇人出入之所。见她则甚？"
        },
        {
          "character": "张良、萧何、陈平、樊哙、随何、韩信",
          "type": "同白",
          "text": "启奏万岁：纪信与臣等共患难，非一朝事，其母既有口奏，陛下当念荥阳替主 赴难之功，容她上殿，以显圣德汪洋，恋念功臣之意。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿所奏，正合孤意。 内侍，宣纪太君上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "万岁有旨：宣纪太君上殿。"
        },
        {
          "character": "纪母",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪母上。"
        },
        {
          "character": "纪母",
          "type": "西皮摇板",
          "text": "忽听金殿宣一声， 来与亡儿诉不平。 即到此间舍了命， 怒气难消立殿庭。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "皇伯母，怒气不消，上得殿来，有何本奏？"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "你还是不知呀，还是故问？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤深知伯母心中之事。 内侍，看座。 皇伯母，有本慢慢奏来。"
        },
        {
          "character": "纪母",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "纪母",
          "type": "西皮原板",
          "text": "未曾开言心酸痛， 尊一声万岁听分明： 今日江山归一统， 可记得当年荥阳城？"
        },
        {
          "character": "刘邦",
          "type": "西皮原板",
