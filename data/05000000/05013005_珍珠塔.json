          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "千总、把总、守备、县官、府官、毕云显",
          "type": "同白",
          "text": "大人请了。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "我等迎接方大人。请吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四挂子、四青衣、四官兵、千总、把总、守备、县官、府官、毕云显、陈连同走圆场，方卿上。"
        },
        {
          "character": "方卿",
          "type": "念",
          "text": "只因急把母亲见，未遑接待诸州县。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "吓众位大人。"
        },
        {
          "character": "千总、把总、守备、县官、府官、毕云显、陈连",
          "type": "同白",
          "text": "不敢，卑职等迎接大人来迟，望乞恕罪。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "贤婿更衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。方卿换衣。"
        },
        {
          "character": "陈连",
