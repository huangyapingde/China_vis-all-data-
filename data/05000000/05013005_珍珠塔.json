        {
          "character": "红云",
          "type": "白",
          "text": "听说是以前说他没有翻身之日这个人。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "莫非我说了这小畜生，今日要斩我么？"
        },
        {
          "character": "红云",
          "type": "白",
          "text": "岂敢岂敢！"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "吓丫头，这怎么处呢？"
        },
        {
          "character": "红云",
          "type": "白",
          "text": "依我不要紧，这时候，我家老爷，同众位老爷都在厅上，你跪行出去，倘姑老 爷要斩，还是有众位大人讲情，你道好不好？"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "咳，我是长辈，怎得拜他？"
        },
        {
          "character": "红云",
          "type": "白",
          "text": "这个叫王子犯法，庶民同罪！"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "不能，不能！"
        },
        {
          "character": "红云",
          "type": "白",
          "text": "夫人快些去罢，若是迟了，尚方宝剑嗐擦一刀，不管丫头之事，快去！"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "如此快去吓，咳，晦气晦气！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方氏下。"
        },
        {
          "character": "红云",
          "type": "白",
          "text": "今日看来，夫人要叩头哉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红云下。"
        }
      ]
