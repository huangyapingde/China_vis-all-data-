      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二丫头、方氏同上。"
        },
        {
          "character": "方氏",
          "type": "唱",
          "text": "只恨生就势利眼， 欺贫爱富悔已迟。"
