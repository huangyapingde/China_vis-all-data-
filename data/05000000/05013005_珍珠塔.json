{
  "script_id": "05013005",
  "title": "珍珠塔",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "方卿",
      "hangdang": "小生"
    },
    {
      "name": "陈翠娥",
      "hangdang": "旦"
    }
  ],
  "plot": "方卿改名方定，得中状元，升授七省巡按，奉旨归家。先到襄阳，扮作道人，往见其姑，其姑见状，依旧反\n脸无情。方卿借唱道情责其嫌贫爱富。乃及见陈连、陈翠娥，始告以身任巡按，随即前往白莲庵中接母。其\n姑深为羞愧，乃向方卿请罪。后方卿与二女成婚，一家团聚。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四挂子、四青袍、院子、门子、方卿同上。"
        },
        {
          "character": "方卿",
          "type": "引子",
          "text": "志节秋霜，领玉符，紫绶金章。"
        },
        {
          "character": "方卿",
          "type": "念",
          "text": "横流澎湃下淮阴，拯济穷黎天子心。秋鼎航海虽有志，济川舟楫我无能。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "下官方卿，改名方定。蒙圣恩钦点头名状元，又放我七省巡按之职。奉旨归家， 打水路而行，先到襄阳，探望表姐姑丈，再看姑母行为。 来，船只可曾齐备？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "早已齐备，候大人登舟。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "就此吩咐，开道登舟。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓！ 大人吩咐，开道登舟。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗，〖牌子〗。四文堂、四挂子、四青袍、院子、门子、方卿同上船。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "上得船来，好凄惨人也。"
        },
        {
          "character": "方卿",
          "type": "唱",
          "text": "三年不见家乡景， 千里行船好惨情。 看看已到襄阳地， 巧装改扮探姑亲。 吩咐船手往前进， 停船不走为何情？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启禀大人：已到襄阳了。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "就此停船。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "大人吩咐，就此停船。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "取我行装过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方卿披破巾富贵衣扮道人，执鱼筒板。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "将船移至城关，不许声张，打了扶手。"
        },
        {
          "character": "方卿",
          "type": "唱",
          "text": "谁知暗藏黄金印， 尚方宝剑斩无情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方卿下。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "大人上岸，不许声张，将船移至城关。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "方卿上。"
        },
        {
          "character": "方卿",
          "type": "唱",
          "text": "巧装改扮道士样， 中国京剧戏考 《珍珠塔》【四本】 2 看她把我怎主张？ 我把道情唱几唱， 要学苏秦骂嫂娘。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "来此已是，我从后花园而进。 里面有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫头上。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "有烦通报，河南方大爷来了。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "怎么，你这样子，就算是方大爷了！不要管他，上年被老爷责骂，今日不要管 他大爷不大爷，待我报与夫人知道，你等着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫头下。"
        },
        {
          "character": "方卿",
          "type": "唱",
          "text": "听凭出言把我伤， 暗唱道情笑炎凉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫头上。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "夫人说：请大爷到兰云堂相见。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "是，带路。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "这里来。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "带路。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "这里来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫头、方氏同上。"
        },
        {
          "character": "方氏",
          "type": "唱",
          "text": "刻来报说穷儿到， 只怕又要把气淘。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "夫人，方公子到。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "叫这穷儿进来。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "穷小子进去。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "吓姑母大人在上，小侄方卿拜见。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "嗄唷唷，勿要肉麻哉。方家门里，生出这样的穷鬼骨头来，勿知祖上做子个吏 部天官，作仔啥个孽了。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "吓姑母大人，小侄不过穷，有什作孽？"
        },
        {
          "character": "方卿",
          "type": "唱",
          "text": "姑娘休得面嘲笑， 并无借人半分毫。 乐得逍遥大街上， 切莫把我来欺嘲。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "吓，我欺了哪个？"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "不是嗄，姑娘是大贤大德，哪敢说姑娘之短。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "吓，莫非你作官哉？"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "我看那世情了然，故此出家唱道情了。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "什么唱道情？"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "就是唱这炎凉世态，忠孝节义的故事。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "夫人就叫方大爷唱一只听看。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "如此你已善唱道情，倒要请教。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "是是，吓姑娘大人，那道情之中，是君子小人，欺贫重富都有，但是姑母休要 见气？"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "有甚见气。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "如此小侄奉命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方卿打鱼板。陈连上。"
        },
        {
          "character": "陈连",
          "type": "念",
          "text": "刻报儿婿后园进，只怕不贤又欺贫。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "吓！他竟弄得这般模样，在那里做些什么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈连在场口做手势，叫方卿不要唱。方卿假作不知，打鱼板。"
        },
        {
          "character": "方卿",
          "type": "道情",
          "text": "想当初，有苏秦， 一家妻嫂笑欺贫。 父母怨，哥嫂恨， 赶出门外去投井。 中国京剧戏考 《珍珠塔》【四本】 3 天不绝，有恩人，救到家庭， 到后来，掌相印，六国封赠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈连点头笑。"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "吓夫人，这妙音到好听。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "唔，好吓，如此再唱。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "是是。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "吓贤婿，你在此唱什么？不要唱了，随我书房去罢。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "不要你管，你女婿有了这妙音，算宝贝，你叫他不要唱，我定要他唱。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "是是，姑母不要生气，小侄再唱便了。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "吓，你定要听唱。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "唔，我定要听唱。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "如此看坐来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈连坐。"
        },
        {
          "character": "方卿",
          "type": "唱",
          "text": "那秦琼有姑娘藩领封赠， 卖双锏售黄骠忙去投亲， 相见后蒙姑娘提拔报恩， 这骨肉岂比那重富欺贫？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈连点头笑。"
        },
        {
          "character": "方卿",
          "type": "唱",
          "text": "如今人甚可恶实实小人， 见富家即忙忙就去亲近。 见贫士顿起个势利无情， 全忘却一枝本骨肉大恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈连笑。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "唱得好，唱得好，好个忘却根本，好个忘却根本！"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "嗄，小畜生，你说我重富欺贫，我欺个哪个？忘却了什么根本，忘了什么？"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "吓姑母大人，小侄早早禀告，这是道曲所有。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "吓，你叫唱的，你这不贤，不要脸的。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "嗄，你有脸，有了这样的道情女婿，还亏你在此多口，好有脸面，有轩昂。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "不要你管，亏你堂堂丞相之女，连那骨肉亲情，同气连枝的根本全无。 贤婿不要理她，我们外面书房去。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "是是。 姑母大人，休要见气，这是小侄自己不肖，不能上进。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "管我甚事，你有好丈人，你去罢。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "不比你这贱人，不要脸面，看你日后有何面目见他母亲。 贤婿，外边坐去。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "是是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方卿下。"
        },
        {
          "character": "陈连",
          "type": "笑",
          "text": "哈哈哈。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "你这老猪狗，我女儿被你害得好苦，对得好亲，此刻做了道官了。你这御史难 道也是唱道情唱来的？"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "女儿是我的，不要你这没脸畜生管账。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈连打。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "嗄哟，老猪狗打起来哉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方氏撞头，打。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "好贱人，老不贤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈连打。陈宣上，劝。"
        },
        {
          "character": "陈宣",
          "type": "白",
          "text": "吓老爷、夫人，不必如此，休要动气。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈宣劝。"
        },
        {
          "character": "陈宣",
          "type": "白",
          "text": "老爷外厢去罢，外厢去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑丫头劝，陈宣推陈连同下。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "哎吓天杀的！老畜生！你叫你好女婿唱道情骂我！杀千刀！杀万刀！老畜生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方氏哭。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "天哪，天杀的！害得我女儿做道士老婆吓！ 中国京剧戏考 《珍珠塔》【四本】 4"
        },
        {
          "character": "丑丫头",
          "type": "白",
          "text": "夫人不要哭，回房去罢。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "我也勿动气了，明日吃了参汤，与他再来打架。吓唷，气死我也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方氏、丑丫头、二丫头同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈宣、方卿、陈连同上。"
        },
        {
          "character": "陈连",
          "type": "唱",
          "text": "世上总有贫和富， 哪知不贤太蠢粗。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "贤婿请坐。"
        },
        {
          "character": "陈宣",
          "type": "白",
          "text": "小主人请坐罢。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "姑丈大人请坐，待小婿拜见。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "不要拜了，请坐。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "陈宣请小姐出来。"
        },
        {
          "character": "陈宣",
          "type": "白",
          "text": "是吓。 小姐有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彩屏、陈翠娥同上。"
        },
        {
          "character": "陈翠娥",
          "type": "唱",
          "text": "耳听父母声喧闹， 想是表弟把气淘。"
        },
        {
          "character": "陈翠娥",
          "type": "白",
          "text": "吓爹爹。"
        },
        {
          "character": "彩屏",
          "type": "白",
          "text": "老爷。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "来来来，见了表弟。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "吓表姐，小弟有礼。"
        },
        {
          "character": "陈翠娥",
          "type": "白",
          "text": "愚姐也有一礼。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "陈翠娥",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "陈连",
          "type": "白",
          "text": "吓女儿，前者写信，打发陈宣河南探信，这是老夫所作，今日说明了。"
        },
        {
          "character": "陈连",
          "type": "唱",
          "text": "只为女儿身有病， 无法可医把计生， 做作河南回音信， 我女才得信为真。 今日贤婿回家门， 免得以后起疑心。 你们快把前事问， 三年何处度光阴？"
        },
        {
          "character": "方卿",
          "type": "唱",
