        {
          "character": "方氏",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "红云",
          "type": "白",
          "text": "在外厅伺候，听说姑爷请出皇帝伯伯御赐尚方宝剑，供在厅上，要斩势利之人。"
        },
        {
          "character": "方氏",
          "type": "白",
          "text": "斩哪个？"
