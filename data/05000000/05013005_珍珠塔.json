        {
          "character": "杨氏",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "方卿",
          "type": "白",
          "text": "众位大人请起。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "千总、把总、守备、县官、府官、毕云显、陈连同起。"
        },
        {
          "character": "方卿",
          "type": "stage",
          "text": "中国京剧戏考 《珍珠塔》【四本】 10"
        },
        {
          "character": "千总、把总、守备、县官、府官、毕云显、陈连",
