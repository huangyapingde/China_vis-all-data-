{
  "script_id": "05014004",
  "title": "张松骂曹",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "张松",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "杨修",
      "hangdang": "老生"
    }
  ],
  "plot": "杨修对曹操夸赞张松奇才，并以其背诵《孟德新书》一事相告。曹操疑与古人暗合，即命将书焚毁。次日在\n教场阅兵，曹操向张松夸示军威。张松冷笑，出语轻慢，曹操责其口出狂言，张松历数曹操以往战败事以讥\n之，并举吕伯奢、陈宫为例，谓其恩将仇报。曹操大怒，将张松赶出帐外。张松对此行甚悔恨，随即收拾起\n程回川。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨修上。"
        },
        {
          "character": "杨修",
          "type": "引子",
          "text": "参透诗书亿，世人心难知。"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是哪个？ 原来是德祖先生。"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "丞相可曾升座？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "现在书房。"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "烦劳通禀。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "随我进来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "主簿杨修，参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "启禀丞相：想那西川张松，乃天下奇才，丞相不可轻视于他。若得此人，必有 大用。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "昨日卑职与他在馆驿闲谈，说起丞相所作新书，令他看过。他说此书，乃是西 蜀小儿熟读。卑职叫他背诵，他从头至尾，一一背念，半字不差。卑职问他， 此书乃何人所作。他说，此书是战国时无名氏所作。如此看来，此人博古通今 岂非天下奇才乎？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀，且住！此书是我出自心裁，怎么又与古人同心，莫非我梦得古书不成？ 罢了！既有此书，要它何用。 中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将此书用火焚化，并令各班部，凡有此书，一概焚毁。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我视张松形容古怪，出言猖狂，有些自大。我不轻视于他，他必然藐视于我。 今日也不用他拜见，以待明日清晨，将文武官员，调齐教场，命他在教场拜见， 一来叫他看看我的威严，二来要他回转西蜀，告与刘璋。此意如何？"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "相爷高见，卑职告退。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "晓谕张松。"
        },
        {
          "character": "杨修",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨修",
          "type": "念",
          "text": "领了丞相命，告知有才人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨修下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "拿我令箭，晓谕文武各班，明日清晨，文穿补服，武披铠甲，各带人马，教场 伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "丞相有令：明日清晨，文穿补服，武披铠甲，各带人马，教场伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张辽、许褚、夏侯惇、夏侯渊同上。"
        },
        {
          "character": "张辽",
          "type": "点绛唇",
          "text": "气盖中华，"
        },
        {
          "character": "许褚",
          "type": "点绛唇",
          "text": "保定邦家，"
        },
        {
          "character": "夏侯惇",
          "type": "点绛唇",
          "text": "操练兵将，"
        },
        {
          "character": "夏侯渊",
          "type": "点绛唇",
          "text": "威振川娃，"
        },
        {
          "character": "张辽、许褚、夏侯惇、夏侯渊",
          "type": "同点绛唇",
          "text": "管叫他心惧怕。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "威风凛凛振，"
        },
        {
          "character": "许褚",
          "type": "念",
          "text": "昂昂杀气生！"
        },
        {
          "character": "夏侯惇",
          "type": "念",
          "text": "站立辕门外，"
        },
        {
          "character": "夏侯渊",
          "type": "念",
          "text": "单听将令行。"
        },
        {
          "character": "张辽、许褚、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "俺！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "张辽。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "许褚。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "夏侯惇。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "许褚、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相有令，命我等披挂整齐，各带人马，在教场以助雄威，惊吓那西川张松， 我等在此伺候！"
        },
        {
          "character": "张辽、许褚、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱、贾诩、荀攸、满庞同上。"
        },
        {
          "character": "程昱",
          "type": "念",
          "text": "少小须勤学，"
        },
        {
          "character": "贾诩",
          "type": "念",
          "text": "文章可立身。"
        },
        {
          "character": "荀攸",
          "type": "念",
          "text": "满朝朱紫贵，"
        },
        {
          "character": "满庞",
          "type": "念",
          "text": "尽是读书人。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "下官程昱。"
        },
        {
          "character": "贾诩",
          "type": "白",
          "text": "贾诩。"
        },
        {
          "character": "荀攸",
          "type": "白",
          "text": "荀攸。"
        },
        {
          "character": "满庞",
          "type": "白",
          "text": "满庞。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "各位大人请了。"
        },
        {
          "character": "贾诩、荀攸、满庞",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相命我等教场伺候。请！"
        },
        {
          "character": "贾诩、荀攸、满庞",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、曹操同上，中军上。"
        },
        {
          "character": "曹操",
          "type": "点绛唇",
          "text": "职掌兵权，霸占中原，领人马，扫尽狼烟，篡汉随吾愿。"
        },
        {
          "character": "程昱、贾诩、荀攸、满庞",
          "type": "同白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "程昱、贾诩、荀攸、满庞",
          "type": "同白",
          "text": "谢丞相。"
        },
        {
          "character": "张辽、许褚、夏侯惇、夏侯渊",
          "type": "同白",
          "text": "末将打恭！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "南征北战胆气豪，胸怀智谋比人高。只因张松逞才干，特集文武唬儿曹。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "本爵，姓曹，名操，字孟德。只因张松到此，我看这厮，甚是狂傲。今日特聚 文武，以伏他心。 中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "文武官员，可曾到齐？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "到齐多时。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传张松进帐！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "丞相有令，张松进帐。"
        },
        {
          "character": "张松",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张松上。"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "好一个曹孟德威风不小， 集文武特叫我张松观瞧。 文一边端朝笏身穿朱皂， 武一旁披铠甲盔缨飘飘。 将一概持斧钺白光照耀， 兵与卒各执着剑戟枪刀。 俺张松观一遍只当不晓， 才知道俺张松枉来一遭。 我有心不会他转回川道，"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "张松入帐！"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "又听得众将官喊声更高。 悔只悔我不该错投此道， 知奸相行霸道祸已自招。 我只得气昂昂大帐进了， 看一看曹孟德怎样开销。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你见本爵，立而不跪，念你是远来之使，不加罪于你。尔今初到许昌，别无可 观，今日特集文武，齐至教场，你看老夫的威风，比尔西蜀如何？"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "这个！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张松冷笑。"
        },
        {
          "character": "张松",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哼！老夫到处战无不胜，攻无不取，无敌于天下，顺吾者昌，逆吾者亡！你倒 笑起老夫来了。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "骂一声小张松忒以狂诈， 敢在这教场上耻笑于咱。 我本当传将令将你斩杀， 又恐怕众文武道我量狭。 看张松形容异身材不大， 古怪的猿猴背狗须乱轧。 他纵有满腹才全是自大， 竟敢在我面前狂口自夸。"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "相爷英名，西蜀皆知！是战不能胜，攻不能取，无颜于天下！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "你且听道！"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "曹丞相你不必说话太傲， 可记得在潼关遇着马超？ 战渭南夺船舟避箭跑掉， 只杀得曹丞相割须弃袍。 在宛城遇张绣子侄丧了， 濮阳城被吕布用火来烧。 在赤壁遇周郎火攻计巧， 华容道求关公才得脱逃。 这都是曹丞相威风不小， 战必胜攻必取莫大功劳！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "骂一声小张松说话太错， 休得要在教场胡言乱说。 大将军谁无有胜败之错， 你再说老夫我待人如何？"
        },
        {
          "character": "张松",
          "type": "白",
          "text": "丞相待人，名扬天下，人人皆知！待我说来，你且听了！"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "想当年献钢刀行刺董卓， 各州县画图形将你捕捉。 行至在中牟县巧言瞒过， 陈公台弃县令随你逃脱。 吕伯奢他待你哪些有错， 杀他的一满门命见阎罗！ 白门楼陈公台被你拿获， 为什么恩不报反把头割？ 这都是丞相你待人不错， 真果是量似海恩如江河。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "张松贼说此话忒以猖狂， 竟敢在我面前说短道长。 叫人来将张松赶出大帐， 也免得这畜生任嘴逞狂。"
        },
        {
          "character": "张松",
          "type": "唱",
          "text": "可笑那曹孟德无才无量， 他把我张永年当做平常。 我本当将地图献于奸相， 又谁知曹孟德一味逞强。 我只得将川图暂且收放， 回西蜀见主公再作商量。 无奈何离去了中军宝帐， 不料想这一遭枉来许昌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张松下。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "我本是调文武叫他害怕， 不料想气得我心火难压！ 忙吩咐众将官各回府下， 任凭他作何为走遍天涯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}