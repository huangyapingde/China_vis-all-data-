{
  "script_id": "05004001",
  "title": "专母训子",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "专母",
      "hangdang": "老旦"
    },
    {
      "name": "专诸",
      "hangdang": "净"
    },
    {
      "name": "专妻",
      "hangdang": "旦"
    }
  ],
  "plot": "伍员荐专诸助姬光夺国，专诸归家别母，有所留恋，专母训诫后自缢，以绝专诸顾虑。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "专母上。"
        },
        {
          "character": "专母",
          "type": "引子",
          "text": "节烈冰霜，慕先贤，百世流芳。"
        },
        {
          "character": "专母",
          "type": "念",
          "text": "苦守居孀耐时光，紧闭蓬门训儿郎。要学当年先贤母，万载名标永流芳。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "老身专诸之母，在这姑苏城外居住。我儿屠猪为生，事母至孝，一生就好交友。 昨日有一位伍子胥，弃楚投吴，与我儿结为生死之交，又将我儿荐在姬千岁 府内，至今未见回转，是老身倚门而望。正是："
        },
        {
          "character": "专母",
          "type": "念",
          "text": "愿儿全忠孝，万古称英豪。"
        },
        {
          "character": "专母",
          "type": "西皮慢板",
          "text": "我母子家虽贫遵古训教， 苦居孀守专诸谨教子曹。 儿成丁喜结交平生所好， 愿我儿与真主辅保龙朝。 清晨起见乌鸦对我乱叫， 或主吉或凶险早现根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸上。"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "伍子胥他与我情投谊好， 结金兰拜兄弟恰如同胞。 昨日里姬千岁传旨一道， 差我在酒席宴前刺杀王僚。 因此上回家去禀母知道，"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "见母亲在草堂闷坐无聊。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "孩儿参见母亲。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "谢坐。母亲，今有姬千岁赏赐金银，儿在膝下献上。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "儿啦，有道是无功不受禄，放在一旁。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "儿啦，那姬千岁将你召进府去，但不知为了何事？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "无非是教习拳棒。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "既是教习拳棒，儿为何眼中落泪呀？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "孩儿不曾落泪。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "你脸上泪痕未干，还敢强辩！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "母亲不必动怒。只因孩儿不愿为官，愿在家中侍奉母亲。是儿进退两难，故而 落泪。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "儿啦，为娘倒明白了。想必是那姬千岁将儿召进府去，有什么大事相托。你看 为娘年迈，不肯前去，你道是也不是？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "既被母亲道破，孩儿不敢隐瞒。儿对母亲实说了罢！那姬千岁，将儿召进府去， 对儿言道：吴王姬僚为君不正，命孩儿献鱼为名，在酒席筵前，行刺那王僚！"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "专母",
          "type": "西皮导板",
          "text": "听一言来魂下掉！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "专母",
          "type": "西皮摇板",
          "text": "酒席筵前儿刺王僚。 那贼人马有多少，"
        },
        {
          "character": "专母",
          "type": "哭头",
          "text": "我的儿啦！"
        },
        {
          "character": "专母",
          "type": "西皮摇板",
          "text": "怕儿性命难脱逃。"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "母亲不必珠泪掉， 孩儿言来听根苗： 但等母亲百年老， 孩儿再去立功劳。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "母亲不必如此，但等母亲百年之后，儿在立功，也还不迟。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "我儿此言差矣。自古道：受人点水之恩，当答涌泉之报。不必挂念为娘，只管 前去才是。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "想那王僚驾下，能将不少，孩儿此去，定然吉凶难定，存亡未卜。倘有不测， 母亲膝下，无人尽孝，孩儿我怎能割舍？"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "你看为娘，桑榆暮景。想你那妻子，颇知礼仪，侍奉为娘，最是尽心。我儿只 管前去。为娘有言，儿且听了。"
        },
        {
          "character": "专母",
          "type": "西皮原板",
          "text": "姬千岁有贤明为人有道， 我的儿保真主莫要辞劳。 自古道尽其忠难行孝道， 方显你尽孝心万古名标。"
        },
        {
          "character": "专诸",
          "type": "西皮原板",
          "text": "谢罢了老娘亲将儿调教， 坐草堂听孩儿细说根苗： 此一番刺王僚凶多吉少， 难免那酒席筵前赴阴曹。 非是儿贪生命不把主保， 还未曾报娘恩养育劬劳。"
        },
        {
          "character": "专母",
          "type": "西皮摇板",
          "text": "遵奉母命就为孝， 奉养高堂食饱勤劳。 快些前去休迟了， 为娘方得喜眉梢。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "儿啦，如今天下刀兵四起。儿为文官则须尽忠，儿为武将则须报效，你休要迟 迟，快些去罢。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "多谢母亲将儿教， 不由专诸泪双抛！ 今生难以行孝道，"
        },
        {
          "character": "专诸",
          "type": "哭头",
          "text": "儿的娘啊！"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "但愿老娘年寿高。 拜别母亲出门道，"
        },
        {
          "character": "专母",
          "type": "哭",
          "text": "儿啦，儿啦！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "难舍难离痛难消。 尽忠哪有行孝好？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "老娘亲！"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "孩儿不愿凌烟标。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "啊儿啦，你为何去而复转？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "非是孩儿去而复转。只因母亲年迈，无人侍奉，孩儿放心不下。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "唗！你既受姬千岁重礼相托，你不肯前去，你就为不忠不孝之人，为娘就要打！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "打死孩儿，儿也是不去的了哇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸哭。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "专母",
          "type": "西皮二六板",
          "text": "听儿言来心焦躁， 思量辗转无有计一条。 我的儿生来性情傲， 把老身的良言付与了波涛。 我儿若是全孝道， 岂不是耽误了儿立功劳？ 老身今日花甲老，"
        },
        {
          "character": "专母",
          "type": "西皮快板",
          "text": "就死黄泉也逍遥。 有夫从夫妇之道， 无夫就当从儿曹。 我儿尽忠把国保， 老身就当赴阴朝。 回头便把专诸叫， 娘有一言听根苗。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "儿啦。你不愿尽忠，情愿尽孝，此话当真？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "孩儿焉敢道谎。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "为娘与你讲了半日，舌干口燥，取碗水来，为娘一用。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "遵命。待孩儿厨下取来。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "唉，为娘要吃涧下清泉之水。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "儿村外去取。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸挑桶下。"
        },
        {
          "character": "专母",
          "type": "白",
          "text": "哎呀且住！趁此时我儿不在家中，待我行个自尽了罢啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专母哭，拴套。"
        },
        {
          "character": "专母",
          "type": "西皮摇板",
          "text": "对白绫不由我哈哈大笑！ 你成就我节烈万古名标。 白绫一抖无常到，"
        },
        {
          "character": "专母",
          "type": "哭头",
          "text": "我的儿啦！"
        },
        {
          "character": "专母",
          "type": "西皮摇板",
          "text": "为儿立功赴阴曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专母上吊。专诸上。"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "适才取水心惊跳， 回到家中奉年高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸看，甩桶。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "见母亲行自尽心如刀绞， 可叹娘为姣儿受尽煎熬。 哭一声老娘亲，哦呀儿的娘啊！ 见了贤妻说根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专妻上。"
        },
        {
          "character": "专妻",
          "type": "西皮摇板",
          "text": "忽听前堂一声吵， 见了婆母问根苗。"
        },
        {
          "character": "专妻",
          "type": "白",
          "text": "儿夫为何这等模样？"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "哎呀妻呀！母亲命丈夫帮助姬光千岁刺王僚，为丈夫言道，母亲百年之后，方 能前去；母亲命我村外取水，谁知母亲自尽了哇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸哭。"
        },
        {
          "character": "专妻",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "专妻",
          "type": "西皮摇板",
          "text": "媳妇村外种田稻， 不想婆婆赴阴曹。 哭一声婆母命丧了，"
        },
        {
          "character": "专妻",
          "type": "哭头",
          "text": "婆母啊！"
        },
        {
          "character": "专妻",
          "type": "西皮摇板",
          "text": "珠泪滚滚锁眉梢。"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "贤妻将母亲尸首，停放灵床之上，我还要守孝百日。"
        },
        {
          "character": "专妻",
          "type": "白",
          "text": "啊夫哇！母亲一死，遗言在耳，你还不前去立功？家中之事，均有为妻料理。 若不去，看母亲拐杖在此！"
        },
        {
          "character": "专诸",
          "type": "白",
          "text": "妻呀！"
        },
        {
          "character": "专诸",
          "type": "西皮摇板",
          "text": "贤妻不必泪垂掉， 丈夫言来听根苗： 母亲尸首成殓好， 埋葬吉地要安牢。 实指望坟前来祭扫， 清明佳节把纸烧。 刻下胎儿年纪小， 还要贤妻好教调。 深施一礼出门道， 行刺王僚美名标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专诸下。"
        },
        {
          "character": "专妻",
          "type": "西皮摇板",
          "text": "见儿夫上了阳关道， 心中好似滚油浇。 急忙棺木来买到， 要学婆母训儿曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专妻下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}