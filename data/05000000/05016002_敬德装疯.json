{
  "script_id": "05016002",
  "title": "敬德装疯",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "徐勣",
      "hangdang": "老生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    },
    {
      "name": "黑夫人",
      "hangdang": "旦"
    },
    {
      "name": "白夫人；旦",
      "hangdang": "未知"
    }
  ],
  "plot": "夏明王窦建德欲与李渊争天下，秦王李世民请秦琼、徐勣、程咬金三人相商。徐勣以窦建德为尉迟恭手下败\n将，建议同往置田庄请尉迟恭出山。李世民等甫抵置田庄，尉迟家人董老已早回庄报信。尉迟恭与黑、白二\n夫人计议，乃于李世民等来时装疯。不料此计为徐勣识破，复命程咬金假扮红旗山寇围庄，索取黑、白二夫\n人，以激怒尉迟恭。尉迟恭果中计，出庄穷追程咬金。李世民等与之相见，即请领兵御敌。尉迟恭不从，提\n及为李道宗几至丧命一事，自今以为憾。经李世民跪请，尉迟恭始允出山。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、李世民同上。"
        },
        {
          "character": "李世民",
          "type": "引子",
          "text": "海晏河清。保父王，驾坐龙廷。"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "允文允武英雄将，济世经纶腹内藏。金阙虽无九五位，金枝玉叶小秦王。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王李世民。今有窦建德打来战表，要夺父王江山，不免请出三位国公，议论 此事。 来。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "有请三位国公进帐。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "有请三位国公进帐。"
        },
        {
          "character": "秦琼、徐勣、程咬金",
          "type": "内同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、徐勣、程咬金同上。"
        },
        {
          "character": "秦琼、徐勣、程咬金",
          "type": "同念",
          "text": "忽听君命召，急忙进大营。"
        },
        {
          "character": "秦琼、徐勣、程咬金",
          "type": "同白",
          "text": "臣等见驾，愿二主千岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "秦琼、徐勣、程咬金",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "秦琼、徐勣、程咬金",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "宣臣等进帐，有何国事议论？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "众位国公有所不知，今有夏明王窦建德打来战表，要与我父王争夺江山，因此 请三位国公进帐，议论此事。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "想窦建德乃敖国公尉迟恭马前败将，非他出阵不可，我君臣去到置田庄，聘请 敖国公到来，方可成功。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "好，吩咐御林军走上。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "御林军走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠自两边分上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "起驾置田庄。"
        },
        {
          "character": "李世民",
          "type": "西皮二六板",
          "text": "我父王坐江山风调雨顺， 全凭着驾下的文武公卿。 恼恨着夏明王战表打定， 一心要夺父王锦绣龙廷。 御林军忙带路急往前进， 但愿得敖国公扫荡烟尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "董老上。"
        },
        {
          "character": "董老",
          "type": "念",
          "text": "一年四季天，但愿好丰年。"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "小老儿董老便是。奉了家爷之命，下田耕种。就此走走。"
        },
        {
          "character": "董老",
          "type": "唱",
          "text": "一寸光阴一寸金， 寸金难买寸光阴。 失落黄金犹自可， 失落光阴无处寻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喊声〗。"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "哎呀！哪里人马呐喊？待我站在高坡一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监、秦琼、程咬金、徐勣、李世民同上。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "来此置田庄。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "人马一拥而进。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "且慢！惊走敖国公，那还了得？必须命鲁国公前去通报。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "程皇兄，命你前去通报。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "众将官，就此安营扎寨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四太监、秦琼、徐勣、李世民同下。"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "哎呀，来了一哨天兵，将我置田庄团团围住。此事不敢隐瞒，报与家爷知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董老下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "引子",
          "text": "谪贬田庄，乐享安康。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "可恨唐王太不仁，听信谗言贬大臣。当年受过披麻拷，谪贬田庄为庶民。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "某，复姓尉迟名恭，字敬德。乃索州山阳人氏。自投唐以来，官拜敖国公之职。 可恨昏王听信谗言，将某谪贬田庄。到了此地，自备几亩良田，倒还逍遥自 在。今日闲暇无事，不免出庄游玩一番便了。"
        },
        {
          "character": "尉迟恭",
          "type": "西皮原板",
          "text": "唐尉迟坐厅前自思评论， 想起了当年事好不伤心。 受过了披麻拷令人可恨， 唐主爷听谗言贬谪大臣。 出庄门到壩桥用目观定，"
        },
        {
          "character": "董老",
          "type": "内白",
          "text": "家爷慢走。"
        },
        {
          "character": "尉迟恭",
          "type": "西皮原板",
          "text": "又只见董老儿奔走庄门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董老上。"
        },
        {
          "character": "董老",
          "type": "念",
          "text": "有事不敢隐瞒，无事不敢乱传。"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "启禀家爷：大事不好了！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "来了一哨天兵，将我置田庄团团围定，报与家爷知道。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "起过了。 且住，来了一哨天兵，将我置田庄团团围定，却是为何？呵呵，是了！莫不是 夏明王窦建德与我主争夺江山，二主秦王，奉了圣命，前来请某发兵相助？想 某当年受过披麻吊拷，发下洪誓大愿，永不替唐王出力报效，这便怎么处？ 有了。来！"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "有请二位夫人。"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "有请二位夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董老下，黑夫人、白夫人同上。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同念",
          "text": "忽听老爷唤，急忙到堂前。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "老爷在上，妾身有礼。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "夫人少礼，请坐。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "有坐。呼唤妾身出来，有何见论？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你二人有所不知，只因天朝大将带领人马，将某置田庄团团围住，想是夏明王 窦建德与我主争夺江山，二主秦王奉了圣命，前来请某发兵相助。想某当年受 过披麻吊拷，发下洪誓大愿，永不与唐王出力报效，故而请出夫人，定一不发 兵之计。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "妾身急切无计。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "某家倒有一计，少时他君臣到来，就说某家出庄游玩，偶得疯病，三言两语打 发他君臣而去。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "此计甚好，照计施行。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "你我定计你我知，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同念",
          "text": "怎能走了这消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "启禀二位皇嫂：二主驾到。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、四太监、秦琼、徐勣同上。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "臣妾见驾，愿二主千岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "皇嫂平身。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "谢坐。千岁不在皇宫，来在荒庄，所为何事？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "皇嫂有所不知，只因夏明王窦建德打来战表，与我父子争夺江山。奉父王之命， 请敖国公回朝，发兵相助。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "千岁来得不凑巧。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "怎样不凑巧？"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "老爷出庄游玩，偶得疯病。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王不信。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "千岁不信，唤出老爷一观，便知明白。 有请老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "二黄导板",
          "text": "一霎时南天门煞神天降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭跌，黑夫人、白夫人同搀起。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "老爷仔细了。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈呵呵。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "险些儿一家人性命有伤。 恼恨着玉皇帝装模作样， 他不该领天兵杀奔田庄。 这两旁站的是天兵天将， 一个个要拿我去见玉皇。 那一旁小哪吒现出金像， 这一边站的是四大金刚。 怒不息忙把那云端来上，"
        },
        {
          "character": "李世民、秦琼、徐勣、程咬金",
          "type": "同白",
          "text": "敖国公请了。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈哈！呵呵呵呵！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "又只见众仙翁俱坐在厅堂。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "敖国公请了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀，彩和大仙请了！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王李世民。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "蓝彩和！"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "二主秦王。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "彩和大仙。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈，呵呵呵！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "上坐着蓝彩和现出金像， 手提着竹花蓝放出毫光。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "彩和大仙到了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "敖国公请了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀，钟离大仙到了！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "山人徐茂公。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "汉钟离！"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "徐先生。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "汉钟离！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "山人徐勣。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "钟离大仙。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈呵呵！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "汉钟离你还是当年模样，"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "敖国公请了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呵喏，纯阳大仙请了！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "本帅秦叔宝。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吕纯阳！"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "秦元帅。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "纯阳大仙呀。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈呵呵！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "唐尉迟有何能劳动纯阳？ 曾记得蟠桃会我告了酒量，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "敖国公请了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呀，你是柳树精？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我是程咬金！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呔，柳树精呀！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "又只见柳树精降下天堂。 这两旁又来了虾兵蟹将， 一个个执法宝放出了毫光。 手执着雌雄鞭将你们打散，将你们打散， 恨不得将你们吞吃在胸膛。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "老爷有惊驾之罪。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "恕他无罪。小王回朝。命太医院前来与他调养病症。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "多谢千岁！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王去也。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "臣妾送驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、四太监、秦琼、程咬金同下，徐勣窃听。"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "请老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "好煞好煞！"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "老爷，他们一起去了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "他们竟自去了，你老爷的病不觉就好了。"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈，哈哈呵呵！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "听一言来笑开怀， 护国军师解不开。 非是某家把疯病害，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "夫人！"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同白",
          "text": "老爷。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "险此儿又要把兵排。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣笑下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "真病容易害，"
        },
        {
          "character": "黑夫人、白夫人",
          "type": "同念",
          "text": "假病最难装。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "好个假病最难装。随某来呀！"
        },
        {
          "character": "尉迟恭",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、黑夫人、白夫人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、李世民、秦琼、程咬金、徐勣同上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生，敖国公得下疯病，如何是好？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "千岁，你道敖国公还是真疯？还是假疯？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "哪有假疯道理？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "非也。若是真疯，二位夫人定然面带忧容；你看二位面带欢容，必是假疯。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生计将安出？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "命鲁国公假扮红旗山的大王，要抢二位夫人以为压寨，尉迟恭闻听此言，必定 出庄，那里君臣就可相会。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "鲁国公听令！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "命你扮红旗山大王，抢他黑白二位夫人，以为压寨。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "有道是："
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "千军容易得，"
        },
        {
          "character": "秦琼、徐勣",
          "type": "同念",
          "text": "一将最难求。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、程咬金同上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "俺，程咬金。奉了二主将令，扮作红旗大王。 三军们，待程爷扮起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金扮。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "爷爷扮得可像？"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "扮得像。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董老暗上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、程咬金同下。"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "哎呀，不好了！红旗山大王要抢黑白二位夫人，以为压寨。此事不敢隐瞒，报 与家爷知道。 有请老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "终日眉头皱，有事在心头。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "启爷爷：大事不好了！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "董老",
          "type": "白",
          "text": "今有红旗山大王，要抢黑白二位夫人，以为压寨。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "反了哇！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "听一言来怒气生， 胆大贼子敢逞能。 董老儿带路月台进， 看一看贼子发来的兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、程咬金同上，过场，同下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "果然果然真果然， 果然贼子发喽兵。 董老儿带路月台下， 你与爷抬鞭上马行。 回言便把董老儿叫， 老爷言来你是听： 去到上房送一信， 庄前庄后要小心。 怒气不息出庄行， 我与贼子大交兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "贼子带兵何往？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "劝你将黑白二位夫人献上便罢，如若不然，将你田庄踏为平地。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "满口胡言，看鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下，尉迟追下。李世民、秦琼、徐勣同上。程咬金上，尉迟恭上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "慢来慢来！看看我还是程咬金？还是柳树精？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "实以为贼子逞威风， 原来中了计牢笼。 本当勒马庄田进，"
        },
        {
          "character": "秦琼、徐勣",
          "type": "同白",
          "text": "二主在此！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "实实难舍二主君。 翻鞍离镫下了马， 尊声千岁可安宁？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "千岁不在皇宫，来在荒庄，所为何事？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "敖国公有所不知，只因夏明王窦建德打来战表，与我父王争夺江山，奉父王之 命，请敖国公回朝，发兵相助。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "千岁呀！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "南征北剿立大功， 中了奸人计牢笼。 不是先生把计用， 险些命丧李道宗。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "敖国公不必怒气冲， 山人言来听从容： 二主秦王来到此， 还望国公度量洪。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啰嗦了！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "敖国公不必怒气生， 本帅言来你是听： 夏明王打来连环表， 还望国公发救兵。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "唠叨了！"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "敖国公不必巧计生， 咬金言来你是听： 二主秦王来到此， 你为什么装病又装疯？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哪个装疯？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你装疯！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "着打！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "一见尉迟不发兵， 倒把小王无计行。 将身跪在尘埃地，"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "尉迟恭怎敢慢主君。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "要臣发兵，却也不难；在此停兵三日，一同发兵相助。备得有宴，与千岁众位 同饮。"
        },
        {
          "character": "李世民、秦琼、徐勣、程咬金",
          "type": "同白",
          "text": "叨扰了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、秦琼、程咬金同下，徐勣欲下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "先生请转。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "敖国公何事？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "某家服了你。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "服山人何来？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "服你好计！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "山人也服了你！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "服某家何来？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "服你装的好疯！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "这个，哼！哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、徐勣同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}