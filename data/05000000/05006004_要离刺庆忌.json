        {
          "character": null,
          "type": "stage",
          "text": "姬光、四龙套、四大铠、夫槩同上"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "且住！庆忌十分骁勇。 众将，弓箭伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庆忌上，拔箭，开打，姬光、四龙套、四大铠、夫槩同败下。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "且住！杀了半日，因何不见二位叔父，败往哪里去了？姬光人马甚众，不免杀 出重围，回艾城整顿人马，再来报仇雪恨。 呔，姬光听者！叫你多活几日，再来取你的狗命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庆忌突围，姬光、四龙套、四大铠、夫槩同上，同开打，庆忌败下。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "众位将军，穷寇莫追，暂且息兵回国者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
