{
  "script_id": "05006004",
  "title": "要离刺庆忌",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "庆忌",
      "hangdang": "净"
    },
    {
      "name": "伍员",
      "hangdang": "老生"
    }
  ],
  "plot": "吴王姬僚被刺，姬光夺其王位。姬僚之子庆忌逃往艾城，屯军纳士，结连邻邦，伺机报仇。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员、专毅、子山、夫槩同上，同起霸。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "冤仇未报气冲天，"
        },
        {
          "character": "专毅",
          "type": "念",
          "text": "子承父职灭奸馋。"
        },
        {
          "character": "子山",
          "type": "念",
          "text": "幸遇兄王恩宠眷，"
        },
        {
          "character": "夫槩",
          "type": "念",
          "text": "盖世英雄美名传。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "伍子胥。"
        },
        {
          "character": "专毅",
          "type": "白",
          "text": "专毅。"
        },
        {
          "character": "子山",
          "type": "白",
          "text": "子山。"
        },
        {
          "character": "夫槩",
          "type": "白",
          "text": "夫槩。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "专毅、子山、夫槩",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "主公兵发江口，阻挡庆忌，你我辕门伺候！"
        },
        {
          "character": "专毅、子山、夫槩",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、专毅、子山、夫槩同下。〖发点〗。四龙套、四大铠引姬光同上。伍员、专毅、子山、夫槩同上。"
        },
        {
          "character": "姬光",
          "type": "引子",
          "text": "图王霸业怀志量，统雄狮亲临战场。"
        },
        {
          "character": "姬光",
          "type": "念",
          "text": "鱼肠剑上生焰光，灭却王僚正朝堂。可叹专诸席前丧，惟惜贤母抱忠亡。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "孤，姬光，只因王僚谋篡基业，是孤怀恨在心。如今王僚一死，惟虑公子庆忌 在外，有万夫不当之勇，行走如飞，手绰燕鸟，犹如探囊取物。为此，孤王御 驾亲临，兵扎江口，以防庆忌归国。 伍将军，孤王此番出兵，剿除叛逆，务须努力争先！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "罪臣伍员，幸蒙大王不忍加戮，收留帐下，敢不奋勇当先。只是臣父兄冤仇未 报，心常耿耿，恐怕战场之上，难敌叛逆，有辱军威。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "将军不要如此，且等平定国乱，孤再兴兵伐楚，替你报仇就是。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "多谢主公。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "就命将军传孤旨意，百官免送，人马起程。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "领旨。 大王有旨，文武百官免送，大小将官护驾，就此兵发江口！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖五马江儿水〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "盖余、属庸同上。"
        },
        {
          "character": "盖余",
          "type": "西皮摇板",
          "text": "星夜逃出天罗网，"
        },
        {
          "character": "属庸",
          "type": "西皮摇板",
          "text": "不知何处是家乡？ 中国京剧戏考 《要离刺庆忌》【前部】 2"
        },
        {
          "character": "盖余",
          "type": "白",
          "text": "俺盖余。"
        },
        {
          "character": "属庸",
          "type": "白",
          "text": "属庸。"
        },
        {
          "character": "盖余",
          "type": "白",
          "text": "贤弟，你我奉了兄王旨意，领兵伐楚，反被楚兵围困日久。闻得姬光杀君夺位， 人伦尽丧。且喜逃出虎口，投奔何处？"
        },
        {
          "character": "属庸",
          "type": "白",
          "text": "那公子庆忌纠连郑、卫，未曾归国，去至那里，再作商议。"
        },
        {
          "character": "盖余",
          "type": "白",
          "text": "如此，马上加鞭。"
        },
        {
          "character": "盖余",
          "type": "西皮摇板",
          "text": "杀君夺位人伦丧，"
        },
        {
          "character": "属庸",
          "type": "西皮摇板",
          "text": "拿住姬光祭兄王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "盖余、属庸同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "庆忌上，起霸。中军上。"
        },
        {
          "character": "庆忌",
          "type": "念",
          "text": "豪气英雄贯斗牛，画戟翻飞神鬼愁。纵横天下无敌手，压伏邻邦众诸侯。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "某，吴国大殿下庆忌。奉了父王旨意，纠连郑、卫二国，回朝复命。这几日心 惊肉跳，不知主何吉凶？ 中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "吩咐满营众将，今朝暂息一日，明晨回朝。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。 呔，下边听者：满营将官暂息一日，明日回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "盖余、属庸同上。"
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "来此已是。 门上哪位在？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？ 原来是二位老殿下，中军有礼。"
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "罢了，通知你家公子，我二人求见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。 启禀公子：二位老殿下求见。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "公子哪里？"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "二位叔父为何惊慌？"
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "今有姬光请你父过府饮宴，那专诸、伍员，在酒席筵前，将你父王刺死。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "将你父王刺死了！"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庆忌气椅。"
        },
        {
          "character": "盖余、属庸、中军",
          "type": "同白",
          "text": "公子醒来！"
        },
        {
          "character": "庆忌",
          "type": "西皮导板",
          "text": "听说是我父王遭毒手！"
        },
        {
          "character": "庆忌",
          "type": "三叫头",
          "text": "我父！父王，哎，我父啊！"
        },
        {
          "character": "庆忌",
          "type": "唱",
          "text": "一腔热血堵咽喉。 那姬光他不念同宗的恩厚， 杀君王留骂名万古存留。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "二位叔父，我父王一死，国中姬光夺位，望二位叔父帮助侄儿，与我父报仇， 恢复吴国基业。 中国京剧戏考 《要离刺庆忌》【前部】 3"
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "我等愿随公子。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "闻得二位叔父，带兵伐楚，何处得来此信？ 属庸"
        },
        {
          "character": "庆忌",
          "type": "同白",
          "text": "公子有所不知，只因楚将沈尹戌、郤宛用沙囊将江口塞断，我们进退无路。连 日救兵不到，看看粮草已尽，我二人差心腹家将，回朝搬兵，探来此事。我兄 弟无心战守，微服而逃，夜奔至此。"
        },
        {
          "character": "盖余、庆忌",
          "type": "白",
          "text": "原来如此。二位叔王歇息一宵，明日营门听令，请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "盖余、属庸同下。"
        },
        {
          "character": "盖余、庆忌",
          "type": "stage",
          "text": "庆忌"
        },
        {
          "character": "盖余、庆忌",
          "type": "唱",
          "text": "老父王他不纳忠臣谏奏， 信用那狗奸党少欠计谋。 到明天发人马问罪贼酋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庆忌、中军同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "报子"
        },
        {
          "character": null,
          "type": "text",
          "text": "（白） 俺夜不收。探得姬光弑逆，报与公子知道。马上加鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马童上，起霸。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "俺马夫是也。奉了殿下旨意，准备龙驹。洗马者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童洗马下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、盖余、属庸、四下手、中军、二马夫、庆忌同上。"
        },
        {
          "character": "庆忌",
          "type": "念",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": ""
        },
        {
          "character": "报子",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "念"
        },
        {
          "character": "报子",
          "type": "stage",
          "text": "庆忌"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "报子",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "报子",
          "type": "stage",
          "text": "庆忌"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": ""
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": ""
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": " 怀恨在胸膛，问罪与姬光。 探得姬光事，报与千岁知。 叩见大公子。 哪路军情，起来讲。 容禀： 姬光行篡逆，刺客名专诸。七首鱼肠剑，刺透铠𤠯猊。 可叹皇王主，霎时魂魄飞。国中机密事，特来报君知。 先王归天之后，何人接位？ 那姬光差人去往晋国，请季子回朝，那季子呵！ 再探！ 二位叔父统领大队人马，以为前站先行，某家亲督后队。响炮抬营！ 得令。 抬枪带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、盖余、属庸、四下手、中军、二马夫同应，众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员、专毅、子山、夫槩、四龙套、四大铠、姬光同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《要离刺庆忌》【前部】 4"
        },
        {
          "character": "伍员、专毅、子山、夫槩",
          "type": "同白",
          "text": "来在江口。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "安营扎寨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启大王：今有公子庆忌，同二位老殿公率领大兵杀奔江口而来。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "且住！想那庆忌来势凶勇，此来必有一番鏖战。 伍将军听令！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "命你带领五百人马迎敌头阵。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "得令。 带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "专毅听令。"
        },
        {
          "character": "专毅",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "带领五百校刀手接应伍员，不得违误。"
        },
        {
          "character": "专毅",
          "type": "白",
          "text": "得令。 带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "专毅下。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "子山听令！"
        },
        {
          "character": "子山",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "命你带领五百长枪手，埋伏芦林深处，敌人前来，放火追烧，违令者斩！"
        },
        {
          "character": "子山",
          "type": "白",
          "text": "得令。 带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "子山下。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "夫槩听令！"
        },
        {
          "character": "夫槩",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "命你带领本部弓箭手，随定孤王去者。"
        },
        {
          "character": "夫槩",
          "type": "白",
          "text": "得令。 带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员、四龙套同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "盖余、伍员同上，会阵，盖余败下，属庸上，战，败下，伍员追下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套、四下手、中军、二马夫、庆忌同上，盖余、属庸同败上。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、四龙套同上，同起打，盖余、属庸同败下，庆忌挡伍员。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "原来是公子。末将甲胄在身，不能全礼，马上打躬。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "伍子胥，老匹夫，想我父王念你有血海冤仇，何等恩待于你，怎么反助姬光刺 杀我父，我把你这犯罪的亡囚！品萧的乞丐！还敢带兵前来断俺的归路，休走， 看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庆忌、伍员同起打，伍员败下，庆忌追下。"
        },
        {
          "character": "庆忌",
          "type": "stage",
          "text": "中国京剧戏考 《要离刺庆忌》【前部】 5"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "专毅、四龙套同上，过场，同下。"
        }
      ]
