      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、子山同上。"
        },
        {
          "character": "子山",
          "type": "白",
          "text": "某，子山。奉了大王将令，芦林埋伏，就此前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、子山同下。"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "盖余、属庸同败上。"
        },
        {
          "character": "盖余",
          "type": "白",
          "text": "贤弟后面追兵甚紧，伍员杀法厉害，不知大公子今在何处？如何是好？"
        },
        {
          "character": "属庸",
          "type": "白",
          "text": "兄长，前边有一芦林，去到那里躲避躲避，再作道理。"
        },
        {
          "character": "盖余",
          "type": "白",
          "text": "快走，快走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "子山暗上。"
        },
        {
          "character": "子山",
          "type": "白",
          "text": "众将官，放火烧林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火彩。盖余、属庸同被烧。"
        },
        {
          "character": "盖余",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "盖余",
          "type": "唱",
          "text": "这一阵烧的我皮焦肉烂，"
        },
        {
          "character": "属庸",
          "type": "唱",
          "text": "烧的我盔和甲化作灰烟。"
        },
        {
          "character": "盖余",
          "type": "唱",
          "text": "只烧得神无主身酥手颤，"
        },
        {
          "character": "属庸",
          "type": "唱",
          "text": "只烧得四肢无力步难前。"
        },
        {
          "character": "属庸",
          "type": "白",
          "text": "兄长，你我烧的这般光景，不能逃生，如何是好？"
        },
        {
          "character": "盖余",
          "type": "白",
          "text": "事到如今，并无别计。你看那旁有官军尸首，将他衣帽剥下，扮作小军模样， 逃出重围，再作道理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "盖余、属庸同换装毕。〖内喊叫声〗。"
        },
        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "快走，快走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "盖余、属庸同下。"
        }
      ]
    },
    {
