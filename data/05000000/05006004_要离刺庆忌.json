    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上，庆忌追上。专毅上，开打。伍员下。接藤牌手打，专毅败下，庆忌追下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姬光、四龙套、四大铠、夫槩同上，四龙套、四下手、中军、二马夫、庆忌同上。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "哪里走？"
        },
        {
          "character": "姬光",
          "type": "白",
          "text": "庆忌还不下马受绑。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "住了！某家不在朝中，你将我父王害死，谋篡基业。今日狭路相逢，姬光啊， 姬光！这也是你大数到了。看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庆忌、姬光同起打，姬光败下，庆忌追下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
