        {
          "character": "盖余、属庸",
          "type": "同白",
          "text": "杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、专毅、四龙套同上，四股荡，盖余、属庸同败下，伍员、专毅同追下。"
        }
      ]
