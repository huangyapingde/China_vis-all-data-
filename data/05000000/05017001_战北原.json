        {
          "character": "诸葛亮",
          "type": "西皮流水板",
          "text": "自从卧龙把山下， 排兵布阵从无差。 四轮辇且往祁山脚下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上，诸葛亮上车。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮流水板",
          "text": "两军阵前取笑他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、车夫同下。"
        }
      ]
