          "type": "同白",
          "text": "众将进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化、马岱、关兴、张苞同上。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你等整顿军马，埋伏祁山脚下，高挑红灯，上搭“郑”字旗号，等候司马前 来偷营劫寨，一拥杀出，司马兵败，不可追赶，老夫在祁山口等候。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、廖化、马岱、关兴、张苞同下。"
