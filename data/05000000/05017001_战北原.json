        {
          "character": "司马懿",
          "type": "白",
          "text": "嘿嘿。一计不成，损伤我两员大将，真乃司马不如亮也。 众将官，悄悄收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、司马师、司马昭、司马懿同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
