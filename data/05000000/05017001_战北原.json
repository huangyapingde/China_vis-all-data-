          "character": "司马懿",
          "type": "白",
          "text": "回复郑将军，就说老夫修书不及，照书行事。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "诸葛亮，诸葛孔明！今番你也中了本督之计也。 众将官，今晚三更时分，饱餐战饭，马摘銮铃，偷营劫寨去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮流水板",
          "text": "老夫背地笑司马， 郑文诈降智谋差。 打虎之计安排下， 撒出鹰鹞把兔抓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "回来了，司马懿见了书信，怎样回答？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "司马言道：回复郑将军，修书不及，照书行事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "记功劳一件。传令下去，将郑文斩首。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "下面听者：丞相有令，将郑文斩首。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三鼓，斩首。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "斩首已毕。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你将郑文首级用白绫裹好，放在食匣之内，司马兵败之后，送至他营，就说 老夫念他连日用兵辛苦，送来些小薄礼，望祈笑纳。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，传众将进见。"
