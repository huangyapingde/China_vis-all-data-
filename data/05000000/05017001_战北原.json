        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "我少陪，少陪——"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "司马懿",
          "type": "西皮摇板",
          "text": "我要收兵将，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "收兵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、廖化、马岱、关兴、张苞同转圆场。"
