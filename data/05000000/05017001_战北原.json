{
  "script_id": "05017001",
  "title": "战北原",
  "alias": [
    "斩郑文"
  ],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "郑文",
      "hangdang": "净"
    },
    {
      "name": "司马懿",
      "hangdang": "净"
    },
    {
      "name": "唐怀",
      "hangdang": "丑"
    }
  ],
  "plot": "诸葛亮六出祁山，与司马懿相拒于北原、渭桥，司马懿命偏将军郑文诈降，再命人假扮秦朗挑战，郑文出而\n斩之，报功；诸葛亮识破，欲斩，郑文哀免，诸葛令其贻书司马，诱劫蜀营。司马懿得书前往，损兵折将，\n诸葛亮并斩郑文。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "廖化、马岱、关兴、张苞同上，同起霸。"
        },
        {
          "character": "廖化",
          "type": "点绛唇",
          "text": "细柳营开，"
        },
        {
          "character": "马岱",
          "type": "点绛唇",
          "text": "马嘶郊外，"
        },
        {
          "character": "关兴",
          "type": "点绛唇",
          "text": "旌旗摆，"
        },
        {
          "character": "张苞",
          "type": "点绛唇",
          "text": "剑竖刀挑，"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同点绛唇",
          "text": "准备拔营寨。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "廖化。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "关兴。"
        },
        {
          "character": "张苞",
          "type": "白",
          "text": "张苞。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "马岱、关兴、张苞",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "丞相升帐，你我两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点。四龙套引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "掌握兵权，运奇谋，拨乱扶贤；六出祁山，取中原，扫狼烟，全图归汉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化、马岱、关兴、张苞自两边分上，诸葛亮坐大帐。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "汉室纷纷齐弄谋，军中战马不停留。司马纵有拿云手，老夫先下钓鱼钩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫，复姓诸葛名亮字孔明，道号卧龙，汉室为臣，官拜武乡侯之职。蒙先帝 三顾之恩，托孤之重，一要扫灭孙曹，二要恢复汉室。我想北原乃魏邦咽喉之 要地，必需兴兵夺取。 众位将军，人马可齐？"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吩咐兵发北原去者。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "众将官，兵发北原去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上，诸葛亮上车，廖化、马岱、关兴、张苞同上马。〖出队子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "点绛唇",
          "text": "白发银条，胸怀略韬，保魏王，建立功劳，要把孙刘扫。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "汉室江山四百春，我主大魏掌乾坤。东吴西蜀不灭尽，黎民涂炭何日宁？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本督，复姓司马名懿字仲达，魏王驾前为臣，官拜大都督之职。可笑孔明前者 用反间之计，魏王听信，将我谪贬，多蒙太傅钟繇保奏，加封平西大都督，提 调各路兵马，以挡蜀兵。可恨孔明带兵攻取北原，不免传众将进帐商议对策。 来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "传众将进帐。"
        },
        {
          "character": "张郃、郑文、司马师、司马昭",
          "type": "内同白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、郑文、司马师、司马昭同上。"
        },
        {
          "character": "张郃、郑文、司马师、司马昭",
          "type": "同念",
          "text": "三国标名姓，豪杰有威名。"
        },
        {
          "character": "张郃、郑文、司马师、司马昭",
          "type": "同白",
          "text": "参见都督。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "张郃、郑文、司马师、司马昭",
          "type": "同白",
          "text": "谢都督。唤末将等进帐，有何军情议论？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "孔明带兵攻取北原，请众位将军商议退兵之策。"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "末将有计献上。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "这……耳目甚众。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "两厢退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、张郃、司马师、司马昭同下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "郑将军有何妙计？"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "少时都督升帐发兵，末将阻令，都督将某重责，叉出不用，末将前去诈降那孔 明。他若收用，末将暗修书信，做个里应外合，大功必成。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "将军有此忠心？"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "食王爵禄，当报王恩，粉身碎骨，理所当然。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "如此请上，受本督一拜。"
        },
        {
          "character": "司马懿",
          "type": "西皮流水板",
          "text": "好一个忠心郑将军， 可算擎天柱一根。 今日与你把计定， 倘若泄露事难成。"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "都督。"
        },
        {
          "character": "郑文",
          "type": "西皮流水板",
          "text": "都督不必细叮咛， 诈降之计某担承。 食君之禄当尽命， 学一个黄公覆他诈降曹营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑文下。"
        },
        {
          "character": "司马懿",
          "type": "西皮摇板",
          "text": "郑文真是忠心耿， 愿受王刑诈孔明。 吩咐升帐忙传令，"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "升帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、张郃、郑文、司马师、司马昭自两边分上，司马懿正坐。"
        },
        {
          "character": "司马懿",
          "type": "西皮摇板",
          "text": "大小将官听令行。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "郑文听令！"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "命你带领本部人马，大战孔明，以挡蜀兵。"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "为何阻令？"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "都督，孔明用兵如神，此去难以取胜，不如弃甲摈盔，降顺汉营。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "唗！大胆郑文，本督用兵，神鬼莫测，擅敢违抗将令，乱我军规，推出斩首。"
        },
        {
          "character": "张郃、司马师、司马昭",
          "type": "同白",
          "text": "启禀都督：郑文犯罪，理当斩首；念在用兵之际，望都督开恩饶恕才是。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "看在众将讲情，也罢，死罪已免，活罪难饶。 来！重责四十。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同打。"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "谢都督的责。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本督打得你可公？"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "不公。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "打得可是？"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "不是。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "不公也要公，不是也要是，用你不着，叉出帐去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑文下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "来！传唐怀进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "唐怀进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐怀上。"
        },
        {
          "character": "唐怀",
          "type": "白",
          "text": "参见都督。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "唐怀听令。"
        },
        {
          "character": "唐怀",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "命你假扮秦朗，去往蜀营讨战，单要郑文出马，附耳上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿耳语。"
        },
        {
          "character": "唐怀",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐怀下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "张郃听令。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "巡营瞭哨，不得有误。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "唐怀上。"
        },
        {
          "character": "唐怀",
          "type": "白",
          "text": "俺唐怀。奉了都督将令，假扮秦朗，去往蜀营讨战，就此马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐怀下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮慢板",
          "text": "想当初在隆中何等潇洒， 闲无事听鸟音观看山花。 先帝爷三顾请才把山下， 曾受过托孤恩怎敢有差。 在蜀中奉王命统领人马， 兵行在祁山地来把营扎。 这几日我未曾去把仗打， 司马懿他必然笑我怕他。 选一个黄道日发动人马， 扫中原灭北魏重整汉家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀丞相：司马营中，一员大将，名唤郑文，前来投降。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军进帐。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "众位将军进帐。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化、马岱、关兴、张苞同上。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "丞相唤末将进帐，有何军情议论？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "适才探马报道，司马懿营中有一员大将，名唤郑文，前来投降。尔等可知此人？"
        },
        {
          "character": "廖化、马岱、关兴、张苞",
          "type": "同白",
          "text": "闻得那司马懿营中，新收一将，名唤郑文。此人武艺高强，足智多谋，丞相须 要小心一二。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "原来如此。 来，"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "击鼓升帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "升帐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传郑文进帐。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "郑文进帐。"
        },
        {
          "character": "郑文",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑文上。"
        },
        {
          "character": "郑文",
          "type": "西皮快板",
          "text": "昔日里伍子胥临潼会下， 都只为杀父仇奔走天涯。 到后来将平王鞭尸基下， 可算得奇男子做事不差。 来至在汉营地离鞍下马， 营门外摆刀枪剑戟如麻。 我这里将宝剑腰间摘下，"
        },
        {
          "character": "郑文",
          "type": "白",
          "text": "郑文告进！"
        },
        {
          "character": "郑文",
