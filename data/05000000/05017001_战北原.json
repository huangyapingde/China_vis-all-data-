        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "你父子回营去养养伤再摆战场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、廖化、马岱、关兴、张苞、车夫、诸葛亮同下。"
