          "text": "千岁，你看风狂浪大，犹如巨吼之声，好不惊怕人也。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "哈哈哈。先生，你胆量太小了。"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "臣胆量不小，看戟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "要离刺。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "哎呀！你原来是刺客！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庆忌抓住要离。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "要离呀，要离！你真乃胆量不小！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。"
        },
        {
          "character": "四大将",
          "type": "同白",
          "text": "千岁，将他赐与臣等，乱刀分尸！"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "此乃天下勇士，不可伤害于他。 要离。"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "千岁。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "你今将孤刺透胸膛，也是孤目不识人，我好自恨也。"
        },
        {
          "character": "庆忌",
          "type": "二黄摇板",
          "text": "好一个奇男子真有胆量， 竟敢在江心内行刺孤王。"
        },
        {
          "character": "要离",
          "type": "二黄摇板",
          "text": "俺要离诈降来忠于君上， 此所谓留后世万古名扬。"
        },
        {
          "character": "庆忌",
          "type": "二黄摇板",
          "text": "饶恕你残生命将你来放， 中国京剧戏考 《要离刺庆忌》【后部】 9 回朝去请功赏全汝忠良。"
        },
        {
          "character": "要离",
          "type": "二黄摇板",
          "text": "杀妻儿绝宗嗣六亲皆丧， 决不肯求富贵身列朝堂。"
        },
        {
          "character": "庆忌",
          "type": "二黄摇板",
          "text": "也是孤无常到前世的魔障，"
        },
        {
          "character": "要离",
          "type": "二黄摇板",
          "text": "为臣我也算是应遭祸殃。"
        },
        {
          "character": "庆忌",
          "type": "二黄摇板",
          "text": "孤王我放汝归休得违抗，"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "要离",
          "type": "二黄摇板",
          "text": "俺要离有一言容诉衷肠。"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "哎呀千岁，臣有三恶，不能留于人世。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "有何三恶？你快快讲来。"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "为臣杀妻断臂，行刺故君的公子，无智，无仁，无义。哎呀千岁，为臣先去， 准备迎接龙驾，就此拜别了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "要离投江。"
        },
        {
          "character": "庆忌",
          "type": "白",
          "text": "打捞上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大将同捞上要离。庆忌拔戟，三笑，死，下。"
        },
        {
          "character": "四大将",
          "type": "同白",
          "text": "要先生醒来！"
        },
        {
          "character": "要离",
          "type": "唱",
          "text": "为国家亡生命满门尽丧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "要离看庆忌。"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "千岁呀！"
        },
        {
          "character": "要离",
          "type": "唱",
          "text": "是何人打捞我二次还阳。 小千岁已死在战船之上， 我再与众将士细说端详。"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "众位将军，千岁已死，你们要好好盛殓千岁，你们看那边敌人来了。"
        },
        {
          "character": "四大将",
          "type": "同白",
          "text": "在哪里？"
        },
        {
          "character": "要离",
          "type": "白",
          "text": "在那厢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "要离抽大将甲宝剑刖双足自杀。"
        },
        {
          "character": "四大将",
          "type": "同白",
          "text": "要离已死，就将公子尸首一并献与吴王，大家降吴去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同哭下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}