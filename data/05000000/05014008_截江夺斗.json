{
  "script_id": "05014008",
  "title": "截江夺斗",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "孙尚香",
      "hangdang": "旦"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    }
  ],
  "plot": "孙权屡讨荆州不得，知刘备入川，乃用张昭之计，差心腹周善赴荆州，伪称母病，接孙夫人携阿斗归宁，欲\n以阿斗为质，换取荆州。孙夫人不察，登舟。赵云得知，驾舟追赶，跃上大船，夺回阿斗；张飞踵至，杀死\n周善，同保阿斗回荆州。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "周善",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周善上。"
        },
        {
          "character": "周善",
          "type": "念",
          "text": "奉了吴侯命，星夜到荆州。"
        },
        {
          "character": "周善",
          "type": "白",
          "text": "俺，周善。奉了吴侯之命，去往荆州，投递书信，就此马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周善下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "引子",
          "text": "金殿盘玉柱，彩凤绕画梁。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "随驾荆襄坐九州，金枝玉叶乐无忧。爱喜刀枪读书史，乘龙佳婿配夫刘。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "本宫，孙尚香。兄长孙权，坐镇东吴。自幼喜爱刀枪，深通书史。配于刘皇叔 玄德为室。只因夫君领兵攻取西川，至今未闻捷报。奴闷坐宫中，十分挂念。 宫娥们，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监引周善同上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启娘娘：东吴周善求见。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "传他进来。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "传周善进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周善传入。"
        },
        {
          "character": "周善",
          "type": "白",
          "text": "参见娘娘。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "周善到此何事？"
        },
        {
          "character": "周善",
          "type": "白",
          "text": "奉太后之命，特来下书。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "书信呈上，下面歇息。"
        },
        {
          "character": "周善",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监引周善同下。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "今日母后有书信到来，待奴拆开观看便了。"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "未曾拆书泪先淋， 纸上相逢母女情。 上写为娘修书信， 尚香儿从头看分明。 为母得了思儿病， 即速起程莫延停。 看罢书信心难忍， 尚香心中暗沉吟。 皇叔不在荆州郡， 恐怕有人阻驾行。 低下头来自思忖， 即刻起驾便登程。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "传周善。"
        },
        {
          "character": "四宫女",
          "type": "同白",
          "text": "传周善。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周善上。"
        },
        {
          "character": "周善",
          "type": "白",
          "text": "多谢娘娘酒饭。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "此时回转东吴，何人保驾？"
        },
        {
          "character": "周善",
          "type": "白",
          "text": "为臣保驾。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "速备船只，即刻起程。"
        },
        {
          "character": "周善",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周善下。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "虽无千丈线，万里系人心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、孙尚香同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、赵云同上，赵云起霸。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "大将生来盖世奇，长坂坡前抖雄威。单人独骑扶幼主，杀气冲霄向空飞。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "俺，赵云。主公领兵攻取西川，俺奉军师将令，把守江口，远远望见哨探来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有娘娘，私抱太子，回转东吴！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "可曾报过军师？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "未曾。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "三将军？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "也无有。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "速去通报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "且住！娘娘私抱幼主，回转东吴，定是周郎奸计。俺不免驾舟追赶。 众将官，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、赵云上马同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张飞同上，张飞起霸。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "豹头环眼气轩昂，桃园结义世无双。当阳桥前一场战，吓退曹营百万郎！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺，张飞。如今大哥统领人马，攻取西川。俺奉军师将令，巡查江口，防备东 吴。远远望见哨探来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "禀三将军！今有娘娘私抱太子，回转江东，特来报知。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "可曾报过四将军？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报过了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "军师那里，可曾报过？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "未曾报。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "速速通报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "且住！适才探子报道：皇嫂抱定太子，私回东吴，定是孙权之计。俺不免将他 赶回。 众将官，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张飞上马同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、孙尚香抱子、周善同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、赵云同上，过场，同上船，同追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张飞同上，过场，同上船，同追下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四宫女、周善、孙尚香抱子同上，四龙套、赵云同追上。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "赵云为何来？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "娘娘哪里去？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "你无军师命。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "你无主公差！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "听一言来怒气生， 大骂常山将赵云。 我为过江探母病， 苦苦阻拦为何情？"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "赵云船头打一躬， 娘娘凤耳听从容： 那东吴定下牢笼计， 皇娘落在圈套中！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "四叔有所不知情， 哀家言来听分明： 今日过江探母病， 骨肉相逢就回程。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "孙、刘结仇如山海， 恐怕一去难回程！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "纲常礼仪全不论， 刘、孙本是骨肉亲。"
        },
        {
          "character": "周善",
          "type": "唱",
          "text": "娘娘过江探母病， 哪个大胆阻路行？"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "听一言来双眉纵， 二目圆睁似火红。 手使长枪分心刺， 这一枪刺个满江红！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "任你说得天花转， 哀家只当耳边风！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "娘娘不与臣作主， 乌鸦敢入凤凰中。"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "骂一声赵云真大胆， 此去探病谁敢拦？"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "临崖勒马收缰晚， 船到江心补漏难。 娘娘若去留太子， 免得为臣挂心间。"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "自古姣儿不离娘， 倘有差错谁承当？"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "娘娘此去有人阻，"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "哪个敢来阻我行！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "赵云船头来挡驾，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "莫非起下反叛心？"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "娘娘若逼臣就死，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "不如一死落江心！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "娘娘投江一死，不致紧要；哪知为臣在那长坂坡前，救幼主的苦处。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "有什么苦处？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "娘娘不嫌絮烦，容臣奏来："
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "赵云标英名，娘娘凤耳听！提起长坂事，令人心胆惊！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "恼刘琮，恨刘琮， 荆襄九郡归奸雄。 君臣无有安身处， 一齐遘奔在江东。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "只杀得："
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "宝剑难入鞘，血染锦战袍。疆场神鬼叫，方显武将高！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "臣奉命保定甘、糜二位夫人，在乱军之中与甘、糜二位夫人失散。俺行在当阳 桥，遇见三将军。那时三将军叫道：赵云哪子龙，言说你保的好家眷！问得为 臣哑口无言。俺只得勒转马头，俺就杀——杀进曹营，寻见了糜夫人，糜夫人 身带箭伤，怀抱幼主，倒卧尘埃，是俺一见，心如箭攒。那糜夫人看见了为臣 叫道：赵云哪将军！快快救我母子！那时节曹兵犹如潮水一般，臣杀前不能顾 后，战左不能顾右。那时为臣奏道：臣保得娘娘，救不得幼主；救得幼主，保 不得娘娘！好一位糜夫人，解了其情，那时节将幼主交付为臣，那糜夫人她…… 她就投井一死！是臣推墙掩井，怀抱幼主，俺就杀入曹营，不想又得了那贼 青虹宝剑，俺得此剑，犹如胁生双翼，这远者枪挑，近者剑砍，二次抖擞精神， 俺就杀杀杀！只杀得真龙出现！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "你是甚等样人，为何真龙出现？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "为臣哪有这等造化！乃是幼主真龙出现，那曹操一见现出金龙，当时传下一令。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "曹操传下什么将令？"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "曹操传将令，晓谕众三军：不许放冷箭，只擒活赵云！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "为臣一闻此言，立时哈哈大笑！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "你笑者何来？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "笑只笑只有为臣杀人，并无人来伤我！不想这马不识高低，它就坠……坠落在 丈二深壑，我君臣眼望苍天无救，忽然西南角下来了一将，打扮大不相同！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "他怎样打扮？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "来将头戴乌油盔，身披乌油甲，跨下乌骓马，手执皂缨枪，对准为臣，分心就 刺！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "可曾刺着？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "有道是防者不会，会者不防！为臣让过枪头，抓住枪杆，那贼死不放枪，为臣 死不放手。人借马势，马借人力，俺就纵、纵、纵上了丈二深壑。娘娘，为臣 在长坂坡前七进七出，好一场厮杀也！"
        },
        {
          "character": "赵云",
          "type": "扑灯蛾",
          "text": "赵云怒气冲，怒气冲， 杀得满眼红，满眼红。 曹营将士心胆痛， 一片丹心报主公！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "只杀遍地成血海， 阎罗王差来追魂牌。 娘娘若去留太子， 免得为臣挂心怀。"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "四弟不必多言讲， 探母一面就回来！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "问得娘娘无话解，"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "四弟莫慌，俺张飞来了吓。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "三千岁驾定小舟来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "大喝一声把船摇， 只为皇嫂过江来。 将身跳在船舱外，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "皇嫂！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "你私自过江你大不该！"
        },
        {
          "character": "孙尚香",
          "type": "唱",
          "text": "三弟有所不知情， 为嫂言来听分明： 今日过江探母病， 骨肉见面就回程。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "孙、刘结仇似山海， 不该私自过江来！ 我若不看大哥面， 一枪刺你穿心怀。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "四弟，何人保驾？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "周善保驾。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "传周善。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周善上，张飞刺死周善。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "去你娘的！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "一枪刺死小周善， 两下分路把船开。 用手抢过皇太子，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞抢子交赵云。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "皇嫂！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "你死在东吴就莫回来！"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "皇嫂做事大不该，不该私自过江来。俺若不看大哥面，一枪刺你穿心怀！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、赵云抱子、八龙套同下。"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香、四宫女同下。张飞、赵云、八龙套同上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "好个常山赵子龙，拦江救主立奇功。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "可笑孙权无见识，周郎妙计一场空！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好吓！好个周郎用计一场空。四弟，你我同见军师缴令。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "三千岁之功！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "四弟之功！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "大家之功！"
        },
        {
          "character": "赵云、张飞",
          "type": "同白",
          "text": "三军的！人马收回！一同缴令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、赵云、八龙套同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}