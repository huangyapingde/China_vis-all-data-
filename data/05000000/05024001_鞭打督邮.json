{
  "script_id": "05024001",
  "title": "鞭打督邮",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "督邮",
      "hangdang": "丑"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    }
  ],
  "plot": "刘备任职安喜县县尉，甚得民心。适有督邮来县视察，勒索贿赂，因刘备不肯逢迎，乃诬刘备贪赃枉法。张\n飞怒将督邮缚于树上鞭打，刘备加以劝阻。认为不必与督邮之流计较短长，乃与关羽、张飞弃官而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、书吏同上。"
        },
        {
          "character": "书吏",
          "type": "念",
          "text": "清官来上任，百姓享太平。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "我等乃安喜县人役。只因新官上任，特地前来迎接。 左右，迎上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内二黄导板",
          "text": "叹火德时方衰大乱萌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "回龙",
          "text": "弟兄们，破黄巾，数十阵，舍命冲杀把贼平，到如今，只落得，安喜县令暂栖 身。"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "叹桓灵御帝位纲纪不振， 到处里狼烟起遍地黄巾。 我弟兄三结义投军效命， 救困危杀贼兵答报朝廷。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "弟兄桃园结信盟，异姓同胞共死生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "大破黄巾救危困，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "论功受赏是虚名。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "俺中山刘备。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "河东关羽。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "涿郡张飞。唉！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟为何叹气？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥，想你我弟兄大破黄巾数十余阵，克城破贼，功盖宇宙，朝廷理当赏功封 爵才是正理，到如今只落得小小县尉，叫小弟心中不服。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟休要烦恼，大丈夫到处安身，听天由命，何必性急。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟言之有理。弟兄暂作苟且安身，久后待时而作。就此马上加鞭。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "英雄无时且耐忍， 掌中无刀怎杀人。 眼望着县城池离此甚近，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、书吏同上。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "安喜县着人迎接老爷。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "又听得书吏们迎接来临。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "书吏。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "休要惊动地面。县衙伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四校尉、督邮同上。"
        },
        {
          "character": "督邮",
          "type": "引子",
          "text": "奉旨出朝，地动山摇。"
        },
        {
          "character": "督邮",
          "type": "念",
          "text": "督邮生来命不穷，金银出手不落空。国家若是将我用，祸国害民抖威风。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "下官督邮。乃是库丁出身。目不识丁，就是有几个好友，劝我作官，我说我的 文理不通，毫无资格，怎么能作官呢。朋友说：现在作官，不论资格，不论文 理，只要有运动，就能作官。我就听人相劝，拿金银埋在花盆里，托人送给十 常侍。哈哈，真正钱能通神，不到三天，就派我为督邮了。哎呀，自出京以来， 一路上那些大小官员，有送金的，也有送珠宝的，我算了一算，出了一万， 回来廿万，真正发财买卖。 校尉们！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "前面已是安喜县。县尉可是刘备？"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "正是那刘备，大破黄巾；还有张飞性情刚强。大人须要小心。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "什么刘备、张飞，大破黄巾，总要拿钱来。闲话少说，带马！"
        },
        {
          "character": "督邮",
          "type": "唱",
          "text": "坐在雕鞍开言道， 两旁人役听根苗： 哪怕张飞性情躁， 哪管那刘备战功高。 倘若是金银送得早， 我与他客客气气两开交。 若是金银送不到， 管叫他吃不成来坐不牢。 人来与爷催前道， 全凭压力手段高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "弟兄们在桃园三结义， 乌牛白马祭神灵。 羊角哀、左伯桃本是异姓， 他二人生死交至今名存。 在雪地让衣食伯桃丧命， 似这等舍命全交尘世上能有几人？ 将身儿且坐二堂等， 怕的是髀肉又复生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书吏上。"
        },
        {
          "character": "书吏",
          "type": "念",
          "text": "忙将行部事，报与刘公知。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "启禀老爷：督邮到此，特来报知。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有请二爷、三爷。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "有请二爷、三爷。"
        },
        {
          "character": "关羽、张飞",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "忽听大哥唤，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "上前去问安。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "参见大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二位贤弟请坐。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "谢坐。唤弟等出来有何吩咐？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "只因督邮行部到此，一同出城迎接。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "慢、慢、慢、慢着。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟为何拦阻？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥，你我弟兄投军以来，大破黄巾，大小三十余战，只换得芝麻大的一个穷 官，还要迎接督邮，难道说服从于他不成么？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "他乃上司，前去迎接，不为失了身份。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥知道，如今官作得大，要钱越要得多。你我倒不如回家种田，免得受气。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟，有道是作此官行此礼。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀三弟，还是同大哥去才是，不要伤了弟兄和气。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "小弟同去就是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这便才是。请。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "高皇帝不过是区区亭长， 英雄辈怀大志岂论弱强。 只要是弟兄们抱定思想， 到后来建功业万古名扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、张飞同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四校尉、督邮同上。书吏、刘备、关羽、张飞同上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "安喜县令刘备迎接大人。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "罢了。公馆伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四校尉、督邮同下。刘备作势。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀哎呀。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟，这是为何？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥与他深施一礼，他坐在马上大模大样，竟自进城去了。你道恼是不恼。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "休要莽撞。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "难怪三弟发怒。暂且忍耐，看他来意如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟言之有理。一同进城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四校尉、督邮同上。书吏、刘备、关羽、张飞同上，同挖门。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "参见大人。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "刘备，你是什么出身？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备乃中山靖王之后。投军以来大破黄巾三十余战，颇有微功，才得此县令。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "哈哈哈，好大根基。现在朝廷要汰黜你们。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "是是是。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "要开除你们。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好好好。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "我给你说话，你是是是，好好好，你拿是是是，好好好当进献物么？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦哦哦。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "哎，你真不开通，你为什么？我为什么？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大人为国家，我也是为国家。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "不对不对，你为国来我为家，你拿金银我来花。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大人说哪里话来。有国就有家，无国你家在哪里？想我刘备在两军阵前，九死 一生，如今才得此小小县令，哪有银钱孝敬上司。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "唗！大胆刘备，冒充宗亲，虚报战功，还不与我下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四校尉、督邮同下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待俺打进去。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟忍耐。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "三弟不必性情躁， 忍辱负重是英豪。 二弟、三弟休要恼， 万事从容作计较。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、四校尉、督邮同上，同挖门。"
        },
        {
          "character": "督邮",
          "type": "唱",
          "text": "可恨刘备不开通， 猛然想起计牢笼。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "可恨刘备，自负功劳，一无所献，我不免将他的书吏拿来，叫他报告刘备，贪 财害民，也好弹劾。 来。"
        },
        {
          "character": "校尉甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "将本县的书吏提来见我。"
        },
        {
          "character": "校尉甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉甲下。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "你们等书吏到来，看我的眼色行事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉甲、书吏同上。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "安喜县书吏与大人叩头。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "我来问你，那刘备有什么不平之事，你说上两件上来，我好弹劾他。"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "哎呀大人，那刘县尉，清如水，明如镜，并无不公不平之事，叫小人从何说起。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "哼！你说他没有不公不平，难道说我倒不公不平吗？"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "小人不敢。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "是了。想那刘备平日与你们上下连手，做贪财害民的事，你给他瞒着是不是？"
        },
        {
          "character": "书吏",
          "type": "白",
          "text": "小人越发不敢。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "不敢。吃撑条。 来呀，将他吊在后面拷打，叫他说出刘备贪财害民，要不，叫打死为止。带下 去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉押书吏同下。"
        },
        {
          "character": "督邮",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "督邮",
          "type": "念",
          "text": "作官不把良心坏，大小老婆哪里来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四百姓同上。"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "列位请了。今有督邮大人要害刘公，我等前去哀求。请！ 门上哪位上差在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉甲上。"
        },
        {
          "character": "校尉甲",
          "type": "白",
          "text": "何事喧哗？"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "我等本城百姓，前来求大人保留刘公在此。"
        },
        {
          "character": "校尉甲",
          "type": "白",
          "text": "大人意志，谁敢违抗。"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "哎呀上司老爷，叫天下作官，俱像刘公，待我们大小百姓清如水，明如镜，我 们就享了福了。"
        },
        {
          "character": "校尉甲",
          "type": "白",
          "text": "滚了下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉甲下。"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "哎呀列位，我们大家跪死在此地。"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "走呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "英雄心中千般恨， 只见父老跪埃尘。 下得马来仔细问， 你们为何哭伤心？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你们有何冤枉，在此啼哭？"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "只因督邮大人拷打书吏，要害刘公。我们在此哭求。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呵哇哇，哎呀呀。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "听一言来怒气生， 大骂贼子敢欺人。 回头叫声众百姓， 我去到馆驿打贼人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "哎呀，这个事情闹大了，快快报与刘公知道才好。 有请刘公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "三爷打进馆驿去了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不好了。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "听一言来心着惊， 三弟卤莽性生成。 二弟看过县令印， 去到馆驿看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
