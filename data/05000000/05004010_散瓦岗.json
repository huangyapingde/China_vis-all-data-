{
  "script_id": "05004010",
  "title": "散瓦岗",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "王伯党",
      "hangdang": "老生"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "徐勣",
      "hangdang": "老生"
    },
    {
      "name": "罗成",
      "hangdang": "小生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    }
  ],
  "plot": "李密无道，瓦岗众将均怀去志。秦琼、徐勣、罗成、程咬金同下山林，离去投唐。李密差王伯党赶至，拟追\n回。四人告知回乡奉母，不再回山，乃各分手，王伯党自回瓦岗。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "家住历城在东庄，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣上。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "全凭八卦定阴阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "习就长枪谁能敌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "魏王不义散瓦岗！"
        },
        {
          "character": "秦琼、徐勣、罗成、程咬金",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "秦琼。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "徐勣。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "罗成。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "程咬金。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "众家兄弟，只因魏王无道，囚禁秦王。三弟巧修本章，将他南牢释放，魏王肆 行不道，只得散了瓦岗，同下山林，各图干功立业。今日天色晴和，弟兄们， 慢慢趱行便了。"
        },
        {
          "character": "徐勣、罗成、程咬金",
          "type": "同白",
          "text": "二哥言之有理。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、徐勣、罗成、程咬金同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、王伯党同上。"
        },
        {
          "character": "王伯党",
          "type": "引子",
          "text": "威镇山岗，豪杰英雄保魏王。"
        },
        {
          "character": "王伯党",
          "type": "念",
          "text": "五湖四海把名扬，方显男儿志量强。帐中领了魏王令，追赶弟兄回山岗。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "俺，王勇字伯党。奉了魏王将令，追赶弟兄回山。 众兵丁！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "赶上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、徐勣、罗成、程咬金同上。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "那旁人马喧嚷，这便怎处？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "想是魏王追兵到来，你我弟兄挡他一阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯党、四上手同上。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "呀，原来众家兄弟，有礼了。大家下马相见。"
        },
        {
          "character": "秦琼、徐勣、罗成、程咬金",
          "type": "同白",
          "text": "好，大家下马相见。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "请问众家弟兄因何不辞而往？"
        },
        {
          "character": "秦琼、徐勣、罗成、程咬金",
          "type": "同白",
          "text": "那昏王无道，我等难以辅保，后会有期。请了！"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "请问众家弟兄，有什么不平之事，对俺王勇说个明白，你们再去未迟。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "好，我们对你说知，贤弟听道。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "兄弟相逢在路旁， 尊一声贤弟听端详： 昏王他把旨来降， 南牢不放小秦王。 石垒坚阵命未丧， 反道我暗地保唐王。 金殿哪容我分讲， 推出午门把我伤。"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "王勇闻言怒气上， 这是昏王理不当。 不念忠臣把国掌， 哪个忠良保朝廊。 回头又对三哥讲， 你今散去为哪桩？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "贤弟。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "六弟不必泪悲伤， 提起心头恨魏王。 只为二哥把本上， 那昏王赶我出朝廊。 他道我与贼同一党， 巧改本章罪难当。 动不动他把死罪降， 谁肯抄手等无常？ 我今回转历城往， 让他一人自称王。"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "先生不把经纶掌， 谁推八卦定阴阳？ 回头我对八弟讲， 你把原由说端详？"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "手挽手儿尊兄长， 小弟言来听心旁。 只为二哥把本上， 反要将我过刀伤。 无奈带了众家将， 回转幽州乐安康。"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "叫声八弟不必忙， 年少英雄各一方。 回头我对咬金讲， 你今缘何散瓦岗？"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "上前尊声六兄长， 小弟略略表几桩： 曾记当初招兵将， 老程三斧取瓦岗。 我今皇帝让他做， 如今逞势坐朝堂。 大家不在心头上， 因此上各自走他的娘！"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "听一言来怒满腔， 指着金殿骂魏王。 且看深山把虎养， 毛衣长足把人伤。 自古国乱思良将， 家贫方显孝儿郎。 低下头来暗思想， 回头尊声众豪强： 李密虽然他无道， 悔不该当初把他降。 依我相劝回山往， 大王降罪我承当，料也无妨。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "贤弟不必多言讲， 愚兄岂肯心不良！ 李密为君少大量， 实实不愿保昏王。 逃笼鹊鸟鱼出网， 历城县还有我亲娘。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "要我转去休妄想， 萤火焉能见太阳？ 李密本是草寇相， 真命天子是唐王。 今日山前别兄往， 去到太原保秦王。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "船到江心补漏难， 马到临崖难收缰。 自古养儿来侍老， 太平积谷保饥荒。 在此拜别六兄长， 小弟归家奉高堂。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "我也不愿奉高堂， 我也不愿回故乡。 我也不愿保唐主， 我也不愿扶魏王。 我今回转历城往， 贩卖竹筢度时光。"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "众位弟兄想一想， 做一个忠良万古扬。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "万古扬来万古扬，"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "哪个忠良有下场！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "任你说的天花样，"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "提起魏王恼心肠！"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "他众人说话都一样， 好叫王勇无主张。 二哥、三哥还乡往， 咬金、罗成归故乡。 单单剩下王伯党， 一人怎比众人强？ 低下头来暗思想， 回头尊声众豪强： 各把前事想一想， 莫做无义小儿郎。 而今若还不思想， 惹动干戈岂寻常？"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "要杀要战齐动手，"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "你有藤牌老子有枪。"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "山前摆下杀人场， 弟兄们今朝来来来战一场。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "一见弟兄动刀枪， 倒叫秦琼着了忙。 要杀就把愚兄斩，"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你来看！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "你家中还有你的伯母娘。"
        },
        {
          "character": "王伯党",
          "type": "西皮导板",
          "text": "山前哭坏王伯党！"
        },
        {
          "character": "王伯党",
          "type": "三叫头",
          "text": "二哥、三哥、八弟呀！我那众兄弟呀！"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "点点珠泪洒胸膛。 手挽手儿尊兄长， 小弟言来听端详： 结义三十九员将， 赛过了桃园刘关张。 到如今各把心来散， 枉费金炉一炷香。 你们一一都去了， 撇下王勇好凄凉！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "六弟要去一路往， 倒不如大家去降唐。"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "我本当与你们一路往， 一臣岂扶二君王？ 山前拜别众兄长！"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "你们跨马下山岗！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "好一个仁义王伯党，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "赛过了当年齐孟尝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣下。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "辞别六哥把马上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "八弟不去也罢！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "他们都去了，留我一人也是枉然。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "悲切切打马下山岗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "众家兄弟下山岗， 铜心肠不合铁心肠！ 舍不得二哥谋略广， 舍不得三哥好阴阳； 舍不得咬金宣化斧， 舍不得八弟回马枪！ 哭断了咽喉枉思想， 好叫王勇无主张。"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "罢呀罢！"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "含悲忍泪把山岗上，"
        },
        {
          "character": "王伯党",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "王伯党",
          "type": "唱",
          "text": "见了魏王说端详。 慢慢商量招兵将， 重兴瓦岗，方显我王勇是个大大的忠良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}