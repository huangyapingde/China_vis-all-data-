{
  "script_id": "05014003",
  "title": "荆襄府",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "刘备、庞统引兵入川，七夕诸葛亮与关羽、张飞在荆州饮宴，诸葛亮见红星陨落，知庞统身故，告众，张飞\n不信。关平持告急书至，果然，众人大惊。诸葛亮乃使张飞先行，并将荆州印交关羽代管，自与赵云引军入\n川，接应刘备。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "蚕眉凤目世无双，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "豹头环眼气轩昂。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "弟兄勇战千员将，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "扶保大哥锦家邦。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室关。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "翼德张！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟请坐。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟，我也曾命四弟过江去请先生，至今未见回报。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "张飞",
          "type": "stage",
          "text": "赵云　　　关羽、"
        },
        {
          "character": "张飞",
          "type": "同白",
          "text": "少礼，请坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "命你去到江夏去请先生，可曾到来？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "现在帐外。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二位千岁在哪里？"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "先生在哪里？"
        },
        {
          "character": "诸葛亮、关羽、张飞",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "不知先生驾到，俺弟兄未曾远迎，先生恕罪！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "岂敢！亮少来问安，千岁恕罪！"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "好说了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "贵帖相招有何见谕？"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "先生有所不知，今当七月七日，众将炼甲之日，请先生前来饮宴，二来请问大 哥之事如何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公么？凶多吉少。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "怎见得？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人算来确是凶多吉少。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "且慢。俺弟兄备得有酒，与先生同饮。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "到此就要叨扰！"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "看酒，待俺弟兄把盏。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不敢，摆下就是。"
        },
        {
          "character": "诸葛亮、关羽、张飞",
          "type": "同白",
          "text": "将宴摆下。"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "荆襄府内摆酒宴，"
        },
        {
          "character": "关羽",
          "type": "回龙",
          "text": "俺与先生饮一番。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "兄王攻打西川县， 有劳先生算根源。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生吓！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "俺弟兄结拜在桃园， 乌牛祭地白马祭天。 俺兄王攻打西川县， 仗先生韬略定中原。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "赵云归降卧牛山， 尊一声先生听根源： 长坂坡前威风显， 保定主公锦江山。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "多蒙千岁摆酒宴， 猛然想起事从前。 我算他落凤坡前身带箭， 他算我拜北斗五丈原命丧黄泉。 猛然提起头来看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮出位，看星落。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "斗大红星殒西南。 袖内八卦暗排算， 庞统先生丧黄泉。 明知假装佯不管："
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮进座。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "停杯不饮卧席前。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想先生往日有百杯之量，今为何倒卧席前？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥，待小弟将他唤醒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟将他唤醒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "师爷醒来。呔！先生醒来！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁，这是为何？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生平日有百杯之量，今日酒未过三巡，菜未过五味，为何倒卧席前？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人看见将星殒落，只恐庞统先生已在落凤坡前带箭身亡了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生，你与庞统有仇？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "无仇。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "有恨?"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "无恨。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "却又来，既无仇恨，为何咒骂与他？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁如若不信，传令下去，人马休撤，酒宴休散，我与千岁饮个落花流水之 间。西川必有人前来报信。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待俺传令。 呔！三军听者：人马休撤，酒宴休散，我与先生饮个落花流水，听杯等候，看 西川有无人来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "蜀中关平到。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下，关平上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待俺老张向前。 关平儿在哪里？"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "三叔父在哪里？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "关平儿，不在西川侍奉你皇伯，来在荆襄做甚？"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "奉了皇伯之命，前来下书。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "书信在哪里？"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "书信在这里。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿过来。随我进来。 见过师爷，见过你父，见过你叔。儿吓，一路之上费了多少辛苦，下面歇息去 吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平下。"
        },
        {
          "character": "张飞",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁为何发笑？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生吓，俺家兄王得了西川，命关平前来下书。接俺弟兄去到西川，同享荣华 富贵，岂不叫俺老张好喜。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "可曾看过书信？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "一定得了西川，看这何来？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "还要看过，香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同拜。"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "先生请看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二千岁请。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟、四弟请看。"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "二哥请看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "还是二千岁请看。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "兄王恕弟不跪之罪了。"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "斩蛇起义汉室传，"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "关平下书到席前。 俺弟兄分手有年半， 今日才得书信还。 对西川施一礼忙拆书笺， 一一从头往下观： 上写拜上多拜上， 拜上师爷虎位前。 拜上三弟和四弟， 再拜二弟关美髯。 愚兄带兵攻西川， 两地交界安营盘。 庞统先生帅印管， 黄忠、魏延先锋官。 凤雏先生带了箭，"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "倒叫俺老张痛心间。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁为何大放悲声？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生有所不知，想庞统先生随俺兄王攻打西川，一日荣华未享，丧命落凤坡， 怎地不叫俺老张好痛、痛、痛吓！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他有何好处？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "他的好处甚多。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "书信未曾看完，你且讲来。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生不嫌，听俺老张道来。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁请讲。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生听道："
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "张松献地理，庞统献连环。黄盖献苦肉，先生烧战船。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "想那庞统先生投汉营以来，俺兄王看他面黄须短，无有什么大才，封他为耒阳 县正堂。想那庞统先生到任以来，每日好酒贪杯不理民事。耒阳县的百姓，做 下了申冤状，告在俺家兄王台前，俺兄王冲冲大怒，就命俺老张同了孙乾，带 领三千人马来到耒阳，查看此事。是俺来到十里接官亭，不见庞统先生迎接于 俺。是俺一马闯到衙前，谁想那庞统先生饮酒未眠和衣而出，俺老张一见，怒 从心头起，恶向胆边生，举鞭就打；不料想庞统先生也是行伍出身，双手抱住 鞭头说：三千岁，因何怒发冲冠？俺老张才将俺兄王旨意取出，庞统先生接旨 看罢，言道：原来一桩小事。三千岁不嫌耳烦，与卑职同审同问，大堂之上设 下两副公案，顷刻击鼓升堂，将那九十九名人犯，一齐带上堂来审问。那庞统 先生果有先见之明，真正是眼观十行字，耳听乱人言，不用茶盏功夫，将那九 十九名人犯，打的打了，罚的罚了。俺老张只当拿来的银钱，买来的百姓。那 时老张回到馆驿，黄昏时候，换了青衣小帽，出离驿馆，查看他虚实。耒阳县 的百姓，三个一群，五个一伙，他们言道，列位吓，列位吓，咱这耒阳县来一 个庞青天庞老爷，断案如神。正是：国正天心顺，官清民自安。俺老张一闻此 言，哈哈哈，大笑而归。回到京都，奏明俺大哥，俺兄王吃惊非小，才知将庞 统先生大材小用了。即刻将他召回京来，封为西台御史，随定俺家兄王攻打西 川。如今命丧落凤坡前，怎不叫俺老张好哭吓！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这书信可曾看完？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "一个人死了，还看它则甚？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "好做准备。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好，看他的结果。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吓先生哪！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "适才观罢书和柬， 不由关某泪涟涟。 抖起绿袍把泪沾， 一一从头往下观： 庞统先生身带箭， 落凤坡前丧黄泉。 愚兄带兵去会战， 不胜张任败回还。 万般出在无计奈， 才命关平把兵搬。 早来三日还相见， 迟来三日见兄难。 看书信哭坏了某的丹凤眼，"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "倒叫俺老张泪不干。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁，主公西川有难，你还是发兵不发兵吓？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生，想俺兄王被困西川，俺老张恨不能身生双翅，飞到西川，焉有不发兵之 理？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁带兵走哪路？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "师爷走哪路？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人走南路。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "被俺老张占了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人走北路。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "又被俺老张占了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "两条路径，俱被三千岁占去，难道说不叫山人发兵不成！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生哪，想你看过西川地理，路径熟知，还望先生指教一二。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告便。 且住，此去西川有七十二座连关大寨，离了此人不能收服，山人自有道理。 三千岁来看，南接江边，北接五岭南水北山中间，有条小路，一人一骑方可过 去。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生，俺老张性情暴躁，水路有些颠三倒四，旱路被俺老张占了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "如此听山人一令："
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "一支将令往下传， 三千岁近前听我言： 山人赐你一令箭， 命你带兵攻西川。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "大帐领了师爷令， 兄王西川等救兵。 三军带过马能行，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三千岁请转。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "师爷呼唤为何情？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此去西川，枪不许挑上将，鞭不准打老军。山人有锦囊一封，带在身旁，为难 之时，打开观看，自有应验。上马去吧，上马去吧。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿过来。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "先生说话真奇巧， 倒叫俺老张解不了。 翻身上了呼雷豹， 乌骓马不住四蹄飘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "二枝将令往下传， 四将军近前听我言： 山人与你一令箭， 命你江下备战船。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "帐中领了一令箭， 命我江下备战船，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "二位将军出宝帐， 再与君侯做商量。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二千岁，主公西川有难，你还是发兵不发兵？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生，兄王被困西川，焉有不发兵之理？但是这荆州无人保守。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二千岁还该在此镇守荆州，倘若东吴兴兵？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "冲锋。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "曹操兴兵？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "对敌。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "两个一齐夹攻？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这个……大丈夫除死方休！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不好了。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "二千岁出言太不祥， 不由山人吃一惊。 联孙拒曹方称我心， 保得荆州如长城。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二千岁镇守荆襄，山人有八个字，牢牢记下：“东和孙权，北敌曹操”。告辞 了。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "在宝帐和君侯拱拱手， 要相逢除非是海水倒流。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "一见师爷出宝帐， 不由关某两泪汪。 某兄王西川打败仗， 并无能将救兄王。 关某有心亲自往， 实实难离这荆襄。 闷恹恹且退连环帐， 但听探马报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}