        {
          "character": null,
          "type": "stage",
          "text": "扈徹上。"
        },
        {
          "character": "扈徹",
          "type": "二黄摇板",
          "text": "闻大王赴长安心惊肉抖， 诚恐怕有命去无命回头。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "参见大王。"
