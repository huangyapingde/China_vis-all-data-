      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陆贾、彭越、二旗牌、四人役同跑上，过场，同跑下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "扈徹领众百姓同跑上，过场，同跑下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫娥、刘邦、吕后同上。"
        },
        {
          "character": "刘邦",
          "type": "西皮原板",
          "text": "灭群雄立汉鼎皇天保佑，"
        },
        {
          "character": "吕后",
          "type": "西皮原板",
          "text": "这也是陛下的洪福当头。"
        },
        {
          "character": "刘邦",
          "type": "西皮原板",
          "text": "但愿得民丰富君民安守，"
        },
        {
          "character": "吕后",
          "type": "西皮原板",
          "text": "愿四海升平日永乐无忧。"
        },
        {
          "character": "刘邦",
          "type": "西皮原板",
          "text": "宫娥女忙摆下佳酿美酒，"
        },
        {
          "character": "吕后",
          "type": "西皮原板",
          "text": "饮一会太平宴鸾侣凤俦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启万岁：今有陆贾陆大人去往大梁，将梁王彭越调来，现在午门候旨。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "起过了。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "啊，陛下调梁王彭越进京何事？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "御妻有所不知，只因大梁太仆前来告变，言道，彭越心有异志。他见你斩了韩 信，终日痛哭，招军买马，恐有反意。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "既然有人告变，赶快将他除之，以免后患。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "金殿之上，众臣之下，恐有辩白，闻之有理，必有保奏之人，恐一时不能除之， 留他恐有后患，奈何奈何？"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "陛下快登殿，臣妾殿后侍听，能除则除，不能除，妾妃自有主意。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "如此，御妻回宫，待孤登殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫娥、吕后同下。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "内侍，击动朝王鼓，敲动景阳钟。待孤登殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦上位，大太监击鼓敲钟。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "宣陆贾上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "万岁有旨，宣陆贾上殿！"
        },
        {
          "character": "陆贾",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆贾上。"
        },
        {
          "character": "陆贾",
          "type": "西皮摇板",
          "text": "上龙楼立玉阶急忙叩首， 奉旨陆贾转回头。"
        },
        {
          "character": "刘邦",
          "type": "西皮摇板",
          "text": "九五尊位开御口， 卿家平身免叩头。 彭越可曾来京走， 卿去之后孤担忧。"
        },
        {
          "character": "陆贾",
          "type": "西皮摇板",
          "text": "臣奉旨意大梁走， 一见彭越甚忧愁， 终日之间他饮酒， 诓他进京是计谋。"
        },
        {
          "character": "刘邦",
          "type": "西皮摇板",
          "text": "卿家才学世少有， 巧言能辩智多谋。 彭越定在午门后， 传旨宣他上龙楼。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "万岁有旨，宣彭越上殿。"
        },
        {
          "character": "彭越",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越上。"
        },
        {
          "character": "彭越",
          "type": "西皮流水板",
          "text": "身在午门等候久， 不见宣召心忧愁。 陆贾胸中难猜透， 怕的是我要例韩侯。 迈步且把玉阶走， 只见汉王坐龙楼。 东华门不见百官走， 西华门不见有王侯。 陆贾金殿侍立候， 威严显赫冷飕飕。 常言道胜者王侯败者寇， 无福遭诛有福之人驾坐龙楼。 白玉阶下忙叩首， 品级台前礼仪周。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "臣彭越见驾，愿陛下万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "下跪可是彭越？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "昔日，孤征战陈豨，调你兵将，你不发兵，违抗旨意，是何道理？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "臣本有病，非敢违抗。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "梁太仆告你谋反，你今还有何说？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "此人不能理事，累次被臣辱骂，因此怀恨，故以诈言诬害，陛下明见万里，当 审其诈，勿为小人所欺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦想。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "谢陛下。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "内侍，将太仆命御史审问，速报孤知。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "候审问明白，你再质对。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "臣遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上，拿帖递刘邦。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏陛下：大梁来了许多百姓，口口声声，要保梁王无损。内有一人，自称大 夫扈徹，劝众百姓不要鼓噪，他还要求见陛下。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "有这等事，宣他们一齐上殿，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "万岁宣大夫扈徹众乡民上殿。"
        },
        {
          "character": "扈徹",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈徹上，众百姓同随上。"
        },
        {
          "character": "扈徹",
          "type": "西皮快流水板",
          "text": "众位父老且退后， 此处不能人自由。 肃静回避休乱走， 让我独自上龙楼。 我见万岁把本奏， 奏明太仆是冤仇。 纵然将我来斩首， 落一个忠义名儿万古留。 列公午门且等候， 撩衣屈膝忙叩头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同下。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "微臣梁大夫扈徹见驾，愿吾皇万岁，万万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "扈徹，你率领众家父老午门鼓噪，难道你不知死吗？"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "臣知死，特来送死。陛下，你今要死，你还不知道呢！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "唗！胆大扈徹，擅敢骂孤王。 内侍，宣刀斧手上殿！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "武士手上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同上。"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "叩见万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "来，将扈徹彭越，绑出午门斩首！"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "扈徹有罪当斩，彭越无罪斩不得。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "怎么，你罪当斩，彭越无罪斩不得？"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "扈徹率领百姓，午门鼓噪，上得金殿与万岁辩白，理当斩首。梁王彭越，他有 何罪，要将他斩首？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "太仆告变，他要谋反。现有告变本章在此为证，理当将他斩首。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "哈哈，原来如此。万岁自创业以来，见了多少战场，难道不知道太仆何等人物， 彭越是何等人也？那太仆见斩了韩信，故此于中取事。梁王彭越，见他不务 正事，责备他几句，也是有的；他恼恨在心，想出这一条离间君臣不和之计， 不辞而别，来京告变。偏偏陛下听他之言，调梁王进京。为臣我，知道梁王乃 忠义之人，必不分辩，刎颈受死，以尽忠心。臣约同大梁父老，苦苦谏劝，梁 王不听我言，他言道：若不奉调，恐万岁兴兵问罪，必动刀兵。好一位仁义的 梁王，他情愿进京一人守戮，不愿叫大梁生灵涂炭，众父老心中不忍梁王遭不 白之冤，无辜身死，故此随来到京。大家言道，能保梁王则保，不能保也可收 梁王尸首。臣此番前来，并非为梁王而来，实实在在为陛下而来！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "为孤王而来？"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "万岁！臣想陛下必听太仆之言，要斩梁王。梁王死后，太仆必然重用。他见万 岁言听计从，今天想想这位大臣待他不好，他也参奏一本，万岁将他斩首；那 一位大臣待他不睦，他也参他一本，万岁也将他斩首。今日要害文，明日要害 武，只怕万岁费了千辛万苦，创来这座锦绣江山，要断送在此人之手！万岁乃 有道明君，请想昔年陛下受困荥阳，若非梁王绝楚粮道，陛下焉有今日？这样 大功之人，听一时无稽之言，遂杀有功之臣，恐天下人人自危也。梁王若有反 意，今日必不肯前来，既来必带重要兵将；他一兵一卒未带，岂不是一个大大 的忠臣？万岁既敬小人，远君子，我也不必多奏。定要将梁王斩首，有大梁百 姓收尸。 武士手，来来来，快将我就在万岁驾前开刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同举刀。"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "杀呀，杀呀！"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "杀不得，杀不得。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "且慢且慢。 彭越，前次孤征战陈豨，托病不行，反状一也；招军买马，其反状二也；见韩 信死痛哭甚哀，每日操练兵将，反状三也。有此三状，叫孤不得不疑，既念前 功，免去官职，废他到西川为民，即日起程。 扈徹听封。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "封你大夫，随朝奉君。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "多谢万岁恩厚，梁王受贬，臣若受官，犬豖不如也。愿放归田里，为臣之意足 矣；官，不敢望也。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "既不愿为官，听其自便。朝事已毕，请驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦、大太监、陆贾同下。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "多承大夫救命之恩。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "大王何出此言。只是赶快着人迎接家小，由别道赴川，京中不可久待。我要同 大梁父老，回转梁地，归里务农去了。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "如此说，你我相会恐无日矣。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "此处不便多谈，各自方便。"
        },
        {
          "character": "彭越",
          "type": "哭",
          "text": "啊大夫啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈徹急。"
        },
        {
          "character": "扈徹",
          "type": "白",
          "text": "大王何必作儿女之态！哎呀，众父老来了，快快挡住他们，快走快走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈徹拉彭越同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四御林军、四宫女、吕后同上。"
        },
        {
          "character": "吕后",
          "type": "西皮原板",
          "text": "我主爷量宽洪世间少有， 叛国臣他不斩惹祸根由。 闻叛乱必须要先除祸首， 既问罪不加刑反成怨仇。 想计策到市上与他争斗， 今必要除后患免后忧愁。 御林军忙摆驾大街来走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四人役抬箱件同上，二从人、彭越骑马同上，四御林军同两边挡。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "吕娘娘凤驾在此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越下马。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "待我参见凤驾。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "梁王彭越要参见娘娘。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "宣他上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。彭越、吕后对亮相。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "你你你，你……"
        },
        {
          "character": "吕后",
          "type": "西皮摇板",
          "text": "是何人挡凤驾定斩不留。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越跪。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "你是甚等样人敢在御街之上，挡住哀家道路，你的目中还有王法？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "臣梁王彭越。万岁将我贬去西川为民奉旨起程，不敢稍停；行路甚急，故此闯 了娘娘御道，罪该万死。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "呵，原来是你。彭越，削职西川为民，你犯了甚罪？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "臣本无罪，万岁贬我为民，娘娘详查。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "如此说来，是万岁冤屈你了？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "本来冤屈臣了。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "随行带的都是甚样物件？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "行囊衣物。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "查看查看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同查箱件。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "内有兵器多件。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "起过了。 彭越，你既为庶民，带许多兵器何用？"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "臣乃自备防身。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "哦，原来自备防身。"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "快走啊，快走啊！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "啊，看看来的都是甚等样人，不要叫他们近前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同允。众百姓衣内藏兵刃同上。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "来人少往前进，要检查行人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同搜。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "启娘娘：每人都暗藏许多兵刃，请娘娘定夺。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "将兵器取下，唤他等近前回话。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "你们众人近前回话。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "叩见娘娘。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "唗！你们俱是甚等样人，带此兵刃，心想如何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同看彭越。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "我们都是好百姓，带此兵刃，要保梁王平安出京，走错了路，遇见了娘娘。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "要保梁王平安出京？你等俱是忠义之人，各自回去，哀家替这位梁王鸣冤。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "谢娘娘，这下就好了哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同下。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "你真正是冤枉，都感动民心，随我去见万岁，以解前罪。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "谢娘娘。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场，到宫门。四人役、二从人同下。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "在此候旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫娥、吕后同进内。"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "圣旨下跪！"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "宣读诏曰：梁王彭越，心怀异志，孤念前功贬为庶民。今擅闯娘娘御道，勾引 匪徒，暗藏利刃，行刺孤王。罪不容诛。就在宫门枭首示众。斩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同斩彭越。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "奏与万岁知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}