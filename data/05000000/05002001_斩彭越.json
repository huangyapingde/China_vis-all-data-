{
  "script_id": "05002001",
  "title": "斩彭越",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "彭越",
      "hangdang": "净"
    },
    {
      "name": "扈徹",
      "hangdang": "老生"
    },
    {
      "name": "刘邦",
      "hangdang": "老生"
    },
    {
      "name": "吕后",
      "hangdang": "旦"
    }
  ],
  "plot": "彭越闻韩信被斩，气冲牛斗，破口大骂。太仆戒其小心，彭越反将太仆逐走。太仆受辱，至长安向刘邦告密，\n谓彭越招兵买马，有意谋反，近闻韩信身亡，又痛哭流涕，早晚必将发兵反汉。刘邦因使陆贾往大梁召彭\n越入京对质。彭越为辩明冤屈，即欲起程。扈徹劝勿前往，应以韩信为鉴。彭越心疑，陆贾保其无事，彭越\n乃决心入京。扈徹倒悬城楼之上，再对彭越苦谏。彭越亦知此去凶多吉少，但恐连累众乡民，仍决心前往。\n扈徹遂邀众乡民备马随同入京。彭越向刘邦陈明太仆因受辱骂，有意陷害。刘邦命将太仆交付御史审问。内\n侍报称扈徹聚众鼓噪，刘邦即宣扈徹一行上殿。扈徹口出不逊之言，刘邦令与彭越同处斩。扈徹慷慨陈辞，\n刘邦以其言之有理，乃将彭越削职为民，而封扈徹为大夫。扈徹辞官，拜别彭越回乡。吕后闻刘邦已赦彭越，\n定计诱之入宫，诬其有意行刺，遂斩之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "奉命探军情，戴月与披星。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "俺，梁王驾前探子是也。今有汉王征战陈豨，吕娘娘同萧何丞相宣淮阴侯韩信 进宫，说他谋反，斩首未央宫。就此报与梁王知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌、彭越同上。"
        },
        {
          "character": "彭越",
          "type": "引子",
          "text": "开国元勋立功劳，成一统，军民逍遥。"
        },
        {
          "character": "彭越",
          "type": "念",
          "text": "汉楚相争在疆场，汉主被困在荥阳。若非断绝楚粮饷，怎得疆土属汉王。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "本爵彭越。自保汉王以来，立了许多功劳。今成一统，封我梁王之位，镇守大 梁。只因陈豨兴兵反汉，汉王有旨意前来，命我前去助阵；我并未发兵。这几 日心神恍惚，坐卧不安，不知何故心中烦闷。 来！"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "看酒来。"
        },
        {
          "character": "彭越",
          "type": "二黄摇板",
          "text": "这几日自觉得精神少有， 坐不安卧不宁愁锁眉头。 叫人来备佳酿开怀饮酒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越上位。"
        },
        {
          "character": "彭越",
          "type": "二黄原板",
          "text": "思一思想一想酒难下喉。 我自从保汉王功名成就， 到如今封王位名扬九州。 一霎时酒下肚精神抖擞， 今日里必定要一醉方休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太仆上。"
        },
        {
          "character": "太仆",
          "type": "二黄摇板",
          "text": "进二堂见王爷恭敬问候， 见梁王独自饮无尽无休。 将身儿站阶前旁观袖手，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越看。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "彭越",
          "type": "唱",
          "text": "是何人大模样礼貌不周。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "唔，何人到此？"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "小官在此。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "唔，既然是你到此，为何不进来相见？立在阶前，这算何意？"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "我观王爷在此，独自饮酒，未敢自进，故此立在笘下候宣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越笑。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "哼哼。来来来。你陪饮几杯如何？"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "小官不敢放肆。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "哼！既不陪饮，站立一旁，看我自饮。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "门上哪位在？"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "王爷可在堂上？"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "王爷现在二堂饮酒。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "烦劳通稟，京中探子求见。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "候着。 启王爷，京中探子求见。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "王爷传见。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "是。 叩见王爷。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "罢了。你探听何事？速报我知。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "启王爷：今有吕娘娘三宣淮阴侯韩信，斩首未央宫！"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "斩首未央宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越惊急，探子下。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "哇呀呀！"
        },
        {
          "character": "彭越",
          "type": "二黄摇板",
          "text": "听韩信斩未央气冲斗牛， 他本是大功臣才封王侯。 灭秦楚多亏他心血用透， 可怜他大英雄不能自谋。 恨汉王成基业全不念旧，"
        },
        {
          "character": "彭越",
          "type": "哭头",
          "text": "韩侯啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太仆笑，彭越气。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "彭越",
          "type": "二黄摇板",
          "text": "我心急你含笑是何根由？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越抓太仆打。"
        },
        {
          "character": "彭越",
          "type": "二黄摇板",
          "text": "我看你披衣冠不如禽兽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越打，走圆场。"
        },
        {
          "character": "彭越",
          "type": "二黄摇板",
          "text": "我今日打死你方称心头。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "王爷呀！"
        },
        {
          "character": "太仆",
          "type": "二黄摇板",
          "text": "劝王爷请息怒快快松手， 听小官把此事细说从头。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "主爷息怒，听小官一言禀告。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "你且讲来。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "启王爷：吕娘娘将韩侯斩首未央宫，她心中一定怀疑，恐怕有韩侯心腹之人， 替他报仇，必要差人各路打听。如今王爷闻韩侯凶信，如此痛哭，被暗访之人， 报与汉王，岂不是自取其祸！小人一时不及出言，故此含笑出声，死罪呀， 死罪！"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "胡说！我同韩信久战疆场，他今已死，怎不叫我心痛！"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "不是噢，恐被汉王知道你要惹火烧身。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "今日此处，只有你我。要遗祸者，必然是你。从此休要胡言，快快滚了出去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越踢太仆出门，太仆冷笑下。"
        },
        {
          "character": "彭越",
          "type": "念",
          "text": "汗马功臣无后首，负屈含冤名不朽。"
        },
        {
          "character": "彭越",
          "type": "白",
          "text": "韩侯啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭越下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。太仆上。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "咳，世界上就有这不知好歹之人。我真正良言劝他不要招祸，他反将我踢出二 堂。这场羞辱，岂能白白干休！想我虽在大梁，本与彭越同为汉臣，他累次辱 我；况我又无家小，不若去长安告变，使他王爵不能自保，彭越呀彭越！"
        },
        {
          "character": "太仆",
          "type": "念",
          "text": "岂知暴虐难长久，暗算无常你死后羞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太仆下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈平、张苍同上。"
        },
        {
          "character": "陈平",
          "type": "念",
          "text": "江山还依旧，"
        },
        {
          "character": "张苍",
          "type": "念",
          "text": "人生转几回。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "下官陈平。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "下官张苍。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "如今汉成一统，共享太平天年。今当早朝，吾主升殿，一同朝房伺候。"
        },
        {
          "character": "张苍",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平、张苍同走圆场，陆贾上。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "二位大人请了。"
        },
        {
          "character": "陈平、张苍",
          "type": "同白",
          "text": "陆大人请了。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "二位大人上朝甚早。"
        },
        {
          "character": "陈平、张苍",
          "type": "同白",
          "text": "陆大人早。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "适才行至御街，偶遇一人，言谈了几句言语，故而来迟了。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "但不知遇见了什么人？"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "遇见了大梁太仆，他言道有机密大事，来禀汉王。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "既如此，此人今在何处？何不请来，等王升殿，一同启奏。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "此人现在午门。如此说来，下官将他请来相见。 有请太仆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太仆上。"
        },
        {
          "character": "太仆",
          "type": "念",
          "text": "寒天饮冷水，点点在心头。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "参见列位大人。"
        },
        {
          "character": "陈平、张苍",
          "type": "同白",
          "text": "罢了。方才听陆大人言道，你有机密大事，特来启奏。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "看东方已晓，吾主升殿，你我分班伺候。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "香烟缭绕，圣驾临朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹打、四小太监、大太监引刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "引",
          "text": "笙歌齐亮乐无疆，军与民共同安享。"
        },
        {
          "character": "陈平、张苍、陆贾、太仆",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "陈平、张苍、陆贾、太仆",
          "type": "同白",
          "text": "谢万岁。"
        },
        {
          "character": "刘邦",
          "type": "念",
          "text": "手提宝剑闯江山，灭秦破楚鬼神寒。万里山河孤掌管，创业容易守业难。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤，刘邦字季。自沛、丰起义以来，灭秦破楚，如今得成江山一统。今当早朝。 众卿，有本早奏，无本退朝。"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "启奏万岁：今有大梁太仆回朝，有机密事启奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦看太仆。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "卿家归班。 太仆回朝，有何机密事，快快当殿奏来。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "容臣启奏：万岁，臣奉旨事梁王彭越，累见梁王有不良之意。见他招集军马， 恐以梁地谋反，其反状一也。前日陛下征陈豨，征兵协助，彼又托病不来，其 反状二也。昨闻韩信已死，十分痛哭，就欲整率三军，早晚发行，其反状三也。 臣本陛下之臣子，见彼谋反，特来告变！"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "可是你亲眼得见之事？不可谎奏。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "臣不敢谎奏。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "归班。"
        },
        {
          "character": "太仆",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "彭越，孤王并未负他，今既如此行为，众卿计将安出？"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "臣启万岁：彭越见诛了韩信，所以谋反。今可差一妥当之人，奉命宣召。如来， 则无反志，但废置可也；如不来，则谋反必矣。然后遣兵征讨，则师出有名。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "就依卿奏。 陆贾，赐你圣旨一道，前赴大梁，召彭越来京，不得有误！"
        },
        {
          "character": "陆贾",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆贾下。"
        },
        {
          "character": "刘邦",
          "type": "白",
