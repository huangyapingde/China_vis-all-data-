{
  "script_id": "05024002",
  "title": "虎牢关",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "吕布",
      "hangdang": "小生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    }
  ],
  "plot": "张飞与袁术打赌，表示一定要生擒吕布。刘备怕张飞有失，漏夜与关羽相商助战之策。次日，张飞、吕布交\n战，张飞果败。刘备、关羽遂与张飞结成三马连环，同战吕布。吕布不敌，被挑下紫金冠，败入虎牢关内。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小军、四下手同上，吕布上，起霸。"
        },
        {
          "character": "吕布",
          "type": "念",
          "text": "少小英雄镇虎牢，狐群鼠辈怎脱逃。咚咚画鼓催军进，指日奏凯转还朝。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "某温侯吕布。为因前部先锋华雄，被云长斩首，相父大怒，命俺统领人马，挡 住虎牢关。相父大兵随后接应，共灭烽烟。正是："
        },
        {
          "character": "吕布",
          "type": "念",
          "text": "推关龙马勒锦辔，试看一战表凌烟。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "呔，众将官，兵发虎牢关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "文堂掌灯上。"
        },
        {
          "character": "刘备",
          "type": "内白",
          "text": "掌灯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "夜静更深意阑珊， 满天星斗露生寒。 悲风瑟瑟明月满， 一声孤雁好凄然。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "某刘备。剿灭黄巾有功，特授平原县令。可恨董卓专权，因此同公孙将军前来 讨贼，苍天呵苍天，可念炎汉纪统，早灭乱贼，肃清朝野，万民乐业，某之愿 也。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "汉室华夷渐倾颓使人感叹， 怎能够诛叛臣国泰民安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。关羽上。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "听大哥在月下长吁短叹， 想必是为董卓扰乱江山。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谢坐。大哥为何长叹？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咳，二弟有所不知，只因三弟与袁术打赌，明日生擒吕布，倘若败下阵来，如 何是好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不妨，且等天明，我二人助他成功便了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟言之有理。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "异姓同胞共患难，"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "唯愿得胜建功还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。张飞上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "人情势利古今同，几个男儿是英雄。安得快人如翼德，要为汉室尽精忠。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "可笑袁术与俺打赌，明日生擒吕布。咳，你看咱的丈八矛在那里瞪眉弄眼，待 俺磨洗磨洗。枪呵枪，你明日见了吕布，这么一枪，将那厮挑下马来，咱封你 枪中王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "天色尚早，待老张打个盹儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。关羽、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "岭岩鼓角三更尽，"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "夜宿貔貅百万兵。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来此已是三弟营盘，听他说些什么。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞醒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "天呵，你是怎的不明，鸡，你是怎的不叫？呵，是了，想是吕布死期未到，待 我再打个盹儿。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "听三弟之言，战心太甚。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "待弟将他唤醒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不消，且待天明，我二人助他一臂之力。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有理。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽同下。〖起五更鼓〗。鸡叫。张飞醒，笑。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好了，天色明了，鸡也叫了，想是吕布死期到了，俺老张跨马快走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，吕布小儿出关受死。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "开关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞杀吕布同下，吕布上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "呔，方才关前来一黑汉，十分骁勇，他再追来，用花枪挑他下马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布杀，张飞败下，吕布追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽同上，两边望。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟大战吕布，唯恐有失，你我催马助阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。张飞上。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "三弟。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三弟还是四弟。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "桃园。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "还是杏园！"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "你与吕布交战，谁胜谁负？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我在前面走，这个娘养的在后面好追呵！"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "敢是败了？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呵，不错，是败了败了！"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "你与袁术打赌一事，难道就忘了？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀大哥二哥，看桃园份上，帮兄弟才好。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "也罢，你我三人，一马上，三马上，一马下，三马下。扣定连环，大战吕布便 了。"
        },
        {
          "character": "刘备、张飞",
          "type": "同白",
          "text": "有理。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥二哥随兄弟这里来。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "三弟到了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈哈哈，好彩头。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "什么彩头？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "到取虎牢关，随兄弟这里来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "到了关前，大哥二哥前去叫关。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "三弟前去叫关。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我去叫关？"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "你去叫关。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀，这个王八厉害！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞望。"
        },
        {
          "character": "关羽",
          "type": "同白",
          "text": "呔，为何不高声？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "高声他不出来了？"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "原要他出来。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥二哥呵！"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "这作什么？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "桃园要紧。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "太小心了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，吕布小儿开关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布上。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "开关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布杀。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "我当是谁，原来是败将。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，你管我老子败不败，我老子又来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布杀，张飞败下。刘备对锏，败下，关羽对刀，败下，张飞上，对抢。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "杀了半日，未曾问你贼名姓。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吕布我的儿，你问你老子名姓，咱姓张名飞，字翼德，自破黄巾以来，众诸侯 闻名皆怕，吕布我的儿，你是怕不怕？"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "张翼德威名谁不晓， 今日擒你献功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、吕布对枪，小钻盘。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吕布敢是怯战？"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "非是老爷怯战，敢与老爷下马赌力？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "三弟，吕布下马，靴尖着地，有九牛二虎之力。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吕布我的儿，你下得马来，有九牛二虎之力，咱老子下得马来，有七象八骆驼 之力。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "张飞，你认得你老爷？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺认得你，你是四姓家奴。"
        },
        {
          "character": "刘备、关羽",
          "type": "同白",
          "text": "三弟，他只有三姓。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呵，大哥二哥，有所不知，他本姓吕，投与丁建阳，杀了丁建阳，投与董卓， 俺弟兄灭了董卓，归了桃园，岂不是四姓！"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "好匹夫！"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "一言怒发三千丈， 胆大匹夫把我伤。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看刀。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "泗水关斩了华雄将， 无名小辈敢逞强。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "看锏！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "董卓残暴把君抗， 重整汉室诛奸党。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "儿呵！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "四姓家奴休妄想， 免得臭名万载扬。"
        },
        {
          "character": "吕布",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "吕布",
          "type": "唱",
          "text": "出兵会过多少将， 三马连环怎能挡？ 出此一枪走了罢，"
        },
        {
          "character": "关羽、张飞、刘备",
          "type": "同唱",
          "text": "虎穴龙潭战一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕布败下，关羽、张飞、刘备同追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四文堂、公孙瓒同上。〖滴溜子〗。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "俺公孙瓒。今有桃园大战吕布，唯恐有失，带领本部三千人马，前去助战。 众将，杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。四小军、四下手、李肃同上。"
        },
        {
          "character": "李肃",
          "type": "白",
          "text": "俺李肃。奉太师之命，大战桃园，杀上前去。 （四上手、四文堂、公孙瓒同上，同杀，李肃败下，众人同打下。打钻盘，李肃败下。吕布引刘备、关羽、 张飞同上，同杀，吕布败进关，张飞挑吕布紫金冠。公孙瓒上。）"
        },
        {
          "character": "张飞",
          "type": "白",
