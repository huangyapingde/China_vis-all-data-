        },
        {
          "character": "伍奢",
          "type": "唱",
          "text": "生死就在这一回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍奢下。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "命何人前去下书？"
