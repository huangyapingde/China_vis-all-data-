{
  "script_id": "05003002",
  "title": "楚宫恨",
  "alias": [],
  "source": "《传统剧目汇编》",
  "characters": [
    {
      "name": "伍奢",
      "hangdang": "老生"
    },
    {
      "name": "楚平王",
      "hangdang": "净"
    },
    {
      "name": "费无极",
      "hangdang": "丑"
    },
    {
      "name": "吴祥公主",
      "hangdang": "旦"
    },
    {
      "name": "马昭仪",
      "hangdang": "旦"
    }
  ],
  "plot": "楚国费无极奉命至秦，迎娶吴祥公主，见公主容貌绝艳，怂恿楚平王纳之，另将秦宫女马昭仪配与太子建。\n太子建哭诉于伍奢。伍奢入宫苦谏，怒打费无极。费无极谗之于楚平王，楚平王怒，欲斩伍奢。费无极请先\n令伍奢修书召其二子、伍员、伍尚入朝，一网打尽，以免后患。伍奢心知是计，仍写家书召二子。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。院子随上。"
        },
        {
          "character": "伍员",
          "type": "引子",
          "text": "奋飞青云，要把凌云扫。经文纬武习六韬，侍君亲惟臣忠孝。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "春城无处不飞花，野外轻烟傍日斜。紫雾祥光映宝殿，朝朝相侍帝王家。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "下官伍员，有举鼎之力，临潼会上斗宝，秦穆公见势不好，将吴祥公主许配我 国太子为婚。君臣在他国耀彩而归。今乃爹娘寿诞，樽开北海。 来，请大老爷。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请大老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚上。"
        },
        {
          "character": "伍尚",
          "type": "念",
          "text": "恭献南山寿，筵开北海樽。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长见礼。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "还礼，请坐。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟，今乃爹娘寿诞之期，酒宴可曾齐备？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "一同请上爹娘。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "孩儿有请爹娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍奢、伍母同上。"
        },
        {
          "character": "伍奢、伍母",
          "type": "同念",
          "text": "华堂开喜色，绣阁耀光辉。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "孩儿拜揖。"
        },
        {
          "character": "伍奢、伍母",
          "type": "同白",
          "text": "儿啦，堂上灯烛辉煌，敢是为我二老的生辰？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "正是。待孩儿拜寿，然后把盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "爹娘请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖园林好〗。伍尚、伍员同拜。"
        },
        {
          "character": "伍母",
          "type": "白",
          "text": "相国，朝中奸佞当道，何不上殿谏奏一本？"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "夫人，老夫岂不知？怎奈平王不纳忠言，也是枉然。"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "圣旨下。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "将宴撤过，夫人退下。香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。伍母下。大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "圣旨下，跪听宣读。诏曰：孤见伍员，文能治国，武能安邦，临潼斗宝有功， 封为飞卫将军。樊城乃咽喉之地，命伍员弟兄前去镇守，不可擅离汛地。旨意 读罢，谢恩。"
        },
        {
          "character": "伍奢、伍尚、伍员",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "有劳大人捧旨前来。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "岂敢。二将军，圣旨到来，即日就要出京。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "那是自然。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "后堂留宴。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "王命在身，要上殿交旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。伍母上。"
        },
        {
          "character": "伍母",
          "type": "白",
          "text": "相国，圣旨到来何事？"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "圣上命伍尚、伍员镇守樊城。无旨不可擅离汛地。"
        },
        {
          "character": "伍母",
          "type": "白",
          "text": "几日起程？"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "即日起程。"
        },
        {
          "character": "伍母",
          "type": "白",
          "text": "后堂摆宴，与我儿饯行。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "多谢爹娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍奢、伍母、伍尚、伍员同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "费无极上。四下手同上。"
        },
        {
          "character": "费无极",
          "type": "引子",
          "text": "位列三台，见君王，喜笑颜开。"
        },
        {
          "character": "费无极",
          "type": "念",
          "text": "昔日青灯老读书，八斗才高学五车。藏定六韬与三略，平王驾前作大夫。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "下臣费无极。平王驾前为臣，官拜下大夫之职。今日早朝，理当上殿奉君。来， 开道上朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。费无极、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍奢、费无极、申包胥、伍成黑同上。"
        },
        {
          "character": "伍奢",
          "type": "念",
          "text": "朝臣待漏五更寒，"
        },
        {
          "character": "费无极",
          "type": "念",
          "text": "月朗星稀上绣栏。"
        },
        {
          "character": "申包胥",
          "type": "念",
          "text": "金钟三响文武至，"
        },
        {
          "character": "伍成黑",
          "type": "念",
          "text": "扬尘舞蹈把君参。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "老夫相国伍奢。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "下官费无极。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "下官申包胥。"
        },
        {
          "character": "伍成黑",
          "type": "白",
          "text": "下官伍成黑。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "请了。主公登殿，分班伺候。"
        },
        {
          "character": "伍奢、费无极、申包胥、伍成黑",
          "type": "同白",
          "text": "香烟霭霭，圣驾临朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四太监、楚平王同上。"
        },
        {
          "character": "楚平王",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "楚平王",
          "type": "念",
          "text": "金殿祥光紫雾开，深宫步出帝王来。金钟三响群臣至，文东武西拜金阶。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "孤熊朱，国号平王。自先王驾崩，传位与孤。登基以来，仰承天运，干戈尽息， 真乃孤之洪福也。今当早朝，众卿有本早奏，无本退班。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "臣伍奢有本启奏。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "当殿奏来。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "主公，昔日临潼赴会，弹压各路诸侯。秦穆公曾将吴祥公主，许配我国太子为 婚。今太子年已弱冠，主公可遣使臣，往秦国迎亲，与太子完婚。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "奏之有理。 费大夫，命你速备花红彩缎，往秦国迎亲，与太子完婚。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "申包胥，命你往齐国催贡，即日起程。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "申包胥",
          "type": "念",
          "text": "若得君王宠，全家享安康。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "申包胥下。"
        },
        {
          "character": "伍奢、费无极、伍成黑",
          "type": "同白",
          "text": "请驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、申包胥同上。"
        },
        {
          "character": "申包胥",
          "type": "念",
          "text": "奉了君王命，催贡到边庭。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "下官申包胥，奉了平王旨意，往各国催贡。 众将，吩咐起马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "申包胥、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四秦臣、四下手、吴祥公主、马昭仪同上。费无极上。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "来此两国交界之地，不劳远送，大人请回去罢。"
        },
        {
          "character": "四秦臣",
          "type": "同白",
          "text": "无有娘娘旨意，我等不敢。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "宫人通禀娘娘，来此两国交界，众文武在此送驾。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "来此两国交界，众文武在此送驾。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "既是两国交界之地，不必远送，吩咐他们回去罢。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "娘娘有旨：此处已是两国交界之地，不必远送，吩咐回去。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "众位大人，娘娘传旨，既是交界之地请大人回去罢。"
        },
        {
          "character": "四秦臣",
          "type": "同白",
          "text": "如此少送了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四秦臣同下。驿官上。"
        },
        {
          "character": "驿官",
          "type": "白",
          "text": "驿官接驾。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "什么驿官？"
        },
        {
          "character": "驿官",
          "type": "白",
          "text": "安城驿。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "公主在此安歇，小心伺候。"
        },
        {
          "character": "驿官",
          "type": "白",
          "text": "知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驿官下。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "众人下面伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同下。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "宣楚国使臣。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "娘娘有旨：宣楚国使臣。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "领旨。 费无极见驾，娘娘千岁。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "你在楚国官居何职？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "下大夫。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "娘娘到了你国，自有赏赐与你。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "谢千岁，请娘娘后面歇息。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "小心伺候。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "吴祥公主",
          "type": "念",
          "text": "离别家乡远，思想泪暗弹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴祥公主、马昭仪同下。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "细观吴祥公主，天姿国色，真乃天宫美人下凡也。"
        },
        {
          "character": "费无极",
          "type": "唱",
          "text": "细观公主娇容貌， 亚赛嫦娥下九霄。 绝色佳人世间少， 巧手丹青难画描。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "且住。我想平王，素日最喜风花雪月，不免将吴祥公主与平王，那时下官呵！"
        },
        {
          "character": "费无极",
          "type": "唱",
          "text": "头上乌纱换金貂， 身上另换紫罗袍。 一品当朝荣耀显， 君王宠信压群僚。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "此计倒好。若是问起，如何对答？有了。那陪驾的宫人，倒也生得俊俏。不免 将金顶轿，改换银顶轿，做一个草内藏珍，就是神仙也难知道。不免唤宫人出 来，商议明白。 宫人走来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马昭仪上"
        },
        {
          "character": "马昭仪",
          "type": "念",
          "text": "心中常思想，记念故乡情。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "宫人叩头。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "起来。娘娘可曾安歇？"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "娘娘早已安歇了。大人呼唤，有何吩咐？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "我见你容貌端正，非同宫人体相，家住哪里？姓甚名谁？一一讲来。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "大人容禀："
        },
        {
          "character": "马昭仪",
          "type": "唱",
          "text": "宫人家住齐国马家敖， 随父上任到秦朝。 父讳马融官显耀， 爵受公卿掌群僚。 只因爹娘亡故早， 丢下青春女鸾娇。 秦王见我无倚靠， 选进宫去伴多姣。 秦楚联姻陪驾到， 因此千里相送不辞劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费无极笑。"
