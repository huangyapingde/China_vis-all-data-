        },
        {
          "character": "鄢将师",
          "type": "念",
          "text": "忽听万岁宣，迈步上金殿。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "鄢将师见驾，愿主千岁。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "孤家有书信一封，命你往樊城诏伍尚兄弟进京，须要一路同来。"
