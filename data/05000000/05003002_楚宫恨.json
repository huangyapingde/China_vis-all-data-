    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "吴祥公主上。"
        },
        {
          "character": "吴祥公主",
          "type": "引子",
          "text": "日色西沉，叫人愁喜难分。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "奴乃吴祥公主。兄王将奴许配楚国太子为婚。自离秦邦，已有二十余日，方到 郢都。适才金殿朝参，只见平王眉来眼去，不像公媳体态。霎时陪伴宫人不见， 既与太子匹配，为何将奴迎入西宫？天色已晚，不见动静。叫人好难解也！"
        },
        {
          "character": "吴祥公主",
          "type": "唱",
          "text": "日晚黄昏烛映阶， 东方月上粉墙来。 吴祥公主愁眉黛， 心中沉吟自疑猜。 秦国既结亲罗带， 就该与太子配和谐。 适才金殿礼朝拜， 只见平王笑满怀。 陪驾宫人今何在， 独坐宫人无人来。 袖内机关人难解， 青鸾黄雁信音乖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、楚平王同上。"
        },
        {
          "character": "楚平王",
          "type": "唱",
          "text": "春日融和三阳泰， 香车俊俏美人来。 孤王魂飞天涯外， 一片机关喜在怀。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "儿媳见驾，父王千岁。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "梓童平身。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "啊！自古道，堂上公公，不见儿媳之面，父王为何梓童相称？非人伦之道。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "其中有个原故。你且坐下，听孤讲来。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "父王在此，焉有儿媳的座位？"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "赐坐便坐，不必过谦。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "谢父王。我兄王将我许配太子为婚，父王为何如此相称？"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "今日乃良辰吉日，看宴与梓童交杯合卺。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "且慢。启父王：我兄在临潼会上将奴许配太子为婚，天下皆知。今若与父王苟 合，岂不怕诸侯议论，太子嗟怨。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "梓童放心。孤王已将陪驾齐女，赐与太子为婚，孤封为昭仪贵妃，当殿完婚， 众诸侯谁敢议论。"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "啊，陪驾齐女，已与太子匹配了！贱人哪，贱人！仆占主婚，败天灭伦，怎的 不气死我也！"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "梓童醒来。"
        },
        {
          "character": "吴祥公主",
          "type": "西皮导板",
          "text": "听一言来魂不在，"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "梓童！"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "喂呀……"
        },
        {
          "character": "吴祥公主",
          "type": "唱",
          "text": "心中阵阵似刀裁。 小贱人她把伦常坏， 仆占主婚大不该。 秦国何等将你待？ 胜似同娘共母胎。 实指望琴瑟多欢爱， 谁知对面不和谐。 恨贱人把奴牙咬坏， 点点珠泪洒胸怀。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "梓童跪上来听封。"
        },
        {
          "character": "吴祥公主",
          "type": "唱",
          "text": "你白发休想鲜花戴， 芙蓉昼开夜不开。 我青春岂配年老迈？ 乌鸦怎与凤同偕？ 思来想去无可奈，"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "吴祥公主",
          "type": "唱",
          "text": "倒不如一死免挂怀。"
        },
        {
          "character": "楚平王",
          "type": "唱",
          "text": "梓童不必泪满腮， 且听孤王说明白。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "梓童不必悲伤。你嫌孤老了，岂不闻昔日纣王宠妲己，幽王宠褒姒，桀王宠妺 喜，皆是年迈之君。何况孤家尚未五旬，何以为老？况且你兄王与孤也是一国 之主，难道还玷辱与你？你若顺从孤，孤王将你封为昭阳正宫，与孤同掌山河。 日后太子登基，现成的国母，有何不美？你何不再思再想，孤还不老，哈哈……"
        },
        {
          "character": "吴祥公主",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "吴祥公主",
          "type": "唱",
          "text": "闻言愁眉面上带， 背转身来暗自猜。 如不与他同欢爱， 一颗宝珠土内埋。 马行夹道无可奈， 事到头来少计算。 无奈何且将愁眉改， 含羞带愧跪尘埃。"
        },
        {
          "character": "楚平王",
          "type": "唱",
          "text": "一见梓童愁眉解， 不由孤王喜心怀。 封你昭阳为正院， 君妃同欢楚阳台。"
        },
        {
          "character": "吴祥公主",
          "type": "唱",
          "text": "谢过大王恩似海， 情愿巫山伴楚台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲上。"
        },
        {
          "character": "太监甲",
          "type": "白",
