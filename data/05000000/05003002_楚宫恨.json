        {
          "character": "费无极",
          "type": "白",
          "text": "臣有一心腹之将，可以前去。"
        },
        {
          "character": "楚平王",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "领旨。 主公有旨：宣鄢将师上殿。"
        },
        {
          "character": null,
          "type": "stage",
