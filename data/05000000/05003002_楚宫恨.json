    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍奢上。"
        },
        {
          "character": "伍奢",
          "type": "念",
          "text": "紫绶金章立庙廊，披肝沥胆扶平王。怀抱一道无情本，削除奸佞整朝纲。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "老夫相国伍奢。平王驾前为臣，官居首相。昨晚太子建私出宫庭，亲到我府哭 诉实情，言道平王将吴祥公主纳为西宫，陪驾齐女，赐与太子当殿完婚，掩我 国文武诸侯之耳目。我想此事，一定是奸贼费无极之谋，因此连夜修下本章， 候大王临朝谏奏。正是："
        },
        {
          "character": "伍奢",
          "type": "念",
          "text": "嫩草怕霜霜怕日，恶人自有正人磨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费无极上。"
        },
        {
          "character": "费无极",
          "type": "念",
          "text": "丝纶阁下文章静，钟鼓楼前时刻长。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "原来是相国，学生拜揖。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "啊，原来是费大人。今日上朝，为何甚早？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "蒙圣恩加升相位。有谢恩本章，故而甚早。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "有道：无功不受禄！"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "受禄必有功！"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "我见你并无寸进之功，为何加升相位？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "老相国说哪里话来，下官奉旨秦国迎亲，主上见我远路风霜，鞍马劳顿，故而 加升相位，怎道无功？"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "这迎亲乃吾儿子胥之事，何足言功？这也罢了。我且问你，吴祥公主许与何人？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "太子建。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "既许太子建，就该完其花烛。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "老相国，难道你不知道，前日鸾轿一到，已在金殿与太子完婚过了。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "怎么讲？"
