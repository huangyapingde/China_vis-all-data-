        {
          "character": "费无极",
          "type": "白",
          "text": "小姐年已长成，尚未婚配。下官有意与你作伐，你意如何？"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "蒙大人美意，不知哪一家？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "就是我国太子建。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "大人说哪里话来，楚国太子，现聘公主为婚，何出此言？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "小姐不知。吴祥公主实系平王所聘，犹恐秦王嫌平王年迈，故而假称太子迎亲， 掩人之耳目。吴祥公主，是平王之妻。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "既如此，必须要奏知公主娘娘。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "小姐若奏知公主娘娘，此事就不能成了。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "我与公主寸步不离，若与太子匹配，必然各居一宫，公主问起，将何言答对？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "小姐放心，若是公主娘娘问起，都推在下官身上便了。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "既如此，大人请上，受奴一拜。"
        },
        {
          "character": "马昭仪",
          "type": "唱",
          "text": "喜盈盈屈膝忙跪倒， 有劳大人天地恩高。 若得成全夫妻妙， 结草衔环报恩劳。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "小姐转来。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "大人何事？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "此事只有天知地知，你知我知。"
        },
        {
          "character": "马昭仪",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马昭仪下。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "费无极",
          "type": "念",
          "text": "为人不用奸谋计，怎得荣华富贵全！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费无极下。"
        }
      ]
    },
    {
