          "character": "四武士",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "伍奢",
          "type": "白",
          "text": "哎，罢了，罢了哇！"
        },
        {
          "character": "伍奢",
          "type": "唱",
          "text": "金殿之上上刑具， 好比笼鸟网内鱼。 望着樊城心内痛，"
