          "character": null,
          "type": "stage",
          "text": "曹操将书信交与祢衡。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "保你高官在朝歌。"
        },
        {
          "character": "祢衡",
          "type": "西皮摇板",
          "text": "丞相宽宏请台座， 披星戴月奔江河。 顺说刘表若不妥，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖快长锤〗。祢衡出门，归大边台口立。四朝官同出门，同归偏小边台口一字立。"
