        {
          "character": null,
          "type": "stage",
          "text": "张辽无奈，还剑入鞘，自下场门下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡，老夫有书信一封，命你去至荆州，顺说刘表来降，保你官职不小。"
