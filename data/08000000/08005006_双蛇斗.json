{
  "script_id": "08005006",
  "title": "双蛇斗",
  "alias": [],
  "source": "《京剧集成》",
  "characters": [
    {
      "name": "白素贞",
      "hangdang": "武旦"
    },
    {
      "name": "青蛇",
      "hangdang": "（前）净，（后）武旦"
    }
  ],
  "plot": "白素贞修行于峨眉山，思念凡尘，遂下山。过青峰山，遇青蛇。青蛇欲娶白素贞，白素贞不允，二人打斗。\n青蛇不敌，化为女身，二人结为姐妹，一路同行。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "白素贞",
          "type": "内西皮导板",
          "text": "离峨眉驾祥云飘越崇山，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四云旗同上。白素贞上，舞蹈。"
        },
        {
          "character": "白素贞",
          "type": "西皮原板",
          "text": "飞过了幽谷峻岭来到凡尘。 自幼儿在深山养性修炼。 习就了隐身术法力无边。 全凭着变化奇随机应变， 施法力呼风唤雨降福民间。 只为我凡心动把红尘思念， 因此上离仙山要自配良缘。 但愿得此一番了却心愿， 宁羡人间我不羡仙。"
        },
        {
          "character": "白素贞",
          "type": "念",
          "text": "俺本白蛇女婵娟，深山悟道数千年。神通广大苦修炼。奇巧变化隐世间。 呕心炼就双锋剑，降妖除怪不费难。任他纵有千般化，难逃仙姑法力全。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "我乃，白蛇仙姑素贞是也。自幼在峨眉修炼，习就奇巧变化，炼成双锋宝剑。 是我思念凡尘美景，为此下得山来观赏人间的湖色河山，以解烦闷。倘遇称心 君子结为共衾同枕之人，以享人间快乐，岂不美哉。不觉前面已是青峰山了。 看那古树盘藤。银杏环山，绿竹摇摆，云霞万色，幽谷俊秀，草木峥嵘，蝶入 群芳，百鸟声喧，好一派景象也。"
        },
        {
          "character": "白素贞",
          "type": "新水令",
          "text": "碧树千里锁青苑， 霞光穿射云环山。 遥望幽谷处， 紫气阵阵寒。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "看幽谷深处紫气冲天，寒气阵阵掠过，定有精灵修炼。待我闯峰越岭者。"
        },
        {
          "character": "白素贞",
          "type": "新水令",
          "text": "速驾云峰闯青山，飞越向前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四云旗、白素贞同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小高台。四风旗、青蛇同上。"
        },
        {
          "character": "青蛇",
          "type": "点绛唇",
          "text": "变化奇巧，法力无边，苦修炼，幻术精湛，尘心常常念。"
        },
        {
          "character": "青蛇",
          "type": "念",
          "text": "俺本青峰一蛇仙，变化奇巧法力全。皆因尘缘难绝断，朝夕思念女婵娟。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "我乃，青峰山光华洞青蛇大仙是也。在深山修炼千年，精通幻变，法力无边。 怎奈尘缘未断，常常思念凡尘之乐，因此正果未成。 啊，看远方云峰起落，朝我仙山而来，定有精灵闯越青峰。 众小仙，驾起云头迎上前去。"
        },
        {
          "character": "四风旗",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四风旗、青蛇同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四云旗、白素贞同上，舞蹈。"
        },
        {
          "character": "白素贞",
          "type": "折桂令",
          "text": "观山景绿深处银杏千年， 望泉水倾斜直下，似银河飞落九天。 这边厢葱翠花鲜， 那边厢白鹤崖畔。 山巅缠绕瑞烟， 翠柏拂云天。 是何物挡住云端， 寻衅者痴想生还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四风旗、青蛇同上。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "呔，何方妖魔擅闯仙山？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "你且听了：俺乃峨眉山得道仙姑白素贞，你是何方魔怪快快通上名来。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "我乃青峰山青蛇大仙是也。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "原来是青蛇仙翁。我来问你，挡住云头，挡我去路，是何意也？"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "白蛇仙子，我对你实言了吧：我看你品貌端正，意欲和你在青峰宝洞，结为终 生伴侣，一同修真养性，求得正果，岂不是美哉？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "休得胡言，你既欲修真养性，以求正果，就该清心寡欲，潜心悟道，怎能生此 邪念。听我相劝，速速断了此念，回山修炼去吧。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "住口，你今依从便罢，稍若迟延，你来看，可知俺青峰宝剑的厉害。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "青蛇精，你大胆。"
        },
        {
          "character": "白素贞",
          "type": "西皮流水板",
          "text": "听一言来怒满膛， 山中魔怪敢猖狂。 我发慈悲将你放， 快去修炼改善良。 再若痴迷心妄想， 双刃青锋剑下亡。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "喳，喳，喳，哇呀呀，看剑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四云旗、四风旗自两边分下。白素贞、青蛇对剑，青蛇败下，白素贞追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四云旗、四风旗同上，群舞，舞毕分下。青蛇败上，白素贞追上，对打。青蛇败下。白素贞耍下场，追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "青蛇败上，白素贞追上，舞蹈。白素贞打青蛇抢背。四云旗、四风旗自两边分上。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "看剑。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "且慢，白蛇仙子果然道法非凡，望乞慈悲，饶恕于我，情愿跟随仙子，侍奉左 右，一同修炼，求得正果。我若口不应心，定遭五雷之劫。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "这……你既发誓，快快请起。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "多谢仙子慈悲。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "青蛇仙翁，你可知阴阳有别，你我怎能一路同行?"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "这个，俺情愿化一女身，侍奉仙子终生。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "既然如此，就请仙翁变来。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "献丑了。"
        },
        {
          "character": "青蛇",
          "type": "西皮散板",
          "text": "口念真言翻身变，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四风旗遮青蛇同下，遮青蛇化身同上。"
        },
        {
          "character": "青蛇",
          "type": "西皮散板",
          "text": "变一个青春女婵娟。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "白蛇仙子，你看我变得如何？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "果然法术高强。我有意与你结为姐妹，生死与共，不知你意如何？"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "正合我意，请问仙子道高几何？"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "七千九百余年。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "哎呀，仙子高我五百余载。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "如此说来我占长了，你我对天一拜。"
        },
        {
          "character": "白素贞",
          "type": "西皮摇板",
          "text": "数千年居山林修真养性，"
        },
        {
          "character": "青蛇",
          "type": "西皮摇板",
          "text": "姐姐你道高我五百余春。"
        },
        {
          "character": "白素贞",
          "type": "西皮摇板",
          "text": "我与你肝胆相照患难与共，"
        },
        {
          "character": "青蛇",
          "type": "西皮摇板",
          "text": "若三心和二意五雷轰身。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "姐姐请上，受小妹一拜。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "为姐也有一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白素贞、青蛇同拜。"
        },
        {
          "character": "青蛇",
          "type": "西皮摇板",
          "text": "从今后姐妹们相依相伴，"
        },
        {
          "character": "白素贞",
          "type": "西皮摇板",
          "text": "同甘苦共患难永不离分。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "请姐姐到古洞观赏。"
        },
        {
          "character": "白素贞",
          "type": "白",
          "text": "正要拜观。"
        },
        {
          "character": "青蛇",
          "type": "白",
          "text": "众小仙，回洞去者。"
        },
        {
          "character": "白素贞、青蛇",
          "type": "同沽美酒",
          "text": "喜相逢，恰相逢， 巧今朝得知音。 同心合意志向同， 在山林拜昆仲。 同修炼拜求长生， 炼仙丹变化无穷。 发慈悲指引迷津， 渡群灵扶助苍身。 俺呵！ 每日里苦炼求经， 学慈航大显神通。 哎呀！ 宏誓愿锦绣前程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "急急风，众人同亮相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}