{
  "script_id": "09003003",
  "title": "卧龙吊孝",
  "alias": [],
  "source": "《京剧流派剧目荟萃》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生，八卦巾、羽毛扇、白孝条（正中绣团寿字）、黑三、银灰团鹤氅、黑彩裤、厚底"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生，忠纱帽、白孝条、黑三、黑官衣，玉带、黑彩裤、厚底"
    },
    {
      "name": "小乔",
      "hangdang": "旦，大头包白绸、白褶子、白裙、白彩鞋"
    },
    {
      "name": "赵云",
      "hangdang": "武生，夫子盔、白靠、红彩裤、厚底"
    },
    {
      "name": "蒋钦",
      "hangdang": "净，扎巾盔、大靠、黑彩裤、厚底"
    },
    {
      "name": "周泰",
      "hangdang": "净，扎巾盔、大靠、黑彩裤、厚底"
    },
    {
      "name": "丁奉",
      "hangdang": "生，扎巾盔、大靠、黑彩裤、厚底"
    },
    {
      "name": "徐盛",
      "hangdang": "生，扎巾盔、大靠、黑彩裤、厚底"
    },
    {
      "name": "旗牌",
      "hangdang": "杂，素大板巾、素箭衣、大带、素马褂、厚底"
    },
    {
      "name": "二丫鬟",
      "hangdang": "旦，素袄裤、素坎肩、白腰巾、彩鞋"
    },
    {
      "name": "四文官",
      "hangdang": "杂，忠纱帽、黑参三、白三、白满、黑彩裤、厚底"
    },
    {
      "name": "四兵士",
      "hangdang": "杂，豹衣裤"
    }
  ],
  "plot": "周瑜死后，东吴将士对诸葛亮深为怨恨。大祭之日，诸葛亮为了吴、蜀联盟，共同破曹，不避斧钺，亲自过\n江祭奠，朗读祭文，声泪俱下，周妻小乔为之所感动，未忍加害。",
  "notes": "取材于《三国演义》第五十七回。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（天幕中悬大“奠”字，两边白纱蝴蝶幕垂、素幕穗。二道幕外。〖奏唢呐曲牌批〗。四兵士搭轿子引蒋钦、"
        },
        {
          "character": null,
          "type": "text",
          "text": "周泰、丁奉、徐盛同上，蒋钦、周泰、丁奉、徐盛同持鞭九龙口一字亮相，同至台口一字勒马站住，四兵"
        },
        {
          "character": null,
          "type": "text",
          "text": "士分站两边。〖大锣归位〗。）"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "同念",
          "text": "都督丧了命，将士恨难平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣住头〗。蒋钦、周泰、丁奉、徐盛分列小八字。"
        },
        {
          "character": "蒋钦",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "周泰、丁奉、徐盛",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "蒋钦",
          "type": "白",
          "text": "可恨诸葛亮将周都督气死，今当大祭之日，我等前去吊祭。"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "同白",
          "text": "军士们！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "四兵士",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "同白",
          "text": "都督府去者！"
        },
        {
          "character": "四兵士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖唢呐批〗。四兵士同插门下。〖大锣抽头〗。蒋钦、周泰、丁奉、徐盛同插门加鞭下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四文官持鞭同上，九龙口站八字斜胡同，引鲁肃上。鲁肃持鞭至中勒马。"
        },
        {
          "character": "鲁肃",
          "type": "西皮摇板",
          "text": "闻噩耗周公瑾柴桑命殒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文官同扯正，鲁肃至台口中勒马。"
        },
        {
          "character": "鲁肃",
          "type": "西皮流水板",
          "text": "我东吴不幸降星辰！ 天不永年悲短命， 伤心何处望归魂。 众大夫趋灵佑同申奠敬，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四文官同插门加鞭下。鲁肃至下场门回身。"
        },
        {
          "character": "鲁肃",
          "type": "西皮摇板",
          "text": "扶棺痛哭吊英灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣回头〗。鲁肃下。〖撤锣〗。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（二道幕启。台中场摆灵桌，桌上置灵牌、香炉、酒斗、左右一对烛台，小边桌角另放一炷供香，桌两边各"
        },
        {
          "character": null,
          "type": "text",
          "text": "一把椅，椅背向外。二旗牌分两边站。二丫鬟扶小乔同上，至台口，小乔翻右水袖，搌泪。〖小锣一击〗。"
        },
        {
          "character": null,
          "type": "text",
          "text": "小乔进灵堂，跪拜，二丫鬟陪同跪拜，站起，二丫鬟分大、小边站立于旗牌里手。小乔归大边，双翻水袖面"
        },
        {
          "character": null,
          "type": "text",
          "text": "向灵桌。〖大锣双叫头〗。）"
        },
        {
          "character": "小乔",
          "type": "叫头",
          "text": "都督，夫君！"
        },
        {
          "character": "小乔",
          "type": "哭",
          "text": "喂呀夫哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣双楗凤点头〗。"
        },
        {
          "character": "小乔",
          "type": "西皮散板",
          "text": "望灵堂哭得我咽喉气短， 我定要与夫君报却仇冤！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小乔拱手。〖大锣住头〗。"
        },
        {
          "character": "四文官、蒋钦、周泰、丁奉、徐盛",
          "type": "同白",
          "text": "文官武将前来吊祭！"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "启禀夫人：文官武将前来吊祭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同拱手。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小乔拱手。二旗牌同向外拱手。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "有请！ （〖奏唢呐哭皇天〗。四文官、蒋钦、周泰、丁奉、徐盛分两边上，同至台口，依次互拱手双进门，面向灵 周泰、丁奉、徐盛同外手站大八字，二旗牌同让至最外手。）"
        },
        {
          "character": "桌，四文官同在前站一排，蒋钦、周泰、丁奉、徐盛同在后站一排，同拜祭，分两边，四文官同里手，蒋钦、小乔",
          "type": "白",
          "text": "请众位大人、将军前厅待茶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小乔拱手。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "众位大人、将军请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同拱手。二旗牌领四文官、蒋钦、周泰、丁奉、徐盛同抽心出灵堂，自两边分下。"
        },
        {
          "character": "鲁肃",
          "type": "内白",
          "text": "鲁大夫到。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟同向小乔拱手。"
        },
        {
          "character": "二丫鬟",
          "type": "白",
          "text": "鲁大夫到。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小乔拱手。二丫鬟同向外拱手。"
        },
        {
          "character": "二丫鬟",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟自分两边分暗下。鲁肃上，至台口，搌泪，进灵堂，跪拜，小乔陪拜。鲁肃拜毕站小边。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "啊大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "夫人。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "都督之死，乃诸葛亮定计所害。就该发动人马，与都督报仇才是！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "夫人，言得极是，若要兴动人马，必须奏知吴侯，方可发兵。"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖冲头〗。旗牌上，进灵堂归大边，面向小乔。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启禀夫人：诸葛亮过江前来吊祭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌向外一指。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖撕边一击〗。小乔上步。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "那诸葛亮他、他、他过江吊祭来了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖撕边一击〗。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "我正要寻他，他倒来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小乔退一步面向鲁肃。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "啊大夫，将诸葛亮带至灵堂见我！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小乔甩右水袖。鲁肃同时双摊手，无奈状。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣长尖〗。鲁肃向小乔拱手，出灵堂，台口双摊手，摇头，手扶脑门，自上场门下。小乔向旗牌。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "有请众位将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌至台口中，拱手。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有请众位将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌自下场门下。"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "内同白",
          "text": "来也！ （蒋钦、周泰、丁奉、徐盛挎宝剑自两边分上。〖大锣长尖〗。蒋钦、周泰、丁奉、徐盛同双进门，分两边 站八字。）"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "同白",
          "text": "参见夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋钦、周泰、丁奉、徐盛同拱手。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "众位将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣五击〗。小乔至台口中。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "那诸葛亮过江吊祭来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小乔右手指出。〖撕边〗。蒋钦、周泰、丁奉、徐盛互对眼神，同抓扔靠绸，同拱手。〖大锣叫头〗。"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "同白",
          "text": "夫人！就该拿下诸葛亮，与我家都督报仇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖撕边一击〗。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "你等埋伏两厢，等那诸葛亮到此——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖撕边一击〗。"
        },
        {
          "character": "小乔",
          "type": "白",
          "text": "看我眼色行事。"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "同白",
          "text": "遵命。 （〖一锤锣〗，〖大锣原场〗。蒋钦、周泰、丁奉、徐盛同抽心双出门，自两边分下。小乔归里，面向里坐 右椅。〖大锣原场〗。）"
        },
        {
          "character": "鲁肃",
          "type": "内白",
          "text": "先生请！"
        },
        {
          "character": "诸葛亮",
          "type": "内白",
          "text": "大夫请！ （〖奏胡琴曲牌西皮哭皇天〗。鲁肃上，至台中，回身拱手引诸葛亮上。诸葛亮带着身历险境、泰然自若的 神情上场，至九龙口处亮相。赵云随后同上，同时亮相。诸葛亮与鲁肃互拱手相让，同至台口，同进灵堂。 诸葛亮挖大边，赵云跟至大边外手，鲁肃挖小边。诸葛亮面向灵桌。〖曲牌止〗，〖大锣双叫头〗。诸葛亮 翻左水袖，向灵位拱手。）"
        },
        {
          "character": "诸葛亮",
          "type": "三叫头",
          "text": "都督，公瑾！哎，都督哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮哭，左袖搌泪。"
        },
        {
          "character": "诸葛亮",
          "type": "反西皮散板",
          "text": "一见灵位泪涟涟， 捶胸顿足向谁言！ 正欲同心破曹瞒， 不料都督归了天。 我哭！哭一声周都督！ 叫叫一声公瑾先生！ 啊！我的心痛酸！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊，鲁大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮，过得江来，谨备祭文一道，相烦大夫赞礼，亮就此与都督，哎！上香了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上步至中场台口，左手整冠，捋髯。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请先生上香！ （鲁肃将桌上的香拿起点燃，交与诸葛亮。诸葛亮接过香，插进香炉，回身至中场，面向灵桌，双腿跪拜。 站起，将羽扇挂右手上，左转身面向台下。）"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请先生读祭文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮向赵云。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "看祭文伺候！ （赵云将祭文从靠内取出，双手递过。〖大锣归位〗。诸葛亮接过祭文，至台口正中，展开祭文，从右至左、 竖式句列面念。）"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "“大汉建安十五年冬十二月廿三日南阳诸葛亮谨备祭文一道致祭于大都督周氏 公瑾之灵位哀而告曰：”"
        },
        {
          "character": "蒋钦、周泰、丁奉、徐盛",
          "type": "内同白",
          "text": "嘿！ （〖急急风〗。诸葛亮、鲁肃、赵云同归里，同面向里。蒋钦、周泰、丁奉、徐盛自两边分上，同抄过，同 至台口，同拔剑亮相。撕边。蒋钦、周泰、丁奉、徐盛同观小乔眼色，小乔站起向蒋钦、周泰、丁奉、徐盛 示意：暂退下。蒋钦、周泰、丁奉、徐盛同将宝剑入鞘。〖八答仓〗、〖急急风〗。蒋钦、周泰、丁奉、徐 盛自两边分下。小乔回座坐。赵云出门，至下场门望门，至上场门望门，回身进灵堂，跨右腿，踢左腿，至 大边。〖四击头〗、〖撕边〗。诸葛亮至台口正中，鲁肃至台口小边，诸葛亮、鲁肃、赵云同亮相。赵云拔 再顺着鲁肃的眼光发现了赵云在拔剑示怒。诸葛亮向赵云示意收剑。）"
