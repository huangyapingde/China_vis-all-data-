{
  "script_id": "13004004",
  "title": "安天会·大战",
  "alias": [],
  "source": "《剧学月刊》",
  "characters": [
    {
      "name": "孙悟空",
      "hangdang": "武生"
    },
    {
      "name": "李天王",
      "hangdang": "净"
    },
    {
      "name": "老君",
      "hangdang": "外"
    }
  ],
  "plot": "孙悟空搅乱蟠桃会，玉帝怒，遣李天王率十万神兵往擒孙悟空，孙悟空被擒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客"
        },
        {
          "character": null,
          "type": "text",
          "text": "星、月孛星、巨灵神、二郎神、哪吒、李天王同上。）"
        },
        {
          "character": "李天王",
          "type": "点绛唇",
          "text": "十万熊罴，星辰齐集，尊天帝，剿灭渠魁，扫尽如斯辈。"
        },
        {
          "character": "四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客星、月孛星、巨灵神、二郎神、哪吒",
          "type": "同白",
          "text": "众将参见！"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客星、月孛星、巨灵神、二郎神、哪吒",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "李天王",
          "type": "念",
          "text": "大将缓缓出御庭，天兵十万列连营。天罗地网安排定，管取妖猴一命倾。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "可恨猴头，大闹蟠桃会，私窃老君丹，玉帝大怒，命俺督领天兵十万，四大天 君、天罡地煞、九曜星君、二十八宿、十二元辰、六丁六甲、东西南北星斗、 三子哪吒、先锋巨灵、灌口二郎神、罗睺、计都、丧门、吊客、月孛星等，罗 布下一十八架天罗地网，来此花果山擒拿妖猴。 众天将！"
        },
        {
          "character": "四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客星、月孛星、巨灵神、二郎神、哪吒",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "吾奉玉旨，擒拿妖猴，尔等须要齐心努力，扫除妖氛，分班听差，听吾号令！ （四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客 星、月孛星、巨灵神、二郎神、哪吒同应。）"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "俺这里神通奇异， 妖氛不与瑞光飞。 俺这里祥云霭霭， 他那里冷雾凄凄。 俺这里一片雄心多智慧， 他那里千般魔力少机宜。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "马天君。"
        },
        {
          "character": "马天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "命你带领罗睺星呵！"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "恁在山前迎战施法力，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天君应，下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "赵天君。"
        },
        {
          "character": "赵天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "命你带领计都星呵！"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "恁在山后运动神机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵天君应，下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "温天君。"
        },
        {
          "character": "温天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "命你带领月孛星呵。"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "恁在那山左接战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "温天君应，下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "刘天君。"
        },
        {
          "character": "刘天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "命你带领丧门、吊客。"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "恁在山右将他魂魄追随。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘天君应，下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "巨灵神。"
        },
        {
          "character": "巨灵神",
          "type": "白",
          "text": "在啊！"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "命你以为前部先锋，带领九曜星君、二十八宿。"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "恁将他巢穴倾倒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巨灵神应，下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "二郎神。"
        },
        {
          "character": "二郎神",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "今日之事，全仗于你，命你带领天罡地煞诸神，将猴头紧追紧赶。"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "休得要半步相离。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二郎神应，下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "哪吒。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "命你带领六丁六甲、十二元辰，以为八方都接应。"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "必须要齐心努力， 务必要扫灭渠魁。"
        },
        {
          "character": "李天王",
          "type": "夹白",
          "text": "俺这里天兵天将施威武，"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "他那里猴卒妖兵乱逞威。"
        },
        {
          "character": "李天王",
          "type": "夹白",
          "text": "只杀得愁云惨淡，"
        },
        {
          "character": "李天王",
          "type": "混江龙",
          "text": "只杀得星斗迷稀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，小猴随上，作完。马天君、赵天君、温天君、刘天君同攒，众人同上，孙悟空攒，打下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "好一场厮杀也！"
        },
        {
          "character": "李天王",
          "type": "油葫芦",
          "text": "只见他雄威赳赳勇如罴， 不枉他号天齐。 只见他往来南北， 冲突东西。 他那里奔驰一似也那如儿戏， 俺这里神通广大可也难逃避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，打下。"
        },
        {
          "character": "李天王",
          "type": "幺篇",
          "text": "俺与他一会价辨个高低， 昏惨惨四野征云起， 闹垓垓几出里军声沸， 恰便似平地上起个轰雷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，打下。"
        },
        {
          "character": "李天王",
          "type": "天下乐",
          "text": "只见那木怪山魈也那挂铁衣， 摇也么旗可也助军威。 可怜那无知亡命好痴迷， 这壁厢吹筚篥， 那壁厢擂鼓鼙， 怎挡俺法力大可也尽披靡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，打下。"
        },
        {
          "character": "李天王",
          "type": "哪吒令",
          "text": "小妖们遍山岭， 沿堤奔腾也那疾似飞。 有的妖把角吹， 有的妖把鼓擂。 老妖们头顶盔， 小妖们并着脮。 这山坡聚几堆， 那山坡聚几堆， 笑他们闹嚷嚷意欲何为？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，打下。"
        },
        {
          "character": "李天王",
          "type": "鹊踏枝",
          "text": "满山头云雾起， 四下里刀枪密。 眼跟前地惨天昏， 耳边厢鬼哭神啼。 越地里山崩海沸， 他们只杀得紫微垣斗转星移。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，打下。"
        },
        {
          "character": "李天王",
          "type": "胜葫芦",
          "text": "这妖猴法力果惊奇， 不能够把他欺。 又只见狰狞相貌多奇异， 他只是三头六臂铜筋铁骨，吼一声似也霹雳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，打下。"
        },
        {
          "character": "李天王",
          "type": "幺篇",
          "text": "俺只见六丁六甲显神威， 四面列重围。 恁就是三头六臂， 休轻敌。 他们都执剑抡枪逞矛戟， 一队队耀武扬威紧相随。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空、二郎神同上，同架住。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "呔！杀了半日，不曾问得姓名，通名再战。"
        },
        {
          "character": "二郎神",
          "type": "白",
          "text": "听者："
        },
        {
          "character": "二郎神",
          "type": "念",
          "text": "清虚妙道二郎神，法力威名天下闻。灵霄宝殿为上将，特来擒你妖猴孙。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "呀呸！这些话只好去哄别人，在孙爷爷面前岂是卖弄得的。你且站定了，听俺 道来。"
        },
        {
          "character": "二郎神",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "天地初分有吾身，参禅学道拜昆仑。神通广大超三界，要上灵霄为帝尊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空、二郎神同打下。众人同上，同摆阵，狗形上。"
        },
        {
          "character": "四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客星、月孛星、巨灵神、二郎神、哪吒",
          "type": "同白",
          "text": "妖猴被擒！"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "猴头啊，猴头！"
        },
        {
          "character": "李天王",
          "type": "煞尾",
          "text": "恁自夸神通广大， 怎挡俺法力威， 这是你自造孽怨着谁。"
        },
        {
          "character": "李天王",
          "type": "夹白",
          "text": "斩仙台上留名誉。"
        },
        {
          "character": "李天王",
          "type": "煞尾",
          "text": "一灵儿何处追随。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "众天将，好生看守猴头，待我请旨定夺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李天王下。"
        },
        {
          "character": "四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客星、月孛星、巨灵神、二郎神、哪吒",
          "type": "同白",
          "text": "猴头啊，猴头！"
        },
        {
          "character": "四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客星、月孛星、巨灵神、二郎神、哪吒",
          "type": "同千秋岁",
          "text": "犯天条，自作休烦恼， 顷刻间尸横市曹。 大圣齐天，大圣齐天， 只落得残身万断零抛， 名和利逐水飘， 风中烛霜下草。 霎时魂飘渺， 看从前事业枉费辛劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李天王上。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "众天将，玉帝有旨！"
        },
        {
          "character": "四文堂、四大铠、四上手、四下手、马天君、赵天君、温天君、刘天君、罗睺星、计都星、丧门星、吊客星、月孛星、巨灵神、二郎神、哪吒",
          "type": "同红绣鞋",
          "text": "将猴头万剐千刀，千刀， 筋挑骨剔肢敲，肢敲。 尸骸碎抛荒郊， 火光烈烟腾高， 留惊世后人瞧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老君上。"
        },
        {
          "character": "老君",
          "type": "白",
          "text": "天王何来？"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "有何见谕？"
        },
        {
          "character": "老君",
          "type": "白",
          "text": "这猴头将我五个葫芦内的金丹尽行偷吃，已奏闻玉帝，命我带回，将他放入八 卦炉中，炼出金丹还我，此妖化为灰烬矣。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "如此老君带去，天兵护送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同应。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "老头儿，走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、老君、孙悟空同下。"
        },
        {
          "character": "李天王",
          "type": "白",
          "text": "众天将！回复玉旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尾声。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}