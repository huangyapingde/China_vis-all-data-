{
  "script_id": "13004005",
  "title": "盘丝洞",
  "alias": [],
  "source": "《剧学月刊》",
  "characters": [
    {
      "name": "月霞仙子",
      "hangdang": "旦"
    },
    {
      "name": "卤虾仙子",
      "hangdang": "丑"
    },
    {
      "name": "金头大仙",
      "hangdang": "净"
    },
    {
      "name": "孙悟空",
      "hangdang": "武生"
    }
  ],
  "plot": "盘丝洞中蜘蛛精月霞仙子等七人，化身女子，擒住唐僧逼婚。猪八戒遇月霞仙子，为丝所缚，孙悟空火烧蛛\n丝，并幻化假唐僧戏弄七妖，救出真唐僧。遇蜈蚣精金头大仙，力败之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子同上，同斜一字。〖牌子〗。"
        },
        {
          "character": null,
          "type": "text",
          "text": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子同挖门，同横一字。）"
        },
        {
          "character": "月霞仙子",
          "type": "念",
          "text": "临空布阵道法高，任我盘旋乐逍遥。炼得五行成精宝，换得金身赴蟠桃。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "吾乃，月霞仙子是也。"
        },
        {
          "character": "云霞仙子",
          "type": "白",
          "text": "云霞仙子是也。"
        },
        {
          "character": "碧霞仙子",
          "type": "白",
          "text": "碧霞仙子是也。"
        },
        {
          "character": "玉霞仙子",
          "type": "白",
          "text": "玉霞仙子是也。"
        },
        {
          "character": "紫霞仙子",
          "type": "白",
          "text": "紫霞仙子是也。"
        },
        {
          "character": "瑞霞仙子",
          "type": "白",
          "text": "瑞霞仙子是也。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "我，卤虾仙子是也。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "吾等齐赴金花大会，朝罢圣母而归，一同回洞去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子同走圆场。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "众位姐妹请坐。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "众位贤妹。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同白",
          "text": "姐姐。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "你我在此盘丝洞中，修炼千年，变化人身，只是不能飞升九天，好不烦闷人也。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "列位姐姐，俗话说得好：心急吃不了豆儿粥。给他慢慢熬着，功到自然成，何 必忧愁烦闷？依我说，趁此春光，百花齐放，我们何不饮酒赏花，消遣开怀， 可烦得是哪一门子哪？"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "众言之有理。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "如此将酒摆在百花亭上，贤妹请。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "跳蜈蚣形，下。〖急急风〗。四风旗、八小蜈蚣引金头大仙同上。"
        },
        {
          "character": "金头大仙",
          "type": "点绛唇",
          "text": "拜斗参天，千年修炼，金丹见，法力无边，来去如飞电。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金头大仙上高台。"
        },
        {
          "character": "金头大仙",
          "type": "念",
          "text": "修炼千年道法通，变化无形乐无穷。乘风驾雾如飞电，光现长空似火龙。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "吾乃，金头大仙是也。今有唐僧往西天拜佛求经，从此经过，我不免告知吾妹 月霞仙子，扮做凡间妇女模样，将他诱进洞中，盗取他的舍利炼成金丹，可以 飞升。 呔！众小妖！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八小蜈蚣同应。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "好生看守洞府，吾往盘丝洞去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八小蜈蚣同应。〖叠字犯〗。八小蜈蚣腿夹头作一串似蜈蚣形同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "月霞仙子上。"
        },
        {
          "character": "月霞仙子",
          "type": "一江风",
          "text": "鸟声姣，报到春光好， 陡地伤怀抱。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "我，月霞仙子。适在洞中饮酒，忽然不爽，因此逃席，不免到山前游玩一番便 了。"
        },
        {
          "character": "月霞仙子",
          "type": "一江风",
          "text": "猛凝眸，只见紫燕双双，粉蝶翩翩，故向花丛绕， 教我难打熬，教我难打熬， 心旌不住摇， 向何方去觅人年少。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子同上。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同一江风",
          "text": "饮香醪，共把金樽倒， 姊妹寻欢笑。 好春朝， 满目韶华，桃柳羞花貌。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同白",
          "text": "姐姐啊！"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同一江风",
          "text": "因何把席逃，因何把席逃， 看你春酣脸晕潮，越显得秋波俏。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "适才饮酒，忽生烦闷，故而逃席，休得见怪。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同白",
          "text": "焉敢见怪。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "姐姐烦闷，想个什么玩耍？"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "咱们打秋千。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "不好。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "大家斗草儿罢。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "也不好。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "体操罢。"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "咳。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "咱们扑蝴蝶罢。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "这却甚好。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "立个罚约。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "扑着饮酒，扑不着罚她站着斟酒。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "如此甚好，请。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "大家扑起来。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "扑起来啊。"
        },
        {
          "character": "卤虾仙子",
          "type": "干吹",
          "text": "不妨沉醉乐滔滔。"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同太师引",
          "text": "酒初消，齐向花间闹， 艳阳天，香风细飘畅，好似推襟送抱。 休辜负，斗草寻苗， 怎顾那，柔枝嫩条，惜花心暂时抛掉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子同笑。"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同太师引",
          "text": "输共赢全凭这遭， 得宜男，喝彩喝彩笑声高。"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "谁扑着啦？ 我扑着个蚂蚱。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "你呢？呦！挂大扁。 你呢？呦！蜣螂飞啦！ 姐姐你呢？"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "蝴蝶。你呢？"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "我啊，十个。"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "什么？"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "手指头。"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "罚你。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "得了姐姐，我说姐姐，您老愁眉不展是什么缘故？"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "贤妹啊！"
        },
        {
          "character": "月霞仙子",
          "type": "太师引",
          "text": "对花姣添人恼， 心中事伊家怎晓。"
        },
        {
          "character": "云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子",
          "type": "同白",
          "text": "多应是，莺歌燕吵， 要求个凤友鸾交。"
        },
        {
          "character": "月霞仙子",
          "type": "太师引",
          "text": "一腔恨，聪明猜着， 称心儿玉人浑少， 那刘阮仙缘岂能遥。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "姐姐，我倒替你愁呢。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "愁者何来？"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "啊哪！"
        },
        {
          "character": "卤虾仙子",
          "type": "太师引",
          "text": "愁你一船难下两支槁， 一船难下两支槁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金头大仙上。"
        },
        {
          "character": "金头大仙",
          "type": "太师引",
          "text": "五毒从来名占叨， 天生百足英豪。"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "大哥来了。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "哥哥来了。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "贤妹。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "哥哥请坐。"
        },
        {
          "character": "金头大仙",
          "type": "笑",
          "text": "啊哈哈哈！"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "你瞧，进门就打哈哈。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "哥哥为何发笑？"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "贤妹有所不知，今有唐僧……"
        },
        {
          "character": "卤虾仙子",
          "type": "白",
          "text": "唐僧？八成是甜的。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "哎！他往西天拜佛求经，打此经过，贤妹可扮做乡间女子，将他诱至洞中，成 其美事，盗取他舍利，为此特来告知。那唐僧呵！"
        },
        {
          "character": "金头大仙",
          "type": "太师引",
          "text": "拜神祠，就计得鸳鸯兆， 参佛土，参佛土，祈求鸾凤交。"
        },
        {
          "character": "月霞仙子",
          "type": "太师引",
          "text": "深谢吾兄情意好， 为奴指引蓝桥， 管教不用玄霜捣， 一饮琼浆婿便招。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "贤妹，那唐僧到来，依计而行。"
        },
        {
          "character": "月霞仙子",
          "type": "白",
          "text": "这个自然。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "金头大仙",
          "type": "念",
          "text": "姻缘本是前生定，"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同念",
          "text": "俱是蟠桃会上人。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子",
          "type": "同白",
          "text": "送兄长。"
        },
        {
          "character": "金头大仙",
          "type": "白",
          "text": "请！ （金头大仙自上场门下，月霞仙子、云霞仙子、碧霞仙子、玉霞仙子、紫霞仙子、瑞霞仙子、卤虾仙子同进 洞，同下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "孙悟空",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，起霸。"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "自幼学道拜昆仑，炼就千变万化身。五行山下皈依佛，今保师父取真经。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "俺，悟空。保定师父前往西天拜佛求经，且喜道路平安，不免请师父趱路呀。 道犹未了，师父来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒、沙僧、唐僧同上。"
        },
        {
          "character": "唐僧",
          "type": "念",
          "text": "驱驰道路往西行，只为求取大藏经。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "参见师父。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "道路平安，请师父趱路。"
        },
        {
          "character": "唐僧",
          "type": "白",
