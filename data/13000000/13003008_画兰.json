  "plot": "王伯谷访名妓马湘兰，观其画兰，题诗于画上。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王伯谷上。"
        },
        {
          "character": "王伯谷",
          "type": "小工调步步娇",
          "text": "甚风儿吹得我心摇扬， 辗转增惆怅。 撩乱情怀好难安放。"
        },
        {
          "character": "王伯谷",
          "type": "白",
          "text": "小生王伯谷，京江人士。春闱落第，流寓京师，赋性不羁，放怀诗酒。只为功 名失意，却教花柳情牵。物色多时，才访得姑苏马湘兰。见她姿容秀美，吐属 温柔，常与往来。可笑近日都中有一种风气，凡有名的姊儿不拘好歹，都要画 不多几日，功夫早已名重一时了。今日独酌无聊𠮩，不免去寻她作画一回，以 遣酒性便了。"
        },
        {
          "character": "王伯谷",
          "type": "小工调步步娇",
          "text": "扶醉过平康， 为丹青特地把红裙访。"
        },
        {
          "character": "王伯谷",
          "type": "白",
          "text": "来此已是兰娘门首。 吓开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小环上。"
        },
        {
          "character": "小环",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "小环",
          "type": "念",
          "text": "忽听叩门声，知是佳客至。"
        },
        {
          "character": "小环",
          "type": "白",
          "text": "是哪个？原来是王相公。请客堂坐。"
        },
        {
          "character": "王伯谷",
          "type": "白",
          "text": "兰娘在家否？"
        },
        {
          "character": "小环",
          "type": "白",
          "text": "在里面。相公请坐，待我唤她。 吓，湘娘，王相公来了！快些出来吓！"
        },
        {
          "character": "马湘兰",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马湘兰上。"
        },
        {
          "character": "马湘兰",
          "type": "风马儿",
          "text": "偷闲读画坐文窗， 闻小婢唤檀郎。"
        },
        {
          "character": "马湘兰",
          "type": "白",
          "text": "相公万福！ 王伯谷"
        },
        {
          "character": "马湘兰",
          "type": "白",
          "text": "湘娘拜揖。"
        },
        {
          "character": "马湘兰",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "王伯谷",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "马湘兰",
          "type": "白",
          "text": "今日甚风吹得到此？"
        },
        {
          "character": "王伯谷",
          "type": "白",
          "text": "独酌无聊，故而到此。不知湘娘作何消遣？"
        },
        {
          "character": "马湘兰",
          "type": "白",
          "text": "就是相公前日醉后画的那幅墨兰，奴家爱玩不止，在里面临摹一回。"
        },
        {
          "character": "马湘兰",
          "type": "风马儿",
          "text": "深惭婢学夫人样， 恰自调水墨亲手写三湘。"
        },
        {
          "character": "王伯谷",
          "type": "白",
          "text": "哈哈！小生正为看画而来。当面请教如何？"
        },
        {
          "character": "马湘兰",
          "type": "白",
          "text": "只是临的不好，不要见笑。"
        },
        {
          "character": "王伯谷",
          "type": "白",
          "text": "自然是好的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王伯谷看。众妓女持画同上。"
        },
        {
          "character": "众妓女",
          "type": "同黄莺儿",
          "text": ""
        },
        {
