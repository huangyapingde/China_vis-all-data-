        {
          "character": "黄盖",
          "type": "西皮散板",
          "text": "曹孟德统雄师兵山将海， 鲁子敬在江夏搬来奇才； 众谋士与孔明舌战比赛， 不由得黄公覆怒满胸怀。"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "呔！鲁大夫从江夏请来诸葛先生，乃当世奇才。公等以唇齿相难，非敬客之礼。 今曹操大军临境，不议御敌之策，乃徒口斗，是何意也？"
        },
        {
          "character": "张昭、步骘、蒋综、陆绩",
          "type": "同白",
          "text": "这……"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "哼！ 啊，诸葛先生请了！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请了。请问老将军尊姓高名？"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "某姓黄名盖字公覆，现为东吴粮官。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "原来黄公覆，失敬了！"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "岂敢。愚闻先生多言获利，不如默而无言。何不将金石之论，为吾主言之，何 必与众人辩论也？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "诸公不识世务，互相问难，亮不容不答耳。"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "吾奉鲁大夫之命，请先生与见吾主。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "请。正是："
        },
        {
          "character": "黄盖",
          "type": "念",
          "text": "暂将金石存腹内，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄盖下。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "舌战群儒似木雕。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "失陪了。"
        },
        {
          "character": "张昭、步骘、蒋综、陆绩",
          "type": "同白",
          "text": "有慢了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "得罪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "张昭、步骘、蒋综、陆绩",
          "type": "同白",
          "text": "哎！倒落了个没趣。见了主公再议。请！"
        },
        {
          "character": "张昭、步骘、蒋综、陆绩",
          "type": "同念",
          "text": "双手捧起西江水，难洗今朝满面羞。"
        },
        {
          "character": "张昭、步骘、蒋综、陆绩",
          "type": "同白",
          "text": "哎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张昭、步骘、蒋综、陆绩同下。"
