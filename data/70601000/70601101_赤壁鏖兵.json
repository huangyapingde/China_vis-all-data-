        {
          "character": "张郃",
          "type": "白",
          "text": "鼓角声高，丞相升帐，你我两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "丹书铁卷，拥旌旄、扫烟尘，群雄尽灭；汉室天子如木偶，锦华夷不日曹接。"
        },
        {
          "character": "张郃、文聘、许褚、张辽、蔡瑁、张允、毛阶、于禁",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "张郃、文聘、许褚、张辽、蔡瑁、张允、毛阶、于禁",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "盖世乾坤已破，一心想占山河。斩杀不待蹉跎，献帝孙刘在佐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫，姓曹名操字孟德。沛国谯郡人也，骁骑出身。自起义兵破黄巾，诛董卓、 擒吕布、灭袁术、平袁绍、得荆襄，称汉家丞相。前者刘备在当阳被老夫一 战，兵败夏口，恐结连东吴是滋蔓也。今奏奉天子命诏，统领八十三万人马大 下江南，孙权必惊疑而来降，吾事济矣。 张郃听令：命汝以为旱路先锋。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "文聘听令：命汝以为水路先锋。蔡瑁、张允以为水军头领，余下之将，随营调 遣。"
        },
        {
          "character": "文聘",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传令下去，我军水陆并进，船骑双行，沿江而走，八十三万人马，大下江南。"
        },
        {
          "character": "张郃、文聘",
          "type": "同白",
          "text": "得令。 令出。唗！下面听者：丞相有令，我军水陆并进，船骑双行，沿江而走，八十 三万人马大下江南。"
        },
        {
          "character": "许褚、张辽、蔡瑁、张允、毛阶、于禁",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "张郃、文聘",
          "type": "同白",
          "text": "传令毕。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "就此起马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。张郃、文聘、许褚、张辽、蔡瑁、张允、毛阶、于禁同领下，伞夫随曹操同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《赤壁鏖兵》【头本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "汉室苗裔，图大业，复立帝基。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "邑郡生英俊，飘然自不群。创业心攸重，求贤礼志勤。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤，姓刘名备字玄德。乃大树娄桑人氏，本中山靖王之后，孝景帝之玄孙，倚 附堂兄刘表，不幸晏驾。孺子刘琮懦弱无为，将荆襄九郡献与曹瞒，使我弃新 野、走樊城、败当阳、走夏口，无处栖身。只得退守江夏。哎！正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "张牙舞爪潜波底，怎得风云起卧龙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳上。"
        },
        {
          "character": "糜芳",
          "type": "念",
          "text": "晓日貔貅帐，春风虎豹营。"
        },
        {
          "character": "糜芳",
          "type": "白",
          "text": "启主公：东吴鲁肃过江求见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊！我想鲁肃与孤素无相识，他今到此，必有要事。请诸葛先生。"
        },
        {
          "character": "糜芳",
          "type": "白",
          "text": "请诸葛先生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "纬地经天安排策，人称南阳大丈夫。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢座。唤山人进帐，有何军情事议？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "适才糜芳报道，东吴鲁肃过江求见，不知何故？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那曹操统率八十三万人马，虎踞江汉。他焉不差人探听虚实。他今此来，正和 我意，待他若问之时，主公只推不知，待山人全凭三寸不烂之舌，去往江东， 激动孙权，与曹操南北相争，山人在于中取事，占得汉室诸土。此乃天赐之机 会也！"
        },
        {
          "character": "刘备",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生高见。请暂退。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来！有请鲁大夫。"
        },
        {
          "character": "糜芳",
          "type": "白",
          "text": "有请鲁大夫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳下。"
        },
        {
          "character": "鲁肃",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "金殿礼决坐，江山一帆风。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊！刘皇叔！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "鲁大夫过江来了！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大夫请来上坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不敢不敢。肃乃一介儒生，焉敢与皇叔对坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你乃江东贵客，理应上坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这就不敢，旁侍一坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "鲁大夫车马降临，蓬荜生辉，实切可幸。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "久闻皇叔大名，无缘拜会；今幸得相见，实为欣慰。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "岂敢岂敢。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "近闻皇叔与曹会战，必知彼军虚实。敢问皇叔，那曹军约有几何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备兵微将寡，但闻曹军一至，备便急走，不知彼军虚实。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "闻得皇叔用诸葛孔明之谋，两次火烧得曹操亡魂丧胆，何言不知也？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "除非问诸葛先生，便知其详。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孔明安在？愿求一见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，请诸葛先生。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请诸葛先生进帐！ 中国京剧戏考 《赤壁鏖兵》【头本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "江东无决计，来使探虚实。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "见过鲁大夫。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊，鲁大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不敢。君莫非是卧龙公？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不敢。草字孔明。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "久仰久仰。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "岂敢岂敢。"
        },
        {
          "character": "刘备",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "向慕先生先生才德，未得拜晤；今幸相遇，愿领大教。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮才疏学浅，有辱明闻。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问先生：曹兵共有多少？可下江南否？⑴"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "曹操奸计，亮已尽知；但恨力未及，故且避之，以待天时耳。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "皇叔今将止于此否？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我主与苍梧太守吴臣，乃旧日故交，将往投之。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吴臣那里，兵微粮少，自不能保，焉能容人？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吴臣那里，虽不能久居，且暂依之，别有良图。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎！我主孙仲谋，虎踞江东，兵精粮足，又极敬贤礼士；今为君计，莫若遣一 心腹往结江东，同心破曹，以图大事，岂不美哉？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我主与孙将军素不相识，恐虚费说词。况且，别无心腹之人可使差矣。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生令兄，现为东吴参谋，日望与先生相见。肃不才，愿与同见我主，共议大 事，你看如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎，孔明乃是吾之师，顷刻不可相离，安可去也？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎，自今孙刘两家结好，同心破曹，以图大事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公，事已至此，山人只得请命一往。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生须要早回。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生啊！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
