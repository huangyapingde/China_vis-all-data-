          "character": "守坛军",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "尔可穿我法衣，上得坛台，山人自有分派。"
        },
        {
          "character": "守坛军",
          "type": "白",
          "text": "啊。 中国京剧戏考 《赤壁鏖兵》【六本】 6"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "与我更衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守坛军穿诸葛亮法衣上台。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "尔可上得台去，闭目躬身，不准偷眼观觑，交头接耳，违令者斩。"
        },
        {
          "character": "守坛军",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "待山人踏罡布斗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮取令箭袖内，看，下台，冷笑下。丁奉、徐盛同上，同上台。"
