  "plot": "曹操败走华容道，又复大笑谓诸葛亮、周瑜毕竟无才。一言未毕，忽闻人马嘶喊，急问众将为何人旗号。众\n将答称乃关羽。曹操拜谢天地。众将怪问其故，曹操告以关羽在许昌时曾许以三不死，谅可活命。当即上前\n与关羽以礼相见，苦苦哀告，请念旧情相释。关羽心软，放走曹操，回营请罪。诸葛亮因刘备、张飞再三求\n情，方许关羽立功赎罪，派其暗袭襄阳。",
  "notes": "清同治、光绪年间四大徽班中之三庆班卢胜奎先生曾将《三国演义》中刘表托孤至取南郡一段故事编成轴子\n戏三十六本，每年露演一次，每演必红遍都门，传得盛赞。《赤壁鏖兵》为其中之八本，从曹操兴师南下至\n败走华容止，包括《舌战群儒》、《激权激瑜》、《临江会》、《群英会》、《横槊赋诗》、《借东风》、\n《烧战船》、《华容道》。这八本戏在三十六本三国戏中所占分量颇重，更因此剧结构严谨、情节动人，演\n来很受欢迎。\n这戏经萧长华先生参考《三国演义》进行删润、校勘。在历次教学与演出中，随教随修、随演随改，现已成\n为流行名剧。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、曹仁同上。"
        },
        {
          "character": "曹仁",
          "type": "点绛唇",
          "text": "军威森严，煞气冲天，兵百万，战将千员，到处凯歌还！"
        },
        {
          "character": "曹仁",
          "type": "念",
          "text": "当阳一战败桃园，刘备计穷心胆寒。蔡氏已把荆襄献，丞相统师下江南。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "本帅，姓曹名仁字子孝。奉丞相之命，镇守南郡一带等处，以防他变。丞相统 领八十三万人马，大下江南，至今未见捷音。也曾命探子前去打探，未见回报。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅；丞相赤壁兵败而回，离南郡不远！"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "众将官，出城附近迎接。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠同领。设南郡城。旗纛随四文堂、四大铠、曹仁同出城，同领下。撤城。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四绿文堂、四大铠、周仓、旗牌、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "三江口鏖兵决战。捉拿曹贼交令还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽坐。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "平生志性烈如钢，读春秋暗习阴阳，使青龙上将命丧，炎汉中盖世无双。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉寿亭侯关。只因三江口赤壁鏖兵，火烧战船，曹贼兵败。吾奉军师之命， 埋伏华容小道，阻挡曹操。 小校带马！"
        },
        {
          "character": "关羽",
          "type": "西皮慢原板",
          "text": "楚汉相争数十载， 中国京剧戏考 《赤壁鏖兵》【八本】 2 王莽起意篡龙台。 光武中兴国号改， 五百年前接下来。 弟兄桃园三结拜， 犹如同母共娘胎。 东吴孙权守疆界，"
        },
        {
          "character": "关羽",
          "type": "西皮垛板",
          "text": "北地曹操领兵来。 我家军师挂了帅， 满营将官俱有差； 不差关某心不爱， 因此上打赌满胸怀。 绿袍罩定黄金铠， 耀武扬威到此来。 叫小校将人马下了寨， 不知曹贼来不来。"
        },
        {
          "character": "四绿文堂、四大铠",
          "type": "同白",
          "text": "来在华容道。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "放起烟墩，曹操到此，速报我知。⑴"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖慢长锤〗。曹操领许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "曹孟德在马上长思短叹，⑵ 手捶胸眼落泪口怨苍天。 在中原领人马八十三万， 实指望取荆州来夺江南。 又谁知小周郎他的韬略广远， 诸葛亮那妖道诡计多端； 黄公覆他那里把苦肉计献， 那蒋干引庞统来献连环； 我只说十一月东风少欠， 哪晓得诸葛亮扭转先天。 烧得我大小兵丁皮焦肉烂， 只剩下一十八骑残兵败将好不惨然！ 曹孟德在马上嘻笑欢天，"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同西皮散板",
          "text": "丞相发笑为哪般？"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "我笑周郎见识呆， 诸葛亮用兵无大才。 此地若埋伏下人马在， 你我主将无处葬埋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声，鼓声。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "一言未尽人马喊， 想必是此地有安排。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，看看什么旗号。 中国京剧戏考 《赤壁鏖兵》【八本】 3"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同看。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "乃是关公旗号。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "谢天谢地。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "到了绝地，还谢甚么天地？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你们哪里知道，当初那关公，在许昌许我三不死，难道一次也不饶么？"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "我们杀不得了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "不用你们杀了。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "也战不得了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "也不用你们战了。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "怎么样？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你们在此养伤。待老夫向前百般哀告于他，或可放你我主将逃走，也未可知？ 中国京剧戏考 《赤壁鏖兵》【八本】 4"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "丞相小心了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我知道。"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "听说是来了关美髯， 忽然一计上眉间， 走向前把礼见， 许昌一别君侯有几年。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启爷：曹操到。"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "耳边厢又听得人厮马闹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上高台。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊，君侯请了。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "皱蚕眉睁凤眼仔细观瞧。 狭路上莫不是冤家来到，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你我乃旧日故交，今逢怎说“冤家”二字？"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "奉军命谁认你旧日故交。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗐，我曹操倒运，这样的好朋友，都不认了。哎呀，罢了罢了。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "汉朝中论奸雄就是曹操，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "岂敢岂敢。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "他一派假殷勤笑内藏刀。 俺今日用命时你何须发笑？ 奉军命捉拿你谁肯恕饶。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "曹孟德听一言满脸赔笑， 尊一声汉君侯细听根苗： 下江南领八十三万人马不少， 实指望扫江东得胜还朝。 又谁知小周郎多端计巧， 烧得我主将们无处奔逃。 只剩下一十八骑残兵来到， 望君侯念旧情放我奔逃。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小校查来。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "曹操人马站齐了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同站。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "一五，一十，十五，一、二、三。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我也是在数的。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启爷！连曹操在内，共有一十八骑残兵败将。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不多？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "不多。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不少？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "不少。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师啊，军师！你枉能会算，却不能所料。慢说他一十八骑残兵败将，他就是 十八只猛虎，我何惧哉！"
        },
        {
          "character": "关羽",
          "type": "西皮过板",
          "text": "料着他好一似鱼儿吞钓，⑶ 伤弓鸟纵插翅也难脱逃。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "想当初待君侯恩高义好， 上马金下马银酒宴多姣； 官封你汉寿亭侯爵禄不小， 望君侯释放我性命一条。"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "你虽然待我的恩高义好， 我也曾报过你十大功劳。 中国京剧戏考 《赤壁鏖兵》【八本】 5 斩颜良诛文丑立功报效， 将印信挂高梁封金辞曹。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "我也曾送文凭差人去到， 临行时在灞桥赠君红袍。"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "休提起送文凭令人可恼， 杀孔秀刺孟坦王植被枭； 诛卞喜斩秦琪文凭才到， 谢丞相空人情不在心梢。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "在灞桥许下我云阳相报， 你本是大丈夫怎忘故交？ 你许饶曹三不死， 为何不饶这头一遭。"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "非是我忘却了云阳相报， 因为你这奸雄罪恶难逃。 在许田射鹿时把君欺藐， 挟天子令诸侯势压群僚。 逼死了董贵妃其罪非小， 你这奸贼起逆心欲篡汉朝。 恨不得拿住了剥皮剪草， 来来来受吃我青龙钢刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓用刀指。曹操哭。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "曹孟德马上泪涟涟， 尊一声汉寿亭侯听我言： 往日里恩情无半点， 百般哀告也枉然。 杀曹操不过污秽一席地， 你枉有个名儿天下传。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "往日里杀人不眨眼， 铁打心肠软如棉。 背地里只把军师怨， 前思后想是枉然。 罢罢罢关某岂作无义汉， 宁可人头挂高杆。 叫小校摆下一字长蛇阵， 释放曹贼回中原。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎么变了卦了？ 来，看看甚么阵势？"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "此乃一字长蛇大阵。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀好了！君侯有释放你我之心，走了吧！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "多蒙君侯施恩典， 才得活命回中原。 老天若遂我的愿， 整顿人马再下江南。 中国京剧戏考 《赤壁鏖兵》【八本】 6"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "不要来了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "君侯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽拱手。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我不来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同下。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "曹操逃走。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "回营交令哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖望家乡〗。"
        },
