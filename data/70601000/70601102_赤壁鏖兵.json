        {
          "character": "张昭、步骘、蒋综、陆绩",
          "type": "同白",
          "text": "千千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "有何事议？"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "闻得主公将兴兵与曹争锋，主公自思比袁绍如何？曹操向日兵微将寡，尚能克 复袁绍；何况今日拥百万之众南征，岂可轻敌？主公若听诸葛亮之言，妄动甲 兵，此谓负薪救火也。"
        },
