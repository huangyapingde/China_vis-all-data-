          "type": "西皮摇板",
          "text": "同胞弟到江东未曾会过， 做说客犹恐怕枉费唇舌。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "贤弟哪里？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "兄长吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮哭拜。"
