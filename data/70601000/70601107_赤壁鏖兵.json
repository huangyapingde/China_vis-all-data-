          "character": null,
          "type": "stage",
          "text": "四文堂、四下手、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀，好烧哇，好烧！ 来此什么所在？"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "来此乌林。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "哎，丞相何故大笑？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吾不笑别人，吾笑的是周瑜少智，诸葛亮无谋。此处山川险峻，树木丛杂。若 老夫用兵，在这里埋伏一军，如之奈何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鼓声。曹操惊。四白文堂、四上手、赵云同上。张郃架住。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "呔！曹兵休走，赵子龙在此。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "杀呀！ （赵云刺曹操下。张郃架住，起大战。四文堂、四下手、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、 于禁同败下。赵云、四白文堂、四上手同追下。）"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四大铠、张飞同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！好杀呀好杀！赵云又来了，又伤孤大半人马。 众将，这是什么地方？ 中国京剧戏考 《赤壁鏖兵》【七本】 7"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "乃是葫芦口。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "哎丞相，方才在乌林发笑，笑出一个赵云来，伤了大半人马。此处又来发笑， 不要笑出祸来。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吾笑周瑜、孔明，毕竟智谋不足。若老夫用兵，此地也要埋伏他一彪人马，以 逸待劳。我等纵然逃脱性命，也难逃此危险。彼见不到，为此笑之。你看这雨 过天晴，此处倒也僻静，正好埋锅造饭哪。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "着哇！吃饱了，也好趱路。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将官，埋锅造饭。"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "呔，曹贼休走，你三爹爹在此啊！ （四下手、许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁、曹操同惊跑下，张飞领四蓝文堂、四大 铠同追上，过场，同下。）"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（曹操上，张飞追杀上，许褚上，架住，救曹操下。接打下手攒，许褚、张辽、曹仁、夏侯惇、张郃、文聘、"
        },
        {
          "character": null,
          "type": "text",
          "text": "毛阶、于禁丢盔卸甲同败下。张飞追下。）"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁同七零八落上，同挖门，曹操涂面上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀，好杀呀，好杀！怎么张飞也来了？哎！好厉害的诸葛亮啊！ 来，看看还有多少人马？"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "一十八骑！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嘿！想老夫，统领八十三万人马大下江南，至今一战，只剩一十八骑残兵败将。 中国京剧戏考 《赤壁鏖兵》【七本】 8"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "唯！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嘿嘿，我是万没有想到啊！ 来，吾兵直奔南郡，从哪条路上好走？"
        },
        {
          "character": "张辽、许褚",
          "type": "同白",
          "text": "大路稍平却远五十里。小路可投华容道，却近五十里。只是地窄路险，坑坎难 行。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "如今走近不走远。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "烟火。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "小路数处烟墩，恐有埋伏，大路并无动静。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待吾看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "烟火。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗐，这又是那妖道诡计。岂不闻兵书有云：“虚则实之，实则虚之。”诸葛亮 多谋，故使人于山僻烧烟，使吾军不敢从这条路上走，他却埋兵在大路。吾料 已定，偏不教中他人之计。你我投奔华容道而走。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "众军无粮。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "乡村去抢。"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "马力尽乏，众军难行。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎，老夫令出山动，违令者斩！"
        },
        {
          "character": "许褚、张辽、曹仁、夏侯惇、张郃、文聘、毛阶、于禁",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "不要哦了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
