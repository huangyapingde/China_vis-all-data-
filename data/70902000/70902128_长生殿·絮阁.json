{
  "script_id": "70902128",
  "title": "长生殿·絮阁",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "唐明皇",
      "hangdang": "冠生"
    },
    {
      "name": "杨贵妃",
      "hangdang": "五旦"
    },
    {
      "name": "高力士",
      "hangdang": "丑"
    },
    {
      "name": "永新",
      "hangdang": "贴旦"
    }
  ],
  "plot": "唐明皇宠爱杨贵妃后，冷淡了梅妃。一夕，偶召梅妃，重叙旧情。杨贵妃赶至，唐明皇托词有恙，需要静养。\n但被杨贵妃发觉了翠钿、凤舄，揭穿真相，于是惹下了爱情风波。唐明皇无奈，只得自认错误，好言慰之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高力士上。"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "自闭昭阳春复秋，罗衣湿尽泪还流。一种蛾眉明月夜，南宫歌舞北宫愁。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "咱家高力士，向年奉使闽粤，选得江妃进御，万岁爷十分宠幸，因她性爱梅花， 赐号梅妃，宫中都称为梅娘娘。自从杨娘娘入侍之后，宠爱日夺，万岁爷竟 将为她迁之上阳宫东楼。昨夜忽然托疾，宿于翠华西阁，遣小黄门密召到来， 戒饬宫人，不得传与杨娘娘知道，命咱在阁前看守。此时天色黎明，恐要送梅 娘娘回宫，咱只得在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高力士下。杨贵妃上。"
        },
        {
          "character": "杨贵妃",
          "type": "醉花阴",
          "text": "一夜无眠乱愁搅， 未拔白潜踪来到。 往常见红日影弄花梢， 软哈哈春睡难消， 犹自压绣衾倒。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "今日呵。"
        },
        {
          "character": "杨贵妃",
          "type": "醉花阴",
          "text": "可为甚凤枕急忙抛？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高力士上。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "咦！那边来的，好似杨娘娘，莫非走漏消息？这便怎么处？"
        },
        {
          "character": "杨贵妃",
          "type": "醉花阴",
          "text": "单只为那筹儿撇不掉。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢高力士叩见娘娘，愿娘娘千岁。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "高力士。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "万岁爷呢？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "在阁中。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "还有何人在内？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "这，没有。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "既没有人，你且开了阁门，待我进去。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "娘娘请暂坐，待奴婢一言告禀。万岁爷昨夜呵！"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "唔？"
        },
        {
          "character": "高力士",
          "type": "画眉序",
          "text": "只为政勤劳， 偶尔违和厌烦恼，"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "既是圣体违和，怎生在此驻宿？"
        },
        {
          "character": "高力士",
          "type": "画眉序",
          "text": "爱清幽西阁暂息昏朝。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "在里面做什么？"
        },
        {
          "character": "高力士",
          "type": "画眉序",
          "text": "偃龙床静养神疲，"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "你在此则甚？"
        },
        {
          "character": "高力士",
          "type": "画眉序",
          "text": "守玉户不容人到。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "你敢不容我进去么？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "这……奴婢怎敢？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "哫！"
        },
        {
          "character": "高力士",
          "type": "画眉序",
          "text": "只因亲奉君王命， 量奴婢敢行违拗？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "哫！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "喳！"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杨贵妃",
          "type": "喜迁莺",
          "text": "休得把虚脾来掉， 休得把虚脾来掉。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢怎敢？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "杨贵妃",
          "type": "喜迁莺",
          "text": "嘴喳喳弄鬼装妖， 焦也波焦！ 急得咱满心越恼。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "我晓得！"
        },
        {
          "character": "杨贵妃",
          "type": "喜迁莺",
          "text": "别有个人儿挂眼梢， 倚着她宠势高。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "杨贵妃",
          "type": "喜迁莺",
          "text": "你明欺俺失恩人时衰运倒。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "杨贵妃",
          "type": "喜迁莺",
          "text": "俺只待自把门敲， 俺只待自把这门敲！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "娘娘请息怒，待奴婢去叩门。 唦！谁在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫娥随唐明皇、梅妃同上。"
        },
        {
          "character": "宫娥",
          "type": "白",
          "text": "是谁叩门？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "杨娘娘在此，快些开门！"
        },
        {
          "character": "宫娥",
          "type": "白",
          "text": "请稍待。 吓，万岁爷醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇哈欠。"
        },
        {
          "character": "唐明皇",
          "type": "画眉序",
          "text": "何事语声高？ 募地将人梦惊觉。"
        },
        {
          "character": "宫娥",
          "type": "白",
          "text": "启万岁爷，杨娘娘在外。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "唐明皇",
          "type": "画眉序",
          "text": "这春光漏泄，怎地开交？"
        },
        {
          "character": "宫娥",
          "type": "白",
          "text": "这门开也不开？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "且慢！梅妃夹幕中，暂躲片时。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅妃下。"
        },
        {
          "character": "宫娥",
          "type": "白",
          "text": "吓，万岁爷吓！"
        },
        {
          "character": "宫娥",
          "type": "画眉序",
          "text": "黄金屋恁样藏娇， 葡萄架霎时推倒。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宫娥！"
        },
        {
          "character": "唐明皇",
          "type": "画眉序",
          "text": "朕和衣假寐佯推睡， 顺索把兽环开了。"
        },
        {
          "character": "宫娥",
          "type": "白",
          "text": "领旨。 奉旨开阁门！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "门开了，请娘娘进去。杨娘娘……"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "哫！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "到。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "妾闻陛下圣体违和，特来问安。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "寡人偶然身子不快，未及进宫，何劳妃子清晨到此？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下致疾之由，妾倒猜着几分了。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子猜着何来？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "哪！"
        },
        {
          "character": "杨贵妃",
          "type": "出对子",
          "text": "都只为相思萦绕，"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "相思？吓哈哈哈！哪有此事？"
        },
        {
          "character": "唐贵妃",
          "type": "出对子",
          "text": "为着个意中人把心病挑。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "寡人意中人，除了妃子，还有何人？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "妾哪里当得陛下意中人来？陛下向来宠爱梅精，何不宣召她来，以慰圣心牵挂？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "此女久置东楼，哪有复召之理？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下休要瞒妾了！"
        },
        {
          "character": "杨贵妃",
          "type": "出对子",
          "text": "俏东君春心偏向小梅梢， 单只待，单只待望着梅来把渴消。 既不沙，"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "杨贵妃",
          "type": "出对子",
          "text": "只问恁是谁把那珍珠去慰寂寥？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子休得多心，寡人昨夜呵！"
        },
        {
          "character": "唐明皇",
          "type": "滴溜子",
          "text": "偶只为微疴，暂息静俏。 恁兰心蕙性，漫多度料， 把人无端奚落。 我神虚懒应酬，相逢话言少。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子！"
        },
        {
          "character": "唐明皇",
          "type": "滴溜子",
          "text": "请暂返香车，容我睡饱。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "咦？这御榻底下不是一只凤舄么？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "喏、喏、喏！又是一朵翠钿。此皆妇人之物，陛下既然独寝，怎得有此？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "好奇怪。 高力士！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "这是哪里来的？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "咦？这是哪里来的？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "寡人不解吓！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "连奴婢也不解！"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下怎么说不解吓？"
        },
        {
          "character": "杨贵妃",
          "type": "刮地风",
          "text": "嗳呀！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "其实不解。 高力士！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "这又奇了！"
        },
        {
          "character": "杨贵妃",
          "type": "刮地风",
          "text": "御榻森严宫禁遥，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "这又奇了！"
        },
        {
          "character": "杨贵妃",
          "type": "刮地风",
          "text": "早难道有神女飞渡嗳冲霄？ 只何这两般儿信物是何人掉？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "昨夜谁侍殿下寝来？"
        },
        {
          "character": "杨贵妃",
          "type": "刮地风",
          "text": "可怎生般凤友鸾交？ 到日三杆犹不临朝？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "外人不知呵，"
        },
        {
          "character": "杨贵妃",
          "type": "刮地风",
          "text": "多说是殢君王是我这庸姿劣貌， 哪知道恋欢娱别有个雨窟云巢！"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "请陛下早出视朝，妾在此候驾回宫。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "寡人有恙，不能视朝了。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "杨贵妃",
          "type": "刮地风",
          "text": "虽则是蝶梦酣，鸳浪翻，春情颠倒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇哈欠。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杨贵妃",
          "type": "刮地风",
          "text": "他困迷离精神难打熬。 怎负他凤墀前鹄立嗳群僚？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子既劝寡人视朝，朕只得勉强出去。 高力士！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "你在此伺候娘娘回宫！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "摆驾！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "唦！ 摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "唐明皇",
          "type": "念",
          "text": "风流惹下风流苦，不是风流总不知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监随唐明皇同下。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢送驾。不免溜了吧！"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "高力士！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "咦，又在那里叫了！ 娘娘，奴婢在。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "好吓！你瞒我做的好事！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢没有瞒着娘娘，做甚么事来。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "我且问你，这翠钿凤舄，是哪里来的？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "这么……"
        },
        {
          "character": "高力士",
          "type": "滴滴金",
          "text": "告娘娘省可闲烦恼， 百纵千随真是多少。 莫说梅亭旧日恩情好， 就是六宫中新窈窕， 也只合佯装不晓， 直恁的破工夫多计较！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "不是奴婢擅多敢嘴，如今满朝臣宰，谁没个大妻小妾？就是富室豪门，也有个 侍婢通房哩！"
        },
        {
          "character": "杨贵妃",
          "type": "哭",
          "text": "何况九重就容不得这宵？"
