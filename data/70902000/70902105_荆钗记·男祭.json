{
  "script_id": "70902105",
  "title": "荆钗记·男祭",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "王十朋",
      "hangdang": "冠生"
    },
    {
      "name": "王母",
      "hangdang": "老旦"
    },
    {
      "name": "李成",
      "hangdang": "末"
    }
  ],
  "plot": "钱玉莲抗拒改嫁，投江自尽，但被钱载和所救。王十朋母子不知其遇救之事，以为她已葬身水底，故在清明\n时节，备礼祭奠之。",
  "notes": "此戏在舞台上很少演出，曲会的清唱中偶或有之。官生的〖北双调折桂令〗用赠板，是一个绝无仅有的特殊\n例子，可与《牡丹亭·硬拷》、《西楼记·错梦》等戏的同牌曲调，比较参考，以见其风格的异同，作为研\n究资料。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王母上。"
        },
        {
          "character": "王母",
          "type": "破阵子引",
          "text": "细雨霏霏时候，柳眉烟锁长愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王十朋上。"
        },
        {
          "character": "王十朋",
          "type": "破阵子引",
          "text": "昨夜东风蓦吹透，报道桃花逐水流。"
        },
        {
          "character": "王母、王十朋",
          "type": "同破阵子引",
          "text": "新愁惹旧愁。"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": "母亲拜揖。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "王母",
          "type": "念",
          "text": "极目家乡远，白云天际头。"
        },
        {
          "character": "王十朋",
          "type": "念",
          "text": "五年离故里，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成上。"
        },
        {
          "character": "王十朋",
          "type": "念",
          "text": "洒泪湿征裘。"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": "告母亲知道。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "起来说。"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": "是。孩儿昨夜，梦见媳妇，扯住孩儿衣袂，说道十朋吓，十朋，我只与你同忧， 不与你同乐。醒来却是南柯一梦。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "敢是媳妇与你讨祭了。"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": "孩儿祭礼已备，请母亲主祭。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "吓！啊呀媳妇儿吓！"
        },
        {
          "character": "王母",
          "type": "念",
          "text": "非是儿夫负你情，只因奸相妒良姻。生前淑性甘贞洁，死后阴魂脱世尘。 餐玉馔，饮瑶樽，水晶宫里伴仙人。待你儿夫任满朝金阙，与你伸冤奏紫宸。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "儿吓，你去祭罢。"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": "是，孩儿告祭了。 吓！啊呀妻吓！我与你好似巫山一片云，秦岭一堆雪，阆苑一枝花，瑶台一轮 月。到如今，云散雪消，花残月缺，好不伤感人也！"
        },
        {
          "character": "王十朋",
          "type": "新水令",
          "text": "一从科第凤鸾飞， 被奸谋有书空寂。 幸萱堂无祸危， 痛兰房受岑寂， 捱不过凌逼。 啊呀妻吓！ 恁身沉在浪涛里！"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "王母",
          "type": "步步娇",
          "text": "将往事今朝重提起，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "李成",
          "type": "白",
          "text": ""
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": ""
        },
        {
          "character": "王母",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "步步娇"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": ""
        },
        {
          "character": "李成",
          "type": "白",
          "text": ""
        },
        {
          "character": "王十朋",
          "type": "折桂令",
          "text": " 越恼得肝肠碎。 省却愁烦，且自酬醴。 李舅看酒。 有酒。 卑幼之丧，何劳母亲奠酒？ 儿吓！ 我不与祭如不祭。 李舅看香！ 有。 昭告灵魂，听剖因依。 俺只为撇不下糟糠 苦推辞桃杏新室。 改调俺在潮阳，啊呀妻吓！ 因此上耽误了恁的归期。"
        },
        {
          "character": "清明祭扫时、须记得圣贤书道、爇沉檀香喷金猊、自从俺宴罢瑶池、宫袍宠赐、相府把俺勒赘、𠮾旧妻、致受磨折、王母",
          "type": "江儿水",
          "text": "听说罢衷肠事，只为伊， 却原来不从招赘生奸计。 凌逼得你好没存济。 早赐灵魂来至。"
        },
        {
          "character": "懊恨娘行忒薄义、母子虔诚遥祭、望鉴微忱、王十朋",
          "type": "白",
          "text": "李舅看酒。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "有酒。"
        },
        {
          "character": "王十朋",
          "type": "雁儿落带得胜令",
          "text": "徒捧着泪盈盈一酒巵， 诉衷曲无回对。 重会面是何时？ 舒不开咱两道眉。 先室！𠲔！ 恨只恨套书信的贼施计。 贤妻！ 俺若是昧诚心自有天鉴知！ 啊呀，昧诚心自有天鉴知！"
        },
        {
          "character": "空列着香馥馥八珍味、慕音容不见伊、呀！俺这里再拜自追思、揾不住双垂泪、王母",
          "type": "侥侥令",
          "text": "不是爹行没主意， 好夫妻中路里。"
        },
        {
          "character": "是你继母太心欺、贪恋富室豪门财和礼、抛闪得好夫妻中路里、王十朋",
          "type": "收江南",
          "text": "呀！ 谁待要赴春闱？ 便做到腰金衣紫待何如？ 说来的话儿， 又恐怕外人知端的， 倒不如布衣，布衣， 啊呀妻吓！ 只索要低声啼哭自伤悲！"
        },
        {
          "character": "早知道这般样拆散呵、王母",
          "type": "园林好",
          "text": "免愁烦回辞了奠仪。"
        },
        {
          "character": "早知道这般样拆散呵、王母",
          "type": "白",
          "text": "啊呀媳妇儿吓！我本待要拜你一拜，恐你消受不起。罢！"
        },
        {
          "character": "早知道这般样拆散呵、王母",
          "type": "园林好",
          "text": "只得拜冯夷， 多加些护持。 早早向波心脱离， 惟愿取免沉溺， 惟愿取免沉溺。"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": "李舅化纸。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "王十朋",
          "type": "沽美酒",
          "text": "纸钱飘，蝴蝶飞， 纸钱飘，蝴蝶飞。 血泪染，杜鹃啼，"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "儿吓，将媳妇绣鞋也焚了罢。"
        },
        {
          "character": "王十朋",
          "type": "沽美酒",
          "text": "睹物伤情越惨凄。 灵魂儿恁自知， 俺不是负心的， 负心的随着灯灭， 花谢有芳菲时节， 月缺有团圆之夜。 俺呵， 徒然间早起晚息， 想伊家念伊。 啊呀妻吓！ 要相逢除非是梦儿里， 和你再成姻契。"
        },
        {
          "character": "王母、王十朋",
          "type": "同尾声",
          "text": "昏昏默默归何处？ 哽哽咽咽常念你，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成下。"
        },
        {
          "character": "王母、王十朋",
          "type": "同尾声",
          "text": "直上嫦娥宫殿里。"
        },
        {
          "character": "王母",
          "type": "念",
          "text": "年年此日须当祭，"
        },
        {
          "character": "王十朋",
          "type": "念",
          "text": "岁岁今朝不可迟。"
        },
        {
          "character": "王母",
          "type": "念",
          "text": "天长地久有时尽，"
        },
        {
          "character": "王十朋",
          "type": "念",
          "text": "此恨绵绵无绝期。"
        },
        {
          "character": "王母",
          "type": "白",
          "text": "随我进来。"
        },
        {
          "character": "王十朋",
          "type": "白",
          "text": "是。 啊呀妻吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王母、王十朋同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}