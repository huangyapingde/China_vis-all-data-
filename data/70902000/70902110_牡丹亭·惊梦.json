{
  "script_id": "70902110",
  "title": "牡丹亭·惊梦",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "杜丽娘",
      "hangdang": "五旦"
    },
    {
      "name": "柳梦梅",
      "hangdang": "巾生"
    },
    {
      "name": "春香",
      "hangdang": "贴旦"
    },
    {
      "name": "杜母",
      "hangdang": "老旦"
    }
  ],
  "plot": "杜丽娘游园归来假寐，梦中见一秀才，两情缱绻，醒后回想梦境，犹萦思不已。",
  "notes": "《牡丹亭》传奇是明代大戏剧家汤显祖的名著，寓有个性解放的启蒙思想，影响极大，为世界文坛所推崇。\n《游园、惊梦》两折富有浪漫主义色彩，文词、曲调、舞蹈三者完美地结合在一起，成为昆曲代表作之一，\n至今仍是舞台上经常演出的剧目。俞振飞与梅兰芳先生合作次数最多，并于1960年摄制了电影。\n剧中“堆花”一段，原本用〖画眉序〗曲牌也有用〖大红袍〗的，实是“咏花”。原有花神、梦神上场，今\n已大都不用，故删。有些欠妥的曲文和有些旋律，俞振飞与梅兰芳演出时作了修改，附在末尾，以供参考。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杜丽娘上。"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "蓦地游春转，小试宜春面。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春吓春！"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "得和你两留连，春支如何遣？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "咳，恁般天气，好困人也！"
        },
        {
          "character": "杜丽娘",
          "type": "山坡羊",
          "text": "没乱里春情难遣， 蓦地里怀人幽怨。 则为俺生小婵娟， 拣名门一例一例里神仙眷。 甚良缘，把青春抛的远。 俺的睡情谁见？ 则索因循腼腆。 想幽梦谁边， 和春光暗流转？ 迁延，这衷怀哪处言？ 淹煎，泼残生除问天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖万年欢〗。杜丽娘入梦。花神引杜丽娘、柳梦梅同上，相见。〖曲牌收〗。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓姐姐！小生哪一处不寻到，却在这里。恰好在花园内，折得垂柳半枝。姐姐， 你既淹通诗书，何不作诗一首，以赏此柳枝乎？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "那生素昧平生，因何到此？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "姐姐，咱一片闲情，爱煞你哩！"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "则为你如花美眷， 似水流年， 是答儿闲寻遍？ 在幽闺自怜。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "姐姐，和你那答儿讲话去。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "哪！"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "转过这芍药栏前， 紧靠着湖山石边。 和你把领扣松，衣带宽， 袖梢儿揾着牙儿苫，也。 则待你忍耐温存一晌眠。"
        },
        {
          "character": "柳梦梅、杜丽娘",
          "type": "同山桃红",
          "text": "是哪处曾相见？ 相看俨然，早难道好处相逢无一言。⑴"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖万年欢〗。柳梦梅、杜丽娘同下。〖曲牌收〗。"
        },
        {
          "character": "众花神",
          "type": "内同画眉序",
          "text": "好景艳阳天，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖一枝花〗。众花神同上，站定。〖曲牌收〗。"
        },
        {
          "character": "众花神",
          "type": "同画眉序",
          "text": "万紫千红尽开遍。 满雕栏宝砌，云簇霞鲜。 督春工珍护芳菲，免被那晓风吹颤， 使佳人才子少系念， 梦儿中也十分欢忭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。"
        },
        {
          "character": "众花神",
          "type": "同滴溜子",
          "text": "湖山畔，湖山畔，云蒸霞焕。 雕栏外，雕栏外，红翻翠骈。 惹下蜂愁蝶恋， 三生锦绣般非因梦幻。 一阵香风，送到林园。 及时的，及时的，去游春，莫迟慢。 怕罡风，怕罡风，吹得了花零乱， 辜负了好春光，徒唤枉然，徒唤了枉然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。"
        },
        {
          "character": "众花神",
          "type": "同五般宜",
          "text": "一边儿燕喃喃软又甜， 一边儿莺呖呖脆又圆。 一边蝶飞舞，往来在花丛间， 一边蜂儿逐趁，眼花撩乱。 一边红桃呈艳， 一边绿柳垂线。 似这等万紫千红齐装点， 大地上景物多灿烂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖万年欢〗。众花神同下。柳梦梅、杜丽娘同上。〖曲牌收〗。"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "这一霎天留人便， 草藉花眠。 则把云鬟点， 红松翠偏。 见了你紧相偎，慢厮连， 恨不得肉儿般和你团成片，也。 逗的个日下胭脂雨上鲜。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "妙！"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "我欲去还留恋， 相看俨然， 早难道好处相逢无一言。⑵"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "姐姐，你身子乏了，将息片时，小生去也。正是："
        },
        {
          "character": "柳梦梅",
          "type": "念",
          "text": "行来春色三分雨，"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "秀才！"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "在！妙吓！"
        },
        {
          "character": "柳梦梅",
          "type": "念",
          "text": "睡去巫山一片云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳梦梅下。杜母上。"
        },
        {
          "character": "杜母",
          "type": "念",
          "text": "夫婿坐黄堂，娇娃立绣窗。怪她裙衩上，花鸟绣双双。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "我儿原来昼眠在此。 我儿！我儿！"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "秀……"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "儿吓！娘在此。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "原来是母亲。母亲万福。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "罢了。你方才说什么“秀”？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "吖，孩儿剌绣才罢。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "为何昼眠在此？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "告母亲知道：适才花园中游玩回来，不觉身子困倦，少睡片时。不知母亲到来， 有失迎接，望母亲恕罪。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "怎么不到学堂中去看书？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "先生不在，且自消停。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "儿吓，花园冷静，少去闲游。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "谨依母亲慈训。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "女儿家长成了，就有许多情态。且自由她，我去了。正是："
        },
        {
          "character": "杜母",
          "type": "念",
          "text": "宛转随儿女，"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "孩儿送母亲。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "杜母",
          "type": "念",
          "text": "辛勤做老娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜母下。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "娘吓！你教孩儿看书，不知哪一种书才消得我闷怀吓！"
        },
        {
          "character": "杜丽娘",
          "type": "绵搭絮",
          "text": "雨香云片， 才到梦儿边。 无奈高堂， 唤醒纱窗睡不便。 泼新鲜， 俺的冷汗粘煎， 闪的俺心悠步軃， 意软鬟偏。 不争多费尽神情， 坐起谁忺，则待去眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "春香上。"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "花深留翠钿，茶熟带红妆。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "啊小姐，绣被已熏，请小姐安睡去吧。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "搀我来！"
        },
        {
          "character": "杜丽娘",
          "type": "尾声",
          "text": "困春心，游赏倦， 也不索香薰绣被眠。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春吓！"
        },
        {
          "character": "杜丽娘",
          "type": "尾声",
          "text": "有心情那梦儿还去不远。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜丽娘下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "杜丽娘",
          "type": "stage",
          "text": "—————————— ⑴〖山桃红〗改词。"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "转过这芍药栏前， 紧靠着湖山石边。 我和你手相携，行并肩， 眼梢儿待共春情展，也。 则怕那花气熏人醉欲眠。"
        },
        {
          "character": "柳梦梅、杜丽娘",
          "type": "同山桃红",
          "text": "是哪处曾相见？ 相看俨然，早难道好处相逢无一言。 ⑵〖山桃红〗改词。"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "这一霎天留人便， 草藉花眠， 则把云鬟点， 红松翠偏。 见了你紧相随，慢厮连， 一似那好花连理开成片，也。 逗得个柳眼梅心别样妍。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "妙！"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "我欲去还留恋， 相看俨然， 早难道好处相逢无一言。"
        }
      ]
    }
  ]
}