{
  "script_id": "70902122",
  "title": "狮吼记·梳妆",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "陈季常",
      "hangdang": "巾生"
    },
    {
      "name": "柳氏",
      "hangdang": "五旦"
    },
    {
      "name": "苏院公",
      "hangdang": "付"
    }
  ],
  "plot": "陈季常应苏东坡游春之约，其妻柳氏恐夫冶游，约定如有妓陪伴将施以杖责。",
  "notes": "宋代诗人苏轼（字子瞻，号东坡）赠其好友陈慥（字季常，别号方山子）诗有句云：“忽闻河东狮子吼，拄\n杖落地心茫然。”诗意原是引用佛家典故，说陈季常好佛，听到讲解教义，好似狮子吼声的振聵发聋，手里\n拄杖堕地，思想上茫然若失。明代剧作家汪廷讷把这两句诗附会虚构为陈季常惧内的故事，写成了《狮吼记》\n传奇。\n在《梳妆、跪池》之间，还有一出《游春》，可以连演，也可省略。这是两出喜剧，舞台演出比较生动，但\n有宣扬“夫纲”的糟粕，以及列举妒妇的例子，冷僻难懂，今已分别作了修改。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈季常上。"
        },
        {
          "character": "陈季常",
          "type": "引子",
          "text": "谈空说有遇名僧，看破浮生，了悟浮生。"
        },
        {
          "character": "陈季常",
          "type": "念",
          "text": "老天生我意如何？受尽闺中恶折磨。早知今日妻纲肃，何苦当初作丈夫？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "卑人陈慥字季常。曾在东坡家雪堂，得遇佛印禅师，谬结同心之契，常聆出世 之谈，欲仗人士因缘，消我前生孽债。咳！茫茫苦海，堕落堪虞;泛泛慈航， 皈依颇切。怎奈我妻……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈季常嗽。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "妻房柳氏，生性跷蹊，遽难化悔，我只得甘心忍耐。今已辰牌时分，不知娘子 起身否？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳氏内嗽。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "言之未已，娘子出来了，只索整衣而待。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳氏哈欠上。"
        },
        {
          "character": "柳氏",
          "type": "引子",
          "text": "朦胧春梦莺啼醒，绿窗外日移花影。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "喂，鹦哥！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喂，鹦哥！"
        },
        {
          "character": "柳氏",
          "type": "念",
          "text": "春眠不觉晓，处处闻啼鸟。"
        },
        {
          "character": "陈季常",
          "type": "念",
          "text": "夜来风雨声，花落知多少？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "喂，鹦哥！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喂，鹦哥！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "吓？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "吓？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，是。娘子拜揖。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "陈郎，今日出门，为何恁早？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "卑人欲寻东坡谈禅，谁想他先不在家了。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "太早了。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，是，太早了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳氏哈欠。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子，看你云鬓虽乱，意态更妍，恍如宿醒太真，绝胜捧心西子，怎不教人可 爱也！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "我也不要你虚头奉承，只要你实心贴服！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子，我和你呀！"
        },
        {
          "character": "陈季常",
          "type": "懒画眉",
          "text": "似关关匹鸟两和鸣，"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "坐了。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，告坐了。"
        },
        {
          "character": "陈季常",
          "type": "懒画眉",
          "text": "夫唱妻随协气生， 白头相爱还相敬， 我怎忍反目徒伤结发情。"
        },
        {
          "character": "柳氏",
          "type": "懒画眉",
          "text": "幽情贞静博芳名，"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "你做丈夫的，"
        },
        {
          "character": "柳氏",
          "type": "懒画眉",
          "text": "宜室宜家道未行。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "哟！若论刑于之化，卑人其实不让于文王，但恐娘子未如淑女哟！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "吓？哪见得我未如淑女哟！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子，卑人与你取笑呀，怎么认真来介？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "吓？谁与你取笑！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是取笑吓。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "哪个与你取笑吓！"
        },
        {
          "character": "柳氏",
          "type": "懒画眉",
          "text": "都是你做耍成真白取憎！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，是。卑人今后，再不敢取笑了。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "这才便是。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "哟！夫妻么岂是取笑得的？不可吓不可！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "陈郎。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "什么时候了？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，待卑人去看来。巳牌时分了。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "取镜台过来，待我整妆。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，敢不小心？敢不效劳？娘子，镜台犀梳，象牙眉掠，俱已停当，请娘子整 妆，待卑人伺候。"
        },
        {
          "character": "柳氏",
          "type": "懒画眉",
          "text": "轻尘拂去镜光明。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "妙！"
        },
        {
          "character": "陈季常",
          "type": "懒画眉",
          "text": "照得你丰采翩翩百媚生。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "啊呀咦！怎么在背后，做我的鬼脸？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "卑人怎敢做娘子的鬼脸介？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "我明明在镜中看见的，还要抵赖！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喔！我看娘子镜中的影儿，好似对门张……"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "吓！张什么？张什么？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喔，好像对门张家媳妇一般。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "喔，原来你看上了什么张家媳妇，兀自来比我！啊呀咦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳氏打。"
        },
        {
          "character": "柳氏",
          "type": "懒画眉",
          "text": "我把菱花攧破恨难平。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "啊呀又说差了！娘子不要动气，卑人与你打扇如何？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "好吓！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "又被你抢去了！"
        },
        {
          "character": "柳氏",
          "type": "懒画眉",
          "text": "这丹青扇面是何人赠？ 莫不是掷果潘安远寄情？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "这把扇儿，倒也精致，一定是年少风流之物。是哪个与你的？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是个小朋友送与我的。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "小朋友？多少年纪了？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "卑人看他，约有十六吓，十七吓……"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "到底多少？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喔唷，多者十八岁了。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "咳！罢了吓罢了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳氏撕扇。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "啊呀！怎么扯碎了？娘子！"
        },
        {
          "character": "陈季常",
          "type": "懒画眉",
          "text": "你捻酸吃醋全不怕外人听， 书中长舌宜三省。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "三省，三省，打得你投河跳井！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "啊呀，什么说话？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "家人们听者！"
        },
        {
          "character": "柳氏",
          "type": "懒画眉",
          "text": "免使东君喜送迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏院公上。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子不要动气，卑人与你捶背。"
        },
        {
          "character": "苏院公",
          "type": "念",
          "text": "为有看花约，因传折柬来。"
        },
        {
          "character": "苏院公",
          "type": "白",
          "text": "几里是哉，等我叫一声。 喂，陈相公！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子，外面有人，待我出去看来。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "不许去！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "为什么？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "恐怕是小朋友！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，是。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "待我去。"
        },
        {
          "character": "苏院公",
          "type": "白",
          "text": "喂，陈相公！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "啐！是个老佣。 陈郎出去看来。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "卑人不去。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "恐怕是小朋友。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "多讲！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，是。 是哪个？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "我且听一听。"
        },
        {
          "character": "苏院公",
          "type": "白",
          "text": "陈相公，是我。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "原来是苏院公。到此何干？"
        },
        {
          "character": "苏院公",
          "type": "白",
          "text": "奉家爷之命，南郊外花市可观，特请相公一游，并无别客，特邀琴操奉陪。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "噤声！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "陈郎！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喔，来了。"
        },
        {
          "character": "苏院公",
          "type": "白",
          "text": "啥说勿得个？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "你在外边坐坐。"
        },
        {
          "character": "苏院公",
          "type": "白",
          "text": "是哉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏院公下。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "啊呀！“琴操”二字，不知娘子可曾听见？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "陈郎快来！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喔，来了！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "苏学士请我游春，并无别客，帖儿在此。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "唔？我方才听见什么“琴”吓？“操”吓？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "没有什么“成”吓，“要”吓。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "琴操奉陪，如何瞒我？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子听错了。他叫卑人“陈慥”呀。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "我倒好笑，哪有主人请客，反呼客名之理？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子有所不知。卑人向在洛中，曾拜子瞻为兄，兄呼弟名，古之常礼。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "“琴操”一定是妓名。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子，今日游春，无妓无客。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "若有妓，回来，便怎么？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "若有妓……喏！卑人甘心受责。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "既然自招，唔，奈家法无大刑法，也罢！你到间壁去问李大嫂，往常打李大伯"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": ""
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": ""
