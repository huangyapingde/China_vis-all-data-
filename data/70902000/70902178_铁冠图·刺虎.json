{
  "script_id": "70902178",
  "title": "铁冠图·刺虎",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "费贞娥",
      "hangdang": "四旦"
    },
    {
      "name": "李过",
      "hangdang": "大面"
    }
  ],
  "plot": "宫女费贞娥，欲为君报仇，假冒公主，伺机行刺李自成。不想李自成将她赐予一只虎李过成亲。洞房之夜，\n费贞娥假献殷勤，将李过灌醉刺死，然后自刎。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥上。"
        },
        {
          "character": "费贞娥",
          "type": "端正好",
          "text": "蕴君仇，含国恨； 切切地蕴君仇， 愤愤地含国恨。 誓捐躯，要把仇讎手刃！ 因此上苟日贪生一息存。 这就里谁知悯？"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奴家费氏，小字贞娥，从幼选入宫闱，以充嫔御，蒙国母娘娘命我服侍公主。 不想流贼簒夺我国，逼死君父，一家骨肉，吓，死于非命。可笑那些臣子，没 有一个为国家报仇雪耻的。难道如此奇冤极恨，就罢了不成？我想忠义之事， 男女皆可做得。为此我到宫中取了一把匕首，藏于身畔，又假妆公主模样，指 望得近闯贼，杀此巨寇，与君父报仇。谁想反将我赐于兄弟一只虎为配。待他 来时，我自有道理！"
        },
        {
          "character": "费贞娥",
          "type": "滚绣球",
          "text": "俺切着齿点绛唇， 搵着泪施脂粉； 故意儿花簇簇巧梳着云鬓， 锦层层穿着这衫裙。 怀儿里冷飕飕匕首寒光喷， 俺佯姣假媚妆痴蠢， 巧语花言谄佞人。 纤纤玉手剜仇人目， 细细银牙啖贼子心！ 要与那漆肤豫让争声誉， 断臂要离逞智能。 拚得个身为齑粉！ 拚得个骨化飞尘！ 誓把那九重帝主沉冤泄， 四海苍生怨气伸。 方显得大明朝还有个女佳人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "呀，听鼓乐之声，想是此贼来了。我且假装欢笑便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥暗哭下。李过上，四小卒随同上。"
        },
        {
          "character": "李过",
          "type": "念",
          "text": "拓地开疆胆气豪，从龙附凰佐皇朝。龙潜且作赵匡义，有日天心属我曹。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "方才众将道俺，今夜与公主成亲，备了筵宴与俺称贺。俺哪有心情饮酒，被他 们你一杯我一盏，吃得大醉，才得放我回营，好不知趣也！回避！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小卒同下，宫女甲、宫女乙同上。"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "二大王回来了。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主在哪里？"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "在内帐。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "就请相见。"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "公主娘娘有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥上。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "吓，将军。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主请！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军万福。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "哈哈……妙吓，这一福，就酥了俺半边也！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军乃盖世英雄，皇朝梁栋。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "不敢，拙夫不才，怎当公主称羡。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奴家乃亡国之女，不堪侍奉宫闱。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "岂敢！公主乃金枝玉叶，凤女天孙，万望勿嫌愚夫鲁莽，万分之幸！今后内宫 之事，悉听公主掌管。凡有吩咐，小将一一从命。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "吓，将军，夫妇乃人伦之始，当行花烛之礼，合卺之仪，方成大礼。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主言之有理，仕女们撤宴过来，待俺与公主交拜天地！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。定席。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主请！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖曲牌收〗。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "呀，银台上好辉煌也！"
        },
        {
          "character": "费贞娥",
          "type": "脱布衫带叨叨令",
          "text": "银台上煌煌的凤烛燉， 金猊内袅袅的香烟喷。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "和你一夜夫妻百夜恩。"
        },
        {
          "character": "费贞娥",
          "type": "脱布衫带叨叨令",
          "text": "恁道一夜夫妻百夜恩， 试问恁三生石上可有良缘分？ 他则待流苏帐暖洞房春， 高堂月满巫山近， 恁便逗上了蓝桥几层， 还只怕漂漂渺渺的波涛滚。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "费贞娥",
          "type": "脱布衫带叨叨令",
          "text": "恁道是乐煞人也么哥！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "费贞娥",
          "type": "脱布衫带叨叨令",
          "text": "又道是喜煞人也么哥！"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "侍女们，看酒来，待俺回敬公主一杯。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军所赐，奴家敢不从命？要请将军陪奴一大杯。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主要俺陪一大杯，当得的，仕女们斟酒！"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主请！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "干！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李过吐。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "费贞娥",
          "type": "脱布衫带叨叨令",
          "text": "赤紧的蠢不剌沙叱利也学些丰和韵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李过醉。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主，俺醉得紧了，安寝了罢！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "侍女们辛苦了，将酒筵分散她们去罢！"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "也要留几个房中服侍。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "房中自有奴家服侍，教她们去罢！"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "吖，想是公主怕羞，不好就寝。 侍女们！"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "过来谢了公主。 宫女乙"
        },
        {
          "character": "李过",
          "type": "同白",
          "text": "多谢公主娘娘。"
        },
        {
          "character": "宫女甲、李过",
          "type": "白",
          "text": "掌灯！"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "回避！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女甲、宫女乙同下。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军今夜为何还穿此铠甲？"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "不瞒公主说，一向在皇兄帐中护卫，提防奸细，日夜不能卸甲。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "如今天下已定，还虑什么奸细。况今宵乃百年喜日，岂可穿此不祥之服？"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主说得有理，俺正要把身子松动松动，俺唤侍女们来卸甲。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "住了。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "吓？"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "待奴家亲与将军卸甲，才是妇道。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "只是劳动不当。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "费贞娥",
          "type": "脱布衫",
          "text": "除下了铁兜鍪凤翅嶙峋， 放下了宝龙泉偷看利刃。 卸下了𤠯猊铠锁子龙鳞。"
        },
        {
          "character": "松解了狮蛮带玉扣双扪、李过",
          "type": "白",
          "text": "哇呀呀……"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军尊臂为何如此？"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "不瞒公主说，前日在宁武关被遇吉打了一鞭，至今尚未痊愈。哈哈痛死我也！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "原来如此。请将军入帐安息罢！"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "公主也早些睡罢。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奴家除了簪珥，脱了袍服就来。"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "就来吓。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "就来的。"
        },
        {
          "character": "费贞娥",
          "type": "小梁州",
          "text": "除下了翠翘宝髻耳珰瑱， 脱却了凤衮龙氤氲。 防滑褪紧拴起绣罗裙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "费贞娥",
          "type": "stage",
          "text": "费贞娥"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "听听房栊寂寂悄无人， 但闻得戍漏频频。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军，将军呀！"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "我觑，觑着他眯奚醉眼醒还昏， 休惊盹，心窝内宝刀抡。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "贼子看刀！ 李过"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "啊呀。啊呀！"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "钢刀上冤气伸，"
        },
        {
          "character": "李过",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "啊呀，啊呀，呓！"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "银灯下冤家殒。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "叹苍天不佑。"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "不能够把巨寇刃， 嗳，便、便死向泉台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女甲、宫女乙同上。"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "房中为何喧嚷？我们进去看来。吓，这是二大王，为何杀死在地？想是她刺死 的，拿去见大王。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "哫，谁敢？ 宫女乙"
        },
        {
          "character": "费贞娥",
          "type": "同白",
          "text": "啊呀，公主饶命㖸！"
        },
        {
          "character": "宫女甲、费贞娥",
          "type": "白",
          "text": "我非公主。 宫女乙"
        },
        {
          "character": "宫女甲、费贞娥",
          "type": "同白",
          "text": "你是何人？"
        },
        {
          "character": "宫女甲、费贞娥",
          "type": "白",
          "text": "我乃费氏宫人，杀此巨寇，与君父报仇。便将我凌迟碎剐，啊呀，也不畏惧的 㖸！"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "大大王将你许配二大王也不辱没了你，亏你下此毒手！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朝天子"
        },
        {
          "character": "费贞娥",
          "type": "stage",
          "text": "恁道谎阳台雨云， 可知俺女专诸不解江皋韵。 啊呀，遇冤家难含忍。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朝天子"
        },
        {
          "character": "费贞娥",
          "type": "stage",
          "text": "拚得个柳憔花翠， 可也珠残玉损。 啊呀早难道贪恋荣华终天恨。"
        },
        {
          "character": "宫女甲、宫女乙",
          "type": "同白",
          "text": "拿你去见大大王就该死哩！"
        },
        {
          "character": "费贞娥",
          "type": "朝天子",
          "text": "一任他碎骨粉身， 一任他扬灰碾尘！ 今日个含笑归泉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "费贞娥",
          "type": "stage",
          "text": "宫女乙"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同白"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "朝天子"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "费贞娥",
          "type": "stage",
          "text": "宫女乙"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同白"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥自刎下。"
