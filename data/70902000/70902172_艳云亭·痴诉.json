  "plot": "枢密萧凤韶被奸臣王钦若参奏，调征西夏。其女萧惜芬遭迫害，入选制仪司，为虞侯毕泓救出出后，假装疯\n癫，寻到盲卜人诸葛暗，以求庇护。",
  "notes": "正旦、丑主戏。正旦唱〖斗鹌鹑〗北曲一套，曲调悠扬动听，于载歌载舞中表演痴儿情状，独具持色。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "诸葛暗上。"
        },
        {
          "character": "诸葛暗",
          "type": "六幺令",
          "text": "昏昏度年， 终日长街东走西穿。 生涯只靠课儿钱。 嚼得着，叫神仙， 口儿打诨将人骗， 口儿打诨将人骗。"
        },
        {
          "character": "诸葛暗",
          "type": "白",
          "text": "我诸葛暗。自从放走洪秀才，恐怕有啥是非轮到我身上来，不敢出去做生意， 等拉屋里吃，吃得筋疲力尽。现在打听打听，勿听见说起载，只好原出去做做 生意，摆张桌子在官井头，生意到呒啥。 二老官！"
        },
        {
          "character": "老官",
          "type": "内白",
          "text": "先生！"
        },
        {
          "character": "诸葛暗",
          "type": "白",
          "text": "桌子阿摆好拉里哉？"
        },
        {
          "character": "老官",
          "type": "内白",
          "text": "摆好仔半日哉！"
        },
        {
          "character": "诸葛暗",
          "type": "白",
          "text": "今朝生意好点么，多把两个铜钱俚哉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小厮甲、小厮乙同上。"
        },
        {
          "character": "诸葛暗",
          "type": "六幺令",
          "text": "忙寻瓦砖， 惹得痴儿戏耍来顽。"
        },
        {
          "character": "诸葛暗",
          "type": "夹白",
          "text": "痴丫头！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧惜芬上。"
        },
        {
          "character": "萧惜芬",
          "type": "夹白",
          "text": "做什么？"
        },
        {
          "character": "诸葛暗",
          "type": "六幺令",
          "text": "阴沟爬出灶中眠。"
        },
        {
          "character": "诸葛暗",
          "type": "夹白",
          "text": "阿吃糕？微微笑，把头点，"
        },
        {
          "character": "萧惜芬",
          "type": "夹白",
          "text": "吃的，拿来㖸！"
        },
        {
          "character": "诸葛暗",
          "type": "六幺令",
          "text": "牙儿嚼断难吞咽， 牙儿嚼断难吞咽。"
        },
        {
          "character": "诸葛暗",
          "type": "白",
          "text": "打，打，打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小厮甲、小厮乙同下。"
        },
        {
          "character": "诸葛暗",
          "type": "白",
          "text": "㕶笃个星贼种！爹多娘少个格？"
        },
        {
          "character": "萧惜芬",
          "type": "白",
          "text": "你们再来玩耍㖸！"
        },
        {
          "character": "诸葛暗",
          "type": "白",
          "text": "呸！格星贼种，去仔么极好个哉，哪说是再来玩耍㖸！看你痴丫头痴到哪哼仔 歇？"
        },
        {
          "character": "萧惜芬",
          "type": "白",
          "text": "先生，你可是诸葛庙中的先生么？"
        },
        {
