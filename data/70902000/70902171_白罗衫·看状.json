{
  "script_id": "70902171",
  "title": "白罗衫·看状",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "徐继祖",
      "hangdang": "小官生"
    },
    {
      "name": "奶公",
      "hangdang": "外"
    }
  ],
  "plot": "徐继祖得老妪所赠白罗衫，又遇苏夫人诉冤，放告之日，再得苏云诉状。他独自细审状词，难信父亲徐能曾\n为海盗。经奶公证实徐能杀父谋母的真情，方知自己认贼作父，不觉痛彻心肺，决心除奸复仇。",
  "notes": "〖太师引〗为南曲名曲，唱出了徐继祖在看状中的疑惑、思虑。接以大段念白，表现出人物激烈的内心冲突。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐继祖上。"
        },
        {
          "character": "徐继祖",
          "type": "引子",
          "text": "为官承乏愧庸才，按视江南敕旨差。有事挂心怀，只为罗衫难解。"
        },
        {
          "character": "徐继祖",
          "type": "念",
          "text": "巡狩卸征鞍，奸邪透胆寒。上方三尺剑，锋锷保民安。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "下官徐继祖。向日在涿州道上井边遇一妈妈，见了我不胜悲伤。及至问起，说 我像他儿子苏云模样，又诉我始末根由。我曾许访问她儿子媳妇消息。临行时 又把罗衫付我，说有人认得此衫者，便有下落。我因公务碌碌，未完此一桩心 事。不意昨日，在王老先生园中游玩，忽有一妇人向我诉冤，问起情由，却就 是苏公的夫人，方知苏云已被强盗谋害。我想那盗贼虽未缉获，那罗衫一事便 有几分下落了。"
        },
        {
          "character": "徐继祖",
          "type": "解三酲",
          "text": "记当日在井边相会， 那老妈妈诉苦哀哀。 见她千愁万恨思儿态， 把褴褛体困尘埃。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "我因有事，未曾访得她的儿子，不想如今苏夫人又来诉冤。"
        },
        {
          "character": "徐继祖",
          "type": "解三酲",
          "text": "又才得清游偶到王公宅， 偏逢着贫妇当场诉枉来， 愁无奈， 何日得除奸恤寡苦尽甘来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖山坡羊〗。门子上，敲梆。奶公上。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "何人传梆？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "领钥匙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奶公开门。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "门子叩头。请大老爷更衣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐继祖下，更衣，上。门子随徐继祖同出门，奶公关门。门子、徐继祖同入衙门，徐继祖归坐。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "皂隶！"
        },
        {
          "character": "皂隶",
          "type": "内白",
          "text": "吓。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "站堂。"
        },
        {
          "character": "皂隶",
          "type": "内白",
          "text": "吓。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "皂隶出班房！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "皂隶上。"
        },
        {
          "character": "皂隶",
          "type": "白",
          "text": "吓。 皂隶叩头！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "验封。"
        },
        {
          "character": "皂隶",
          "type": "白",
          "text": "原封。领钥匙开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖山坡羊〗。"
        },
        {
          "character": "皂隶",
          "type": "白",
          "text": "开门吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖曲牌收〗。〖一枝花〗。巡捕官、文堂同上。〖曲牌收〗。"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "巡捕官告进！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "进！"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "吓！ 巡捕官叩头！禀大老爷：巡风无事。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "辕门侍候。"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "放告牌抬出。"
        },
        {
          "character": "文堂",
          "type": "白",
          "text": "放告牌抬出！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏云上。"
        },
        {
          "character": "苏云",
          "type": "引子",
          "text": "弥天冤抑向谁论，只恐哀猿不忍闻。"
        },
        {
          "character": "苏云",
          "type": "白",
          "text": "来此已是按院衙门，不免跪门则个。 冤枉！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "跪门者何人？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "跪门者何人？"
        },
        {
          "character": "文堂",
          "type": "白",
          "text": "是告状的。"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "是告状的。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "是告状的。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "取状词。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "取状词。"
        },
        {
          "character": "文堂",
          "type": "白",
          "text": "取状词。"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "取状有了。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "状词呈上！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "“原任兰溪县知县苏云”…… 唔，告状人且回，三日后听审。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "三日后听审！"
        },
        {
          "character": "文堂",
          "type": "白",
          "text": "三日后听审！"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "三日后听审，"
        },
        {
          "character": "苏云",
          "type": "白",
          "text": "是是是，好了。"
        },
        {
          "character": "苏云",
          "type": "念",
          "text": "眼望旌旗捷，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏云下。"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "堂事毕。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "收牌掩门！"
        },
        {
          "character": "巡捕官",
          "type": "白",
          "text": "是，吓。"
        },
        {
          "character": "文堂",
          "type": "白",
          "text": "收牌掩门啰！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巡捕官、文堂同下。〖水龙吟〗。"
        },
        {
          "character": "皂隶",
          "type": "白",
          "text": "交钥匙！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "请大老爷退堂。 （皂隶下。奶公上，开门。徐继祖、门子同进门，徐继祖下，更衣。门子放引、放状，取钥匙交奶公，出门。 奶公关门上闩，奶公下。门子在外上闩，贴封条，下。徐继祖上。曲牌收。以上念白、动作均在曲牌中进 行。）"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "好奇怪，那苏云已被强盗谋害，怎么又来告状？"
        },
        {
          "character": "徐继祖",
          "type": "太师引",
          "text": "看将来此事真奇怪， 这状词教我心中怎猜？"
        },
        {
          "character": "徐继祖",
          "type": "夹白",
          "text": "那苏云呵！"
        },
        {
          "character": "徐继祖",
          "type": "太师引",
          "text": "既道是江心遭害， 怎能向公府伸哀？"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "且看状词如何。 “原任兰溪知县苏云，告为群盗劫杀事：窃云赴任兰溪路，由扬子江中遇盗一 伙，将云推入江心，复又遭巨寇刘权捞救，拘禁山寨一十八载，如今官民剿刘 趁机潜逃得脱羁囚。” 吖，原来苏云不曾死！"
        },
        {
          "character": "徐继祖",
          "type": "太师引",
          "text": "被拘禁绿林山寨， 因此上余生还在。 这冤山仇海反添我闷怀。"
        },
        {
          "character": "徐继祖",
          "type": "夹白",
          "text": "是了。"
        },
        {
          "character": "徐继祖",
          "type": "太师引",
          "text": "须知道察奸伸枉是乌台。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "且看后面如何？ “一门家眷，尽被强盗徐能谋害”…… 徐能！是我父亲的名字，难道我爹爹……哎，岂有此理！"
        },
        {
          "character": "徐继祖",
          "type": "太师引",
          "text": "不信我严亲，"
        },
        {
          "character": "徐继祖",
          "type": "夹白",
          "text": "吓！"
        },
        {
          "character": "徐继祖",
          "type": "太师引",
          "text": "成无赖， 望见状词教我如痴似呆。 既道是江心劫掠将人谋害， 少不得身隐名埋， 为什么堂皇无碍？ 恐还是别有同名在。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "呣，我想天下同名同姓的原因是不少，这个徐能定是他人，休得多疑，唉！休 得胡思乱猜。徐能啊徐能！你这该杀的强盗，怎么偏偏与我爹爹姓名相同，教 我好不心神难定。"
        },
        {
          "character": "徐继祖",
          "type": "太师引",
          "text": "我是承王命身为按台， 君恩重奋拳缚虎怎徘徊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奶公嗽上。"
        },
        {
          "character": "奶公",
          "type": "念",
          "text": "扬子江中水，蒙山顶上茶。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷请坐！老爷请用茶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐继祖吃茶。奶公看状，徐继祖嗽。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "是是是……"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "吓？"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "吖，是是是……"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "这等不小心！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "吖，原来十八年前扬子江中事发了，那苏知县不曾死，有天理吓有天理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奶公下。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "奶公转来！奶公转来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奶公上。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷有何吩咐？"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "老爷有事要问你。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "你是自幼跟随太老爷的呢，还是长大了来的？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老奴是自幼跟随太老爷的。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "我来问你，太老爷姓什么？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "太老爷姓徐吓！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "我老爷呢？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "太老爷姓徐么，老爷自然也姓徐了！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "好，好个也姓徐！太老爷今年多少年纪了？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "六十三岁。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "太夫人呢？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "没有的。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "吓，没有太夫人，我老爷从何而来？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "吖，老奴只知有太老爷，不知有什么太夫人。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "我再问你，太老爷平昔作何生理？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "这……老奴不敢言讲。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "倘被太老爷知道了，怪罪起来，老奴担当不起了！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "不妨，有我在此，讲。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "太老爷呢，原是船户出身，惯在江湖上做些没本钱的买卖。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "什么叫做没本钱的买卖？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "哪哪哪，就是见人家有财有货，白白地搬他回来么，这就叫没本钱的买卖。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "啊呀，咄、咄、咄！好个没本钱的买卖！太老爷平昔可曾害人？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "太老爷作恶多端，老奴也记不得这许多。吖，就把一十八年前揽了苏知县的载……"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "住了！可就是状词上的苏云？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "好，我正要问你，快讲！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷容禀：想当年，太老爷揽了苏知县的载，那苏知县资装，却也有限。那苏 夫人倒有几分姿色。太老爷一见顿起不良之心，把船一行，行至扬子江中，将 苏知县一推，推入江中，把苏夫人抢了回来，逼勒成亲。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "那苏夫人，从也不从？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "好个苏夫人，千贞万烈，抵死不从！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "好，好，像位夫人。后来呢？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "亏了二员外。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "哪个什么二员外？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "就是太老爷的兄弟，名唤徐熊。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "他便怎样？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "假言庆贺，将酒灌醉了太老爷，悄悄开了后门，放苏夫人逃走了！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "吖，太老爷酒醒时，不见了苏夫人，难道就罢了不成？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "太老爷醒来，不见了苏夫人，他就追、追、追吓……"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "追到哪里？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "赶、赶、赶吓……"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "可曾赶着？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "赶到旷野之时，苏夫人赶不着，竟抱……"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "抱什么？抱什么？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "吖，竟、竟、竟跑了回来！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "抱……跑……哆！老狗才，你若不说明白，我将上方砍你的驴头下来！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷请息怒，待老奴说就是了！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "快讲！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "啊呀老爷吓，苏夫人赶不着，竟抱了一个初生婴儿回来！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "唉！哪个问你什么婴儿！我问你此事以后如何？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "此事么无有了。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "人命关天，难道就罢了不成？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "苏知县已死，苏夫人不知去向，此事也只得罢了。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "奶公，此事始末根由，是真是假？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "桩桩是实，句句是真。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "哆！老狗才，徐能杀人越货，你定是同伙人！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老奴怎敢！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "你为何一十八年隐匿不讲？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "非是老奴隐匿不讲，倘说将出来，以奴告主，便要乱棒打死，老奴死不足惜， 怕只怕不能保全一个婴儿的性命。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "哪个婴儿？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "就是十八年前，从旷野之中抱回来的婴儿。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "吖，起来讲。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "是是是…… 记得那年，老爷在涿州道上，遇见一位老妈妈，老妈妈拿出一件白罗衫，老奴 在旁见这白罗衫，与婴儿身上包裹的罗衫一般无二，方知那婴儿便是老妈妈的 孙儿，苏知县亲生之子。老奴说将出来，只怕泄漏机关，被徐能知晓，那婴儿 定然性命难保！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "那婴儿现在何处？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "那婴儿么……"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "他早已长大成人，功成名就出仕皇家，苍天有眼！苏夫人逢凶化吉，院中诉冤， 苏知县死里逃生，衙前告状，罢！老奴愿拼却性命，也要当堂作证。只是一 十八年深仇大恨能否得报，全在这孩儿身上！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "奶公，那苏云之子，莫非她……"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "他、他、他就是老爷你啊！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "吖！不想一十八年，竟认仇为父！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐继祖昏倒。"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷醒来……老爷醒来！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "奶公，奶公啊！你十八年来，养育保全恩重如山，一番苦心我何以为报，你是 我苏门的恩公！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "折杀老奴！老爷请起。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "罗衫现在何处？"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "现在老奴妻子处。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "你连夜赶回，取了那幅罗衫，随即哄骗那伙强盗，前来见我，快去！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老奴遵命，老奴就去！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "奶公转来！奶公转来呀！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷有何吩咐？"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "此事干系重大，你要小心了！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷放心。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "你要保重！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "老爷请回！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "待我拜送！"
        },
        {
          "character": "奶公",
          "type": "白",
          "text": "折杀老奴！"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "快走！快走！快走！"
        },
        {
          "character": "徐继祖",
          "type": "念",
          "text": "堪恨强徒认我儿，谁知冥冥勿相欺。善恶到头终有报，只争来早与来迟。"
        },
        {
          "character": "徐继祖",
          "type": "白",
          "text": "好恼啊好恼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐继祖、奶公同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
