{
  "script_id": "70902102",
  "title": "东窗事犯·扫秦",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "疯僧",
      "hangdang": "丑"
    },
    {
      "name": "秦桧",
      "hangdang": "白面"
    },
    {
      "name": "老和尚",
      "hangdang": "外"
    }
  ],
  "plot": "南宋时奸臣秦桧害死了岳飞父子以后，一次，到杭州灵隐寺进香，遇见一位疯僧，将他与王氏在东窗下设计\n通敌、陷害忠良的前后隐私，一一揭穿，终于狼狈而去。",
  "notes": "剧中指出疯僧是地藏王菩萨的化身，实际是反映了当时人民对这个“莫须有”三字冤狱的极大义愤，具有强\n烈的人民性，因此长期流传在昆剧舞台上。\n此剧旧题《精忠记》，或《如是观》，皆非；实系元孔学诗所作杂剧《东窗事犯》之一折。\n这是昆曲丑角的唱工戏，俞粟庐先生欣赏其曲调之别具风格，所以在俞振飞年幼时就教其学唱了这个戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "老和尚上。"
        },
        {
          "character": "老和尚",
          "type": "念",
          "text": "扫地恐伤蝼蚁命，爱惜飞蛾纱罩灯。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "贫僧乃灵隐寺中主持便是。今日秦丞相到此拈香，只得在此侍候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青袍引秦桧同上。"
        },
        {
          "character": "秦桧、青袍",
          "type": "同出队子",
          "text": "三公之位，自小登科占大魁。 只因前日梦惊疑， 使我心中如醉痴。 灵隐寺修斋虔诚忏悔。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "贫僧迎接相爷。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "罢了。经典可曾诵完？"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "诵完了。请相爷大殿拈香。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "引导！ 第一柱香，愿风调雨顺，国泰民安。第二柱香，愿秦桧夫妇，百年偕老。第三 柱香，愿……"
        },
        {
          "character": "青袍",
          "type": "白",
          "text": "喝！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "卸下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青袍下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊呀佛爷吓！愿岳家父子，早登仙界。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖朝天子〗。秦桧下跪，站起。曲牌收。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "请相爷各处随喜随喜。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "引导！这是什么所在？"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "香积厨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "倒也洁净。壁上有诗，待我看来。"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "“缚虎容易纵虎难，无言终日倚栏杆。男儿两眼凄惶泪，流入襟怀透胆寒。”"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好奇怪！这诗我与夫人在东窗下做的，何人写在此？ 和尚，这诗何人写的？"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "是个远方和尚写的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "如今可在？"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唤过来。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "是。启相爷，此僧有些疯癫，恐冒犯相爷。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "不计较他。快唤过来。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "是。 也十一！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "谁唤我？"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "秦丞相唤你。"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺忙哩。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "甚么忙？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "烧火忙。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "撇下烟头子快来。"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺又忙哩。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "又是甚么忙？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "念佛忙。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "念的甚么佛？"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "我念的佛，普天下世人多不省的。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "你念来我听。"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "南无阿弥陀佛！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "三岁孩童多会念的。快来！"
        },
        {
          "character": "疯僧",
          "type": "内白",
          "text": "俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧上。"
        },
        {
          "character": "疯僧",
          "type": "干唱",
          "text": "波罗蜜，波罗蜜，一口沙糖一口蜜。 河里洗澡，睡在寺里，黄牛儿可不羞杀你！ 你好痴，攒金银，打首饰，与汝妻。 自己死后，四块板儿一领席，这便是落得的！ 南无大慈大悲广大灵感观世音菩萨！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "看你垢面疯痴，怎么了？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳，师父！"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "休笑俺垢面疯痴， 恁可也参不透我的本来主意。 我笑那世人痴， 不解我的禅机。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "看你鬓发蓬松。"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "休笑俺发蓬松……"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "挂着这织袋何用？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "挂着这破织袋。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "袋内甚么东西？"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "这里面倒包，包藏着天地。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "手中拿的是甚么？"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "我拿着这吹火筒，却离了这香积。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他那知我是地藏王化身哩！"
        },
        {
          "character": "疯僧",
          "type": "粉蝶儿",
          "text": "今日个泄天机，故来临凡世。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "你经忏也不看些！"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "我不会看经忏在恁那法堂中， 我只理会打，打的勤劳在恁那山寺里。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "看你今日涂，明日涂，涂出事来了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "涂出什么事来？"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "秦丞相唤你！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "可是那奸臣秦桧！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "唔！秦丞相！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我正要去见他。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "疯僧唤到。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唤过来！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老和尚下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "呸！我道是怎么一个疯僧，原来是个腌臢和尚！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我道是怎么一个丞相，原来是个奸臣秦桧！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！你怎么道我的名？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你的名我不道，谁道？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你认我是谁？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你么！"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "恁是个上瞒天子下欺臣， 我单道着你，你，"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "休笑俺污秽， 我这肚皮中倒干净似你的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我来问你的缘由！"
        },
        {
          "character": "疯僧",
          "type": "醉春风",
          "text": "恁来问俺的缘由， 我对伊家说破，看他怎生得将俺来支对？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我且问你，这壁上的诗，可是你写的？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是你做的，我写的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何胆字能小？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我的胆小出了家，你的胆大弄出事来哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！你可知我的来意？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我怎不知？"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "恁主意我先知， 则恁那梦境恶， 故来到——故来到俺这山寺里。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我拜当阳求忏悔。"
        },
        {
          "character": "疯僧",
          "type": "迎仙客",
          "text": "恁来这里拜俺的当阳求忏悔。 恁则待要灭罪消释， 哪里是念彼观音力？"
        },
        {
          "character": "疯僧",
          "type": "石榴花",
          "text": "太师着俺说个因依， 俺与恁便仔细话个真实。 恁可也悔当初， 错听了恁那大贤妻？ 她也曾屡屡地便诱你， 恁却也依随。 恁在那东窗下不解我的西来意。 只见他葫芦提无语将俺支对， 恁那谗言谮语，恁便将心昧， 恁可也立起一统儿价正直碑？"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "恁待要结媾金邦哩， 也只是肥家——"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "哪里肯为国？ 恁如今事要前思， 吓哈免劳——免劳得这后悔！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "悔什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "秦桧，你下阶来。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "看上面是什么？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是天。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "可又来！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "却不道湛湛青天不可欺， 如今人都理会的。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "吓哈……左右与我拿下！"
        },
        {
          "character": "疯僧",
          "type": "斗鹌鹑",
          "text": "恁在这里吓鬼瞒神哩， 恁做的事事，做得来藏头嗳露尾。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你手中拿的是甚么东西？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是箕帚。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "要它何用？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "昔日边上扫烟尘，今日在佛殿上扫奸臣！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！那呢？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是火筒。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "又要它何用？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "要它私通外国！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "何不放下来？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "放不得。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "放下来，就要弄权哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我是君子人！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "红绣鞋",
          "text": "君子人只怕当权倚势， 待俺说着呵，害得他一家儿恰便似烟灭灰飞。 恁待要节外生枝， 可便落甚么便宜。 俺为甚不在恁那厨房中放， 常则在我这手中持。 啊呀火筒儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老和尚上。"
        },
        {
          "character": "疯僧",
          "type": "红绣鞋",
          "text": "这其间引狼烟倾了他的社稷！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，你平日可有功？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有功的都被你杀了！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "功课？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "在这袋内。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "取！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "取去！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "功课有了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "为何恁绉？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "在蜡丸内取出来的，怎么不绉？"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "“久闻丞相理乾坤，占断朝纲第一人。都领群臣朝北阕，堂中埋没老元勋。 闭门杀害忠良将，塞上欺君枉万民。贤相一心归正道，路上行人口……”"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！怎么诗不全？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "若遇施全，你就该死了！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "左右！若遇施全，与我拿下！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "还有。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "横看去！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "诗怎么横看？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你的事怎么横行呢？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！“久占都堂，闭塞贤路”。唗！你是敢侮弄我朝中的宰职么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "嘚！秦桧。"
        },
        {
          "character": "疯僧",
          "type": "十二月",
          "text": "卖弄恁那朝中得这宰职！ 恁可也懊恼我这闍黎？ 俺这里明明得这取出， 他那里暗暗观窥。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "疯僧",
          "type": "十二月",
          "text": "休笑俺疯魔和尚会嘴。 恁可也干净似你堂食？ 呀！这的是坐而不觉， 立而得这饥。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "讲了半日，想是他肚中饥了。 和尚，赏他一份斋。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "是。 相爷赏你一份斋。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我不吃。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "倾坏了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "再赏他一份。"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "又赏你一份。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我不吃！"
        },
        {
          "character": "老和尚",
          "type": "白",
          "text": "又倾坏了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "你不吃罢了，怎么连坏了我两个？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老和尚下。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "呔！秦桧！我坏了你两个，你就发恼，亏你害了他三个哩！"
        },
        {
          "character": "疯僧",
          "type": "十二月",
          "text": "两头白面做来的， 坏了恁那两个有谁得这知？ 恁便屈杀了他三人待推着谁？ 痴也么痴，其间造化机！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这是馒头。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这不是馒头。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "敢是谗馅？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "也不是谗馅。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是甚么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "哪！"
        },
        {
          "character": "疯僧",
          "type": "十二月",
          "text": "这的是岳家肚皮中腌臢气！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "这里不好讲话，随我到冷泉亭上来讲。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "冷泉亭上不好，倒是清风亭上好行事哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，我看你伶牙俐齿，有甚本事？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "我会呼风唤雨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "风雨在天上，如何唤得来？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "唤得来，还要退得去。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "如此我要一阵大风。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有，有，有。如来佛，助弟子一阵大风！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大风！收了，收了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "收，收，收！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我如今还要一阵大雨！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有，有，有。东海龙王，助奸臣秦桧一阵大雨！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大雨！收了，收了！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "收，收，收！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "唔！我想风雨在天上，如何来得恁骤？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "连发十二道金牌召来的，怎么不骤？"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "吓哈哈哈！"
        },
        {
          "character": "秦桧",
          "type": "快活三",
          "text": "风来时，雨便起； 云过处，电光辉。 把他拿住风来握住雨不淋漓。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大风吓！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "这不是风。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "是什么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "是朱仙镇上那些黎民的怨气！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "好大雨吓！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "也不是雨。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "又是甚么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "哪！"
        },
        {
          "character": "疯僧",
          "type": "快活三",
          "text": "这的是屈杀了岳家父子天垂泪！"
        },
        {
          "character": "疯僧",
          "type": "朝天子",
          "text": "太师爷俺与恁便说知。 说着恁那就里，俺只索要忍辱波罗蜜。 恁可也悔当初屈杀了他三人，可也无着无对， 到如今悔后迟，他在阴司下便等你，在阎王殿前去告你。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "告我甚么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他告你私造下十座牢房。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "哪十座？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "雷霆施号令，星斗焕文章。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "他在哪一号？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "他在章字号等你哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊呀佛爷呀佛爷！"
        },
        {
          "character": "秦桧",
          "type": "朝天子",
          "text": "这的是恁自造下落得这旁州例。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "和尚，我如今要免六道轮回之苦，可免得过去么？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "你随我出了家，削了发，就可免了。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "我要出家，怕没有高僧剃度。况灵隐寺小，怎藏得我下？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "灵隐寺虽小，佛力最大哩！"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "方才这八句诗，如何讲？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "方才这八句诗？"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "做一个哑谜儿与恁猜。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "横头上八个字？"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "横头上八个字——"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "做一张闷弓儿在恁那心上射。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "有一日东窗事犯——"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "才知我的西来意。"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "那时节，捶着胸，跌着脚，嘚！秦桧！"
        },
        {
          "character": "疯僧",
          "type": "煞尾",
          "text": "恁可也慢慢地悔！"
        },
        {
          "character": "疯僧",
          "type": "白",
          "text": "俺去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "疯僧下。"
        },
        {
          "character": "秦桧",
          "type": "白",
          "text": "啊呀！倒被这疯僧一番言语，说得毛骨悚然。回去与夫人商议便了。 打道！"
        },
        {
          "character": "秦桧",
          "type": "念",
          "text": "疯僧一席话，使我魂魄飞！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦桧下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}