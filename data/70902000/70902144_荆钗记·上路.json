{
  "script_id": "70902144",
  "title": "荆钗记·上路",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "钱流行",
      "hangdang": "外"
    },
    {
      "name": "姚氏",
      "hangdang": "副"
    },
    {
      "name": "李成",
      "hangdang": "末"
    }
  ],
  "plot": "钱流行夫妇由李成陪伴，同赴吉安。途中弃舟登岸，边行边观赏田野景色。",
  "notes": "常与《开眼》连演，题作《开眼上路》。主曲〖八声甘州〗曲调悠扬；外、副、末三个角色，身段优美，画\n面多姿多彩，于载歌载舞中描摹出阳春三月的诗情画意，是典型的“三脚撑”戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姚氏上。"
        },
        {
          "character": "姚氏",
          "type": "念",
          "text": "东城渐觉风光好，绉浪恬波行客棹，绿杨烟外少人行，红杏枝头春意闹。 浮生常恨欢娱少，堪爱婵娟倾一笑。为君歧路看斜阳，且向花间留晚照。"
        },
        {
          "character": "姚氏",
          "type": "白",
          "text": "老身姚氏，幸喜我女婿升任吉安知府，打发李成回来，接我老夫妇到任，同享 荣华。咳，此时我女儿若在，同赴任所，岂不风光？正是："
        },
        {
          "character": "姚氏",
          "type": "念",
          "text": "娇女投何处？痛杀白头亲！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钱流行内嗽。"
        },
        {
          "character": "姚氏",
          "type": "白",
          "text": "言之未已，员外出舱来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钱流行上。"
        },
        {
          "character": "钱流行",
          "type": "小蓬莱",
          "text": "策杖登程去也， 西风里劳碌艰辛， 澹烟荒草， 夕阳古渡， 流水孤村。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成上。"
        },
        {
          "character": "姚氏",
          "type": "小蓬莱",
          "text": "满目堪图堪画， 野景萧萧， 冷浸黄昏。"
        },
        {
          "character": "李成",
          "type": "小蓬莱",
          "text": "樵歌牧唱， 牛眠草径， 犬吠柴门。"
        },
        {
          "character": "钱流行",
          "type": "念",
          "text": "绿遍汀州三月景，锦江风静帆收。 垂杨低映木兰舟，半蒿春水滑，一段夕阳愁。"
        },
        {
          "character": "姚氏",
          "type": "念",
          "text": "灞水桥东回首处，美人亲卷帘钩。"
        },
        {
          "character": "李成",
          "type": "念",
          "text": "落花几阵入红楼，行云归楚峡，飞梦绕温州。"
        },
        {
          "character": "钱流行",
          "type": "白",
          "text": "连日在舟中闷坐，今朝日丽风和，花明景曙，我们一同登岸走走！"
        },
        {
          "character": "姚氏、李成",
          "type": "同白",
          "text": "员外先请，我们随后。"
        },
        {
          "character": "钱流行",
          "type": "白",
          "text": "好天气吓！"
        },
        {
          "character": "钱流行",
          "type": "八声甘州",
          "text": "春深离故家， 叹衰年"
        },
        {
          "character": "钱流行、姚氏、李成",
          "type": "同八声甘州",
          "text": "倦体奔走天涯。 一鞭行色， 遥指剩水残霞。 墙头嫩柳篱畔花， 只见古树枯藤棲暮鸦， 槎枒， 遍长途触目桑麻。"
        },
        {
          "character": "姚氏",
          "type": "八声甘州",
          "text": "呀呀， 幽禽聚远沙，"
        },
        {
          "character": "姚氏",
          "type": "夹白",
          "text": "老老！"
        },
        {
          "character": "姚氏",
          "type": "八声甘州",
          "text": "对仿佛禾黍宛似蒹葭。"
        },
        {
          "character": "钱流行、姚氏、李成",
          "type": "同八声甘州",
          "text": "看江山如画， 无限野草闲花， 旗亭小桥景最佳。 见竹锁溪边有三两家， 渔艖， 弄新腔一笛堪夸。"
        },
        {
          "character": "姚氏",
          "type": "白",
          "text": "喔唷，走勿动哉！"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "员外安人在此坐坐，待男女去看船来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成下。"
        },
        {
          "character": "钱流行",
          "type": "白",
          "text": "想我早岁游庠，何曾遭此跋涉。老迈龙钟，反受许多苦楚！"
        },
        {
          "character": "姚氏",
          "type": "白",
          "text": "今日个苦，才是孙汝权个拖牢洞害我俚个！"
        },
        {
          "character": "钱流行",
          "type": "白",
          "text": "妈妈不要说了。"
        },
        {
          "character": "钱流行",
          "type": "解三酲",
          "text": "为当初被人谎诈， 把家书暗地套写， 致我儿一命丧在黄泉下， 受多少苦波查。 今日幸蒙佳婿来迎也， 又还愁逆旅淹留人事赊。"
        },
        {
          "character": "钱流行、姚氏",
          "type": "同解三酲",
          "text": "空嗟呀，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成上。"
        },
        {
          "character": "钱流行、姚氏、",
          "type": "同解三酲",
          "text": "自叹命薄难苦怨他。"
        },
        {
          "character": "钱流行、姚氏、李成",
          "type": "同解三酲",
          "text": "步徐徐水边林下， 路迢迢野田禾稼， 景萧萧疏林中暮霭斜阳挂， 闻鼓吹闹鸣蛙， 一经古道西风鞭瘦马， 漫回首盼想家山泪似麻。 空嗟呀， 自叹命薄难苦怨他。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "员外看仔细！"
        },
        {
          "character": "姚氏",
          "type": "白",
          "text": "喔唷鸡眼痛哉！"
        },
        {
          "character": "钱流行",
          "type": "白",
          "text": "下船去罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钱流行、姚氏、李成同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}