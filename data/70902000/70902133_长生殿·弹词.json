{
  "script_id": "70902133",
  "title": "长生殿·弹词",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "李龟年",
      "hangdang": "老生"
    },
    {
      "name": "李謩",
      "hangdang": "巾生"
    },
    {
      "name": "听客甲",
      "hangdang": "末"
    },
    {
      "name": "听客乙",
      "hangdang": "付"
    },
    {
      "name": "听客丙",
      "hangdang": "白面"
    },
    {
      "name": "听客丁",
      "hangdang": "贴旦"
    }
  ],
  "plot": "安禄山乱起，人民流离失所。宫廷供奉李龟年也流落江南，卖唱为生。善吹铁笛的李謩，在鹫峰寺大会上，\n与众人一起聆听李龟年弹唱。老伶工慨叹国家兴衰，把唐明皇宠爱贵妃、失政致乱的经过，唱得声泪俱下，\n深深感动了听众，从此，李謩结识了这位前辈，向他学习，继承了《霓裳羽衣曲》的全谱。",
  "notes": "这是老生的唱工名剧，曲调苍凉悲壮，颇为感人。在昆曲盛行的时代，传播很广。所谓“家家收拾起，户户\n不提防”，即指《千忠戮·惨睹》和这出戏而言。俞振飞先生幼时，曾由其父俞粟庐先生教过此曲，但其中\n〖梁州第七〗及〖八转〗两支，一般都不唱，予以省略。读者如需要，需要查《长生殿曲谱》、《集成曲谱》\n、《与众曲氆》等书。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李龟年上。"
        },
        {
          "character": "李龟年",
          "type": "念",
          "text": "一从鼙鼓起渔阳，宫娥俄看蔓草荒。留得白头遗老在，谱将残恨说兴亡。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "老汉李龟年。昔日为内苑伶工，供奉梨园，蒙万岁恩宠。自从在朝元阁，教演 霓裳，曲成奏上，龙颜大悦，与贵妃杨娘娘，各赐缠头，不下数万。谁想禄山 造反，破了长安，圣驾西巡，万民逃窜，梨园部中也都七零八落。各自奔逃。 老汉来到这江南地方，盘缠都已使尽，只得抱着这琵琶，唱个曲儿糊口。今日 鹫峰寺大会，游人甚多，不免到彼卖唱。咳咳咳！想当日天上清歌，今日沿门 鼓板，好不颓气人也！"
        },
        {
          "character": "李龟年",
          "type": "一枝花",
          "text": "不提防余年值乱离， 逼拶得歧路遭穷败。 受奔波风尘颜面黑， 叹凋残霜雪鬓须白。 今日个流落天涯， 只留得琵琶在！ 揣羞脸上长街， 又过短街。 哪里是高渐离击筑悲歌！ 吓哈倒，倒做了伍子胥吹箫也那乞丐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李龟年下。李謩上。"
        },
        {
          "character": "李謩",
          "type": "念",
          "text": "花动游人眼，春伤故国心。霓裳人去后，无复有知音。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "小生李謩，向在西京，乱后方回，自从在宫墙之外，偷按霓裳数迭，只是未得 全谱，各处访问，无有知音。昨闻有一老者，抱着琵琶卖唱，人人都说手法不 同，像个梨园旧人。今日鹫峰寺大会，不免前去寻访一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四听客同上。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请吓！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "看游人好不热闹！"
        },
        {
          "character": "听客甲",
          "type": "念",
          "text": "闲步寻芳惜好春，"
        },
        {
          "character": "听客乙",
          "type": "念",
          "text": "且看胜会逐游人。"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "大姐，"
        },
        {
          "character": "听客丙",
          "type": "念",
          "text": "咱和你及时行乐休空过，"
        },
        {
          "character": "听客丁",
          "type": "白",
          "text": "客官，"
        },
        {
          "character": "听客丁",
          "type": "念",
          "text": "好听琵琶一曲新。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "请问这位大姐，说什么琵琶一曲新？"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "老兄你个不知。这里新到一位老丈，弹得一手好琵琶，唱得一嘴好曲儿，今日 鹫峰寺大会，我们大家前去一听。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "小生正欲访他。同行如何？"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同念",
          "text": "行行去去，去去行行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李龟年上。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "这里是了。吓老丈请了。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "列位请了。敢是听曲儿的么？"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "待在下唱来者。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请教。"
        },
        {
          "character": "李龟年",
          "type": "九转货郎儿",
          "text": "唱不尽兴亡梦幻， 弹不尽悲伤感叹。 抵多少凄凉满眼对江山！ 俺只待拨繁弦传幽怨， 翻别调写愁烦， 慢慢的把天宝当年遗事弹。"
        },
        {
          "character": "听客甲",
          "type": "白",
          "text": "天宝当年遗事，好大题目也。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "天宝当年遗事，一时哪里唱得尽？请老丈先把贵妃娘娘，当时怎生进宫，唱来 我们一听。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "听者。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请教。"
        },
        {
          "character": "李龟年",
          "type": "二转",
          "text": "想当初庆皇唐太平天下， 访丽色把蛾眉选刷。 有佳人生长在弘农杨氏家， 深闺内端的是玉无瑕。 那君王一见了就欢无那， 把钿盒金钗亲纳， 评跋做昭阳第一花。"
        },
        {
          "character": "听客丁",
          "type": "白",
          "text": "请问老丈，那贵妃娘娘生得如何？"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "可有咱家大姐这样标致么？"
        },
        {
          "character": "听客乙",
          "type": "白",
          "text": "还差个点点来。"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "听者。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请教。"
        },
        {
          "character": "李龟年",
          "type": "三转",
          "text": "那娘娘生得是似仙瓷佚貌， 说不尽幽闲窈窕。 端的是花输双颊柳输腰， 比昭君增妍丽，较西子倍丰标。 似天仙飞来海峤， 恍嫦娥偷离碧霄。 更春情韵饶，春酣态娇，春眠梦悄， 抵多少百样娉婷也难画描！"
        },
        {
          "character": "听客乙",
          "type": "白",
          "text": "老丈，听说贵妃娘娘恁般标致，这股活现，好像你亲眼见的。只怕你说谎！"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "唔！管他说不说谎，只要唱得好听。 老丈，不知那皇帝老官，怎生看待她？老丈你快唱下去。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "听者。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请教。"
        },
        {
          "character": "李龟年",
          "type": "四转",
          "text": "那君王看承得似明珠没两， 镇日里高擎在掌。 赛过那汉飞燕在昭阳。 可正是玉楼中巢翡， 金殿上锁着鸳鸯。 宵偎昼傍， 直弄得那官家丢不得舍不得那半刻心儿上。 守住情场，占断柔乡， 美甘甘写不了风流帐。 行厮并坐一双， 端的是双浓爱长， 博得个月夜花朝真受享。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "听客丙笑。"
        },
        {
          "character": "听客乙",
          "type": "白",
          "text": "做啥做啥？癞团子吃仔刺毛哉！"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "听得咱雪狮子向火。"
        },
        {
          "character": "听客乙",
          "type": "白",
          "text": "哪解说？"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "化了，化了。"
        },
        {
          "character": "听客乙",
          "type": "白",
          "text": "吓哟，木头能个人，倒亦会听化哉！"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "你晓得什么！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "老丈，当日宫中，有《霓裳羽衣》一曲，闻说是御制的，又说是贵妃娘娘所作， 老丈必知其详，请唱来我们一听。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "待老汉唱来者。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请教。"
        },
        {
          "character": "李龟年",
          "type": "五转",
          "text": "当日个那娘娘在荷亭把宫商细按， 谱新声将霓裳调翻。 昼长时亲自教双鬟， 舒素手拍香檀， 一字字都口吐自朱唇皓齿间。 恰便似一串酾珠声和韵闲， 恰便是莺与燕弄关关， 恰便是鸣泉花底流溪涧， 恰便是明月下泠泠清梵， 恰便是缑岭上鹤唳高寒， 恰便是步虚仙珮夜珊珊。 传集了梨园部，教坊班， 向翠盘中高簇拥个美貌如花杨玉环。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "妙吓！一派仙音，宛然在耳，好形容也。"
        },
        {
          "character": "听客甲",
          "type": "白",
          "text": "当日唐天子宠爱贵妃，朝欢暮乐，致使渔阳兵起，说来令人痛心！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "吓老先生，休要埋怨贵妃娘娘。当日只为误任边将，委政权奸，以致庙谟颠倒， 四海动摇。若使姚宋犹在，哪得有此？"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "阿呀列位吓！若说起渔阳兵起一事，真个天翻地覆，惨目伤心！列位若不嫌絮 烦，待老汉再唱者。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请教。"
        },
        {
          "character": "李龟年",
          "type": "六转",
          "text": "吓哈哈，恰正好喜孜孜霓裳歌舞， 不提防扑通通渔阳战鼓， 划地里慌慌急急， 早则是惊惊恐恐、仓仓卒卒、挨挨挤挤、抢抢攘攘出延秋西路， 携着个娇娇滴滴贵妃同去。 又则见密密匝匝的兵， 重重迭迭的卒， 闹闹炒炒、轰轰剨剨四下喧呼， 生逼散恩恩爱爱、疼疼热热帝王夫妇。 霎时间画就一幅惨惨凄凄绝代佳人命绝图！"
        },
        {
          "character": "听客丁",
          "type": "白",
          "text": "苦吓！"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "大姐，为何哭起来了？"
        },
        {
          "character": "听客丁",
          "type": "白",
          "text": "那贵妃娘娘尚然如此，不知奴家，后来怎生结果！"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "不妨事，有咱在此。"
        },
        {
          "character": "听客乙",
          "type": "白",
          "text": "勿番道，还有我拉里勒。"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "去你的！"
        },
        {
          "character": "听客丁",
          "type": "白",
          "text": "请问老丈，又贵妃娘娘死后，葬于何处？"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "咳！说也可怜！"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "请教。"
        },
        {
          "character": "李龟年",
          "type": "七转",
          "text": "破不喇马嵬驿舍， 冷清清佛堂倒斜， 一代红颜为君绝， 千秋遗恨滴罗巾血。 半行字是薄命的碑碣， 一抔土是断肠的墓穴， 再无人过荒凉野。 嗳莽天涯，谁吊梨花榭？"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "可怜！"
        },
        {
          "character": "李龟年",
          "type": "七转",
          "text": "可怜那抱悲怨的孤魂， 只伴着呜咽的鹃声冷啼月。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "天色晚了，我们回去罢。老丈，有个小意思在此，请收了。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "多谢列位。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同白",
          "text": "好说。"
        },
        {
          "character": "听客甲、听客乙、听客丙、听客丁",
          "type": "同念",
          "text": "无端唱出兴亡恨，引得旁人也泪流。"
        },
        {
          "character": "听客丙",
          "type": "白",
          "text": "大姐，咱和你喝烧刀子去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四听客同下。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "老丈，我听你这琵琶，非同凡手，得自何人传授？乞道其详。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "官人吓。"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "这琵琶曾供奉开元皇帝， 重提起心伤泪滴！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "如此说来。是梨园旧人了。"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "俺也曾在梨园籍上姓名题。 亲向那沉香亭花里去承值， 华清宫里宴上去追随。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "莫不是贺老？"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "俺不是贺家的怀智，"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "敢是黄旝绰？"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "黄旝绰同咱，"
        },
        {
          "character": "李龟年",
          "type": "笑",
          "text": "哈、哈、哈……"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "皆老辈。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "莫不是雷海青？"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "俺虽是弄琵琶却不姓雷。 吥哈他呵！骂逆贼久已身死名垂。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "一定是马仙期了。"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "俺也不是擅场方响马仙期。 那些旧相识多休嗳话题。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "老丈因何到此？"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "俺只为家亡国破兵戈沸， 因此上孤身流落在江南地。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "老丈毕竟是谁？"
        },
        {
          "character": "李龟年",
          "type": "九转",
          "text": "恁官人絮叨叨苦问俺是谁， 则俺老伶工名唤做龟年身姓李。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "吖原来是李教师，啊呀呀呀失敬了！"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "岂敢。官人尊姓大名？何以知道老汉？"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "小生姓李名暮。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "莫不是吹铁笛的李官人么？"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "然也。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "啊呀，幸会！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "岂敢。请问老丈，那霓裳全谱，可还记得否？"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "也还记得。官人为何问及？"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "不瞒老丈说，小生向在西京，乱后方回。老丈在朝元阁教演霓裳，小生曾傍宫 墙窃听，已将铁笛偷写数段，只是未得全谱，各处访求，无有知音。今日幸逢 老丈，不识肯赐教否？"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "既遇知音，何惜末技。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "多感盛情。请问老丈，尊寓何处？"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "唉！穷途流落，尚乏居停。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "如此屈到舍下，慢慢请教如何？"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "只是打搅不当。"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "好说。就请同行。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "官人吓！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "老丈！"
        },
        {
          "character": "李龟年",
          "type": "尾声",
          "text": "俺好似惊马绕树向空枝外， 谁承望旧燕寻巢入画栋来？ 今日个知音喜遇知音在， 这相逢异哉！恁相投快哉！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "今日相逢，堪称幸会。"
        },
        {
          "character": "李龟年",
          "type": "白",
          "text": "官人吓！"
        },
        {
          "character": "李謩",
          "type": "白",
          "text": "老丈！"
        },
        {
          "character": "李龟年",
          "type": "尾声",
          "text": "待俺慢慢的传与恁一曲霓裳播千载。"
        },
        {
          "character": "李龟年、李謩",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李龟年、李謩同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}