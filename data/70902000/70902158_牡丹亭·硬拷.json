  "plot": "柳梦梅至淮阴拜见岳父杜宝，反被当作掘坟贼，解回临安拷问。幸朝廷科试发榜，又以新科状元身份为试官\n苗舜宾救出。",
  "notes": "全剧用南北合套，刻画柳梦梅、杜宝两人不同心理。北曲〖折桂令〗、〖雁儿得胜〗多见于武戏，此处由巾\n生柳梦梅演唱，曲调细嫩多姿，别具一格，传为名曲。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杜宝、众人同上。"
        },
        {
          "character": "众人",
          "type": "同唐多令",
          "text": "玉带蟒袍红， 新参近九重。 浑不是黑头公。 杜宝"
        },
        {
          "character": "众人",
          "type": "念",
          "text": "秋来力尽破重围，入掌银壶护紫微。回头却叹浮生事，长向东风有是非。"
        },
        {
          "character": "众人",
          "type": "白",
          "text": "老夫杜宝。因淮扬平寇有功，叨蒙圣恩，起迁相位。前在淮阴，有一棍徒假充 门婿，已着递解临安府监禁。今日不免细审一番。 左右！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "众人",
          "type": "stage",
          "text": "杜宝"
        },
        {
          "character": "众人",
          "type": "白",
          "text": "临安府犯人可曾解到？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "解到了！"
        },
        {
          "character": "杜宝",
          "type": "白",
          "text": "带进来！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "临安府原解，带犯人听审！"
        },
        {
          "character": "狱卒",
          "type": "白",
          "text": "柳梦梅走动！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳梦梅上。"
        },
        {
          "character": "柳梦梅",
          "type": "新水令",
          "text": "则这怯书生剑气吐长虹，"
        },
        {
          "character": "狱卒",
          "type": "白",
          "text": "来此已是相府了。"
        },
        {
          "character": "柳梦梅",
          "type": "新水令",
          "text": "原来丞相府十分尊重。 杜宝"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "刑法伺候！"
        },
        {
          "character": "柳梦梅",
          "type": "新水令",
          "text": "他声息儿忒汹涌， 咱礼数缺通融。"
        },
        {
          "character": "狱卒",
          "type": "白",
          "text": "犯人进！犯人当面！"
        },
        {
          "character": "杜宝",
          "type": "白",
          "text": "打开刑具。"
        },
        {
          "character": "狱卒",
          "type": "白",
          "text": "领钧旨，犯人当堂开刑具，交签！"
        },
        {
          "character": "杜宝",
          "type": "白",
          "text": "明日领回文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "狱卒允，下。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓！岳丈！"
        },
        {
          "character": "杜宝",
          "type": "白",
          "text": "哆！谁是你岳丈？ 柳梦梅　　老大人！"
        },
        {
          "character": "杜宝",
          "type": "新水令",
          "text": "俺这里曲曲躬躬， 他那里半抬身全不动。"
        },
