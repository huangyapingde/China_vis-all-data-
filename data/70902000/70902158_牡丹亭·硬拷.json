          "text": "带马！"
        },
        {
          "character": "柳梦梅",
          "type": "沽酒令",
          "text": "那时节才提破了牡丹亭杜鹃残梦。"
        },
        {
          "character": "苗舜宾",
          "type": "白",
          "text": "老平章请了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曲牌收。苗舜宾、柳梦梅同下。"
