          "character": "苗舜宾",
          "type": "白",
          "text": "吓呀呀呀！"
        },
        {
          "character": "苗舜宾",
          "type": "园林好",
          "text": "嗔怪你会平章的老相公， 不刮目破窑中吕蒙。 忒做作前辈们的性重， 敢折到丈人峰，敢折到丈人峰？"
        },
        {
          "character": "柳梦梅",
          "type": "沽酒令",
          "text": "只这孔夫子把公冶长陷缧絏中， 柳盗跖打地洞向鸳鸯冢。 有日呵，把病理阴阳问相公， 要无语对春风。 则待列笙歌画堂中， 抢丝鞭御街拦纵。 把穷柳毅赔笑在龙宫， 老夫差失散了韩重， 俺呵，人雄气雄， 老平章深躬浅躬，"
        },
        {
          "character": "众人",
          "type": "同沽酒令",
          "text": "请状元升东转东。"
        },
        {
          "character": "苗舜宾",
          "type": "白",
          "text": "请状元赴琼林宴去罢！"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "岳丈，你女婿赴琼林宴去者！"
        },
        {
          "character": "柳梦梅",
          "type": "沽酒令",
          "text": "呀，"
        },
        {
          "character": "苗舜宾",
