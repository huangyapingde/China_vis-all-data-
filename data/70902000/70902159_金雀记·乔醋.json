{
  "script_id": "70902159",
  "title": "金雀记·乔醋",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "井文鸾",
      "hangdang": "五旦"
    },
    {
      "name": "潘岳",
      "hangdang": "巾生"
    },
    {
      "name": "瑶琴",
      "hangdang": "付"
    },
    {
      "name": "彩鹤",
      "hangdang": "丑"
    }
  ],
  "plot": "井文鸾得知丈夫潘岳将金雀赠于妓女巫彩凤，订下婚约，她故作妒忌之情状，调笑潘岳。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "潘岳上。"
        },
        {
          "character": "潘岳",
          "type": "穿花蝶",
          "text": "承恩命， 除书新授河阳令。 种花满县， 曷胜荣幸。"
        },
        {
          "character": "潘岳",
          "type": "念",
          "text": "赋罢气凌霄汉，文成口吐珠玑。夜常老叟执青藜，杖上红光焰起。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "下官潘岳。自到任以来，且喜黎庶从约，士子秀文，坐致物阜民安，益见太平 景象。喜得山公与嵇、阮诸君子，同会此方。因此多觅奇花异卉，时复相邀， 共谈诗酒。已差瑶琴遍访名花，待他来时，必有几种奇花异卉也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "瑶琴上。"
        },
        {
          "character": "瑶琴",
          "type": "念",
          "text": "正欲清谈逢客至，偶思小饮报花开。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "老爷，瑶琴叩头。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "瑶琴你回来了。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "所觅奇花今得几种？"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "花样甚多，花名不一。觅得金雀花在此，老爷请看！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "取来。唵，此花生得好古怪吓！"
        },
        {
          "character": "瑶琴",
          "type": "念",
          "text": "古怪真古怪，说来好惊骇。请看这封书，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "取来！"
        },
        {
          "character": "瑶琴",
          "type": "念",
          "text": "泪湿香罗带。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "把花供在书房，你自茶饭去。"
        },
        {
          "character": "瑶琴",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "瑶琴下。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "待我拆开来看。"
        },
        {
          "character": "潘岳",
          "type": "念",
          "text": "遭兵守志如空门，幸遇瑶琴达远音。不识河中金雀女，可能再会月车人。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "潘岳",
          "type": "太师引",
          "text": "顿心惊，蓦地如悬磬， 止不住盈盈泪零。 记当日在长亭分袂， 问归期细嘱叮咛。 却缘何身罹邟阱？ 犹幸得保全躯命， 劈鸳鸯是猖狂寇兵。 最堪怜蓬踪浪迹似浮萍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘岳下。"
        },
        {
          "character": "彩鹤",
          "type": "内白",
          "text": "请夫人下轿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾、彩鹤同上。"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "远涉兼程， 已到河阳锦绣城。"
        },
        {
          "character": "彩鹤",
          "type": "白",
          "text": "夫人。"
        },
        {
          "character": "彩鹤",
          "type": "太师引",
          "text": "官衙近，"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "彩鹤。"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "你忙行通报便相迎。"
        },
        {
          "character": "彩鹤",
          "type": "白",
          "text": "是。 有请老爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘岳上。"
        },
        {
          "character": "彩鹤",
          "type": "白",
          "text": "老爷，彩鹤叩头。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "彩鹤，夫人接到了么？"
        },
        {
          "character": "彩鹤",
          "type": "白",
          "text": "接到了。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吩咐开正门！"
        },
        {
          "character": "彩鹤",
          "type": "白",
          "text": "吓，开正门！"
        },
        {
          "character": "潘岳",
          "type": "太师引",
          "text": "出公庭，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓，夫人！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "夫人请！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公请！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "请，请，请！"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "喜今官爵威仪盛，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "惶恐吓，惶恐！"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "不弃糟糠感志诚。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "唷，唷，唷，夫人说哪里话！夫人请上，下官有一拜。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "妾身也有一拜。"
        },
        {
          "character": "潘岳",
          "type": "太师引",
          "text": "真徼幸， 偶因代赋承新命， 有惭为令。"
        },
        {
          "character": "家院",
          "type": "内白",
          "text": "候着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启爷：上司有紧急公文请老爷出堂签押挂号。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "看大衣服侍候！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "吓，各役侍候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓，夫人！正欲谈心，不想上司有紧急公文发下，待下官出堂发遣文书，即来 陪夫人。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公请便。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓啊呀呀呀！夫人请坐，下官是就来的！ 吩咐开门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘岳袖中遗书。"
        },
        {
          "character": "家院、彩鹤",
          "type": "内同白",
          "text": "开门吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "堂鼓三记。潘岳下。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "呀！看相公匆匆出堂，袖中遗下一封书来，待我拾起来看。"
        },
        {
          "character": "井文鸾",
          "type": "念",
          "text": "“遭兵守志如空门，幸遇瑶琴达远音。不识河中金雀女，可能再会月车人。”"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "吖，原来是巫妹所寄之书，可见我相公时刻将她在念。待我藏于袖中慢慢以言 试之。吓巫妹吓！"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "你剪雪裁冰，"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公吓！"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "袖失遗书太薄情！ 似杨花性， 沾泥飞絮类书生。"
        },
        {
          "character": "潘岳",
          "type": "内白",
          "text": "掩门！"
        },
        {
          "character": "家院、彩鹤",
          "type": "内同白",
          "text": "掩门吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "堂鼓四记。潘岳上。"
        },
        {
          "character": "潘岳",
          "type": "太师引",
          "text": "见卿卿，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓，夫人！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公！"
        },
        {
          "character": "潘岳",
          "type": "太师引",
          "text": "今朝喜得交鸳颈。"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "不负当年金雀盟。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "是吓，下官与夫人所分金雀想必带来。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "妾之金雀朝夕佩带，君之金雀存乎？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "下官的么？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "好，好像在书箱内。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "当年赠别金雀轻分，今日重逢合当成对。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "是吓。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "去！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓，哪里去？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "去取金雀来。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "将来何用？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "待我仍以绣线系于一处。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "嗄，待下官取金雀来与夫人么，仍以绣线同心系于一处。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "唔。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "啧、啧、啧，好个同心两字！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "快去取来！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "是、是、是，待下官即刻就去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "井文鸾私白。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "看他取什么来？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "且住！我想夫人初到，未可轻言巫姬一事，她倒提起金雀来，将什么东西与她 对合呢？吖，有了，将巫姬所寄之书与她一看，或者见她为我守志投崖，接来 完聚亦未可知。有理吓，有理！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "来了。 啊呀，书呢？哪里去了？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "快来！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吖，来了。 啊呀哪里去了？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "相公快来。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吖，来了，来了，来了！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "金雀呢？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "取来！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "这……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘岳欲走。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "夫人请坐！下官一时寻不见书箱上的锁匙，待寻见了锁匙就有金雀，有吓，在， 在，在，吓哈哈……"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "真薄幸，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "怎见得下官薄幸？"
        },
        {
          "character": "井文鸾",
          "type": "太师引",
          "text": "缘何陇蜀相兼并？这般渴病！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "唷，夫人忒多心了。那金雀好好在书箱内，就是明日取来与夫人看么，也未为 迟吓！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "那金雀乃至灵之物，先已飞到我袖中来了。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "嗄，在夫人袖中？我不信！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "你不信么？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "不信。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "待我取出来与你看！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "是吓，倒是取出来看的好。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "哪，这不是么？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "这，唷，唷，唷，是夫人的吓！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "不差，原是我的。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "如何，我原说是夫人的！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "还有。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓，还有？请夫人一发取出来看。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "哪，这不是一对么？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "是哪一个的？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓，哈哈，吓，哈哈，吓哈哈哈……这又奇了，吓哈哈……"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "嗳——"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "休得要乔妆行径， 我跟前不耐听。 金雀当年婚订，得谐和双姓， 绾红丝牵缔盟。 我和你鸳侣交颈，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "连枝同并的㖸！"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "连枝同并， 只合气求相应，共享安宁。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "今日相逢，和你共享安宁之福。"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "你旁支为何觅小星，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "旁支？哪有此事？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "你言清行浊，太亏心短行。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "下官有甚亏心短行呢？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "闲说！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "你还要语惺惺！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "走来！"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "潘岳",
          "type": "江头金桂",
          "text": "这诗题绝句伊谁寄？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吓，这诗怎么也在夫人处？还了我，还了我！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "井文鸾",
          "type": "江头金桂",
          "text": "雀鲜双飞却怎生？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "夫人吓！"
        },
        {
          "character": "潘岳",
          "type": "江头金桂",
          "text": "非是我亏心短行，"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "夫人吓！"
        },
        {
          "character": "潘岳",
          "type": "江头金桂",
          "text": "你从来贤惠称。"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "我平日是极贤惠的。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "贤惠，贤惠！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "今日么——"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "唵？"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "权且不贤惠这一遭。"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "唷，这也是儿女之故态嗄！"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "吓？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "啊呀，夫人吓！"
        },
        {
          "character": "潘岳",
          "type": "江头金桂",
          "text": "一自与卿分手，良明胥庆。 喜巫……"
        },
        {
          "character": "井文鸾",
          "type": "白",
          "text": "“巫”什么？“巫”什么？"
        },
        {
          "character": "潘岳",
          "type": "白",
          "text": "吖——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江头金桂"
        },
        {
          "character": "井文鸾",
          "type": "白",
