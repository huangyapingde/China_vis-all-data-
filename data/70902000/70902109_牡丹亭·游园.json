{
  "script_id": "70902109",
  "title": "牡丹亭·游园",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "杜丽娘",
      "hangdang": "五旦"
    },
    {
      "name": "春香",
      "hangdang": "贴旦"
    }
  ],
  "plot": "太守杜宝之女杜丽娘，深居闺阁，偶与婢女春香，游览花园，目睹春景，感动情思。",
  "notes": "《牡丹亭》传奇是明代大戏剧家汤显祖的名著，寓有个性解放的启蒙思想，影响极大，为世界文坛所推崇。\n《游园、惊梦》两折富有浪漫主义色彩，文词、曲调、舞蹈三者完美地结合在一起，成为昆曲代表作之一，\n至今仍是舞台上经常演出的剧目。俞振飞与梅兰芳先生合作次数最多，并于1960年摄制了电影。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杜丽娘上。"
        },
        {
          "character": "杜丽娘",
          "type": "绕池游",
          "text": "梦回莺啭，乱煞年光遍， 人立小庭深院。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "春香上。"
        },
        {
          "character": "春香",
          "type": "绕池游",
          "text": "炷尽沉烟，抛残绣线， 恁今春关情似去年？"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "晓来望断梅关，宿妆残。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "你侧着宜春髻子恰凭栏。"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "剪不断，理还乱，闷无端。"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "已吩咐催花莺燕惜春看。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春香，可曾吩咐花郎，扫除花径么？"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "已吩咐过了。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "取镜台衣服过来。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "云髻罢梳还对镜，罗衣欲换更添香。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，镜台衣服在此。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "放下。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "好天气也！"
        },
        {
          "character": "杜丽娘",
          "type": "步步娇",
          "text": "袅晴丝吹来闲庭院， 摇漾春如线。 停半晌整花钿， 没揣菱花偷人半面， 迤逗的彩云偏。 我步香闺怎便把全身现？"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐。"
        },
        {
          "character": "春香",
          "type": "醉扶归",
          "text": "你道翠生生出落的裙衫儿茜， 艳晶晶花簪八宝填。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春香。"
        },
        {
          "character": "杜丽娘",
          "type": "醉扶归",
          "text": "可知我一生儿爱好是天然？"
        },
        {
          "character": "杜丽娘、春香",
          "type": "同醉扶归",
          "text": "恰三春好处无人见。 不堤防沉鱼落雁鸟惊喧， 则怕的羞花闭月花愁颤。"
        },
        {
