{
  "script_id": "70902146",
  "title": "琵琶记·赏荷",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "蔡邕",
      "hangdang": "冠生"
    },
    {
      "name": "牛氏",
      "hangdang": "六旦"
    }
  ],
  "plot": "蔡邕在牛府招亲，离家经年，思念家中父母与妻子，但又不敢透露消息。牛氏请他弹一曲《风入松》，他却\n误弹了《思归引》，牛氏排宴，他只得强忍悲愁，与之同饮。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蔡邕上。"
        },
        {
          "character": "蔡邕",
          "type": "夹白",
          "text": "闲庭——"
        },
        {
          "character": "蔡邕",
          "type": "一枝花",
          "text": "槐影转， 深院荷香满， 帘垂清昼永，怎消遣？"
        },
        {
          "character": "蔡邕",
          "type": "念",
          "text": "翠竹影摇金，水殿帘栊映碧阴。人静昼长无外事，沉吟，碧酒金樽懒去斟。 幽恨苦相寻，离别经年没音信。寒暑相催人易老，关心，欲把闲愁付玉琴。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "吓，琴、鹤二童。"
        },
        {
          "character": "琴童、鹤童",
          "type": "内同白",
          "text": "啥个？"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "在象牙床上取蕉尾纨扇出来！"
        },
        {
          "character": "琴童、鹤童",
          "type": "内同白",
          "text": "来哉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "琴童、鹤童同上。"
        },
        {
          "character": "琴童、鹤童",
          "type": "同金钱花",
          "text": "自小承值书房、书房， 快活其实难当、难当， 只管打扇与烧香， 荷亭畔好乘凉， 吃饱饭上眠床。"
        },
        {
          "character": "琴童、鹤童",
          "type": "同白",
          "text": "老爷，蕉尾纨扇有了。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "放下。"
        },
        {
          "character": "琴童、鹤童",
          "type": "同白",
          "text": "是哉！"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "你二人一个烧香，一个打扇，违者各打十三。"
        },
        {
          "character": "蔡邕",
          "type": "懒画眉",
          "text": "强对南熏奏虞弦，"
        },
        {
          "character": "琴童",
          "type": "夹白",
          "text": "兄弟你烧香，我打扇。"
        },
        {
          "character": "鹤童",
          "type": "夹白",
          "text": "有理个。"
        },
        {
          "character": "蔡邕",
          "type": "懒画眉",
          "text": "只觉指下馀音不似前。 那些个流水共高山， 只见满眼风波恶， 似离别当年怀水仙。"
        },
        {
          "character": "琴童、鹤童",
          "type": "同白",
          "text": "环佩声响，夫人出堂。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "尔等回避。"
        },
        {
          "character": "琴童、鹤童",
          "type": "同白",
          "text": "是哉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "琴童、鹤童同下，牛氏上。"
        },
        {
          "character": "牛氏",
          "type": "引子",
          "text": "嫩绿池塘，梅雨歇，熏风乍转。"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "吓，相公。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "夫人请坐。"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "有坐。相公原来在此操琴。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "久闻相公善于音律，如何来到此间，丝竹之音杳然绝响？奴家斗胆，请教相公 试操一曲如何？"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "吖，夫人要听琴么？"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "弹什么好？"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "当此清凉夏景，弹一曲风入松罢。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "蔡邕",
          "type": "琴曲",
          "text": "一别家乡远， 思亲泪暗弹。"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "相公弹差了。风入松为何弹起思归引来？"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "吓，夫人，下官在家惯弹旧弦，这新弦欲弹不惯。"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "何不撇了新弦，重整旧弦？"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "新旧二弦俱撇不下！"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "既撇不下，提它怎么？"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "吓夫人！"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "相公。"
        },
        {
          "character": "蔡邕",
          "type": "桂枝香",
          "text": "危弦已断， 新弦不惯。 旧弦再上不能， 待撇了新弦难拚。 我一弹再鼓，我一弹再鼓， 又被宫商错乱。 非干心变， 这般好凉天， 正是此曲才堪听， 又被风吹别调间。"
        },
        {
          "character": "牛氏",
          "type": "夹白",
          "text": "相公！"
        },
        {
          "character": "牛氏",
          "type": "桂枝香",
          "text": "非弹不惯， 只是你意慵心懒。 既道是寡鹄孤鸾， 又道是昭君宫怨。 更思归别鹤， 无非愁叹，有何难见？ 即不然， 你道是除了知音听，道奴不是知音不与弹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "琴童、鹤童、惜春同上。"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同烧夜香",
          "text": "楼台倒影入池塘， 绿树阴浓夏正长， 一架蔷薇满院香。 泛霞觞， 卷起帘儿，明月正上。"
        },
        {
          "character": "蔡邕、牛氏",
          "type": "同白",
          "text": "看酒。"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同白",
          "text": "有酒。"
        },
        {
          "character": "蔡邕、牛氏",
          "type": "同梁州新郎",
          "text": "新篁池阁，"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同梁州新郎",
          "text": "槐阴庭院， 日永红尘隔断。 碧栏杆外， 寒飞漱玉清泉。 只觉香肌无暑，素质生风， 小簟琅玕展。 昼长人困也，好清闲。 忽被棋声惊昼眠。 金缕唱，碧筒劝， 向冰山雪巘排佳宴， 清世界有几人见？"
        },
        {
          "character": "蔡邕",
          "type": "梁州新郎",
          "text": "蔷薇帘箔，荷花池馆， 一点风来香满。 湘帘日永， 香销宝篆沉烟。 漫有枕欹寒玉，扇动齐纨， 怎遂得黄香愿？"
        },
        {
          "character": "牛氏",
          "type": "夹白",
          "text": "相公为何落下泪来？"
        },
        {
          "character": "蔡邕",
          "type": "夹白",
          "text": "非也。"
        },
        {
          "character": "蔡邕",
          "type": "梁州新郎",
          "text": "我猛然心地热， 不觉透香汗，"
        },
        {
          "character": "牛氏",
          "type": "夹白",
          "text": "惜春，纨扇。"
        },
        {
          "character": "惜春",
          "type": "夹白",
          "text": "是。"
        },
        {
          "character": "蔡邕",
          "type": "梁州新郎",
          "text": "我欲向南窗一醉眠。"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同梁州新郎",
          "text": "金缕唱，碧筒劝， 向冰山雪巘排佳宴， 清世界有几人见？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。"
        },
        {
          "character": "蔡邕、牛氏",
          "type": "同梁州新郎",
          "text": "向晚来雨过南轩，"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同梁州新郎",
          "text": "见池面红妆零乱。 渐轻雷隐隐雨收云散。 但闻得荷香十里，新月一钩，此景佳无限。 兰汤初浴罢，不觉晚妆残， 深院黄昏懒去眠。 金缕唱，碧筒劝， 向冰山雪巘排佳宴， 清世界有几人见？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖庆南枝〗。"
        },
        {
          "character": "蔡邕、牛氏",
          "type": "同节节高",
          "text": "涟漪戏彩鸳， 把露荷翻， 清香泻下琼珠溅。 香风扇，芳沼边，闲亭畔， 坐来不觉人清健， 蓬莱阆苑何足羡。"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同节节高",
          "text": "只恐西风又惊秋， 暗中不觉流年换。 清宵思爽然，好凉天， 瑶台月下清虚殿。 神仙眷，开玳筳，重欢宴， 任教玉漏催银箭， 水晶宫里把笙歌按。 只恐西风又惊秋， 暗中不觉流年换。"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同尾声",
          "text": "光阴迅速如飞电， 好良宵可惜渐阑， 管取欢娱歌声喧。"
        },
        {
          "character": "蔡邕",
          "type": "白",
          "text": "几鼓了？"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同白",
          "text": "三鼓了。"
        },
        {
          "character": "牛氏",
          "type": "白",
          "text": "相公。"
        },
        {
          "character": "牛氏",
          "type": "念",
          "text": "欢娱休问夜如何，"
        },
        {
          "character": "蔡邕",
          "type": "念",
          "text": "此景良宵能几多？"
        },
        {
          "character": "琴童、鹤童、惜春",
          "type": "同念",
          "text": "遇饮酒时须饮酒，"
        },
        {
          "character": "蔡邕、牛氏、琴童、鹤童、惜春",
          "type": "同念",
          "text": "得高歌处且高歌！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}