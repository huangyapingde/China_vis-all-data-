{
  "script_id": "70902114",
  "title": "紫钗记·折柳",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "霍小玉",
      "hangdang": "五旦"
    },
    {
      "name": "李益",
      "hangdang": "冠生"
    },
    {
      "name": "浣纱",
      "hangdang": "贴旦"
    }
  ],
  "plot": "唐诗人李益先与已故郡王之女霍小玉相好，后来从军有功，别娶他姓，霍小玉抑郁而亡。",
  "notes": "出自明汤显祖所撰《紫钗记》传奇，是一个悲剧。\n《紫钗记》流传演唱的唯此《折柳、阳关》，在原本中是一个折子，后世改题为两出。曲文典雅深奥，颇不\n易解，而旋律缠绵悱恻，很具特色，是小冠生与闺门旦的唱功戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众人随中军同上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "马来。"
        },
        {
          "character": "众人",
          "type": "同金钱花",
          "text": "渭城今雨清尘，清尘。 轮台古月黄云，黄云。 催花羯鼓去从军。 枕头上，别情人； 刀头上，做功臣。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "俺乃玉门关外刘节镇老爷麾下领兵骁将是也。只为土番征战河西，军中少一记 室，命新科状元李老爷为参谋，着俺领兵迎接。 众将！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "速往灞桥伺候！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "众人",
          "type": "同金钱花",
          "text": "枕头上，别情人； 刀头上，做功臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军、众人同下。浣纱引霍小玉同上。"
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": "车来。"
        },
        {
          "character": "霍小玉",
          "type": "金珑璁",
          "text": "春纤余几许？ 绣征衫亲付与男儿。 河桥外，香车驻， 看紫骝开道路。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "奴家只为李郎，仓促西征，因此禀过母亲，往灞桥送别。"
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": "启郡主：前面已是灞陵桥了。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "咳！哪里是灞陵桥，分明是一座消魂桥也！"
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": "老爷尚未到来，请郡主歇息片时。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "浣纱、霍小玉同下。众人喝道引李益同上，书童随上。"
        },
        {
          "character": "李益",
          "type": "念",
          "text": "旌旗日暖散春寒，洒湿沙场泪不干。花里断肠人一刻，明朝相忆路漫漫。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "下官李益，名魁春榜，官拜翰林，奉旨往西镇参军，只为军情紧急，火速起行 也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同喝道。"
        },
        {
          "character": "李益",
          "type": "点绛唇",
          "text": "逞军容出塞荣华， 这其间有喝不倒的灞陵桥跨。 接着阳关路， 后拥前呼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "浣纱上。"
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": "老爷请住马，郡主在此送别。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "老爷，郡主拉笃送别哉。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "点绛唇"
        },
        {
          "character": "李益",
          "type": "stage",
          "text": "百忙里陡的个雕鞍住。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "吩咐暂住头踏。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "吓！嘚，暂住头踏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，同下。霍小玉上。"
        },
        {
          "character": "书童",
          "type": "stage",
          "text": "霍小玉"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "吓李郎。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "夫人。"
        },
        {
          "character": "李益",
          "type": "念",
          "text": "出门何意向边州，"
        },
        {
          "character": "霍小玉",
          "type": "念",
          "text": "匹马今朝不少留。"
        },
        {
          "character": "李益",
          "type": "念",
          "text": "极目关山何日尽，"
        },
        {
          "character": "霍小玉",
          "type": "念",
          "text": "断肠丝竹为君愁。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "吓李郎，今日虽是荣行，难教妾不悲怨。此是灞陵桥，妾待折柳尊前，一写阳 关之思。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "多谢夫人。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "浣纱看酒。"
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": "有酒。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "𠮾……"
        },
        {
          "character": "霍小玉",
          "type": "寄生草",
          "text": "怕奏阳关曲。 生寒渭水都。 汀洲草碧粘云渍。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "这柳呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寄生草"
        },
        {
          "character": "霍小玉",
          "type": "stage",
          "text": "纤腰倩作绾人丝， 可笑它自家飞絮浑难住。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "想昨夜呵！"
        },
        {
          "character": "李益",
          "type": "寄生草",
          "text": "倒凤心无阻， 阳台半霎云何处。 问芳卿为谁断送春归去？"
        },
        {
          "character": "交鸳画不如、衾窝宛转春无数、花心历乱魂难驻、起来鸾袖欲分飞、霍小玉",
          "type": "白",
          "text": "李郎，妾有泪珠千点，沾君袖也。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "咳！可怜！"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "这泪呵！"
        },
        {
          "character": "霍小玉",
          "type": "寄生草",
          "text": "慢点悬清目， 残痕界玉姿。 珠盘溅湿红绡雾。 轻臙染就湘文筯。"
        },
        {
          "character": "冰壶迸裂蔷薇露、阑干碎滴梨花雨、怕层波溜溢粉香渠、这袖呵、李益",
          "type": "白",
          "text": "下官此去，不久就归，请止悲泣罢。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "李郎可有甚言语，嘱咐妾身？"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "夫人吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寄生草"
        },
        {
          "character": "李益",
          "type": "stage",
          "text": "和闷将闲度， 留春伴影居。 你通心纽扣蕤蕤束， 连心腰彩柔柔护， 惊心的衬褥微微絮。 分明残梦有些儿， 睡醒时好生收拾疼人处。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李益、霍小玉同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}