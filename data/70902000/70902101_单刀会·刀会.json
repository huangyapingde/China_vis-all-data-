{
  "script_id": "70902101",
  "title": "单刀会·刀会",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "净"
    },
    {
      "name": "周仓",
      "hangdang": "丑"
    },
    {
      "name": "鲁肃",
      "hangdang": "末"
    }
  ],
  "plot": "故事写刘备向孙权借驻荆州，历久未还。鲁肃设宴，邀请荆州守将关羽。关羽仅带周仓一人，持单刀赴会。\n鲁肃在筵前，索取荆州。关羽斥责鲁肃不应埋设伏兵，反而将鲁肃执住，鲁肃只得作罢。关羽遂鼓帆而去。",
  "notes": "此乃元代伟大剧作家关汉卿名作，应题《单刀会》杂剧，俗署《三国志》，误。曲词雄壮豪迈，气势、意境，\n俱臻上乘，数百年来，传唱不衰，并为其他剧种所移植改编，长期在舞台上演出。\n昆剧传统以正净饰演关羽，要求气度肃穆，唱念浑厚沉着，《新水令》、《驻马听》二曲，更要苍凉悲壮，\n慷慨激昂。后面演述辞曹归汉，过关斩将的过程时，手舞足蹈，身段动作，尤须雍容大方，切忌过分夸张，\n失诸过野。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、二旗牌同上。"
        },
        {
          "character": "鲁肃",
          "type": "引子",
          "text": "虎帐夜叹兵，坐守威名振。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "三尺龙泉万卷书，老天生我意何如？山东宰相山西将，彼丈夫时我丈夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "下官姓鲁名肃，字子敬。在吴王驾前，官居护军都督，镇守沿江等处。只是日 前刘备兵败当阳，身无所归。那时下官力保，暂借荆州，以为养军之所。今经 数载不还，未知是何意也。前日着人取讨，那刘备一言不发，云长公云：汉家 土地，岂肯尺寸与人？为此今日与众谋士议计，设宴临江，暗伏雄兵，特请云 长公赴席，筵前就取讨荆州，如若不允，金钟为号，伏兵齐起，筵前拿住，不 怕刘备不双手奉还。 来！"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯驾到，即忙通报。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "不施万丈深潭计，怎得骊龙项下珠？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、二旗牌同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周仓嗽上。"
        },
        {
          "character": "周仓",
          "type": "念",
          "text": "志气凌云贯九霄，周仓随驾显英豪。父王今赴单刀会，全仗青龙偃月刀。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "今日东吴鲁大夫，请俺父王赴宴，为此驾舟前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽内嗽。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "道言未了，父王出舱来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "波涛滚滚渡江东，独赴单刀孰与同？片帆瞬息西风力，鲁肃今日认关公。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "船行到哪里？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "大江。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吩咐水手，风帆不用扯满，把船缓缓而行。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓！ 呔，哨手听者！"
        },
        {
          "character": "哨手",
          "type": "内同白",
          "text": "吓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "父王有令，风帆不用扯满，把船缓缓而行！"
        },
        {
          "character": "哨手",
          "type": "内同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏水声，傍妆台。关羽观江景，曲牌收。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好一派江景也！"
        },
        {
          "character": "关羽",
          "type": "新水令",
          "text": "大江东去浪千迭， 趁西风驾着这小舟一叶。 才离了九重龙凤阙， 早来到千丈虎狼穴。 大丈夫心烈，大丈夫心烈， 觑着这单刀会赛村社。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看这壁厢山连着水，那壁厢水连着山。想二十年前，隔江斗智，曹兵八十三万 人马，屯据赤壁之间，也是这般山水，到今日……"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "依旧的水涌山迭，依旧的水涌山迭， 好一个年少的周郎，恁在何处也？ 不觉的灰飞烟灭， 可怜黄盖暗伤嗟。 破曹樯橹恰又早一时绝， 只这鏖兵江水犹然热。 好教俺心惨切，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声效果。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "嘎，哈……好水吓，好水！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这不是水！"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "这是二十年流不尽英雄血！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏水声。鲁肃、二旗牌同上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "鲁大夫过船！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吓，君侯！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "早知君侯光临，鲁肃只合远迎，接待不周，勿令见罪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢！想某有何德能，敢劳大夫治酒张筵。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "酒非洞府之长春，餚乃人间之菲仪，敢劳君侯屈高就下，降尊临卑，实乃东吴 之万幸也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢！贱足踹贵地。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不敢。贵足踏贱地。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "江露寒冷，先饮三杯御寒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯请。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，可知主不饮……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "客不宁。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "照杯！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "干。君侯请！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "酒不饮单……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "色不寝二。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "照杯。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "干。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曲牌收。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯请。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，可知某的刀，也会饮酒？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "名将必有宝刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀吓，刀！想你在百万军中，取上将的首级，如探囊取物，今日多蒙鲁大夫请 某赴宴。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "席上有不平之处，霎时劳你一劳，先饮一杯。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "要敬君侯，多是下官饮了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "少间席上，多饮几杯。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗，定席。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊呀呀，不敢！"
        },
        {
          "character": "关羽、鲁肃",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曲牌收。旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "上酒，请周将军用饭。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "不用。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯，我们还在哪里一别，直至如今？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "在当阳。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是吓！想光阴如骏马加鞭，人世如落花流水，去得好疾也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "果然去得好疾也。"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "想古今立勋业，"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "舜有五人，汉有三杰。"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "哪里有舜五人，汉三杰？ 两朝相隔只这数年别， 不复能够会也，恰又早这般老也！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯不老，下官倒苍也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "皆然。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请君侯开怀畅饮一杯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "开怀来饮数杯，"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯！"
        },
        {
          "character": "鲁肃",
          "type": "胡十八",
          "text": "请开怀饮数杯，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "某只待要尽心儿可便醉也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吓哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏节节高牌。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曲牌收。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯，昔日辞曹归汉，弃印封金，五关斩将，千里独行，这一场事业，下官只 是耳闻，未曾目睹，请君侯试说一遍，下官洗耳恭听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，想这节事，只可耳闻，不可目睹。闻者寻常，见者却也惊人。大夫若不 嫌絮烦，待某出席卸袍，手舞足蹈，试说一遍。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "愿闻。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "卸袍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下，奏大开门。关羽上，曲牌收。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想某辞曹归汉，弃印封金，出城时日色刚刚乍午。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "只听得韵悠悠画角绝，韵悠悠画角绝， 昏惨惨日得这西斜。 曹丞相满捧这香醪， 他自将来某只待在这马上接。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "赠君侯何物？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "赐某红锦战袍，要赚某下马。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯可曾下马？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某在马上，叉手躬身道，丞相，恕关某不下马来者！"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "某就卒律律刀挑了锦征袍，某只待去也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "行至哪里？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三里桥。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "嘎，三里桥。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某回头一望，只见曹兵如潮水一般，涌将上来。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯便怎么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某在马上，顿生一计。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "生何计？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "见路旁有棵柳树，有如许之大，被某提起青龙偃月刀，喀咤！分为两段。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "好宝刀吓！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某就出一令。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "出何令？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "也呔！曹兵听者：如有人过此桥者，只将柳树为号！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "好严令吓！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某只此一句。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "某就吓得他，吓得他马怯惊，人似痴呆。 没早晚不分个明夜，"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不分明夜，又行至哪里？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "古城。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "令兄令弟，自然相会了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥三弟，俱在城楼之上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "令兄可有什么言语？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥乃仁德之君，一言不发。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "令弟如何呢？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟乃一员虎将，他就开言道：“也呔！红脸的！你既降曹，又来则甚？”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯如何道？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某百般分说，他只是不信。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "啊呀大夫吓！好教俺浑身是口怎的样分说？ 脑背后将军猛烈， 那素白旗上他就明明得这标写。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "标写什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "“大将蔡阳”。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他与君侯无仇吓！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "只为某在东岭关，斩了他外甥秦琪，故此提兵前来报仇。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "原来为此。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时三弟不知，他就开言道：“也呔！红脸的！你既不降曹，为何有曹兵接着 呢？”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯便怎么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某说：“三弟！你既疑我降曹，你且开了城门，请了二位皇嫂车辆进来， 助俺一支人马，待某立斩蔡阳。”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时令弟三将军可允否？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟倒也粗中有细。道：“这话哄谁？哄谁？开了城门，助你人马，可不被 你杀个里应外合么？”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这也疑得是吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "只此一句，说得某顿口无言。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯便怎么呢？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某道：“三弟！那城门不要你开，人马也不要你助，可看桃园结义份上，助俺 三通战鼓，待俺立斩蔡阳。”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时令弟如何呢？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟他就拍手呵呵大笑，说：“二哥，这个使得，这个使得。哈……”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯便怎么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时恼了某的性儿，把二位皇嫂车辆，请过一旁。某道：“三弟，与我擂鼓者！ ”"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "只听得扑通通鼓声儿未绝，忽喇喇征鞍上骤也， 卒律律刀过处似雪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "喀咤！"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "人头儿落也，"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "斩了蔡阳，令兄令弟自然相会了吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时大开城门，请了二位皇嫂进城，弟兄三人，挽手而行。大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "才能够兄弟哥哥每欢悦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏节节高牌。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哈……请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曲牌收。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问君侯，方才这节事，叫做什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "以德报德，以直报怨。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "好个以德报德，以直报怨。我想借物不还，谓之怨也；想君侯熟读春秋左传， 通练兵书，匡扶社稷，救困扶危，谓之仁也；待玄德公如亲骨，视曹操如寇仇， 谓之义也；辞曹归汉，弃印封金，五关斩将，千里独行，谓之礼也；坐缚于 禁，水淹七军，谓之智也。我想君侯仁义礼智俱全，只少个“信”字。咳咦咦…… 惜乎吓惜乎！若得“信”字完全，真乃五常之将，无出君侯之右也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想某从未失信与人。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯未曾失信，令兄玄德公曾失信来。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥乃仁德之君，焉肯失信与汝？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽嗽。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "昔日贤昆玉兵败当阳，身无所归。那时孔明，只与下官同见吾主，即日兴师， 共除曹操于赤壁之间。那时东吴，费了巨万之资，又折了大将黄盖等。不为贤 昆仲，端为何来？皆为玄德公无尺寸之地，故此暂借荆州，以为养军之所。今 经数载不还，是何理也？今日下官，低情屈意，暂恳荆州，待等仓库丰盈，那 时再献与君侯掌管。下官不敢自专，伏乞君侯台命。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，今日还是请某饮酒，还是索取荆州？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这酒也要饮，荆州也要还。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "噤声！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "我把真心儿待你， 恁将那筵宴来设。 攀今吊古分什么枝叶， 俺跟前使不得之乎者也，诗云子曰！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "荆州原是吴地。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "噤声！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "但开言只教你剜口截舌！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孙刘结亲，以为两邦和好。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "可又来！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "有义孙刘目下反成做吴越。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣边一击。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "什么响？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "剑响。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "主何吉凶？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "人头落地。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "响过几次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三次。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第一？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斩颜良。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第二？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "诛文丑。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第三？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "第三，莫非轮着大夫了！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊呀呀！言重吓，言重！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某出剑休惊。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "此剑神威不可当，庙堂之上岂寻常？筵前索取荆州事，一剑须教子敬亡。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊呀……"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "凭着你三寸不烂舌， 休恼我三尺无情铁。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这剑！"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "饥餐了上将头， 渴饮的仇人血。 这的是龙在鞘中蛰， 虎向坐间歇。 今日个故友们重相见， 休教俺弟兄们相间别。 鲁子敬听者！ 心下休惊怯， 畅好是日西斜。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯莫非醉了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "吾当醉也。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "果然醉了。 军士们依计而行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、周仓同揪住鲁肃。"
        },
        {
          "character": "关羽、周仓",
          "type": "同白",
          "text": "可有埋伏？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "无有埋伏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "既无有埋伏呵！"
        },
        {
          "character": "关羽",
          "type": "搅筝琶",
          "text": "却怎生闹吵吵把三军列？ 有谁人把俺拦挡者？ 挡着俺呵， 只叫恁剑下身亡，目前见血。 恁便张仪口，蒯通舌，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哪里去躲藏者？"
        },
        {
          "character": "关羽",
          "type": "搅筝琶",
          "text": "恁且来来来！好好送某到船上，和你慢慢的别。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请鲁大夫过船谢宴。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓呔！请你过船谢宴！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "多多拜上君侯，说我不过船了。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "谅你也不敢！呔，开船！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏水声。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，受惊了。吓哈……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不敢，够了。"
        },
        {
          "character": "关羽",
          "type": "煞尾",
          "text": "承款待，多称谢， 只这两句话儿，恁可也牢牢记者："
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "从命。"
        },
        {
          "character": "关羽",
          "type": "煞尾",
          "text": "百忙里称不得老兄心，"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "恕不送了。"
        },
        {
          "character": "关羽",
          "type": "煞尾",
          "text": "急切里分不得汉家业！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏水声、尾声。关羽、周仓同下。鲁肃叹，下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}