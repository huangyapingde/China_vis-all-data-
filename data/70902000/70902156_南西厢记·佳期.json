{
  "script_id": "70902156",
  "title": "南西厢记·佳期",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "红娘",
      "hangdang": "六旦"
    },
    {
      "name": "莺莺",
      "hangdang": "五旦"
    },
    {
      "name": "张珙",
      "hangdang": "巾生"
    }
  ],
  "plot": "红娘怂恿莺莺到张珙书斋幽会，自己在外望风，想起背着老夫人促成这段姻缘，十分得意。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张珙上。"
        },
        {
          "character": "张珙",
          "type": "临镜序",
          "text": "彩云开， 月明如水浸楼台。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "吓，小姐来了么呀，啐。"
        },
        {
          "character": "张珙",
          "type": "临镜序",
          "text": "原来是风弄竹声， 只道是金珮响， 月移花影疑是玉人来。 意孜孜双业眼， 急攘攘那情怀， 倚定门儿待。 只索要呆打孩， 青鸾黄犬信音乖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙下。"
        },
        {
          "character": "红娘",
          "type": "内白",
          "text": "小姐看仔细。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "莺莺上。"
        },
        {
          "character": "崔莺莺",
          "type": "赚",
          "text": "徐步花街，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘上。"
        },
        {
          "character": "红娘",
          "type": "赚",
          "text": "抹过西厢傍小斋。"
        },
        {
          "character": "红娘",
          "type": "夹白",
          "text": "小姐！"
        },
        {
          "character": "红娘",
          "type": "赚",
          "text": "你且在门儿待，"
        },
        {
          "character": "红娘",
          "type": "夹白",
          "text": "待红娘去，"
        },
        {
          "character": "红娘",
          "type": "赚",
          "text": "轻轻悄悄把门挨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙上。"
        },
        {
          "character": "张珙",
          "type": "赚",
          "text": "甚人来？ 想是莺娘到此谐欢爱， 忙整衣冠把户开。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "张先生。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘姐姐，小姐来了么？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐么！"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "红娘回去罢。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "啊呀小姐吓——"
        },
        {
          "character": "红娘",
          "type": "赚",
          "text": "你且藏羞态， 前番变卦今休再！"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘姐。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "啐，没用的东西，来，来，来㖸——"
        },
        {
          "character": "红娘",
          "type": "赚",
          "text": "上前参拜。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘，你看那边有人来了。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "张珙",
          "type": "念",
          "text": "双双携素手，款款入书斋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙、崔莺莺同下。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "十二红"
        },
        {
          "character": "红娘",
          "type": "stage",
          "text": "没有吓，吓，张先生开门，开门㖸！呀，看他二人竟自闭门进去，撇了我红娘 在外，正是独立谁为伴，慢自支离恨咬牙。𠲔，想他二人呵—— 君瑞君瑞济川才。 一双才貌世无赛，堪爱。 爱他们两意和谐。 一个又惊又爱。 好似襄王神女会阳台。 似露滴牡丹开，香姿游蜂采。 也不管堕折宝钗。 也不管冻却瘦骸。 竟不管红娘在门儿外待！ 将好事翻成害。 将门叩，叫秀才。"
        },
        {
          "character": "红娘",
          "type": "夹白",
          "text": "嗳，秀才！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "十二红"
        },
        {
          "character": "红娘",
          "type": "stage",
          "text": "你忙披衣袂把门开。"
        },
        {
          "character": "红娘",
          "type": "夹白",
          "text": "小姐吓！"
        },
        {
          "character": "红娘",
          "type": "十二红",
          "text": "你莫贪余乐惹飞灾。"
        },
        {
          "character": "红娘",
          "type": "夹白",
          "text": "啊呀，不、不好了㖸——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "十二红"
        },
        {
          "character": "红娘",
          "type": "stage",
          "text": "看、看月上粉墙，来，"
        },
        {
          "character": "红娘",
          "type": "夹白",
          "text": "嗳。"
        },
        {
          "character": "红娘",
          "type": "十二红",
          "text": "莫怪我再三催！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙、崔莺莺同上。"
        },
        {
          "character": "张珙",
          "type": "节节高",
          "text": "春香抱满怀，畅奇哉， 浑身上下都通泰。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "好吓，你们两个通泰，撇我红娘在外！"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "有罪了。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "哟——"
        },
        {
          "character": "红娘",
          "type": "节节高",
          "text": "好无聊赖，难摆划，凭谁解。"
        },
        {
          "character": "张珙",
          "type": "节节高",
          "text": "梦魂飞绕青霄外，"
        },
        {
          "character": "昨夜梦中愁无奈、红娘",
          "type": "夹白",
          "text": "小姐回去吧！"
        },
        {
          "character": "张珙",
          "type": "节节高",
          "text": "今宵相会碧纱厨， 何时再解香罗带？"
        },
        {
          "character": "张珙",
          "type": "夹白",
          "text": "小姐！"
        },
        {
          "character": "张珙",
          "type": "节节高",
          "text": "是必破功夫明日早些来！"
        },
        {
          "character": "风流不用千金买、贱却人间玉与帛、红娘",
          "type": "白",
          "text": "张先生，来，来，来。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "红娘姐，怎么说？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "如今的病是好了吓？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "十分去了九分了。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "还有这一分呢？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "还在红娘姐身上。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "啐，起初有我红娘，"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "如今吓？"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "唵……"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "红娘回去罢。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "啐，小姐慢些走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔莺莺、红娘同下。"
        },
        {
          "character": "张珙",
          "type": "白",
          "text": "吓哈哈......这丫头好生作怪吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张珙下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}