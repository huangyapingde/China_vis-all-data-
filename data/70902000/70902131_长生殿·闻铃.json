{
  "script_id": "70902131",
  "title": "长生殿·闻铃",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "唐明皇",
      "hangdang": "冠生"
    },
    {
      "name": "陈元礼",
      "hangdang": "末"
    },
    {
      "name": "高力士",
      "hangdang": "丑"
    }
  ],
  "plot": "唐明皇避乱迁蜀，行至剑阁，正值风雨交加，听到檐前铃声聒耳，更加思念已在马嵬坡缢死的杨贵妃。不胜\n凄凉之感。",
  "notes": "这是一出有名的唱工戏，由两支〖南双调武陵花〗组成，曲调十分凄婉，节奏由慢转快，层次分明，要求一\n气呵成，声情并茂。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众人引陈元礼同上。"
        },
        {
          "character": "陈元礼",
          "type": "念",
          "text": "金戈铁马扬飞乌，猛将齐驱下国都。管教乱贼归吾掌，方显人间大丈夫。"
        },
        {
          "character": "陈元礼",
          "type": "白",
          "text": "俺，右龙武将陈元礼是也。只因安禄山造反，圣驾西巡，命俺统禁军，护驾西 行，前面已是栈道了。 嘚，众将官！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "陈元礼",
          "type": "白",
          "text": "好生护驾者！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下，高力士上。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "请万岁爷缓辔而行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇上。"
        },
        {
          "character": "唐明皇",
          "type": "武陵花",
          "text": "万里巡行， 多少凄凉途路情！ 看云山重迭处，似我乱愁交并。 无边落木响秋声， 长空孤雁添悲哽！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "寡人自离马嵬坡，饱尝辛苦。前日遣使臣赍奉玺册，传位太子去了。行了月余， 将近蜀中，且喜贼兵渐远，可以缓程而进。只是对此乌啼花落，水绿山青， 无非助朕悲怀，如何是好？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "万岁爷途路风霜，十分劳顿，请自排遣，幸勿过伤。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "朕与妃子，坐则并几，行则随肩，今日仓卒西巡，断送她这般结果，教寡人如 何撇得下也！"
        },
        {
          "character": "唐明皇",
          "type": "武陵花",
          "text": "提起伤心事，泪如倾。 回望马嵬坡下，不觉恨填膺， 袅袅旗旌，背残日期风摇影。 匹马崎岖怎么暂停？怎么暂停？ 只见黄埃散漫天昏暝。 哀猿断肠，听子规叫血，好教人怕听。 兀的不惨煞人也么哥！ 兀的不惨煞人也么哥！ 萧条怎生？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "雨来了！"
        },
        {
          "character": "唐明皇",
          "type": "武陵花",
          "text": "峨嵋山下少人经， 冷雨斜风扑面迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈元礼上。"
        },
        {
          "character": "陈元礼",
          "type": "白",
          "text": "众将官，暂往剑阁避雨者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同呐喊，同下。"
        },
        {
          "character": "唐明皇",
          "type": "念",
          "text": "独自登临意转伤，蜀山蜀水恨茫茫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "应风雨声。"
        },
        {
          "character": "唐明皇",
          "type": "念",
          "text": "不知何处风吹雨，点点声声迸断肠！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "应铃声。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "听那壁厢不住的声响，聒得人好不耐烦！ 高力士。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "看何物声响？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "应铃声。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "启万岁爷：是树林中雨声，和那檐前铃铎，随风而响。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "咳！这铃声，好不做美也！"
        },
        {
          "character": "唐明皇",
          "type": "武陵花",
          "text": "渐渐零零， 一片悲凄心暗惊。 遥听隔山隔树，战合风雨，高响低鸣。 一点一滴又一声， 点点滴滴又一声， 和愁人血泪交相迸。 对着这伤情处，转自忆荒茔。 白杨萧瑟雨纵横， 此际孤魂凄冷。 鬼火光寒，草间湿乱萤。 自悔仓皇负了卿！负了卿！⑴ 我独在人间，委实的不愿生！ 语娉娉，相将早晚伴幽冥。 一恸空山寂听铃声相应， 阁道崚嶒，⑵ 似我回肠恨怎平！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "雨住了，请万岁爷下阁去罢。"
        },
        {
          "character": "唐明皇",
          "type": "尾声",
          "text": "迢迢前路愁难罄， 厌看水绿与山青。 啊呀妃子吓！ 伤尽了千秋万古情！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "唐明皇",
          "type": "stage",
          "text": "—————————— ⑴加铃声，每一小节拍打一下。 ⑵铃声止。"
        }
      ]
    }
  ]
}