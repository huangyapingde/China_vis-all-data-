{
  "script_id": "70902113",
  "title": "牡丹亭·叫画",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "柳梦梅",
      "hangdang": "巾生"
    }
  ],
  "plot": "书生柳梦梅，寄居梅花观中，病后偶游废园，于假山石下，拾得一幅美人画像，带回寓所，展玩赞叹，为之\n倾倒不已（此画实乃杜丽娘之像）。",
  "notes": "此剧是出巾生的独脚戏，唱念、做表，极为细腻，必须揣摩神情，曲曲传出，方为合适。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "柳梦梅上。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "待我展开，观玩一番。"
        },
        {
          "character": "柳梦梅",
          "type": "二郎神",
          "text": "能停妥， 这慈容只合在莲花宝座。 咦，为甚独立亭亭在梅柳左？ 吓，不栽紫竹，边傍不放鹦哥。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "原来不是观音。哪！"
        },
        {
          "character": "柳梦梅",
          "type": "二郎神",
          "text": "只见两瓣金莲在裙下托。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓，是尊嫦娥！吓，又不像吓！我想既是嫦娥呵！"
        },
        {
          "character": "柳梦梅",
          "type": "二郎神",
          "text": "并不见祥云半朵。 嗳，也非是嫦娥。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "既不是观音，又不是嫦娥，喂，难道人间女子不成？"
        },
        {
          "character": "柳梦梅",
          "type": "二郎神",
          "text": "吓哈哈哈！这画蹊跷， 教人难揣难摩。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "呀呸！只管胡思乱猜。看帧首之上，有小字数行，待我看来。"
        },
        {
          "character": "柳梦梅",
          "type": "念",
          "text": "“近睹分明似俨然，远观自在若飞仙。他年得傍蟾宫客，不在梅边在柳边。”"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓！原来人间女子的行乐图。吓！何言不在梅边在柳边呢？啊呀，真乃奇哉怪 事也！"
        },
        {
          "character": "柳梦梅",
          "type": "集贤宾",
          "text": "蟾宫哪能得近她？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "唔，"
        },
        {
          "character": "柳梦梅",
          "type": "集贤宾",
          "text": "怕隔断天河。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "美人，你有此容貌，怕没个好对头，为甚傍柳依梅去寻结果？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "想天下姓柳、姓梅的，却也不少，偏偏小生么，叫做柳梦梅。若论起梅边，小 生是有份的；那柳边么，啊呀呀呀，也是有份的㖸！"
        },
        {
          "character": "柳梦梅",
          "type": "集贤宾",
          "text": "喜偏咱梅柳停和。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "看这美人，有些熟识得紧，曾在哪里会过一次的，怎么一时再也想不起？"
        },
        {
          "character": "柳梦梅",
          "type": "集贤宾",
          "text": "我惊疑未妥。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓，"
        },
        {
          "character": "柳梦梅",
          "type": "集贤宾",
          "text": "似曾向何方会我。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓，我想起来了！记得去春，曾得一梦，梦一大花园，梅树之下，立着一位美 人么，喏喏喏，就是她。她说柳生吓柳生，与俺有姻缘之分，发迹之期。喂， 美人可是你说的？是也不是？阿呀是也不是吓！"
        },
        {
          "character": "柳梦梅",
          "type": "集贤宾",
          "text": "你休见左， 敢则是梦中真个？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "唔！待我仔细认她一认，唵！看这美人，半枝青梅在手，却似提掇小生一般。"
        },
        {
          "character": "柳梦梅",
          "type": "莺啼御林",
          "text": "她青梅在手诗细哦， 逗春心一点蹉跎。 小生待画饼充饥， 姐姐似望梅止渴。 她未曾开半点么荷。 咦！她含笑处朱唇淡抹。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "哈哈！看这美人，这双俊俏的眼睛，只管顾盼着小生。小生走到这边，喏喏喏， 她也看着小生。待我走到那边，咦咦咦！哈哈！她又看着小生。啊呀美人！ 你何必只管看着我，何不请下来相叫一声？吓美人，请吓，请请请吓！呀呸！ 柳梦梅呀，你好痴也！"
        },
        {
          "character": "柳梦梅",
          "type": "莺啼御林",
          "text": "晕情多， 如愁欲语只少口气儿呵！"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "小娘子，你画似崔徽，诗如苏蕙，行书逼真卫夫人也。小生虽则典雅，怎及得 小娘子万分之一？蓦地相逢，不免步韵一首："
        },
        {
          "character": "柳梦梅",
          "type": "念",
          "text": "“丹青妙处欲天然，不是天仙即地仙。”"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "唔，地仙，竟竟竟是地仙！哈哈！"
        },
        {
          "character": "柳梦梅",
          "type": "念",
          "text": "“欲傍蟾宫人近远，恰如春在柳梅边。”"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "岭南柳梦梅熏沐敬和。吓小娘子，这是小生的拙作，少不得么，还要请教，啊 呀，还要请教㖸！"
        },
        {
          "character": "柳梦梅",
          "type": "簇御林",
          "text": "她题诗句，声韵和， 猛可的害相思颜似酡。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "啊，不是这等，待我狠狠的叫她几声。喂美人！小娘子！小姐，啊呀，我那姐 姐吓！"
        },
        {
          "character": "柳梦梅",
          "type": "簇御林",
          "text": "向真真啼血你知么？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "莫怪小生，"
        },
        {
          "character": "柳梦梅",
          "type": "簇御林",
          "text": "我叫，叫得你喷嚏一似天花唾。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "咦！下来了。"
        },
        {
          "character": "柳梦梅",
          "type": "簇御林",
          "text": "嗳，动凌波。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "请坐㖸。"
        },
        {
          "character": "柳梦梅",
          "type": "簇御林",
          "text": "盈盈欲下，"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "呀呸！"
        },
        {
          "character": "柳梦梅",
          "type": "簇御林",
          "text": "全不见些影儿哪。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓小娘子，小生孤单在此，少不得将小娘子的画像，做个伴侣，早晚么，玩之， 叫之，拜之，赞、赞、赞之！"
        },
        {
          "character": "柳梦梅",
          "type": "尾声",
          "text": "俺拾得个人儿先庆贺。 敢柳和梅有些瓜葛？ 美人吓！ 只被你有影无行盼煞我。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "吓小娘子，这里有风，请到里边去。唷，小娘子是客，自然小娘子先请，小生 么，随后。唵，请吓！请请请吓！阿呀来㖸！哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳梦梅下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}