{
  "script_id": "70902132",
  "title": "长生殿·哭像",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "唐明皇",
      "hangdang": "冠生"
    },
    {
      "name": "高力士",
      "hangdang": "丑"
    }
  ],
  "plot": "唐明皇避乱入蜀，传位太子，自称太上皇。因悼念杨贵妃，特敕成都府建立祠庙一座，用旃檀香木雕成妃子\n生像，命高力士迎进宫来，然后亲自送入庙供养。所以在习惯上，把此剧前半部分称为“迎像”，后半部分\n称为“哭像”，实际则是一出戏。",
  "notes": "此剧是大冠生的主要唱工戏，要独唱十三支曲子，必须通过感情充沛的唱、白，表现出人物的年龄、地位、\n心情和特定环境中强烈的哀伤气氛。关于这些唱、念和表演，俞振飞先生另有专文阐述，可供参考。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇上。"
        },
        {
          "character": "唐明皇",
          "type": "念",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "端正好"
        },
        {
          "character": null,
          "type": "stage",
          "text": "滚绣球"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "唐明皇",
          "type": "stage",
          "text": "蜀山水碧蜀山青，圣主朝朝暮暮情。但恨佳人难再得，岂知倾国与倾城！ 寡人自幸成都，传位太子，改称太上皇。喜得郭子仪兵威大振，指日荡平。只 念妃子，为国捐躯，无可表白，特敕成都府建庙一座，又选高手匠人，将旃檀 想起当时，可怜我那妃子呵！ 是寡人昧了她誓言深，负了她恩情广。 生拆开比翼鸾凤。 早不道半路里遭魔障！ 出延秋便沸沸扬扬。 落便手脚慌张。 𠲔 ！可恨那陈元礼呵！"
        },
        {
          "character": "唐明皇",
          "type": "叨叨令",
          "text": "不催他车儿马儿一谜价延延挨挨的望！ 生逼个身儿命儿一霎时惊惊惶惶的丧！ 兀的不痛煞人也么哥！ 兀的不苦煞人也么哥！ 闪得俺形儿影儿这一个孤孤凄凄的样！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "咳！寡人好不悔恨也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "脱布衫"
        },
        {
          "character": "唐明皇",
          "type": "stage",
          "text": "羞煞咱俺面悲伤， 救不得月貌花庞！ 不合呵，将他轻放！"
        },
        {
          "character": "唐明皇",
          "type": "小粱州",
          "text": "我当时若肯将身去抵挡， 未必她直犯君王。 纵然犯了又何妨？ 泉台上，倒博得永成双！"
        },
        {
          "character": "唐明皇",
          "type": "幺篇",
          "text": "我如今独自虽无恙， 问余生有甚风光？ 只落得泪万行，愁千状， 人间天上此恨怎能偿？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高力士上。"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "数点香泥入庙门，巫山云雨洛川城。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "启万岁爷：杨娘娘宝像已迎到宫门了。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宣进来！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。 万岁爷有旨：宣杨娘娘宝像进宫！"
        },
        {
          "character": "宫娥",
          "type": "内同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。太监抬杨贵妃雕像同上，众人进庙。〖大开门收〗。〖朝天子〗。"
        },
        {
          "character": "宫娥",
          "type": "同白",
          "text": "娘娘朝参。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖曲牌收〗。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓，阿呀！妃子吓！"
        },
        {
          "character": "唐明皇",
          "type": "上小楼",
          "text": "别离一向， 忽看娇样。 待与你叙我冤情，说我惊魂，话我愁肠。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子！"
        },
        {
          "character": "唐明皇",
          "type": "上小楼",
          "text": "怎不见你回笑庞， 答应响，移身前傍？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吖！"
        },
        {
          "character": "唐明皇",
          "type": "上小楼",
          "text": "原来是刻香檀做成的神像！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "传旨马儿在左，车儿在右，朕与娘娘并行者。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。 万岁爷有旨：马儿在左，车儿在右，万岁爷亲送娘娘入庙。"
        },
        {
          "character": "宫娥、太监",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "众人",
          "type": "同幺篇",
          "text": "谷碌碌凤车呵，紧贴着行； 袅亭亭龙鞭呵，相对着扬。 依旧到辇儿厮并，肩儿齐亚，影儿成双。 情暗伤心自想， 想当时联镳游赏， 怎到头来刚做了恁般随唱！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "已到庙门，请万岁爷下马。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宫娥们！伏侍娘娘升座者！"
        },
        {
          "character": "宫娥",
          "type": "同白",
          "text": "领旨。 娘娘谢恩。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖曲牌收〗。"
        },
        {
          "character": "唐明皇",
          "type": "快活三",
          "text": "俺只见有宫娥们簇拥将， 把团扇护新妆。 犹错认定情初夜入兰房。 可怎生冷清清独坐在这影画生绡帐？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "看香！"
        },
        {
          "character": "唐明皇",
          "type": "朝天子",
          "text": "热腾腾宝香，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "初上香。"
        },
        {
          "character": "唐明皇",
          "type": "朝天子",
          "text": "映荧荧烛光，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "上香。"
        },
        {
          "character": "唐明皇",
          "type": "朝天子",
          "text": "猛逗着往事来心上。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子！"
        },
        {
          "character": "唐明皇",
          "type": "朝天子",
          "text": "记当日在长生殿里御炉旁， 对牛女把深盟讲。 又谁知信誓荒唐， 存殁参商！ 空忆前盟不暂忘， 阿呀妃子吓！今日里我在这厢，你在哪厢。 把着这断头香在手掭凄怆！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士，看酒来，朕与娘娘亲奠一杯。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "是。初赐爵。"
        },
        {
          "character": "唐明皇",
          "type": "四边静",
          "text": "把杯来擎掌， 怎能够檀口还从我手内尝？ 按不住凄惶， 叫一声妃子也亲陈上。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "唐明皇",
          "type": "四边静",
          "text": "泪珠儿溶溶满觞，溶溶满觞！ 怕添不下半滴葡萄酿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖雁儿落〗。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "亚赐爵。 终赐爵。"
        },
        {
          "character": "唐明皇",
          "type": "四煞",
          "text": "奠灵筵礼已终， 诉衷情话正长。 你娇波不动可见我愁模样？ 只为我金钗钿盒情辜负， 致使你白练黄泉恨渺茫！ 向此际槌胸想， 好一似刀裁了肺腑， 火烙了肝肠！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "你看娘娘脸上流出泪来了。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "待奴婢看来。 咦，果然的流出泪来了！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓！啊呀妃子吓！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "啊呀娘娘吓！"
        },
        {
          "character": "唐明皇",
          "type": "三煞",
          "text": "只见她垂垂地湿满顾， 汪汪地含在眶， 纷纷地点滴在神台上。 分明是牵衣请死愁容貌， 回顾吞声惨面庞。 这伤心真无两。 休说是泥人堕泪， 便教那铁汉也肠慌！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "万岁爷请免悲伤，待奴婢们叩见娘娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高力士、众人同拜。"
        },
        {
          "character": "高力士、宫娥",
          "type": "同白",
          "text": "啊呀娘娘吓！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "唐明皇",
          "type": "二煞",
          "text": "只见老常侍双膝跪， 旧宫娥伙地伤， 叫不出娘娘千岁，一个个含悲向。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子！"
        },
        {
          "character": "唐明皇",
          "type": "二煞",
          "text": "只为你当日在昭阳殿里施恩遍， 今日个锦水祠中遗爱长。 悲风荡， 肠断煞数声杜宇，半壁斜阳！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "天色将晚，请万岁爷回宫，将息圣体。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宫娥们，把娘娘神帐放下者！"
        },
        {
          "character": "宫娥",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "摆驾！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。 唦！摆驾！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子，寡人是去了㖸！"
        },
        {
          "character": "唐明皇",
          "type": "尾声",
          "text": "出新祠泪未收， 转行宫痛怎忘？ 对残霞落日空凝望。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子！寡人今夜呵……"
        },
        {
          "character": "唐明皇",
          "type": "尾声",
          "text": "把哭不尽的衷情和你梦儿里再细讲！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇、众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}