{
  "script_id": "70902142",
  "title": "四声猿·骂曹",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "祢衡",
      "hangdang": "老生"
    },
    {
      "name": "判官",
      "hangdang": "净"
    },
    {
      "name": "曹操",
      "hangdang": "副"
    },
    {
      "name": "二鬼卒",
      "hangdang": "杂"
    },
    {
      "name": "四女乐",
      "hangdang": "旦"
    },
    {
      "name": "天史",
      "hangdang": "小生"
    }
  ],
  "plot": "祢衡在阴司劫数已满，将为仙，阎罗殿判官令其重演当年击鼓骂曹之事，其间曹操不时为自己辩解。骂完后，\n曹操继续收监，祢衡则奉召升天。",
  "notes": "此剧为昆剧老生的重要剧目，其中一套完整的北曲〖点绛唇〗，曲子较多，演唱时有一定的难度。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "判官、鬼卒甲同上。"
        },
        {
          "character": "判官",
          "type": "念",
          "text": "俺这里算子忒明白，善恶到头撒不来。就是那少债的会躲，也躲不得几时，却 从来没有不还的债。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鬼卒乙上。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "俺，姓蔡名幽，字能平，别号火球道人。平生善断持公，在五殿阎罗天子殿下， 做一个洒落的好判官。当日祢衡先生与曹操对讦那一桩公案，是俺掌管。向 来祢先生气概超群，才学出众，凡一应文书皆着他起草，待以上宾。昨日晚衙， 殿主对咱说，上帝所用一伙修文郎，并皆迁次别用。今拟召刑满应补之人， 祢先生亦在其内。他如今不久要上天去了，俺待要请他出来，把当日打鼓骂曹 之事演说一番，留在阴司做个千古美谈，有何不可。 鬼卒，请祢先生。"
        },
        {
          "character": "鬼卒甲",
          "type": "白",
          "text": "祢先生有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡嗽上。"
        },
        {
          "character": "祢衡",
          "type": "念",
          "text": "挝鼓掀槌骂未休，无端枉害恨悠悠。不平正气将为出，留与人间作话头。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "吓，判翁大人请了。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "请了。请坐。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "有坐。大人见召，有何台谕？"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "请先生到来非为别事，想当日打鼓骂曹，实为天下奇事。今日再请先生，权做 旧日的模样，演述那骂座的光景，了此夙愿。不知先生意下如何？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "这，有何不可。只是一件，当日骂座之时，那曹瞒罪恶，尚未有如此之多，倘 骂将来，恐冷淡寂寥。今日要骂，须直骂到铜雀台分香卖履，方得个痛快人心。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "先生见教得极是。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "吓，判翁大人。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "祢先生。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "你一向谦厚，不肯坐观。但当日骂座之时，那曹瞒原有宾客在座，今日权仗大 人，为曹瞒之宾，坐而观之，方成体统。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "如此妙极。 鬼卒，带曹操。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡暗下。"
        },
        {
          "character": "鬼卒甲",
          "type": "白",
          "text": "曹操走动。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "曹操当面。啊呀判爷饶命吓！"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "曹操，今日要你扮做当日丞相模样，与祢先生演述昔日打鼓骂曹的故事。你若 是做得那等小心畏惧，藏过了那些狠恶的模样，嘿嘿，鬼卒，赏他一百铁鞭！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "是是是，判爷吩咐敢不遵命。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "带去更衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鬼卒甲带曹操同下。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "吩咐起乐。"
        },
        {
          "character": "鬼卒乙",
          "type": "白",
          "text": "起乐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖春日景和〗。曹操上。〖曲牌〗收。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大人请。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "丞相请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖傍妆台〗。定席。〖曲牌〗收。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓，大人，我们下有一鼓吏，名唤祢衡，可要叫他出来挝鼓侑酒如何？"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来，唤祢衡。"
        },
        {
          "character": "鬼卒乙",
          "type": "白",
          "text": "丞相唤祢衡。"
        },
        {
          "character": "祢衡",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "点绛唇",
          "text": "俺本是避乱辞家，遨游许下，登楼罢，回首天涯，不想道屈身躯扒出他们胯。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "狂生，你既为鼓吏，自有本等服色，怎不换来。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "俺就换来也。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "丞相请。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大人请。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "祢衡",
          "type": "混江龙",
          "text": "他那里开筵下榻， 叫俺操槌按板把鼓来挝， 正好俺借槌来打落， 又合着鸣鼓攻他。 嘚，曹操！ 俺这骂，一句句锋芒飞剑戟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡击鼓。"
        },
        {
          "character": "祢衡",
          "type": "混江龙",
          "text": "这鼓，一声声霹雳捲风沙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡划皮。"
        },
        {
          "character": "祢衡",
          "type": "混江龙",
          "text": "这皮是恁身儿上躯壳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡击槌。"
        },
        {
          "character": "祢衡",
          "type": "混江龙",
          "text": "这槌，是恁嘴儿上獠牙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡划鼓钉。"
        },
        {
          "character": "祢衡",
          "type": "混江龙",
          "text": "这钉孔儿，是恁心窝里毛窍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡击鼓身。"
        },
        {
          "character": "祢衡",
          "type": "混江龙",
          "text": "这板杖儿，是恁肘儿下肋巴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡击鼓二下。"
        },
        {
          "character": "祢衡",
          "type": "混江龙",
          "text": "两头蒙，总打得恁泼皮穿。 俺一时间也酬不尽恁亏心大， 且从头数起， 嘚，曹操！ 恁洗耳听咱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打第一段鼓。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "狂生，我教你打鼓，怎么指东划西，将人比畜？我这里铜锤铁杖好不厉害，仔 细你那舌头和那牙齿。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "这生果然无礼。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "嘚，曹操！"
        },
        {
          "character": "祢衡",
          "type": "油葫芦",
          "text": "第一来逼献帝迁都又将伏后来杀， 使郗虑去拿。 嗳，可怜那九重天子， 救不得一浑家。 帝道后少不得恁先行， 咱也只在目下。 更有那两个儿， 又不是别树上花。 都总是姓刘的亲骨血， 在宫中长大， 却怎生把那龙雏凤种做一瓮鲊鱼虾。"
        },
        {
          "character": "祢衡",
          "type": "夹白",
          "text": "那董贵人呵！"
        },
        {
          "character": "祢衡",
          "type": "天下乐",
          "text": "是汉天子第二位嗳美娇娃， 她该什么刑罚？ 恁差也不差？ 她肚子里又怀着两三月小娃娃， 恁便既杀了她娘， 又连着胞搭， 把那娘儿们两口砍做血虾蟆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打第二段鼓。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "狂生，自古风吹草动，人要害虎，虎也要害人。那伏后与董承等，谋图害俺， 故有此举。纵不然是俺先怀歹意，去害他们的么？"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "丞相说得是。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "嘚，曹操！你把汉天子呵！"
        },
        {
          "character": "祢衡",
          "type": "哪吒令",
          "text": "他若讨吃么，恁与他几块歪喇， 他若讨穿么，恁与他几匹檾麻。 他有时传旨么， 叫鬼来与拿。 是石人也动心， 是石人也动心。 纵痴人也害怕， 羊也咬人家。"
        },
        {
          "character": "祢衡",
          "type": "鹊踏枝",
          "text": "袁公那两家， 也不留片甲， 刘琮那一答， 又逼他来献纳。"
        },
        {
          "character": "祢衡",
          "type": "夹白",
          "text": "孙权呵！"
        },
        {
          "character": "祢衡",
          "type": "鹊踏枝",
          "text": "几遍几乎，"
        },
        {
          "character": "祢衡",
          "type": "夹白",
          "text": "玄德呵！"
        },
        {
          "character": "祢衡",
          "type": "鹊踏枝",
          "text": "两边价抢他的妈妈， 是处儿城空战马， 递年来尸满啼鸦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打第三段鼓。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大人，那时天下乱纷纷，非是曹操一人耳。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "俺阴司都有案卷。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "嘚，曹操！"
        },
        {
          "character": "祢衡",
          "type": "寄生草",
          "text": "仗威风只自假， 进官爵不由他。 一个女孩儿竟坐在中宫驾， 骑中郎直做到侯王霸。 铜雀台直把那云烟架， 僭车旗直按到朝廷胯。 恁当时险夺玉皇尊， 到如今还使得阎罗怕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打第四段鼓。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "嘚！打鼓的，你且停了鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "闻得丞相府中，有班女乐，何不唤出来侑酒如何？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哟，这是往事，如今哪里还有？"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "你唤自然就有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "是。 来，唤女乐。"
        },
        {
          "character": "鬼卒甲",
          "type": "白",
          "text": "女乐们走动。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女乐同上。"
        },
        {
          "character": "四女乐",
          "type": "同白",
          "text": "来了。"
        },
        {
          "character": "四女乐",
          "type": "同念",
          "text": "当日无情落花去，今朝相识燕归来。"
        },
        {
          "character": "四女乐",
          "type": "同白",
          "text": "女乐们叩头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "起来。你们自造一个小令儿，好生歌唱。"
        },
        {
          "character": "四女乐",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "四女乐",
          "type": "同悠悠曲",
          "text": "那里一个大鹈鹕呀， 一个抵都，呀一个抵都， 变一个花猪抵打都、打抵都。 唱鹧鸪呀一个抵都、呀呀一个抵都。 唱得好时犹自可呀一个抵都、呀一个抵都， 不好之时抵打都、打抵都， 唤王屠呀一个抵都、呀呀一个抵都。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "什么王屠？"
        },
        {
          "character": "四女乐",
          "type": "同白",
          "text": "王屠杀猪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "㕶。斟酒。"
        },
        {
          "character": "四女乐",
          "type": "同白",
          "text": "是！"
        },
        {
          "character": "四女乐",
          "type": "同悠悠曲",
          "text": "丞相做事太心欺呀， 一个跷蹊，呀一个跷蹊。 引得旁人跷打蹊，打跷蹊， 说是非呀一个跷跷，呀呀一个跷蹊。 雪隐鹭鸶飞始见呀，一个跷蹊，呀一个跷蹊， 树藏鹦鹉跷打蹊，打跷蹊，语方知呀一个跷蹊，呀呀一个跷蹊。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这都是旧话，提它怎么。"
        },
        {
          "character": "四女乐",
          "type": "同白",
          "text": "虽是旧话，倒也切题。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "斟酒。"
        },
        {
          "character": "四女乐",
          "type": "同悠悠曲",
          "text": "抹粉搽脂这一回儿红呀， 一个冬烘，呀一个冬烘，报恩结怨烘打冬，打冬烘， 落花风呀一个冬烘，呀呀一个冬烘。 万事不由人计较呀，一个冬烘，呀一个冬烘， 算来都是烘打冬，打冬烘， 一场空呀一个冬烘，呀呀一个冬烘。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "回避了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女乐同下。祢衡暗上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大人，我倦得紧了，要去睡了。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "你要睡么？ 鬼卒，赏他一百铁鞭！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "是是是，醒了，醒了。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "嘚，曹操，你便倦了。俺的鼓儿、骂儿还不倦哩！"
        },
        {
          "character": "祢衡",
          "type": "六幺令",
          "text": "恁哄他人口似蜜， 害贤良只当耍。 把一个杨德祖立斩在辕门下， 碜磕磕血洒零落。 孔先生丹鼎灵砂，月底金蟆，仙观琼花， 易奇而法，诗正而葩。 他两个嫌隙与恁只有针尖儿大， 不过是口唠噪，有甚争差。 一个为忒聪明，参透了鸡肋话， 一个是一言不洽，都双双命淹黄沙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡打第五段鼓。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吓大人，我曹操其实是冤枉的。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "难道那人的头儿，是自己掉下来的么？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "是是是。 祢先生，俺也曾有些好处待你，休埋没了俺。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "祢先生，再骂他几句。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "嘚，曹操！"
        },
        {
          "character": "祢衡",
          "type": "煞尾",
          "text": "恁造铜雀要锁二乔，谁想道梦巫峡， 羞杀恁靠赤壁火烧一把。"
        },
        {
          "character": "祢衡",
          "type": "夹白",
          "text": "你临死呵！"
        },
        {
          "character": "祢衡",
          "type": "煞尾",
          "text": "和那些歪喇们话离别， 又卖履分香待怎么？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢爷爷饶了我罢。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "俺且饶你。"
        },
        {
          "character": "祢衡",
          "type": "煞尾",
          "text": "争奈我渔阳三弄、鼓槌儿乏。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "把曹操带去收监。"
        },
        {
          "character": "天史",
          "type": "内白",
          "text": "玉旨下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鬼卒甲带曹操同下，祢衡暗下。〖小开门〗。天史上。祢衡换官服上。〖曲牌〗收。"
        },
        {
          "character": "天史",
          "type": "白",
          "text": "玉旨下跪。"
        },
        {
          "character": "祢衡、判官",
          "type": "同白",
          "text": "圣寿无疆！"
        },
        {
          "character": "天史",
          "type": "白",
          "text": "玉帝有旨，案下旧有修文郎，向有迁次别用。拟召劫满应补之人，以备原例。 兹尔祢衡，才华盖绝一世，豪气又贯于千秋，禠奸雄之魄于操槌，逞狂士之怀 作鼓吏，昔为千古奇人，今作九天仙吏，特授尔符册，擢登录籍，钦哉受旨！"
        },
        {
          "character": "祢衡、判官",
          "type": "同白",
          "text": "圣寿无疆！"
        },
        {
          "character": "天史",
          "type": "白",
          "text": "请过玉旨。香案供奉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡接旨，鬼卒乙应，下。"
        },
        {
          "character": "天史",
          "type": "白",
          "text": "吓，祢先生。"
        },
        {
          "character": "天史",
          "type": "耍孩儿",
          "text": "挟鸿名懒去投， 赋鹦哥点不加。 你文光直透在三台下， 奇禽瑞兽虽佳兆，倚马雕龙却祸芽。"
        },
        {
          "character": "天史",
          "type": "夹白",
          "text": "吓，祢先生，谁似你先凶后吉。"
        },
        {
          "character": "天史",
          "type": "耍孩儿",
          "text": "这好花样有谁能搨， 待枣儿甜口，已橄榄酸牙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "天史下。"
        },
        {
          "character": "祢衡",
          "type": "一煞",
          "text": "向天门渐不遥，我辞地主痛愈加， 几时再得陪清话。 风波满眼君为主， 攩裘马朝天我即家。"
        },
        {
          "character": "祢衡",
          "type": "夹白",
          "text": "吓判翁大人，下官有句话。"
        },
        {
          "character": "判官",
          "type": "夹白",
          "text": "请教。"
        },
        {
          "character": "祢衡",
          "type": "一煞",
          "text": "大包容饶了曹瞒罢， 我想那眼前孽景，尽雨后春花。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "来此已是阴阳交界，下官不能越境相送，就此拜别。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "下官也有一拜。"
        },
        {
          "character": "判官",
          "type": "尾声",
          "text": "自古道胜读十年书，"
        },
        {
          "character": "祢衡",
          "type": "尾声",
          "text": "与君一席话。"
        },
        {
          "character": "判官",
          "type": "尾声",
          "text": "提醒人都指鹿作马，"
        },
        {
          "character": "祢衡",
          "type": "尾声",
          "text": "方信道曼倩诙谐，也不是耍。"
        },
        {
          "character": "祢衡、判官",
          "type": "同笑",
          "text": "吓哈哈……"
        },
        {
          "character": "祢衡、判官",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。祢衡、判官自两边分下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
