{
  "script_id": "70902129",
  "title": "长生殿·惊变",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "唐明皇",
      "hangdang": "冠生"
    },
    {
      "name": "杨贵妃",
      "hangdang": "五旦"
    },
    {
      "name": "高力士",
      "hangdang": "丑"
    },
    {
      "name": "杨国忠",
      "hangdang": "白面"
    }
  ],
  "plot": "唐明皇和杨贵妃在御花园中，游赏秋景，浅斟低酌。杨妃用李白所做“清平词”为歌舞，唐明皇大悦，劝饮\n至醉。宫廷中正在欢娱，杨国忠入奏安禄山称兵做乱，已破潼关，即到长安。唐明皇大惊，传旨天下勤王，\n起驾幸蜀避祸。",
  "notes": "这是以大冠生和闺门旦为主的昆曲著名剧目，歌舞、表演，都很有精采之处。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高力士上。"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "玉楼天半起笙歌，风送宫娥笑语和。月影殿开闻夜漏，水晶帘卷近秋河。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "咱家高力士。奉万岁爷之命，着咱家在御花圈中，安排小宴，要与贵妃娘娘同 来游赏，只得在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水龙吟〗。众内侍、众宫娥引唐明皇、杨贵妃同上。〖曲牌〗收。"
        },
        {
          "character": "唐明皇、杨贵妃",
          "type": "同粉蝶儿",
          "text": "天淡云闲， 列长空数行新雁。 御园中，秋色斓斑： 柳添黄，苹减绿，红莲脱瓣。 一抹雕栏， 喷清香桂花初绽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "奴婢高力士接驾，请万岁爷、娘娘下辇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇、杨贵妃同下辇。〖曲牌〗收。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "吓，陛下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子，朕和你散步一回。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下请。"
        },
        {
          "character": "唐明皇、杨贵妃",
          "type": "同泣颜回",
          "text": "携手向花间， 暂把幽怀同散。 凉生亭下， 风荷映水翩翻。"
        },
        {
          "character": "杨贵妃",
          "type": "泣颜回",
          "text": "爱桐阴静悄，碧沉沉。"
        },
        {
          "character": "唐明皇、杨贵妃",
          "type": "同泣颜回",
          "text": "并绕回廊看， 恋香巢秋燕依人，"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下。"
        },
        {
          "character": "杨贵妃",
          "type": "泣颜回",
          "text": "睡银塘鸳鸯醮眼。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓哈哈…… 高力士，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "酒宴过来。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "宴已摆齐，请万岁爷、娘娘上宴。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "待臣妾把盏。 吓，陛下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓，阿呀呀妃子！"
        },
        {
          "character": "唐明皇",
          "type": "石榴花",
          "text": "不劳恁玉纤纤高捧礼仪烦， 只待小饮对眉山。 俺与恁浅斟低唱互更番， 三杯两盏，遣兴捎闲。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下请。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子请。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "干。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "干。妃子，今日虽是小宴，倒也清雅。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "便是。"
        },
        {
          "character": "杨贵妃",
          "type": "石榴花",
          "text": "回避了御厨中， 回避了御厨中， 烹龙炰凤堆盘案， 咿咿哑哑乐鼓劲催趱。 只几味脆生生， 只几味脆生生蔬菜和果清肴馔， 雅称你仙肌玉骨美人餐。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下请。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子请。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "干。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "干。妃子，朕和你清幽小饮，那些梨园旧曲，都不耐烦听它。记得那年在沉香 亭赏牡丹，召翰林李白，草“清平词”三章，命李龟年度成新谱，其词甚佳。 不知妃子可还记得？"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "妾还记得。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "为朕歌之。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "待朕按板。"
        },
        {
          "character": "杨贵妃",
          "type": "泣颜回",
          "text": "花繁浓艳想容颜， 云想衣裳光璩。 新妆谁似？可怜飞燕娇懒！ 名花国包笑微微， 常得君王看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐明皇笑。"
        },
        {
          "character": "杨贵妃",
          "type": "泣颜回",
          "text": "向春风解释春愁， 沉香亭同倚栏杆。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓，哈哈哈！妙哉！李白锦心，妃子绣口，真乃双绝也！ 宫娥们。"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "取巨觥来，朕与娘娘对饮。"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "唐明皇",
          "type": "斗鹌鹑",
          "text": "畅好是喜孜孜驻拍停歌， 喜孜孜驻拍停歌， 笑吟吟传杯弄盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖回回曲〗。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子请。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下请。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "干。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "干。"
        },
        {
          "character": "唐明皇",
          "type": "斗鹌鹑",
          "text": "不须他絮烦烦射覆藏钩， 絮烦烦射覆藏钩， 闹纷纷弹丝弄板。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖回回曲〗。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宫娥仪容斟酒。"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妃子，再请一杯。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "臣妾不能饮了。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宫娥们，跪劝娘娘。"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "领旨。 请娘娘再干一杯。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓，妃子请。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "陛下请。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "干。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "噢……"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "干。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "噢……"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "干、干、干吓！⑴"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨贵妃吐。〖曲牌〗收。"
        },
        {
          "character": "唐明皇",
          "type": "笑",
          "text": "吓，哈哈哈！"
        },
        {
          "character": "唐明皇",
          "type": "斗鹌鹑",
          "text": "我这里无语持觞仔看细。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "妙！"
        },
        {
          "character": "唐明皇",
          "type": "斗鹌鹑",
          "text": "早只见花一朵上腮间。 一会价软哈哈柳亸花欹， 软哈哈柳亸花欹， 困腾腾莺娇懒。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓，妃子！妃子！"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "娘娘醉了。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吖，妃子竟醉了！ 宫娥们，"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "好生扶娘娘回宫去罢。"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "领旨。 请娘娘回宫。"
        },
        {
          "character": "杨贵妃",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "杨贵妃",
          "type": "扑灯蛾",
          "text": "态恹恹轻云软四肢， 影蒙蒙空花乱双眼， 娇怯怯柳腰扶难起， 困沉沉强抬娇腕， 软设设金莲倒褪， 乱松松香肩亸云鬟。 美甘甘思寻凤枕， 几步迟迟倩宫娥搀入绣帏间。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "扶好了。"
        },
        {
          "character": "众宫娥",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众宫娥扶杨贵妃同下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "扶好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖鼓声〗。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吓？何处鼓声骤发？ 高力士，出去看来！"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨国忠上。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "啊呀，不好了！"
        },
        {
          "character": "杨国忠",
          "type": "念",
          "text": "渔阳鼙鼓动地来，惊破霓裳羽衣曲。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "高公公。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "杨老先。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "万岁爷在哪里？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "在御花园中。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "军情紧急，不免径入。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "杨丞相朝参。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "臣杨国忠见驾，愿吾皇万岁，万岁！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "卿有何事，这等慌张？"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "启陛下不好了！禄山造反，杀破潼关，不日就到长安了！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "守关将士安在？"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "哥舒翰兵败，已降贼了！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "吖，啊呀！"
        },
        {
          "character": "唐明皇",
          "type": "上小楼",
          "text": "恁道失机的哥舒翰， 称兵的安禄山。 赤紧的离了渔阳， 赤紧的离渔阳， 陷了东京，破了潼关。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "唬，"
        },
        {
          "character": "唐明皇",
          "type": "上小楼",
          "text": "唬得人胆战心摇， 唬得人胆战心摇， 肠荒腹热，魂飞魄散！ 早惊破月明花粲！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "卿有何策，可退敌兵？"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "臣当日再三启奏，禄山必反，陛下不听，如今果应臣言。事起仓卒，怎生抵敌？ 莫若权时幸蜀，以待天下勤王。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "依卿所奏，快传旨，命诸王百宫，即且随驾幸蜀便了。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨国忠下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高力士。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "命右龙将军陈元礼，统领羽林军三千，护驾前行。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高力士下。太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "请万岁爷回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "咳！正尔欢娱，忽而此变，怎生是了！"
        },
        {
          "character": "唐明皇",
          "type": "扑灯蛾",
          "text": "嗳稳，稳的宫廷晏安， 吖哈扰，扰的边廷造反。 冬冬的鼙鼓喧，腾腾的烽火黫， 滴溜扑碌臣民逃散。 黑漫漫乾坤覆翻， 碜磕磕社稷摧残， 碜磕磕社稷摧残！ 嗳，萧萧飒飒西风送晚， 黫黫的一轮落日冷长安！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宫娥们！"
        },
        {
          "character": "众宫娥",
          "type": "内同白",
          "text": "有。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "杨娘娘可曾安寝？"
        },
        {
          "character": "众宫娥",
          "type": "内同白",
          "text": "安寝了。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "不要惊她，且待明朝五鼓同行。"
        },
        {
          "character": "众宫娥",
          "type": "内同白",
