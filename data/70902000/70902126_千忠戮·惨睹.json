{
  "script_id": "70902126",
  "title": "千忠戮·惨睹",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "建文帝",
      "hangdang": "冠生"
    },
    {
      "name": "程济",
      "hangdang": "老生"
    }
  ],
  "plot": "明初，燕王朱棣举兵“靖难”，迫使其侄建文帝让位，并大批杀戮朝臣，甚至株连十族。《惨睹》写建文帝\n剃度为僧，逃窜在外，一路上看到被杀朝臣，传首四方，以及被牵连的在乡臣子和宦门妇女，押解赴京，种\n种惨状，不忍目睹，因而悲愤万分。",
  "notes": "全出由八支曲子组成，每曲都以“阳”字结束，故又名“八阳”。长期以来，传唱不衰，所谓“家家收拾起”，\n即指第一支曲首句“收拾起大地山河一担装”而言。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "程济",
          "type": "内白",
          "text": "大师趱路！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济随建文帝同上。"
        },
        {
          "character": "建文帝",
          "type": "倾杯玉芙蓉",
          "text": "收拾起大地山河一担装， 四大皆空相。 历尽了渺渺程途，漠漠平林，垒垒高山，滚滚长江。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "我自吴江别了诸徒出门，师弟两人，一路登山涉水，夜宿晓行。一天心事，都 付浮云，七尺形骸，甘为行脚。身似闲云野鹤，心同槁木死灰。"
        },
        {
          "character": "建文帝",
          "type": "倾杯玉芙蓉",
          "text": "但见那寒云惨雾和愁织， 受不尽苦雨凄风带怨长。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "程徒。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "前面是哪里了？"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "是襄阳城了。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "嗄？喔唷！"
        },
        {
          "character": "建文帝",
          "type": "倾杯玉芙蓉",
          "text": "雄城壮，看江山无恙， 谁识我一瓢一笠到襄阳。"
        },
        {
          "character": "二旗牌",
          "type": "内同白",
          "text": "走吓！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师那边有许多车辆来了，我们且躲过一边。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "是，是，是，躲过一边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "建文帝、程济同下。"
        },
        {
          "character": "二旗牌",
          "type": "内同白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌、二车夫同上。"
        },
        {
          "character": "二旗牌、二车夫",
          "type": "同刷子芙蓉",
          "text": "颈血溅干将， 尸骸零落，暴露堪伤。 又首级纷纷，驱驰枭示他方。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "咳！想皇上杀了许多大臣，就在京城号令罢了，又听陈御史之言，凡系哪处人 犯，发往本处号令，把头儿装了数十车辆，着咱们各处分解。这样苦差，好不 耐烦！"
        },
        {
          "character": "二车夫",
          "type": "同白",
          "text": "其实苦差！"
        },
        {
          "character": "旗牌乙",
          "type": "白",
          "text": "嗳！不要说了，起来趱路。"
        },
        {
          "character": "二旗牌、二车夫",
          "type": "同刷子芙蓉",
          "text": "凄凉，叹魂魄空飘天际， 叹骸骨谁埋土壤？"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "车夫们，把车辆打伙而行，不要催前落后。"
        },
        {
          "character": "二车夫",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "咳！俺想那些众公卿，到今日里呵！"
        },
        {
          "character": "二旗牌、二车夫",
          "type": "同刷子芙蓉",
          "text": "堆车辆，看忠臣榜样， 枉铮铮自夸鸣凤在朝阳。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌、二车夫同下。建文帝、程济同上。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "吓！看车儿上都是我臣子的首级，好痛心也！"
        },
        {
          "character": "建文帝",
          "type": "锦芙蓉",
          "text": "裂肝肠！痛诛夷盈朝丧亡，郊野血汤汤。 好头颅如山，车载奔忙。 又不是逆朱温清流被祸， 早做了暴嬴秦儒类遭殃！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师，此乃臣子分内之事，不必悲伤，我们趱路要紧。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "咳！为我一人，连累万人性命，是我累及他们了！"
        },
        {
          "character": "建文帝",
          "type": "锦芙蓉",
          "text": "添悲怆，叹忠魂飘飏， 羞杀我独存一息泣斜阳。"
        },
        {
          "character": "女差",
          "type": "内白",
          "text": "趱路！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师，那边许多犯妇来了，且闪过一边。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "是，是，是，闪过一边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程济、建文帝同下。女差上。"
        },
        {
          "character": "女差",
          "type": "白",
          "text": "趱路！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众犯妇同上。"
        },
        {
          "character": "众犯妇",
          "type": "同白",
          "text": "苦吓！"
        },
        {
          "character": "众犯妇",
          "type": "同雁芙蓉",
          "text": "苍苍呼冤震响， 流血泪千行万行。 家抄命丧资倾荡， 害妻孥徙他乡。"
        },
        {
          "character": "女差徙",
          "type": "白",
          "text": "他乡，徙他乡，你们不曾看见那些夫人小姐？砍的砍，剐的剐，还要发教坊， 赏象奴，不知死去了千千万万，哪在你们这几百个么？"
        },
        {
          "character": "众犯妇",
          "type": "同雁芙蓉",
          "text": "啊呀苦吓！ 叹匹妇沟渠抛丧。"
        },
        {
          "character": "众犯妇",
          "type": "同哭",
          "text": "啊呀！"
        },
        {
          "character": "女差",
          "type": "白",
          "text": "吓？怎么你们都睡倒了？"
        },
        {
          "character": "众犯妇",
          "type": "同白",
          "text": "我们鞋弓袜小，走不动了。"
        },
        {
          "character": "女差",
          "type": "白",
          "text": "鞋弓袜小走不动？嘿！谁教你们当初，把这个脚，裹得这样一兜兜的，要讨老 公的喜欢！你瞧老娘的脚多大，要走一百，就是一百，要走二百，就是二百， 好不爽快。快跟我起来走！"
        },
        {
          "character": "众犯妇",
          "type": "同白",
          "text": "我们实是走不动了。"
        },
        {
          "character": "女差",
          "type": "白",
          "text": "啊？你们不走，招老娘的打！"
        },
        {
          "character": "众犯妇",
          "type": "同白",
          "text": "啊呀！"
        },
        {
          "character": "众犯妇",
          "type": "同雁芙蓉",
          "text": "啊呀天吓！ 真悲怆，纵偷生肮脏， 倒不如钢刀骈首丧云阳。"
        },
        {
          "character": "女差",
          "type": "白",
          "text": "趱路！"
        },
        {
          "character": "众犯妇",
          "type": "同白",
          "text": "苦吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女差、众犯妇同下。建文帝、程济同上。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "好恼吓，好恼！纵然杀戮忠臣，与这些妇女们何干？"
        },
        {
          "character": "建文帝",
          "type": "小桃映芙蓉",
          "text": "惨听著哀号莽， 惨睹著俘囚状。 裙钗何罪遭一网？ 连抄十族新刑创。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "这也是人间浩劫，天降灾殃了。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "建文帝",
          "type": "小桃映芙蓉",
          "text": "纵然是天灾降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "建文帝",
          "type": "stage",
          "text": "消不得诛屠恁广。 𠲔！"
        },
        {
          "character": "建文帝",
          "type": "小桃映芙蓉",
          "text": "恨少个裸衣挝鼓骂渔阳。"
        },
        {
          "character": "男差",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师，后面又有许多犯官来了，我们再躲过一边。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "是，是，是，再躲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "建文帝、程济同下。男差、众犯官同上。"
        },
        {
          "character": "男差",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "众犯官",
          "type": "同普天芙蓉",
          "text": "为邦家输忠谠， 尽臣职忤强项。"
        },
        {
          "character": "男差",
          "type": "白",
          "text": "只因你们要做忠臣，故此圣上特来奉请。"
        },
        {
          "character": "众犯官",
          "type": "同白",
          "text": "我们久不为官，又来拿解，岂不冤枉？"
        },
        {
          "character": "众犯官",
          "type": "同普天芙蓉",
          "text": "山林隐甘学佯狂， 俘囚往誓死翱翔。"
        },
        {
          "character": "男差",
          "type": "白",
          "text": "你们有话，到圣上面前去讲。"
        },
        {
          "character": "众犯官",
          "type": "同白",
          "text": "呀呸！讲什么？要砍就砍罢了！"
        },
        {
          "character": "犯官甲",
          "type": "白",
          "text": "吓，列位老先生。"
        },
        {
          "character": "众犯官",
          "type": "同白",
          "text": "老先生。"
        },
        {
          "character": "犯官甲",
          "type": "白",
          "text": "总是我们不是，当初无能御敌，直至纵虎归山，悔之晚矣！"
        },
        {
          "character": "众犯官",
          "type": "同白",
          "text": "是吓！"
        },
        {
          "character": "男差",
          "type": "白",
          "text": "好一班不知死活的囚徒！"
        },
        {
          "character": "众犯官",
          "type": "同普天芙蓉",
          "text": "空悲壮，负君恩浩荡， 拼得个死为厉鬼学睢阳！"
        },
        {
          "character": "男差",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "男差、众犯官同下。建文帝、程济同上。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "罢了吓罢了。我只道独诛戮朝中臣宰，不想又捕捉那些弃职官员。正人君子吓， 定无噍类矣！"
        },
        {
          "character": "建文帝",
          "type": "朱奴插芙蓉",
          "text": "眼见得普天受枉， 眼见得忠良尽丧。 张毒焰古来无两。 程济"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "大师，天色已晚，趱路要紧。"
        },
        {
          "character": "弥天怨气冲千丈、建文帝",
          "type": "白",
          "text": "咳！我想做忠臣的到这个地位，那些读书的，还要做什么官？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱奴插芙蓉"
        },
        {
          "character": "弥天怨气冲千丈、建文帝",
          "type": "stage",
          "text": "我言非戆劝冠裳罢想， 倒不如躬耕陇亩卧南阳。 程济"
        },
        {
          "character": "弥天怨气冲千丈、建文帝",
          "type": "白",
          "text": "此处湖广要道，京中来往公干甚多，倘有识认，祸生不测。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "阿呀！这便怎么处？"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "不妨。我们且赶到武冈州，速往贵州，直至云南，深山居住，方可安身。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "如此快走。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师请。"
        },
        {
          "character": "建文帝",
          "type": "尾声",
          "text": "路迢迢，心怏怏。"
        },
        {
          "character": "程济",
          "type": "尾声",
          "text": "何处得稳宿梧枝上？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟声。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "咦？程徒，景阳钟鸣了！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "吓，大师，此乃野寺晚钟，非景阳钟也。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "嗄！咳！"
        },
        {
          "character": "建文帝",
          "type": "尾声",
          "text": "错听了野寺钟鸣误景阳。"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "大师趱路。"
        },
        {
          "character": "建文帝",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "程济",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "建文帝、程济同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}