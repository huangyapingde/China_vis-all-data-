{
  "script_id": "70902119",
  "title": "玉簪记·琴挑",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "潘必正",
      "hangdang": "巾生"
    },
    {
      "name": "陈妙常",
      "hangdang": "五旦"
    }
  ],
  "plot": "书生潘必正，寄居在其姑母所住的女贞观中，得遇道姑陈妙常，深为爱慕。一夕，闻听琴韵清幽，循声而往，\n乃陈妙常所弹。潘必正遂借琴曲以挑之。陈妙常虽亦有意，碍于戒律，故作嗔据。但情愫已通，从此心心\n相印了。",
  "notes": "《琴挑》曲调优美，久著曲坛；表演上也很细腻，是生、旦戏中的佳作。俞振飞常演出此戏，和程砚秋先生\n合作的次数最多。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "潘必正上。"
        },
        {
          "character": "潘必正",
          "type": "懒画眉",
          "text": "月明云淡露华浓， 欹枕愁听四壁蛩。 伤秋宋玉赋西风， 落叶惊残梦。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "小生对此溶溶夜月，悄悄闲庭，背井离乡，孤衾独枕，好生烦闷。呀，不免到 白云楼下闲步一回，多少是好。"
        },
        {
          "character": "潘必正",
          "type": "懒画眉",
          "text": "闲步芳尘数落红。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常上。"
        },
        {
          "character": "陈妙常",
          "type": "懒画眉",
          "text": "粉墙花影自重重， 帘卷残荷水殿风。 抱琴弹向月明中， 香袅金猊动。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "我妙常，连日冗冗俗事，未曾整理冰弦。今夜月明如水，夜色新凉，不免弹潇 湘水云一曲，稍寄幽情。"
        },
        {
          "character": "陈妙常",
          "type": "懒画眉",
          "text": "人在蓬莱第几宫。"
        },
        {
          "character": "潘必正",
          "type": "懒画眉",
          "text": "步虚声度许飞琼， 乍听还疑别院风。"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "妙！"
        },
        {
          "character": "潘必正",
          "type": "懒画眉",
          "text": "听凄凄楚楚那声中， 谁家夜月琴三弄。 细数离情曲未终。"
        },
        {
          "character": "陈妙常",
          "type": "懒画眉",
          "text": "朱弦声杳恨溶溶，"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "原来陈姑在此操琴，门儿半掩，不免挨身而进。"
        },
        {
          "character": "陈妙常",
          "type": "夹白",
          "text": "咳！"
        },
        {
          "character": "陈妙常",
          "type": "懒画眉",
          "text": "长叹空随几阵风。"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "弹得好吓！"
        },
        {
          "character": "陈妙常",
          "type": "夹白",
          "text": "呀！"
        },
        {
          "character": "陈妙常",
          "type": "懒画眉",
          "text": "仙郎何处入帘栊， 早是人惊恐。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "小儿独坐无聊，步月闲行到此，惊动了。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "相公此来呵！"
        },
        {
          "character": "陈妙常",
          "type": "懒画眉",
          "text": "莫不为听云水声寒一曲中？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "小生忽听花下，琴声嘹亮，清响绝伦，不觉闲步到此。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "小道亦见月明如水，夜色清凉，故而操弄丝桐，少遣岑寂。远辱尊听，实切惶 恐。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "久闻足下，指法精妙，操弄绝佳。欲乘此兴，请教一曲如何？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "小生略知一二，只是班门弄斧，怎好出丑。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "休得太谦，定要请教。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "如此请。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "有坐。好琴吓！"
        },
        {
          "character": "潘必正",
          "type": "琴曲",
          "text": "雉朝雊兮清霜， 惨孤飞兮无双。 念寡阴兮少阳， 怨鳏居兮彷徨，彷徨。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "好！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "出丑！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "此乃雉朝飞也。君方盛年，何故弹此无妻之曲？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "小生实未有妻！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "这也不关我事！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "欲求仙姑……"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "呀，面教一曲如何？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "既听佳音，以清俗耳，何必初学，又乱芳声。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "休得太谦，请教了。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "但恐污耳。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "献丑了。"
        },
        {
          "character": "陈妙常",
          "type": "琴曲",
          "text": "烟淡淡兮轻云， 香霭霭兮桂阴。"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "请教。 叹长宵兮孤冷，"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "弹得好吓！"
        },
        {
          "character": "陈妙常",
          "type": "夹白",
          "text": "请坐！"
        },
        {
          "character": "陈妙常",
          "type": "琴曲",
          "text": "抱玉兔兮自温，自温。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "好！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "出丑！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "此乃广寒游也，正是出家人所弹之曲。只是长宵孤冷，难消遣些！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "潘相公，好言重吓！我们出家人，有甚难消遣处？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "这也难道！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "陈妙常",
          "type": "朝元歌",
          "text": "长清短清，那管人离恨？ 云心水心，有甚闲愁闷？ 一度春来，一番花褪，怎生上我眉痕？ 云掩柴门，钟儿磬儿在枕上听。 梅子座中焚，梅花帐绝尘， 果然是冰清玉润。 长长短短，有谁评论？怕谁评论？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "仙姑，吓！"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "更声漏声，独坐谁相问？ 琴声怨声，两下无凭准。 翡翠衾寒，芙蓉月印，三星照人如有心。"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "仙姑吓！"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "只怕露冷霜凝，衾儿枕儿谁共温？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "潘相公，你出言太狂，屡屡讥诮。呀，莫非有意轻薄奴家？好吓！我去告诉你 姑娘，看你如何分解？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "仙姑，小生信口相嘲，出言颠倒，伏乞海涵！"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "巫峡恨云深，桃源羞自寻。"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "仙姑！"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "你是个慈悲方寸， 望恕却少年心性，少年心性。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "告辞！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "言语冒犯。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "好说。咳！"
        },
        {
          "character": "潘必正",
          "type": "念",
          "text": "她把心肠铁样坚，"
        },
        {
          "character": "陈妙常",
          "type": "念",
          "text": "岂无春意恋尘凡。"
        },
        {
          "character": "潘必正",
          "type": "念",
          "text": "今朝两下轻离别，一夜相思枕上看。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "潘相公，花荫深处，仔细行走。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "如此借灯一行。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "呀！看陈姑十分有意于我，及至挑动她，她又着恼。待我躲过一边，听她说些 什么。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正下。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "呀！听寂然无声，想是他进书馆去了。咳！潘郎吓潘郎！"
        },
        {
          "character": "陈妙常",
          "type": "朝元歌",
          "text": "你是个天生俊生， 曾占风流性。 看他无情有情， 只见他笑脸儿来相问。 我也心里聪明，"
        },
        {
          "character": "陈妙常",
          "type": "夹白",
          "text": "适才呵！"
        },
        {
          "character": "陈妙常",
          "type": "朝元歌",
          "text": "把脸儿假狠， 口儿里装做硬。 我待要应承， 这羞惭怎应他那一声？ 我见了他假惺惺，"
        },
        {
          "character": "陈妙常",
          "type": "夹白",
          "text": "咳！"
        },
        {
          "character": "陈妙常",
          "type": "朝元歌",
          "text": "别了他常挂心。 看这些花阴月影，凄凄冷冷， 照他孤另，照奴孤另！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "夜深人静，不免抱琴进去罢。正是："
        },
        {
          "character": "陈妙常",
          "type": "念",
          "text": "此情空满怀，未许人知道。明月照孤帏，泪落知多少！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正嗽。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "吓？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吓？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常下。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吓哈……小生在此，听了半晌，虽不甚明白——"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "听她一生两声， 句句含愁闷。 看她人情道情， 多是尘凡性。"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "妙常！"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "你一曲琴声，凄清风韵， 怎教人不断送青春？ 那更玉软香温， 情儿意儿那些儿不动人？ 她独自理瑶琴，"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "身上寒冷了！"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "我独立苍苔冷。 分明是西厢行径，"
        },
        {
          "character": "潘必正",
          "type": "夹白",
          "text": "老天吓！"
        },
        {
          "character": "潘必正",
          "type": "朝元歌",
          "text": "早早成就少年秦晋，少年秦晋！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "呀唷！身上寒冷了！寒、寒、寒冷了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}