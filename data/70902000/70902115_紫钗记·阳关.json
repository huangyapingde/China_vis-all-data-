  "plot": "唐诗人李益先与已故郡王之女霍小玉相好，后来从军有功，别娶他姓，霍小玉抑郁而亡。",
  "notes": "出自明汤显祖所撰《紫钗记》传奇，是一个悲剧。\n《紫钗记》流传演唱的唯此《折柳、阳关》，在原本中是一个折子，后世改题为两出。曲文典雅深奥，颇不\n易解，而旋律缠绵悱恻，很具特色，是小冠生与闺门旦的唱功戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李益、霍小玉、送客甲、送客乙同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "送客乙"
        },
        {
          "character": null,
          "type": "text",
          "text": "（同白） 请吓。"
        },
        {
          "character": "送客甲、送客甲",
          "type": "念",
          "text": "才子跨征鞍，"
        },
        {
          "character": "送客乙",
          "type": "念",
          "text": "思妇愁红玉。"
        },
        {
          "character": "送客甲",
          "type": "念",
          "text": "芳草送莺啼，"
        },
        {
          "character": "送客乙",
          "type": "念",
          "text": "落花催马足。"
        },
        {
          "character": "送客甲、送客乙",
          "type": "同白",
          "text": "吓，君虞兄请了。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "二位请了。 送客乙"
        },
        {
          "character": "李益",
          "type": "同白",
          "text": "军中笳鼓喧鸣，良时吉日，早些起行罢。"
        },
        {
          "character": "送客甲、李益",
          "type": "白",
          "text": "实不相瞒，小玉姐话长，使人难别。 送客乙"
        },
        {
          "character": "送客甲、李益",
          "type": "同白",
          "text": "古人云：“仗剑对樽酒，耻为离别颜。”男儿意气，为何留恋如此？"
        },
        {
          "character": "送客甲、李益",
          "type": "白",
          "text": "咳！过来见了二位。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "二位。"
        },
        {
          "character": "送客甲、送客乙",
          "type": "同白",
          "text": "吓郡主，我们还要送君虞兄数程，回来自有平安寄上。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "多谢二位。 送客乙"
        },
        {
          "character": "霍小玉",
          "type": "同白",
          "text": "军行有程，未可滞他行色。吓君虞兄，我们先往长亭恭候。"
        },
        {
          "character": "送客甲、李益",
          "type": "白",
          "text": "二位先请。"
        },
        {
          "character": "送客甲、送客乙",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "送客甲",
          "type": "念",
          "text": "长旗掀落日。"
        },
        {
          "character": "送客乙",
          "type": "念",
          "text": "短剑割离情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "送客甲、送客乙同下。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "李郎，你去也罢，只是眼下呵！"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "唵！"
        },
        {
          "character": "霍小玉",
          "type": "解三酲",
          "text": "恨锁着满庭花雨， 愁笼着蘸水烟芜。 花枝外，影踟蹰。"
        },
        {
          "character": "也不管鸳鸯隔南浦、李益",
          "type": "白",
          "text": ""
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": ""
        },
        {
          "character": "霍小玉",
          "type": "解三酲",
          "text": ""
        },
        {
          "character": "李益",
          "type": "解三酲",
          "text": ""
        },
        {
          "character": "霍小玉",
          "type": "解三酲",
          "text": ""
        },
        {
          "character": "李益",
          "type": "白",
          "text": ""
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": ""
        },
        {
          "character": "李益",
          "type": "白",
          "text": ""
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": " 被叠慵窥素女图。 看酒来，待我回敬夫人一杯。 是。 镜里鸾孤。 受多娇密宠难疏。 乡泪回穿九曲珠。 𠮾 春老吟余。 俺怎生有听娇莺情绪？ 全不着整花朵工夫。 从今后怕愁来无着处。 听郎马，盼音书。 落照关西妾有夫。 有恨香车。 吓夫人，只怕塞外风霜，老却人也！ 妾有一言，幸君垂听。 愿闻。 然后妙选高门，别求秦晋，亦未为晚。妾便舍弃人事，剪发披缁，夙昔之愿……"
        },
        {
          "character": "俺待把钗敲侧唤鹦哥语、新人故、一霎时眼中人去、倚片玉生春乍熟、正寒食泥香新燕乳、行不得，话提壶、把骄骢系软相思树、，销魂处、多则是人归醉后、想驻春楼畔花无主、河桥路、见了些无情画舸、妾年始十八，君才二十有二，待君壮室之秋，犹有八岁。一生欢爱，愿毕此期、李益",
          "type": "白",
          "text": "唵？"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "啊呀，于此足矣！"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "啊呀妻吓！皎日之誓，死生系之。与卿偕老，犹恐未惬素志，岂敢辄有二三？ 固请勿疑，啊呀端居相待！"
        },
        {
          "character": "李益",
          "type": "解三酲",
          "text": "夫人城倾城怎遇？ 女王国倾国也难模。 拜辞你个画眉京兆府。 那花没艳，酒无娱。 忘不了小玉窗前自叹吁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "李益",
          "type": "stage",
          "text": "中军"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "前军催迫，请大老爷起程。"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "知道了！"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "晓得哉！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": "吖！难道一刻也停留不得了么？"
        },
        {
          "character": "李益、霍小玉",
          "type": "同白",
          "text": "吓！啊呀（妻）（李郎）吓！"
        },
        {
          "character": "李益",
          "type": "解三酲",
          "text": "伤情处， 香冷唇朱。 书童"
        },
        {
          "character": "李益",
          "type": "白",
          "text": "阿呀老爷，三军亦拉笃催哉㖸！"
        },
        {
          "character": "见了你晕轻眉翠、李益",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "李益哭。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": ""
        },
        {
          "character": "李益",
          "type": "鹧鸪天",
          "text": ""
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "鹧鸪天"
        },
        {
          "character": "霍小玉",
          "type": "stage",
          "text": "李益"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": " 霍小玉"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李益下。"
        },
        {
          "character": "霍小玉",
          "type": "白",
          "text": ""
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人引李益同绕场。"
        },
        {
          "character": "李益、霍小玉",
          "type": "同白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "李益、众人同下。"
        },
        {
          "character": "霍小玉",
          "type": "鹧鸪天",
          "text": ""
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": ""
        },
        {
          "character": "霍小玉",
          "type": "鹧鸪天",
          "text": ""
        },
        {
          "character": "浣纱",
          "type": "白",
          "text": " 阿呀妻吓！听笳鼓喧鸣，催我行色匆匆，密意深情，非言所尽。阿呀，只得拜 别了呢！ 妾身也有一拜。 𠮾碧玉居。 李郎！ 不妨我啼鸟落花初。 夫人请回罢！ 李郎慢行！"
        },
        {
          "character": "掩残啼回送你上七香车、守着梦里夫妻、但愿你封侯游昼锦、吓！阿呀",
          "type": "妻",
          "text": "（李郎）吓！ 浣纱，和你灞桥一望。 是。"
        },
        {
          "character": "吓！啊呀",
          "type": "妻",
          "text": "（李郎）吓！ 富贵英雄美丈夫。 绿杨隔断，望不见了，请郡主回去罢！ 驿路逢人数寄书。 车来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "霍小玉、浣纱同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
