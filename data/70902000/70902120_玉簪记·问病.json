  "plot": "潘必正自与陈妙常操琴挑逗以后，还不能明白对方真实态度，因此抑郁成病，难以排遣。适姑母前来问病，\n陈妙常随同探望，言词之间，暗通衷曲。于是潘必正豁然而愈，引出后面偷诗订盟的情节。",
  "notes": "此剧篇幅不大，很少身段动作，但〖山坡羊〗曲调，曼妙可听。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姑母上。"
        },
        {
          "character": "姑母",
          "type": "一剪梅",
          "text": "病中孤馆自嗟呀， 才说离家，便恨离家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常上。"
        },
        {
          "character": "陈妙常",
          "type": "一剪梅",
          "text": "闲庭开遍紫薇花， 人在天涯，病在天涯。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "师父！ 姑母"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "徒弟，侄儿有病书斋，我去看看就来。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "师父，既是潘相公有恙，徒弟陪师父去问一声。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "姑母",
          "type": "念",
          "text": "仲子羞归下第病， 陈妙常"
        },
        {
          "character": "姑母",
          "type": "念",
          "text": "一腔心事少人知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姑母、陈妙常同下。进安嗽上。"
        },
        {
          "character": "姑母",
          "type": "stage",
          "text": "进安"
        },
        {
          "character": null,
          "type": "stage",
          "text": "念"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "姑母",
          "type": "stage",
          "text": "潘必正"
        },
        {
          "character": null,
          "type": "stage",
