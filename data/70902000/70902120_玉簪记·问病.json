        {
          "character": "潘必正",
          "type": "白",
          "text": ""
        },
        {
          "character": "进安",
          "type": "白",
          "text": " 海上有方医杂症，人间无药治相思。 我进安。好笑我俚相公，因不第羞归，来投女贞观安歇，偏偏遇着仔陈妙常个 让我扶俚出来，散散闷，或者好点，亦未可知。 喂，相公！相公！ 怎么？ 阿要扶唔到外头来坐坐？ 使得。 看仔细。 风雨暮秋天气。 坐好仔。 钟磐惊回枕上眠，客窗风雨恨长天。 咳！ 许多心事相谁言。 病里偏教人易老，秋来转觉恨常添。 𠲔 ！ 只因心事有相牵。 进安。 相公。"
        },
        {
          "character": "冤家，终日眉来眼去，我俚相公竟害仔相思病哉。服药无效，格么哪处？呀、愁滋味、潘必正",
          "type": "白",
          "text": "我自别家乡，旅馆萧条，染成一病，如何是好？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公，勿番道格，我前日子替相公起仔一课。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "课上怎么说？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "说相公个病，是阴人面上来个，勿消吃得药，只要掇一碗女亡人羹饭，送拉东 南方去仔么，相公个病，就好哉。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "些须小事，就该与我送了吓。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公，死鬼末好送，活鬼么哪哼送得脱介？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "狗才！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "勿要肝经火旺，替唔跌两记背罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姑母、陈妙常同上。"
        },
        {
          "character": "姑母",
          "type": "念",
          "text": "转过荷香径，又来丹桂阴。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公，姑奶奶来哉。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "陈妙常",
          "type": "念",
          "text": "忽闻长叹语，使我更关心。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "咦，格个宝贝倒也来个。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "吓，侄儿，这两日病体如何了？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "越发沉重了！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "更加勿是哉。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "吓，潘相公，吉人自有天相，料然无事。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吓！是哪个讲话？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "是俚哉㖸！"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "妙常徒弟，在此看你。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "在哪里！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "拉笃格搭！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "阿呀，有劳吓有劳！"
        },
        {
          "character": "相公",
          "type": "白",
          "text": "好仔勒谢还来得及个。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "侄儿，你把起病根由，说与我知道。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "姑娘，一言难尽！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "格叫哑子吃黄连，说勿出个苦！"
        },
        {
          "character": "潘必正",
          "type": "山坡羊",
          "text": "这病儿何曾经害， 这病儿好难担代。 这病儿好似风前败叶， 这病儿好似雨过花羞态。 我难摆开，"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "心头便怎么？"
        },
        {
          "character": "潘必正",
          "type": "山坡羊",
          "text": "心头去复来。 黄昏梦断，梦断天涯外。 我心事难提泪满腮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常哭。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "勿关唔啥事，为啥了哭。"
        },
        {
          "character": "潘必正",
          "type": "山坡羊",
          "text": "伤怀，"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "敢是风寒上起的？"
        },
        {
          "character": "潘必正",
          "type": "山坡羊",
          "text": "不为风寒眼倦开。 堪哀，"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "敢是忧愁上起的？"
        },
        {
          "character": "潘必正",
          "type": "山坡羊",
          "text": "只为忧愁头懒抬。"
        },
        {
          "character": "姑母",
          "type": "山坡羊",
          "text": "莫不是害了些王仲宣登楼无奈？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公阿是？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "不是。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "勿是个。"
        },
        {
          "character": "姑母",
          "type": "山坡羊",
          "text": "莫不是染了些楚三闾江潭流派？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公阿是？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "也不是。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "也勿是个。"
        },
        {
          "character": "姑母",
          "type": "山坡羊",
          "text": "莫不是渴中山病儿转深？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "也不是。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "才勿是个。"
        },
        {
          "character": "姑母",
          "type": "山坡羊",
          "text": "莫不是赴高唐酬孽债？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "阿呀我好恨呀！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "我好钝吓！"
        },
        {
          "character": "陈妙常",
          "type": "山坡羊",
          "text": "你休恨来，"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "夜明珠打哈欠，宝贝开口哉。"
        },
        {
          "character": "陈妙常",
          "type": "山坡羊",
          "text": "愁肠须摆开。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "姑奶奶，阿曾吃饭拉？"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "吃过了。"
        },
        {
          "character": "陈妙常",
          "type": "山坡羊",
          "text": "月圆月缺，月有盈亏害，"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "阿要泡壶茶唔吃？"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "不消。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "格么替唔跌两记背罢？"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "这倒使得。"
        },
        {
          "character": "陈妙常",
          "type": "山坡羊",
          "text": "岂可人无一日灾？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "格两日殿上烧香个阿多？"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "还好。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "唔革响里是健个？"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "倒也安逸。"
        },
        {
          "character": "陈妙常",
          "type": "山坡羊",
          "text": "襟怀， 你把那段心儿且放开。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "一条百脚！"
        },
        {
          "character": "姑母",
          "type": "山坡羊",
          "text": "书斋， 好听春雷天上来。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "侄儿，恐佛殿上有人来烧香，我去看看就来。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "姑娘请便。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "潘相公，还是服药为上。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "咳！吃什么药？"
        },
        {
          "character": "潘必正",
          "type": "念",
          "text": "心病还将心药医，"
        },
        {
          "character": "姑母",
          "type": "念",
          "text": "休将闲口惹是非。"
        },
        {
          "character": "陈妙常",
          "type": "念",
          "text": "只因闲口生心病，"
        },
        {
          "character": "进安",
          "type": "念",
          "text": "但愿冤家早脱离！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "哫！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "我奉太上老君急急如律令敕！妖怪速退！"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "妙常。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "吖，来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姑母、陈妙常同下。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "哈哈，好笑我俚相公，直梗病重，听见说陈姑来哉，看俚直立个立起来，说道 有劳吓有劳！几乎跌下去。吖，让我来开开俚个心看。 喂，相公，相公！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吓，吓……正欲朦胧睡去，什么大惊小怪？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "方才我送姑奶奶出去，看见陈姑格张小嘴，对仔我一扭，我就明白哉，走得上 去。陈姑说道：吓，进安哥，你家相公的病我都晓得。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吖她竟晓得？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "才晓得个呀。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "她便怎么说？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "俚说我有绝妙的方儿，管教一服就好。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吓！是她说的？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "是俚说个。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吖，待我就去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正嗽。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公，格付样式，哪好去介？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "是吓，待我除下帕儿。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "解脱仔包头。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "卸了裙儿。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "脱落仔格裙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正嗽。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公，唔到落里去？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "到陈姑房中，写方儿去。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "啥人说个？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "是你说的吓！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "我是叫唔到戏房里去养养神。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "狗才！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "哪，格条裙，自家带子进来。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "狗才，拿了进去！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "得罪唔，自家拿子进去罢。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "放肆的狗才！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正、进安同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}