{
  "script_id": "70902136",
  "title": "凤凰山·百花赠剑",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "百花公主",
      "hangdang": "五旦"
    },
    {
      "name": "海俊",
      "hangdang": "雉尾生"
    },
    {
      "name": "江花右",
      "hangdang": "四旦"
    }
  ],
  "plot": "全故事写安西王谋反，朝廷派海俊打入王府，充当间谍。安西王不察，重用海俊。王府总管叭喇疑海俊，设\n计灌醉，扶入百花公主帐中，意欲借百花公主之手除去之，岂料侍女江花右实乃海俊之妹（原本系姐弟关系），\n失散多年，偶然相逢，遂加掩护。百花公主见海俊年少英俊，爱之，竟许以终身。其后百花公主助父举\n兵，但因海俊为朝廷间谍，兵败，百花公主自刎而亡。",
  "notes": "此折原名《赠剑联姻》，系“吹腔”戏。\n全本或名《百花公主》。俞振飞与程砚秋合演时，则称《女儿心》。一九五八年，与言慧珠赴欧演出单折，\n改今名，删去间谍情节，写叭喇忌才，百花公主爱才，成为爱情短剧。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖起初更鼓〗。〖吹打〗。叭喇引小太监扶海俊同上，藏于百花公主帐中。叭喇、小太监同下。〖乐止〗。"
        },
        {
          "character": null,
          "type": "text",
          "text": "江花右上。）"
        },
        {
          "character": "江花右",
          "type": "唱",
          "text": "花披露，月有影， 青灯照得我如花容貌，别具精神。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "啊，公公，我是饮不下了。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "呔！那一汉子竟敢擅入公主内室，休走，看剑！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "啊！你……你敢是我妹子江花右么？"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "是啊！兄长因何来到此地呀？"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "咳！再也不要提起。只因今日，那内侍叭喇，请我饮酒，不觉大醉，我也不晓 得怎么会来到这里的呀。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "啊呀，兄长啊！此乃公主内室，倘有擅入者，斩首示众！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "这个……啊呀，妹子啊，想我乃是中了奸人之计，你快快送我出去才好呀。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "这……好，随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "啊呀兄长呀！公主她……"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "她回来了！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "海俊",
          "type": "唱",
          "text": "我不道这场大祸， 恐吉少又凶深。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江花右引海俊藏在桌后。〖起二更鼓〗。"
        },
        {
          "character": "百花公主",
          "type": "内白",
          "text": "掌灯回亭者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖出队子〗。宫女引百花公主同上。宫女下。〖小开门〗。百花公主坐定。〖乐止〗。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "天色不早，公主安睡了罢！"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "天色尚早。我来问你，昨日教你的兵法十三篇，可曾熟否？"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "吖，烂熟的了。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "好，你且背来。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "啊公主，你今日实是乏了，早些安睡罢。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "不背么，也好。与我讲来。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "是，我讲。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "你讲。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "我。不不……讲。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "啊！你这丫头，今日为何颠三倒四，敢是疯了不成？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花公主剑鞘击桌，惊起海俊。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "海俊",
          "type": "唱",
          "text": "啊呀唬！唬得我魂飞胆摇， 望恕却残生这遭。 披肝胆敢装奸狡。"
        },
        {
          "character": "亦非是越墙之盗、亦非是挟匕的那英豪、百花公主",
          "type": "唱",
          "text": "觑他容貌非奸狡， 俊堂堂一貌丰标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唱"
        },
        {
          "character": "亦非是越墙之盗、亦非是挟匕的那英豪、百花公主",
          "type": "stage",
          "text": "江花右"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "唱"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "海俊",
          "type": "stage",
          "text": "百花公主"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": ""
        },
        {
          "character": "海俊",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "唱"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唱"
        },
        {
          "character": "海俊",
          "type": "stage",
          "text": "唗！ 因甚事潜身来到？ 少时刻一命难逃！ 呔！那一汉子，家住哪里？姓甚名谁？快快讲来！ 是，是，是。公主容禀！ 恨无端生出祸根苗。 𠲔 ！可恨那叭喇呵！ 唔！你是甚等样人，敢言我内侍叭喇？ 是啊！你是甚等样人，敢言我内侍叭喇？ 是，是，是。哪！ 他忌才能暗藏机巧。 小生海俊，新任西府参军。不想内侍叭喇，假意庆贺为由，将酒把我灌醉呵。 不知怎么到了公主内庭，内庭上来了。 哎呀公主呀！ 恕微臣误入在蓬岛。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "啊哈哈哈……"
        },
        {
          "character": "既不是越墙之盗、将此事诉根苗、百花公主",
          "type": "白",
          "text": "唔！你深夜潜入内庭，理当问斩，念你中了他人之计，我就不杀你了。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "快快谢了公主！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "是，是，是。多谢公主！"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "只是便宜了你。 江花右！"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "看看哪里粉墙可越，送他出去。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "啊呀且住！我看公主倒有爱我哥哥之意，唔，我自有道理。正是："
        },
        {
          "character": "江花右",
          "type": "念",
          "text": "闭门推出窗前月……"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "啊妹子，你送我出去呀！"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "江花右",
          "type": "念",
          "text": "吩咐梅花自主张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江花右下。"
        },
        {
          "character": "江花右",
          "type": "stage",
          "text": "百花公主"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "你还未曾去么？"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "未曾。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "江花右呢？"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "不知去向。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "待我唤来。 啊江花右！江花右！这丫头不知往哪里去了。 啊海生，深夜无人，待我送你出去。 海俊"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "多谢公主。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "就在此攀梅而过。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "有劳公主。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "海生。"
        },
        {
          "character": "百花公主",
          "type": "念",
          "text": "休将老梅来折损，待他乘月泄春光。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "啊？那公主为何道此两句？唔，莫非她有爱我之意呀？唔，我且闪过一旁，听 她讲些什么。有理吓有理！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "想那海生，言语清朗，气度轩昂。我有意将终身托付与他，怎奈女孩儿家，羞 人答答，不好启齿。吖有了！待我稟过父王，方好成其美事。啊呀……好个海 生！好个海生！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "海生在！"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "百花公主",
          "type": "雁儿落",
          "text": "广寒岑寂，仙子思飘遥， 须知道桂蕊向少年抛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖雅笛〗。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "海生，我不杀你，你心中可明白？"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "多蒙公主将终身相许，我是何以为报？何……以为报？"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "只恐书生情薄，后来忘恩负义！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "哎！我若负了公主之情，对天可表。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "但凭……"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "公主听了！"
        },
        {
          "character": "海俊",
          "type": "雁儿落",
          "text": "明月在上，照我心苗。 蒙公主不弃鹪鹩， 恩高意高，情好意好， 我岂做王魁把盟山负却了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。海俊逼百花公主，跪步至上场口。〖曲牌收〗。"
        },
        {
          "character": "百花公主",
          "type": "雁儿落",
          "text": "啊呀海生呀！ 自古道姻缘姻缘事非偶然， 何必心急怎的？心急怎的？ 啊呀海生呀！ 我岂不知恩爱好， 纵使欢娱，怎免得旁人嘲笑？"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "多蒙公主见爱，必须赠我一物，以为今日定情之证。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "唵……"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "我有宝剑二股。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "喔！"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "今赠一股与君。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "以为定情之证。"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "如此，多谢公主！"
        },
        {
          "character": "海俊、百花公主",
          "type": "同雁儿落",
          "text": "相逢好，赠青锋为表照。 愿嫦娥带剑为证，愿嫦娥带剑为证， 好姻缘于飞及早。 一双双鸾凤交， 待功成渡鹊桥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "江花右上。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "啊？公主叫你出去，你为何不出去呀？"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "多谢公主不杀与他，还赠送宝剑，我这里当面谢过。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "啊？你是他的什么人？"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "我是他的……"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "妹子呀！"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "吖，原来你们是兄妹？"
        },
        {
          "character": "海俊、江花右",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "啊呀，我倒被他们作弄了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。"
        },
        {
          "character": "江花右",
          "type": "白",
          "text": "天已亮了，叫我哥哥回去罢。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "海生！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "百花公主",
          "type": "白",
          "text": "去罢！"
        },
        {
          "character": "海俊",
          "type": "白",
          "text": "是。告辞了。"
        },
        {
          "character": "百花公主、海俊",
          "type": "同雁儿落",
          "text": "千金买不住良宵， 准备相思，教人难打熬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花公主、江花右同下，海俊自另边下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}