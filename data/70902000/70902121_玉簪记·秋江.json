{
  "script_id": "70902121",
  "title": "玉簪记·秋江",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "潘必正",
      "hangdang": "巾生"
    },
    {
      "name": "陈妙常",
      "hangdang": "五旦"
    },
    {
      "name": "姑母",
      "hangdang": "老旦"
    },
    {
      "name": "进安",
      "hangdang": "丑"
    },
    {
      "name": "艄公",
      "hangdang": "白面"
    },
    {
      "name": "艄婆",
      "hangdang": "付"
    }
  ],
  "plot": "潘必正与陈妙常两情相好，欢娱正浓。姑母催迫潘必正，立赴临安应试。陈妙常因在众人前，无法话别，乃\n赶往秋江，与潘必正倾诉离情，然后黯然分袂。",
  "notes": "此剧重在唱工，曲调婉转缠绵，极为美听。戏的风格，与同名川剧迥然不同。有些曲白，不大健康，已作修\n改。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姑母、潘必正、进安同上。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "侄儿走吓！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "噢！"
        },
        {
          "character": "姑母",
          "type": "水红花",
          "text": "天空云淡蓼风寒，"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "勿要看，进去个哉。"
        },
        {
          "character": "姑母",
          "type": "水红花",
          "text": "透衣单。江声凄惨，"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "狗才！"
        },
        {
          "character": "姑母",
          "type": "水红花",
          "text": "晚潮时带夕阳还。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "潘必正",
          "type": "水红花",
          "text": "泪珠弹，愁肠千万。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "姑娘，转去，转去。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "侄儿这些要紧书籍，都不曾带来。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "勿消费心，才带拉里个哉。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "狗才！"
        },
        {
          "character": "潘必正",
          "type": "水红花",
          "text": "我欲待将言遮掩， 怎禁他恶狠狠把话儿揽。 只得赴江干，也啰。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "姑奶奶，到仔江边哉。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "进安唤船。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "是哉。 小船摇上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艄公上。"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "来哉。"
        },
        {
          "character": "艄公",
          "type": "念",
          "text": "撑船道业，各服一行。"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "阿是叫船？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "到落里去？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "到临安去会试个。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "吓船家，只怕今日，江中风大，去不得吓。"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "咳，风没大，倒是兜艄顺风，去得个。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "狗才！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "勿要多拌，阿要几化铜钱？"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "老实说，要一两笃。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "苏州人杀半价，五钱拉里，阿去？"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "少点，勿去。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "狗才！"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "作啥骂哉？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "这里到临安，有多少路，与你五钱银子，还不去。 姑娘，转去，转去！"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "慢点慢点，勿要逗，依㕶么几化？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "依我吓。"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "几化？"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "与你三分银子。 姑娘，我们转去，转去！"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "慢点慢点，我么郭璞格儿自，拗种，五钱勿去，摇㕶格三分。请下船来。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "啊呀狗才！"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "格么八钱拉笃。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "姑娘，侄儿是去了。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "路上小心。"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "开船哉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘必正、艄公、进安同下。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "我且到望江楼上一看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常上。"
        },
        {
          "character": "陈妙常",
          "type": "水红花",
          "text": "霎时间云雨暗巫山， 闷无言，不茶不饭， 满口儿何处诉愁烦？ 隔江关，怕他心淡， 顾不得脚儿紧赶。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "呀，看望江楼上，好似观主模样。天吓，早是我先看见了。"
        },
        {
          "character": "陈妙常",
          "type": "水红花",
          "text": "若还她撞见，好羞惭。 且在人家竹院，也啰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常下。"
        },
        {
          "character": "姑母",
          "type": "白",
          "text": "侄儿去远，料他决不转来。咳，妙常吓！"
        },
        {
          "character": "姑母",
          "type": "念",
          "text": "从今割断藕丝肠，免系鹍鹏飞不去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姑母下。陈妙常上。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "潘郎吓！"
        },
        {
          "character": "陈妙常",
          "type": "念",
          "text": "君去也，我来迟，两下相思各自知，教我心呆意似痴。 行不动，瘦腰肢，且将心事托舟师，见他强似寄封书。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "想他去得不远，不免唤只小船儿，赶上前去。 吓，船家，摇上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艄婆上。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "来哉。"
        },
        {
          "character": "艄婆",
          "type": "念",
          "text": "终日滩头坐，一日过九餐。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "小师父，阿是叫船？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "到落里去？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "要赶着前面那只会试船的。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "啊呀去远哉，只怕赶勿着哉。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "只要赶着了，船钱重谢。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "格么要依我格笃。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "你要多少，一总与你。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "格么我要五钱银子笃。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "就与你五钱。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "早晓得么，说子一两哉。请下船来。咦？㕶是女贞观里小师太哇？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "正是。快些开船。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "噢，格么开船哉！"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "快些摇吓！"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "原是摇，勿拉里撑。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "啐！缆也不曾解，只管摇！"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "拨㕶催昏子落，摇仔半日个船，缆也不曾解。让我解仔缆来看。嗳束来！那么 开船哉。小师太，阿要泡壶茶㕶吃吃？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "不要。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "格么唱只山歌㕶听听？"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "也不要。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "要听格。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "快些开船。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "格么我唱哉。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "偏偏叫了只老船。"
        },
        {
          "character": "艄婆",
          "type": "吴歌",
          "text": "吓吓吓喑，风打船头雨又来， 满天风雾了喑那哼把船开？"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "㕶看白云阵阵吹黄叶。"
        },
        {
          "character": "艄婆",
          "type": "吴歌",
          "text": "惟有江上芙蓉了喑独自开。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "为啥满肚皮格心事介？"
        },
        {
          "character": "陈妙常",
          "type": "红衲袄",
          "text": "奴好似江上芙蓉独自开， 只落得冷凄凄漂泊轻盈态。 恨当初与他曾结鸳鸯带， 到如今怎生分开鸾凤钗！ 别时节羞答答怕人瞧，头懒抬， 到如今闷昏昏独自担着害。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "小师太，㕶看水面上，一对鸳鸯，拉笃打雄。咦，雄格飞子去，雌格拉笃赶上 来。"
        },
        {
          "character": "陈妙常",
          "type": "红衲袄",
          "text": "爱煞那一对鸳鸯在水上也， 羞煞我哭啼啼今宵独自捱。"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "扳得来吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常、艄婆同下。潘必正、进安、艄公同上。"
        },
        {
          "character": "艄公",
          "type": "吴歌",
          "text": "满天子介风雾日影子介暖， 远波疏林月影子介寒。 看南来北往流勿尽相思泪吓， 别时容易了喑见时难。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "潘必正",
          "type": "红衲袄",
          "text": "我只为别时容易见时难， 你看那碧澄澄断送行人江上晚。 昨宵呵，醉醺醺欢会知多少， 今日里愁脉脉离情有万千。 莫不是锦堂欢缘分浅？ 莫不是蓝桥倒时运悭？ 伤心怕向篷窗也，"
        },
        {
          "character": "艄婆",
          "type": "内白",
          "text": "喂，前头格只，阿是会试船？"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "正是，问俚作啥？"
        },
        {
          "character": "艄婆",
          "type": "内白",
          "text": "有位女师太，要会㕶笃公子了。"
        },
        {
          "character": "进安",
          "type": "白",
          "text": "相公，陈姑来哉。"
        },
        {
          "character": "潘必正",
          "type": "红衲袄",
          "text": "堆积相思两岸山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈妙常、艄婆同上。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "快些摇上去吓！"
        },
        {
          "character": "艄婆",
          "type": "白",
          "text": "是哉。"
        },
        {
          "character": "陈妙常",
          "type": "侥侥令",
          "text": "忙追赶，去寻船， 见风里，正开帆。"
        },
        {
          "character": "潘必正",
          "type": "侥侥令",
          "text": "忽听人呼声声唤， 是何人且向前。"
        },
        {
          "character": "住兰棹，定眼看、陈妙常",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "妙常，快些过船来！ 艄婆"
        },
        {
          "character": "潘必正",
          "type": "同白",
          "text": "吖哟，看仔细，几乎做大汤圆。"
        },
        {
          "character": "艄公、陈妙常",
          "type": "哭相思",
          "text": "半日里抛伊不见， 泪珠儿湿染红衫。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "船家，把船泊在江口，暂停片时。"
        },
        {
          "character": "艄公",
          "type": "白",
          "text": "是哉，搭㕶到后艄头去，燉茶吃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "艄公、艄婆同下。"
        },
        {
          "character": "艄公",
          "type": "stage",
          "text": "陈妙常"
        },
        {
          "character": "艄公",
          "type": "念",
          "text": "事无端，恨无端，平地风波拆锦鸳，羞将泪眼向人看。"
        },
        {
          "character": "潘必正",
          "type": "念",
          "text": "这其间，那其间，恨我姑娘紧紧拦，狠心直送到江干。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "早上听得师父唤我们出来送你，好不惊煞人也。不知何人，走漏消息？吖，一 定是你口儿不紧，以至如此。"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "小生对谁说来？这是平地风波，痛肠难尽。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "方才在众姑姑面前，有话难提，有情难诉，为此赶来送你。潘郎吓！我有千言 万语，一时哪里说得尽吖！"
        },
        {
          "character": "潘必正",
          "type": "白",
          "text": "多感厚情，铭刻肺腑，早晨在众姑姑面前，一言不得相别，方抱痛肠。今得见 卿，如获珍宝。妙常吓！和你少叙片时，再作道理。"
        },
        {
          "character": "陈妙常",
          "type": "白",
          "text": "噢。"
        },
        {
          "character": "潘必正、陈妙常",
          "type": "同小桃红",
          "text": "秋江一望泪潸潸， 怕向那孤篷看，也。 这别离中生出一种苦难言。"
        },
        {
          "character": "恨拆散在霎时间、都只为心儿里眼儿边、血儿流把",
          "type": "你",
          "text": "（我）的香肌减，也。 生隔断银河水，断送我春老啼鹃。"
        },
        {
          "character": "恨煞那野水平川、潘必正",
          "type": "下山虎",
