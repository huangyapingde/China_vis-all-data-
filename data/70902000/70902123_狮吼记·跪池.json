          "character": "陈季常",
          "type": "白",
          "text": "果有神道？实有神道？果有神道？"
        },
        {
          "character": "苏东坡",
          "type": "笑",
          "text": "𠼦！哈哈哈……"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "啊呀啊呀！吓？子瞻，你好没道理！缘何不待通报，竟直入人家内室？岂有此 理！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "若待通报，你的膝盖儿，跪得越发疼了！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "跪的是我，与足下何干？扯淡！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "衣冠不正，尚属朋友之过。陶渊明不为五斗米折腰，至今犹有生气。你既为男 子甘心屈膝于妇人？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "我自甘屈膝，与老兄什么相干！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "世间哪有你这样缩头的男子！"
        },
        {
          "character": "柳氏",
          "type": "内白",
          "text": "跪在哪里？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "跪在此。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喂！季常，这是哪个的声音？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "我家娘子。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喔哟！犹如狮吼一般！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳氏上。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "缘何不待发放，擅自起来？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "动也没有动吓！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "你与哪个在此讲话？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "苏学士在外。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "我正要见他，权且放你起来。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "多谢娘子。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "请进来。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "是，请进来。 吓！子瞻兄呢？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "啊呀，恭喜恭喜！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "发放了吓！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "吓呀！休得取笑，房下相请。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "我正要见她。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "且慢！须要以礼而待之吓！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "这个自然。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "随我来。 吓，娘子，子瞻兄来了。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "吓。尊嫂。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "苏大人。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "子瞻。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "季常。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "子瞻兄请坐。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子么，喏、喏、喏，请上坐。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "不知礼！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "太小心了！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "不是哟，此位吓，我有些坐不惯喔。哈哈哈……"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "苏大人到舍，有何贵干？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "下官有言奉告。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "请教。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "尊嫂，轼闻闺房之内，和气为先。季常有何罪而令其长跪池边？窃恐夫既不夫， 妇亦不妇，辱没斯文，伤风败俗。不可吓不可！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "苏大人。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "尊嫂。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "奴家虽系裙钗，略知经史。自古夫妻之道，相敬如宾。原是他夫即不夫，莫怪 我妇亦不妇，只缘夫纲不正，今日我丈夫呵！"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "心神不定， 面皮忒厚，"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "季常乃潇洒之士。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "其实潇洒。"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "把昨日行踪虚构。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "季常你的面皮太厚了。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "我的厚吓？你的厚，你的厚。"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "要他循规蹈矩， 多结良伴佳俦。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "吓苏大人！"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "羡你望隆山斗，"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "啊呀呀，不敢吓不敢。"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "却怎心恋烟花？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "子瞻兄望隆山斗，久仰吓久仰。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "谁要你来奉承？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "吓，我来奉承你？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "倒不是你来奉承我？"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "休把我的儿夫诱。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "琴操是我的相知，季常不过陪坐而已，尊嫂何必吃这样的寡醋？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "吓，你引乱他心，反说我吃寡醋！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "子瞻，少说些！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "啊呀咦！"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "恨不得青藜杖打，"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喔唷！季常打得，下官是打不得的。"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "打杀你这老牵头，"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "吓，娘子，子瞻是打不得的。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "季常不要放手！"
        },
        {
          "character": "柳氏",
          "type": "梁州序",
          "text": "教你狗党狐朋莫再游， 免使我厉声咒。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "喔哟，气死我也！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "好厉害！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子不要生气，待卑人与你捶背。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喂，季常！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "嗤！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "来啊！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "来啊！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "怎么介？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "果然厉害！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "如何！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "连我也有些胆怯起来了。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "你今日才见！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "待我进去说她几句。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "吓子瞻，她手中之物，不是当耍的！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "你放大了胆，有我在此。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "有你在此？不要连累我吓！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "不连累你的。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "好好，随我来。 吓，娘子，子瞻又来了。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "吓，尊嫂，从来那些悍戾之妇呵！"
        },
        {
          "character": "苏东坡",
          "type": "梁州序",
          "text": "终年为害， 千秋遗臭， 把四德三从一旦丢开脑后。 蛮声悍气， 全无半点温柔。 看她隔窗破口， 帷下裂眸， 全不把仪礼纲常守。 有时磨刀刃似凶仇， 这般狼虎威严鬼也愁。 〒！ 狠毒心， 岂能有？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "喂，老苏！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喔哟，好美称吓！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "你言言嘲讪，句句扛帮，我须奈何你不得？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "把我便怎样？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "陈郎过来！都是你引他来的，我只是打你！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "啊呀娘子吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈季常跪。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "诺，诺，诺，又跪了！"
        },
        {
          "character": "陈季常",
          "type": "梁州序",
          "text": "告娘行细察因由， 苏学士突然来候， 这颠言狂语尽皆纰漏。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "他明明来嘲笑我。"
        },
        {
          "character": "陈季常",
          "type": "梁州序",
          "text": "我是随伊饶舌， 惮尔青藜，朝夕权相守。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "我一向问得你在他家谈禅，十分敬服，谁想谈的都是老婆禅！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "什么老婆禅？"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "喂，老苏！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "又是老苏！"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "自古道各家门，各家户，今后免劳下顾！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "下官还要来看季常的。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "你若再引他上门，我和你做一世的死冤家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳氏哭。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "啊呀娘子吓！"
        },
        {
          "character": "陈季常",
          "type": "梁州序",
          "text": "是非今说破，莫追求。 不是冤家不聚首。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "子瞻。来、来、来。"
        },
        {
          "character": "陈季常",
          "type": "梁州序",
          "text": "请先退，暂迁就。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "赶他出去！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "岂有此理！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "子瞻请回吧！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "吓，季常，你年正强壮，尚未有子，何不与令正商量，娶一妾如何？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "禁声！还想娶妾？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "自然吓！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "小弟前在洛阳，忽有苍头来报，说家中已纳下四妾了。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "这就好了。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "小弟急急赶回看时，却娶了四个魑魅魍魉！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "就是容貌丑些，但能生子，亦是美事。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "未到月余，连那丑的，都赶出去了。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喔，都赶出去了？待我再去说她几句。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "子瞻，你又要连累我吓！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "不连累你的，有我在此。"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "又有你在此？不连累我？好、好，随我来。 吓，娘子，子瞻又进来了。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "吓尊嫂，季常今后……"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "今后便怎么？"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喔哟！再不敢恋酒贪花了。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "唔！讲了半日的话，只这一句中听。"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "喔，下官的话，只有一句中听？"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "娘子，子瞻是极通理的㖸。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "只有一句！吓，苍头，看茶来与苏老爷吃了吓！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "茶倒不消，下官还有一言奉告。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "你的说话，怎么再也说不完？"
        },
        {
          "character": "苏东坡",
          "type": "梁州序",
          "text": "待东坡略现愚谋， 论不孝须防无后。"
        },
        {
          "character": "柳氏",
          "type": "白",
          "text": "陈门无后，与苏氏何干？扯淡！"
        },
        {
          "character": "陈季常",
          "type": "白",
          "text": "扯淡！"
        },
        {
          "character": "苏东坡",
          "type": "白",
          "text": "下官与季常呵！"
        },
        {
          "character": "苏东坡",
