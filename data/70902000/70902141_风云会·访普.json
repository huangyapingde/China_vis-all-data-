{
  "script_id": "70902141",
  "title": "风云会·访普",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "净"
    },
    {
      "name": "赵普",
      "hangdang": "外"
    },
    {
      "name": "张千",
      "hangdang": "丑"
    },
    {
      "name": "曹彬",
      "hangdang": "末"
    },
    {
      "name": "石守信",
      "hangdang": "小生"
    },
    {
      "name": "王全斌",
      "hangdang": "副"
    },
    {
      "name": "潘仁美",
      "hangdang": "净"
    }
  ],
  "plot": "赵匡胤称帝后，雪夜造访丞相赵普，商议用兵之策。",
  "notes": "元杂剧《风云会》第三折。经朱关荣改写，突出君臣互相沟通，达成治国平天下的共识，内容更为充实。辛\n清华改谱，李梁配器，保持了原曲调激昂慷慨的风格，同时人物情感表达更为贴切。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "内侍。"
        },
        {
          "character": "内侍",
          "type": "内白",
          "text": "有。"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "带路。"
        },
        {
          "character": "内侍",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍引赵匡胤同上。风雪扑面。赵匡胤、内侍同侧身以袖避之。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵匡胤",
          "type": "端正好",
          "text": "夤夜出宫墙， 瑞雪空中降。 有心一举过长江， 又愁百废待兴旺， 问良策，私访贤相。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "寡人大宋天子赵匡胤。只因基业初立，江南未平，夜来睡卧不安，故而冲寒冒 雪，去往丞相赵普家中商谈国事。喔呵呀，好大雪！"
        },
        {
          "character": "赵匡胤",
          "type": "滚绣球",
          "text": "纷纷似蝶翅飞， 漫漫如柳絮狂。 舞冰花旋风儿飘扬， 践琼瑶将脚步儿奔忙。 俺将这斗篷儿两面遮， 把金盏来搪。 猛回头将凤楼凝望， 全不见碧琉璃铸就鸳鸯。 一霎时九重宫阙如银砌， 半刻儿万里山河似玉妆。 粉填满封疆。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "启奏万岁：来此已是相府。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "上前扣门。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "领旨。 开门哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千上。"
        },
        {
          "character": "张千",
          "type": "念",
          "text": "半夜碰门拎不清，冻得我浑身冷冰冰。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "外面是谁呀？"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "是我。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "干什么的？"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "要见相爷。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "什么，见相爷？你也不挑个时候。半夜三更的，得，您请回吧。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "为什么？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "为什么？让我告诉你，相爷相爷一人之下，万万人之上，可不是什么张三、李 四、王二麻子想见都能见得着的。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "今儿个来的可不是一般人。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "不是一般人？总不见得是万岁爷驾到了吧？"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "正是万岁……"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "是万岁山前的赵大郎。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "咳！我说，你说话别大喘气，吓我一大跳。什么大郎小郎的，压根儿我没听说 过。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "唉！做事休论大小，就是平民百姓有事求见，做丞相的也该见哪。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "对对对！也不是一概不见，是咱们相爷忙得很啊。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "忙着何来？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "当朝宰相，日理万机。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如今是夜晚了。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "晚上？晚上也得看书写文章。这叫充电，你懂吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤笑。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这就对了。相烦通报一声，就说我有机密事儿待要商议。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "什么，有机密事儿你怎么不早说。你等着。 有请相爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵普上。"
        },
        {
          "character": "赵普",
          "type": "念",
          "text": "欲行治国策，熟读圣贤书。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "外面有一官员，口称有机密事要见。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "可曾问他，是何处的官员？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "他说了，是什么万岁山前……喔赵大郎。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "啊呀呀，是万岁驾到。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "啊，圣驾？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "快开正门，掌灯接驾。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "开正门，掌灯接驾。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣赵普接驾来迟，万岁恕罪。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "爱卿平身。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呀！下面长跪者是谁？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "罪人张千。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何罪之有？"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "小的有眼无珠，冒犯了万岁。小人该死，小人该死！"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "你这厮如此无礼！ 来，与我拿下了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "慢来，慢来。将张千拿下了，哪个与你看门哪？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "冒犯万岁，万万赦不得。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "赦得，赦得。大寒天，是寡人搅了他的好梦。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "是张千该死，是我有眼无珠，狗眼看人低。小的冒犯万岁，小人该死，小人该 死！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "好了，好了。今后做事，要一视同仁。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "还不谢过万岁。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "谢万岁不杀之恩。 好险哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤与赵普相视一笑。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "万岁深夜到此必有要事，何不请到书房一叙？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "好。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "张千带路。 陛下请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。张千引赵匡胤、赵普同进书房。〖曲牌收〗。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊爱卿，天气寒冷，身子可好？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "托万岁鸿福，老臣倒也康健。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "嫂夫人呢？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "喔，她偶染风寒早已睡下了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "可曾请医看过？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "尚未。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "内侍，明日一早请御医前来，为嫂夫人诊治。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍下。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "多谢万岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风声〗。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "啊万岁，天气寒冷，有道是酒能御寒，臣备有水酒，请万岁饮上几杯如何？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "倒也使得。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "看酒。 万岁请。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤饮毕。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "万岁因何闷闷不乐？莫非这酒……"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "想今夜寒风似箭，密雪如麻，朕身穿貂皮，尚不能御寒，何况平民百姓呵！"
        },
        {
          "character": "赵匡胤",
          "type": "幺篇",
          "text": "忧只忧当站的身无挂体裳， 忧只忧为农的家无隔宿粮。 忧只忧甘贫的昼眠在深巷， 忧只忧读书的夜坐寒窗。 忧只忧号寒的妻怨着夫， 忧只忧啼饥的子唤着娘。 忧只忧行船的怕一江风浪， 忧只忧驾车的受万里风霜。 忧只忧布衣贫士无活计， 忧只忧铁甲将军守战场。 提起来感叹也悲伤。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "万岁如此体恤民情，真乃万民之幸也。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "百废待兴，四寇未平，如何是好？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "啊万岁，想那江南李王、吴越钱王、西川孟昶、两广刘怅，皆沉湎于酒色，何 不乘我大宋立国之初，声威大振，一举除却那四寇？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "爱卿所言，朕也曾再三思之。只是连年征战，劳民伤财，再若出兵，又恐百姓 受苦，实实地叫朕左右为难。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "万岁，如今南北分割，四寇作乱。多少百姓，妻离子散，家破人亡？万岁若能 除却那四寇，百姓就能合家团圆，安居乐业了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如此说来，还是发兵的好？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "有道是，“长痛不如短痛”。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "喔，长痛不如短痛？好！朕主意已决，定当亲自挂帅，除却那四寇。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "何劳圣天子远行。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这是怎么说？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "如今陛下，已非昔日马背上的将军，乃是一国之君。理当日坐金銮殿，夜思富 民策。有道是，“得民心者得天下”。陛下何不安置流民，从事农桑？民富则 国力强盛，粮足则可充军饷，何愁天下不平？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "爱卿言之有理，只是那出征的大事呢？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "杀鸡何用牛刀？臣已思之，可命曹彬下江南，石守信取吴越，王全斌收四川， 潘仁美定两广。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这四将当得如此重任？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "当得重任。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "不会误了朕的大事？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "万岁放心。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "何以为凭？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "微臣力保。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "我的好丞相啊！依卿所奏，速传四将前来。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "领旨。 张千，传曹、王、石、潘四将前来商议。"
        },
        {
          "character": "张千",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张千下。"
        },
        {
          "character": "赵匡胤",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "朕日夜思之不决，坐卧难宁之事，不想被丞相三言两语便化解了。爱卿真不愧 是治国的奇才。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "万岁过奖了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬、石守信、王全斌、潘仁美同上。"
        },
        {
          "character": "曹彬、石守信、王全斌、潘仁美",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "众位将军，听丞相代朕宣旨。"
        },
        {
          "character": "曹彬、石守信、王全斌、潘仁美",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "曹将军听令：命你下江南。 石将军听令：命你取吴越。 王将军听令：命你收西川。 潘将军听令：命你平两广。 即日兴师，毋得骚扰百姓，功成之日论功行赏。"
        },
        {
          "character": "曹彬、石守信、王全斌、潘仁美",
          "type": "同白",
          "text": "谢万岁。"
        },
        {
          "character": "赵普",
          "type": "脱布衫",
          "text": "取金陵飞渡长江， 下钱塘平定他邦。 西川路休辞栈道， 那南蛮地莫愁烟瘴。"
        },
        {
          "character": "赵普",
