  "plot": "李自成即将攻陷京城，崇祯帝领众人到太庙哭告，放走太子，刺死公主，赐皇后自尽，自己则独上煤山。",
  "notes": "此折用南曲，角色的唱段灵活多样，有独唱、合唱、接唱，展现了明王朝覆灭之际，不同人物的悲惨命运。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "费贞娥",
          "type": "内山坡羊",
          "text": "云黯黯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥上。"
        },
        {
          "character": "费贞娥",
          "type": "山坡羊",
          "text": "但见烽烟笼罩， 乱纷纷只见金鼓声喧闹。 哭哀哀只见百姓们争先恐后， 凄惨惨败兵退如潮。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奴家费贞娥。自幼选入宫闱，奉国母娘娘恩厚，命我服侍公主，也曾伴读经书， 略知君臣之礼。眼见金瓯破碎，社稷震摇，恨不能似男儿仗剑杀敌，报国捐 躯，空怀一腔热血，徒付几声悲叹也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王承恩上。"
        },
        {
          "character": "王承恩",
          "type": "念",
          "text": "天灾从天降，社稷已难保。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "王公公。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "费宫人，你怎么出宫来了？"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奉国母娘娘之命，出宫打听军情。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "啊呀费宫人哪，监军杜勋，竟大开城门，迎贼进城了！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "吖！如此速速奏明圣上。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王承恩、费贞娥同下。"
        },
        {
          "character": "娘娘、太子、公主",
          "type": "内同白",
          "text": "啊呀苦吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "娘娘、太子、公主同上，崇祯帝急上。"
        },
        {
          "character": "崇祯帝",
          "type": "山坡羊",
          "text": "金鼓连天，海沸山崩顷刻间。"
        },
        {
          "character": "娘娘",
          "type": "白",
          "text": "臣妾见驾。"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "啊呀梓童吓！贼兵攻城，危在旦夕，眼见得邦家不能保全了。"
        },
        {
          "character": "娘娘、太子、公主",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "御妻——"
        },
        {
          "character": "娘娘",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "我儿——"
        },
        {
          "character": "太子、公主",
          "type": "同白",
          "text": "父王！"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": " 公主"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同园林好"
        },
        {
          "character": "崇祯帝",
          "type": "园林好",
          "text": " 公主"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同园林好"
        },
        {
          "character": "娘娘",
          "type": "江儿水",
          "text": ""
        },
        {
          "character": "崇祯帝、太子、公主",
          "type": "同江儿水",
          "text": ""
        },
        {
          "character": "崇祯帝",
          "type": "五供养",
          "text": ""
        },
        {
          "character": "王承恩",
          "type": "内白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "王承恩、费贞娥同上。"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": ""
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": ""
        },
        {
          "character": "王承恩",
          "type": "念",
          "text": ""
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": ""
        },
        {
          "character": "王承恩",
          "type": "念",
          "text": ""
        },
        {
          "character": "娘娘、太子、公主",
          "type": "同白",
          "text": ""
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": ""
        },
        {
          "character": "王承恩",
          "type": "念",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "五供养"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": " 随朕到太庙中哭、哭告一番！ 领旨！ 拜列圣英风未遥。 啊呀，痛不肖承基不道。 倾社稷怨难消。 痛王家骨肉身难保。 十七载王事辛劳。 停乐不逍遥。 谁料上天不佑保。 回首苍穹泪血空抛。 啊呀不好了吓！ 啊呀陛下不好了！ 吓。 天灾到，贼兵百万布城壕。 那杜勋呢？ 他奸谋狡，启关迎寇长驱捣。 啊呀！ 𠮾！ 虎贲龙骧呈散逃！ 休逆料，潜身逃遁须趁早。 仓忙觅道，仓忙觅道。 苍天哪，天！朝廷上下，分崩离析。勤王无师，立锥无地。朕惟有一死——"
        },
        {
          "character": "告宗庙望先灵鉴昭、亡家国恨难保、啊呀帝室如悬磬、宫闱似覆巢、我也曾食旰衣宵、我也曾减刑又爆税、盼只盼国富民有靠、风不顺雨不调、风不顺雨不调、上天不佑保、众人",
          "type": "同白",
          "text": "𠮾……"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "啊呀，以谢天下。"
        },
        {
          "character": "众人",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "我儿过来。"
        },
        {
          "character": "太子",
          "type": "白",
          "text": "父王。"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "可惜你生之不辰，罹遭国难。你可外穿民服，内藏玉牒，逃奔他乡，虽不指望 你中兴，尚可继续宗祧。你速速改装，逃命去吧！"
        },
        {
          "character": "太子",
          "type": "白",
          "text": "啊呀父王吓！儿臣不肖，不能为国抒忠，以致国家沦亡，今日岂敢偷生逃遁。 这生死——愿同一处的哟！"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "唗！胡说，你欲同死，何益于事？若不逃往他处，必然绝灭宗祧，岂非天地间 之大罪人吗？快去、快去、快去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥陪太子同下。"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "啊呀爱卿哪！当此国破家亡之际，可恨满朝文武各顾家身。今秉忠仗义，惟汝 一人，你今保护太子逃命去吧！"
        },
        {
          "character": "王承恩",
          "type": "白",
          "text": "陛下。奴婢受陛下雨露深恩，粉身难报。今当保太子出宫潜藏僻静村庄，况太 子生处无人厮认，奴婢当竭力保护，请万岁爷放心。"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "卿乃大忠臣也。你……改装去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王承恩下，太子便装上。"
        },
        {
          "character": "太子",
          "type": "白",
          "text": "父王，父王！啊呀！吓……"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "我儿，我儿！"
        },
        {
          "character": "崇祯帝、太子",
          "type": "同千秋岁",
          "text": "泪如潮， 此际心如搅， 急嚷嚷逃奔荒郊。 死別生离，死別生离， 只索向海角天涯飘渺。 离群雁生难料。 覆巢卵谁能保？ 逃脱渔阳道。 任潜踪匿迹，形影相吊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王承恩拉太子同下。"
        },
        {
          "character": "娘娘",
          "type": "白",
          "text": "我儿——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "静场。"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "取酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥取酒上。"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "岁在甲申，暮春三月，大明气数，于厮尽矣！"
        },
        {
          "character": "公主",
          "type": "白",
          "text": "父王母后啊！值此大难临身，微躯弱质何足为惜。请父王速将佩剑，立斩孩儿， 父王也可放心矣！"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "好！难得，难得！"
        },
        {
          "character": "公主",
          "type": "越恁好",
          "text": "严亲恩浩， 严亲恩浩， 自小沐恩高， 香消粉散，拚尸骸弃蓬蒿。 痛红颜幼娇， 痛红颜幼娇， 瘦怯怯赴泉台茫茫路遥。 君臣义母子恩， 碎首何堪报。"
        },
        {
          "character": "崇祯帝",
          "type": "越恁好",
          "text": "看剑光闪处节义名标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇祯杀死公主。"
        },
        {
          "character": "娘娘",
          "type": "白",
          "text": "儿啊——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇祯帝扔剑给娘娘。"
        },
        {
          "character": "娘娘",
          "type": "白",
          "text": "亲儿慢行，做娘的来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "娘娘自刎。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "万岁，娘娘自刎了！"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "好！死得好，死得好……"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "万岁……"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "费宫人，你逃命去吧！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奴婢愿与万岁娘娘共存同亡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇祯帝苦笑。"
        },
        {
          "character": "崇祯帝",
          "type": "白",
          "text": "哈，哈……有道是君死为社稷，尔死又何益？你，你逃生去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇祯帝撕衣襟写血书。"
        },
        {
          "character": "崇祯帝",
          "type": "念",
          "text": "朕非亡国主，误国是奸谗。吾尸可碎裂，百姓望垂怜。"
        },
        {
          "character": "崇祯帝",
          "type": "尾声",
          "text": "家亡国破何足道， 只索向泉台路遥。 苍天吓，天！ 恨只恨三百载皇图啊呀一旦抛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇祯帝自管向煤山走去。"
        },
        {
          "character": "费贞娥",
          "type": "尾声",
          "text": "朕非亡国主，误国是奸谗。 吾尸可碎裂，百姓望垂怜，百姓望垂怜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
