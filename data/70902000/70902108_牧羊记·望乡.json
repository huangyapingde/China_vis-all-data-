{
  "script_id": "70902108",
  "title": "牧羊记·望乡",
  "alias": [],
  "source": "俞振飞剧本选",
  "characters": [
    {
      "name": "苏武",
      "hangdang": "老生"
    },
    {
      "name": "李陵",
      "hangdang": "冠生"
    }
  ],
  "plot": "汉武帝时，苏武出使匈奴，被拘不降，牧羊于北海边，餐毡啮雪，艰苦卓绝。名将李广之后李陵，领兵五千\n来战，败于匈奴。汉帝杀李陵一家，毁其祖宗坟墓。匈奴单于乘机诱降了李陵。李陵往见苏武，一同拜望家\n乡。苏武大义凛然，责李陵降敌；李陵羞惭而去。苏武在匈奴十九年，不屈不挠，其后终于归汉。",
  "notes": "此剧老生、小生并重，要求通过唱工，塑造两个正反不同的人物形象，以伸张民族气节，批判投降行为。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苏武上。"
        },
        {
          "character": "苏武",
          "type": "谒金门",
          "text": "凝望眼， 极目关山远。 思想君亲肠寸断， 怎消忠孝愿？ 回首羝羊散乱， 幸遇野人为伴。 试把节旄一看， 表我君亲面。"
        },
        {
          "character": "苏武",
          "type": "念",
          "text": "海水无边无际，沙场无极无垠。无亲无眷又无邻，况又无家可奔。 日里无衣无食，夜间无被无衾。又无历日记时辰，不知春夏来，哪识秋冬尽？"
        },
        {
          "character": "苏武",
          "type": "忒忒令",
          "text": "我只得告天天可怜， 望天天与人做方便。 怎把我英雄来困？ 到不如那楚屈原： 他抱忠魂葬鱼腹， 也落得个话传！"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "啊呀我倒差了！那屈原因谏楚怀王不从，抱石投江而死。我苏武，受汉朝三世 厚恩，言听计从，没来由比他则甚！且住，前日有个渔父来说，汉将李陵，为 我而来，也被胡人拿住。后来单于招他为婿，不知可有此事。哎！岂有此理？"
        },
        {
          "character": "苏武",
          "type": "忒忒令",
          "text": "那李将军为人最贤， 怎肯与那羯膻为姻眷？"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "我想此事也非干李陵之故，哧！"
        },
        {
          "character": "苏武",
          "type": "忒忒令",
          "text": "多因是卫律那逆贼，哄他为不善。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "若是李陵在此，也该来看我。为何不来呢？吖是了。"
        },
        {
          "character": "苏武",
          "type": "忒忒令",
          "text": "莫不是他害羞惭， 为降虏也难相见。 因此上，不来到海边？"
        },
        {
          "character": "四小番",
          "type": "内同白",
          "text": "杀！"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "苏武",
          "type": "沉醉东风",
          "text": "我见，见一簇人马闹喧。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "吖吓，是了！"
        },
        {
          "character": "苏武",
          "type": "沉醉东风",
          "text": "莫不是胡贼又来相劝？"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "他若来时呵！"
        },
        {
          "character": "苏武",
          "type": "沉醉东风",
          "text": "拼一命丧黄泉，誓无他愿！ 早难道意回心转！ 为君守节，为亲保全， 何曾为一身上苟延？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小番引李陵同上。"
        },
        {
          "character": "李陵",
          "type": "沉醉东风",
          "text": "苏子卿别来数年， 受尽了艰辛万千。 遥望草窝边，见一人寒贱， 免不得上前相见。 为君守节，为亲保全， 何曾为一身上苟延！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "回避了。"
        },
        {
          "character": "四小番",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小番同下。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "哥哥在哪里？吓，啊呀哥哥吓！"
        },
        {
          "character": "李陵",
          "type": "哭相思",
          "text": "怎知今日重相见？"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "㕶！"
        },
        {
          "character": "李陵",
          "type": "哭相思",
          "text": "这冤苦向谁分辨！"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "李陵，看你这般打扮，莫非走差了路了？"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "哥哥，小弟一言难尽！"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "坐了讲。"
        },
        {
          "character": "李陵",
          "type": "园林好",
          "text": "从别后，朝廷与兵五千。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "与你五千人马，到哪里去？"
        },
        {
          "character": "李陵",
          "type": "园林好",
          "text": "到虏庭，与哥哥报冤。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "胜败如何？"
        },
        {
          "character": "李陵",
          "type": "园林好",
          "text": "不想道一身落殿。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "你竟败了？"
        },
        {
          "character": "李陵",
          "type": "园林好",
          "text": "这羞惭脸，怎生言？"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "但说无妨。"
        },
        {
          "character": "李陵",
          "type": "园林好",
          "text": "说将起，泪涟涟。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "那单于待你如何？"
        },
        {
          "character": "李陵",
          "type": "园林好",
          "text": "那单于惜才重贤。 赐咱官，委托将权。 每日里开筵设宴。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "闻单于招你为婿，可有此事？"
        },
        {
          "character": "李陵",
          "type": "园林好",
          "text": "将花艳女，绾良缘， 因此上，被利名牵。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "呀呀呀呸！你在此享荣华，受富贵，朝廷怎饶得你过？"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "啊呀哥哥吓！"
        },
        {
          "character": "李陵",
          "type": "江儿水",
          "text": "不想朝廷怒， 将咱祖冢迁。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "儿女也不顾了？"
        },
        {
          "character": "李陵",
          "type": "江儿水",
          "text": "满门儿女遭刑宪！ 望巴巴，有眼无由见； 哭啼啼，血泪空如霰！"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "哭也无用，何不回去？"
        },
        {
          "character": "李陵",
          "type": "江儿水",
          "text": "教我如何回转？"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "你的忠义孝心哪里去了？"
        },
        {
          "character": "李陵",
          "type": "江儿水",
          "text": "把孝义忠心，因此上，将刀割断！ 闻说哥哥在， 李陵常挂牵。 几回要见无由见。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "要见也不难。"
        },
        {
          "character": "李陵",
          "type": "江儿水",
          "text": "雁门关阻隔平生愿。 请哥哥到望乡台， 聊叙别离叹。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "到那里去做什么？"
        },
        {
          "character": "李陵",
          "type": "江儿水",
          "text": "到那里畅饮，何妨消遣？"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "我不去。"
        },
        {
          "character": "李陵",
          "type": "江儿水",
          "text": "你休得推辞。看李陵平昔交情之面。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "我断然不去。"
        },
        {
          "character": "李陵",
          "type": "川拨掉",
          "text": "你休执恋， 请前行，莫久延。 论兴衰贵贱，由天； 论兴衰贵贱，由天。 沧海与桑田，几番变迁。 把离愁且放宽。"
        },
        {
          "character": "苏武",
          "type": "川拨掉",
          "text": "这离愁怎放宽？ 我身似秋霜难久延！ 我的忠心，铁石样坚！"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "李陵！"
        },
        {
          "character": "苏武",
          "type": "川拨掉",
          "text": "若要我折节延年，若要我折节延年，"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "罢！"
        },
        {
          "character": "苏武",
          "type": "川拨掉",
          "text": "我拼一命死在眼前。"
        },
        {
          "character": "李陵",
          "type": "川拨掉",
          "text": "把离愁且放宽。"
        },
        {
          "character": "苏武",
          "type": "川拨掉",
          "text": "这离愁怎放宽？"
        },
        {
          "character": "苏武",
          "type": "尾声",
          "text": "形孤影只谁为伴？ 忍饿耽饥北海边。"
        },
        {
          "character": "李陵",
          "type": "尾声",
          "text": "谁与我兄解倒悬？"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "李陵，你今日到此何干？"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "小弟此来，非为别事；只因受降城外，新筑一台，名曰望乡台，请哥哥到彼望 南一拜，以表哥哥忠孝之心。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "李陵，你教我干别的事，断然不去，教我拜望家乡，哪有不去之理？"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "如此，哥哥请。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "苏武",
          "type": "念",
          "text": "客邸思君切，家乡未得归。"
        },
        {
          "character": "李陵",
          "type": "念",
          "text": "欲穷千里目，更上一层台。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番甲持酒上。"
        },
        {
          "character": "小番甲",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "住了，我自到此间，不食胡地之物。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "这是小弟自备的。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "哼哼，好个自备的。"
        },
        {
          "character": "李陵",
          "type": "画眉序",
          "text": "同上望乡台， 翠幕高张玳筵开。 幸相逢知己， 共倒金罍。 台下列珠履瑶簪， 座间拥姣娥粉黛。 这杯满饮休辞醉。 何妨暂展愁眉？"
        },
        {
          "character": "苏武",
          "type": "画眉序",
          "text": "鲰生愧不才， 历尽艰辛受狼狈。 对樽前欢笑。 自觉含哀。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "呀！看云山万迭，烟树模糊，不知哪一答是我的家乡？"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "望南一带就是。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "嘎！望南一带就是。吓！"
        },
        {
          "character": "苏武",
          "type": "画眉序",
          "text": "阿呀！我那圣上吓！念圣主……"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "吓，李陵，你在那里做什么？"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "与哥哥同拜家乡。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "呸！你既降顺在此，那一答就不是你的家乡了。谁要你拜！没廉耻！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "苏武",
          "type": "画眉序",
          "text": "啊呀我那圣上吓！ 念圣主，阊阖忧怀。 啊呀亲娘吓！ 叹慈母，倚门凝待。"
        },
        {
          "character": "李陵",
          "type": "画眉序",
          "text": "这杯满饮休辞醉， 何妨暂展愁眉？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同上。"
        },
        {
          "character": "众人",
          "type": "同神仗儿",
          "text": "悬丝傀儡， 妆模作样， 前引后随， 大家高声唱采， 活脱似神仙降临凡界。 齐看取，好诙谐； 齐看取，好诙谐！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "小番们把酒。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "哪里差来的？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "丁大王差来承应的。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "小心承应。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "众人",
          "type": "同回回曲",
          "text": "高高山上一庙堂， 姑嫂两个去烧香： 嫂子烧香求男女， 小姑烧香早招郎， 小姑烧香早招郎。"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "哆！"
        },
        {
          "character": "苏武",
          "type": "滴溜子",
          "text": "思量起，思量起，倦容怎抬？ 思量起，思量起，闷怀怎解？ 最苦一生飘败， 君亲未报答， 逆天罪大，怎禁得汪汪珠泪盈腮！"
        },
        {
          "character": "众人",
          "type": "同鲍老催",
          "text": "劝君放怀， 不必怨嗟时运乖。 常言否极当泰来， 枯木逢春花再开。 郎饮酒，高歌唱，休憔悴。 人生怎逃百年外， 无常到来恐翻悔。 请放下腰间带， 请放下腰间带。 红日正升， 皓月又来， 明里去，暗中来， 莫把朱颜改。 劝君了却相思债， 新愁旧恨权忍耐。 任造物，安排在。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "哆！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "回避了！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "苏武",
          "type": "尾声",
          "text": "离情万种愁无奈， 又被胡人恼乱怀。"
        },
        {
          "character": "李陵",
          "type": "夹白",
          "text": "哥哥！"
        },
        {
          "character": "李陵",
          "type": "尾声",
          "text": "怎遣得愁山并闷海！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "哥哥，小弟有言告禀。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "是。怀忠守节，虽义士之纲常；应变随机，乃达人之权度。单于这等看待，哥 哥当以折节奉承，岂可待兔守株？何必胶柱鼓瑟？"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "背义忘恩，实人臣之共耻；去顺效逆，岂忠孝之所为？我苏武受汉朝三世厚恩， 岂肯食胡地一粒之粟？顾此陋质，真如撮土之微；念及君恩，不减泰山之重。 我宁甘饿死，决不贪生！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "哥哥，此话非小弟之故。单于闻陵与哥哥交厚，故使小弟来说，不想哥哥是……"
        },
        {
          "character": "李陵",
          "type": "铧锹儿",
          "text": "受尽了千磨百灭， 一点丹心似铁。 欲待劝哥哥降顺， 教我有口难说。 思量起，恁忠洁， 好似严霜皓月！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "这等看来，我李陵与卫律之罪，上通于天，不可容也！"
        },
        {
          "character": "李陵",
          "type": "铧锹儿",
          "text": "我自叹嗟，徒意切。 这羞惭满面，悄地偷弹泪血！"
        },
        {
          "character": "苏武",
          "type": "铧锹儿",
          "text": "为人臣子， 当为君亲守节。 我若是见利忘恩， 肯与那盗贼无别？"
        },
        {
          "character": "苏武",
          "type": "夹白",
          "text": "李陵！"
        },
        {
          "character": "苏武",
          "type": "铧锹儿",
          "text": "你教我去顺膻羯， 我宁甘殒绝。 我的意已决， 和你从此别！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "还请三思。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "李陵，我和你相交半世，还不晓得我的性儿么？"
        },
        {
          "character": "苏武",
          "type": "铧锹儿",
          "text": "我若是贪图荣贵， 哪肯餐毡啮雪！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "哥哥！"
        },
        {
          "character": "李陵",
          "type": "念",
          "text": "铁石心肠不肯移，含悲洒泪枉嗟吁。"
        },
        {
          "character": "苏武",
          "type": "念",
          "text": "一片忠心难尽说，空中惟有老天知。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "哥哥，小弟告辞。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "李陵，今后不许来看我！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "自然还要来看哥哥的。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "吓！你若再来，我就一剑。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "没廉耻！还不走！"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "苏武",
          "type": "白",
          "text": "亏你羞也不羞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏武急下。"
        },
        {
          "character": "李陵",
          "type": "白",
          "text": "咳！羞死我李陵也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李陵下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
