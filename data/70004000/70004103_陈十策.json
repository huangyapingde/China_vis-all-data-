{
  "script_id": "70004103",
  "title": "陈十策",
  "alias": [],
  "source": "唐韵笙剧本选",
  "characters": [
    {
      "name": "闻仲",
      "hangdang": "净，画“老脸”，头戴帅盔，口戴白满，身穿红蟒，足穿黑靴"
    }
  ],
  "plot": "殷朝太师闻仲奉旨扫平北悔，生擒袁福通。忽报东、南伯侯叛反朝廷，正欲发兵前往，又见其子闻梦云来报，\n闻仲惊闻朝中大乱，急速班师回朝。闻仲于金殿呈治国安邦条陈十策，纣王不允，闻仲怒极将费仲、尤浑\n押入天牢。忽闻黄飞虎反出五关，闻仲执鞭闯入内宫责问纣王，探报姜于牙助西岐兵发朝歌，纣王无奈，准\n闻仲条陈十策、拆鹿台、废酷刑、贬妲己、斩费尤，闻仲奉旨兵伐西岐。",
  "notes": "此剧根据神话小说《封神演义》及传统连台本戏《封神榜》重新创作而成。创作、首演于一九三二年左右，\n花脸应工。二十世纪三十年代曾上演于天津、北京、东北三省，一九五九年重新修改后与《绝龙岭》一剧穿\n连来来，形成一出文武并重的大戏。\n为收集《陈十策》、《绝龙岭》两个剧本，曾几经周折，从曾与先父（唐韵笙）合作多年的老演员康昆山处\n获得由他口述录音、经刘沧春同志整理的先父早年的演出本，在此基础上又经先父的亲传弟子邵继笙仔细回\n忆，按一九五九年传授于他的原样恢复成此本。\n早年的演出本第二场闻仲、闻梦云均唱高拨子，由散板、导板、回龙、垛板组成。一九五九年修改后，将原\n第二场的高拨子改为西皮，并在第三场增加了二黄汉调，第四场增加西皮流水等唱段。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "邓忠、陶容、张节、辛环同上，同起霸。"
        },
        {
          "character": "邓忠、陶容、张节、辛环",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "邓忠。"
        },
        {
          "character": "陶容",
          "type": "白",
          "text": "陶容。"
        },
        {
          "character": "张节",
          "type": "白",
          "text": "张节。"
        },
        {
          "character": "辛环",
          "type": "白",
          "text": "辛环。"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "陶容、张节、辛环",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "太宰征战北海，大获全胜，收了降将袁福通。今日大宰班师还朝，你我两厢伺 候！"
        },
        {
          "character": "陶容、张节、辛环",
          "type": "同白",
          "text": "请哪！"
        },
        {
          "character": "陶容、张节、辛环",
          "type": "同粉蝶儿",
          "text": "杀气冲霄， 众儿郎杀气冲霄。 （〖急急风〗。邓忠、陶容、张节、辛环自两边分下。吉利、余庆同翻上，牵麒麟作洗马动作，牵下。〖大 发点〗。八大铠同上，同站门，二旗牌捧剑、印、中军捧令、四小马夫抬二鞭同上。八飞虎旗挡闻仲同上。）"
        },
        {
          "character": "闻仲",
          "type": "粉蝶儿",
          "text": "奉王命征北海， 得胜还朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。闻仲上高台。邓忠、陶容、张节、辛环同上。"
        },
        {
          "character": "邓忠、陶容、张节、辛环",
          "type": "同白",
          "text": "参见太宰！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "邓忠、陶容、张节、辛环",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "闻仲",
          "type": "念",
          "text": "我本朝中第一臣，胯下走兽墨麒麟。征战北海十五载，钢鞭一举定乾坤。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老夫，太宰闻！老夫奉天子命诏，带领人马，征战北海一十五载。昨日一战， 生擒袁福通，好言相劝，情愿归降，愿献上降书顺表年年进贡，岁岁来朝。 众将官！传降将袁福通进帐！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "传北海降将袁福通进见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵土捧降书同上，袁福通上，跪。"
        },
        {
          "character": "袁福通",
          "type": "白",
          "text": "北海降将袁福通献上降书顺表，太宰请看！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲看。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "袁将军快快请起！待老夫奏明圣上，自有封赠。"
        },
        {
          "character": "袁福通",
          "type": "白",
          "text": "多谢太宰！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老夫就要班师还朝，命你原镇北海不得有误！"
        },
        {
          "character": "袁福通",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁福通下。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "邓忠、陶容、张节、辛环、吉利、余庆",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "打罢得胜鼓，班师还朝！ （起牌子。吉利、余庆同下，带麒瞵同上。闻仲下高台。邓忠、陶容、张节、辛环、吉利、余庆同下，闻仲 上麒麟，闻仲、八大铠、二旗牌、中军、四小马夫、八飞虎旗同亮相，同下。）"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "闻梦云上，趟马，下。二报子同上，同趟马，走四犄角，领起圆场。"
        },
        {
          "character": "二报子",
          "type": "同白",
          "text": "闻太师来也！ （闻仲、邓忠、陶容、张节、辛环、吉利、余庆、中军、八大铠、二旗牌、四小马夫、八飞虎旗同上，下场 斜门。）"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "前队为何不行？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "报子挡道。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "挖门。闻仲归正场，二报子同下马。"
        },
        {
          "character": "二报子",
          "type": "同白",
          "text": "闻太师在上。报子大参！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "打探哪路军情，起来讲！"
        },
        {
          "character": "二报子",
          "type": "同白",
          "text": "太宰容秉！"
        },
        {
          "character": "报子甲",
          "type": "白",
          "text": "东伯侯兴兵造反，"
        },
        {
          "character": "报子乙",
          "type": "白",
          "text": "南伯侯叛反朝廷！"
        },
        {
          "character": "二报子",
          "type": "同白",
          "text": "两路叛军兵是兵山，将是将海，好不威严也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "打探有功，赐银牌一面，再去打探！"
        },
        {
          "character": "二报子",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二报子同下。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "唉呀且住！我想东伯侯姜恒楚乃是皇亲国戚，南伯侯鄂祟禹乃世代忠良，为何 谋反？定是圣上有负诸侯也！若不安抚他们，必然引起天下大乱。老夫暂不还 朝，将人马发至东南两处，以解此危！ 众将官！人马暂不还朝，前队改为后队；向东南进发！"
        },
        {
          "character": "闻仲",
          "type": "唱",
          "text": "正欲班师转回朝， 不想东南起风云。 拨转麒麟催前进， （八大铠、二旗牌、中军、四小马夫反领同下。邓忠、陶容、张节、辛环、吉利、余庆、闻仲同走反圆场， 闻梦云上，见闻仲，大推磨。）"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "爹爹慢走！"
        },
        {
          "character": "闻梦云",
          "type": "唱",
          "text": "孩儿有话禀爹尊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲、闻梦云分下马。"
        },
        {
          "character": "闻梦云",
          "type": "唱",
          "text": "走上前来礼恭敬，"
        },
        {
          "character": "闻仲",
          "type": "唱",
          "text": "开言问声小梦云。 不在朝歌伴王驾，"
        },
        {
          "character": "闻梦云",
          "type": "唱",
          "text": "朝中出了叛逆臣。 昏王信宠妲己女，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "妲己她是何人？"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "爹爹有所不知，只因冀州侯苏护进来一女名唤妲己，自从她进得朝来与费仲尤 浑狼狈为奸，造炮烙修鹿台，诸多罪孽俱在她一人身上所起！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "怎么？俱在她一人身上所起？"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "难道说满朝文武就被袖手旁观不成？"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "闻梦云",
          "type": "唱",
          "text": "文武保本君不听。 最可叹姜国母挖目烙手身已死，"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "啊？姜国母乃是贤德的皇后，为何挖目烙手一死？"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "只因妲己要夺正宫国母之位，与费仲、尤浑定下一计，命刺客埋伏粉宫楼前， 刺王杀驾，被殿前武土拿获。刺客言道，他与后宫姜国母乃是内亲，奉了姜国 母之命刺王杀驾。怒恼圣上，将姜国母挖目烙手而死。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "噢！贤德的皇娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲哭。"
        },
        {
          "character": "邓忠、陶容、张节、辛环、吉利、余庆",
          "type": "同哭",
          "text": "贤德的皇后啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲抓住闻梦云。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "梦云！你、你、你往下讲！"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "闻梦云",
          "type": "唱",
          "text": "方弼、方相反五门。 殷郊殷洪无踪影， 梅伯炮烙丧残生。 最可叹比干丞相剖心死，"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "啊！比干丞相乃是三朝元老，为何剖心一死？"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "只因妲己生了重病，胡喜媚奏道乃是旧病复发，百药俱全缺少药引。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "什么药引？"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "七孔玲珑心。那胡喜媚言道满朝文武俱是心血，唯有比干丞相是七孔玲珑心， 圣上将比干丞相唤上鹿台，与他借心一片，那比干丞相就剖心一死！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "闻梦云",
          "type": "白",
          "text": "剖心一死！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "啊！三朝元老如此的下场！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲哭。"
        },
        {
          "character": "邓忠、陶容、张节、辛环、吉利、余庆",
          "type": "同哭",
          "text": "比干丞相……"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "你、你、你往下讲！"
        },
        {
          "character": "闻梦云",
          "type": "唱",
          "text": "商容碰死在龙廷。 成王与朝臣把计定， 搬请爹爹回朝门。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "反了啊反了！"
        },
        {
          "character": "闻仲",
          "type": "唱",
          "text": "闻言犹如雷轰头顶， 冷水浇头怀抱冰。 实指望征北海商汤安定， 有谁知出妲己扰乱朝廷。 造炮烙，修虿盆， 最可叹商容、梅伯、姜后、比干，一个一个一个一个丧残生！ 只剩下老闻仲白发苍苍发如银， 锦绣江山化灰尘，泪双淋，痛煞人！"
        },
        {
          "character": "闻梦云",
          "type": "唱",
          "text": "爹爹痛哭有何用， 不如班师回朝门。"
        },
        {
          "character": "闻仲",
          "type": "唱",
          "text": "娇儿一言来提醒， 险些误了大事情！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "且住！朝纲大乱，妲己与费仲、尤浑狼狈为奸，若不还朝重整朝纲，势必引起 天下大乱。 邓忠、陶容，听令！"
        },
        {
          "character": "邓忠、陶容",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "命你二人速去泗水关，命总兵韩荣抵挡东伯侯！"
        },
        {
          "character": "邓忠、陶容",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "张节，辛环听令！"
        },
        {
          "character": "张节、辛环",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "命邓九公之女邓蝉玉迎战南伯侯不得有误！"
        },
        {
          "character": "张节、辛环",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "众将官！大队人马班师回朝！ （八大铠、二旗牌、中军、四小马夫、邓忠、陶容、张节、辛环、同过场，同下。闻梦云随下。吉利、余庆、 闻仲压场，同马趟子亮相，同下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四太监、大太监、四文官、四武官、费仲、尤恽、纣王自下场门同上，同站八字。闻仲、闻梦云、邓忠、"
        },
        {
          "character": null,
          "type": "text",
          "text": "陶容、张节、辛环、吉利、余庆、中军、八大铠、二旗牌、四小马夫、八飞虎旗同上。闻仲见纣王，下麒鳞。"
        },
        {
          "character": null,
          "type": "text",
          "text": "纣王赐酒，闻仲接祭天地，进大礼，纣王扶闻仲起，纣王进位，四文官、四武官同拜闻仲。）"
        },
        {
          "character": "闻仲",
