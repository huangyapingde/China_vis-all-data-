{
  "script_id": "70004107",
  "title": "未央宫斩韩信",
  "alias": [],
  "source": "唐韵笙剧本选",
  "characters": [
    {
      "name": "韩信",
      "hangdang": "老生，头戴金踏镫，口戴黑三，身穿红蟒，足穿黑靴"
    },
    {
      "name": "吕后",
      "hangdang": "旦"
    },
    {
      "name": "萧何",
      "hangdang": "老生"
    },
    {
      "name": "刘邦",
      "hangdang": "老生"
    }
  ],
  "plot": "刘邦即位后，命陈豨出征。陈豨求计韩信，韩信劝同反，并作内应。陈豨反后，刘邦亲往征讨，并捉住下书\n人，搜得韩信反书，降旨委吕后处之。吕后与萧何定计，诓韩信入未央宫，斩之。",
  "notes": "此剧根据《史记·淮阴侯列传》、《西汉演义》及传统本戏《楚汉争》重新创作而成。一九三五年创作首演\n于沈阳，老生应工。首演时作为单折戏演出。一九四七年先父（唐韵笙）赴江南各地时，曾先后演出过《楚\n汉争》（包括《九里山》、《别虞姬》、《伐陈豨》、《人头会》、《未央宫》、《斩韩信》），以及《全\n部汉宫秘史》（包括《楚汉交兵》、《霸王别姬》、《季布降汉》、《金殿封官》、《严拿楚将》、《随何\n访齐》、《钟离自刎》、《韩信献头》、《贬官降职》、《陈豨求计》、《兵困曲阳》、《公著告变》、\n《吕后变计》、《萧何诓信》、《人头大会》、《未央斩信》），其中《斩韩信》一折均按此本演出。一九五\n四年先父（唐韵笙）在上海演出时，将此剧作了整理，仍作为单折戏演出。全剧自刘邦降旨派陈豨出征起，\n未央宫斩韩信止。在演出中曾经一度将萧何诓信与未央宫斩信并为一场。本书编入的是一九五四年整理后的\n演出本。\n此剧与于占先、刘汉臣、小杨月楼等演出的《斩韩信》，情节、场子、表演、唱腔、扮相完全不同。剧中以\n近四十句的西皮慢流水、二黄碰板做为韩信的两个主要唱段，在演唱的处理上均俱特色。表演上运用了转跪、\n蹦跪等动作，细腻紧凑，扣人心弦，是一出唱做并重的老生戏，该剧演出后深受欢迎，成为唐派艺术的代\n表剧目。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "萧何、夏侯婴、田肯、季布、随何同上。"
        },
        {
          "character": "萧何、夏侯婴、田肯、季布、随何",
          "type": "同点绛唇",
          "text": "楚汉相争，项羽无能，乌江丧，诸侯归心，汉室江山定。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "启乐。大太监、四太监、四大铠、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "引子",
          "text": "嬴秦无道，山河破，虎斗龙争。"
        },
        {
          "character": "萧何、夏侯婴、田肯、季布、随何",
          "type": "同白",
          "text": "臣等见驾，陛下万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "萧何、夏侯婴、田肯、季布、随何",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": "刘邦",
          "type": "念",
          "text": "孤王起义在沛丰，逐鹿中原楚汉争。项羽无谋乌江丧，汉室才得基业宁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤，刘邦。自沛丰起义，蒙文臣武将辅佐，平秦灭楚，破赵收燕，方得江山初 定。今设早朝，众卿可有本奏？"
        },
        {
          "character": "萧何",
          "type": "白",
          "text": "启奏陛下：今有冒顿，在赵国代州兴兵扰乱，请陛下定夺。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "冒顿屡次扰乱，孤早有意征伐，只是江山初定，将士疲乏，故未兴兵。既又来 犯，理应征讨。 内侍，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "宣陈豨上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "万岁有旨：陈豨上殿哪！"
        },
        {
          "character": "陈豨",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈豨上。"
        },
        {
          "character": "陈豨",
          "type": "念",
          "text": "拜将封侯印，英雄立战功。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "陈豨见驾陛下万岁。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "万万岁。宣臣上殿，有何旨意？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "今有冒顿扰乱代州，命你带兵征剿。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "臣启陛下：那冒顿兵强将勇，为臣恐难胜他，若命淮阴侯韩信领兵征剿，定能 一战成功。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "韩信么……一来数年征战疲劳，二来久未上朝参与国事，恐难当此任。不要多 奏，领旨下殿。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": "萧何、夏侯婴、田肯、季布、随何",
          "type": "同白",
          "text": "请驾回宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦、萧何、夏侯婴、田肯、季布、随何、大太监、四太监、四大铠同下。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "且住。万岁命俺征剿冒顿，却为何不用韩信为帅？有了，我不免去至韩府商议 便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈豨下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩信上。"
        },
        {
          "character": "韩信",
          "type": "引子",
          "text": "龙韬豹略，平秦楚，智广才多。"
        },
        {
          "character": "韩信",
          "type": "念",
          "text": "昔日弃楚后归汉，受阅登坛掌兵权。九里山前曾一战，逼得霸王刎龙泉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同上。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "本爵，韩信。曾在项羽帐下以为执戟郎官，蒙张良赠我角书，萧何三荐，受阅 登坛，平秦灭楚，破赵收燕，汉室才得一统。可恨刘邦只能共患难，不能同富 贵。他疑心于我，将我兵权撤掉，三齐王贬为淮阴侯。是我心中不服，久不上 殿朝拜，长此以往，何日是俺出头之日！正是："
        },
        {
          "character": "韩信",
          "type": "念",
          "text": "汗马功劳终何用，敌国一破亡谋臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谢公著上。"
        },
        {
          "character": "谢公著",
          "type": "念",
          "text": "有事来禀报，无事不乱传。"
        },
        {
          "character": "谢公著",
          "type": "白",
          "text": "启禀侯爷：陈豨将军求见。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。陈豨上。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "元帅在上，末将大礼参拜。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "只行常礼了吧！"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "哪有不拜之礼。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "啊将军，到此必有所为。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "只因冒顿扰乱代州，汉王命我征讨，想那冒顿兵强将勇，只恐难以取胜，为此 特来向元帅求计。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "那冒顿乃乌合之众，骄兵憨将，不足为惧。可将弱兵陈于前，精兵伏于后，出 奇制胜，定能破敌。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "多谢元帅指教。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "岂敢。唉！"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "元帅为何长叹？"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "将军，征讨冒顿倘若得胜，比韩信功劳如何？"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "末将纵然得胜，也比不得元帅平秦灭楚功高盖世。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "想汉室江山，出于我手。也不过是朝则王侯暮则匹夫之辈耳！"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "啊元帅，何计教我？"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "你如今兵权在手，何不另想别图？"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "听元帅之言，莫非叫末将反——"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "噤声！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩信示谢公著，谢公著下。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "将军，那汉王只能共患难，不能同富贵。本帅当年立下汗马功劳，一朝尽弃。 将军此番征讨冒顿得胜之后，你可按兵不动，自立为王，如此汉王定要兴兵问 罪。到那时，我在咸阳起事，得了汉室江山，富贵共之如何？"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "正合我意。啊元帅，末将在此久留只恐汉帝生疑，告辞了。"
        },
        {
          "character": "陈豨",
          "type": "唱",
          "text": "元帅一言将我警，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈豨下。"
        },
        {
          "character": "韩信",
          "type": "唱",
          "text": "背转身来暗沉吟。 非是韩信行不正， 只为恢复旧功勋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩信下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引吕后同上。"
        },
        {
          "character": "吕后",
          "type": "唱",
          "text": "五年来楚汉争烽烟滚滚， 随军旅受颠簸饱尝艰辛。 江山定我得以参与国政， 待来日偿夙愿地动天惊。"
        },
        {
          "character": "刘邦",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、刘邦同上。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "恨陈豨在代州按兵不动， 见梓童议国事带兵亲征。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕后出迎，拜，归坐。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "陛下今日回宫，因何不悦？"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "梓童不知，今有陈豨占了赵代，按兵不动，蓄意谋反。本当征讨，怎奈朝中无 有能将，故而忧烦。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "既如此，陛下就该御驾亲征，群雄慑胆，以振王威。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "孤有意亲征，又恐韩信在朝生变，故尔犹豫不决。"
        },
        {
          "character": "吕后",
          "type": "白",
          "text": "陛下尽可放心。如今韩信已无兵权，如若生事，妾妃自能除之。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "如此甚好。待孤留下宝剑一口，上写“斩韩信”三字，你可便宜行事，宝剑伺 候。"
        },
        {
          "character": "刘邦",
          "type": "唱",
          "text": "梓童代孤理朝政， 尚方宝剑与你留存。 上写三字“斩韩信”，"
        },
        {
          "character": "吕后",
          "type": "唱",
          "text": "请陛下放宽心去出征。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘邦、吕后同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、陈豨同上。"
        },
        {
          "character": "陈豨",
          "type": "唱",
          "text": "为反刘邦占赵代， 每日操演把兵排。 按兵不动严阵待，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "汉王亲自领兵征讨。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "众将官，迎战者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠引刘邦同上。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "原来是汉王御驾亲征，恕末将甲胄在身，不能全礼。"
        },
        {
          "character": "刘邦",
          "type": "白",
          "text": "陈豨！你竟敢起义谋反，孤王今日兴兵来此，还不下马受缚！"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "刘邦！你为人奸诈，诛戮功臣，只能共患难，不能同富贵，哪个扶保于你！"
        },
        {
          "character": "刘邦、陈豨",
          "type": "同白",
          "text": "众将官，拿（陈豨）（刘邦）！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、四大铠同起打。陈豨败下。刘邦率四大铠同追下。陈豨败上。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "且住！汉王兵强将勇，我军难以对敌，不免修书与韩元帅求计。 来，启开文房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。陈豨修书。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "旗牌过来。命你将书信面呈现淮阴侯，要多加小心。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "陈豨",
          "type": "白",
          "text": "众将官！兵屯曲阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈豨下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌引韩信同上。"
        },
        {
          "character": "韩信",
          "type": "唱",
          "text": "想当年我也曾弃楚归汉， 恨项羽他用我执戟郎官。 到褒中蒙萧何诚心三荐， 那时候我才得拜将登坛。 官封到三齐王禄厚爵显， 到如今困咸阳撤去兵权。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谢公著上。"
        },
        {
          "character": "谢公著",
          "type": "白",
          "text": "启侯爷：下书人求见。"
        },
        {
