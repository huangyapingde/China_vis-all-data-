        {
          "character": "韩信",
          "type": "唱",
          "text": "非是韩信多心细， 内宫摆宴令我心疑。 不进未央我回府去，"
        },
        {
          "character": "萧何",
          "type": "内白",
          "text": "淮阴侯你要来呀！"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "哦哦来了！"
        },
        {
          "character": "韩信",
          "type": "唱",
          "text": "萧何焉能把我欺。 功高盖世何所惧， 平秦灭楚功第一。 大丈夫向前莫退避，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同上，同拿住韩信，同下。"
        }
      ]
    },
