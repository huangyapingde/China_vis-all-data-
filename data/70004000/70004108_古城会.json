    },
    {
      "name": "蔡阳",
      "hangdang": "净"
    },
    {
      "name": "甘夫人",
      "hangdang": "旦"
    },
    {
      "name": "糜夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "关羽过关斩将行近古城，遣马童探得张飞下落，急而往见。张飞疑关羽负义，关羽含泪剖白。张飞若有所动，\n忽见蔡阳率兵追至，迎嫂而闭城。关羽无奈，力斩蔡阳，张飞始悟，亲迎关羽入城，并前往请罪。关羽义\n责张飞，二皇嫂出面跪劝，弟兄和好如初。",
  "notes": "此剧系唐韵笙根据王鸿寿先生的演出本整理而成。整理、演出年代约于一九三五年。其中关羽出场的西皮导\n板、原板，城下见张飞的西皮二六均与老本不同，训弟一折不上刘备，由二皇嫂劝弟。一九五七年作过一次\n修改。曾一度易名《古城释疑》，其中二六的个别唱词和场子有所改动。一九六零年唐韵笙对该剧重新做了\n修订。该剧从情节的处理到台词、唱词，与王本有明显区别，成为唐派红生戏中的代表剧目。三十年代以后，\n东北演关羽戏的演员大都宗唐派的路子演出。\n关羽面部揉红脸，头戴夫子巾，穿软靠，披斗篷，手执马鞭，三停青龙刀。训弟穿绿蟒折扇。口戴黑三，足\n穿黑靴。\n在艺术处理上，关羽第一个出场由马夫扛刀牵马而上，西皮二六以后没有小开打，斩蔡后增加了下马后的表\n演动作，训弟中强调了对于张飞的教育等。唐韵笙在该剧中通过细致的唱和做，着力表现关羽性格中的一个\n侧面，即始终如一地忠于桃园结义的情感。表演细腻、含蓄、深沉，使该剧具有鲜明的唐派风格。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "念",
          "text": "探得军情事，报与将军知。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "俺，曹营探子是也。只因关羽过关斩将，在黄河渡口将大将秦琪刀劈马下，俺 不免将此事报与蔡阳老将军知道。就此马上加鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大帐。发点。众兵将、蔡阳同上。"
        },
        {
          "character": "蔡阳",
          "type": "点绛唇",
          "text": "出师朝堂，盔甲明亮，军威壮，将勇兵强，要把烟尘扫荡。"
        },
        {
          "character": "蔡阳",
          "type": "念",
          "text": "须是三冬雪，发如九秋霜。中原为上将，威名天下扬。"
        },
        {
          "character": "蔡阳",
          "type": "白",
          "text": "老夫，蔡阳。只因刘辟、龚都二次汝南谋反，今奉曹丞相将令，统领五万人马 兴师问罪，今乃黄道吉日，正好兴兵。 众将官，兵发汝南去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报！老将军在上，探子大参！"
        },
        {
          "character": "蔡阳",
          "type": "白",
          "text": "有何军情起来讲！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "老将军容禀；今有关羽过关斩将，在黄河渡口将少将军秦琪刀劈马下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小牌子。"
        },
        {
          "character": "蔡阳",
          "type": "白",
          "text": "不好了！再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "蔡阳",
          "type": "白",
          "text": "且住。胆大关羽竟敢将吾外甥秦琪刀劈马下，岂能容他猖狂。 众将官，人马不去汝南，追赶关羽去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人领起，同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "关羽",
          "type": "内唱",
          "text": "挂印封金辞汉相，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人、二车夫、老军、小校同上，关羽、马夫同上。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "灞陵挑袍马蹄忙。 千里单骑寻兄长， 一路风霜离许昌。 过五关斩了六员将， 黄河战惇别郭常。 晓行夜宿阳关上， 饥餐渴饮路途忙。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "启禀二爷：一路匆忙，人困马乏，前面有一松林何不歇息歇息再走。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好，军仗从人转入松林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同入林，关羽下马。马夫牵马下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "参见二位嫂嫂。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二弟免礼！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谢嫂嫂。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二弟，千里风尘艰难险阻，我姐妹连累你了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此乃小弟份内之事，何足挂齿。只是小弟一路闯关斩将，二位嫂嫂车仗之上多 受惊慌，乃弟之罪也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫急上。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "启禀二爷：东南角下尘土高起，想是曹兵追来！"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "喂呀！"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同唱",
          "text": "虎口余生才脱险， 又遇豺狼把路拦。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二位嫂嫂，休要惊慌。前面芒砀山下有一古城，孙乾对弟言道，三弟在彼处占 据，不知真假，待小弟差人前去探听明白，若是三弟在此，命他出城迎接。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "如此速速派人前去。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二位嫂嫂请入后松林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马夫，命你去至前面古城，若见你家三爷，就说你家二爷保定二位主母来到古 城，叫他快些出城迎接。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "转来，你家三爷性情不好，你要小心回话。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "小人知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "不惧千般险，一心复桃园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "弟兄结拜在桃园，乌牛白马祭地天。徐州不幸曾失败，红脸的他负义降曹瞒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺，张飞。当年弟兄徐州失败，俺老张来到芒砀山赶走了古城狗官，嘿！我就 坐了这古城的县令。每日操演人马以图后举，谁想那红脸的竟降顺了曹阿瞒， 日后若得相见，我岂肯与他干休！适才校场操演，尔等的武艺越发精壮了，哈 哈哈哈！ 嘚，三军的，准备羊羔美酒大家痛饮哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫上。"
        },
        {
          "character": "马夫",
          "type": "念",
          "text": "离了松林地，来此是古城。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "里面哪位听事？"
        },
        {
          "character": "兵士",
          "type": "白",
          "text": "作什么的？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "有劳通禀，就说马夫求见。"
        },
        {
          "character": "兵士",
          "type": "白",
          "text": "候着。 启禀三爷：外厢马夫求见。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "唤他进来。"
        },
        {
          "character": "兵士",
          "type": "白",
          "text": "是。 随我进来。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "是。 马夫与三爷叩头。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "起来。你奉何人所差？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "奉我家二爷所差。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "敢是那红脸的吗？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "正是我家二爷。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "将他哄了出去！"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "且慢！我家二爷保定二位主母千里迢迢来到古城，请三爷迎接。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你且住了！你家二爷无仁无义，忘却桃园盟誓，有始无终真心降顺曹营，有何 脸面来见弟兄。若要相见除非是临阵交锋。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "小人有下情回禀。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "三爷容禀：我家二爷有仁有义不忘桃园盟誓，有始有终假意归顺曹公。千里迢 迢来会弟兄，眼前讲话有一人不通。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哪个不通？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "就是三爷不通。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "三爷你不通！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咋咋咋哇呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞用枪刺马夫，马夫下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嘿！若不是他两腿快如风，这丈八矛定要刺他个前后皆通！ 小校的！带马出城会他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、众兵士同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马夫上。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "有请二爷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "参见二爷。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢了，可曾见着三爷？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "见着了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "为何不见他出城迎接？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "二爷容禀：那三爷言道，二爷无仁无义，忘却桃园盟誓，有始无终，真心归顺 曹公。若要相见除非是临阵交锋！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马夫，旁人不知，难道你还不知你二爷的苦心？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "小人怎的不晓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你是怎样回答？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "小人言道：我家二爷有仁有义不忘桃园盟誓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯……"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "有始有终假意归顺曹公。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "着啊！"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "千里迢迢奉嫂寻兄，眼前讲话有一人不通，三爷问道哪个不通，小人斗胆言道 就是三爷不通！怒恼了三爷，他、他、他提枪就刺！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你便怎样？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "哎呀二爷呀！若不是小人两腿快如风，险些被他刺个前后皆通！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "噢！三弟还是这样性暴！弟兄失散多年难免疑心，待我亲自会他。 小校的，好好保护二位主母。 马夫，与爷抬刀带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下，换衣上，马夫领起，同走圆场，亮相，同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众兵将、蔡阳同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。关羽、马夫同上。起鼓。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "三爷出城来了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "噢，三弟来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、四兵士同上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟！弟兄失散多年见了愚兄一言不发，为何劈面就刺？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "红睑的！你忘了桃园结义归顺曹营，有何面目来会弟兄？你看枪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟！只因愚兄被困土山，二位嫂嫂在城中无人保护，万般无奈约下三事，降 汉不降曹。三弟为何如此多疑？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "红睑的，红睑的！你在曹营，那曹操待你是何等恩厚，三日一小宴，五日一大 宴，上马献金下马献银，赐你美酒红袍，是何等快乐，你回来作甚？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟！那曹操虽然待兄不薄，我也曾斩颜良诛文丑报效于他。今闻大兄长现在 河北冀州袁绍处，为此奉嫂寻兄，三弟不信，车仗之上问过二位嫂嫂你就明白 了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "噯！不提起斩颜良诛文丑还则罢了，提起此事叫你张三爷我好恼啊！好恨！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你恨着何来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你且听道：当年我弟兄除州失散，俺大哥投奔河北袁绍帐中，暂为栖身。那袁 绍差遣大将颜良攻打白马坡，被你刀劈马下，延津你又诛了文丑，那袁绍闻得 此讯要将俺大哥推出斩首。幸得大哥巧言相辩，哄过袁绍才得活命。这，这都 是你办的好事！你啊你看枪吧！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟，你当真不认为兄？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "不认你！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "果然不认为兄？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "实话跟你说吧，我呀，早跟你拔了香头子了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你我弟兄撕杀起来岂不被人耻笑，望三弟将二嫂接进城去，待为兄下马自刎一 死，以表真心！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好哇！你自刎一死免得你张三爷动手！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢！罢！罢！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "勒马停蹄珠泪掉， 青龙刀斜跨在马鞍鞒。 想当年在徐州弟兄们失散了， 困土山得相会故友张辽。 失下邳为保护二位皇嫂， 约三事降汉室并未降曹。 曹孟德他待我礼义甚好， 上马金下马银美酒红袍。 官封我汉寿亭侯爵禄非小， 大丈夫岂能够忘却了旧交。 今闻得大兄长投奔袁绍， 挂印封金饯行在灞陵桥。 过五关斩六将直奔黄河道， 斩秦琪走单骑千里迢迢。 念桃园三结义同把汉保， 刘、关、张虽异姓似同胞，莫动枪刀！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嘿！咱老张这铁石心肠被他这么一哭，也就哭软了！嗯，也罢，待我将二位嫂 嫂接进城去，少时再来与他辩理。 啊二哥，既然如此就请二位嫂嫂进城也就是了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嘚三军的，将古城打开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。甘夫人、糜夫人、车夫同上，过场，同下。"
        },
        {
          "character": "张飞、关羽",
          "type": "同白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、关羽同上马。起堂鼓。张飞观望，进城关门，关羽至城前，急勒马退。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟，因何将兄关在城外？"
