{
  "script_id": "70004105",
  "title": "闹朝击犬",
  "alias": [],
  "source": "唐韵笙剧本选",
  "characters": [
    {
      "name": "赵盾",
      "hangdang": "老生，头戴相貂，口戴白三，手执圭，足穿黑靴。前场穿香色蟒，挂硬带；“鉏麂行刺”一场换紫色"
    },
    {
      "name": "蟒，挂硬带；“施计闹朝”一场穿紫蟒，执圭，挂剑；“击犬”一场内穿箭衣，斜紫蟒，挂硬带、执圭",
      "hangdang": "未知"
    },
    {
      "name": "屠岸贾",
      "hangdang": "净"
    }
  ],
  "plot": "周时，晋灵公无道，荼害百姓。相国赵盾屡谏不听，挡驾于桃园门外激怒晋灵公。佞臣屠岸贾献计，命武士\n鉏麂行刺赵盾。鉏麂见赵盾忠正为国，不忍加害，触槐而死。屠岸贾又生二计，诓赵盾君前献剑，遂放獒犬\n追噬。赵盾临危不惧，奋力搏斗，力士提弥明杀死獒犬被围逼自刎。赵盾之子赵朔、赵穿救出赵盾，闯进宫\n去，弑晋灵公于内宫。",
  "notes": "此剧根据历史小说《东周列国志》第五十回情节编写。一九三四年创作，首演于沈阳。老生应工，全剧共八\n场。二十世纪三、四十年代常演于东北三省，二十世纪四十年代后期演出于江南各地。一九六二年唐韵笙对\n此剧作了整理，并将原名《闹朝扑犬》改为《闹朝击犬》。曹艺斌、田子文、邵继笙等曾演出，董春柏曾受\n教于唐韵笙。\n全剧唱、念、做、舞并重。其中“挡驾谏本”的唱，“鉏麂行刺”的做，“施计闹朝”、“击犬”的舞均俱\n有鲜明的特色。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "【第一场：桃园肆虐】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一贯干牌。众武士、四太监、屠岸贾、晋灵公同上，摆队同入桃园。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "众武士，寡人驾游桃园，不许百姓在外喧哗，如有靠近桃园者，杖责四十。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "尔等禁守桃园，无论何人不许擅入。两厢退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众武士同下。獒奴牵犬上，犬向晋灵公、屠岸贾摇尾，晋灵公抚犬笑。"
        },
        {
          "character": "晋灵公",
          "type": "西皮摇板",
          "text": "画阁雕梁绛霄楼， 金碧辉煌似瀛洲。 龙楼凤阁如锦绣， 富贵属于公伯王侯。"
        },
        {
          "character": "屠岸贾",
          "type": "西皮摇板",
          "text": "晋国江山升平奏， 君臣安享乐无忧。 得饮酒来且饮酒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "啊大王，前者为臣与大王比试弹法，未见胜负，今日为臣还请一试，大王意下 如何？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "寡人正有此意。 内侍，看弓弹伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扭丝。大太监托盘献弓弹。"
        },
        {
          "character": "晋灵公",
          "type": "西皮摇板",
          "text": "又见空中鸟当头。 开弓弹打飞鸟落，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。晋灵公打鸟落。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "大王好弹法！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "卿家试来。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "为臣献丑了。"
        },
        {
          "character": "屠岸贾",
          "type": "西皮摇板",
          "text": "只恐为臣逊一筹。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "啊，大王请看，此时宫中无有飞鸟，叫为臣拿何物来试弹法？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公、屠岸贾同远视。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "卿家你来看，这桃园以外，来往的百姓甚是讨厌，何不将他们当做飞鸟来试你 我的弹法，你看如何？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "这样的试法，真乃妙得很，大王叫为臣先打哪一个呢？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "你打年轻的，我打年老的。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "若是俊俏的妇女呢？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "俊俏的妇女么——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公笑。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "不但不打，还要叫她进园，陪伴寡人吃酒。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "如此你我君臣，各持弓弹等候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老汉甲上。"
        },
        {
          "character": "老汉甲",
          "type": "西皮散板",
          "text": "背柴草到街头去把粮换，"
        },
        {
          "character": "晋灵公",
          "type": "西皮散板",
          "text": "这一弹定打中背草的老年。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老头儿！"
        },
        {
          "character": "老汉甲",
          "type": "白",
          "text": "哪一个？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老汉甲回头看。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "看弹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公打中，老汉甲倒下，众百姓同上扶老汉甲。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "卿家快来试弹！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "好！打打打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾连打。〖牌子〗。众百姓同逃下。屠岸贾笑。"
        },
        {
          "character": "晋灵公",
          "type": "西皮散板",
          "text": "众百姓好一似飞鸟落网，"
        },
        {
          "character": "屠岸贾",
          "type": "西皮散板",
          "text": "打得他头破血流叫爹娘。"
        },
        {
          "character": "晋灵公",
          "type": "西皮散板",
          "text": "见他们男和女乱碰乱撞，"
        },
        {
          "character": "屠岸贾",
          "type": "西皮散板",
          "text": "好一似深山中迷途羔羊。"
        },
        {
          "character": "晋灵公",
          "type": "西皮散板",
          "text": "叫内侍快献上御羹熊掌，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "御羹熊掌伺候！"
        },
        {
          "character": "膳夫",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "膳夫上。"
        },
        {
          "character": "膳夫",
          "type": "西皮散板",
          "text": "忙将御羹献大王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "膳夫跪献，犬一扑，膳夫惊，将羹打翻在地。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "唗！好个膳夫，寡人腹中饥饿，竟将御羹洒落尘埃。 殿前武士，将膳夫推出斩了！"
        },
        {
          "character": "膳夫",
          "type": "白",
          "text": "哎呀大王啊！小臣被獒犬撞倒尘埃，并非有意。望大王饶命吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "膳夫哭。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "啊大王，看他哭得可怜，就赏他个全尸吧！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "好！就与他留个全尸。 獒奴！将灵赘锁链打开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "獒奴打锁。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "灵獒啊灵獒，想是你也饿了，去咬那穿蓝袍的官儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "獒奴示意，犬扑向膳夫追咬，搜场，膳夫死。屠岸贾笑。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "内侍，将膳夫尸首装在竹笼里面，抬至郊外掩埋去吧！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士抬膳夫同下。〖水底鱼〗。太监捧数本上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启奏大王：众位大人有本呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公看。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "这是士会、韩厥、赵相国的本章，真真的讨厌。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "他等多管闲事，大王休要理他。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "内侍，吩咐在画阁楼摆宴。卿家随孤来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公、屠岸贾同笑，众人同下。"
        },
        {
          "character": "晋灵公",
          "type": "stage",
          "text": "【第二场：闭宫胆谏】"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "好昏王啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乱锤。众百姓同上。"
        },
        {
          "character": "百姓甲",
          "type": "西皮摇板",
          "text": "晋侯做事太凶狠， 弹打无辜众黎民。 怒气满胸难消恨，"
        },
        {
          "character": "提弥明",
          "type": "内白",
          "text": "列位闪道，相国来也！"
        },
        {
          "character": "百姓甲",
          "type": "西皮摇板",
          "text": "见了相国诉冤情。"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "我们在此等候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "撞金钟。提弥明推车、赵盾坐车同上。"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "幞头冠整将朝衣， 五云深处奏丹墀。 军民为念忧国事，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同跪。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "相国快与我们作主吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同哭，赵盾下车扶众百姓起。"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "父老为何泪悲啼？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "列位因何这等模样？"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "大王信宠屠岸贾，在绛霄楼上打弹伤人，只打得我们耳目带伤，头破血流，可 怜乡亲们俱不敢在桃园门前经过，务农的不敢到田间种地，为商的不敢到街头 做买卖。求相国与我们大家作主吧！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "众位父老，大王信宠屠岸贾这样胡为，皆是老夫不能谏君之过，才连累大家受 此痛楚。万望你们各自回去，好好调治伤痕，要勤俭务农，经营商贾，千万不 可荒废。待老夫即刻进宫谏君，使大王悔过自新，改恶从善，谢罪军民就是！"
        },
        {
          "character": "众百姓",
          "type": "白",
          "text": "多谢相国，我们大家回去了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同下。"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "街头巷尾民磋怨， 都道大王信谗奸。 日久恐要激成大变，"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "速速上朝！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾上车走圆场。士会、韩厥同上。"
        },
        {
          "character": "士会、韩厥",
          "type": "同白",
          "text": "相国！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "两位大夫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾下车。"
        },
        {
          "character": "士会、韩厥",
          "type": "西皮摇板",
          "text": "拜见相国问金安。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "啊二位大夫，大王数月未曾设朝理事，满朝文武屡谏不听，请问二位大夫何计 教我？"
        },
        {
          "character": "士会",
          "type": "白",
          "text": "大王信宠屠岸贾，在绛霄楼上朝欢暮乐，荒度岁月，不理朝事。相国就该率领 文武力谏事非，使大王痛改前非，如若不然，恐怕晋国危矣！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "老夫也曾多次上本力谏，只是大王忠言逆耳，如之奈何？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "此乃屠贼撺掇大王作此祸国殃民之事，屠贼不除，我晋国无有太平之日了！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "嗐！如今百姓怨声载道，国家危亡就在旦夕，我们就此进宫力谏，若能贬了屠 岸贾，封锁桃园，乃是我晋国之幸也！"
        },
        {
          "character": "士会、韩厥",
          "type": "同白",
          "text": "我二人愿随相国进宫力谏。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "如此二位大人请了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "五锤。"
        },
        {
          "character": "赵盾",
          "type": "念",
          "text": "走过金阶御路，便是生死禁门。"
        },
        {
          "character": "士会",
          "type": "念",
          "text": "秉公为国除奸，是非直言无隐。"
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "但愿改恶从善，今后悔过自新。"
        },
        {
          "character": "赵盾",
          "type": "念",
          "text": "当念民为邦本，"
        },
        {
          "character": "大太监",
          "type": "内白",
          "text": "武士们抬着走啊！"
        },
        {
          "character": "赵盾",
          "type": "念",
          "text": "那旁有磋跄之声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾看。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "闪躲一旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。四武士抬竹笼同上，大太监上。士会、韩厥同指，赵盾会意。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "侍臣转来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监领回。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "原来是相国与二位大夫。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "我来问你，这竹笼里面所置何物？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "这个……此乃大王旨意，小臣不敢言讲，相国要看，请您自己打开一看，您就 明白了。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "你等打开竹笼，大王降罪有老夫担当。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "既有相国担当，待我打开。相国请看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾、士会、韩厥同看，同惊。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "这、这具死尸是哪里来的？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "小臣不敢言讲。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "嗯！深宫之中，出此人命之事还敢隐瞒，实言告我便罢，如若不然，先斩汝头！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "如此相国听禀。"
        },
        {
          "character": "大太监",
          "type": "江儿水",
          "text": "一碗熊羹灵獒餐， 膳夫被啮丧黄泉。 尸体藏在竹笼内， 禁止宫中莫外喧。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "抬出掩埋去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士、大太监抬竹笼同下。"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "可怜无辜死得惨， 轻视人命如草菅。 国家安危在一旦，"
        },
        {
          "character": "士会、韩厥",
          "type": "同西皮摇板",
          "text": "定是那屠岸贾献媚进谗。"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "外忧未定内生患， 权奸不除国不安。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "一同进宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾、士会、韩厥同走圆场。扭丝。"
        },
        {
          "character": "士会、韩厥",
          "type": "同白",
          "text": "相国！"
        },
        {
          "character": "士会、韩厥",
          "type": "同西皮摇板",
          "text": "大王阻谏把宫门掩，"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "立求面奏叩宫环。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "待我叩环。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥叩环。"
        },
        {
          "character": "太监",
          "type": "内白",
          "text": "何人叩环？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "赵相国带领士会、韩厥进宫有本启奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "大王有旨，文武百官如有本章均由赵相国一人代理，一概免参免见哪！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "老夫审查本章已毕，要进宫面奏，快去通禀。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "如此相国候旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "闭宫阻谏，定是屠贼的奸谋使臣不能见君，君不能见本，他好从中专权，难道 从此就无有见面之日了么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "赵相国听旨，大王御体欠安，一切朝政委托相国代理，不必进宫面奏。回府去 吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "可恼啊！可恼！"
        },
        {
          "character": "士会",
          "type": "白",
          "text": "罢了啊！罢了！"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "这才是君昏臣心窘， 贪娱阻谏闭深宫。 一片丹心终何用，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "士会、韩厥同下。"
        },
        {
          "character": "赵盾",
          "type": "西皮摇板",
          "text": "闭桃园挡圣驾力谏灵公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾浪子头，下。"
        },
        {
          "character": "赵盾",
          "type": "stage",
          "text": "【第三场：挡驾谏本】"
        },
        {
          "character": "晋灵公",
          "type": "内西皮导板",
          "text": "夏日长艳阳天百花争艳，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。众武士、大太监、屠岸贾、晋灵公同上。"
        },
        {
          "character": "晋灵公",
          "type": "西皮原板",
          "text": "绛霄楼饮琼浆观览市廛。 听笙歌赏午曲百遍不厌， 理朝事整江山好不耐烦。 到桃园与嫔妃大摆筵宴，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二武士同迎上。"
        },
        {
          "character": "二武士",
          "type": "同白",
          "text": "迎接大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公见门。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "晋灵公",
          "type": "西皮原板",
          "text": "桃园门紧关闭所为哪般？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "武士的，寡人游逛桃园，何人大胆紧闭园门？"
        },
        {
          "character": "二武士",
          "type": "同白",
          "text": "赵相国有命将桃园门关闭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公看屠岸贾。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "这个老厌物又来多事，还是不见他的好。 内侍，摆驾回宫。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "且慢！启奏大王：自古以来，只有臣让君，哪有君让臣之理？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "他见了寡人总是絮絮叨叨说长道短，叫孤好不耐烦！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "大王今日若不进桃园，难道从此将桃园让与相国不成？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "岂有此理！待寡人问个明白。 内侍，传赵相国，就说孤王到了！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "大王有旨：宣赵相国见驾呀！"
        },
        {
          "character": "提弥明",
          "type": "内白",
          "text": "启相国：大王驾到！"
        },
        {
          "character": "赵盾",
          "type": "内西皮导板",
          "text": "秉圭当胸幞头冠整，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾上，提弥明随上。"
        },
        {
          "character": "赵盾",
          "type": "西皮原板",
          "text": "启园门谏圣主拼死捐生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。提弥明开门，赵盾见晋灵公拜。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "相国平身！"
        },
        {
          "character": "赵盾",
          "type": "西皮原板",
          "text": "几道表章未见恩准，"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老卿家拿管朝政，何必寡人恩准？"
        },
        {
          "character": "赵盾",
          "type": "西皮原板",
          "text": "圣驾离朝事何因、有什么军情？"
        },
        {
          "character": "晋灵公",
          "type": "西皮原板",
          "text": "寡人宫中心烦闷，"
        },
        {
          "character": "屠岸贾",
          "type": "西皮原板",
          "text": "绛霄楼上饮杯巡。"
        },
        {
          "character": "赵盾",
          "type": "西皮原板",
          "text": "惶恐顿首——"
        },
        {
          "character": "赵盾",
          "type": "西皮流水板",
          "text": "臣告秉， 谏奏主上是非要辨清。 有道之君民乐于天下， 无道之君以乐己身。 曲直力谏臣节之本， 舜造漆器谏者有十人。 小事不谏成大事， 望祈主上悔过自新。 休听那撺掇佞臣巧言论， 就请御驾转回朝门。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "寡人驾游桃园乃寻常之事，相国何必阻拦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公欲进园，赵盾拦。"
        },
        {
          "character": "赵盾",
          "type": "西皮流水板",
          "text": "绛霄楼上宠奸佞， 不该弹打无辜之人。 任意宫中草菅人命， 民为邦本本固邦宁。 为臣我怎比夏桀、伊尹？ 臣赵盾怎比商汤萁子、微子，老比干在那鹿台上剑剖心。 万望圣上近贤远佞， 雨顺风调享太平。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "臣启大王：我朝只有贤臣，哪里来的佞臣，真乃一派罔奏！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "赵盾",
          "type": "西皮流水板",
          "text": "屠岸贾谗言乱朝政， 我与你分个谁是清来谁是浑。 你要把晋国来吞并， 以酒为池肉为林。 有朝马死黄金尽， 万剐凌迟是佞臣。 今朝不报来日报， 远在儿孙近在身，你要仔细思忖！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "建造桃园乃是寡人旨意，老卿家不要诬赖好人……"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "大王啊！"
        },
        {
          "character": "赵盾",
          "type": "西皮流水板",
          "text": "非是臣弄舌抗君命， 只为奸贼他玩法欺君。 外邦俱道我国德政， 国家危亡俱在他一个人。 伏望圣上纳臣谏本， 臣纵埋沟渠死犹生。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老卿家，太也唠叨了！"
        },
        {
          "character": "晋灵公",
          "type": "唱",
          "text": "何用你絮叨叨长篇大论，"
        },
        {
          "character": "屠岸贾",
          "type": "唱",
          "text": "抗君命就该问斩刑！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "赵盾",
          "type": "西皮散板",
          "text": "急水滩头难流月， 钢刀不杀无罪的人。 竟敢与我来厮挺，"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "你敢怎样？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "晋灵公",
          "type": "西皮散板",
          "text": "欺压他如同轻慢寡人。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老相国，屠卿家忠心于寡人，况且他有功无过，何必与他作对！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "臣要理治君子，法度小人，这奸贼不除，实为国家之患！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "大王，他这样辱骂为臣，真真欺人太甚！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "是啊！老卿家，你再若如此，寡人要生气了！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "臣遵旨！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "寡人还要游逛桃园，你快快闪道！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "臣还有本奏。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "哎！这桃园以外不是议论国家大事的所在，有本明日进宫再议。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "为臣也曾三次进宫，但是大王掩闭宫门……"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "好了！好了！寡人这一次绝不食言就是。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "为臣实为国家之计，既然如此，明日为臣进宫商议国家大事，臣别驾了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾对屠岸贾。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "撺掇献媚的小人，提防尔的陆阳魁首！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾上车下。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "老儿不死实为贼！"
        },
        {
          "character": "屠岸贾",
          "type": "唱",
          "text": "这老儿若不死实为后患，"
        },
        {
          "character": "晋灵公",
          "type": "唱",
          "text": "思一计灭赵盾好保桃园。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "卿家，那赵盾老儿若是不除，这桃园恐怕难保！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "大王要除赵盾，臣倒有一计献上。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "卿家有何妙计？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "为臣府中有一勇士，名叫鉏麂，此人膂力过人，颇有胆量，命他今晚夜入相府， 刺杀赵盾，大王意下如何？"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "好，卿家命他前去，将赵盾杀死，寡人重重有赏！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "晋灵公",
          "type": "念",
          "text": "不施万丈深潭计，"
        },
        {
          "character": "屠岸贾",
          "type": "念",
          "text": "怎得骊龙颌下珠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公、屠岸贾同下。"
        },
        {
          "character": "屠岸贾",
          "type": "stage",
          "text": "【第四场：鉏麂行刺】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。程婴持灯上。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "有请相国。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "提弥明、赵盾同上。〖起初更鼓〗。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "今日在桃园挡驾谏本，大王坦护屠贼，不纳忠言，命我明日进宫商议国政。看， 初更已过，待老夫修好本章，准备进宫中申奏。 程婴！溶墨何候！"
        },
        {
          "character": "赵盾",
          "type": "调角儿",
          "text": "臣赵盾惶恐顿首百拜， 启奏圣主晋侯： 臣执政誓除奸尤， 效圣贤汤尧德厚。 窃闻之仁德布、四海靖、霸诸侯、安天下， 五谷丰收。 主勿效周幽烽火戏诸侯。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "程婴，周幽王烽火戏诸侯而失天下，大王今在绛霄楼上打弹伤人，朝欢暮乐， 唯恐蹈前朝复辙，老夫以此谏奏，你看如何？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "相国直言谏奏，真乃社稷之臣！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "咳，朝事不明，谗臣当道。老夫今已年迈，我赵家只有赵穿、赵朔，他兄弟二 人虽是文武兼全，但是刚柔不能相济。我看你虽然年幼，素性诚实，日后还望 你在他弟兄面前多加指点才好。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "启相国：程婴年幼，才疏学浅，怎比二位少公子文式兼全，日后相国如有用我 之处，程婴赴汤投火万死不辞！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "如此老夫放心了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "赵盾",
          "type": "调角儿",
          "text": "鼓咚咚更深夜静， 文武朝臣待漏。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "提弥明，今夜我要早到朝房，等候大王宣召，二更己过，命你府外备车，四更 时分我就要上朝。"
        },
        {
          "character": "提弥明",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "五锤。提弥明开门，下。鉏麂上，看。"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "哎呀妙啊！是俺正在为难，不能进府，忽然见一大汉，将府门开放，此乃是天 助俺成功也。看院内有棵槐树，待我悄悄进去，隐住身影见机行事便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "五锤。鉏麂隐。扭丝。赵朔上。"
        },
        {
          "character": "赵朔",
          "type": "二黄散板",
          "text": "老爹爹为国事深夜不倦， 年迈人怎经得秋末风寒。"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "啊爹爹，二更已过尚未安眠，莫非朝中有为难之事不成？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "国家安危就在旦夕，难道我儿你还不知么？"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "孩儿一一尽知，皆是屠岸贾奸贼之过，爹爹天明上朝，孩儿有意随爹爹进宫一 同力谏，不知爹爹意下如何？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "这倒不用，但有一事，我儿须要留心在意。"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "爹爹有何吩咐？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "那屠岸贾心怀叵测，近闻他招纳亡命之徒，图谋不轨，儿要查其动静以防不测。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵朔允。〖起三更鼓〗。"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "三更已过，夜已深了，请爹爹安歇片刻。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "咳！儿啊！"
        },
        {
          "character": "赵盾",
          "type": "二黄原板",
          "text": "朝臣待漏五更寒， 铁甲将军夜渡关。 我朝中出了屠贼奸患， 民不聊生历日艰难。 为父的报国心青天可鉴， 昼夜忧思睡不成眠，哪顾得辛劳饥寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "相国可要用茶？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "好，打茶来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "赵盾",
          "type": "二黄原板",
          "text": "那程婴性忠义颇有远见， 儿与他多亲近同苦共甘。 国与家儿必须时刻防患，"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "儿要记下了。"
        },
        {
          "character": "赵盾",
          "type": "二黄原板",
          "text": "为父的言语谨记心间。"
        },
        {
          "character": "赵朔",
          "type": "二黄原板",
          "text": "孩儿我遵父命怎敢怠慢，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵朔自上场门下。"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "我今错矣了！"
        },
        {
          "character": "鉏麂",
          "type": "二黄原板",
          "text": "见此情好叫我犹豫不安。 莫非是屠大人将我来骗， 俺鉏麂到如今进退两难， 且不可妄杀人急忙回转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鉏麂欲走。"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "鉏麂",
          "type": "二黄原板",
          "text": "既到此我怎能空手而还？ 受人托休得要中途改变， 到此时覆水难收箭已上弦。"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "鉏麂",
          "type": "二黄原板",
          "text": "赵相国你一死休把我怨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "五锤。鉏麂砍。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾盯鉏麂，逼视，鉏麂退。撞金钟，凤点头。鉏麂惊，悔，撇刀，搭躬。"
        },
        {
          "character": "赵盾",
          "type": "二黄原板",
          "text": "见刺客撇刀搭躬面带羞惭。 这一壮士你叫什么名字？"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "俺叫鉏麂。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "老夫与你有何仇恨？"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "无仇无恨。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "既无仇无恨，为何刺杀老失？噢是了，莫非受旁人唆使？"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾厉声。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "我听说相国你是个误国殃民之臣，因此前来杀你！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "哎！我赵家三世任晋，股肱之臣，未敢有负国恩，怎见得是误国殃民？我看壮 士相貌堂堂，定是个直性的汉子。今被人唆使，不察真伪，黑夜之间，闯进相 府，行此不义之事，岂是丈夫所为！幸而堂上无人，若有侍尉在此只要老夫一 声令下，壮士你命休矣！无仇无恨，不忍杀你，壮士你决快出府去吧！"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "赵相国，你果然是忠义之臣，我对你实说了吧！俺奉屠岸贾所差，前来行刺， 今见相国乃是个为国为民的忠臣，俺不忍下手，可恨屠岸贾他借刀杀人，却将 俺于不仁不义之中，俱怪俺当初做事不明，错投奸臣门下，以至今日从奸杀忠， 身败名裂，罪当万死！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "原来壮士为屠贼所骗，幸而未成大误，常言道不知者不怪罪，壮士何不就在我 府听差，老夫自有用你之处你意下如何？"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "相国啊！今蒙不杀，感恩不尽。我想大丈夫做事要光明磊落，岂能苟且偷生。 那屠岸贾待俺倒有些薄恩小惠，如今想来却是他行奸弄巧，刁买人心，利用俺 杀害忠良陷俺于不义之中。有道是，正义天下去得，无理寸步难行。俺鉏麂愧 无脸面立于人世，俺就自刎了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾拦，鉏麂抛刀看树。"
        },
        {
          "character": "鉏麂",
          "type": "白",
          "text": "待俺触槐一死了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾拉鉏麂，鉏麂推赵盾，碰树。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "哎呀不好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冲头。赵穿、赵朔、程婴、提弥明同上。"
        },
        {
          "character": "赵穿、赵朔、程婴、提弥明",
          "type": "同白",
          "text": "怎么样了？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "儿来看！刺客触槐一死！"
        },
        {
          "character": "赵穿、赵朔、程婴、提弥明",
          "type": "同白",
          "text": "大大便宜了此贼！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "儿啊！此人名叫鉏麂，被屠岸贾所骗，前来行刺。他见我是个忠良，不忍下手， 自知把事做错，故而触傀一死，真乃是视死如归的大英雄！"
        },
        {
          "character": "赵盾",
          "type": "二黄散板",
          "text": "不甘屈辱刚强汉， 自知己过恨前言愆。 我本当留他作证见， 谁知他触槐死，死得可怜。 尔等快把尸体掩，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "提弥明！"
        },
        {
          "character": "赵盾",
          "type": "二黄散板",
          "text": "急忙驾车进朝班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵穿捧剑，程婴呈本，赵朔交圭，提弥明推车，赵盾上车下。"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "兄长，爹爹上朝恐有不测，你我带领家将，在午门探听消息，你着如何？"
        },
        {
          "character": "赵穿",
          "type": "白",
          "text": "就依贤弟，一同前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "赵穿",
          "type": "stage",
          "text": "【第五场：施计闹朝】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扭丝。屠岸贾上。"
        },
        {
          "character": "屠岸贾",
          "type": "唱",
          "text": "只说一计杀赵盾， 谁想鉏麂丧残生。 急忙进宫报一信，"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "有请大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公、大太监同上。"
        },
        {
          "character": "晋灵公",
          "type": "唱",
          "text": "问声卿家事可成？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "臣启大王：鉏麂行刺未成，碰头已死，如今大事泄漏，你我君臣危在旦夕了！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "少时赵盾前来提及此事，叫寡人拿何言答对？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "他若进宫，大王千万不可放他回去。若是放他出宫，如同放虎归山势必伤人！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "用何妙计将赵盾置于死地？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "那赵盾若问行刺之事，大王就说无有人证难辨真假，然后借他宝剑以作防身之 用，他若献剑，那时节为臣呐喊“赵盾刺王杀驾”，大王急唤武士将他杀死， 以绝后患！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "徜若赵盾不献宝剑如何是好？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "他若不献，岂不有抗旨不遵之罪，就放出灵獒将他咬死！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "好，武士们进宫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众武士同上。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "命你等埋伏宫外，等赵盾进宫，听孤旨意，不得有误！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众武士同允，同下。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "将灵獒牵进宫来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "獒奴、犬同上。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "将锁链打开，藏在龙书案下。"
        },
        {
          "character": "提弥明",
          "type": "内白",
          "text": "赵相国宫外候旨。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "赵相国宫外候旨。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "宣他进宫。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "赵相国进宫。"
        },
        {
          "character": "赵盾",
          "type": "内白",
          "text": "臣，遵旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾上，提弥明随上。"
        },
        {
          "character": "赵盾",
          "type": "念",
          "text": "久未理朝政，今朝辨是非。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "臣，赵盾见驾，大王千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾跪。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老卿家平身，赐坐。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "谢大王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾坐。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "臣启大王：士会，韩厥与为臣俱有本章，大王御览。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "晋灵公看。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "卿等所奏俱合孤意，只是修建绛霄楼，寡人费尽心血，用了许多金银。一旦废 弃，岂不可惜！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "大王若不禁闭绛霄楼，封锁桃园，何以谢罪军民，倘若激成大变，实非大王之 福。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "如此就依卿所奏，寡人痛改前非也就是了。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "人非圣贤，孰能无过，知过必改，乃是圣君。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老卿家真乃社稷之臣也！"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "臣启大王：昨夜臣府，有一刺客，刺杀为臣，是他言道乃是奉了屠岸贾之所差， 我朝竟有这样的奸臣，请大王依法除之！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "启奏大王：为臣昨夜在官中与大王一处著棋，怎能派人前去行刺！此乃相国有 意与为臣作对，他是血口喷人！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老卿家，刺客可曾拿住？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "刺客自知被人欺骗，已然碰头身亡了！"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "刺客已死无有对证，难辨真假。待等查明，再咎其罪。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "望大王明查。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "老卿家，既是刺客行刺，因何不用宝剑诛之，为何任他碰头一死？"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "为臣宝剑虽利，不杀无辜之人。"
        },
        {
          "character": "晋灵公",
          "type": "白",
          "text": "是呀，寡人久闻卿家之剑乃是切金断玉之宝，呈上来待孤瞻仰瞻仰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "提弥明会意。"
        },
        {
          "character": "赵盾",
          "type": "白",
          "text": "此剑不过寻常之物，有何为奇，待臣摘下。"
        },
        {
          "character": "提弥明",
          "type": "白",
          "text": "且慢！君前献剑，有失臣节，相国你！失计了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵盾将剑交提弥明。"
        },
        {
