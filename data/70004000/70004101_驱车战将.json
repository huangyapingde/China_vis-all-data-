{
  "script_id": "70004101",
  "title": "驱车战将",
  "alias": [],
  "source": "唐韵笙剧本选",
  "characters": [
    {
      "name": "南宫长万",
      "hangdang": "武生，搓红脸，头戴改良黑绒“二伯温”，口戴黑五绺，足穿黑靴；第一场穿红蟒；第二场以后"
    },
    {
      "name": "穿黑绒改良靠，上镶亮泡，护心镜，执双头长戟；第十四场执枪",
      "hangdang": "未知"
    }
  ],
  "plot": "宋闵公命大将南宫长万助齐攻鲁，南宫长万为鲁军所擒，被释回国。宋闵公对南宫长万不满，屡加讥讽，南\n宫长万怒，酒后杀宋闵公。公子御说逃奔鲁国，请兵诛南宫长万。鲁庄公领兵至宋，诈开宋城追杀南宫长万。\n南宫长万一手持戟，一手推辇，护母逃往陈国。鲁军截杀，箭射其母，南宫长万突围而去。",
  "notes": "此剧根据历史小说《东周列国志》第十七回编写。一九二七年创作，首演于哈尔滨。武生应工。全剧共十四\n场，是先父（唐韵笙）早年编写的第一个列国戏。二十世纪三十年代曾由曹艺斌、高雪樵、周林昆、郑玉廷、\n张铁华、李春元、黄云鹏等演员传演于东北、津、沪各地，成为武生演员经常上演的剧目。一九四七年在\n上海演出时，第十四场情节有所改动，一九六零年先父对全剧作了修订。\n一九四七年在上海演出时曾改为大扮、穿大靠，用双戟，“弑君”一场着重于表演，“见母”一场有大段的\n西皮流水唱腔，“战将突围”一场创造了联弹中的开打。先父塑造的南宫长万具有威重、勇猛、耿直的特点，\n虽是武生应工，却具有花脸的气度，是一出具有唱念做打全面技能的武生戏。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "【第一场：奉旨伐鲁】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧、华督、御说、南宫牛同上。〖点绛唇〗。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "上大夫仇牧。"
        },
        {
          "character": "华督",
          "type": "白",
          "text": "太宰华督。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "公子御说。"
        },
        {
          "character": "南宫牛",
          "type": "白",
          "text": "护殿将南宫牛。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "华督、御说、南宫牛",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "主公升殿，你我两厢伺候了。"
        },
        {
          "character": "华督、御说、南宫牛",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧、华督、御说、南宫牛自两边分下。四太监、宋闵公同上。"
        },
        {
          "character": "宋闵公",
          "type": "引子",
          "text": "巍巍宫殿，自在安然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧、华督、御说、南宫牛同上，同见驾。"
        },
        {
          "character": "宋闵公",
          "type": "念",
          "text": "乾坤浩荡日月明，列国强弱起伐争。周室何能安天下，到处狼烟不太平。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "孤，宋闵公。自先王晏驾，众卿保孤为君，我国倒也强盛。今日早朝，众卿有 本早奏，无本退班。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "启奏主公：今有齐桓公差人前来下书，请主公观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧呈书。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "待孤一观。 众卿，齐桓公兴兵伐鲁，欲雪长勺之恨，要孤出兵相助，众卿意下如何？"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "启主公：齐桓公与我国交好甚厚，今日前来求助焉有不救之理。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "依卿所奏，何人挂帅前往？"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "南宫长万有万夫不挡之勇，何不命他前去助战？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "就依卿家，宣南宫长万上殿。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "主公有旨：南宫长万上殿。"
        },
        {
          "character": "南宫长万",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万上。"
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "杀气贯虹霓，寒光照铁衣。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "臣，南宫长万见驾，主公子岁！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万归班。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "宣臣上殿有何国事议论？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "齐桓公兴兵伐鲁，要孤出兵相助，就命卿家代领甲车五百乘，前去助阵，你子 南宫牛为前战先锋，卿意如何？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "区区鲁国，弹丸之地，何用重兵相助，赐臣甲车二百乘，一战成功。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "就依卿家，得胜回来，孤家设宴庆贺，另有升赏。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        },
        {
          "character": "宋闵公",
          "type": "stage",
          "text": "【第二场：鲁国出迎】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子偃、颛孙生同上，双起霸。"
        },
        {
          "character": "公子偃",
          "type": "念",
          "text": "紫金盔齐眉盖顶，鱼鳞甲遮体护身。"
        },
        {
          "character": "颛孙生",
          "type": "念",
          "text": "展旌旗英雄临阵，持银枪神鬼皆惊！"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "俺，公子偃。"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "颛孙生。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "将军请了！"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "主公升帐，你我两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子偃、颛孙生同下。四军士、二将、鲁庄公同上。"
        },
        {
          "character": "鲁庄公",
          "type": "点绛唇",
          "text": "经武整军，秣马厉兵，士气振，壮志凌云，哪怕强敌侵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁庄公归大座，公子偃、颛孙生同上，同见。"
        },
        {
          "character": "鲁庄公",
          "type": "念",
          "text": "可恨齐国屡犯境，恃强欺弱害众生。多行仁义民心顺，举国一致扫烟尘！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "孤，鲁庄公。可恨齐国妄自尊大，以强凌弱，是孤统领人马长勺一战大败齐桓 公。 众位将军，齐国倘若再次兴兵，尔等有何良谋破敌？"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "主公但放宽心，长勺一战齐国损兵折将，未必再敢轻举妄动。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "恐难预料也。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "宋国南宫长万，带领甲车与齐国助战攻打我国来了！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "且住！探马报道，宋国发兵与齐国助战，想那南宫长万有万夫不挡之勇，我军 与他交战胜负也未可量也！"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "某将倒有一计：主公赐臣一哨人马，个个身披虎豹之皮，黑夜之间冲进阵去， 那宋军不战自乱，那时长万可擒也！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "就依将军，众将带马迎敌者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "鲁庄公",
          "type": "stage",
          "text": "【第三场：出征会战】"
        },
        {
          "character": "南宫长万",
          "type": "内唱",
          "text": "气吐虹霓马咆哮，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将士、南宫牛、南宫长万同上。"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "儿郎斜挎斩将刀。 日照金盔龙斗宝， 风吹连环锁甲绦。 大丈夫赤胆忠心把国保， 驱车争战某要立功劳。 队队儿郎你们抖擞威风把阵讨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、颛孙生、鲁庄公同上，碰头。"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "谁胜谁败论论英豪。"
        },
        {
          "character": "鲁庄公",
          "type": "西皮摇板",
          "text": "孤家领兵兴天道， 通上名来把兵交。"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "南宫长万谁不晓，"
        },
        {
          "character": "鲁庄公",
          "type": "西皮摇板",
          "text": "无名匹夫小儿曹。"
        },
        {
          "character": "南宫长万",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "摇唇鼓舌真可笑， 你们似羊群入虎口——"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "你往哪里逃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同会阵，开打，鲁庄公败下，南宫长万追下。"
        },
        {
          "character": "南宫长万",
          "type": "stage",
          "text": "【第四场：中箭被擒】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将士扮虎形、公子偃同上。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "埋伏了。 （四将士、公子偃同虚下。鲁庄公，上，过场，败下。南宫长万、南宫牛、四将士同上，遇虎形，南宫牛、 四将土同惊下，公子偃追下。）"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "且住，鲁国人马假扮虎豹之形，我国人马不战而乱，今日必须决一死战方可取 胜。 众甲兵，听我一令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万边念边舞。"
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "何惧虎豹勇，阵前立大功。鞭敲金蹬响，回国受赏封。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将土、南宫长万同下。鲁庄公趟马上。"
        },
        {
          "character": "鲁庄公",
          "type": "西皮摇板",
          "text": "南宫长万真饶勇， 可算将中一英雄。 来到军前观动静，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁庄公下马，登高台。"
        },
        {
          "character": "鲁庄公",
          "type": "西皮摇板",
          "text": "等他到来放雕翎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万败上，公子偃、颛孙生同追上，开打。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万中箭，被擒，众人同下。"
        },
        {
          "character": "鲁庄公",
          "type": "stage",
          "text": "【第五场：获释】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军土、鲁庄公同上。颛孙生、公子偃同上。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "启主公：南宫长万被擒。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "押了上来。"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "将南宫长万押了上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手押南宫长万同上。"
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "英雄至死如梦，羞惭天地可容。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "南宫长万，你今披擒，还不降顺孤家。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "某至死不降！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "真乃英雄也，待孤亲自与你松绑。将军请回国去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万出帐，复进帐。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "将军回来作甚？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "鲁侯待某如此恩厚，长万无地自容，待某回国，奏知我国主公，两国结为盟好， 永罢干戈，鲁侯意下如何？"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "但凭将军。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "待某将立字为凭。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "且慢，将军右肩带伤焉能提笔。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "区区箭伤，何足道哉。上写：宋国长万兵败啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "主公请看。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "多谢将军美意，你我后会有期，请回国去吧。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "谢鲁侯。正是："
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "颠覆兵山损车甲，从前英名枉自夸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万下。"
        },
        {
          "character": "公子偃",
          "type": "白",
          "text": "主公为何将南宫长万放回国去？"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "放他回去，宋国感之免动刀枪，也好兵抗强齐也。"
        },
        {
          "character": "颛孙生、公子偃",
          "type": "同白",
          "text": "主公高见，臣等皆服。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "打起得胜鼓，班师还朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "鲁庄公",
          "type": "stage",
          "text": "【第六场：遭辱】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、仇牧、宋闵公同上。"
        },
        {
          "character": "宋闵公",
          "type": "唱",
          "text": "命长万领甲车狼烟扫荡， 但愿得此一去平灭鲁邦。 得胜归一定要加官封赏，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "御说上。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "启奏主公：南官长万被鲁国打得折兵败将围困营中！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "想那南宫长万在孤面前夸下海口，必能取胜，他今日一败，宋国威名付于流水。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫牛、南宫长万同上。"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "鲁庄公他待我恩高义厚， 回国来见宋君满面含羞。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "平身。哎呀将军哪，你此番征战鲁国，必然是大获全胜，令人可敬，令人佩服！ 来，看酒伺候。来来来，待孤家敬你、攻无不取战无不胜、百战百胜的大将 军三杯酒。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "主公尚未知晓为臣兵败么？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "大将军说哪里话来，临行之时，夸下海口，焉能战败而归，莫要推托，快快饮 下这杯得胜酒。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "主公莫要羞辱为臣。实指望统领甲车，扫灭狼烟，以报主公之恩，不想鲁国人 马身披虎豹之皮，深夜闯入，我军不战自乱，损车败将，为臣孤身冲入敌军之 内，不料鲁庄公暗放一箭，正中为臣右肩之上，左腿又中一枪，因此被擒，鲁 庄公为了两国合好，放臣回国，实无脸来见主公，臣当——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一击。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "万死！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "听你之言，你战败了？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "为臣战败了。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "嘿！得胜酒我替你喝了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋闵公喝。冲头。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "长万，你右膀中箭是你的箭法不好，左腿中枪是你的枪法不高！被囚鲁国有何 面目来见孤家，无耻囚徒下殿去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫牛怒，南宫长万羞愧，拦。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "谢主公。"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "拜别主公下殿往！ 一场羞辱愧难当。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫牛、南宫长万同下。"
        },
        {
          "character": "仇牧",
          "type": "唱",
          "text": "长万本是英雄将， 主公莫要把他伤。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "臣启主公：军家胜败乃是常理，主公这样羞辱于他，恐怕后来不服。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "孤不过是几句戏言，灭灭他的火性，以免后来在孤家面前夸口。卿家去宣长万， 明日随孤郊外射猎以试其心。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        },
        {
          "character": "仇牧",
          "type": "stage",
          "text": "【第七场：见母】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫母上。"
        },
        {
          "character": "南宫母",
          "type": "西皮原板",
          "text": "叹周室历年间臣心失散， 论强弱动刀兵黎民倒悬。 我的儿征鲁邦未见回转， 倒叫我坐不安睡不成眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、南宫长万同上。"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "败兵归来无颜面， 来到堂前问娘安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万跪拜。"
        },
        {
          "character": "南宫母",
          "type": "唱",
          "text": "用手儿搀起了我儿长万， 只见他眼含泪神色不安。 你把那征战事细说一遍， 也免得年迈人挂在心间。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "娘啊！"
        },
        {
          "character": "南宫长万",
          "type": "西皮慢流水板",
          "text": "儿领兵驱甲车两国来交战， 中了他伏兵计儿败走荒山。 那鲁庄王居高临下暗暗射一箭， 因此上将儿绳索捆绑到营盘。 儿本应在阵前为国殉了难， 思想起老母在堂前无人来守看。 要尽忠舍老娘何人来照管， 为尽孝因此孩儿转回还，尽忠尽孝不能够两双全。 回国来见宋君惭愧无有脸面， 阵阵红云甚是羞惭。 儿的娘啊莫要悲声叹， 为老娘不作官，为民倒也安然。 男儿汉立地天， 自古道父母恩情重如泰山。 双膝跪倒我的心如愿，"
        },
        {
          "character": "南宫长万",
          "type": "西皮散板",
          "text": "从今后奉老娘孝敬天年。"
        },
        {
          "character": "南宫母",
          "type": "唱",
          "text": "我儿阵前受磨难， 今日母子又团圆。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "儿呀，既然阵前中箭，不知你箭伤如何？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "今已痊愈，母亲不必挂心。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "待我谢天谢地。"
        },
        {
          "character": "仇牧",
          "type": "内白",
          "text": "仇大夫到。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "母亲请到二堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫母下。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧上。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "仇大人到此何事？"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "适才主公在金殿之上，只想兵败之辱而怒责将军，莫要挂怀。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "是某将两军阵前兵败而归，不能与国家报效，倒使某愧无脸面矣！"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "军家胜败，古之常理，何必多心。主公不过是几句戏言，莫要伤了君臣大义。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "某将不敢。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "明日主公郊外射猎，命将军保驾前往。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "明日随驾前去射猎也就是了。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "告辞了。"
        },
        {
          "character": "仇牧",
          "type": "西皮摇板",
          "text": "明日射猎到郊外， 君戏臣子莫挂心怀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧下。"
        },
        {
          "character": "南宫长万",
          "type": "西皮摇板",
          "text": "只怪我战敌军大意失败， 美英名成画饼羞煞将才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万下。"
        },
        {
          "character": "南宫长万",
          "type": "stage",
          "text": "【第八场：救驾】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万、华督、仇牧、御说同上。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "二位大人，主公郊外射猎，你我一同伺候。"
        },
        {
          "character": "华督",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、宋闵公同上。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "众卿你等俱已到齐，为何不见长万在此？"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "想必是调动猎兵、安排射猎去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万上。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "鲁国囚徒，因何来迟？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "臣在校场操演猎兵，故而来迟。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "从今以后，你要小心伺候。 来，郊外去者！"
        },
        {
          "character": "南宫长万、华督、仇牧、御说",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。"
        },
        {
          "character": "南宫长万、华督、仇牧、御说",
          "type": "同白",
          "text": "来到郊外。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "围住猎场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同串过下。"
        },
        {
          "character": "宋闵公",
          "type": "唱",
          "text": "下马且把高坡上， 观看众将射虎狼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋闵公上高台。南宫长万趟马。"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "猎游郊外心暗想， 主公出言又把我伤。 耳边听得风声响，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上，南宫长万不敢起弓，下马。虎形上高台抓宋闵公，南宫长万将虎形打死。四太监、四军土同上。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "主公请转，为臣在此。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "吓煞孤也！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "臣已将虎打死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋闵公见虎形，变脸。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "唗！孤家正要生擒猛虎，不想被你打死，你多事！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一击。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "你真真多事！"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "主公，长万打虎救驾，其功非小，就该重赏才是。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "这算什么功劳，不过是一勇之夫！带马回城！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "送主公。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "你多事！ （宋闵公、四太监、四军士、华督、仇牧、御说同下。南宫长万羞愧无地自容。锣经“战场”。南宫长万走 身段。）"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万下。"
        },
        {
          "character": "南宫长万",
          "type": "stage",
          "text": "【第九场：弑君】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、御说、宋闵公同上。"
        },
        {
          "character": "宋闵公",
          "type": "唱",
          "text": "郊外射猎心神爽， 军士个个逞豪强。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "啊主公，昨日长万打死猛虎主公未曾重赏，臣见他面带怒容，莫非他有谋反之 意？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "此事未定真假，待孤宣他进宫，用言语打动于他，看他动静如何。宣南宫长万 进宫，你等退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、御说同下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "主公有旨：南宫长万进宫。"
        },
        {
          "character": "南宫长万",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万上。"
        },
        {
          "character": "南宫长万",
          "type": "念",
          "text": "两道眉锁英雄恨，一片心怀志士忧。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "参见主公！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "平身赐坐。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "谢主公。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "长万，孤见你这几日面带不悦，莫非你怀恨孤家不成？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "为臣焉敢心怀不忿，不过是战败回来心中愧恨，不能与主公出力耳！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "原来如此，今日闲暇无事，待孤与你搏棋一回，哪家败了罚酒三杯。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "就依主公。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "来，棋盘摆下。"
        },
        {
          "character": "宋闵公",
          "type": "二黄原板",
          "text": "君臣们宫中饮洒把棋摆， 论一论高和低各逞英才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋闵公饮酒。"
        },
        {
          "character": "南宫长万",
          "type": "二黄原板",
          "text": "我主公称妙手招数难解， 长万我虽用心也难安排。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "你输了！"
        },
        {
          "character": "南宫长万",
          "type": "二黄原板",
          "text": "不料想失一着臣又战败，"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "你败了！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "臣败了！"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "罚酒三杯！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万饮三杯。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "你多喝点儿罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋闵公执壶灌南宫长万。"
        },
        {
          "character": "南宫长万",
          "type": "二黄原板",
          "text": "醉沉沉身无力难把头抬。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "南宫长万，再与孤家见个胜负！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋闵公、南宫长万同下棋。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "为臣我又战败了。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "怎么，你又输了？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "输了。"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "看将起来，你真是个屡败不胜的囚徒！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "主公，自古君臣不可相戏，屡次辱骂为臣是何道理？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "住了！想你带领人马征讨鲁国吃了败仗，今日对坐下棋，你又打了败仗，你真 真是个屡败不胜的囚徒！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "屡败不胜的囚徒！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "我把你这无道的昏君！"
        },
        {
          "character": "南宫长万",
          "type": "二黄散板",
          "text": "自古君臣无戏耍， 无道昏君做事差。 长万为国功劳大， 囚徒也能把人杀。"
        },
        {
          "character": "宋闵公",
          "type": "二黄散板",
          "text": "长万胆量比天大， 不由弧家怒气发。 手持棋盘将你打，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋闵公持棋盘打南宫长万，南宫长万怒。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "昏君！你要打谁？"
        },
        {
          "character": "宋闵公",
          "type": "白",
          "text": "我要打你这囚徒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万冷笑。"
        },
        {
          "character": "南宫长万",
          "type": "笑",
          "text": "嘿嘿嘿嘿……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万夺棋盘。"
        },
        {
          "character": "南宫长万",
          "type": "二黄散板",
          "text": "无道君竟敢在虎口拔牙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万杀死宋闵公。五锤。南宫长万出门，仇牧上。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "将军为何这样慌张？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "这……何必多问，大人要想何往？"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "进宫与主公问安，"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "那无道的昏君……"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "将军何出此言？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "哎呀大夫哇！昏君屡次出言不逊，失了君臣之道，是某一时怒气难忍，我就将 他……"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "杀死了！"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "哎呀将军你吃醉了！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "大夫不信，随我进宫看来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万、仇牧同进宫。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "仇牧",
          "type": "二黄散板",
          "text": "一见主公丧了命， 逆臣长万忒狠心。"
        },
        {
          "character": "仇牧",
          "type": "白",
          "text": "长万哪！贼子！主公待你不薄，你不该反将主公杀死，豁出我这老命不要，我 与你拼了吧！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "使不得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "仇牧撞死剑上。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "可惜呀！可惜！"
        },
        {
          "character": "南宫长万",
          "type": "二黄散板",
          "text": "只为昏君太猖狂， 连累忠良丧无常。 事到头来难言讲，"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "南宫长万",
          "type": "二黄散板",
          "text": "顺某昌来逆某亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万下。御说上。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "且住！南宫长万手提宝剑出宫而去，定有缘故，待我进宫看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "御说进宫。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "哎呀主公啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "长万啊，贼子！你将主公杀死，我不免投奔鲁国借兵报仇便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "御说下。"
        },
        {
          "character": "御说",
          "type": "stage",
          "text": "【第十场：杀将】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万、南宫牛同上，双进门。"
        },
        {
          "character": "南宫牛",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "我儿速速进宫，将公子御说抓来见我。"
        },
        {
          "character": "南宫牛",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫牛下。华督上。"
        },
        {
          "character": "华督",
          "type": "白",
          "text": "南宫长万！主公待你不薄，你不该将主公杀死，休走看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万夺剑将华督杀死。南宫牛上。"
        },
        {
          "character": "南宫牛",
          "type": "白",
          "text": "公子御说逃走，直奔鲁国而去。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "谅他走至不远，命你带领甲车一二百乘，紧紧追赶！"
        },
        {
          "character": "南宫牛",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万、南宫牛自两边分下。"
        },
        {
          "character": "南宫牛",
          "type": "stage",
          "text": "【第十一场：伐宋】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军土、二鲁将、公子偃、颛孙生、鲁庄公同上。"
        },
        {
          "character": "鲁庄公",
          "type": "唱",
          "text": "齐国以强把弱欺， 宋国无端起战机。 释放长万孤有妙计，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "御说上。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "鲁侯啊……"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "公子为何这等模样？"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "鲁侯容禀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "既是南宫长万谋反，待孤发兵与你父报仇就是。"
        },
        {
          "character": "御说",
          "type": "白",
          "text": "多谢鲁候。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "南宫牛讨战！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "何人出马，擒那南宫牛？"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "待臣前去擒来！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "多加小心！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颛孙生下，四军士带马同下。通鼓。颛孙生绑南宫牛同上。"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "南宫牛擒到！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "大胆南宫牛，你父子谋反朝廷，将宋闵公杀死，哪里容得，推出斩了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二军土押南宫牛同下。二军士同上。"
        },
        {
          "character": "二军士",
          "type": "同白",
          "text": "斩首已毕。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "颛孙生听令：命你假扮南宫牛模样，诈开城门速速进城，孤家大兵随后就到。"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "众将官！兵发宋国去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "鲁庄公",
          "type": "stage",
          "text": "【第十二场：诈城】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "城墙。四军士绑御说、颛孙生同上。"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "来此宋国城下，待俺放一号箭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万上城。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "城下何人放箭？"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "南宫牛回来了。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "捉拿公子御说可曾拿到？"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "今已拿到，父帅请看。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "我看他不清，待为父与你开城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万出城摸黑，颛孙生、南宫长万抓枪同下。四军士、二鲁将同上，同进城。"
        },
        {
          "character": "南宫长万",
          "type": "stage",
          "text": "【第十三场：护母出城】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫母上。"
        },
        {
          "character": "南宫母",
          "type": "唱",
          "text": "耳边厢又听得军鼓声震， 但不知我儿他可曾出兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万、颛孙生同上，小开打。颛孙生败下。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "参见母亲。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "外面何来战鼓之声？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "母亲，那鲁庄公将城池打破，眼看就要杀进府门来了！"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "即是城池已破，你不进宫保护主公，回来作甚？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "这个——"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "回来作甚？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "恐怕母亲有失。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "儿可知国家养兵千日，用兵一时，为娘不用我儿保护，速速进宫保驾去罢！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "快去！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "快去！"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "哎呀母亲哪！主公他……"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "他怎么样了？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "他、他、他归天了！"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "南宫母",
          "type": "西皮小导板",
          "text": "听说主公丧了命， （四军士、二鲁将、公子偃、颛孙生、鲁庄公同上，过场，同下。南宫长万出门，望门。五锤。南宫长万进 门。）"
        },
        {
          "character": "南宫母",
          "type": "唱",
          "text": "锦绣家邦化灰尘。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "哎呀儿呀！如今国破家亡如何是好？"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "母亲且莫惊慌，待孩儿寻找车辆保定母亲，陈国避难，日后借来人马再报此仇。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "就依我儿。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "待孩儿寻找车辆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万出门。公子偃上，开打，南宫长万、公子偃同架下。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "南宫母",
          "type": "西皮散板",
          "text": "最可叹众黎民遭此不幸， 但愿得到陈国搬来救兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万推车架二鲁将同上。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "母亲请来上车！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二鲁将同架住。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "母亲快来上车！"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫母上车，南宫长万推车架二鲁将同下。鲁庄公、四军士同追下。"
        },
        {
          "character": "南宫母",
          "type": "stage",
          "text": "【第十四场：战将突围】"
        },
        {
          "character": "南宫长万",
          "type": "内二黄导板",
          "text": "驱车战将军鼓震， （撕边。南宫长万左手推车右手执枪，架住二鲁将、颛孙生、公子偃同出场，于“八大倾仓”中亮相唱“震” 。起〖急急风〗。南宫长万推车、驾将走至上场门台口。起软四击头。南宫长万向左斜方推车。起软四击 头。南宫长万向右台口推二鲁将、颛孙生、公子偃。起三锤。南宫长万将车送至高台前，南宫母上高台。起 四击头。南宫长万推出二鲁将、颛孙生、公子偃，打二鲁将、颛孙生、公子偃同腾鼻，二鲁将、颛孙生、公 子偃同退后，南宫长万旋子上高台，背枪亮相。四兵士，鲁庄公抱令旗暗同上，鲁庄公在上场门台口的高台 上下，后站四兵。）"
        },
        {
          "character": "南宫母",
          "type": "回龙",
          "text": "我的儿要留神，"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "年迈高堂你且莫耽惊。"
        },
        {
          "character": "颛孙生",
          "type": "唱",
          "text": "尔可敢杀？"
        },
        {
          "character": "公子偃",
          "type": "唱",
          "text": "尔可敢争？"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "俺似猛虎， 看你们好以羊群， 不由我二目圆睁， 我的杀气腾腾， 鲁国的人马哪一个愿死不用生，你们来显奇能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万尾腔中耍枪花，于“衣大大仓”中亮相。起原板过门。"
        },
        {
          "character": "鲁庄公",
          "type": "二黄原板",
          "text": "众将官且退后莫往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起长锤。二鲁将、颛孙生、公子偃同允，反领圆场，自上场门同下。起垛头。南宫长万耍枪亮住。"
        },
        {
          "character": "南宫母",
          "type": "二黄原板",
          "text": "观人马似潮涌好不惊人。"
        },
        {
          "character": "南宫长万",
          "type": "二黄原板",
          "text": "儿好比铁石汉，何惧他们以多为胜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万尾腔中耍枪，“衣大大仓”中亮相。起“战场”。二鲁将同上。"
        },
        {
          "character": "二鲁将",
          "type": "同白",
          "text": "哪里走！ （二鲁将各执双刀，欲登高，被南宫长万挡开，开二鲁将枪背，南宫长万翻下，与二鲁将打三股挡，二鲁将 同败下。起垛头。南宫长万耍枪亮相。）"
        },
        {
          "character": "南宫母",
          "type": "二黄原板",
          "text": "暗瞩告众神灵。"
        },
        {
          "character": "鲁庄公",
          "type": "二黄原板",
          "text": "休要放走叛逆之臣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子偃在鲁庄公唱时执枪暗上。"
        },
        {
          "character": "公子偃",
          "type": "二黄原板",
          "text": "你往哪里逃生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子偃唱时持枪扎南宫长万脖，南宫长万于“衣大大仓”中反扎公子偃脖，亮住。"
        },
        {
          "character": "南宫长万",
          "type": "二黄原板",
          "text": "你是休想活命， 鲁国纵有百万兵， 管叫你们难以回程。 （南宫长万唱“回程”时，边唱边与公子偃对打，唱完起锣经“战场”打“老虎枪”。南宫长万开公子偃枪 背，公子偃下，南宫长万上高台。颛孙生执枪上，攻高台，以枪刺南宫长万，南宫长万抓住。颛孙生随之上 高台，南宫长万、颛孙生同一拽两拽，南宫长万踢开颛孙生手，颛孙生抢背落地。起垛头。南宫长万亮相。）"
        },
        {
          "character": "南宫长万",
          "type": "二黄原板",
          "text": "我下山坡，"
        },
        {
          "character": "南宫母",
          "type": "二黄原板",
          "text": "儿莫战争，"
        },
        {
          "character": "颛孙生",
          "type": "二黄原板",
          "text": "敢来对阵？"
        },
        {
          "character": "南宫长万",
          "type": "二黄原板",
          "text": "开口骂颛孙生， 你是败将有何本领， 刹时叫你命丧残生！ （二鲁将、公子偃同上。南宫长万由高台蹦下边唱“残生”边与颛孙生、公子偃、二鲁将同开打。锣经转 〖急急风〗。南宫长万腾开二鲁将、公子偃、颛孙生，于右外角起“四击头”，上高台，对峙亮相。）"
        },
        {
          "character": "鲁庄公",
          "type": "唱",
          "text": "人来看过弓和箭， 看他母子怎逃生。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁庄公射箭，南宫长万低头，南官母中箭。"
        },
        {
          "character": "南宫母",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫母握箭坐椅上。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "南宫长万",
          "type": "唱",
          "text": "一见母亲中了箭， 舍死忘生护娘亲。"
        },
        {
          "character": "鲁庄公",
          "type": "白",
          "text": "乱箭齐发！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起风入松牌。四兵士同射箭，南宫长万持枪拨打，二鲁将同上前欲打。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万刺死鲁将甲，颛孙生接过兵士甲弓箭射南宫长万。"
        },
        {
          "character": "颛孙生",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万抓箭，众人同惊后退。"
        },
        {
          "character": "南宫长万",
          "type": "白",
          "text": "长万去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南宫长万亮相。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}