{
  "script_id": "70004104",
  "title": "绝龙岭",
  "alias": [
    "闻太师夜战绝龙岭；一名：闻仲归天"
  ],
  "source": "唐韵笙剧本选",
  "characters": [
    {
      "name": "闻仲",
      "hangdang": "净"
    }
  ],
  "plot": "闻仲奉旨，领兵征伐西岐。姜子牙助武王迎战，并邀各路诸侯助阵，会战于“绝龙岭”。闻仲寡不敌众，被\n逼上“绝龙岭”，突围不成，全军覆没。",
  "notes": "此剧根据神话小说《封神演义》及传统连台本戏《封神榜》重新创作而成，又名《闻太师夜战绝龙岭》。创\n作、首演于一九三二年左右，花脸应工。三、四十年代曾上演于天津、北京、东北三省。四十年代后期演唱\n演于津、沪、江南各地。一九五零年先父（唐韵笙）根据文化部整理传统剧目的精神，将《绝龙岭》一剧中\n的神妖出场删去，改为各路诸侯助姜子牙伐纣。一九五九年又将《陈十策》、《绝龙岭》修改后穿连起来，\n作为文武并重的大戏演出。\n闻仲画“老脸”，头戴帅盔，足穿黑靴，首演时穿红蟒、麒麟铠甲，两肩两胯有虎头犄角。四十年代后期改\n为大扮，红蟒、红靠。手执双长鞭。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "发点。八麒麟兵拿飞虎旗同上。吉利、余庆捧鞭引闻仲同上。"
        },
        {
          "character": "闻仲",
          "type": "点绛唇",
          "text": "杀气冲宵，儿郎虎豹，军令号——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。邓忠、陶容、张节、辛环自两边分上，同亮相。"
        },
        {
          "character": "闻仲",
          "type": "点绛唇",
          "text": "地动山摇，要把狼烟扫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。闻仲归大坐。"
        },
        {
          "character": "邓忠、陶容、张节、辛环",
          "type": "同白",
          "text": "参见太宰！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "邓忠、陶容、张节、辛环",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "闻仲",
          "type": "念",
          "text": "飞龙幡红缨闪闪，飞凤幡子午盘旋。飞虎幡腾腾杀气，飞豹幡盖地遮天！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老夫，太宰闻仲。只因东、南伯侯俱被杀退，唯有西伯侯姬昌叛反朝廷甚是猖 狂，老夫奉天子命诏，带领人马征战西岐。今日万岁亲到校场饯行。 各位将军。"
        },
        {
          "character": "邓忠、陶容、张节、辛环",
          "type": "同白",
          "text": "太宰。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "伺侯了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四太监、大太监、纣王同上。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老臣见驾，我主万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "太宰平身！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老臣有何德能，敢劳万岁亲到校场饯行？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "你乃三朝元老，征战西岐，孤王理当饯行。 内侍，看酒伺候！"
        },
        {
          "character": "纣王",
          "type": "西皮散板",
          "text": "内侍看过酒一樽， 我与太宰来饯行。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "万岁校场来饯行， 老臣西征立功勋。 人来带过墨麒麟，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麒麟兵甲带麒麟上，咆哮。"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "麒麟咆哮为何情？"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "启稟太宰：麒麟咆哮与出军不利，就该将人马撤回才是。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "哎呀，将军说哪里话来，为臣者以身许国而记其家，上马论兵而记其命，哪有 大将上阵不死带伤之理，此乃常事，何足异也？近日麒麟不曾出战，也未曾演 试，筋骨不能舒伸，故有此咆哮。将军何言出军不利？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "啊太宰，千万不要将人马撤回，若是将人马撤回，各路诸侯知晓，岂不耻笑太 宰惧敌耳？"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老臣焉能将人马撤回，只要万岁改过自新，整理朝政，老臣纵然战死疆场，死 而无怨也！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "老太宰不要口出不利之言，此番征战西岐，必然得胜归来，孤王改过自新整理 朝政也就是了。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老臣别驾了！"
        },
        {
          "character": "闻仲",
          "type": "西皮摇板",
          "text": "辞别万岁跨麒麟， 征战西岐走一程！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲、八麒麟兵、吉利、余庆、邓忠、陶容、张节、辛环同下。"
        },
        {
          "character": "纣王",
          "type": "西皮摇板",
          "text": "一见太宰登路程， 回宫去见妲己畅饮杯巡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纣王、四太监、大太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。四大刀手、姜文焕、鄂顺、崇黑虎同上。"
        },
        {
          "character": "姜文焕、鄂顺、崇黑虎",
          "type": "同白",
          "text": "某！"
        },
        {
          "character": "姜文焕",
          "type": "白",
          "text": "姜文焕。"
        },
        {
          "character": "鄂顺",
          "type": "白",
          "text": "鄂顺。"
        },
        {
          "character": "崇黑虎",
          "type": "白",
          "text": "崇黑虎。"
        },
        {
          "character": "姜文焕",
          "type": "白",
          "text": "二位诸侯请了。"
        },
        {
          "character": "鄂顺、崇黑虎",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "姜文焕",
          "type": "白",
          "text": "今有闻仲兵发西岐，姜子牙相邀我等前去助战，就此前往。"
        },
        {
          "character": "姜文焕、鄂顺、崇黑虎",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "闻仲",
          "type": "内西皮导板",
          "text": "离皇城兵压渑池小县，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八麒麟兵、邓忠、陶容、张节、辛环、吉利、余庆同上，扎犄角，闻仲上。"
        },
        {
          "character": "闻仲",
          "type": "西皮流水板",
          "text": "战鼓咚咚震山川。 鞭鞘一举风云转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "领起，下场门斜门。"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "前队不行为哪般？"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "前队为何不行？"
        },
        {
          "character": "邓忠、陶容、张节、辛环、吉利、余庆",
          "type": "同白",
          "text": "来到绝龙岭。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "听罢言来心暗转， 举目抬头四下观。 绝壁悬崖山势险， 不由闻仲心胆寒。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "将人马扎山脚待我查看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八麒麟兵同归上场门。"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "层层叠叠迷山岩。 重重绕绕好凶险， 倒叫老夫愁锁眉尖，"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "鞭来！"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "击碎岩石免遭难，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三锣。闻仲击石。"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "我军禁止过此山。"
        },
        {
          "character": "邓忠",
          "type": "白",
          "text": "太宰为何烦恼？"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "尔来看！这“绝龙岭”山路崎岖，丛林密布，乃是一条死路，与我军不利，老 夫击碎岩石以作标记，尔等若行兵至此，必须绕道而行，不可进山安营，若遇 敌军，四面受敌，就有全军覆没之险！"
        },
        {
          "character": "邓忠、陶容、张节、辛环",
          "type": "同白",
          "text": "我等记下了！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "邓忠、陶容听令！"
        },
        {
          "character": "邓忠、陶容",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "命你二人攻打头阵！"
        },
        {
          "character": "邓忠、陶容",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓忠、陶容同下。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "众将官，绕过绝龙岭，向西岐进发！"
        },
        {
          "character": "闻仲",
          "type": "西皮散板",
          "text": "麒麟军摧战马莫要迟缓， 但愿得此一去奏凯回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。黄飞虎、三将同上，同亮相。发点，四周将自两边分下。八周兵、姜子牙同上。"
        },
        {
          "character": "姜子牙",
          "type": "引子",
          "text": "纣王无道，宠妲己，残害忠良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜子牙归大坐，四周将自两边分上。"
        },
        {
          "character": "四周将",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "众位将军少礼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四周将同允。"
        },
        {
          "character": "姜子牙",
          "type": "念",
          "text": "昆仑修炼四十年，身背封神下高山。渭水河边曾垂钓，偶遇文王访高贤。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "贫道，姓姜名尚字子牙，道号飞熊，只因三教共议封神榜，师父命我背榜下山， 扶保武王。昨日探马报道，闻仲带领人马打西岐，岂可容他猖狂？ 众将官，出城迎敌者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二龙出水。邓忠、陶容同上。姜子牙打邓忠、陶容下。"
        },
        {
          "character": "姜子牙",
          "type": "唱",
          "text": "邓忠、陶容无本领， 敢在疆场显其能。 耳旁听得风声震，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八麒麟兵同上，闻仲、邓忠、陶容、张节、辛环、吉利、余庆同上。"
        },
        {
          "character": "闻仲",
          "type": "唱",
          "text": "胆大姜尚敢挡天兵。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "呜呼呀！我当何人，原来是闻太师到此，恕我有甲胄在身不能施礼，太师莫怪。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "姜子牙！尔有三行大罪，你可知晓？"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "不知哪三行大罪，请道其祥。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "你且听了，私立武王为君，其罪一也；收纳叛臣黄飞虎，其罪二也；老夫大兵 到此，尔敢兴兵抗拒，其罪三也；有此三行大罪，还不下骑投降，等到何时？"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "闻太师，只因纣王无道宠信妲己残害忠良，各路诸侯心中不忿，要夺取纣王的 天下，如今周室当兴，纣氏当灭，劝你下骑投降，免得封神榜上留名。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "尔是一派胡言，休走看鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。两边钻烟筒分下，姜子牙、闻仲开打，闻仲打姜子牙一鞭，八周兵救姜子牙同下。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "姜子牙不要害怕，老夫不来追赶尔等了！"
        },
        {
          "character": "闻仲",
          "type": "唱",
          "text": "人道姜尚有本领， 雌雄鞭下难逃生。 众将回营且安顿， 明日踏平西岐城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "姜子牙、八周兵、四周将挖门同进，姜子牙归坐。"
        },
        {
          "character": "四大刀手",
          "type": "内同白",
          "text": "众位诸侯到。"
        },
        {
          "character": "周将甲",
          "type": "白",
          "text": "启稟元帅：众位诸侯到。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。姜文焕、鄂顺、崇黑虎、四大刀手挖门同进。"
        },
        {
          "character": "姜文焕、鄂顺、崇黑虎",
          "type": "同白",
          "text": "姜丞相怎么样了？"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "闻仲甚是骁勇！"
        },
        {
          "character": "姜文焕、鄂顺、崇黑虎",
          "type": "同白",
          "text": "就该命我等与他车轮大战。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "有劳各位诸侯前来助战，东伯侯听令！"
        },
        {
          "character": "姜文焕",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "命你带领人马，三更时分，前去偷营劫寨，出其不意，杀他个措手不及！"
        },
        {
          "character": "姜文焕",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "南伯侯听令！"
        },
        {
          "character": "鄂顺",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "姜子牙",
          "type": "白",
