        {
          "character": "周仓",
          "type": "白",
          "text": "咋咋咋……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽扔刀，大转身，众人护关羽同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。众人拥关羽同上。挖门，归座。"
