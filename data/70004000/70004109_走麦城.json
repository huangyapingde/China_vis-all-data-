        {
          "character": null,
          "type": "stage",
          "text": "曹仁不睬。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "众将官，高架云梯，奋勇杀敌，齐攻城。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": "关羽",
