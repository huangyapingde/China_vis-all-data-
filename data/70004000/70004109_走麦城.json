    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "童儿、华佗同上。"
        },
        {
          "character": "华佗",
          "type": "引子",
          "text": "精于歧黄，施妙药，普济安康。"
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "三国群雄起，纷纷征战急。砍杀伤和气，太平何日期？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "在下，华佗，字元化。沛国谯郡人氏。一生调于歧黄，医疗为本。近日闻得关 云长将军身中箭伤。想那二君侯乃是大义之人，深受世人钦佩。意欲过得江去， 一来拜见，二来与他调治伤势。 嗯，童儿，准备药箱，随为师过江去者！"
        },
        {
          "character": "华佗",
          "type": "吹腔",
          "text": "征战纷纷群雄并起， 不知何日天下太平？ 叫童儿你把那药箱背定， 随为师过江去诊治伤情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣原场。华佗示意童儿叩门。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "门上哪位在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓上。"
        },
        {
          "character": "周仓",
          "type": "念",
          "text": "柳林晨试马，虎帐夜谈兵。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "啊将军，烦劳通禀：小老儿华佗求见二君侯。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "噢……老丈稍候。 请父王。"
        },
