          "character": "周仓",
          "type": "白",
          "text": "父王！北门以外定有埋伏，父王万万不可出城！"
        },
        {
          "character": "王甫",
          "type": "白",
          "text": "不可出城！"
        },
        {
          "character": "赵累",
          "type": "白",
          "text": "万万不可出城！"
        },
        {
          "character": "关平、周仓",
          "type": "同白",
          "text": "千万出不得！"
        },
        {
          "character": "关平、周仓、王甫、赵累",
          "type": "同白",
          "text": "（父王）（君侯）。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平、周仓、王甫、赵累同跪。乱锤切住，三撕边，〖四击头〗。亮住。"
        },
        {
          "character": "关羽",
          "type": "哭",
          "text": "咿！咿！咿！啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽悲泣，收住。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想这麦城不过弹丸之地，内无粮草，外无救应。廖化上庸搬兵至今音信皆无， 倘被贼兵攻破城池，岂不束手待毙！我意已决，尔等不必多言！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖撕边一击〗。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "起来！起来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一番二番切住。关羽高声。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "起来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同起。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "王甫、周仓，命你二人紧守城池。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "低音锣一击。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平、赵累，随我夜闯北门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "切住。急冲头，切住。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "众将！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三锤。均上步。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "今夜三更时分，人掩铠甲，马摘銮铃，随我夜闯北门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人合式亮相。大锣凤点头。"
        },
        {
          "character": "关羽",
          "type": "高拨子散板",
          "text": "荆襄九郡遭沦陷， 宁可玉碎不瓦全。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖撕边一击〗。关羽亮住，急下。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、吕蒙双抄场。"
        },
        {
          "character": "徐晃、吕蒙",
          "type": "同白",
          "text": "（众将官）（儿郎的）！埋伏了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、吕蒙同下。转场。众兵同扫雪，关羽、关平、赵累、周仓、王甫同上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "送父王！"
        },
        {
          "character": "王甫",
          "type": "白",
          "text": "送君侯！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小心把守！ （关羽率众人同下。徐晃、吕蒙、众将双过场。关羽、众人同上，众兵同扫雪，领起归正，徐晃、吕蒙双抄 场下。）"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "启父王：伏兵四起！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平、赵累！随为父冲阵者！ （关羽领起，开打。关羽见徐晃，起打，箭伤疼。关平、徐晃开打，败下。赵累上，战死。关平上，开打， 败下，徐晃追下。关羽上，舞，见徐晃、吕蒙，败下。关平追上，关平、徐晃、吕蒙开打，败下，徐晃、吕 蒙同追下。关羽上，关平追上。）"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "启父王：赵累死于万马军中！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽哭介。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我儿不要害怕，随为父杀，杀，杀！ （关羽下。徐晃上，徐晃、关平开打，关平败下。吕蒙、众人同上，众人同挖门。三通鼓。关羽上，压马， 引关平上。徐晃、吕蒙同追至，关羽、关平落陷马坑。〖尾声〗。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
