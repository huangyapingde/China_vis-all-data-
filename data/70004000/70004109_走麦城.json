        {
          "character": "华佗",
          "type": "白",
          "text": "准备明日就要过江去了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "后帐设宴，与先生同饮。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "讨扰了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽挽华佗手，同下。周仓作状随下。"
        }
      ]
