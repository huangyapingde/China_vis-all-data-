{
  "script_id": "70003120",
  "title": "临江会",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "旗牌",
      "hangdang": "丑"
    }
  ],
  "plot": "诸葛亮既至江东，助周瑜起兵拒曹。刘备因无消息，特遣糜竺前往，以犒军为名，暗中探听诸葛亮消息。不\n意周瑜反乘机诱请刘备过江宴叙，暗伏刀斧手于两厢，拟以掷杯为号，出擒刘备。孰意刘备虽惠然肯来，却\n有关羽戎装紧随，不离一步。周瑜方传杯，忽瞥见关羽按剑而立，怒容满面，凛凛不可犯。时周瑜尚未识关\n羽也。问之刘备，始知即过五关、斩颜良、诛文丑之关云长。周瑜乃大惊，汗流浃背，遂不敢实行，刘备始\n得安然而返。先是诸葛亮在外，得知刘备为周瑜骗过江东，大骇，急往都督府探视，见两厢虽伏刀斧手，然\n有关羽在，必无妨也，遂出。先至刘备来船中伺候，及刘备返舟，诸葛亮告知其意，刘备回忆前宴，始惊诧\n不定。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "糜子仲奉命东吴去了， 不由刘备挂心梢。 又无孔明书信到， 不知所为哪一条？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜竺上。"
        },
        {
          "character": "糜竺",
          "type": "西皮散板",
          "text": "奉命东吴将军犒， 未见先生把话交。"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "糜子仲去至东吴，可曾见着军师？"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "未曾见着军师。那周瑜在东吴临江亭设宴，请主公即刻过江赴宴。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦！请我过江赴宴……糜子仲，命你准备船只，备即刻过江。"
        },
        {
          "character": "糜竺",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜竺下。"
        },
        {
          "character": "关羽",
          "type": "内白",
          "text": "住者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "河梁赴会场，胜似宴鸿门。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "参见大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟少礼，请坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟进帐何事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "闻听大哥要往临江赴会，可有孔明先生书信？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这……无有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想那周郎诡计多端，又无孔明先生书信，大哥不可前往。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "想孙、刘两家同心破曹，若是不去，两下猜疑，事不谐矣。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥执意要去，小弟同往。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好。命子龙、翼德紧守城池，二弟同兄前往。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请大哥更衣。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。刘备、关羽同换衣。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "带马登舟去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同走圆场。船夫迎上，刘备、关羽、四红龙套同上船。"
        },
        {
          "character": "船夫",
          "type": "白",
          "text": "与主公叩头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鸣金开船！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声，开船。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "上得船来，看波浪滔滔，水天一色，好一派江景也！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "汉阳江上船开了， 对对旌旗空中飘。 周郎请孤河梁到， 不见先生音信杳。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟，船行江中，愚兄想起一桩心事来了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥，想起什么心事？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "想孙、刘两家同心破曹，又不见诸葛先生音信，周郎诡计多端，此番临江赴宴， 二弟须要留心一二。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥说哪里话来！想赵国蔺相如，手无缚鸡之力，完璧归赵，使秦人丧胆。你 我弟兄驰骋疆场，威名远震，何惧东吴鼠辈，只要俺一人奋勇，霎时教他万夫 难挡。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "兵在精来不在多， 将在智谋凭略韬。 弟兄威名谁不晓， 何惧东吴小儿曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四红龙套、关羽、刘备同下船。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军士们，就在此处下船。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套引周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "念",
          "text": "计就月中擒玉兔，谋成海底捉金鳌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启禀都督：刘皇叔到。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦！刘备过江来了。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "带来多少随军？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "一军十卒。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊……一军十卒！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊哈哈哈！此人性命休矣，中军听令！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "速命刀斧手帐内埋伏，听得金钟一响，便出帐下手，不得有误！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众将官，摆队相迎！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、周瑜同下，同上。四红龙套、关羽、刘备同上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "皇叔过江来了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备过江来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、周瑜同笑。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "皇叔请。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备不敢，都督请。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "你我挽手而行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、周瑜同笑，同下。四白龙套、四红龙套、关羽同随下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（关羽上，旗牌自下场门上，碰面。关羽怒目以视，旗牌惧，关羽下，旗牌随下。四红龙套、四白龙套、关"
        },
        {
          "character": null,
          "type": "text",
          "text": "羽、旗牌、周瑜、刘备同上，同挖门。）"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "皇叔请来上坐，待瑜大礼参拜。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不敢，不敢，你我分宾主而坐。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "皇叔如此过谦，只得从命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、周瑜同坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请问都督：孔明先生现在哪里？请出相见。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "孔明先生另有公务去了，少时即来相见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "都督相约，不知有何见教？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "我东吴承蒙皇叔协力破曹，特备水酒薄蔬以表寸心，便得共议军务。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备有何德能，敢劳相邀赏宴。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "看宴！待瑜把盏。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不敢，摆下就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、周瑜同入座。旗牌跪。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "赏宴，举杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、周瑜同饮。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "告干，请落台。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "都督，这做什么？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "皇叔驾临，江东生辉，理应跪敬。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "天气炎热，免了罢。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "谢过皇叔。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "多谢皇叔。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "问皇叔那里带来多少人马？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是。 喂，来人嘚。"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "做什么？"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "我家都督问你们带来多少人马？"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "一军十卒。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启都督：一军十卒。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦，一军十卒！酒肴犒赏。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "来人嘚！我家都督酒肴犒赏。"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "启禀二将军：周都督酒肴犒赏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "酒放下，肴撤去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同撤去肴盘。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "酒呢？"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "有人贪杯。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有人贪杯？我看看是谁贪杯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "我怕看他，又遇见他啦！ 请问是您贪杯吗？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "然！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "您是客，我给您斟上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌斟酒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有道是：主不食，客不饮。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "什么是主不食客不饮哪，您怕这里头有毒药，我先喝一小杯您看看——不行， 这大杯我受不了。来来来，我来一小杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌斟饮。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "您瞧怎么样？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "酒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽饮。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "干。斟上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌斟酒。关羽饮。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斟上！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "得啦！十个人的酒，教您一个人都给喝啦，真是个酒囊饭袋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽冷笑。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "英雄海量尔怎晓， 怎比东吴小儿曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽两望。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "俺大哥饮酒脸带笑， 周郎满脸杀气高！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住！看俺大哥在座上谈笑自若，周郎小儿满脸杀气。两旁悬挂壁影，定有埋 伏。俺不免站在大哥身旁，看他是怎样下手！"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "昔日樊哙威风好， 鸿门宴上保汉高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌撞钟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "金钟三响有圈套， 教他个个命难逃。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "都督请！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "大才可算都督高， 孙、刘同心破奸曹； 但愿得曹操灭却了， 两家胜似一同胞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜冷笑。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "皇叔请！"
        },
        {
          "character": "周瑜",
          "type": "西皮原板",
          "text": "胸藏谋略他怎晓， 幸喜枭雄入笼牢。 假意殷勤奉醇醪，"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "周瑜",
          "type": "西皮原板",
          "text": "刘备身旁一英豪！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "皇叔，瑜敬酒一杯，请皇叔满饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备饮。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "多谢皇叔。请问皇叔身后何人？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟云长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜惊惶。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦！这就是斩颜良、诛文丑的二君侯么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "久仰啊，久仰！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "岂敢哪，岂敢！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "瑜告便。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜出帐。"
        },
        {
          "character": "周瑜",
          "type": "叫头",
          "text": "哎呀且住！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "关羽乃世之虎将，在百万军中取上将首级，犹如探囊取物，吾若动手，岂不先 被他所害……这……周瑜呀周瑜！你此计用错了！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "本来的错了！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哼！不如放过今日，徐图别计。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "也只好是如此！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哼！ 既是君侯到此，何不入席同饮。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某大哥在此，关某入席不便。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "到此是客，坐坐何妨。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "如此，关某有僭了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、周瑜同入座。诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "正在舟中童儿报， 我主中了计笼牢。 定是周郎生计巧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃迎上。"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "再与孔明把话交。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊大夫，你家都督大宴何人？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "宴请你主刘豫州，难道你还不知么？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哦，是是是。啊大夫，我要在帐外偷觑偷觑，可使得么？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "使得。各讨方便，请哪！"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "辞别先生回营号， 他人难解计笼牢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "事在紧急如何好？ 我主误进虎穴巢。 蹑足隐身来观瞧， 周郎满脸杀气高。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎呀且住！看我主坐在上面谈笑自若，周郎满脸杀气，两旁悬挂壁影，定有埋 伏，我主性命危矣！这……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮笑。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二将军保驾身旁，我主已无忧矣，待我转去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生可曾看见你家主公？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "看见了。啊子敬，我要告辞了！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "辞别子敬登舟去了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "孔明难解机谋高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃下。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "开言我对都督道， 多少人马破奸曹？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请问都督，灭却曹操要用多少人马？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "想我东吴兵精粮足，何惧曹操乌合之众，只要本督旌旗一举，曹兵可破矣！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥，听公瑾之言甚是容易，你我告辞回转江夏，看他怎样破曹！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "都督，破曹之后，备再来恭贺。告辞了！"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "临江会上多叨扰，"
        },
        {
          "character": "周瑜",
          "type": "西皮散板",
          "text": "破曹之后再想邀。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "都督素日韬略好， 你今错用计一条！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、四红龙套同下。"
        },
        {
          "character": "周瑜",
          "type": "西皮散板",
          "text": "画虎不成反见笑， 丝纶无力逃金鳌。 越思越想羞又恼， 不杀刘备恨难消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "大事眼看成八九， 上手鱼儿脱了钩。 将身且进宝帐口， 只见都督气不休。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊都督，既将刘备诓过江来，为何又将他放走？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "大夫啊！本督正要擒那刘备，谁想关羽在身旁保驾，幸喜本督未曾动手，我若 动手，岂不先被关羽所害！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是啊，一动不如一静哪。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊？何必多言！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌引二下书人同上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "曹营下书人求见。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "传他进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌出帐。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "传你们进见，要小心了！"
        },
        {
          "character": "二下书人",
          "type": "同白",
          "text": "与都督叩头。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "奉何人所差？"
        },
        {
          "character": "二下书人",
          "type": "同白",
          "text": "曹丞相所差，书信呈上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜看信。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "“汉大丞相”——呀呸！曹贼，曹贼！在你营中称得汉大丞相；在我东吴，你 是什么汉大丞相也！"
        },
        {
          "character": "周瑜",
          "type": "西皮散板",
          "text": "曹瞒把我东吴藐， 怎不教人气冲霄。 喝令两旁众将校，"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "周瑜",
          "type": "西皮散板",
          "text": "杀一人来放一人逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同杀下书人甲，下书人乙逃下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "都督！两国相争不斩来使，为何将下书人杀了一个放了一个，是何意也？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "大夫啊！那曹操与本督书信，前来惑我军心，今吾杀之，以振军威。 中军听令！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "命丁奉、徐盛、蒋钦、周泰等带领五万人马，来日三江夏口挑战，不得有误！"
        },
        {
          "character": "周瑜",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜下。〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}