          "character": "关羽",
          "type": "白",
          "text": "恕不强留了。"
        },
        {
          "character": "陈登",
          "type": "白",
          "text": "二将军对刘使君言讲，千万不可回城。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "陈登",
          "type": "白",
          "text": "二将军对刘使君言讲，是陈登前来送信。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": "陈登",
          "type": "白",
          "text": "啊，二将军。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "记下了，请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈登下。张飞上，看。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "何人到此？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥学友前来送信，那车胄要灭桃园弟兄。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊，待俺进城与车胄辩理，要了他的狗命！"
