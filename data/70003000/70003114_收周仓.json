{
  "script_id": "70003114",
  "title": "收周仓",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    },
    {
      "name": "孙乾",
      "hangdang": "生"
    },
    {
      "name": "郭常",
      "hangdang": "生"
    },
    {
      "name": "郭少常",
      "hangdang": "丑"
    },
    {
      "name": "裴元绍",
      "hangdang": "净"
    },
    {
      "name": "夏侯惇",
      "hangdang": "净"
    }
  ],
  "plot": "关羽保护甘、糜二夫人过关斩将，往汝南寻兄。某夕宿老人郭常家。郭子勾结绿林裴元绍往劫赤兔马。正厮\n杀中，卧牛山英雄周仓慕关羽威名，前来搭救。杀死裴元绍。关羽释放郭子，收下周仓。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、大刀手、夏侯惇同上。"
        },
        {
          "character": "夏侯惇",
          "type": "念",
          "text": "统令兵和将，争战马蹄忙。曹营为上将，英名天下扬。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "某，夏侯惇。奉丞相将令，查看黄河，提防河北袁绍暗渡。这且不言，只因蔡 老将军，将他外甥秦琪，托付某家部下为将，我也曾命秦琪，把守黄河渡口。 呀！看帅字旗无风自摆，必有紧急军情。且听探马一报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有关羽过关，刀劈秦琪落马！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "再探！不好！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖牌子〗。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "众将官！带马追赶关羽去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "关羽",
          "type": "内西皮导板",
          "text": "挂印封金心归汉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小校、老军、二车夫、甘夫人、糜夫人、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "关山阻隔路遥远。 千里寻兄心似箭， 青龙斩将出五关。 诛孔秀斩王植非我本愿， 杀韩福刺孟坦洛阳关前， 镇国寺蒙普净将我指点， 沂水关杀卞喜怒发冲冠， 过黄河遇秦琪刀劈两段， 夺船只渡黄河费尽心田。 紧加鞭催赤兔"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "风云似电，"
        },
        {
          "character": "孙乾",
          "type": "内白",
          "text": "云长公慢走！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "又只见一骑马飞奔如烟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾上。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "二将军！稍停战马，孙乾赶来相谈。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "孙先生，自汝南一别，一向消息如何？"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "刘辟、龚都自将军去后，复夺汝南，遣某去往河北，结好袁绍，同谋破曹。不 想河北将士，各相妒嫉。田丰尚在狱中，沮受斥退不用，审配、郭图，各自争 权。袁绍多疑，主持不定。某与刘皇叔商议，先求脱身之计，往汝南会合刘辟、 龚都去了。恐将军不知，投到袁绍营中，反为伤害，特命某一路接迎将军， 幸得相见。将军可速往汝南，与刘皇叔相会。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "言得极是！见过二位夫人。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "参见二位夫人。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "罢了！将军所言，可是实情？"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "句句实言。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同哭。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "孙将军先行，寻俺大哥，报知关某随后而行，我弟兄不日相见。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小校！"
        },
        {
          "character": "小校",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "人马不去河北，速奔汝南去者！"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "适才孙乾把信传， 大哥逃奔在汝南。 但愿弟兄早相见——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、大刀手、夏侯惇同上，过场，同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "旌旗遮住半壁天。 车辆休惊往前趱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇上。"
        },
        {
          "character": "夏侯惇",
          "type": "西皮散板",
          "text": "过关斩将理不端。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "关羽你往哪里走！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "夏侯将军！汝来赶我，岂不失丞相大度？"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "住了！你沿路杀人，斩我部下之将，无礼太甚，俺特来生擒活捉，将你献与丞 相麾下，休走看枪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关某，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽架刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不恭了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、夏侯惇欲会阵。"
        },
        {
          "character": "李典",
          "type": "内白",
          "text": "二位将军，住手！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李典上。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "将军何来？"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "丞相敬爱关将军忠义，恐一路关隘拦阻，故遣末将，特递公文，遍行诸处。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "关羽过关斩将，丞相可知？"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "这，不知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、夏侯惇会阵。乐进上。"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "二将休得动手！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "乐将军！可是丞相命你，生擒关羽？"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "非也！丞相恐守关将士阻拦，差某报知关口，一律放行。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "丞相可知关羽过关斩将？"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "这，未知。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "众将！将关羽团团围住！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起打。关羽下，夏侯惇追下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上，过场，下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、夏侯惇同上，张辽赶上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "二将军休惊，弟张辽来也。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "张将军！关羽闯关斩将，丞相可知？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相尽知，特命我报与各处，一律放行，将军何故如此？"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "想那秦琪，乃是蔡阳托付在吾营下，被他刀劈马下，叫我怎生对待蔡老将军？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "吾见蔡老将军自有说服，丞相大度，我们将士，不可违令。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "关将军，夏侯惇得罪了，请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇、四龙套、四上手、大刀手同下。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "二将军，夏侯将军多有得罪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关兄，今欲何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哎！闻兄长又不在袁绍处，吾欲游遍天下寻之。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "既未知玄德兄下落，且再回营去见丞相，意下如何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哈哈哈哈！安有斯理。相烦文远，回见丞相，幸为我谢罪，未尽之恩，容日报 答。弟告辞了！"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "自从下邳进曹营， 唯有你我共同心。 今日分别"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "泪难忍，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远！"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "为弟拜上徐公明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、关羽同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郭常上。"
        },
        {
          "character": "郭常",
          "type": "西皮摇板",
          "text": "静坐家中心烦闷， 去到庄门散散心。"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "老汉郭常。小儿少常，长大成人，不习正道，每日游荡射猎，残害生灵，实是 我家门不幸。这且不言。哎！静坐家中无聊，去至庄门散逛便了！"
        },
        {
          "character": "郭常",
          "type": "西皮摇板",
          "text": "叹人生在世间如梦不醒， 有财帛和儿女难乐天伦。 我郭常生逆子未有德行， 终日里锁双眉常挂泪痕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小校、老军、二车夫、甘夫人、糜夫人、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "天色冥晦路难奔，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "只见山旁一庄门。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老丈请了！"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "请了！将军可是关去长乎？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老丈何以识我？"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "久闻盛名，赤面长髯。今见将军如此象貌，故而冒叫一声。将军莫怪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢！关某辞曹归汉，行至此间，天色已晚，在此借住一宵，明日早行。"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "贵客临门，合庄之幸也！将军请进。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "尚有二位皇嫂。"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "老妻奉陪。老妈妈快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭常妻上。"
        },
        {
          "character": "郭常妻",
          "type": "白",
          "text": "老老何事？"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "贵客驾临，你奉敬二位夫人，后堂安歇。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请二位嫂嫂后面歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同下车。"
        },
        {
          "character": "郭常妻",
          "type": "白",
          "text": "二位夫人请进。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "老人家请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人、郭常妻同下。马童、车夫、小校同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请问老丈上姓？"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "小老儿姓郭名常，祖居在此。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "原来是郭老先生。关某失敬了！"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、郭少常同上。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "你又往哪里去了？"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "射猎去了！"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "不习正道。见过关将军！"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "参见关将军。 伙计们，走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭少常、四下手同下。"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老丈！方才少年是谁？"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "此愚男少常也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此数人何来？"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "哎！老汉耕读传家，只生此子，不务正业，惟以射猎为事，不习正道。唉！是 我家门不幸也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老丈！何出此言？方今乱世，若武艺精熟，亦可取得功名。何言不幸二字？"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "他若练习武艺，便是有志之人了！请将军后面用过酒饭好安歇。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "叨扰了！"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "何出此言？正是："
        },
        {
          "character": "郭常",
          "type": "念",
          "text": "千里有缘来相会，"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "对面无缘不相逢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭常、关羽同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、郭少常同上。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "伙计们！你们看来的那人，骑得一匹好红马。你们各带兵器，庄门等候。待俺 盗他的宝马。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、郭少常同下。马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "今夜晚借宿郭家庄， 老丈的礼义如孟尝。 东奔西驰路途忙， 苍天何不助忠良？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马童！看守马匹，须要小心！"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童下。郭少常上。"
        },
        {
          "character": "郭少常",
          "type": "念",
          "text": "习学射猎事，武艺全不通。乔装来改扮，盗马显本领。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "俺，郭少常。是俺改扮，偷盗战马，就此动手。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭少常下。马叫声。郭少常上，被马踢倒在地。马童上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "着打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭常妻、甘夫人、糜夫人、郭常同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马童！此子因何倒卧在地？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "此人前来偷盗赤兔马，被马踢倒，我等闻声，特来查看。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呔！猎贼儿，敢来盗我马乎？"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "将军！此子罪当万死，奈老妻最怜爱此子，望将军仁慈宽恕。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此子果然不肖。方才老翁所言，真乃知子莫若父也。我看汝父之面，姑且恕之。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭少常下。"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "谢将军恩德！天交三鼓，请各安歇了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭常妻、甘夫人、糜夫人同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好好看守马匹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童下。"
        },
        {
          "character": "郭常",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭常、关羽同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、郭少常同上。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "郭少常",
          "type": "念",
          "text": "量小非君子，无毒不丈夫。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "伙计们！战马未曾到手，我们与裴元绍送上一信，路途之中，劫夺红脸大汉行 囊马匹。正是："
        },
        {
          "character": "郭少常",
          "type": "念",
          "text": "一不做来二不休，打蛇不成反成仇。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭少常下，四下手随下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "裴元绍上。"
        },
        {
          "character": "裴元绍",
          "type": "念",
          "text": "我本草莽一英豪，占领山林多逍遥。"
        },
        {
          "character": "裴元绍",
          "type": "白",
          "text": "俺，裴元绍。在此山林之中，打劫商旅，倒也逍遥自在。我有一好友，名叫郭 少常，近日为何不见？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报，郭少爷上山拜访！"
        },
        {
          "character": "裴元绍",
          "type": "白",
          "text": "有请郭贤弟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭少常上。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "裴大王！山下来了一红脸大汉，骑得一匹好红马，何不下山劫去。"
        },
        {
          "character": "裴元绍",
          "type": "白",
          "text": "好，众喽兵！带马下山！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴元绍下，众人随下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小校、马童、二车夫、甘夫人、糜夫人、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "醉花阴",
          "text": "彻夜趱行汝南去， 读春秋雄心盖世。 云雾漫日当空，为寻兄赶程心急， 恨不得胁生双翅。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "昨日郭家借宿，郭常倒有孟尝礼义，他子少常，好无男儿之志也！"
        },
        {
          "character": "关羽",
          "type": "醉花阴",
          "text": "凭赤兔行千里快如飞， 青龙刀斩将如泥， 何俱那千军敌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周仓上，起霸。"
        },
        {
          "character": "周仓",
          "type": "念",
          "text": "两肩勇力似金刚，卧牛山前自为王。武艺精通谁敢挡，黄巾事败落山冈。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "某，周仓，字元福。当年曾在黄巾张宝帐下为将。黄巾事败，张宝已死，是俺 统领本部人马，无处投止，占了卧牛山，自立为王。我想久在绿林，哪有出头 之日。久闻桃园弟兄，威名远震，有志投于赤面长髯关云长麾下，奈无机会。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。四喽兵同上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启大王：山下有一红脸大汉随同车辆闯山而过。特来报知。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "再探！ 呔！众喽兵，抬枪带马，下山去者！"
        },
        {
          "character": "周仓",
          "type": "西皮摇板",
          "text": "卧牛山威名谁不晓， 抖擞威风逞英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、郭少常同上，过场，同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴元绍上，过场，下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽、马童、小校、甘夫人、糜夫人、二车夫同上，同走圆场。"
        },
        {
          "character": "关羽",
          "type": "喜迁莺",
          "text": "路不平崎岖高低， 紧加鞭心急箭催， 俺恨马迟急得俺钢牙咬碎， 过五关斩六将抖擞雄威。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、郭少常、裴元绍同上，冲散甘夫人、糜夫人、二车夫同下，裴元绍追下。"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "将马留下，放你过去。"
        },
        {
          "character": "小校",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小校将郭少常打败。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且慢，看他父面，放他去吧！"
        },
        {
          "character": "郭少常",
          "type": "白",
          "text": "谢关爷爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭少常溜下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好无知逆贼也！"
        },
        {
          "character": "关羽",
          "type": "刮地风",
          "text": "哎呀呵—— 郭常子两次来欺， 看他父面暂留首级， 加鞭纵马追车骑， 地形险恶要防提。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。关羽率小校、马童同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周仓率四喽兵同上。二车夫推车旗引甘夫人、糜夫人同上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "呔，何人轿车，留下金银财宝，饶尔不死！"
        },
        {
          "character": "车夫甲",
          "type": "白",
          "text": "刘使君轿车。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "我不管甚么牛使君马使君的，留下买路钱！"
        },
        {
          "character": "车夫乙",
          "type": "白",
          "text": "汉寿亭侯驾护二位夫人，莽汉休得无礼！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "我却不信。"
        },
        {
          "character": "裴元绍",
          "type": "内白",
          "text": "裴元绍来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴元绍上。"
        },
        {
          "character": "裴元绍",
          "type": "白",
          "text": "呔！留下车辆，饶尔不死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴元绍对周仓怒视。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "哪里来的狂徒，竟敢口出狂言大话？"
        },
        {
          "character": "裴元绍",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "你黑老爷周仓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓一枪刺死裴元绍。"
        },
        {
          "character": "关羽",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童、小校引关羽同上。关羽、周仓同架住，亮相。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "果然是美髯公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓收刀，跪。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "周仓拜见汉寿亭侯！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吾与公素不识面，何知吾的名姓？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "某姓周名仓，字元福。原在张宝帐下为将。张宝已死，流落绿林。常听人言， 将军虎威，恨无门径相见，今日得遇将军，某之幸也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想绿林之中，非豪杰扎足之处。公今后去邪归正，方是英雄也！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "将军所言甚是。望收为步卒，早晚侍奉鞍前马后，某死亦心甘！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "将军意愿随我，汝手下人伴如何？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "愿从则从，不愿从者听之可也。"
        },
        {
          "character": "众喽兵",
          "type": "白",
          "text": "关将军威名远震，我们俱愿顺从！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "妙啊！"
        },
        {
          "character": "关羽",
          "type": "水仙子",
          "text": "呀呀呀宝刀提， 呀呀呀宝刀提， 喜喜喜，喜今朝把英雄聚， 谢谢谢，谢苍天并和地， 是是是，是大哥洪福起， 到到到，到来日疆场建功劳， 俺俺俺，俺真堪喜。可也喜气豪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "水仙子",
          "text": "看看看，看红日坠落西山道。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "关将军！看红日西坠，请至卧牛山上一叙！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好！往牛头山去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}