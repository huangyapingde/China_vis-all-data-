{
  "script_id": "70003109",
  "title": "诛文丑",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "文丑",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "生"
    },
    {
      "name": "袁绍",
      "hangdang": "净"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "颜良阵亡，袁绍遣文丑与刘备攻曹，势不可挡。曹操用言激怒关羽。关羽刀劈文丑，但仍未能与刘备相遇。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗，〖急急风〗。四龙套、四大刀手同上，同挖门，文丑上。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "某，无敌大将军文丑，奉主帅之命催运粮草，粮草催齐，回营交令。 呔！军士们，回营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。文丑下。四龙套、四大刀手同随下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、袁绍同上。"
        },
        {
          "character": "袁绍",
          "type": "引子",
          "text": "虎牢兵败，众诸侯，各霸一方。"
        },
        {
          "character": "袁绍",
          "type": "念",
          "text": "忆昔举义灭权奸，各路诸侯心太偏；烟尘四起民遭难，曹操胜比董卓奸。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "某，袁本初。前者兴兵灭曹，命大将颜良，攻打白马坡，未知胜负，且听探子 一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文丑、四龙套、四大刀手同上。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "参见主帅，粮草催齐，末将交令。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "将军之功，帐外歇息。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "谢主帅！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文丑下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀主帅：颜良在白马坡，被红脸大汉，刀劈落马。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "且住！颜良被红脸大汉，刀劈落马，定是刘备之弟关羽所为。 来，传刘备进帐！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "刘备进帐。"
        },
        {
          "character": "刘备",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "西皮快板",
          "text": "盟主帐中唤一声， 倒叫刘备犯叮咛。 迈步且把宝帐进， 盟主发怒为何情？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "参见盟主。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "唗，大胆刘备，我大将颜良，被红脸大汉，刀劈落马，定是你二弟关云长所为！ 来啊，将刘备推出斩了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "且慢，容备一言奉告。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "明公只听一面之词，而绝往日之情耶？备自徐州失散，二弟云长未知存亡，天 下同貌者颇多，岂赤面长髯之人，即为云长？望公思之。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "唔呼呀，不是使君明言，险些误伤好人。使君起过一旁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "谢明公。"
        },
        {
          "character": "文丑",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文丑上。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "哇呀……"
        },
        {
          "character": "文丑",
          "type": "唱",
          "text": "听说颜良把命丧， 不由某家怒满堂。 迈步且把宝帐上——"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "主帅！"
        },
        {
          "character": "文丑",
          "type": "唱",
          "text": "誓与颜良报冤枉。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "主帅，探马报道，颜良被红脸大汉，刀劈落马。末将愿讨一支将令，与颜良报 仇雪恨啊！"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "将军有此胆量？"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "有此胆量！"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "好，命你带领三万人马，与颜良报仇雪恨，不得有误！"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "且慢，文将军，备愿相助于你。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "住了，行军有你跟随，与军中不利。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "休出此不利之言！将人马拨与刘使君三千，归入后队。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "众将官，带马阵前去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁绍上马，下。四龙套、四文堂、四大刀手、文丑同随下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "文丑",
          "type": "内西皮导板",
          "text": "杀气连天稠云散——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大刀手、文丑同上。"
        },
        {
          "character": "文丑",
          "type": "唱",
          "text": "旌旗遮盖半壁天。 鞭梢一指催马趱， 刘备紧追马加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "参见文将军。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "使君赶来何事？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "文将军，此去阵前，若遇我二弟云长，不可与他交战！"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "我与你二弟云长，并不相认。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赤面长髯，就是我二弟，不可交战。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "两军交锋，哪里顾得许多！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待备去到阵前，高坡之上，执一红灯，若是我二弟出马，我将红灯坠下，将军 千万不可交战，备说他来降！"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "好，就依使君。请先过渡。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备先行了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、四龙套同下。"
        },
        {
          "character": "文丑",
          "type": "白",
          "text": "登舟去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大刀手、文丑同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁同上。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "千军列队伍，万马扎团营。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "诸位将军请了！"
        },
        {
          "character": "夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "前者关云长，斩了颜良，解了白马之围。曹丞相进朝启奏，我等在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套、二旗牌、郭嘉、程昱、曹操同上。"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "谢丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将可齐？"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "俱已到齐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "关羽可曾到此？"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "尚未到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看旌旗招展，关将军来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "月华旗手、马童同上，大纛旗引关羽同上。〖吹打〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军，接旨。圣旨下。"
        },
        {
          "character": "关羽、张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "万岁。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "跪听宣读！诏曰：关羽解除白马之围，加封汉寿亭侯，众将各升三级。旨意读 罢，望诏谢恩。"
        },
        {
          "character": "关羽、张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看印拜过。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。关羽接印，交马童捧印过去。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恭喜将军，贺喜将军。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大家之喜。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "备得有酒，与二将军、诸位将军同饮。"
        },
        {
          "character": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "谢丞相。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某当奉陪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁分坐。"
        },
        {
          "character": "关羽、张辽、夏侯惇、乐进、徐晃、许褚、李典、曹洪、曹仁",
          "type": "同白",
          "text": "丞相请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀丞相：今有河北袁绍，差大将文丑，统领人马与颜良报仇。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "丞相，文丑与颜良报仇，末将愿带领人马，大战文丑。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗳！文丑乃河北大将，汝不可轻视。坐下！ 二将军请酒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "文丑讨战！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "丞相，文丑讨战，待末将出马，生擒那文丑进帐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗯，小小年纪，出此狂言，还不坐下。 二将军请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "文丑营外骂阵。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唔呼呀，河北名将，一个个如此英勇，真名不虚传也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽怒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯，某看文丑，不是前来讨战，分明是前来送死！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "何出此言？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某在白马坡斩了颜良，文丑前来报仇。某不才愿讨一支将令，斩文丑首级，献 与丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军斩了颜良，又要出战，忒已劳倦。先命众将出马，倘若不胜，再请将军出 战。 众将官！粮草先行，人马在后。"
        },
        {
          "character": "徐晃、张辽",
          "type": "同白",
          "text": "且慢，粮草先行，那厮劫去粮草，我军不战自乱。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫用兵之计，非汝等所知。徐晃、张辽，命你二人押粮前行，附耳上来。"
        },
        {
          "character": "徐晃、张辽",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、徐晃同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众位将军，二队接杀。"
        },
        {
          "character": "夏侯惇、乐进、许褚、李典、曹洪、曹仁",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇、乐进、许褚、李典、曹洪、曹仁同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军！众将不胜，将军出马不迟。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相啊！"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "赤兔战马声嘶喊， 青龙偃月金光寒。 白马坡曾把颜良斩， 河北的儿郎心胆寒。 辞别丞相跨雕鞍， 斩奸除恶不费难。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、月华旗手、马童、大纛旗同下。"
