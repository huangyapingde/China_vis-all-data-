        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "战船一列入虎啸。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "叔父，小侄在此，请速上船。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "原来是贤侄。众将，快快上船者！"
