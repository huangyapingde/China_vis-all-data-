{
  "script_id": "70003119",
  "title": "汉津口",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "刘琦",
      "hangdang": "小生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "许褚",
      "hangdang": "净"
    },
    {
      "name": "张辽",
      "hangdang": "老生"
    }
  ],
  "plot": "荆州刘表亡故，其子刘琮献荆州与曹操。刘备闻知，弃新野，欲取荆州。曹兵追赶甚急，赵云长坂坡突围，\n张飞当阳桥上阻挡曹兵。刘备率众退至汉津口，时诸葛亮已派关羽从江夏搬兵迎击，挡住曹兵。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "威震乾坤，扶汉室，一点丹诚，秉赤心！"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "忠义一腔贯古今，补天化日庆升平。英雄侪辈称夫子，怎比当年古圣人。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室关。可恨曹操，上欺天子，下压群臣。诓哄孺子刘琮，献了荆襄，反 遭其害。某大哥弃了新野，欲取荆州。曹兵百万，追赶甚紧。因此孔明先生， 令吾来江夏，与公子刘琦，调兵救急。怎奈刘琦染病未愈，不能发兵。使某焦 躁也！"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "叹不尽炎汉家气运已倒， 汉刘邦三尺剑斩却蟒蛟。 承天意下咸阳灭秦除暴， 萧相国荐韩信火烧栈道。 楚霸王丧乌江波浪滔滔， 四百年锦江山雨顺风调。 王莽后出董卓今又曹操， 众黎民陷水火有苦难告。 我大哥帝室胄欲将国保， 时不至空使人枉费劬劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘琦上。"
        },
        {
          "character": "刘琦",
          "type": "唱",
          "text": "这几日染沉病今日略好， 进帐去与叔父共议破曹。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "侄儿参见叔父！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "公子少礼！"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "啊，君侯。刘琦抱病失信，贻误大事。有罪，有罪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "公子贵恙痊愈，即速传令发兵，前去救应，恐皇叔悬望。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "叔父之事，小侄急如星火，适才已发令传谕，大小将官，府堂伺候。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "如此点将前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "公子，孔明军师到。"
        },
        {
          "character": "关羽、刘琦",
          "type": "同白",
          "text": "孔明先生为何来此？快快有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。龙套、车夫、诸葛亮同上。"
        },
        {
          "character": "关羽、刘琦",
          "type": "同白",
          "text": "参见先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师，某大哥现在何处？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此刻闲言不及叙了。主公兵败当阳，盼望救兵不到，故此我亲自前来求救。望 公子念昔日之情，即速接应！"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "哎呀！俺刘琦一闻叔父兵败之讯，恨不能插翅前去，怎奈患病数日，二叔父到 此，正欲发兵，不想军师到来。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "如此快快点齐众将。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "众将听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同上。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "参见军师！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "两旁听令！"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "就请军师发令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有僭了。二将军听令！命你领兵一万，从汉津陆地前往当阳，接应主公，不得 迟误！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "显神威领雄兵接应切要， 阻汉贼扶炎汉全在今朝。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "在府堂领将令晓谕小校， 斩曹操准备俺偃月宝刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "关云长此一去吓煞曹操， 还得要刘公子水路分劳。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "公子，你可带兵一万，从荆江水路前往救应。我自在夏口料理。舟船之上，须 要小心。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "刘琦",
          "type": "唱",
          "text": "多谢了好军师将兵提调， 去水路接皇叔何惧辛劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘琦下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "曾学得黄石公兵机玄妙， 秉忠心保皇叔辅佐汉朝。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "看二将军、刘琦水陆二路已去，谅可无虑。我趁此时，前去夏口料理。 左右，随我去者！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "这二路安排定谅已可保， 趁此时回夏口运筹略韬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众将、曹操同上。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "哎呀，好厉害呀！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊？张飞大吼一声，犹如霹雳一般！我营百万之众，闻声而逃。想昔日关羽曾 在许昌言道：张飞在百万军中，取上将之首级，犹如探囊取物一般。众将以后， 若遇张飞，不可轻敌，速速回兵者。"
        },
        {
          "character": "众将",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "西皮导板",
          "text": "张翼德长坂桥天神模样，"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "吓坏了曹孟德马蹄奔忙， 怕的是吼一声如同雷响， 怕的是诸葛亮埋伏桥旁。"
        },
        {
          "character": "许褚、张辽",
          "type": "内同白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、张辽同上。"
        },
        {
          "character": "许褚、张辽",
          "type": "同唱",
          "text": "又不曾打败仗丞相何往？ 急赶来扶玉鞍挽住丝缰。"
        },
        {
          "character": "许褚、张辽",
          "type": "同白",
          "text": "丞相休惊。张飞一人，何足深惧。急令回军，杀上前去，刘备可擒也！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "唉，尔等哪里知道也！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "擒刘备这三字再也休讲， 怕的是豹子头环眼老张。 幸喜得我首级还在项上， 且退兵息争战免了恐慌。"
        },
        {
          "character": "众将",
          "type": "白",
          "text": "丞相身经百战，会过多少有名上将，尚且不惧。今遇张飞，未曾交锋，闻声而 退。张飞虽勇，寡不敌众，丞相何其弱也？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将！非是老夫怕他，不战而退。昔日关云长有言，张翼德在万马军中，取上 将首级，犹如探囊取物，今恐有伤诸将，故此退走。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "若如丞相之言，我等皆是无用之辈了！"
        },
        {
          "character": "众将",
          "type": "同西皮摇板",
          "text": "随丞相经百战无人抵挡，"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "今日里遇张飞未分弱强。"
        },
        {
          "character": "曹仁",
          "type": "西皮摇板",
          "text": "大家去长坂桥莫要惊慌——"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将哪里去？"
        },
        {
          "character": "许褚、张辽",
          "type": "同白",
          "text": "擒桃园保丞相驾坐许昌。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "住了！尔等既要前去大战张飞，待老夫差人打探长坂桥消息，再战不迟。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "许褚、张辽听令！"
        },
        {
          "character": "许褚、张辽",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你二人即去长坂桥边，探看张飞如何？速来回报。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "你二人探消息小心前往， 遇张飞急跑回迟恐有伤。"
        },
        {
          "character": "许褚、张辽",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "说一派丧气话军威不壮，"
        },
        {
          "character": "许褚",
          "type": "西皮摇板",
          "text": "且去看是真否便知端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、许褚同下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "我本是惊弓鸟谨慎为上， 他二人初生犊不怕虎狼。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将！尔等休逞血气之勇，藐视张飞。我今说与尔等听者！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "只见他眼与须那等怪相， 便可知战吕布天下名扬。 我与你惜性命岂可孟浪， 那张飞丈八矛英勇非常。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许褚、张辽同上。"
        },
        {
          "character": "许褚、张辽",
          "type": "同西皮摇板",
          "text": "探知他退当阳回复丞相， 霎时间影无踪拆断桥梁。"
        },
        {
          "character": "许褚、张辽",
          "type": "同白",
          "text": "启禀丞相：那张飞拆断桥梁而去。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊，那张飞拆断桥梁而去！哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "听此言不由人大笑拍掌， 谅张飞他也知曹某之强。"
        },
        {
          "character": "众将",
          "type": "同西皮摇板",
          "text": "适才间欲退兵多少惆怅， 问丞相因何事喜气眉扬。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "丞相，为何发笑？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我不笑别人，只笑张翼德到底怕我，拆桥而走。众将官！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传令速搭浮桥三座，今夜便要过去，擒那刘备。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "丞相此去，恐诸葛亮用诱兵之计，不可轻去。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张飞一勇之夫，岂有此智。搭桥只恐不及，传令众将，各取大石一块，填平河 溪，追赶刘备，违令者斩！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "又有兵又有将谁能阻挡， 投砂石便可以填平长江。 擒刘备釜底鱼休得轻放， 再遇见猛张飞有我莫慌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、众将同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "糜竺、糜芳、甘夫人、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "败当阳过长江夏口逃奔， 猛回头望不见襄阳县城。 堪可叹十余万百姓生灵， 刘荆州生劣子误了黎民。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎，想我刘备，好生命苦！实指望困守新野，缓图功业；谁知兵败当阳，竟成 画饼。子龙虽然救得甘夫人，还有那糜夫人与阿斗尚无着落。三弟又去接应， 未知吉凶。使我好不放心。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "主公但请放心，子龙、翼德，定保阿斗无恙也！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "纵然救得此子，怎奈新野十万百姓身遭惨毒，好不伤心人也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "自桃园三结义誓扶汉鼎， 与关张投公孙建立功勋。 在安喜鞭督邮弃了县印， 仗大义救孔融陶谦让城。 收吕布却反被吕布兼并， 饮曹操青梅酒一场虚惊。 失徐州投河北袁绍不信， 幸喜得关二弟挂印封金。 弟兄们古城会团圆侥幸， 又失机投荆州新野安身。 吃尽了千般苦万种悲恨， 到如今反落得奔波飘零。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人啼哭。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "看起来功业事无有凭准， 不由人伤心处泪满衣襟。"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "主公慢走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "血染了素白袍银甲红映， 乱军中救不出糜氏夫人。 见主公忙下马惶愧不定，"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哎呀主公啊！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "失夫人臣之罪万死犹轻。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "可怜你血染袍勇力用尽， 因何事忽然间两泪淋淋？ 这其间反叫我惶愧不定， 恨只恨福分浅有累贤卿。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊，子龙，吃苦了！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哎呀主公啊！赵云之罪，万死犹轻。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊，何耶？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "糜夫人身带箭伤，不肯上马，投井而死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人哭泣。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云只得推倒土墙，填井掩埋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备哭泣。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "云便怀抱公子，力突重围，赖主公洪福，幸而得脱。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "阿斗何在？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "适才公子尚在怀中啼哭，此时不见动静，想是不保了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人惊哭。"
        },
        {
          "character": "甘夫人",
          "type": "白",
          "text": "速速看来！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "待俺解甲看来。咦！他倒睡着了！幸得公子无恙，主公请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备接过阿斗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "小畜生！为了你这孺子，几乎伤我一员股肱大将也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "说不得年半百子是根本， 为孺子险丧我股肱之臣。 思想起怒冲冲要尔做甚？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备欲摔阿斗。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "我岂肯学袁绍溺爱不明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人哭泣。"
        },
        {
          "character": "甘夫人",
          "type": "白",
          "text": "哎呀皇叔啊！"
        },
        {
          "character": "甘夫人",
          "type": "唱",
          "text": "赵子龙行忠勇幸无伤损， 小阿斗也算是死里逃生。 此时间真可算险中侥幸，"
        },
        {
          "character": "甘夫人",
          "type": "白",
          "text": "喂呀呀呀！"
        },
        {
          "character": "甘夫人",
          "type": "唱",
          "text": "望垂怜乞恕他无知无闻。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公啊！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "在疆场受辛劳云之本分， 又何必将公子摔落埃尘？ 似这般爱将意犹如尧舜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云哭泣。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "赵子龙愿献上碧血丹心。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "蒙主公如此厚恩，云虽肝脑涂地，也不能相报于万一也！"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "蒙大德待赵云如此信任， 纵然是碎肝脑也难报恩。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "我与你患难交兄弟相称， 又何必分彼此谈论报恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备递阿斗与甘夫人。"
        },
        {
          "character": "甘夫人",
          "type": "唱",
          "text": "可怜我小姣儿险些丧命， 最可叹殉难的糜氏夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军门、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "长坂桥喝一声曹兵退净， 到柳林说与我大哥知闻。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥！俺退了曹兵了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟，你是怎样退的？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺独立桥上，大喝一声，把那曹兵都吓跑了！小弟心生一计，将桥梁拆断，量 那曹兵一辈子也过不来了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，我弟勇则勇，惜乎失了计较。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊？怎么失了计较？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "曹操多谋，你今断桥，彼必来追赶矣！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "他被我一喝，倒退数里，为何反来追赶？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你不断桥，彼恐我有埋伏，不敢进兵。今既拆断桥梁，彼料我军怯战，必来追 赶。他有百万之众，江河可填石而过，岂惧一桥之断也！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "劝贤弟你休夸自己本领， 弄巧计反成拙惹来追兵。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公言得极是，速从小路投汉津而去。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎咦，张飞你错了！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "我只说拆桥梁又牢又稳， 想不到他有兵还能填平。 尊大哥柳林下你且略等——"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "我再去搭起了桥曹兵必惊。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "笑三弟说此话又乖又蠢， 曹孟德又不是三岁童生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内呐喊声。"
        },
        {
          "character": "赵云",
          "type": "唱",
          "text": "尘土起乌云合遥见旗影，"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "紧战袍忙上马准备战争。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "哎呀主公啊！后面尘土四起，曹兵即至，速上马前去。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟开路，子龙押后队，汉津去者！"
        },
        {
          "character": "众将",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "受不尽凶险苦锋剑白刃， 战不退奸雄贼乱国曹兵。 车和马向夏口风卷云紧， 但愿得有船只起渡汉津。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众将引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "追桃园兵将勇龙吟虎啸， 此一番胆包天个个英豪。 似簇拥转眼时小山过了， 望平原是一派旌旗飘摇。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "启丞相：已是长坂断桥了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "尔等各抱石头一块，填塞溪河，追赶刘备，违令者斩。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "每一人抱一块不分大小， 填平这小溪河也算功劳。 顷刻间水断流成了路道，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "呵哈哈哈！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "何必要费工夫搭起浮桥。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "启丞相：桥已填满。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将听令！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "今日刘备，如同釜中之鱼，牢中之虎。若不就此擒之，一如放鱼入河，纵虎归 山。须速努力向前，不得违误！"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "釜中鱼牢中虎容易擒到， 休放他入大海归山脱逃。 生擒者万户侯凌烟阁表， 要成功忙催鞭就在今朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "关羽",
          "type": "内西皮导板",
          "text": "青龙偃月威风凛，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "赤兔胭脂起风云。 提起曹操冲天恨， 许田射鹿藐视君。 弄权意在夺汉鼎， 犹如王莽之后身。 桃园弟兄秉忠正， 誓必扶转汉乾坤。 相逢曹操难饶命， 但愿除奸在汉津。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、马童、关羽同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众人引张飞、赵云、糜竺、甘夫人抱阿斗、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "兵败当阳何足论， 借兵江夏渡汉津。 曹兵百万难抵挡， 车滞马迟愈觉慌， 前行不走举目望——"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "汪洋一片是长江。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唔呼呀！行至此地，前有大江，后有追兵，这便如何是好？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥！怕些什么？曹兵到来，待俺与他决一死战。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，人虽不怕，马匹困乏，如何是好？"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "此时已难逞强壮， 务须留意各紧防。 加鞭催马向前往，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "奋勇抗敌休着慌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹将同上，开打。刘备、众人同下，同上。曹将同追下，追上，开打。曹操暗上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "二次又入虎穴境，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众将官！军中骑白马的，就是刘备。有人生擒者，加封万户侯。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "把话说与列位将军： 我本是新野县逃难的百姓， 望列位放我走感你等大恩。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "不要听他的谎言。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "勒缰催马往外闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "后面来了翼德张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞救刘备同下。曹操率众将同追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四马童、马童、关羽同上。张飞、刘备、众人同上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥你来了，杀这些王八日的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、众人同上。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "来将？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "汉寿亭侯关。"
        },
        {
          "character": "曹操",
