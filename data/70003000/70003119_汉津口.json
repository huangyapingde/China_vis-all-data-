          "character": "众将",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "天幸贤侄接应到， 不然残兵无下梢。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "小侄迎接来迟，有罪，有罪！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，不想蔡瑁、张允，如此不仁，失陷荆州，以致遭此离乱。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "此乃家门不幸也！叔父且请至江南再议。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "言得极是。摆桨速行。"
        },
        {
          "character": "刘琦",
          "type": "白",
          "text": "艄手驾桨速行！"
        },
        {
          "character": "众将",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，波浪滚滚，人生碌碌，汉室倾颓，功名不遂，好不伤感人也！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "长江滚滚如海潮， 汉室社稷似波涛。 英雄容颜易衰老， 不立功勋非英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内鼓声。众人同望。"
        },
        {
          "character": "众将",
          "type": "白",
          "text": "禀主公：江面上来战船无数。"
