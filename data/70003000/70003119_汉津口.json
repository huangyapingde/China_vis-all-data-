        },
        {
          "character": "刘备",
          "type": "白",
          "text": "快请过船。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。诸葛亮过船。"
        },
        {
          "character": "诸葛亮",
