    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、孙乾、糜竺、糜芳、简雍、诸葛亮、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "战鼓喧天鸾铃响， 敌败我胜喜洋洋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、赵云、关平、刘封同上。"
        },
        {
          "character": "关羽、赵云、关平、刘封",
          "type": "同白",
          "text": "交令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "参见大哥。 军师，咱老张斩了夏侯惇，人头献上。 啊？未曾听见，你的好阴阳！好八卦！道俺擒不着那夏侯惇，咱斩了夏侯惇的 首级，特来交令。 啊，军师！明知咱老张旗开得胜，马到成功，斩来夏侯惇之头，你就该迎接咱 老张，将军师大印，付咱执掌。你在那厢，大模大样，扬扬不睬，是何道理？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三将军回营，想是那夏侯惇被你擒住了？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "擒到不曾擒着，斩有夏侯惇的人头，特来交令！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟，此非夏侯惇之头，乃是他弟夏侯兰的首级。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊！糟了，糟了！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "嘿嘿嘿嘿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮冷笑。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "升帐！来，将翼德推出斩了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且慢！军师，桃园弟兄，誓同生死，今日斩了翼德，我桃园弟兄，就不义气了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "是呀！军师开恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "恐众将不服。"
        },
        {
          "character": "关羽、赵云、关平、刘封",
          "type": "同白",
          "text": "我等皆服，望军师开恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "翼德！本当将你斩首，看在主公金面，诸位将军讲情，将你饶过。从今以后， 立功折罪。你要仔细了，你要打点了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥！小弟实实服了军师了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟！吾得孔明军师，可称得如鱼得水。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咋，咋，咋！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今日取功，乃诸位将军之力，后帐摆宴，与众将军贺功，与三将军压惊。正是："
