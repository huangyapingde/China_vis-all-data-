{
  "script_id": "70003118",
  "title": "火烧博望坡",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "夏侯惇",
      "hangdang": "净"
    }
  ],
  "plot": "刘备三顾茅庐，请出诸葛亮，占据新野，操练兵马，军势大振。曹操命夏侯惇前来攻打。诸葛亮分遣关羽、\n赵云等迎击，惟张飞不听调遣。曹兵至，诸葛亮火烧博望坡，大败曹兵。关羽讲情，张飞幸免惩处。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、毛玠、崔琰、司马懿、夏侯惇同上。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "打道辕门！"
        },
        {
          "character": "毛玠、崔琰、司马懿、夏侯惇",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "夏侯惇。"
        },
        {
          "character": "毛玠",
          "type": "白",
          "text": "毛玠。"
        },
        {
          "character": "崔琰",
          "type": "白",
          "text": "崔琰。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "司马懿。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "众位将军请了！"
        },
        {
          "character": "毛玠、崔琰、司马懿",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "丞相大典之期，定然兴师，征剿孙、刘，大家辕门伺候。 众将官，打道辕门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。当场挖门。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "丞相尚未升帐，我等打座片时。"
        },
        {
          "character": "毛玠、崔琰、司马懿",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大刀手、四下手、四藤牌手、徐庶、荀彧、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引",
          "text": "智谋压群雄，统雄师，掌生杀，独霸朝中。"
        },
        {
          "character": "毛玠、崔琰、司马懿、夏侯惇",
          "type": "同白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站立两厢！"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "威名压群雄，统领百万兵。中原归我掌，孙、刘顷刻终。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫孟德曹。汉室称臣，官居丞相之职，扫荡各路烟尘。可恨桃园弟兄，败走 古城，霸占新野之地，今不扫除，恐为后患矣！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "丞相，近闻刘备在新野，每日操演士卒，必为后患。末将情愿统领人马，灭却 刘备。"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "且慢！刘备乃英雄也。现今请诸葛以为军师，足智多谋，不可轻敌。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "刘备鼠辈，我必生擒之！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "将军且勿轻视玄德，今刘备请诸葛亮为辅，如虎生翼矣！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "元直，诸葛何人也？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "亮字孔明，道号卧龙，有经天纬地之才，出鬼入神之计，真当今之奇士，非可 小视耳！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "比公如何？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "庶焉敢比亮。庶乃萤火之光，亮乃皓月之明也。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "元直差矣。我看诸葛亮如草芥耳，何足惧哉！我若不能一战生擒刘备，活捉诸 葛，愿将首级献与丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "汝等不必争论。夏侯惇听令！拜你为都帅，于禁、李典、韩皓、夏侯兰为副将， 曹真、曹仁、曹洪、文聘协力相助，领兵十万，直抵博望，以窥新野。早传 捷报，以慰我心，不得违误！"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "夏侯惇",
          "type": "唱",
          "text": "元直说话真量小， 荀彧先生也不高。 辞别丞相仰天笑， 洋洋得意逞英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯惇下。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "骏马初行恨路小，"
        },
        {
          "character": "荀彧",
          "type": "唱",
          "text": "损兵折将在今朝。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "看他此去威风好，"
        },
        {
          "character": "荀彧",
          "type": "唱",
          "text": "回来凤凰脱翎毛。"
        },
        {
          "character": "徐庶",
          "type": "唱",
          "text": "你我所言他不晓，"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "丞相呀！"
        },
        {
          "character": "荀彧",
          "type": "唱",
          "text": "定中诸葛计笼牢。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "老夫威名谁不晓， 何足惧哉小儿曹； 三军各自归营号， 眼见中原归孤曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李典、于禁、夏侯兰、韩皓、曹真、曹洪、曹仁、文聘同上。同起霸。"
        },
        {
          "character": "李典、于禁、夏侯兰、韩皓、曹真、曹洪、曹仁、文聘",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "李典。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "于禁。"
        },
        {
          "character": "夏侯兰",
          "type": "白",
          "text": "夏侯兰。"
        },
        {
          "character": "韩皓",
          "type": "白",
          "text": "韩皓。"
        },
        {
          "character": "曹真",
          "type": "白",
          "text": "曹真。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "曹洪。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "曹仁。"
        },
        {
          "character": "文聘",
          "type": "白",
          "text": "文聘。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "众位将军请了，都督升帐，两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点。四下手、四藤牌手、四龙套、四大刀手、夏侯惇同上。"
        },
        {
          "character": "夏侯惇",
          "type": "念",
          "text": "匹马单刀抖威风，三国上将夏氏雄。统领战将雄兵众，夺取新野除枭雄。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "本督，夏侯惇。奉丞相将令，夺取新野，剿灭刘备。众位将军，人马可齐？"
        },
        {
          "character": "李典、于禁、夏侯兰、韩皓、曹真、曹洪、曹仁、文聘",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "起兵前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "弟兄三顾卧龙岗， 聘请诸葛下山岗。 文韬武略智谋广， 元直之言不虚谎。 暂居新野屯兵将， 扭转汉室锦家邦。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，请二将军、三将军进帐！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "请二将军、三将军进帐。"
        },
        {
          "character": "关羽、张飞",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "三顾茅庐卧龙岗，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "迎风踏雪受凄凉；"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "聘请高贤难测量，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "活活气坏翼德张。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "参见大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟、三弟少礼。请坐。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "谢座。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟为何闷闷不语？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "非是小弟烦闷。弟兄三顾，聘请高贤，自到吾营，未见丝毫奇才，大哥相敬如 师，实实令人罕见！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我记水镜先生之言，卧龙、凤雏，若得一人，可安天下。今得诸葛辅助，如鱼 得水。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥！那孔明年幼娃娃，有什么才学，大哥待他过甚。又无见他真实效验，凭 他花言巧语，指挥军情。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟、三弟，可知昔日汉韩信，当时年幼，高主二十四拜，登台拜帅之事乎？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "他如何比得！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有夏侯惇，统领人马，攻打博望、新野。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥！何不使鱼去打，使水去冲？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "智赖孔明，勇须二弟，何可推诿，弟等暂退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请军师进帐。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "军师进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "豫州当年叹孤穹，何须南阳有卧龙。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢座。主公传山人进帐，敢是曹操兴兵前来吗？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是。探马报道：夏侯惇统兵攻打新野、博望，先生计将安出？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "自古道：兵来将挡，水来土屯。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生就请遣将对敌。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "但恐关、张不听吾令，亮欲向主公暂假剑印。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "就依先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今乃黄道吉日，速聚众将，帐前听令。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "提兵调将按军令，"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "保国常怀忧虑心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、刘备同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞、赵云、关平、刘封同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "驰骋疆场美名标，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "敌人闻名望风逃。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "如鱼得水归刘主，"
        },
        {
          "character": "关平、刘封",
          "type": "同念",
          "text": "同心协力保汉朝。"
        },
        {
          "character": "关羽、张飞、赵云、关平、刘封",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关羽。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "张飞。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "关平。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "刘封。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "诸位将军，诸葛高贤升帐，看他如何调度。吾等两厢伺候！ （四龙套、四上手、四马童、四月华旗手、四长枪手、四火牌手、简雍、孙乾、糜竺、糜芳、刘备、诸葛亮 同上。诸葛亮拜印拜剑。）"
        },
        {
          "character": "关羽、张飞、赵云、关平、刘封",
          "type": "同白",
          "text": "参见军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "诸位将军少礼！"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "避世隐居在山林，三顾茅庐蒙君恩。韩信登台令樊哙，山人今日学先生。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人复姓诸葛名亮字孔明，道号卧龙。蒙主公敬拜为军师，扫除曹瞒蝼蚁之众。 昨日樊城调回赵云，今此一战，惊破曹瞒，以服关、张。众位将军，博望之 左，有山名曰玉山，山右有林名安林，可以埋伏。军马各自当先，今此一战， 曹兵失败，叫他一世惧怕吾军矣！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请问军师，吾等皆去迎敌，未审军师却作何事？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我只坐守此城。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咋，咋，咋！哇呀呀呀！军师！我等都去厮杀，你却在此城中坐守，逍遥自在， 你倒快乐的紧呀！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "岂不闻：运筹帷幄之中，决胜千里之外。剑印在此，违令者斩！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咋，咋，咋！哇呀呀呀！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "闻言怒发三千丈， 活活气坏翼德张。 我军个个年高长， 提兵何用村夫郎。 老张遵令去打仗， 除非红日出西方。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三弟呀！"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "三弟说话太莽撞， 莫忘桃园一炉香。 军师年幼剑印掌， 弟兄聘请下山岗。 你我不遵他令将， 教他怎伏众儿郎。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "众将休要纷纷讲， 顺者昌来逆者亡。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今日此战，非比寻常。赵云听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你统领本部人马，埋伏博望坡后，曹兵到此，且战且败，不得违误。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "关平、刘封听令！"
        },
        {
          "character": "关平、刘封",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带领军卒，准备引火之物，埋伏博望两厢，等候初更时分，速速放火，不得有 误！"
        },
        {
          "character": "关平、刘封",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平、刘封同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二将军听令！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带领一千人马，埋伏玉山南面，火起之时速速杀退贼兵，不得有误！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三将军听令！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领五百军卒，埋伏背后山谷之中，看南面火起，上博望城抢屯粮草，用 火焚烧。若遇夏侯惇，杀退不可紧追。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "军师讲什么杀退不可紧追，俺今若遇夏侯惇，定要生擒入帐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "慢说你生擒夏侯惇，你若得夏侯惇之首，山人愿将军师大印，付你执掌。你若 干办不来，便怎么样？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咋，咋，咋！军师，俺若擒不得夏侯惇，定斩那贼首级献上；如若干办不来， 愿将咱的黑头号令辕门。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军无戏言。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "愿立军状。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "当帐写来。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "军师请看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "待山人收下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊？慢来，慢来！军师若要此状，必须我们双手交换。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "好好好！山人也立军状。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。诸葛亮写。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将此军状，烦劳主公收讫。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待我收起。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥！好好收存，咱老张的性命，还在里面。 三军的！马来，马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "糜竺、糜芳听令！"
        },
        {
          "character": "糜竺、糜芳",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带领五百人马，紧守新野县门，不得违误！"
        },
        {
          "character": "糜竺、糜芳",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜竺、糜芳同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "孙乾、简雍听令！"
        },
        {
          "character": "孙乾、简雍",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "准备酒宴，安排功劳簿伺候！"
        },
        {
          "character": "孙乾、简雍",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾、简雍同下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我军兵微将寡，今次胜负如何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎，主公啊！"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "我主休疑心安定， 军少将勇敌万人。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "但愿旗开早得胜， 运筹帷幄赖先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、刘备、众人同下。"
        }
      ]
