          "character": "张继昌",
          "type": "白",
          "text": "哎呀，太爷呀！实实无有此事。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "哈哈，这么大岁数耍无赖呀。 来呀，与我乱棍打出去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同轰打张继昌。苗信退堂下。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "好狗官哪！"
        },
        {
          "character": "张继昌",
          "type": "西皮摇板",
          "text": "狗赃官行事令人恨， 他官官相护欺良民。"
        },
        {
          "character": "张继昌",
          "type": "叫头",
          "text": "好王法呀！好王法！"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "熊祥这贼串通狗官将我女儿押入监中，将我打……下堂来。这……也罢！拚着 我的老命不要，上告于他。我就是这个主意，我就是这个主意。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张继昌下。"
        }
      ]
