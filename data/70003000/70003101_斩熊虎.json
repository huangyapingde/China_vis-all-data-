{
  "script_id": "70003101",
  "title": "斩熊虎",
  "alias": [
    "关公出世"
  ],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "生"
    },
    {
      "name": "熊虎",
      "hangdang": "净"
    },
    {
      "name": "张继昌",
      "hangdang": "老生"
    },
    {
      "name": "张鸾姣",
      "hangdang": "旦"
    },
    {
      "name": "苗信",
      "hangdang": "丑"
    },
    {
      "name": "熊祥",
      "hangdang": "丑"
    }
  ],
  "plot": "蒲州太守熊虎之子熊祥，勾结县令苗信，强占士人张继昌之女张鸾姣。关羽闻讯不平，去公堂辩理，打死恶\n霸熊祥，火焚衙署，劈监救出张鸾姣和所有犯人，逃至圣母庙。熊虎率众捕快追赶，火焚庙宇。关羽从火中\n冲出，在路旁小河净面，脸色变成丹红。时熊虎从后面追来，关羽劈死熊虎，逃奔范阳。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍抬礼物同上，四文官、四武官、苗信同上，站门。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "众位年兄、年弟请了。"
        },
        {
          "character": "四文官、四武官",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "熊太守千秋之日，我们大家一同前去拜寿。"
        },
        {
          "character": "四文官、四武官",
          "type": "同白",
          "text": "一同前往。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "开道，熊府去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "熊祥上。"
        },
        {
          "character": "熊祥",
          "type": "念",
          "text": "吾父蒲州太守，仗势惯把人压。最喜美貌女姣娃，官府我都不怕。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "我，熊祥。今乃我父寿诞之日，本州大小官员，必定前来拜寿。我不免请爹爹 出来，与他老人家拜寿。 有请爹爹。"
        },
        {
          "character": "熊虎",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊虎上。"
        },
        {
          "character": "熊虎",
          "type": "念",
          "text": "老夫官居为太守，全凭势力压蒲州。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "爹爹请上，孩儿拜寿。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "生受你了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊福上。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "启禀太守：文武官员前来拜寿，礼单呈上。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍抬礼物同上，四文官、四武官、苗信同上。"
        },
        {
          "character": "苗信、四文官、四武官",
          "type": "同白",
          "text": "太守请上，门生等拜访寿。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "不必拜了，哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊虎笑。众人同拜。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "酒宴摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。熊虎正坐，四文官、四武官分两边坐。〖牌子〗。众人同饮酒。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "再饮几杯。"
        },
        {
          "character": "苗信、四文官、四武官",
          "type": "同白",
          "text": "我等告辞。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "送客。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四青袍、四文官、四武官、苗信同出门，同下。熊虎暗下。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "哎呀可完事啦。 熊福，我在家闷极啦。咱们爷儿俩，外边游玩游玩。福儿带路。"
        },
        {
          "character": "熊祥",
          "type": "唱",
          "text": "主仆二人出府门， 寻找美貌女佳人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊祥、熊福同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "车夫、张鸾姣、张继昌同上。"
        },
        {
          "character": "张继昌",
          "type": "西皮摇板",
          "text": "只因内弟身染病， 带领女儿去探亲。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "老汉张继昌。只因内弟身染病症，带领小女前去看望。幸喜内弟病休痊愈，回 转家中。 女儿，我们速速回去吧。"
        },
        {
          "character": "张继昌",
          "type": "西皮摇板",
          "text": "心忙似箭往家奔——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊祥、熊福同上，熊祥看张鸾姣。张继昌、张鸾姣、车夫同下。"
        },
        {
          "character": "熊祥",
          "type": "西皮摇板",
          "text": "这个女子动我心。 熊福带路回府门，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊祥、熊福同走圆场，同回家。"
        },
        {
          "character": "熊祥",
          "type": "西皮摇板",
          "text": "你快想妙计娶佳人。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "大爷，您看上那个女子啦吧？"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "不错，你认识吗？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "那个老头子叫张继昌，就在前面大街居住。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "那么你就给我提这门亲事自怎么样？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "您放心，我一说就成。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "事成之后，重金赏赐。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "您听喜信吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊祥、熊福自两边分下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张继昌、张鸾姣同上，同进门，张鸾姣下。院子自下场门上。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "家中可有人来访？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "无人来访。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊福上。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "门上有人吗？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "烦劳通禀一声：熊府管家求见。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请稍待。 启禀员外：外面有熊府管家求见。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "我与熊府并无来往呀！好，请他进来。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "参见张员外。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "罢了。到此何事？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "恭喜员外，贺喜员外！"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "我奉熊府之命，前来向小姐求婚，与我家公子结为秦晋之好。您是一定不能推 辞啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张继昌冷笑。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "嘿嘿嘿……熊府父子仗势欺人，人人愤恨，老汉是安善良民，岂肯与那万恶官 吏结亲。 家院，将他轰了出去！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "出去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张继昌、院子同下。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "老小子，瞧着我的吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊福出门，走圆场，进门。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "有请公子。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊祥上。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "回来啦，亲事成啦吧？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "把我骂回来啦。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "这真是给脸不要脸。你有什么好主意，把那小妞弄到手才好？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "这事好办。咱们造一张假字据，上写“张继昌借银三千两，限期三月归还。三 个月不还，情愿将女儿送上熊府为妾。空口无凭，立字为证。”拿着这张假字 据，到县衙去求苗老爷作主，苗知县是老太爷的门生，一定替您办好这件美事。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "好，好！你就快写去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊福下。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "好妙计也！"
        },
        {
          "character": "熊祥",
          "type": "西皮散板",
          "text": "满口扯谎摇舌剑， 尽将假话作真言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊福上。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "写好啦。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "带路县衙走走！"
        },
        {
          "character": "熊祥",
          "type": "西皮散板",
          "text": "见机而行随机变， 花言巧语胡乱谈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊祥、熊福同走圆场，到县衙。"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "哪位听事？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子上。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "熊福",
          "type": "白",
          "text": "熊公子求见。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "请稍候。 禀老爷：熊公子求见。"
        },
        {
          "character": "苗信",
          "type": "内白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苗信上，迎熊祥同进。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "师兄请坐。"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "师兄驾临，有何见教？"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "有人欺诈小弟，这有字据一张，请师兄作主。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苗信接过字据，看。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "岂有此理！这还了得！ 传捕快前来。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "捕快进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四捕快同上。"
        },
        {
          "character": "四捕快",
          "type": "同白",
          "text": "太爷有何吩咐？"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "你等随同熊公子，将张继昌女儿拿来听审！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊祥、熊福、四捕快同下。苗信暗下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张继昌、张鸾姣同上。"
        },
        {
          "character": "张继昌",
          "type": "念",
          "text": "收拾俱停当，"
        },
        {
          "character": "张鸾姣",
          "type": "念",
          "text": "避祸奔他乡。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "儿啊，那熊府说亲不成必来肇事。你我赶快他乡躲祸去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四捕快、熊福、熊祥同上。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "你们是作什么的？"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "你借我的银子，还我不还？"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "你们熊府欺人忒甚，哪个借你的银子？"
        },
        {
          "character": "熊祥",
          "type": "白",
          "text": "不与你多说，咱们堂上说去，把他女儿带走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四捕快、熊福带张鸾姣同下。张继昌揪熊祥，被熊祥推倒。熊祥下。张继昌追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、苗信同上。四捕快带张鸾姣同上。"
        },
        {
          "character": "张鸾姣",
          "type": "白",
          "text": "叩见太爷。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "你是张继昌的女儿吗？"
        },
        {
          "character": "张鸾姣",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "你父借熊府三千两银子，不能偿还，将你送上熊府，你知道吧？"
        },
        {
          "character": "张鸾姣",
          "type": "白",
          "text": "无有此事啊。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "什么无有此事！ 来呀，传女禁卒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "禁婆上。"
        },
        {
          "character": "禁婆",
          "type": "白",
          "text": "伺候老爷。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "将此女带去收监。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "禁婆对张鸾姣。"
        },
        {
          "character": "禁婆",
          "type": "白",
          "text": "随我走吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "禁婆押张鸾姣同下。张继昌上。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "冤枉！"
        },
        {
          "character": "青袍",
          "type": "白",
          "text": "有人喊冤。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "上堂回话。"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "与太爷叩头。"
        },
        {
          "character": "苗信",
          "type": "白",
          "text": "你叫什么名字？有什么冤枉？"
        },
        {
          "character": "张继昌",
          "type": "白",
          "text": "小人张继昌，只因太守公子将我女儿抢来，求太爷作主。"
