{
  "script_id": "70003122",
  "title": "战长沙",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "黄忠",
      "hangdang": "老生"
    },
    {
      "name": "魏延",
      "hangdang": "净"
    },
    {
      "name": "韩玄",
      "hangdang": "老生"
    }
  ],
  "plot": "赤壁鏖兵，曹操惨败。刘备占据荆州，命关羽攻打长沙。守将韩玄命黄忠出战，马失前蹄，关羽释之。次日\n会战，黄忠箭射关羽盔缨，以报关羽不斩之恩。韩玄怒责黄忠通敌，将斩，魏延押粮归来，杀死韩玄，与黄\n忠同降刘备。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "壮志凌云冲霄汉，统领雄师扶汉鼎。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "赤人赤马秉赤心，青龙偃月建功勋。将令一出山摇震，某保大哥锦乾坤。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室关。桃园结义，誓同生死，三顾茅庐，聘请诸葛先生下山，攻无不取， 战无不胜。某与军师打赌争印，夺取长沙。今乃黄道吉日，正好兴师。 军士们！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "听某一令！"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "某奉军师将令差，"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "威风凛凛坐将台。 旌旗不住空中摆， 大小儿郎显英才。 此一番夺取长沙界， 个个奋勇不迟延。 某家出世威名在， 哪把长沙挂心怀。 三军与爷把马带， 施展虎威擒敌来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同上，同起霸。"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "英雄威名大，"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "疆场把敌杀。"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "全凭刀和马，"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "保韩镇长沙。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "姓黄名忠字汉升。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "姓魏名延字文长。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "将军请了。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "元帅升帐，你我两厢伺候。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝龙套、韩玄同上。"
        },
        {
          "character": "韩玄",
          "type": "引子",
          "text": "镇守长沙，掌兵权，保主家邦。"
        },
        {
          "character": "韩玄",
          "type": "念",
          "text": "堂堂男儿将，烈烈震疆场。全凭黄、魏将，与主定家邦。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "本帅，韩玄。奉丞相将令，镇守长沙。近闻桃园弟兄，兴兵前来，不免与黄、 魏二将，商议退敌之策。 来！黄忠、魏延进帐。"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "黄魏二将进帐！"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "报，（黄忠）（魏延）告进，参见元帅。 韩玄　　　黄忠、"
        },
        {
          "character": "魏延",
          "type": "同白",
          "text": "谢座！传末将等进帐，有何军情议论？"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "近闻桃园弟兄，兴兵前来。请二位将军进帐，商议退敌之策。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "且听探马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "关羽挑战！"
        },
        {
          "character": "韩玄、黄忠、",
          "type": "同白",
          "text": "再探！"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "元帅，关羽挑战，末将愿领人马生擒关羽进帐。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "慢、慢、慢着！老将军，想那关羽，文韬武略，战法精通，老将军出马，恐不 是关羽对手，待俺魏延出马，一战成功。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "魏将军，末将老则老这头上发，额下须；胸中韬略却还不老。有道是：虎老雄 心在，这年迈力刚强！"
        },
        {
          "character": "黄忠",
          "type": "西皮二六板",
          "text": "魏文长把话错来讲， 有几辈古人听端详： 赵国廉颇年高长， 力举千钧镇疆场。 昔日有个姜吕望， 八十二岁遇文王。 你道那关羽是好将， 强手之中还有强。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "老将军哪！"
        },
        {
          "character": "魏延",
          "type": "西皮快板",
          "text": "老将军休要逞刚强， 末将言来听端详： 关羽威名某久仰， 千里路上保皇娘。 过五关曾斩六员将， 擂鼓三通斩蔡阳。 你今此去恐难挡， 此任让与魏文长。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "你不能！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "你不能！"
        },
        {
          "character": "韩玄",
          "type": "西皮摇板",
          "text": "魏文长说话少志量， 甘把自家威风丧。 魏延暂且退宝帐， 黄忠进前听端详： 我今赐你一支令， 命你大战关云长。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "黄忠接令下宝帐， 那旁气坏魏文长。 抖擞精神把马上， 舍死忘生战一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手与黄忠带马，黄忠、四上手同下。"
        },
        {
          "character": "韩玄",
          "type": "西皮摇板",
          "text": "魏延听我把令降， 命你四路去催粮。"
        },
        {
          "character": "魏延",
          "type": "西皮摇板",
          "text": "韩玄小视魏文长， 压下不满且去催粮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "韩玄",
          "type": "西皮摇板",
          "text": "黄忠、魏延下宝帐， 且听探马报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝龙套、韩玄同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、关羽同上"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "兵到长沙！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "夺取长沙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、黄忠同上，会阵。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "呔，马前来的敢是关羽？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "关羽！你有多大本领，敢来夺取长沙？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "若问某家本领，你且听道："
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "勒马停蹄站疆场，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。二龙出水，转场。"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "黄忠老儿听端详： 某大哥堂堂帝王相， 当今皇叔天下扬。 某三弟翼德猛勇将， 大吼一声断桥梁。 某四弟子龙常山将， 长坂坡前救过小王。 三请军师诸葛亮， 神机妙算世无双。 某家出世斩熊虎， 匹马单刀斩颜良。 过五关曾斩六员将， 擂鼓三通斩蔡阳。 劝你早把长沙让， 稍若迟延在某的刀下亡。"
        },
        {
          "character": "黄忠",
          "type": "西皮二六板",
          "text": "勒住丝缰把话讲， 叫声蒲州关云长。 某家今年六旬上， 斩人犹如宰鸡羊。 你取长沙心妄想， 顷刻命你刀下亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、黄忠开打，关羽败下，黄忠追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽、四红龙套同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住！黄忠老儿，倒也骁勇。他若来时，拖刀计伤他！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上，开打，黄忠落马。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "呔，关羽！老夫跌下马来，你为何不杀？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某家出师以来，不斩落马之将，回营换马再战。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好一员老将！ 军士们，收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝龙套、韩玄同上。"
        },
        {
          "character": "韩玄",
          "type": "西皮摇板",
          "text": "黄忠领令去打仗， 胜负难测挂心上。 坐卧不安进宝帐， 汉升回来问端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、黄忠同上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "老将军胜负如何？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "两军交锋，不分胜败，明日末将出马，定要生擒关羽进帐。"
        },
        {
          "character": "韩玄",
          "type": "白",
          "text": "好，听本帅令下！"
        },
        {
          "character": "韩玄",
          "type": "西皮散板",
          "text": "你若擒得关云长， 凌烟阁上把名扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝龙套、韩玄同下。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "黄忠接令出宝帐， 倒叫老将无主张。"
        },
        {
          "character": "黄忠",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "今日阵前，某被关羽拖下马来，不忍伤我性命，反叫我回营换马，再决胜负。 似这等恩情，焉能不报。也罢！明日两军阵前，施起百步穿杨之技，只射盔缨 不射咽喉，以报他不杀之恩便了！"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "明日黄忠到阵上， 不把关羽咽喉伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "黄忠老将好武艺， 敢与关某来对敌。 我把黄忠好一比， 绵羊见虎把头低。 将身来到宝帐里……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "黄忠讨战！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "三军带过追风骑， 今日战场见高低。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、黄忠同上。会阵。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "黄忠，昨日饶你不死，今日又来送命不成？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "今日与你决一死战。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "口出不利之言，定被我擒。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、黄忠开打，黄忠败下，关羽追下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝龙套、韩玄同上。"
        },
        {
          "character": "韩玄",
          "type": "西皮散板",
          "text": "黄忠二次战场到， 不由本帅挂心稍。 下得马来上城道， 观看两家比英豪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "紧催战马用目瞧， 关羽追我不欲饶。 拉弓搭弦扭转腰，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠射箭，下。关羽上，接箭。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "接过雕翎箭一条。 明知深山有虎豹， 大胆上山去砍樵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "关羽不解其中情， 紧急加鞭随后跟。 二次开弓放雕翎，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠射箭，下。关羽上，接箭。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "连接雕翎箭二根。 百步穿杨射虽准， 放箭哪有某接箭能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。黄忠上。"
        },
        {
