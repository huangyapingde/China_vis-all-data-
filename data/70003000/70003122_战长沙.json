        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "魏文长说话多粗鲁， 怕的是元帅不能留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
