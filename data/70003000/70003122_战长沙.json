          "text": "奉令夺取长沙地， 威风凛凛把兵提。 义扶汉室三分鼎， 且听探马报军机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀君侯：黄忠、魏延辕门投降。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吩咐架起刀门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "传黄忠、魏延进帐！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "下面听者！君侯有令：黄忠、魏延进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。黄忠、魏延同上。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "人言桃园多仁义，"
        },
        {
          "character": "魏延",
          "type": "西皮散板",
          "text": "话不虚传果第一。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "来在辕门用目觑，"
        },
        {
          "character": "魏延",
          "type": "西皮散板",
          "text": "刀枪剑戟摆列齐。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "归顺桃园我不去，"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "魏延",
          "type": "西皮散板",
          "text": "你若不去我不依。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "我这里报门跪帐里， 恕黄忠——"
        },
        {
          "character": "魏延",
          "type": "西皮散板",
          "text": "魏延"
        },
        {
          "character": "黄忠、魏延",
          "type": "同西皮散板",
          "text": "归降迟。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "丹凤眼来观觑， 只见二将跪丹墀， 为什么停兵不交战？ 归降的事儿说端的。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "都只为韩玄不仁义，"
        },
        {
          "character": "魏延",
          "type": "西皮散板",
          "text": "末将讲情他不依。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "怒恼魏延将他斩，"
        },
        {
          "character": "魏延",
          "type": "西皮散板",
          "text": "韩玄的首级在手里。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "将首级高挂营门地， 我兄王到此报功绩。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老将军好刀法。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "二君侯也不差。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "昨日阵前为何不见魏将军？"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "末将奉令催粮，回来与黄将军求情，韩玄不准。恼怒杀死韩玄斩了他的家眷， 长沙印信呈上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某兄王驾到定有封赏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "主公、军师到。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二位将军帐外候令。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。四龙套、诸葛亮、刘备同上。"
        },
        {
          "character": "刘备、诸葛亮",
          "type": "同白",
          "text": "恭喜君侯，贺喜君侯！一战成功，可喜可贺！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "主公洪福，军师妙算。末将何功之有？"
        },
        {
          "character": "刘备、诸葛亮",
          "type": "同白",
          "text": "君侯之功也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "收来黄忠、魏延现在帐外听令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传他二人进帐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "黄、魏将军进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、魏延同上。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "来也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "见过主公、军师。"
        },
        {
          "character": "黄忠、魏延",
          "type": "同白",
          "text": "参见主公、军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "黄老将军出帐歇息。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "谢军师。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将，将魏延绑了！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "啊？为何将某绑了？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来！将魏延推出斩了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刀斧手押魏延同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀下留人！ 军师为何将魏延斩首？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏延居其地，献其土，食君禄，弑其主，居心叵测，喜怒无常。似这等人今日 若不将他斩首，日后恐有反汉之举。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "若将魏延斩首，我桃园弟兄就不义气了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "是啊，外人谈论，我弟兄就不义气了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "望军师开恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "好，将魏延赦回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "谢军师不斩之恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢过主公、君侯讲情。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "多谢主公、君侯讲情。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "魏延！从今以后，在山人帐中听用，山人军法无情，你要仔细了！你要打点了！"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "长沙印信呈上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "后帐摆宴，与君侯贺功。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谢军师。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}