{
  "script_id": "70003123",
  "title": "单刀会",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    },
    {
      "name": "关平",
      "hangdang": "小生"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    }
  ],
  "plot": "孙权因刘备久借荆州不还，命诸葛瑾前往索取，刘备佯允以长沙、零陵、桂阳三郡抵还，命去荆州关羽处商\n割。关羽不与。鲁肃设宴诓请关羽过江，关羽明知有诈，只携周仓一人，单刀赴会；席间历述战功，威势凛\n然。鲁肃讨索荆州，关羽佯醉，一手持剑，一手执鲁肃，驾一叶小舟，安然返回荆州。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大刀手、八将、四上手、中军、鲁肃同上。"
        },
        {
          "character": "鲁肃",
          "type": "引子",
          "text": "熟读经纶，蕴韬略，愿竭丹心辅东吴。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "三尺龙泉万卷书，皇天生我意何如。山东宰相山西将，彼大夫兮我大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "本督，鲁肃字子敬。吴侯驾前为臣，官拜水军都督。只因前三日，吴侯有火牌 到来，诏某回朝，不知为了何事？今乃黄道吉日，正好班师。 中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "人马班师还朝。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令！ 令出。众将官，人马班师回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖五马江儿水〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、孙权同上。"
        },
        {
          "character": "孙权",
          "type": "引子",
          "text": "威镇江东，恨刘备，霸孤疆土。"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "当年孙、刘破曹瞒，得了荆州起祸端。刘备借去屯军马，霸占数年不归还。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤，孙权字仲谋。当年孙、刘同心破曹，得了荆州，被刘备借去，屯军养马， 言明三载交还。如今霸占多年，其情可恼！不免召宣吕蒙，商议妙计，讨回荆 州。 内侍。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "宣吕蒙上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "吕蒙上殿哪！"
        },
        {
          "character": "吕蒙",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕蒙上。"
        },
        {
          "character": "吕蒙",
          "type": "念",
          "text": "幼习战法武艺，扶保吴侯江山。"
        },
        {
          "character": "吕蒙",
          "type": "白",
          "text": "臣，吕蒙见驾，吴侯千岁！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "吕蒙",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "吕蒙",
          "type": "白",
          "text": "谢座。宣臣上殿，哪路军情？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "只因刘备，久占荆州不还，请将军商议，讨回荆州。"
        },
        {
          "character": "吕蒙",
          "type": "白",
          "text": "想我朝诸葛瑾，乃孔明之兄，主公将瑾之家眷收入监牢，命他去讨荆州，若是 讨不回荆州，将他满门斩首，那诸葛瑾，必将此情，说与孔明，他二人有手足 情份，定将荆州讨回，岂不妙哉！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "此计甚好。 来。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "宣诸葛瑾上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "诸葛瑾上殿哪！"
        },
        {
          "character": "诸葛瑾",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾上。"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "忠心赤胆扶吴主，江东老臣个个贤。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "臣，诸葛瑾见驾，吴侯千岁！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "千千岁！宣臣上殿，有何议论？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "命你过江，催讨荆州，意下如何？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "想为了荆州，费了多少兵马钱粮，未能讨回，为臣此番过江催讨，也恐难以遂 愿。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "唗！分明念你弟诸葛亮，现在刘备营中，故而花言巧语，蒙哄孤王。现将你满 门老少，押在监牢。此去讨不回荆州，定将你满门斩首。退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、吕蒙、孙权同下。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "千岁一怒退了殿， 不容臣子发一言。 低头下殿心盘算， 怕的是讨荆州有去无还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、诸葛亮、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "孤王立帝坐西川， 众卿保孤锦江山。 恢复中原平生愿， 灭除孙、曹心始安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启主公：东吴诸葛瑾过江，求见主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "令兄过江，不知为了何事？倘为荆州，孤允是不允？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公若是依从，二君侯哪里安身？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "依先生之见？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣暂退，吾兄进帐，主公须要惊吓与他。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请便。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾上。"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "全凭三寸舌，说回荆州城。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "外臣，诸葛瑾见驾，陛下千岁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "子瑜少礼，请坐。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "子瑜过江，必有所为？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "这个……臣奉命催讨荆州。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "嗯！大胆诸葛瑾，出言如此癫狂，不看你远路风尘，定要你头！ 左右，轰了出去。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "险些又要丧了命， 无国无家似游魂。"
        },
        {
          "character": "诸葛瑾",
          "type": "哭头",
          "text": "眼望苍天悲声震，苍天哪……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "兄长痛泪为何情？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "兄长几时来的，因何落泪？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "吾弟不知，只因我主，将兄满门老小，押入监牢，兄若讨不回荆州，将吾满门 斩首。方才进帐，你主大怒，将兄叉出帐来，望吾兄念在手足情份，劝你主退 还荆州，好救兄满门性命。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吾兄但放宽心，你我一同进帐，跪求吾主。倘若将别地抵还你国，你也好回复 你主。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "哎，兄弟啊！"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "一同进帐忙跪定，"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "尊声主公容告禀。"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "为臣讨不回荆州郡，"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "他满门老小命难存。"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "望陛下开天恩——"
        },
        {
          "character": "诸葛亮、诸葛瑾",
          "type": "同哭头",
          "text": "慈悲大发！主公呀！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "倒叫孤王无计行。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生、子瑜请起，请、请坐。"
        },
        {
          "character": "诸葛亮、诸葛瑾",
          "type": "同白",
          "text": "谢座。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，子瑜如此悲痛，孤心难忍，先生你何计教我？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公！就将零陵、桂阳、长沙三郡，交还东吴，以抵荆州，命吾兄去至荆州， 与二君侯去取，不知主公以为如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "就依先生之见，子瑜去至荆州，与孤二帝说知，定然退让三郡，速速去吧。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "谢皇叔。"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "多谢仁义刘主君， 回头再谢手足情。 辞别皇叔出大营， 连夜飞奔荆州城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生不叫退还荆州，反将三郡之地，交还东吴，是何理也？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公啊！"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "主公但把心放定， 管叫他晦气回吴双手空。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、刘备同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、马良、傅士仁、赵累、四马夫、糜芳、廖化、王甫、关羽同上。发点。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "赤面长髯，秉丹心，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平、周仓同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "威镇荆州震乾坤。"
        },
        {
          "character": "马良、傅士仁、赵累、糜芳、廖化、王甫",
          "type": "同白",
          "text": "参见君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "马良、傅士仁、赵累、糜芳、廖化、王甫",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "赤兔马千山踏遍，青龙刀遮日光寒。镇荆州成王霸业，保大哥立帝西川。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室荆州王关。桃园结义盟誓，恢复汉室。如今某大哥，西川立帝，三弟 阆中为将，封某荆州为王。想这荆襄乃借东吴之地，未必甘休，每日教演军卒， 提防冲锋。 站堂军，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启千岁：东吴诸葛瑾求见。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。诸葛瑾上。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "君侯在上，瑾大礼参拜。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "远路而来，只行常礼。请坐。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "子瑜驾临，必有所为？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "瑾奉吾主之命，讨回荆州，刘皇叔将零陵、桂阳、长沙三郡退还，以抵荆州， 望君侯交还三郡之地。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "怒发冲冠三千丈， 一言怒恼关云长。 这荆州原本是关某执掌， 你们哪一个大胆敢提夺荆襄。 不看军师诸葛亮， 定斩你首级挂营房。"
        },
        {
          "character": "关羽",
