        {
          "character": "孙权",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "吕蒙",
          "type": "白",
          "text": "都督。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吕将军请坐。 请问主公，斩斩杀杀，是哪路功臣？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "乃诸葛瑾。命他讨取荆州，未能取得，反而回朝舌辩巧言，故而将他斩首！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "想为了荆州，费尽多少兵马钱粮，未能取得。今命子瑜入川，岂能讨回。瑾在 蜀营，定然受了许多惊恐，奔回东吴，主公若将他斩首，岂不亏负臣心。望吴 侯开恩赦却。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "都督言之甚是。 来，将诸葛瑾赦回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾上。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "多谢吴侯不斩之恩。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "谢过都督讲情。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "多谢都督讲情。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "子瑜受惊，下殿去吧。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "遵命。正是："
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "不是子敬把本保，险些一命赴阴曹。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "险啊！"
