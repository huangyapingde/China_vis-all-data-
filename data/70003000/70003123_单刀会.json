          "character": "关羽",
          "type": "喜迁莺",
          "text": "观江水滔滔浪涌， 波浪中隐隐伏兵。 俺惊也莫惊， 凭着俺青龙偃月敌万军。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "父王，前面已是东吴了。"
        },
        {
          "character": "关羽",
          "type": "刮地风",
          "text": "观东吴缥缈缈旌旗绕， 恰便似虎入羊群何惧尔曹。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将，对东吴大喊，荆州王过江，命鲁肃前来迎接。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "遵命。 呔，东吴儿郎听者：荆州王驾到，鲁肃前来迎接。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八将、吕蒙、四龙套、大刀手、鲁肃同上。"
        },
        {
          "character": "鲁肃",
          "type": "西皮散板",
          "text": "三国纷纷蜀魏吴， 隔江斗志显英武。 我今若把荆州索， 方显东吴有丈夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文上。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "关羽到！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吕将军，领众将埋伏去吧。"
        },
        {
          "character": "吕蒙",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕蒙下，八将同下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。吕蒙、八将同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、鲁肃、周仓、关羽同上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯久违了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "久违了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、关羽同笑。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯请。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不敢，大夫请。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "你我挽手而行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、鲁肃同过船，落座。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯驾到，肃未曾远迎，望君侯休罪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢，关某有何德能，敢劳大夫陆口设宴。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孙、刘交厚，何必太谦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文上。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "看宴，来！待我把盏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这就不敢。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "理应如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "定席。周仓搜看，三笑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫请，啊，大夫请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃惊呆。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊、啊、啊，君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "在这厢。"
        },
        {
          "character": "鲁肃、关羽",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖园林好〗。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "久闻君侯，自桃园结义以来，屡建奇功，黄童白叟，牧子渔樵，皆知其名，无 不敬仰。肃只是耳闻，未曾目睹，今日得会尊颜，真乃三生有幸！望君侯赐讲 一遍，肃洗耳恭听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫请听。"
        },
        {
          "character": "关羽",
          "type": "叨叨令",
          "text": "银台上辉煌的丰筵锦， 引得俺威武赳赳血气性。 忆当年百战疆场名远震， 兀的是喜煞人来也么哥，"
        },
        {
          "character": "关羽、鲁肃",
          "type": "同白",
          "text": "（大夫）（君侯）请。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "真是名不虚传！请问君侯，怎样斩颜良、诛文丑？君侯赐教一听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某当年所做之事，听者倒也惊人，见着却是平常。大夫若不嫌耳烦，待某下位 细说一遍。当年我弟兄三人，徐州失散，关某困于土山，那曹操差去张文远， 顺说关某降曹，某因不知哥弟存亡，二嫂依赖，万般无奈，暂为降曹。河北袁 绍差去大将颜良攻打白马坡，曹操请某观敌掠阵，众将不能取胜，是关某一怒， 一马冲下土山。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯你因何不战？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "非但关某不战，还落马停刀。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯可慌？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不慌。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "可忙？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "一些儿也不忙，那时关某，青龙刀起，颜良头落。后来又诛文丑，关某在曹营， 立有些小之功，不足挂齿。大夫见笑了，见笑了！哈哈哈哈！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "马到头落，将军天生威武，令人钦佩！肃把敬一斗酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。〖急急风〗。吕蒙引八将自两边抄上。鲁肃出座。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "动手还早。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕蒙引八将同下。鲁肃入内归座。周仓观望。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "父王，东吴旌旗摆动，定有埋伏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！小小年纪，舞口弄舌，想为父冲锋未遇三合之将。东吴乃蝼蚁之众，他纵 有刀山剑林，关某何惧？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊君侯，闻听曹操与公，三日一小宴，五日一大宴，上马献金，下马献银，因 何过关斩将？请道其详。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫不嫌絮烦，待某再说一遍。某自进曹营，曹公三日小宴，五日大宴，上马 献金，下马献银，赠袍赐马，保某为汉寿亭侯，十分恩德。某新恩虽厚，旧义 难忘。某攻打汝南，阵前得遇孙乾，道俺大哥，已在河北袁绍营中，不知真假， 是某回师许昌，心悬两地，闷闷不乐。某大哥使陈震前来下书。某得着大哥 书信，连辞曹公，回避牌高挂，不容相见。是某万般无奈，挂印封金，写柬辞 曹，出得北门，只听得后面，这哗啦啦人马呐喊。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "来的何人？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "许褚、张辽。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "来此作甚？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请某少行片时，曹公前来饯行。关某独立桥梁，待曹公赶到，送来古美酒、大 红袍，亲自送行。某心生一计，这酒，酒祭青龙刀，这刀，刀挑大红袍。某本 应下马称谢，恐其有诈，是某催马过这八里桥！"
        },
        {
          "character": "关羽",
          "type": "四块玉",
          "text": "他他他，曹兵胆战惊， 哪个大胆敢前进。 那是俺虎狼威吓掉贼魂， 那曹兵个个往后退， 行过了灞陵桥日近黄昏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "场面做刀响效果。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯什么响亮？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关某刀响。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "响过几次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "响过三次。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第一次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "汜水关前斩华雄。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "二次？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斩颜良、诛文丑。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这第三？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "只怕应在你东吴，大夫的头上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯言重了，君侯言重了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "言重了？哈哈哈哈！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯，肃有一言，不知当讲不当讲？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有何金言？请讲当面。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是。想君侯桃园结义，誓同生死，乃为义也；降汉不降曹，乃为仁也；千里寻 兄，乃为礼也；过关斩将，乃为智也。想君侯仁义礼智，惜乎惜乎！怎么单单 缺少一个“信”字？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "嗳嗳嗳！君侯尚不失信于人，令兄玄德公，乃一国之主，言出如山，信义为重， 当年借去我国荆州，乃肃为保，言明屯军养马，三载交还，久借不归，前者 催讨，令兄言道，得了西川，退还荆州。今西川俱得，又去催讨，将零陵、桂 阳、长沙三郡退还，以抵荆州，又闻君侯不允，请问公啊，公啊，信义可在否？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此皆吾兄之事，非某所宜与也！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "某闻君侯，与皇叔桃园结义，誓同生死，皇叔即君侯也，何得推托乎？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "想天下乃人人之天下，有德者居之，无德者失之，岂独是你东吴当有……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！大夫，今日请某过江，还是饮宴，还是催讨荆州？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这酒也要饮，荆州也要讨。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大胆！鲁大夫请某赴宴，提起军国之事，真正岂有此理！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯，今日之宴，原为讨取荆州，你今日写下退割文约便罢，若是不写呀，嗯……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鲁大夫！吾今日不写退割文约，你便怎么样？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不是啊，我鲁肃为难哪！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鲁大夫，事到其间，你为难何来？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯你来看，遍江都是我国人马，你若不写退割文约，慢说你是一将，就是一 只猛虎，你也难闯过江去。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "量不就！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "量得就！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "量不就！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "告便。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请便。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "众将走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八将同上。关羽抓住鲁肃。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "鲁大夫，请某过江，敢有奸诈？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "并无奸诈。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这些人马？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "护送君侯的。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "护送关某的？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是是是！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关某领谢了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽挟鲁肃同至江边。"
        },
        {
          "character": "关羽",
          "type": "尾声",
          "text": "汉江饮宴多叨扰， 孙、刘还是旧故交。 若不看子敬情意好，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "关羽",
          "type": "尾声",
          "text": "俺怎肯将你恕饶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓、关羽同下。"
        },
        {
          "character": "八将",
          "type": "同白",
          "text": "都督醒来，都督醒来！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那关公呢？"
        },
        {
          "character": "八将",
          "type": "同白",
          "text": "逃走了！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "逃走了？"
        },
        {
          "character": "八将",
          "type": "同白",
          "text": "驾舟追赶！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "你去赶，吾鲁肃不去了。"
        },
        {
          "character": "八将",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四船夫、四龙套、四马夫、关平同上。迎周仓、关羽同上船，同走大圆场。"
        },
        {
          "character": "关羽",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "开船！"
        },
        {
