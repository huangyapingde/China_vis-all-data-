          "character": "鲁肃",
          "type": "白",
          "text": "臣倒有一计献上。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "有何高见？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "臣将人马，埋伏陆口，修书一封，请关羽过江赴宴，酒席筵前，叫他写下退割 文约，他若不写，吾即出伏兵擒之，荆州岂不唾手而得？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "好！待孤与你修书。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "命何人前往？"
