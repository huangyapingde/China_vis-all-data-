{
  "script_id": "70003103",
  "title": "造刀投军",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    }
  ],
  "plot": "刘备、关羽、张飞结拜后，公议投军，邀请工匠铸造兵器。众工匠为关羽造成三停冷艳锯，忽一小蛇伏踞刀\n面，口吐鲜血，刀显红光，众人为易名青龙偃月刀，以示纪念。苏双等义士仰慕桃园弟兄，愿一同前去投军。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "四工匠",
          "type": "内同白",
          "text": "诸位长者请哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四工匠同上。"
        },
        {
          "character": "四工匠",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "四工匠",
          "type": "数板",
          "text": "一生学习铁工匠，全仗五金度时光。昼夜里叮当响，烈火里乌烟扬；造枪刀， 铁棍棒，单双剑，丈八枪，铛槊双锤鞭锏铁练流星钩镰枪，九耳连环刀钢叉斧 钺两头忙。保管上阵去打仗，建立功勋得胜还乡，功劳簿上把名扬，提写几行， 提写几行。"
        },
        {
          "character": "四工匠",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "工匠丁",
          "type": "白",
          "text": "哎呀呀，诸位长者！我们说的话，自思可笑。用我们打造的兵器，能够疆场厮 杀，临阵交锋，还保得胜，这话岂不可笑啊？哈哈哈哈！"
        },
        {
          "character": "工匠甲",
          "type": "白",
          "text": "我们作工的，生活劳累，打造兵器时，说些个吉言吉语，使人家听着，心里高 兴，多多赏我们一些酒钱罢啦。"
        },
        {
          "character": "四工匠",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "工匠乙",
          "type": "白",
          "text": "老哥哥讲的真是心腹言语。"
        },
        {
          "character": "工匠丙",
          "type": "白",
          "text": "你说得虽好，生在这兵荒马乱之时，纵有金钱，也是无用啊！"
        },
        {
          "character": "工匠丁",
          "type": "白",
          "text": "阿叔说的有道理。宁做太平犬，不做乱世人。"
        },
        {
          "character": "工匠甲",
          "type": "白",
          "text": "闲言少讲。刘、关、张三位找我们打造兵器。闻听这三位义士，要与国家出力 报效，大家要尽心尽意地制造。"
        },
        {
          "character": "工匠乙、工匠丙、工匠丁",
          "type": "同白",
          "text": "那是自然。"
        },
        {
          "character": "工匠甲",
          "type": "白",
          "text": "张家庄去者！"
        },
        {
          "character": "工匠乙、工匠丙、工匠丁",
          "type": "同白",
          "text": "请哪！"
        },
        {
          "character": "四工匠",
          "type": "同梅花板",
          "text": "叹苍生乱世， 炎汉十常侍误国专权， 谋害贤良，生灵涂炭民不安， 家家户户少食无穿， 连年的荒旱百姓遭难， 何时才得个太平年？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四工匠同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同上，同打扫桃园。"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有请诸位义士。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "内同白",
          "text": "三位义士请哪！"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "内同白",
          "text": "诸位义士请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏双、张世平、吕常、方雄、刘备、关羽、张飞同上。"
        },
        {
          "character": "刘备",
          "type": "梅花板",
          "text": "范阳巧遇关与张， 心投意合同志向。"
        },
        {
          "character": "关羽",
          "type": "梅花板",
          "text": "为不平把祸闯， 逃灾避难走范阳。 幸喜得会英雄酒楼上，"
        },
        {
          "character": "张飞",
          "type": "梅花板",
          "text": "刘关张异姓结拜一炉香。"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同梅花板",
          "text": "喜洋洋笑非常， 豪杰良将聚一堂。"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。苏双、张世平、吕常、方雄、刘备、关羽、张飞同入席。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "请问关二爷，因何来在范阳，三雄会见？赐教一遍，我们大家洗耳恭听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "列位不嫌耳烦，容某下位手舞足蹈，叙说一遍。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "请道其详。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "平生志气刚，文武记胸膛。恨无出头日，明珠土内藏。 宦臣掌朝政，汉室乱纲常，官吏天良丧，黎民遭祸殃。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关羽自幼磨穿铁砚，深通诗书。平生好打不平，那日正在酒肆之中沽饮，忽然 闯进一白发老者，遍体汗淋，痛哭流涕，惨不忍观。问其情由，老者言道：他 名张继昌，乃蒲州解良人氏，老妻去世，只有一女，名叫鸾姣。一日，熊府家 人，前来提亲，张家不允。熊祥诈写假借约一张，告到解良苗信台前。想那苗 信，乃是熊太守门生，自然是官官相护，将张继昌父女抓到衙中，张鸾姣扣押 监中，张继昌用乱棍打下堂来。可怜张继昌年过花甲，上下衙门，叩告喊冤， 均不准状。在酒肆之中，遇着关某，领他击鼓鸣冤。狗官又将张继昌暴打，那 时某上得堂去，与赃官辩理，问得狗官，哑口无言。狗子熊祥，向某威唬，某 家一怒，当堂将熊祥打死。刀劈监牢，放出一伙被难囚犯，救了张氏父女，火 焚解良县衙。逃出城来，只听得后面，人声呐喊，官兵追赶而来。那时某身无 寸铁，如何抵挡。幸喜路旁，有一圣母娘娘古庙。是某进庙躲藏，不多时间， 又听得这哗啦啦一声响亮，火光冲天，乌烟四起！"
        },
        {
          "character": "关羽",
          "type": "四块玉",
          "text": "他他他狐群追赶紧， 个个凶勇似鹞鹰， 那时某独树不成林， 手无兵刃无奈古庙把身存， 只见那烈焰起， 某闯出了火海险境。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某从烈火之中，闯出庙门，正遇熊虎，我二人话不投机，被某夺那厮宝剑， 斩了熊虎，杀死一伙恶奴。我闯了此祸，山西地面不能存身，因此奔走范阳， 巧遇刘、张二位义士。我三人言谈议论，志趣相同，结为金兰之好，又遇众 位义士相助，真乃万千之幸！这是关某从解良来到范阳一事。众位义士贻笑了， 哈哈哈哈！"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "关二爷真君子也！我等敬奉三杯。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。苏双、张世平、吕常、方雄、刘备、关羽、张飞同饮酒。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "请问刘兄贵乡何处？有何志向？愿闻其详。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备就是这县郡大树楼桑人氏，姓刘名备，字玄德。我乃中山靖王之后，孝景皇 帝陛下之玄孙，祖父刘雄，父印刘宠，曾为涿郡太守，去世之后家业贫穷，只 落得织席贩履为生。幼读经纶，深通兵法，素怀大志，久欲上报国家，下安黎 庶，扫平外患，定国安邦。怎奈我时运不至，唉，真是苍天困煞英雄也！"
        },
        {
          "character": "刘备",
          "type": "叨叨令",
          "text": "俺平生怀大志丈夫血性， 愧煞我徒有宏图报国心。 恨无力斩权臣， 外患平， 兀的是恼煞人也么哥， 兀的是恨煞人也么哥。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "刘兄乃是汉室宗亲，素怀救国安民之心，令人钦佩！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "夸奖了，哈哈哈哈！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "列位乡邻！咱张飞家世列位尽知。咱老张的志愿，与关、刘二兄，可算志同道 合，相同无二。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "张三爷！我们大家还未曾请教，张三爷你怎么自己就提起来了？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "列位义士问完关兄、刘兄，少不得就要问咱老张。咱张飞自己讲了出来，就免 得诸位兄台多费唇舌了。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "快人快语，真乃英雄也！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咋，咋，咋！哎呀，列位义士抬爱了，哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小院子上。"
        },
        {
          "character": "小院子",
          "type": "白",
          "text": "启禀三位老爷：打造兵器的工匠来了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "快快叫他们进来讲话。"
        },
        {
          "character": "小院子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "四工匠",
          "type": "内同白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四工匠同上。"
        },
        {
          "character": "四工匠",
          "type": "同念",
          "text": "全凭两膀臂力，老君炉内求金。"
        },
        {
          "character": "四工匠",
          "type": "同白",
          "text": "参见诸位义士！"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "四工匠",
          "type": "同白",
          "text": "请问刘、关、张三位义士，打造兵器，有多少钢铁？"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同白",
          "text": "折铁两千斤。"
        },
        {
          "character": "四工匠",
          "type": "同白",
          "text": "打什么兵器？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "提龙双股剑。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "丈八蛇矛枪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三停冷艳锯。"
        },
        {
          "character": "四工匠",
          "type": "同白",
          "text": "在哪里打造？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "家院！领他们去到后园草地打造。"
        },
        {
          "character": "小院子",
          "type": "白",
          "text": "是。 诸位随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小院子、四工匠同下。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "三位义士！我们必须多聚集些志同之人，前往投军方好。"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同白",
          "text": "那是自然！还须要招军买马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小院子上。"
        },
        {
          "character": "小院子",
          "type": "白",
          "text": "庄外来了许多壮年汉子，带了许多兵器，良马数十骑，前来拜见刘、关、张与 众位义士来了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我们何不出庄迎接！"
        },
        {
          "character": "苏双、张世平、吕常、方雄、关羽、张飞",
          "type": "同白",
          "text": "言得极是！大家一同出庄去者。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四工匠抬刀、枪、剑同上。刘备、关羽、张飞、苏双、张世平、吕常、方雄同上，观看兵器，称赞。"
        },
        {
          "character": "工匠丁",
          "type": "白",
          "text": "哎呀！稀奇，稀奇！一阵大风，从草内钻出一条小青蛇，可怜它死在这冷艳锯 刀头之上。口内吐出鲜血，真如画在刀头之上，诸位义士请看。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "恭喜关兄，贺喜关兄！青龙钻踪冷艳锯刀头之上，口现红光，冷艳锯堪称青龙 偃月刀。此乃大吉之兆也！"
        },
        {
          "character": "关羽",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈哈！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "多谢列位义士相赠青龙偃月刀名。关某得志，建功立业，展土辟疆，仰仗诸位 金言也！大家收拾马匹，明日一同投军，与国除患，安邦去者！"
        },
        {
          "character": "苏双、张世平、吕常、方雄、刘备、关羽、张飞",
          "type": "同尾声",
          "text": "风云聚会艳阳娇， 桃园饮宴集英豪； 明日里投军报效， 疆场上建立功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}