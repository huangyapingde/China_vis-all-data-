{
  "script_id": "70003106",
  "title": "屯土山",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "张辽",
      "hangdang": "老生"
    }
  ],
  "plot": "曹操征讨刘备，占领徐州破小沛，刘备、张飞败走。关羽守下邳，保护刘备家小。曹操爱关羽义勇，诱关羽\n出城，断其归路，困于土山，命张辽劝降。关羽为保嫂寻兄，以图再举，相约三事。曹操一一依从。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "许褚、徐晃同上，双起霸。"
        },
        {
          "character": "许褚、徐晃",
          "type": "同点绛唇",
          "text": "将勇兵强，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李典、乐进同上，双起霸。"
        },
        {
          "character": "李典、乐进",
          "type": "同点绛唇",
          "text": "威风浩荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪、夏侯惇同上，双起霸。"
        },
        {
          "character": "曹洪、夏侯惇",
          "type": "同点绛唇",
          "text": "军气旺；"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱灵、路昭同上，双起霸"
        },
        {
          "character": "朱灵、路昭",
          "type": "同点绛唇",
          "text": "集将鼓响，"
        },
        {
          "character": "众将",
          "type": "同点绛唇",
          "text": "烟尘齐扫荡。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "列位将军请了。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "我军今番兴师，袭了徐州，攻破小沛，战败刘备、张飞，下邳指日可破。丞相 今日升帐理事，我等两厢候令。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "发点、大开门。四文堂、四上手、八大刀手、荀彧、荀攸、郭嘉、程昱、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "队伍雄威，气轩昂，统领三军，烟尘扫荡。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "老夫统兵出许都，文韬武略胜伊筹。三军威武小沛破，眼望下邳顷刻收。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操。昨日战败刘备，袭了徐州，攻破小沛，某有意攻打下邳，为此升帐 理事。诸位先生有何高见？"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "想下邳乃云长镇守，是他保护玄德妻小，死守此城，若不速取，恐为袁绍所得。 丞相取之此为上策也。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吾素爱云长武艺人才，欲得之以为己用。"
        },
        {
          "character": "郭嘉",
          "type": "白",
          "text": "云长义气深重，必不肯降，若使人说之，恐被其害。我营张辽将军，与云长有 一面之交，命他前往说之可也。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "文远虽与云长有旧，吾观此人非言词可说也。某有一计，使其进退无路，然后 用文远说之，必归丞相矣！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生有何高见？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "那云长有力敌万人之勇，非智谋不能取之。今可差刘备投降之兵，投入下邳， 见了云长，诡说使逃回的军卒，使其伏于城中以为内应；再引云长出战，诈败 佯输，诱入他处，以精兵截其归路，然后说之可也。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "真乃妙计。 来，传徐州降军进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同上。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "叩见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命汝等投入下邳，作为内应，附耳上来。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "夏侯惇听令！命你以为先锋，统领众将，将关羽诱至高岗之处。哪家损伤云长 者，斩！起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四月华旗手、四马童、大马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "秉丹心，扫荡烟尘，扶汉室，扭转乾坤。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "桃园结拜义同心，纵横天下显奇能。赤胆忠心冲宇宙，扫尽狼烟灭奸臣。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室关。弟兄结义以来，久战疆场，威名远振。某大哥镇守徐州，三弟统 兵小沛，某奉大哥重托，保定二嫂，镇守下邳。可恨曹操，上欺天子，下压群 臣。闻得曹操带兵攻打徐州，不知大哥胜负如何，也曾命人前去哨探，未见回 报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启禀二将军：徐州已破，刘使君不知下落，有徐州兵丁，逃到此间，辕门哭告， 要求二将军收留，现在辕门候令。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "既是徐州逃来的军兵，不可欺压他们，唤他们进帐。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "徐州兵丁进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同上。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "与二将军叩头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "曹操攻破徐州，使君何在？"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "刘使君不知下落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同哭。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "汝等不必悲痛，各自休息几日，随营报效。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "多谢二将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀二将军：徐州已破，小沛已失，使君与三将军不知下落。曹操统领人马， 攻打下邳，特来报知。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住，探马报道，曹兵夺了徐州，大哥、三弟不知下落……也罢！俺不免出城 与曹军决一死战。 众将官，开城迎敌去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人出城同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、曹将、夏侯惇同上，过场，同下。"
        },
        {
          "character": null,
          "type": "text",
          "text": "（四月华旗手、四马童、大马童、关羽同上，站门，会阵开打，夏侯惇败下，关羽、四月华旗手、四马童、"
        },
        {
          "character": null,
          "type": "text",
          "text": "大马童同追下。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、郭嘉、程昱、荀彧、荀攸同上。四军士同上，出城迎曹操同进城，同下。"
        },
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、四大刀手、乐进、路昭、朱灵、于禁、夏侯渊同上。曹将、夏侯惇同上。关羽、四月华旗手、四"
        },
        {
          "character": null,
          "type": "text",
          "text": "马童、大马童同上，会阵开打，曹将败下。关羽破大刀手，追下。）"
        },
        {
          "character": null,
          "type": "text",
          "text": "（四龙套、四上手、张郃、宋宪、徐晃、许褚同上。曹将同上。关羽、四月华旗手、四马童、大马童同上，"
        },
        {
          "character": null,
          "type": "text",
          "text": "会阵，上山。曹将双抄，两边下。起火。关羽站山头。）"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "四面俱是曹兵将， 误中诡计困山岗， 眼望下邳火光亮——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "只见关羽困山岗。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "云长公，别来无恙？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远，欲来相敌耶？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "非也。念故人旧日之情，特来相见。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "既然如此，请下马上山叙谈。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "弟下马上山来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上山，关羽、张辽分坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远莫非说关某汉乎？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "不然。昔日蒙兄救弟，弟今日安得不来救兄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "然则文远将欲助我乎？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "亦非也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "既不助我，此来何干？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "玄德不知存亡，翼德未知生死。昨日曹公已破下邳，军民毫无伤损，并差人护 玄德家眷，不许惊扰。如此相待，弟特来报兄，免得悬挂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽怒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯……我今虽处绝地，视死如归。汝当速去，吾即下山迎战。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "哈哈哈……兄出此言，岂不被天下人耻笑乎？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我为忠义而死，安得为天下人耻笑？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "兄今若死，其罪有三。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "汝且说我哪三罪？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关兄听道：当初刘使君与兄结义之时，誓同生死，今使君方败，而兄战死，倘 使君复出，欲求兄相助，而不可得，岂不负当年之盟誓？其罪一也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请问二罪？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "刘使君以家眷付托与兄，兄今战死，二位夫人无所依赖，负却使君付托之重， 其罪二也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请问这三罪？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "兄武艺超群，兼通经史，不思与使君匡扶汉室徒欲赴汤蹈火，以逞匹夫之勇， 安得为义，其罪三也！兄有此三罪，弟不得不告，望兄详细思之。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "汝说我有三罪，欲我如何？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "今四面皆曹公之兵，兄若不降，则必战死，徒死无益，不如且降曹公，打听刘 使君下落，即往投之，一者可以保二夫人，二者不背桃园之约，三者可留有用 之身，以图后举。有此三便，望兄再思再想。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "兄言三便，吾有三约。如丞相能从我，当即卸甲，如其不允，吾宁受三罪而死。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相宽宏大量，何所不容，愿闻一事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "一者，吾与皇叔，誓扶汉室，吾今只降汉帝，不降曹操。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "请问二事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二者，二位嫂嫂要食某大哥之俸禄，一应上下人等皆不许擅入内室。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "请问三事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三者，但知刘皇叔去向，不管千里万里，便当辞去。三者缺一，断不肯降，望 文远急急回报。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "这三事重大，待俺秉知丞相再议。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下山，上马，下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二幕下。关羽下。众人随下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操、众人同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "统领雄师龙虎斗， 将士英勇战徐州。 关羽被困土山口， 文远顺说未回头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "千军容易得，一将最难求。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "去说关羽一事如何？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关羽约下三事：一者降汉不降曹。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哈哈哈……吾为汉相，汉即我也，此可从之。二事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "二夫人请给皇叔俸禄，一应上下人等，皆不许擅入内室。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吾于皇叔俸内，更加倍与之。至于严禁内外，乃是家法，又何疑焉！三事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "但知玄德信息，虽远必往。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "然则吾养云长何用？此事难从。"
        },
        {
          "character": "张辽",
          "type": "白",
