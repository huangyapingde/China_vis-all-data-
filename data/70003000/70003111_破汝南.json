{
  "script_id": "70003111",
  "title": "破汝南",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "孙乾",
      "hangdang": "生"
    },
    {
      "name": "刘劈",
      "hangdang": "生"
    },
    {
      "name": "龚都",
      "hangdang": "净"
    }
  ],
  "plot": "汝南刘辟、龚都联合袁绍声讨曹操，曹洪屡战不胜。关羽一为寻兄下落，二为报曹操厚待，请令出战。夜获\n奸细，相见乃是孙乾。孙乾告知刘备下落，劝关羽辞曹。孙乾归，刘辟、龚都欲俟关羽到河北后，与之共灭\n曹操，遂假意兵败，关羽得入汝南。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、于禁、张辽、许褚、乐进、李典、夏侯渊、夏侯惇同上，同起霸。"
        },
        {
          "character": "徐晃、于禁",
          "type": "同点绛唇",
          "text": "将勇兵强，"
        },
        {
          "character": "张辽、许褚",
          "type": "同点绛唇",
          "text": "虎威雄壮；"
        },
        {
          "character": "乐进、李典",
          "type": "同点绛唇",
          "text": "战疆场，"
        },
        {
          "character": "夏侯渊、夏侯惇",
          "type": "同点绛唇",
          "text": "马蹄奔忙，"
        },
        {
          "character": "众将",
          "type": "同点绛唇",
          "text": "烟尘齐扫荡。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "徐晃。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "于禁。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "张辽。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "许褚。"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "乐进。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "李典。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "夏侯渊。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "夏侯惇。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "诸位将军请了。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "想我军，此次出征，剿灭河北袁绍，仗关羽英勇，斩了颜良、文丑，才得班师 许都。今日丞相升帐，吾等两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、荀彧、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "谋略压群雄，掌生杀，剿灭凶勇，壁垒森严，谁敢轻，定乾坤，狼烟齐扫。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "忆昔当年居孝廉，谋刺董卓起祸端。中牟县内得脱难，才得领兵掌大权！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操。只因前者，河北袁绍，兴兵攻打白马坡，颜良、文丑被关羽刀劈落 马。吾军齐唱凯歌，班师回朝。今日升帐理事。 众位将军，"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吾军屡次凯歌，老夫奏知圣上，众军定有升赏。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "丞相提拔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀丞相：今有汝南刘辟、龚都谋反，曹洪将军屡战不胜，难以抵敌，报与丞 相知道。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "丞相，探马报道，刘辟、龚都谋反，曹洪将军难以取胜，就该派吾等，前去帮 助。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "言得极是，容吾思之。"
        },
        {
          "character": "关羽",
          "type": "内白",
          "text": "嗯喷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "闲观春秋孙武策，白马解围显英杰。赤兔喜走千里路，青龙爱饮上将血。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "闻得汝南谋反，曹洪难以对敌，不免进帐讨令，一来寻兄下落，二来报曹公之 恩待。正是："
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "奸相枉将虚礼侍，岂知关羽不降曹。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相在上，关某参。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军少礼，请坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军进帐，有何公论？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某闻汝南谋反，关某愿效犬马之劳，平复汝南。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军建立大功，未曾重酬，岂可复劳征讨！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相不知，关羽久闲，必生病矣！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "如此就复劳将军前往。于禁、乐进以为副将，余下将士随营调遣。统领五万人 马，平复汝南回来，老夫率领大小三军，亲自出城，迎接十里之外。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得令呀！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "云长接令暗自笑，"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "曹公真个有韬略： 五日大宴三日小， 送美女赐马又赠红袍， 上马金下马银奉敬英豪。 此番汝南把贼讨， 一来报效二来寻故交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下，众将同下。"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "啊？丞相，那云长素有归刘之心，倘知消息必去矣。丞相何用云长出征？丞相 详查。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "今次取功，吾不复教云长临敌，以隐他去之心。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四下手、四大刀手、四将、刘辟、龚都同上。"
        },
        {
          "character": "刘辟、龚都",
          "type": "点绛唇",
          "text": "镇守汝南，雄心胆，恨曹瞒，自称英男，统兵灭奸佞。"
        },
        {
          "character": "刘辟、龚都",
          "type": "同念",
          "text": "堂堂丈夫立帝基，雄心盖世武艺奇。空中五色旌旗摆，烈烈轰轰世无敌。"
        },
        {
          "character": "刘辟、龚都",
          "type": "同白",
          "text": "某，（刘辟）（龚都），威镇汝南一带，可恨曹贼专权，是俺会同河北袁绍， 共灭曹瞒。也曾命探马前去打探，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀将军：今有曹操挂关羽为帅，统领五万人马，战将千员，攻打汝南，特来 报知！"
        },
        {
          "character": "刘辟、龚都",
          "type": "同白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘辟",
          "type": "白",
          "text": "关羽统兵前来，将军有何退兵之计？"
        },
        {
          "character": "龚都",
          "type": "白",
          "text": "想桃园当年失散，各自东西，今晚吾军前去偷营劫寨，假意被擒，将刘备在河 北之事，对他说明，那关羽闻知兄信，定离曹寻刘。吾二人明日在阵前，用言 语激发于他，吾军退出汝南，俟关羽到了河北，与吾军共灭曹操，岂不美哉！"
        },
        {
          "character": "刘辟",
          "type": "白",
          "text": "好！ 传孙乾、袁刚进帐。"
        },
        {
          "character": "孙乾、袁刚",
          "type": "内同白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾、袁刚同上。"
        },
        {
          "character": "孙乾、袁刚",
          "type": "同念",
          "text": "要为天下奇男子，须立人间稀世功。"
        },
        {
          "character": "孙乾、袁刚",
          "type": "同白",
          "text": "参见将军，有何军情？"
        },
        {
          "character": "刘辟",
          "type": "白",
          "text": "命你二人，统领本部人马，今晚去至关羽营盘，偷营劫寨，附耳上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘辟耳语授计。"
        },
        {
          "character": "孙乾、袁刚",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾、袁刚、四下手同下。"
        },
        {
          "character": "刘辟",
          "type": "白",
          "text": "孙乾此去，定然成功。正是："
        },
        {
          "character": "刘辟",
          "type": "念",
          "text": "将在谋略哪在勇，"
        },
        {
          "character": "龚都",
          "type": "念",
          "text": "兵在精来何用多！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘辟、龚都同下。众人随下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、于禁、张辽、许褚、乐进、李典、夏侯渊、夏侯惇、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "来至汝南地界。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "人马列开，就地安营下寨。今晚提防那贼前来偷营劫寨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。四下手、孙乾、袁刚同上。四上手、四将同上。开打，孙乾、袁刚被擒。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "有请二将军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童持灯引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "风吹旌旗转，气出斗牛寒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "拿住奸细。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "绑进帐来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "上手绑孙乾、袁刚同上，同跪。关羽一惊，继又正色。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唗！无能之将，竟敢前来偷营劫寨。来！将此贼——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽指袁刚。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "斩首，号令营门。众将歇息去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同下，袁刚押下。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "二将军！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "噤声！ 两厢退下，老军伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "孙将军受惊了，请坐。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "自溃散之后，一向踪迹不闻，今何为至此？"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "某自逃难，飘泊汝南，幸得刘辟收留。将军因何落在曹营？甘、糜二位夫人， 可无恙否？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "自那年失散之后，被困土山。为保定二位皇嫂，某万般无奈，与曹操约下三事， 暂栖曹营。幸得二位夫人身体安泰。吾与曹公有言在先，若知大哥下落，立 功便离曹营。请问将军，可知某大哥今落何处？"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "近闻玄德公，在河北袁绍营中，末将意往投之，未得其便。今刘辟、龚都二人 归顺袁绍，相助攻曹。今将军到此，刘、龚二人特令小军领路，教某以为细作， 来报将军。明日二人虚败一阵，公可速引二夫人，去投河北袁绍处，也好与 玄德公相见。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "既兄在袁绍营中，吾必星夜而往，但恨吾斩袁绍二将，恐其事有变矣。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "将军休得忧疑，吾当先往，探彼虚实，再来报知将军如何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好。但见兄长一面，虽万死不辞。今回许昌，必辞曹操也。拜烦将军先行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "打四更。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "夜已更深，将军暗暗出营去吧！"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "告辞了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住。孙乾言道，俺大哥今在河北袁绍营中，又言刘辟、龚都退让汝南，此事 未知虚实。明日阵前，见机而行便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘辟、龚都同上。"
        },
        {
          "character": "刘辟",
          "type": "唱",
          "text": "孙乾一去未回报， 且等回营把令交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾上。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "参见将军。"
        },
        {
          "character": "刘辟",
          "type": "白",
          "text": "罢了。可曾与关羽相遇？"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "那关羽言道，今回许昌，定辞曹操。阵前须要用言语激发于他。"
        },
        {
          "character": "刘辟",
          "type": "白",
          "text": "那是自然。后帐歇息去吧。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "谢将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾下。"
        },
        {
          "character": "刘辟",
          "type": "白",
