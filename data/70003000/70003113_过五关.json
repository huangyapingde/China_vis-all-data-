        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士同上，过场，同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小校、老军、车夫、甘夫人、糜夫人、马童、关羽同上，普净迎上。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "云长公别来无恙？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我与禅师，素未识面，何以知我？"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "请问将军离故乡几载？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这——不觉二十余载。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "哈哈哈！这就怪不得了。小僧也是蒲东人氏，你我只隔一河，难道将军你就忘 怀了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔呼呀！原来是故乡旧邻，云长失认了。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "岂敢。请到禅堂待茶。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "还有二位皇嫂车辆。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "请到内禅堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人、二车夫、老军、小校、马童同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请问师父上下？"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "小僧普净。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "原来是普净禅师，关羽失敬了。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "禅师因何至此？"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "这镇国寺乃汉明帝御前香火寺院，贫僧云游至此，暂为栖身之地。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "今日还要打扰宝刹。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "贵驾光临，蓬壁生辉，乃敝寺之幸也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "将军少坐片时，小僧打杯茶来，与将军解渴。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "普净",
          "type": "扑灯蛾",
          "text": "闻得将军到此游，到此游。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "普净打手势向关羽示意。"
        },
        {
          "character": "普净",
          "type": "扑灯蛾",
          "text": "小僧特备茶恭候。 我本当说根由， 泄漏机关结冤仇，结冤仇。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我与禅师初次相见，何言“冤仇”二字？"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "不是啊。小僧有两句言语，只是不敢言讲。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有何金言，当面赐教。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "说出来恐将军你害怕。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯，某屡经大敌，何惧两句话耳？"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "哎呀将军！那卞喜请将军饮宴，并非好意，两旁俱有埋伏，少时酒席宴前，掷 杯为号，要害将军性命。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哦！卞喜这厮不仁，待某将他除却。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "将军若是造次，岂不连累小僧？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "听禅师之言，难道罢了不成？"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "不妨事。少时酒席筵前，将军先发制人，勒住卞喜，一同出关，定然转祸为福。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "卞喜至此，禅师你要小心了。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "将军你也要仔细了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "卞喜来了。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "各讨方便。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "普净下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、卞喜同上。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "酒筵排下，二将军请。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "二将军今欲何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "辞曹归汉，河北寻兄。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "拿来。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "甚么？"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "文凭路引。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺不受曹丞相节制，要甚么文凭路引？"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "你无有文凭路引，休想出关。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！你可知某诛孔秀，斩韩福、孟坦之故？"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "他等俱是无能之辈。今日来到沂水关，你，你休想过去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卞喜欲掷杯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽拉卞喜同下。四兵士随下。小校、车夫、甘夫人、糜夫人、马童同上，过场，同下。普净上。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "且住！看他两下动起手来那卞喜岂能与我干休！这…… 小沙弥，收拾衣钵戒牒，你们逃生去吧！"
        },
        {
          "character": "普净",
          "type": "扑灯蛾",
          "text": "我拜，拜别佛圣尊，佛圣尊。 我吹，吹灭佛前灯。 收了铙钹罄， 我卷，卷了佛前经。 慌忙出庙门， 云游去偷生，云游去偷生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "普净下。"
        }
      ]
    },
    {
