          "character": null,
          "type": "stage",
          "text": "胡班下。"
        },
        {
          "character": "王植",
          "type": "白",
          "text": "众将官，各自准备器械。掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
