      "hangdang": "旦"
    }
  ],
  "plot": "关羽一行，离开许昌，一路经过东岭、洛阳、沂水、荥阳、黄河渡口等五处关隘，先后斩了孔秀、孟坦、韩\n福、卞喜、王植、秦琪六员曹将。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、杜远同上。〖快点绛唇〗。杜远上高台。"
        },
        {
          "character": "杜远",
          "type": "念",
          "text": "占山称霸自为王，打家劫舍逞刚强。不怕王法无拘束，最喜美貌女姣娘。"
        },
        {
          "character": "杜远",
          "type": "白",
          "text": "俺，杜远。曾命喽兵下山打探买卖，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "山下有两轮车辆，打此经过。"
        },
        {
          "character": "杜远",
          "type": "白",
          "text": "知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "杜远",
          "type": "白",
          "text": "呔！众喽兵，一同下山去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "甘夫人、糜夫人",
          "type": "同西皮散板",
          "text": "二弟义气实可钦， 挂印封金离曹营。 耳边听得人声震……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、杜远同上。"
        },
        {
          "character": "杜远",
          "type": "西皮散板",
          "text": "快抢车辆回山林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜远、喽兵掳小校、老军、甘夫人、糜夫人、车夫同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "廖化上。"
        },
        {
          "character": "廖化",
          "type": "念",
          "text": "英雄埋没在风尘，流落荒山暂栖身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜远、喽兵押小校、老军、车夫、甘夫人、糜夫人同上。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "大哥下山，有甚么好买卖？"
        },
        {
          "character": "杜远",
          "type": "白",
          "text": "抢来两个妇女，正好与你我做个压寨夫人。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "不可胡言，待某看来。 请问二位夫人，何人宝眷？"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "我姐妹二人，乃刘玄德家眷。二弟关云长，在灞陵桥与曹丞相相谈，车辆先行， 被你等抢来。快快把我们放下山去。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "原来是刘使君宝眷。 啊，杜远兄，此乃刘使君宝眷，快快送下山去，才是正理。"
        },
        {
          "character": "杜远",
          "type": "白",
          "text": "住了！大丈夫要劫劫皇杠，要抢抢皇娘。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "近前来。"
        },
        {
          "character": "杜远",
          "type": "白",
          "text": "有何话讲？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化杀死杜远。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "喽兵紧守山寨。"
        },
        {
          "character": "喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "喽兵同下。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二位夫人，休得惊怕，随俺下山，寻找关将军去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "适才饮别灞陵桥，曹操赠某大红袍。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "适才在灞陵桥，曹公与某饯行，二嫂车辆过桥前行，俺赶行至此，为何不见？ 马童，速速打听二位主母下落！"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住，某在灞陵桥，与曹公稍谈几句，二嫂车辆前行，此处不见踪影，其中定 有缘故。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "二位主母车辆，并无踪影。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "灞陵桥左右，再去打探。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哎呀且住！想俺大哥，将保护二位皇嫂重任，付予关某，若有差池，乃关某之 罪也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "启禀二爷：大事不好了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "此处土人言道，二位主母车辆，被一伙强盗抢了去了！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "二位主母车辆，被一伙强盗抢了去了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "听说车辆被贼抢， 倒叫关羽无主张。 有何面目见兄长？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化上。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二将军！"
        },
        {
          "character": "廖化",
          "type": "西皮散板",
          "text": "尊声将军莫惊慌。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二将军休得惊慌，二位夫人现在此地。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请下山叙话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化下山。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "参见二将军！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请问将军尊姓大名？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "在下姓廖名化。只因伙伴杜远，将二位夫人车辆，抢上山去，是他不纳良言， 我已将他杀死。特来禀报二将军知道。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "车辆何在？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "现在山下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "快快请来！"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "有请二位夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人、二车夫同上。小校、老军同上。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同哭",
          "text": "喂呀！"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二弟呀！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二嫂受惊，弟之罪也。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二弟何出此言。若不是这位将军相救，险遭不测。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "蒙将军相救之恩，关某这里谢过。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "岂敢。末将情愿跟随将军，侍奉鞍前马后。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二位夫人同行，一路多有不便，你我后会有期。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "末将告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请二嫂登车。 马童，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡华上。"
        },
        {
          "character": "胡华",
          "type": "引子",
          "text": "归隐茅庐，终日里，闲散江湖。"
        },
        {
          "character": "胡华",
          "type": "念",
          "text": "桓灵无道宠张让，烟尘四起各一方。冷眼识破权奸象，告职归林隐村庄。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "老汉胡华。昔在先帝时，曾为议事，如今致仕归乡。小儿胡班，在荥阳王植部 下以为从事。看红日西坠，不免去到庄外，游玩一番便了。"
        },
        {
          "character": "胡华",
          "type": "西皮原板",
          "text": "可叹炎汉锦乾坤， 宠用常侍十奸臣， 生灵涂炭民遭困， 狼烟四起不太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小校、老军、二车夫、甘夫人、糜夫人、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "天色昏暗路难奔， 见一老丈在庄门。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老丈请了。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "请了。来的敢是关云长将军？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "正是。老丈何以知我？"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "将军斩颜良、诛文丑，威名远震。老汉冒叫一声，将军恕罪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "将军施礼为何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "天色已晚，借宿一宵，明日早行。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "贵客临门，请到舍下奉茶。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "还有二位皇嫂。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "请至后院，老妻奉陪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二嫂请进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二车夫、甘夫人、糜夫人、小校、老军、马童同下。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "将军今欲何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "辞曹归汉，河北寻兄。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "将军河北寻兄，定从荥阳经过。小儿胡班，现在王植部下为将，小老儿有心修 书一封，烦将军至荥阳交与小儿，不知将军意下如何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "当得效劳。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "好，待我修书。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡华写信。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "拜烦将军面交小儿。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某记下了。"
        },
        {
          "character": "胡华",
          "type": "白",
          "text": "后面备酒，与将军同饮。正是："
        },
        {
          "character": "胡华",
          "type": "念",
          "text": "将军英名人钦敬，"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "一介勇夫有何能？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、孔秀同上。"
        },
        {
          "character": "孔秀",
          "type": "念",
          "text": "奉了丞相令，镇守东岭关。"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "俺，孔秀。奉了丞相之命，镇守东岭关。 众将官，带路上关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人、车夫、小校、老军、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "昨夜借宿胡家庄， 老丈美意似孟尝。 勒住丝缰用目望， 东岭关紧闭甚严防。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "开关！"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "何人叫关？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关云长在此。"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "二将军到了，开关。 参见二将军。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "今欲何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "河北寻兄。"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "拿来！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "甚么？"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "文凭路引。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "行时慌迫，未曾讨得。"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "无有文凭路引，不能过关。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊？敢挡关某乎？"
        },
        {
          "character": "孔秀",
          "type": "白",
          "text": "看鞭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽杀死孔秀，出关，众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四兵士、孟坦同上，帐外侍立。四兵士、韩福同上。〖快点绛唇〗。韩福入座。"
        },
        {
          "character": "孟坦",
          "type": "白",
          "text": "参见太守。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "将军少礼。"
        },
        {
          "character": "孟坦",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "韩福",
          "type": "念",
          "text": "旌旗耀日月，令箭调三军。奉了丞相命，镇守洛阳城。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "本太守韩福。今乃操演之日。 众将官！校场操演去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！启禀太守：今有关羽，在东岭关刀劈孔秀，特来报知。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "孟将军，关羽过关斩将，将军有何妙计以制关羽？"
        },
        {
          "character": "孟坦",
          "type": "白",
          "text": "太守出关，与关羽讲话，末将暗放冷箭，哪怕关羽不灭。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "此计甚好。带马迎敌关羽去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同上关。小校、老军、车夫、甘夫人、糜夫人、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "开关！"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "何人叫关？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关云长在此。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "二将军到了，众将开关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩福出关。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "参见将军。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "二将军何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "辞曹归汉，河北寻兄。"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "拿来！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "甚么？"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "文凭路引。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺不受曹丞相节制，要甚么文凭路引！"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "无有文凭路引，休想过去。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！你可知某在东岭关，诛孔秀之故？"
        },
        {
          "character": "韩福",
          "type": "白",
          "text": "这个——"
        },
        {
          "character": "孟坦",
          "type": "白",
          "text": "看箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟坦放箭，关羽刀劈韩福、孟坦，过关，众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士引卞喜同上。"
        },
        {
          "character": "卞喜",
          "type": "西皮摇板",
          "text": "奉命统军威风盛， 镇守沂水谁不尊？ 将令一出山摇震， 冲锋对垒神鬼惊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！启禀太守：今有关羽，在东岭关刀劈孔秀，洛阳城斩韩福、孟坦落马。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "且住！关羽过关斩将，看看来到沂水。此人英勇无敌。只可智取。我不免去到 镇国寺，与老和尚商议灭却关羽之计。 来！带马镇国寺去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场，小和尚迎上。"
        },
        {
          "character": "小和尚",
          "type": "白",
          "text": "迎接太守。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "烦劳通禀，本太守求见你家师父。"
        },
        {
          "character": "小和尚",
          "type": "白",
          "text": "哎呀不敢不敢，罪过，罪过。 有请师父。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "普净上。"
        },
        {
          "character": "普净",
          "type": "念",
          "text": "静守禅林修三宝，出家拜佛念经文。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "小和尚",
          "type": "白",
          "text": "太守求见。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "说我出迎。"
        },
        {
          "character": "小和尚",
          "type": "白",
          "text": "我家师父出迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小和尚暗下。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "太守哪里？太守……"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "禅师。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卞喜、普净同入内，落座。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "太守在上，小僧有礼。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "禅师少礼，请坐。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "谢座。太守贵驾来临，有何见教？"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "只因关羽过关斩将，看看来到沂水，本太守要借宝刹一用。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "要小刹何用？"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "就在寺中设摆酒宴，两旁设下刀斧手，本太守掷杯为号，擒那关羽，此事万无 推辞了。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "太守此言差矣。想这镇国寺乃清静佛地，岂能作那杀人战场。请太守另想别策。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "唗！若是走漏消息，定要你的老命。 来！带马迎接关羽去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卞喜、四兵士同下。"
        },
        {
          "character": "普净",
          "type": "白",
          "text": "哎呀且住！我当卞喜借我寺院为了何事，原来设下奸计，要害关羽性命。我想 那关羽，乃当今英雄，国家有用之材；况且我二人俱是蒲东人氏，与他同乡共 里。想我出家人，慈悲为本，方便为门，如今他来到这沂水关镇国寺中有难， 我岂可见他死而不救！哎呀这……有了，我不免等他到来，用言语打动于他。 正是："
        },
        {
          "character": "普净",
          "type": "念",
          "text": "非是贫僧施恻隐，只为擎天柱一根。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "普净下。"
        }
      ]
    },
    {
