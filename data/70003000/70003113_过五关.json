      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、卞喜同上。关羽、甘夫人、糜夫人、马童、小校、老军同上，同出关。"
        },
        {
          "character": "关羽",
