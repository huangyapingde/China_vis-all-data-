        {
          "character": "卞喜",
          "type": "白",
          "text": "护送二将军的。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯！某领谢了。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "沂水关前多叨扰， 你送我出关我送你还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽斩杀卞喜。"
        },
        {
          "character": "四兵士",
          "type": "同白",
          "text": "二将军饶命！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "与你等无关，掩埋这贼尸首，你们逃命去吧！"
        },
        {
          "character": "四兵士",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "带马，荥阳去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
