      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关羽、小校、老军、车夫、甘夫人、糜夫人、马童同上，同进门，甘夫人、糜夫人、小校、老军同下。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "心中烦闷，看书解闷。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "想起了误中牢笼困土山， 张文远顺说暂从曹瞒。 挂印封金辞曹归汉， 不知弟兄何日团圆？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡班上。"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "哎呀且住！久闻关公英勇，只是耳闻，未曾目睹，待俺偷觑偷觑。 唔呼呀！赤面长髯，真英雄也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "外面有人，我去看来。"
