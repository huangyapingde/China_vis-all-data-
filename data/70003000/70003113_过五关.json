    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "卞喜、关羽同上。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "二将军驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "来得鲁莽，太守海涵。"
        },
        {
          "character": "卞喜",
          "type": "白",
          "text": "人在镇国寺设宴，二将军请先行一步，我随后就到。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我当先行，告辞了。"
        },
        {
          "character": null,
          "type": "stage",
