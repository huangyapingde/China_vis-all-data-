        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "胡班",
          "type": "白",
          "text": "巡营官胡班在此。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "胡班？我来问你，许昌城外胡华老丈，是你甚么人？"
