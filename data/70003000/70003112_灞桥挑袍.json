        {
          "character": "关羽",
          "type": "白",
          "text": "二嫂休得悲痛，待小弟封金挂印，写柬辞曹。嫂嫂收拾行囊，明日起程。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "这便才是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "准备车辆，明日伺候起程。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马童，将曹公所赠之物，摆列两厢，一一封好。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。马童封金。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "待某写柬辞曹。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "提羊毫我这里忙修小柬， 一桩桩一件件细写根源。 辞公数次未相见， 因此上挂印封金寻兄践前言。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "印信在此，悬挂中堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童挂印。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "将印信悬挂中堂之上， 大丈夫作事须与日月同光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童、老军、小校、二车夫、甘夫人、糜夫人同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老军，这有书信一封，送至丞相府中，然后速出北门，追赶你爷。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "曹公之物，不可携带丝毫；旧日军卒，随吾同行。车辆可齐？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "俱以齐备。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请二嫂登车。马童带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、守城官同上。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "许昌守城官是也。奉丞相之命，把守北门。 来，打道上关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童、小校、二车夫、甘夫人、糜夫人、关羽同上。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "参见二将军。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "将军何往？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "奉丞相之命，另有公干。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "可有文凭路引？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这——无。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "无有，不能过去。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你敢拦阻关某乎？"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "这个——"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "出关！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "哎呀且住！关羽带领军卒出关去了，待俺报与丞相知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守城官下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、郭嘉、程昱、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "辕门战鼓响，将士列两旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "罢了。文远进帐何事？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "云长可曾至此，求见丞相？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "云长连辞老夫数次，回避牌悬挂，不容相见，谅他无法去矣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军上。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "哪位听事？"
        },
        {
          "character": "军士",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "下书人求见。"
        },
        {
          "character": "军士",
          "type": "白",
          "text": "候着。 下书人求见。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "军士",
          "type": "白",
          "text": "传你。小心了。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "与丞相扣头，书信呈上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "奉何人所差？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "关将军所差。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "外厢伺候。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "云长有书信到来，老夫一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嘿嘿，云长去矣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守城官上。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "启禀丞相：关云长带了家小，出关去了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊！尔敢私自放他出关？ 来，斩了！"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "哎呀丞相！想那关云长，斩颜良，诛文丑，英勇无敌，小官焉能拦挡。望丞相 开恩。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可也是啊，那关羽英雄非常，汝等如何阻拦；与你无干，去吧。"
        },
        {
          "character": "守城官",
          "type": "白",
          "text": "谢丞相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "守城官下。许褚、于禁、曹仁同上。"
        },
        {
          "character": "许褚、于禁、曹仁",
          "type": "同白",
          "text": "丞相，关羽挂印封金而去，带末将等将他赶回。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "且慢，想那关羽，不忘故主，来明去白，真大丈夫！汝等皆应效之。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相待关羽甚厚，今不辞而去，乱言片楮，冒渎钧威，其罪大矣。若纵之使归 袁绍，是与虎添翼也。不若追而杀之，以绝后患，望丞相思之。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生所言虽是，奈吾昔日已许之，岂可失信与彼。各为其主，且毋追也。那云 长挂印封金，财贿不足以动其心，爵禄不足以移其志，此等人吾甚敬之。想他 此去不远。 文远，可先去请住云长，待老夫亲自与他送行。快去！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二位先生，准备路资、美酒、大红战袍，赠与云长，以为后日纪念。 众将不许暗带军器，随吾与云长送行，违令者斩。带马追赶云长去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、许褚、于禁、曹仁、曹操同下。"
        },
        {
          "character": "郭嘉",
          "type": "白",
          "text": "先生，丞相要与关羽送行，何不在酒内暗下毒药，灭却关羽。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "此计甚好。"
        },
        {
          "character": "郭嘉",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "郭嘉",
          "type": "念",
          "text": "暗中施毒计，"
        },
        {
          "character": "程昱",
          "type": "念",
          "text": "谅他难解知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱、郭嘉同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（老军、小校、二车夫、甘夫人、糜夫人、马童、关羽同上，过场，同下。张辽上，过场，下。四军士、许"
        },
        {
          "character": null,
          "type": "text",
          "text": "褚、于禁、曹仁、郭嘉、程昱、曹操同上，过场，同下。）"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "老军、小校、马童、二车夫、甘夫人、糜夫人、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且佳，看后面烟尘四起，定是曹操追赶前来。 老军，车辆过桥，望大路紧行；你爷独站灞陵桥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人、小校、老军、二车夫同下。张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关兄请转。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远莫非追赶关某回去乎？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "非也。丞相知兄远行，欲来相送，关兄略等一时，别无他意。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好啊！便是丞相铁骑到来，某愿决一死战。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关兄休疑，丞相来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、许褚、于禁、曹仁、郭嘉、程昱、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军请转。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔呼呀！原来是丞相。恕关某马上不能全礼；打躬！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公为何不辞而别？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "公此言差矣，关某前曾禀过丞相，今故主在河北，不由某不急去。屡次造府， 不得相见，故挂印封金，拜书告辞。还望丞相勿忘昔日之言为幸。何言关某不 辞而别？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "不不不是啊，吾安肯有负前言。恐将军前途乏用，特具路资相送。来来来！这 有黄金一盘，将军收纳，以做路上之用。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "屡蒙恩赐，尚有余资，留此黄金，以赏军士。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "特以少酬大功于万一，何必推辞。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "区区微劳，何足挂齿。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哈哈哈……云长真天下义士。恨吾福薄，不得相留，特备水酒，聊表寸心。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某愧领了！"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "在灞陵桥与丞相某就拱拱手，"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "众将官一个个勒马站桥头。 曹丞相虽待我恩义厚， 吾岂肯把桃园义气一笔勾。 曹孟德双手捧上香醪酒， 张文远在一旁暗地皱眉头。 我本当饮了这斗酒， 又恐怕酒内暗藏奸谋； 我本当下桥与他来争斗， 又恐怕难过这灞桥头，前后担忧。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "叫马童看过这香醪酒， 猛然一计上心头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相，某在公处，屡立奇功，这青龙宝刀，曾助一臂之力。今日恩赐美酒，一 祭宝刀。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "任凭将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽祭刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "青龙偃月火光冒， 不由关某怒眉梢！ 任尔奸来任尔巧， 难逃我青龙偃月刀。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "霎时一阵红光冒， 吓得老夫魂魄消！ 你们哪一个大胆生计巧， 回营查出定不饶。 羞得老夫无话表……"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "将军哪！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "灞陵桥赠送你这大红袍。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "人言曹操多奸巧， 他还念当初的旧故交。 叫马童看过了爷的青龙刀， 灞陵桥刀挑这大红袍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽挑袍。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相！蒙公三日一小宴，五日一大宴，上马献金，下马献银；青山不改，绿水 长流，未尽之恩，容日答报。关某告辞了。"
        },
        {
          "character": "关羽",
          "type": "三笑",
          "text": "哈哈！哈哈！啊哈哈哈……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "此人无礼太甚，待俺擒之。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那云长一人一骑，吾等数十余骑，他安得不疑；休得多言，带马回营。"
        },
        {
          "character": "许褚、张辽、于禁、曹仁",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}