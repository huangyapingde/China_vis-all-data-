{
  "script_id": "70003112",
  "title": "灞桥挑袍",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "关羽从汝南归来，决意辞曹寻兄，曹操有意回避不见。关羽不得已，乃挂印封金，保护甘、糜二夫人上路。\n曹操知关羽去志不可夺，率众将送行，至灞陵桥，见关羽横刀立于桥上，赠以锦袍。关羽恐其有诈，以刀挑\n袍，扬长而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、中军、袁绍同上。"
        },
        {
          "character": "袁绍",
          "type": "点绛唇",
          "text": "将士兵豪，儿郎虎豹，军威浩，地动山摇，要把群雄扫！"
        },
        {
          "character": "袁绍",
          "type": "念",
          "text": "河北英雄志量高，四世三公姓字标。群雄各自争疆土，百万貔貅灭奸曹。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "某，姓袁名绍字本初。可恨曹操专权，欺压各路诸侯，妄自称尊。是我兴师进 讨，前者差大将颜良，攻打白马坡，被关羽刀劈落马；又命文丑统领人马，与 颜良报仇，未知胜负。且听探马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启主公：文丑被关羽刀劈马下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "且住。关羽连斩我营两员上将，欺我太甚！但等刘备回营交令，将他斩首，以 消此恨。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮快板",
          "text": "听说文丑命丧了， 只恐祸事在今朝。 低头不语宝帐进，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "参见明公。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "唗！大胆刘备，关羽降曹，伤我两员大将，你必通谋。 来，绑了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "且慢，明公请息雷霆之怒，备有言奉禀。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "你有何话讲？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "明公容禀：想备二弟，今困曹营为将，那曹操知备在公处，故使云长诛杀颜、 文二将；明公闻之，必将我斩首。云长得知，定然实心助曹，攻打河北，此乃 曹操，借公之手，杀备之头，使公得不义之名，而助曹贼成功也。望明公详细 思之。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "唔呼呀！不是使君明言，险些中了曹操借刀之计，误伤好人，使君请坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "闻你桃园弟兄，誓同生死。使君何不招云长前来，共图大事。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备早与此心，怎奈无心腹之人，前往许昌下书。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "我命陈震前去，万无一失。使君请回馆驿修书。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "告辞！正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "不是刘备心机巧，险些项上吃一刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "陈震进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "陈震进帐。"
        },
        {
          "character": "陈震",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震上。"
        },
        {
          "character": "陈震",
          "type": "念",
          "text": "汉室君王弱，河北事诸侯。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "参见主公。唤某进帐，有何将令？"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "命你去到馆驿，听候刘使君差遣。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "刘备心中如刀绞， 鸟入牢笼怎脱逃！ 文房四宝端正好——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备写信。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "手提羊毫珠泪抛。 你在曹营富贵好， 忘却桃园生死交。 书不尽言难细表，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震上。"
        },
        {
          "character": "陈震",
          "type": "西皮散板",
          "text": "见了使君问根苗。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "参见使君，有何差遣？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这有书信一封，烦先生改装，去至许昌，我二弟那里，就说备别了二弟，犹如 失掉膀臂一般，叫他速离许昌，前来相会。先生请上，受备一拜。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "但愿云长早来到， 不枉将军费勤劳。"
        },
        {
          "character": "陈震",
          "type": "西皮摇板",
          "text": "使君但把心放了， 此事陈震当效劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震下。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "但愿二弟早来到， 重整汉室灭奸曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、郭嘉、程昱、二旗牌、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "老夫洪福齐天降，"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "颜良、文丑丧疆场。 刘辟、龚都贼犯上， 关羽领兵灭强梁。 但愿得早把凯歌唱， 且听探马报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启丞相：关将军得胜回营。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖牌子〗。四兵士、郭嘉、程昱、二旗牌摆队同下，曹操下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四士兵、许褚、张辽、于禁、曹仁、小校、老军、马童引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四兵士、郭嘉、程昱、二旗牌、曹操同迎上。四士兵、许褚、张辽、于禁、曹仁、小校、老军、马童、关"
        },
        {
          "character": null,
          "type": "text",
          "text": "羽同上。关羽下马。）"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军，幸苦了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "理当效劳。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二将军请。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不敢，丞相请。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "如此你我挽手而行。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关某斗胆了。"
        },
        {
          "character": "曹操、关羽",
          "type": "同笑",
          "text": "啊哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下，同上。曹操、关羽同入坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恭喜二将军，一战成功，真神勇也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢，仗天子洪福。羽何功之有！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "备得喜酒，与将军接风。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "还要到二嫂台前请安，改日奉陪，告辞了。 带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上马，关羽、军士、马童同下。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "启禀丞相：近闻刘备，投在河北袁绍帐下，关羽闻之，恐生去心，丞相不可不 妨。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哦，那刘备现在袁绍处吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操想。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "文远！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你去至关羽那里，探听他的去心如何，不得有误。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "好个美髯关云长， 智谋双全非寻常。 屡立功勋某的军威壮， 只恐他在曹营难得久长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同上。"
        },
        {
          "character": "甘夫人",
          "type": "西皮散板",
          "text": "姐妹如同陷罗网，"
        },
        {
          "character": "糜夫人",
          "type": "西皮散板",
          "text": "思念皇叔挂心肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小校、老军、马童、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "汝南城外打一仗， 刘辟、龙都败疆场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小校、老军、马童同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "参见二位嫂嫂。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谢嫂嫂。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二弟，几日未曾进内，有何公干？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "弟奉丞相将令，攻破汝南，少在台前问安；二位嫂嫂可安泰否？"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "倒也安泰。啊，二弟，连日出兵在外，可知你大哥的下落。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这……弟久思兄长，屡次出兵，探听大哥下落，未得音讯。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "连日辛苦，歇息去吧。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "谢嫂嫂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "甘夫人",
          "type": "白",
          "text": "贤妹，听二弟之言，皇叔一定不在人世了。"
        },
        {
          "character": "糜夫人",
          "type": "白",
          "text": "是啊，定然亡故了。喂呀，皇叔啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "麋夫人哭。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同西皮散板",
          "text": "自从徐州遭失散， 不只皇叔在哪厢？ 想是不幸黄泉往， 皇叔啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军暗上。"
        },
        {
          "character": "老军",
          "type": "西皮散板",
          "text": "二位主母莫悲伤。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "二位主母休得悲伤，大主人还在。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "何人答话？"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "旧日随降老军。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "进内讲话。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "是。 参见二位主母。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "罢了。老军，大主人之事，你因何知晓，快些讲来！"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "只因跟随二将军，攻破汝南，在阵前有人言道，大主人现在河北袁绍军中，故 而知晓。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "快快请你家二爷前来。"
        },
        {
          "character": "老军",
          "type": "白",
          "text": "是。 有请二爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老军下。关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "栖身暂居在曹营，思兄想弟泪沾襟！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "参见嫂嫂。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "嗯——你在汝南阵前，得着你大哥的信息，为何不禀报嫂嫂知道？难道你受曹 操的新恩，忘却桃园旧义不成么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二嫂请息怒。弟奉丞相将令，攻打汝南，在阵前得遇孙乾，道某大哥在河北袁 绍军中，此事未辨真假，恐其有诈，故未敢明言。弟虽受曹丞相新恩，焉能忘 却某大哥的旧义。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "原来如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "张将军求见。"
