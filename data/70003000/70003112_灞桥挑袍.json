        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马童，带马相府去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、马童同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、旗牌、郭嘉、程昱、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "袭徐州夺下邳声威大震，"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "张文远说云长投降吾营。 赠锦袍赐战马恩厚恭敬， 上马金下马银美女十名。 破汝南在阵前他闻知兄讯， 因此上命张辽探听真情。 十二载待关羽我的心神用尽， 为的是买动他扶我的真心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "西皮摇板",
          "text": "关云长不忘旧仁义可敬， 回营来忙报与丞相知情。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "启禀丞相，云长命末将转禀丞相，毋食前约，他去心已决矣。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哦！云长叫老夫毋食前约，不日寻兄去矣。唉，想云长自进吾营，老夫三日一 小宴，五日一大宴；上马献金，下马献银，赠袍赐马，奉送美女十名；屡赠之 物，不计其数，待他十分恩厚。只求他真心襄助老夫，如今闻得刘备音讯，就 要弃我而去。唉，云长啊云长，你于心何忍！"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相休得自叹，早设留他之策。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫自有留他之法，文远附耳上来……"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。"
        },
