        {
          "character": null,
          "type": "stage",
          "text": "陈震下。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "二弟，今得实信，就该辞曹寻兄才是。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二嫂请至后面，待弟去到相府辞曹。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "这便才是。"
