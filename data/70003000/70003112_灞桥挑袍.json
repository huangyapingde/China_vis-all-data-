        {
          "character": "张辽",
          "type": "白",
          "text": "恭喜关兄，贺喜关兄！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "兄攻破汝南，阵前得着玄德兄音讯，岂不是一喜？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "故主虽有音讯，未会其面，何喜之有？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "兄与玄德交，比弟与兄交如何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远此言差矣，吾与兄乃朋友之交也；吾与玄德朋友而兄弟，兄弟而君臣也， 岂能共论乎？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "令兄果在河北袁绍军中，兄可往从否？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "昔日之言，安肯背之。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "大丈夫要来明去白。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "就烦文远代禀丞相，说关某不日寻兄去矣。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "这——弟告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽下。马童上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "启爷，故友相访。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "啊？某在曹营数载，那里来的故友相访？ 有请！"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震上。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "将军在哪里？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "故友在—— 不相认。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "本来不相认。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请坐。 请问公乃何人也？"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "我乃南阳陈震，在袁绍帐中，以为从事，我奉刘……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "噤声！ 退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刘什么？"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "吾奉刘使君之命，前来下书。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "书信安在？"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "将军请看。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请至迎宾馆。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某大哥有书信到来，待吾拆书一观。 大哥，弟有罪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽念信。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "“备与足下，自桃园缔盟，誓以同死，今何中道相违，割恩断义？君必欲功名， 图富贵，愿献首级，以成全功。书不尽言，死待来命，死待来命。”"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽哭。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥！非弟不欲寻兄，奈不知所在。俺岂肯贪图富贵而背盟誓乎？窃闻义不负 心，忠不顾死，羽自幼读书，粗知礼义，睹羊角衰，左伯桃之事，未尝不三吁 而流涕也。大哥使人下书，待俺禀明嫂嫂知道。 有请嫂嫂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同上。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "何事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "兄长有书前来，嫂嫂请看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。甘夫人、糜夫人同看信。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "何人前来下书？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "陈震前来。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "唤他前来。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "是。 有请陈震先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "见过二位夫人。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "参见二位夫人。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "罢了。刘皇叔现在何处？"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "现在河北袁绍军中。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "可安泰否？"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "二位夫人容禀，千不该，万不是，乃二将军之错；在白马坡前，斩了颜良，袁 绍闻报，立时要将刘使君斩首……"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "还在呀！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你快些讲来！"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "好个使君，花言巧语，将袁绍哄过。袁绍又命文丑前去延津，又被二将军所诛； 那袁绍大怒，就将使君绑出辕门……"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "不必惊慌，还有下文呢。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "陈先生，你快快讲来！"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "使君复又舌辩，袁绍方罢；因此使我前来下书。哎呀将军哪！你速速离了曹营， 与使君相见，才是正理。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "想人生天地间，无始终者，非君子也。吾来时明白，去时不可不明白。容我辞 曹寻兄。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "倘曹操不允，如之奈何？"
