        {
          "character": "陈震",
          "type": "白",
          "text": "告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈震出门，折回。"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "啊二将军，使君望公，甚是殷切，要速速前去。"
