        {
          "character": "关羽",
          "type": "白",
          "text": "吾宁死，岂肯留于此地！"
        },
        {
          "character": "陈震",
          "type": "白",
          "text": "公速回禀，免得使君悬望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童暗上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "待某修书。 关某呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。关羽修书。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "烦公转达吾兄长，关某不死必去，不去必死。"
