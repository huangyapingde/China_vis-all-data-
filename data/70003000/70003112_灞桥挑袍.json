        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童下。〖牌子〗。张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "关兄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远，请坐。"
