      "hangdang": "老生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    },
    {
      "name": "关平",
      "hangdang": "武生"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    },
    {
      "name": "曹仁",
      "hangdang": "净"
    }
  ],
  "plot": "赤壁之战，大破曹兵。曹操率领十八骑败走华容，与关羽相遇，曹操苦苦哀求，并以往日恩惠打动关羽。关\n羽竟然释放曹操。回营交令，为诸葛亮、张飞所责，方悔自己的错误行为。刘备讲情，命关羽攻取襄阳，将\n功赎罪。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云、张飞、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "冲锋对垒建奇功，"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "当阳桥头杀气横，"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "长坂坡前威风勇，"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同念",
          "text": "扶保汉室灭奸雄。"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关云长。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "张翼德。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵子龙。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "二位将军请了！军师升帐，两厢伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、四月华旗手、四下手、刘备、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "三顾茅庐，下山林，汉室重兴。"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "参见军师！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军少礼！"
        },
        {
          "character": "关羽、张飞、赵云",
          "type": "同白",
          "text": "谢军师！"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "单人独自过江东，南屏山上借东风。周郎纵有千般计，难逃山人掌握中。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人诸葛亮。孙刘同心破曹，南屏山祭借东风，回转江夏，暗中取事。 赵云听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领三千人马，埋伏乌林，曹兵到此，劫杀一阵。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令！ 带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、赵云同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "翼德听令！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带领本部人马，埋伏在葫芦峪口，曹兵至此，夺他锣鼓、帐篷、器皿等件，不 得违误。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "得令！ 带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、张飞同下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军务完毕，退帐！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽三笑。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二将军为何发笑？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师，今逢大敌，扫荡曹瞒，满营将官，均有差遣，独把关某一字不提，是何 理也？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今逢大敌，扫荡曹瞒，将官均有差遣，哪有不用二将军之理？今有一紧要之处， 非二将军不可。只恐二将军干办不来。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师，哪有塌天崩地之事，俺关某就干办不来？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "一非塌天，二非崩地，只因曹操赤壁兵败，从华容经过，本当命二将军前去， 犹恐你擒不住那曹操。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师，慢说是那曹操赤壁兵败，残兵败将，就是蛟龙猛虎，俺关某也要生擒入 帐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不是哟，公在曹营时，那曹操待公实在恩厚，故而不敢相烦。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师，那曹操虽然恩厚，俺也曾白马解围，报效与他。今日狭路相逢，各为其 主，岂能以私废公。俺此番前去，若是擒不住那曹操，当按军令，愿输项上的 人头！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军无戏言。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "愿立军状！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "当帐立来。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关羽呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。关羽立军状。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师请看。军师，俺此番擒不着曹操，当按军令。那曹操若是不走华容呢？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那曹操若是不走华容，山人愿将军师大印，付与将军执掌。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "口说无凭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人也立军令状。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "但凭军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "孔明呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。诸葛亮立状。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得罪了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "两下抵换。二将军听令！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领五百校刀手，埋伏华容，曹操至时，一伙擒拿，若放一兵一卒，按军 令斩！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "背地里笑军师用兵不到，"
        },
        {
          "character": "关羽",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "他那里在大营藐视英豪。 此一番领兵埋伏在华容道， 准备智谋去拿奸曹操。 安排打虎牢笼套， 准备金钩去吊海鳌。 将校带过爷的赤兔胭脂豹，"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "一战成功立功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四月华旗手、关羽下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "云长讨令出帐道， 去至华容擒奸曹。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮大笑。四文堂、刘备、诸葛亮同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张辽、五曹将、曹操同上。"
        },
        {
          "character": "张辽、五曹将",
          "type": "同白",
          "text": "丞相醒来！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好烧啊，好烧！众将，来此什么地方？"
        },
        {
          "character": "张辽、五曹将",
          "type": "白",
          "text": "来此乌林。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "乌林？哈哈哈哈！"
        },
        {
          "character": "张辽、五曹将",
          "type": "白",
          "text": "丞相为何发笑？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "笑的是诸葛亮，他不会用兵。此处若有一起人马，我们大家性命难保！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内鼓架子。四上手、赵云同上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "呔！曹操，赵云在此！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。开打，张辽、五曹将同败下，赵云追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引张飞同上，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、张辽、五曹将、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好杀，好杀！众将，来此什么所在？"
        },
        {
          "character": "张辽、五曹将",
          "type": "同白",
          "text": "葫芦峪口。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "葫芦峪口，快快埋锅造饭。"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "呔！曹操，张翼德在此！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、张飞同上，同开打，曹操跑下。张辽、五曹将同败下。张飞追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四月华旗手、关平、周仓、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平、周将！大路埋伏烟尘，小路埋伏火炮，华容去者！"
        },
        {
          "character": "曹操",
          "type": "内西皮导板",
          "text": "曹孟德在马上长吁短叹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、五曹将、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "手捶胸眼含泪口怨苍天。 在中原领人马八十三万， 实指望灭刘备扫平江南。 恨只恨小周郎诡计阴险， 诸葛亮借东风火烧战船。 只烧得众将官头焦肉烂， 只剩下一十八骑好不可怜！ 勒丝缰停战马喜笑满面，"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "张辽、五曹将",
          "type": "同西皮摇板",
          "text": "丞相发笑为哪般？"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "笑只笑周郎见识浅， 孔明袖内少机关。 此处若有人和马， 大家性命难以还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内鼓声。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "耳旁听得金鼓喊， 旌旗招展心胆寒。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看看是什么旗号？"
        },
        {
          "character": "张辽、五曹将",
          "type": "同白",
          "text": "启禀丞相：此乃关字旗号。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "关字旗号，待我谢天谢地！"
        },
        {
          "character": "张辽、五曹将",
          "type": "同白",
          "text": "事到如今，谢的什么天地？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那关云长在许昌曾许我三不死，难道今日一次全都不饶吗？"
        },
        {
          "character": "张辽、五曹将",
          "type": "同白",
          "text": "如此说来，不用我们杀了？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "不用你们杀了。"
        },
        {
          "character": "张辽、五曹将",
          "type": "同白",
          "text": "也不用我们战了？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "也不用你们战了。你们歇息去吧。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "听说来了关美髯， 不由孟德喜心间。 走向前把礼见，"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "许昌一别有数年。"
        },
        {
          "character": "关平、周仓",
          "type": "同白",
          "text": "启禀父侯，曹操到！"
        },
        {
          "character": "关羽",
          "type": "西皮导板",
          "text": "耳边厢又听得马嘶人闹，"
        },
        {
          "character": "关羽",
          "type": "西皮原板",
          "text": "皱蚕眉睁凤眼仔细观瞧。 狭路上莫不是奸曹操来到， 奉军命谁认你是旧日的故交。 汉朝中论奸雄要算曹操， 一派的假殷勤暗里藏刀。 败赤壁走华容擅敢发笑， 奉军命捉拿你怎肯轻饶。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "曹孟德在马上一言禀告， 尊一声二君侯细听根苗： 在赤壁中火攻一阵败了， 只烧得众儿郎皮肉全焦。 只留下十八骑残兵来到， 二君侯若不信请来观瞧。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将！向前查看，多少人马？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "得令！ 呔，曹操你们站齐了！一五，一十，十五，一、二、三。呔！曹操！你要小心 了，你要打点了哇哇哇哇！ 启父侯：曹操一十八名残兵败将。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "军师啊，军师！慢说曹操一十八骑残兵败将，就是蛟龙猛虎，关某何惧！"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "料想他好一似鳌鱼吞钩， 尔是惊弓鸟纵有翅也难飞逃。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "在曹营我待你恩高意好， 上马金下马银美女红袍。 保荐你寿亭侯爵禄不小， 难道说你忘却了旧日故交。"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "你虽然待我的恩高意好， 我也曾战白马立过功劳。 斩颜良诛文丑立功报效， 亭侯印挂中梁封金辞曹。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "我也曾命文远文凭送到， 灞陵桥又送你美绫红袍。"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "休提起送文凭令人可恼， 诛孔秀刺孟坦王植被削。 过黄河斩秦琪文凭才到， 谢丞相沽美酒大红袍某哪放在心稍。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "在许昌曾许我云阳答报， 为什么今日里一次不饶？"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "非是我忘却了云阳答报， 因为你这奸曹罪恶难逃。 在许田射鹿时把君欺藐， 挟天子令诸侯欺压群僚。 害死了董贵妃其罪非小， 杀董承刺马腾谋篡汉朝。 恨不得拿住你剥皮馅草， 向前来试一试偃月钢刀。"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "一见云长变了脸， 倒叫孟德无话言。 望求君侯开恩典，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "二君侯啊！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "释放孟德活命还。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "曹孟德苦哀求泪流满面， 倒教我关云长有口难言。 我往日杀人不眨眼， 今日铁打心肠软如棉。 本当擒住曹孟德， 奏功受赏在帐前； 本当放了曹孟德， 定斩我头挂高竿。 背地只把军师怨， 左思右想某难上难。 大丈夫说话要兑现， 我岂能忘却当初诺言。 罢罢罢，关某岂是无义汉，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "孟德！"
        },
        {
          "character": "关羽",
          "type": "西皮快板",
          "text": "孟德近前听根源： 当初待某有恩典， 关某亦非无义男。 今日放你回朝转， 千万不可反中原。 我这里阵式忙开展， 认得此阵你就马加鞭。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "看看什么阵式？"
        },
        {
          "character": "张辽、五曹将",
          "type": "同白",
          "text": "一字长蛇阵。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "一字长蛇阵，想是放我们逃走？大家逃走了吧！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "好个大义关美髯， 释放孟德回中原； 老天若能逞我愿， 整顿了人马再下江南。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、五曹将、曹操同下。"
        },
        {
          "character": "周仓、关平",
          "type": "同白",
          "text": "启父侯：曹操逃走。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "回营交令！"
        },
        {
          "character": "周仓、关平",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "关羽",
          "type": "西皮流水板",
          "text": "听说是曹操逃走了， 不由关某心内焦。 我当年曾许他云阳答报， 今日里应人情又犯律条。 叫小校你与爷马前通报， 你就说关二爷放了奸曹。 青锋剑，把头枭， 一腔热血染战袍。 汗马功劳齐抛掉， 见了军师把令交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四月华旗手、关平、周仓、关羽同下。"
        }
      ]
    },
