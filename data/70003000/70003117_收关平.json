        {
          "character": "刘备",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "汉刘备坐雕鞍自思自忖， 数年来为国家费尽精神； 东西征南北剿心血用尽， 到如今还是这奔波伶仃。 军士们前引路关庄投奔， 桃园义讲的是一片诚心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
