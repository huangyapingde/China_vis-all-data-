        {
          "character": "关宁、关平",
          "type": "同白",
          "text": "随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关宁、关平、四马夫、大马夫同下。"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "将军请坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有座。冒造贵府，老丈恕罪！"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "岂敢。久闻将军威名，自恨无缘相遇。今日得会尊颜，真敝庄之幸也！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "关平打茶来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平上。"
        },
        {
          "character": "关平",
          "type": "念",
          "text": "捧茶进草堂，偷视关二王。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "关将军请茶。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "老丈请。此是令郎吗？"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "不敢，次子关平。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "长者何名？"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "长子关宁喜文，次子关平好武。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关宁上。"
        },
        {
          "character": "关宁",
          "type": "白",
          "text": "启爹爹，酒宴齐备。"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "关将军请至后堂小饮。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "叨扰了！请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "二弟游猎未回程， 倒叫刘备心不宁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "昨日二弟带领随从数名，出城游猎，不想天降甘霖，未回古城，使吾一夜未宁。 适才闻报：二弟在关定庄中投宿。因此带领亲随兵丁，前往关定庄，接吾二 弟同回古城。 军士们！"
        },
