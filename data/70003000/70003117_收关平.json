        {
          "character": "关羽",
          "type": "白",
          "text": "正是。老丈怎样知我？"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "风雨甚大，将军请到草堂再叙。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "打扰了！"
        },
        {
          "character": "关定",
          "type": "白",
          "text": "何出此言？关宁、关平，引关将军随从后面款待。"
