{
  "script_id": "70003102",
  "title": "桃园结义",
  "alias": [
    "三结义；一名：刘关张"
  ],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "生"
    },
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "酒保",
      "hangdang": "丑"
    }
  ],
  "plot": "关羽翦除恶霸后，逃到范阳涿州，在三好酒楼与刘备、张飞相遇，三人志趣相投，在桃园结拜。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "引子",
          "text": "臂力过人，性鲁莽，惯打不平。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "自幼生来胆气豪，爱习兵法与枪刀。惯打人间不平事，以强压弱命难逃。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺，姓张名飞家翼德。涿州人氏。自幼爱习拳棒武艺，今日心中烦闷，不免去 到城外闲游一番便了。"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "闷坐家中心焦躁， 出郊游玩走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四车夫、苏双、张世平、吕常、方雄同上。"
        },
        {
          "character": "苏双、张世平、吕常、方雄",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "苏双",
          "type": "白",
          "text": "苏双。"
        },
        {
          "character": "张世平",
          "type": "白",
          "text": "张世平。"
        },
        {
          "character": "吕常",
          "type": "白",
          "text": "吕常。"
        },
        {
          "character": "方雄",
          "type": "白",
          "text": "方雄。"
        },
        {
          "character": "苏双",
          "type": "白",
          "text": "众位兄弟请了。如今群雄四起，道路难行。前面已是涿郡，大家赶到那里投店 便了。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "大哥言之有理。"
        },
        {
          "character": "苏双",
          "type": "白",
          "text": "弟兄们，趱行者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "头戴方巾乌角，鹑衣百结褴破。足踏草鞋跟踢拖，堪叹英雄落魄。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我，刘备字玄德，乃大汉中山靖王之后，孝景皇帝玄孙。不幸家道冷落，父母 早丧，一贫如洗，只落得织履为生，人人将我叫做刘穷。因此，我也就隐其真 名不露。看天下荒荒，刀兵四起，黎民涂炭，欲想出世做一番事业，扶持社稷， 匡救朝廷。怎奈无有进身引荐之人，以至英雄落魄，流落天涯。苍天危困英 雄，良可叹也！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "刘备家贫甚惨凄， 每日里卖草鞋去东转西。 破衣褴衫难遮体， 饥寒困苦无食无衣。 何日里才得转时机， 大鹏展翅冲天飞。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "卖鞋，卖草鞋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。四百姓同上。"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "列位请了。朝廷出了告条，招募军兵。我们前去看上一看。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四百姓同走圆场，同看告示。刘备上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "卖了半日，一只草鞋，也未曾卖得。 他们在这里讲些什么，待我向前问过。 列位请了，你们在此看的是什么啊？"
        },
        {
          "character": "百姓甲",
          "type": "白",
          "text": "刘穷来了，不要沾了我们一身穷气，我们快些走吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四百姓同下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咳！这伙小人，真是气煞人也！正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "燕雀安知鸿鹄志，怎识风尘一丈夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上前看告示。"
        },
        {
          "character": "关羽",
          "type": "内白",
          "text": "闲人闪开，车来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽推车上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，可惜我刘备呀！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看那旁有一汉子，在那里自言自语，待我向前问来。 那一汉子你在此作甚？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我呀，看榜。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "粘贴榜文，为了何事？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "烟尘四起，朝廷招募新兵，保卫疆土。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你便怎么样？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有道是国家兴亡，匹夫有责。意欲前去投军，与国家做些惊天动地之事呀！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔呼呀！原来是个狂生。待我走去。闲人闪开，车过来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽推车下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀呀，这个红脸大汉，他也看不起我啊！"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "西皮散板",
          "text": "街巷人人来谈论， 处处百姓不安宁。 花开美景无人问， 又见城门贴榜文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、张飞对看，同背供。"
        },
        {
          "character": "刘备、张飞",
          "type": "同白",
          "text": "此人仪表倒也不凡！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "那一汉子在此作甚？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我在此观榜。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "可是招募新军之事？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是。唉，可惜呀，可惜。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你可惜何来？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我有心投军报效，怎奈落得这样贫穷，衣衫褴褛，被人薄眼相看。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "听兄台之言，你我倒也志趣相同。此地不好细讲，请到三好酒楼一叙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备为难。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我来作东道，走，走，走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、张飞同走圆场。刘备看招牌。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "念",
          "text": "肆外高挂三尺布，飘来飘去招主顾。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哪位？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我呀。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "刘穷，你又来赊账来啦？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "今日有人请我来的。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "谁请您？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你看，这是我的朋友哇。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "好，你今天又算有准饭碗啦。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三好，你这是怎样讲话！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "张大爷，我和他也是好朋友，常常说笑话。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嗯，带路！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是。您二位请吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、刘备同进门，同坐。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您吃什么酒？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好酒取来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "伙计们，好酒一壶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保下，上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "酒到，您请吃吧。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "请问兄长大名？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我姓刘名备，大树楼桑人氏。请问兄台尊姓大名？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在下姓张名飞字翼德，涿州人氏。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦张仁兄。失敬了，失敬了。请酒，请酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "西皮散板",
          "text": "闷坐店中神不定， 沽饮几杯解烦心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽看。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三好酒楼。酒保。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "来啦，您吃酒请进吧。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "前面带路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽进门。刘备、关羽、张飞互看，同背供。"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同白",
          "text": "此人仪表不凡，倒有些英雄气概。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "快将好酒取来。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你快些取酒来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是啦，是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保取酒送给张飞。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呔！酒保，俺要酒在先，你倒与他们先送上，莫非你这酒馆欺人不成！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞怒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "住了！你这人好无道理，俺在这里吃酒，你在一旁大惊小怪，是何理也？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住了！俺与酒保讲话，你在一旁答言，莫非你心中不服？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺本来不服。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我劝你少管。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我一定要管。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呸！着打！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "着打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞对打。刘备劝解。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不要打，不要打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、刘备对看。"
        },
        {
          "character": "关羽、刘备",
          "type": "同白",
          "text": "此人在哪里见过……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽同想。"
        },
        {
          "character": "关羽、刘备",
          "type": "同白",
          "text": "哦……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你可是那推车的那个汉子？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你可是那观榜的那个汉子？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不错。你吃酒来了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "既是朋友，恕咱老张莽撞了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "不敢。是我错了。"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同白",
          "text": "笑话了。"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "请坐，请坐。我们一处来饮。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请，我的东道。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎，我的东道。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我的东道吧。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "说大话哪。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三好，快取好酒来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保取酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "酒到，我与你们三位斟上。"
        },
        {
          "character": "刘备、关羽、张飞",
          "type": "同白",
          "text": "请，干。哈哈哈……"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "请问二位兄台尊姓大名？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我姓刘名备字玄德，大树楼桑人氏。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在下张飞字翼德，涿州人氏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刘、张二兄，失敬了。"
        },
        {
          "character": "刘备、张飞",
          "type": "同白",
          "text": "不敢。尊兄大名？贵乡何处？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "小弟姓关名羽字云长，乃蒲州解良人氏。"
        },
        {
          "character": "刘备、张飞",
          "type": "同白",
          "text": "关仁兄，失敬了。请问兄到此何事？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "前来贸易未遂，俺意欲前去投军，与国家出力报效。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我们志气相同。"
        },
        {
