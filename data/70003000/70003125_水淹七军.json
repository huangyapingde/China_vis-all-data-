{
  "script_id": "70003125",
  "title": "水淹七军",
  "alias": [
    "威震华夏"
  ],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "庞德",
      "hangdang": "净"
    },
    {
      "name": "关平",
      "hangdang": "武生"
    },
    {
      "name": "周仓",
      "hangdang": "净"
    }
  ],
  "plot": "关羽大败曹仁。曹操挂于禁为帅，庞德为先锋，统率七军往救。庞德预制棺木，誓与关羽死战。于禁嫉庞德\n夺功，不令出战，并将七军移屯城北罾口川。关羽乘襄江水涨，放水淹之，于是大破曹兵，生擒于禁、庞德。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "庞德上，起霸。"
        },
        {
          "character": "庞德",
          "type": "念",
          "text": "乌叶盔铠皂罗袍，大将威风杀气高。于禁挂了元帅印，庞德奋勇逞英豪。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "俺，姓庞名德字令名。只因曹仁襄阳败阵，魏王挂于禁为帅，命俺以为先行。 俺自备皮榇一口，此去援军，定与关羽决一死战。远远望见元帅来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、于禁同上。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "起兵襄阳去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "小马童引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "赤面雄心，须似乌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓上，亮相。"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "绿袍锦甲，逞威武。秉烛达旦天下晓，汉室美髯一丈夫。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "参见父王！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "威镇荆州统雄兵，运筹帷幄鬼神惊。东吴君臣俱丧胆，智压曹瞒百万军。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "桃园结义，玄德兄、翼德弟，誓同生死。某奉大哥之命，威镇荆襄九郡。前者 曹仁失机兵败，曹操定不干休。也曾命赵累将军，探听魏军动静，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵累上。"
        },
        {
          "character": "赵累",
          "type": "念",
          "text": "探得机密事，回报君侯知。"
        },
        {
          "character": "赵累",
          "type": "白",
          "text": "启禀君侯：今有曹操，挂于禁为帅，统领七路人马。庞德以为先锋，自带皮榇 一口，要与君侯决一死战。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "参谋紧守大营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵累下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "且住！庞德小儿，不过是马超帐下一员小将，何敢出此狂言？庞德呀，庞德！ 任你英勇无敌手，难逃关某偃月刀。 周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "排开阵式，迎敌者！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "咋，排开阵式，迎敌者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、马童、庞德、关羽同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "呔，马前来的敢是庞德？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "然！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "庞将军！关某威名，尔岂不知？若肯归降，关某有爱将之癖，饶你不死。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "关羽！某奉魏王之命，来解樊城之围。今日阵前相会，倒要看看你的刀法如何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关羽马前，未遇三合之将。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。关羽、庞德同对刀。于禁、马良双上，摇旗。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "呔，关羽你敢是怯战？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你营先自鸣金，何言关某怯战？ 众将官！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、马童、众将同下。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "且住。某与关羽，大战一百余合，眼见关羽气力不足。不知元帅为何鸣金收兵？ 众将官！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、于禁同上。"
        },
        {
          "character": "于禁",
          "type": "念",
          "text": "统领七军身为重，岂容庞德立头功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、四上手同上。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "参见元帅！"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "庞将军辛苦了。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "元帅，适才关羽阵前，力已不支，正要擒他下马，元帅为何鸣金收兵？"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "这个……某恐关羽有诈，故而鸣金。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "元帅，依某之见趁此锐气，统领七军，冲入敌营，以解樊城之围。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "哎！临行之时，魏王曾传谕旨，告诫我等不可轻敌。依本帅之见，只宜谨守， 切莫贪功。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "元帅！魏王有言，可取则取，不可取则宜谨守。今日一战，胜负即见，理当进 取。何言庞某贪功？"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "本帅遵奉谕旨，早有成算在心。就将七路大军，移往樊城之北，依山下寨。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "庞德听令！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "命你带领本部人马，屯扎山谷之内，无令不可进兵，本帅自有奇谋破敌。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "得令！带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、四下手同下。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "将人马扎在山旁，截断大路，阻挡关羽，并防庞德擅自进兵。就此移营者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "于禁、众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马童、周仓引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "传令下去，人不可卸甲，马不可离鞍，明日五鼓天明，大战庞德。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "咋，咋，咋！ 三军的，人不可卸甲，马不可离鞍，明日五鼓天明，大战那庞德。"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童下。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "传令已毕。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "起过一旁。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "收了刀枪卷了旗，两下鸣金各自归。强中自有强中手，庞德刀法世间稀。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "庞德好刀法！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "恨庞德英勇无敌，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓交过刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀哇！想你过关斩将，何等威风。今日小小庞德，战他不过，好不气煞人也！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "纵有青龙刀要尔何用。 大骂庞德尔好威风，尔好煞气， 阵前逞能轻视俺关某—— 赤兔马要尔还何用。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "只怕那庞德，明日再来讨战。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "那庞德明日里若来讨战——"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "待俺周仓会他一会。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你么？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "某与少将军一同出马。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "我等随定君侯，杀他个三马连环。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "三马连环战庞德，岂不羞惭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平上。"
        },
        {
          "character": "关平",
          "type": "念",
          "text": "于禁迁移营，进帐报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平进帐。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "启禀爹爹：今有于禁将七路军马，移在山口扎营。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有这等事？ 关平、周将随我查看者。"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "离却宝帐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽向下场望。"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "出营房敌情查防，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽向上场望。"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "雾腾腾杀气弥漫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽向中场望。"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "上山冈仔细观望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽正场高望。"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "白茫茫一带襄江，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声。"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "又听得水声沧浪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "七军同上，过场，同下。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "哇呀呀！"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "魏营中移营盘军号喧嚷， 猛然间计上胸膛。 乘襄江狂涛怒涨， 擒庞德和七军尽赴汪洋。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "回营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、周仓、关平同下山，关羽归座。众将同上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哈哈哈！"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "爹爹为何发笑？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我笑的是庞德恃勇，于禁无谋。七路大军，屯扎在罾口川低洼之处。鱼入罾口， 岂能久乎？某略施小计，管叫他全军尽没。"
        },
        {
          "character": "周仓、关平",
          "type": "同白",
          "text": "君侯之计如何？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "沿江决口，水淹七军。 周将听令！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "咋。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "命你将树伐倒，造成木排，带领五百水手，生擒庞德。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平听令！"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "命你带领一千人马，准备沙囊土袋，去至襄江，将上下流水堵塞。只等江水暴 涨，将近上流土袋撤去，决破堤口，然后水面杀敌。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "全军人马，连夜移驻高阜之上准备船只，尽灭七军去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、于禁同上。"
        },
        {
          "character": "于禁",
          "type": "念",
          "text": "兵扎罾口川，犹如铁桶般。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德、四下手同上。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "庞将军到此何事？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "适才差人暗探敌人动静，荆州兵马，移驻高阜之上，其中有诈。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "关羽移营，何诈之有？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "想这七军屯于川口，地势甚低，而今秋雨连绵，江水暴涨。倘若关羽决口放水， 我军危矣。就请元帅传令，速速移营！"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "哎！移营方定，军士辛苦，再若移动，那关羽乘势截杀，如何抵挡？"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "兵贵神速，不可迟疑。关羽杀来，有某抵挡。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "说什么迟疑不迟疑，分明是你危言耸听，贪功好胜。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "元帅！某以七军为重，何言贪功好胜？元帅不肯移营，俺庞德愿将本部军马， 移驻高阜之上，倘有不测，也好接应。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "容某思之。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅，襄江决口，直灌我营。"
        },
        {
          "character": "于禁",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "众将官！速速离营！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声冲众人同下。"
        }
      ]
    },
    {
