      "hangdang": "生"
    },
    {
      "name": "费诗",
      "hangdang": "生"
    },
    {
      "name": "糜芳",
      "hangdang": "丑"
    },
    {
      "name": "傅士仁",
      "hangdang": "丑"
    },
    {
      "name": "诸葛瑾",
      "hangdang": "生"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    },
    {
      "name": "曹仁",
      "hangdang": "净"
    }
  ],
  "plot": "曹操遣满宠往东吴求和，步隲献策，孙权命诸葛瑾向关羽为世子求婚，以结纳西蜀，共同抗曹。关羽拒之，\n称虎女焉能配犬子。孙权大怒，决心与曹操联盟。刘备进位汉中王，封关羽、张飞、赵云、马超、黄忠为五\n虎上将，密嘱关羽攻取襄阳、樊城。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张昭、诸葛谨、步隲、阚泽同上。"
        },
        {
          "character": "众人",
          "type": "同点绛唇",
          "text": "三国纷纷，屡起战争，何日里，干戈宁静，军民齐安定。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "张昭。"
        },
        {
          "character": "诸葛谨",
          "type": "白",
          "text": "诸葛谨。"
        },
        {
          "character": "步隲",
          "type": "白",
          "text": "步隲。"
        },
        {
          "character": "阚泽",
          "type": "白",
          "text": "阚泽。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "列公请了。"
        },
        {
          "character": "诸葛谨、步隲、阚泽",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "今有曹操差满宠前来求和，稍时吴侯登殿，把本启奏。看！香烟缭绕，圣驾临 朝，分班伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引孙权同上。"
        },
        {
          "character": "孙权",
          "type": "引子",
          "text": "占据江东，承父业，虎踞龙争。"
        },
        {
          "character": "张昭、诸葛谨、步隲、阚泽",
          "type": "同白",
          "text": "臣等见驾，吴侯千岁！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "张昭、诸葛谨、步隲、阚泽",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "承父兄业守江东，人杰地灵称英雄。刘备借去荆州地，久据不还恼心中。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤，姓孙名权字仲谋。承父兄基业，虎踞江东。当年赤壁鏖兵，得了荆襄九郡。 可恨刘备，借去荆州，屯兵养马，久据不还，欺人忒甚。今日设立早朝，商 议讨回荆州之策。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "臣启吴侯：今有曹操，命满宠前来求和，现在殿角候旨。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "代孤传旨，满宠上殿。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "满宠上殿。"
        },
        {
          "character": "满宠",
          "type": "内",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "满宠上。"
        },
        {
          "character": "满宠",
          "type": "念",
          "text": "离了许昌地，求和到东吴。"
        },
        {
          "character": "满宠",
          "type": "白",
          "text": "满宠见驾，吴侯千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "罢了。先生驾临江东，有何见教？"
        },
        {
          "character": "满宠",
          "type": "白",
          "text": "奉了我主之命，前来议和，现有书信呈上。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张昭接信递与孙权。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "曹公有书信到来，待孤拆开一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。孙权观书信。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "请满先生暂到迎宾馆待茶，容我君臣商议。"
        },
        {
          "character": "满宠",
          "type": "白",
          "text": "告退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "满宠下。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "众卿！曹操差满宠前来，会同东吴合攻荆州，众卿之意如何？"
        },
        {
          "character": "步隲",
          "type": "白",
          "text": "臣有一计献上。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "卿家有何妙计？"
        },
        {
          "character": "步隲",
          "type": "白",
          "text": "闻得关羽生有一女，甚为贤淑，我主世子，聪明过人。可命一人前去求婚，倘 若应允，孙刘合兵，共破曹操；若不成功，孙曹联盟，先取荆州，后破西蜀， 有何难哉。千岁圣裁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "此计甚好，就命子瑜速往荆州求婚，联盟破曹，不得有误。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾下。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "子布准备酒宴。款待满宠。退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四马夫过场。关平、廖化、王甫、周仓、四绿文堂、四上手、糜芳、傅士仁、马良、伊籍、关兴、赵累、"
        },
        {
          "character": null,
          "type": "text",
          "text": "关羽同上。）"
        },
        {
          "character": "关羽",
          "type": "引子",
          "text": "绿袍金甲须似灰，凤目蚕眉美髯公。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "参见君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "少礼，站下。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "谢君侯。"
        },
        {
          "character": "关羽",
          "type": "诗",
          "text": "志气凌云贯斗牛，平生最喜读春秋。丈夫须抱凌云志，自然谈笑觅封侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某，汉室关。今奉大哥与军师将令，镇守荆州一带等处。可恨曹操，命曹仁据 守襄阳、樊城，久欲前去攻取，怎奈未奉大哥诏谕，未便妄动。我想荆州乃东 吴之地，未必就此罢休，为此每日操演人马，紧防对敌。 站堂军！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀君侯：诸葛瑾求见。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔呼呀！想诸葛瑾乃军师令兄，不可慢待。 来！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾上。"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "奉了吴侯命，讲和来求亲。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "君侯在上，瑾大礼参拜。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "子瑜远道而来，只行常礼。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "哪有不拜之理。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "来！与先生看座。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "慢来，君侯帐下，哪有瑾的座位！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "远来贵客，焉有不坐之礼。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生到此，必有所为。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "恭喜君侯，贺喜君侯！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "何喜之有？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "我主有一世子，聪明过人，闻得君侯令爱十分贤淑。瑾奉我主之命，前来求婚， 两家结为秦晋之好，共同破曹。望乞君侯，幸勿推辞。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "汝主犬子，岂配关某虎女？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "公言犬子不配虎女。可记得令兄玄德公，在甘露寺招亲之事乎？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "子瑜大胆！"
        },
        {
          "character": "关羽",
          "type": "西皮二六板",
          "text": "闻言怒发三千丈， 一言怒恼关云长； 若不看军师诸葛亮， 定斩尔首级挂营房。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唗！胆大诸葛瑾，进得帐来，信口胡言。若不看有令弟之面，定要汝头。 来，叉出帐去！"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "出帐去吧！"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "用手捧尽湘江水，难洗今朝满面羞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾下。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二君侯失计了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "诸葛瑾前来提亲，君侯既不应允，就该用善言回复，不该将他羞辱一场。他今 回去，定在孙权面前，搬动是非。倘若孙曹合兵，同取荆州，岂不又费波折。 望君侯从速准备应敌，以防措手不及。君侯三思。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "瓮中之水，能起多大波浪；蝼蚁之辈，焉能撼动泰山。且勿多言。 掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、步隲、张昭、孙权上。"
        },
        {
          "character": "孙权",
          "type": "西皮散板",
          "text": "子瑜荆州去求婚， 但愿相去把功成。 誓扫中原烟尘定， 同心破曹方趁心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛谨上。"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮散板",
          "text": "可恨关羽言不顺， 上殿启奏我主君。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "子瑜回来了，提亲之事如何？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "关羽不允亲事，反而出言不逊，臣未敢冒奏。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "无妨，只管奏来。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "是他言道：虎女不配犬子。并将为臣羞辱一场。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "可恼哇，可恼！"
        },
        {
          "character": "孙权",
          "type": "西皮散板",
          "text": "恼恨关羽言不逊， 不该胡云伤孤身。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "可恨关羽品出不逊，藐视东吴，欺孤忒甚，众卿有何对策？"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "臣启主公：既然如此，正好命满宠回复曹公，照书行事，孙曹合兵，攻打荆州。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "卿言正合孤意，满先生上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "满面先生上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "满宠上。"
        },
        {
          "character": "满宠",
          "type": "白",
          "text": "参见吴侯。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "罢了！拜上你主，照书行事，请速进兵，先取荆州，后破西蜀。"
        },
        {
          "character": "满宠",
          "type": "白",
          "text": "告退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "满宠下。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "众卿！不知命何人挂帅，方可当此重任？"
        },
        {
          "character": "步隲",
          "type": "白",
          "text": "速调吕蒙还朝议事，就命子明挂帅，必然成功。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "子布替孤传旨，速调子明还朝议事。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关平、周仓同上。"
        },
        {
          "character": "关平、周仓",
          "type": "同念",
          "text": "父子同心秉忠义，扶保汉室锦乾坤。"
        },
        {
          "character": "费诗",
          "type": "内白",
          "text": "诏命下。"
        },
        {
          "character": "关羽",
          "type": "内",
          "text": "香案接诏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂引关羽、费诗同上。众将自两边分上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "司马为何不开读？"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "有密言相告，请过圣命。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "香案供奉。司马有何密言？当面赐教。"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "主公进位汉中王了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某大哥进位汉中王，封某何职？"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "五虎上将之首。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "五虎将不知都是何人？"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "关、张、赵、马、黄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关、张、赵、马、黄？翼德，我弟也。子龙久随大哥，建立功勋，犹我弟也。 孟起世代名家。黄忠老儿乃长沙一武夫耳，焉能与某等并列？关某不受此爵。"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "二君侯此言差矣！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "二君侯何必计位高下，昔日高祖与萧、曹共议大事，韩信乃楚国之亡将耳，后 封三齐王，并未曾闻萧、曹争过爵位。汉中王与君侯亲同手足，视为一体，汉 中王即君侯，君侯即汉中王。君侯受汉中王厚恩，当与同共休戚，不宜计较官 爵之高下，望君侯三思。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔呼呀！若不是司马明言指教，险误大事，看印拜过。"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "现有密旨一道，命二君侯攻打襄阳、樊城。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "领旨。 糜芳、傅士仁听令！"
        },
        {
          "character": "糜芳、傅士仁",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "命你二人以为前站先锋，城外扎营，听候调遣。"
        },
        {
          "character": "糜芳、傅士仁",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳、傅士仁同下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "备有酒宴与司马同饮。"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "到此就要叨扰。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平把盏。 司马请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀君侯：城外营中失火。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平听令！"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "速往城外查看。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "司马请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平上。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "启父王：糜芳、傅士仁纵军饮酒，自不小心，因而起火，伤损粮草军器炮火， 死伤本部军卒数名。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "噢！竟有这等事，将他二人抓来见我。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "司马请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关平上。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "糜芳、傅士仁传到。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在！"
