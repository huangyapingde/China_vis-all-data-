          "character": "周仓",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳、傅士仁同上。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "嘚！糜芳、傅士仁，君侯叫你二人报门而进。要仔细了！要打点了！ 报门！"
        },
        {
          "character": "糜芳、傅士仁",
          "type": "同白",
          "text": "报！（糜芳）（傅士仁）告进！参见君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唗！你二人竟敢纵军饮酒，伤损本部军卒，推出斩了！"
        },
        {
          "character": "费诗",
          "type": "白",
          "text": "且慢！用兵之际，斩将不利。"
