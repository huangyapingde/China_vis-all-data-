        {
          "character": "关羽",
          "type": "白",
          "text": "关平以为副将。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马良、伊籍听令。"
