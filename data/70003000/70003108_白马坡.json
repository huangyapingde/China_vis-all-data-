        {
          "character": "曹操",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "我营将士心胆寒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良上。朱灵、路昭同上，起打，颜良杀朱灵、路昭。"
        },
        {
          "character": "颜良",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颜良下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可怜二将，又死于颜良之手！无人能敌，如何是好？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "丞相休惊，某虽不才，愿去万军之中取颜良首级，来献麾下。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "啊，二将军，有道是军无戏言。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文远，你好小量关某也。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "非是关某敢斗胆， 熟读春秋志不凡。 精神贯日扶炎汉， 气盖群雄社稷安。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽卸袍。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "辞别丞相跨雕鞍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下山。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "即刻立功寻兄还！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        }
      ]
