{
  "script_id": "70003104",
  "title": "斩华雄",
  "alias": [
    "汜水关"
  ],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "刘备",
      "hangdang": "生"
    },
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "袁绍",
      "hangdang": "净"
    }
  ],
  "plot": "曹操约同十八路诸侯至陈留举义，誓欲剿灭董卓。刘备率领关、张随公孙瓒同往陈留。董卓部将华雄骁勇无\n敌，连斩数将，众诸侯不敢出战。关羽讨令，袁绍轻慢，曹操斟酒敬关羽，以示鼓励。关羽出马立斩华雄，\n回营交令，杯酒尚温。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹嵩上。"
        },
        {
          "character": "曹嵩",
          "type": "西皮原板",
          "text": "董卓专权行不正， 害得我一家骨肉分。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。曹操上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "曹嵩",
          "type": "白",
          "text": "吾儿回来为何？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "爹爹容禀：孩儿献剑谋刺董卓事败，多蒙中牟县令陈宫，弃官与儿同逃，才得 回到陈留。"
        },
        {
          "character": "曹嵩",
          "type": "白",
          "text": "就该约请各路诸侯，灭除国贼，与民除害！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孩儿正有此意。"
        },
        {
          "character": "曹嵩",
          "type": "白",
          "text": "如此书房速速修书，派人分路前往。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹嵩、曹操同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四旗牌同上。"
        },
        {
          "character": "旗牌甲",
          "type": "白",
          "text": "请了。奉了曹公之命，搬请各路诸侯，陈留起义，就此分路前往！"
        },
        {
          "character": "三旗牌",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四旗牌自两边分下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗，〖急急风〗。四龙套、程普、祖茂、黄盖、韩当、孙坚同上。"
        },
        {
          "character": "孙坚",
          "type": "白",
          "text": "俺，长沙太守孙坚。只因曹公有书相约，陈留举义。 众将官！陈留去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉同上。"
        },
        {
          "character": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉",
          "type": "同白",
          "text": "孙将军，今欲何往？"
        },
        {
          "character": "孙坚",
          "type": "白",
          "text": "曹公相约，陈留举义。列公何往？"
        },
        {
          "character": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉",
          "type": "同白",
          "text": "我等也是为此事而来。"
        },
        {
          "character": "孙坚",
          "type": "白",
          "text": "好，兵合一处，一同前往。 众将官，陈留去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、马童、袁绍同上。"
        },
        {
          "character": "袁绍",
          "type": "西皮摇板",
          "text": "四世三公谁不晓， 协力忠心辅汉朝， 鞭稍一指催前哨——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚同上。"
        },
        {
          "character": "袁绍",
          "type": "西皮摇板",
          "text": "列公缘何共相邀？"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "众位诸侯，统兵何往？"
        },
        {
          "character": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚",
          "type": "同白",
          "text": "曹公相约。袁公何往？"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "俺也是曹公相约，大家一同前往。"
        },
        {
          "character": "袁绍",
          "type": "西皮摇板",
          "text": "合兵同往陈留郡， 见了曹公叙衷情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四龙套同上，公孙瓒上。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "俺，公孙瓒。曹公约我，陈留议事，前面已是平原县，不免约请桃园弟兄，一 同前往。 军士们，平原县去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "东奔西驰路重重， 沙滩无水困蛟龙， 何日才得风云动， 英雄方能建奇功。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，请二爷、三爷前来！"
        },
        {
          "character": "关羽、张飞",
          "type": "内同白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "桃园结义似同胞。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "冲锋陷阵把名标。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "参见大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "贤弟少礼，请坐。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "谢座。唤弟等前来，有何事议？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "想你我弟兄为国建立大功，董卓老贼在朝专权，愚兄才得区区平原县令之职， 二弟、三弟只为步马弓手。不知何日才得出头？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "当初若依小弟，打死督邮，杀死董卓，你我弟兄焉能身受此害！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "静等机会，自有出头之日。"
        },
        {
          "character": "四龙套",
          "type": "内同白",
          "text": "公孙太守到。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。〖牌子〗。公孙瓒、四龙套同上，刘备迎，同入座。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "公孙太守到此必有所为。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "曹公在陈留举义，贤弟因何不去？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "官卑职小，又无引荐之人。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "兄与你做个引荐之人。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "公孙兄先行，弟随后就到。"
        },
        {
          "character": "公孙瓒",
          "type": "白",
          "text": "告辞了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公孙瓒、四龙套同下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "带马伺候。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "公孙太守来约请， 陈留郡府走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、关羽、张飞同上马，同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹操上。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "陈留会诸侯，灭却祸国臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "各路诸侯到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚、公孙瓒、程普、祖茂、黄盖、韩当同上，过"
        },
        {
          "character": null,
          "type": "text",
          "text": "场，同下。刘备、关羽、张飞同上，过场，同下。袁绍、四龙套、马童同上，过场，同下。曹操、旗牌同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚、公孙瓒、程普、祖茂、黄盖、韩当同上。刘"
        },
        {
          "character": null,
          "type": "text",
          "text": "备、关羽、张飞同上，同进城，同下。袁绍、四龙套、马童同上。）"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊，袁公。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "曹公。 （曹操、袁绍同笑，同下。曹操、袁绍、王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚、公孙 瓒、程普、祖茂、黄盖、韩当、刘备、关羽、张飞同上，同挖门。）"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众位诸侯驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚、袁绍、公孙瓒",
          "type": "同白",
          "text": "岂敢。来得鲁莽，曹公海涵。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚、袁绍、公孙瓒",
          "type": "同白",
          "text": "曹公相约，不知为了何事？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "只因董卓在朝专权，上欺天子，下压群臣，实为国家之患，黎民之害。为此约 请众位诸侯，到此一同商议，灭除董卓，以除后患。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "要灭董卓，必须立一盟主，大家听候调遣。"
        },
        {
          "character": "王匡",
          "type": "白",
          "text": "要立盟主非袁公不可。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "绍才疏学浅，不敢当此重任。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "本初乃四世三公，门多故吏，此任非袁公不可。"
        },
        {
          "character": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚、公孙瓒",
          "type": "白",
          "text": "就请袁公登台点将。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "多承列公抬爱，恕某有僭了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。〖牌子〗。袁绍登将台。"
        },
        {
          "character": "王匡、马腾、孔融、陶谦、鲍信、袁术、潘凤、俞涉、孙坚、公孙瓒",
          "type": "同白",
          "text": "参见盟主。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "列公少礼。"
        },
        {
          "character": "袁绍",
          "type": "念",
          "text": "可恨董卓祸国臣，招惹四路起战争。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "绍蒙列公抬举，立为盟主，今为剿灭国贼，必须人人奋勇，各个当先，兵法有 云：兵马未动，粮草先行。 袁术听令！命你催押粮草，不得有误。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁术下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "哪位诸侯带领人马，攻打汜水关，当帐请令。"
        },
        {
          "character": "孙坚",
          "type": "白",
          "text": "盟主，俺孙坚不才，愿统领人马，攻打汜水关，生擒华雄进帐。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "好，孙文台听令！命你带领本部人马，攻打汜水关，生擒华雄，不得有误。"
        },
        {
          "character": "孙坚",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙坚、四龙套、程普、祖茂、黄盖、韩当同下。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "撤去将台，某得罪了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "后帐摆宴，与列公接风。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁绍、曹操、王匡、马腾、孔融、陶谦、鲍信、潘凤、俞涉、公孙瓒同下，刘备、关羽、张飞同叹，同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套、上手、大刀手、华雄同上。华雄上高台。"
        },
        {
          "character": "华雄",
          "type": "念",
          "text": "匹马单刀建奇功，久敌疆场马蹄红。今日兴动人和马，要把诸侯一扫空！"
        },
        {
          "character": "华雄",
          "type": "白",
          "text": "某，华雄。奉董太师钧旨，镇守汜水关，剿灭各路诸侯。也曾命探子扫探军情， 未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "诸侯讨战！"
        },
        {
          "character": "华雄",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "华雄",
          "type": "白",
          "text": "众将官！带马，杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙坚、四龙套、程普、祖茂、黄盖、韩当同上，会阵。"
        },
        {
          "character": "华雄",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "孙坚",
          "type": "白",
          "text": "长沙太守孙坚。"
        },
        {
          "character": "华雄",
          "type": "白",
