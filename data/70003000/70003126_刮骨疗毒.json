{
  "script_id": "70003126",
  "title": "刮骨疗毒",
  "alias": [],
  "source": "李洪春剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红生"
    },
    {
      "name": "华佗",
      "hangdang": "生"
    }
  ],
  "plot": "关羽攻克襄阳，继取樊城。曹仁放冷箭射中关羽右臂，箭镞有毒，致使右臂青肿，无法出战。名医华佗慕关\n羽神威，自往医治。关羽与马良弈棋，坦然伸臂，华佗乃刮骨疗毒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、吕常上。"
        },
        {
          "character": "吕常",
          "type": "念",
          "text": "奉了魏王命，镇守在樊城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹仁、众人同上。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "杀败了哇，杀败了！"
        },
        {
          "character": "吕常",
          "type": "白",
          "text": "将军为何这等模样？"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "襄阳失守，关羽追杀前来，如何是好？"
        },
        {
          "character": "吕常",
          "type": "白",
          "text": "将军不必惊慌，末将有一计在此。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "吕常",
          "type": "白",
          "text": "末将出城，与关羽对敌，将军伏在城楼，暗放冷箭，哪怕关公不灭。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "此计甚好！但听一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "关羽讨战。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "众将官，杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吕常、众人同出城。曹仁站城上。众将、关羽同上。二龙出水。关羽、吕常同架住。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "吕常",
          "type": "白",
          "text": "大将吕常。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽劈死吕常。关羽望城。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "曹仁闭关不战，真乃匹夫之辈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽面向外三笑。曹仁放冷箭，中关羽右臂。众将扶关羽同下。曹仁下城。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "小心防守。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马良上。"
        },
        {
          "character": "马良",
          "type": "念",
          "text": "君侯去出征，未见转回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、众将同上。"
        },
        {
          "character": "众将",
          "type": "白",
          "text": "君侯醒来！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "这一阵杀得我精神衰，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽抚伤。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "胆大的曹仁贼暗放冷箭。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "君侯出战，中了何人冷箭？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "适才两军阵前，曹仁暗施冷箭，伤我右膀。曹仁哪，贼！我不伤你非为丈夫也！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "是好汉尔就该冲锋对垒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽手抚伤处。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "冷箭伤人尔非为英雄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "免战牌高悬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "华佗上。"
        },
        {
          "character": "华佗",
          "type": "新水令",
          "text": "清水池边红日悬， 松柏滴翠柳成行。 济世仙人行善念， 堪笑世人利禄忙。"
        },
        {
          "character": "华佗",
          "type": "念",
          "text": "天上星辰日月，人间山水物华。山中风景多幽雅，还是天地为大。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "贫道姓华名陀字元化，乃沛郡人也。自幼入山修炼，蒙异人传授歧黄，医治为 本，并非贪利，不过济世救人。前者在东吴医治周泰箭伤；近闻关公在襄阳身 中箭伤，不免前去医治，顺便瞻仰关公虎威。 童儿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小童暗上。"
        },
        {
          "character": "小童",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "背了药箱前往蜀营去者。"
        },
        {
          "character": "华佗",
          "type": "新水令",
          "text": "只为云长一箭伤， 亲自前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华佗、小童同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周仓上。"
        },
        {
          "character": "周仓",
          "type": "念",
          "text": "悬挂招医榜，满营昼夜忙。"
        },
        {
          "character": "华佗",
          "type": "内白",
          "text": "带路！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小童引华佗同上。"
        },
        {
          "character": "华佗",
          "type": "江儿水",
          "text": "路行飘荡速速去慌忙， 携带药箱奔荆襄； 五虎上将人钦仰， 特来医治到樊襄。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "门上哪位听事？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "作什么的？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "烦劳通禀，华佗求见。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有请父王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马良引关羽同上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "惟恐军心乱，忍痛下围棋。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "华佗求见。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马将军，华佗何许人也？"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "华佗乃世外高人，前在东吴曾医周泰箭伤，君侯快快传见。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "说我有请。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有请华先生。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "君侯在上，贫道有礼。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生少礼，请坐。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "君侯在上，哪有贫道的坐位。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "有话叙谈，焉有不坐之理。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生到此，有何见教？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "闻得君侯在樊城中箭，特来医治。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "就劳先生一看。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "待贫道一观。唔呼呀！此乃弩箭所伤，箭头有毒透入骨髓，若不急速医治，此 臂就残废了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唔！请问先生可有治法？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "在厅前立一标杆，上钉铜环，君侯将膀臂穿在环内，用绳索捆住；再选数名精 壮大汉，扶定将军，方可医治。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生医治箭伤，用标杆铜环大汉何用？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "君侯哪里知道，治此箭伤，必须割破皮儿，挖去烂肉，刮净骨儿疗去毒，恐君 侯难以忍痛耳。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哼哼哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽冷笑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某久历疆场，百万军中，向无惧色，今日何惧箭伤！我与马将军饮酒弈棋，就 请先生动手。 周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "设下棋盘，与先生更衣。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "遵命。 （万年欢牌。大边斜摆竖桌，关羽、马良对坐。周仓站小边，华佗更衣，小童跪端盆，华佗置关羽右手于小 童头上。关羽举杯。）"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽饮酒。"
        },
        {
          "character": "关羽",
          "type": "吹腔",
          "text": "设下棋盘两交战， 不用刀枪我和你厮杀一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "万年欢牌。华佗医伤，周仓哭泣，关羽笑，马良敬酒。周仓不时拦阻。华佗刮毒时，关羽举杯让酒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽笑。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "嗯——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽示周仓不许拦阻。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "请二君侯试臂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽站起，三伸右膀。"
        },
        {
          "character": "关羽",
          "type": "三笑",
          "text": "哈哈，哈哈，哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上坐，华佗下坐。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "马良听令！"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "镇守荆州去吧！"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马良下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生真乃神人也。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "贫道一生未尝见过君侯如此虎威，真乃天神也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看黄金千两，赠送先生。"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "且慢！贫道浪迹江湖，要那黄金何用！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关某何以答报？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "君侯乃当世英雄，贫道特来解救，未敢望报。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生几时启程？"
        },
        {
          "character": "华佗",
          "type": "白",
          "text": "明日动身。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周将！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "准备船只，明日送先生过江。后帐摆宴，与先生送行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}