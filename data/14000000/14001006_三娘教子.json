        {
          "character": "王恩",
          "type": "白",
          "text": "为国勤劳，何言风霜之苦。"
        },
        {
          "character": "薛子奇",
          "type": "白",
          "text": "后堂留宴。"
        },
        {
          "character": "王恩",
          "type": "白",
          "text": "朝命在身，不敢久留。告辞了。 孩子们打道。"
        },
        {
          "character": "薛子奇、王春娥、薛倚哥、薛保",
          "type": "同白",
          "text": "送公公。"
        },
        {
          "character": "王恩",
          "type": "白",
          "text": "免送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王恩、四小太监同下。薛子奇、王春娥、薛倚哥、薛保同笑。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "薛保，看官诰过来。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "是，官诰在此。"
        },
        {
          "character": "薛倚哥",
          "type": "白",
          "text": "母亲，孩儿上京，平步登云。挣来凤冠霞帔，母亲请来穿戴。"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "为娘穿了你父的。 先堂前。"
        },
        {
          "character": "薛倚哥",
          "type": "念",
          "text": "愿母亲长穿长戴，"
        },
        {
          "character": "王春娥",
          "type": "念",
          "text": "喜我儿官上加官。"
        },
        {
          "character": "薛子奇",
          "type": "念",
          "text": "父子们名登京榜，"
        },
        {
          "character": "薛保",
          "type": "念",
          "text": "双官诰万古流传。"
        },
        {
          "character": "薛子奇",
          "type": "白",
          "text": "好一个“万古流传”。府门照事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏、刘氏同上。"
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "天不怕，"
        },
        {
          "character": "刘氏",
          "type": "念",
          "text": "地不怕，"
        },
        {
          "character": "张氏",
          "type": "念",
          "text": "只怕薛保，"
        },
        {
          "character": "刘氏",
          "type": "念",
          "text": "这老家伙。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "实只望改嫁了享受荣华，谁想仍是朝不保夕，有一顿没一顿的。闻听老爷未死， 衣锦还乡。儿子倚哥少年登科，想他们顾念旧情，必然收容你我。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "正是。现在也顾不了许多，且回家去走一遭。来此已是，薛保这老头儿，我有 些怕他。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "好，待我前去见他。 薛保，薛保！"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "什么人，大胆敢叫我一声薛保？"
        },
        {
          "character": "刘氏、张氏",
          "type": "同白",
          "text": "你张、刘二奶奶回来了。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "张、刘二妇。"
        },
        {
          "character": "刘氏、张氏",
          "type": "同白",
          "text": "二奶奶。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "在我家里是张、刘二奶奶。如今另行改嫁，还是二妇。"
        },
        {
          "character": "刘氏、张氏",
          "type": "同白",
          "text": "二奶奶也罢，二妇也罢，与我们传稟，就说我们两个回来了。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "叫谁与你们传稟？"
        },
        {
          "character": "刘氏、张氏",
          "type": "同白",
          "text": "叫你与我们传稟。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "你如今还劳不起我呢。"
        },
        {
          "character": "张氏",
          "type": "白",
          "text": "我想妹子，人是自己的人。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "门是自己的门。何用你传，我自己进去。"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "不必进去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张氏、刘氏同进门。"
        },
        {
          "character": "张氏、刘氏",
          "type": "同白",
          "text": "恭喜老爷，我们回来了。"
        },
        {
          "character": "薛子奇",
          "type": "白",
          "text": "呸！无耻贱人，还不往下站！"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "往下站！"
        },
        {
          "character": "薛子奇",
          "type": "白",
          "text": "三娘，当日二贱人，怎样为难与你，上前骂来！"
        },
        {
          "character": "王春娥",
          "type": "白",
          "text": "老爷！"
        },
        {
          "character": "王春娥",
          "type": "西皮散板",
          "text": "闻此言思前情伤心落泪， 到庭前把贱人数骂一番。 望老爷休见怪妾身之罪，"
        },
        {
          "character": "薛子奇",
          "type": "白",
          "text": "不怪与你。"
        },
        {
          "character": "王春娥",
          "type": "西皮散板",
          "text": "老薛保忙打坐莫把帘垂。 出言来骂一声无耻贱婢， 抬起头睁开眼你们看看我是谁？ 想当初虐待我悔也不悔？ 到如今受饥饿又来怨谁？ 只骂得二贱婢无言答对， 叫薛保赶出门莫令回归。"
        },
        {
          "character": "薛子奇",
          "type": "西皮散板",
          "text": "王夫人息怒且归位， 二贱婢把我的双目气黑。 想当年我四人鸾交凤配， 夫在世妻改嫁是何道理？ 既改嫁你何必心思追悔， 你只知王夫人有三从四德， 只骂得二贱婢无言答对。 叫薛保你与我把二贱婢赶出门外！ 薛保　　　张氏　　　（白）　　　　　妹子，状元是你养的，是我抱大的。我二人分状元来。 老爷，状元是她生的，我抱大的，我们要分状元。"
