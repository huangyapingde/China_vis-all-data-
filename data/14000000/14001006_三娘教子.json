          "text": "罢罢罢，看我儿与薛保之面， 头戴凤冠我把霞帔来穿。"
        },
        {
          "character": "张永",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": "薛子奇",
          "type": "白",
          "text": "夫人请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王春娥下。"
        },
        {
          "character": "薛倚哥、薛子奇",
