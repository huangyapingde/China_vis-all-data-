        },
        {
          "character": "薛子奇、王春娥、薛倚哥、薛保",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": "大监",
          "type": "白",
          "text": "听宣读诏曰，只因薛子奇镇守镇江有功，圣上见喜，封为忠义大夫。薛忠孝年 轻登科，外赐孝义科家。王氏春娥教子成名，封为节义夫人。老薛保为主受过 千辛万苦，封为织机员外郎，恩赐龙头半拐，哪家争吵打死勿论。又命本处地 方官长，在十字街头，与三娘盖造贞节牌坊一座，留名千古。前赐“忠孝节义” 四字牌匾，悬挂中堂。旨意读罢，望诏谢恩。"
        },
        {
          "character": "薛子奇、王春娥、薛倚哥、薛保",
          "type": "同白",
          "text": "谢万岁！"
        },
        {
          "character": "王恩",
          "type": "白",
          "text": "请过圣命。"
        },
        {
          "character": "薛子奇",
          "type": "白",
          "text": "有劳公公奉旨前来，一路之上，多受风霜之苦。"
