        {
          "character": "薛倚哥",
          "type": "西皮摇板",
          "text": "尊一声母亲听儿言： 母亲受过雪里寒， 这凤冠霞帔理当穿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛保暗上。"
        },
        {
          "character": "王春娥",
          "type": "西皮散板",
          "text": "小娇儿休得要把娘来劝， 自有你生身母她指日回还。"
        },
        {
          "character": "薛保",
          "type": "西皮散板",
          "text": "薛保抬头用目看， 看他父子为了难。 手拿凤冠霞帔双膝跪，"
        },
        {
          "character": "薛保",
          "type": "白",
          "text": "三主母啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛保哭。"
        },
        {
          "character": "薛保",
          "type": "西皮散板",
