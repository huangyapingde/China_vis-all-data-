{
  "script_id": "14002009",
  "title": "目莲救母",
  "alias": [],
  "source": "《戏典》",
  "characters": [
    {
      "name": "刘氏",
      "hangdang": "老旦"
    },
    {
      "name": "目莲",
      "hangdang": "小生"
    },
    {
      "name": "大鬼",
      "hangdang": "净"
    }
  ],
  "plot": "刘氏清蒂的儿子目莲僧，既已修成佛道，闻得母亲还在阴间受罪，特地前来探望。母子们会着面不免悲喜交\n集。刘氏哭诉一番，要目莲救她出去。鬼卒不许，经不得目莲使起佛法，只得任他将刘氏带走。目莲又将冤\n魂怨鬼放跑。鬼卒一想不好交差，也就溜之大吉。刘氏经过了这次磨难，这才一心向善，终究也修成了正果。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大鬼上。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "哽吓。"
        },
        {
          "character": "大鬼",
          "type": "数板",
          "text": "阎君命我作鬼头，十鬼见了九鬼愁。行善的金桥走，作恶的打不休来骂不休， 哪怕小鬼作对头。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "我乃大鬼是也。阎君朝拜佛祖去了，命我看守酆都城，不免在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "目莲上。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "在仙山奉了师父命， 来到阴曹探望娘亲。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "小生目莲僧。奉了师父之命，来到阴曹探望娘亲。就此走走。"
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "西方路上一只鹅， 口含仙草念弥陀。 扁毛倒有修行意， 人不修来待如何？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "来此已是酆都城，待我念起咒语。唵嘛呢叭咪吽。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "啊。哪里这样惊天动地？待我看来。 原来是小师父，姓甚名谁？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "小生目莲僧。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "到此何事？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "掌关听了。"
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "在仙山奉了师父命， 来到阴曹探望娘亲。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "你母亲姓甚名谁？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "目莲",
          "type": "二黄原板",
          "text": "我的母并非是别的名姓， 刘氏清蒂就是我娘亲。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "待我与你问来。 众鬼卒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鬼卒内同应。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "里面可有个刘氏清蒂，她子目莲僧看望于她，有者即来答话。"
        },
        {
          "character": "刘氏",
          "type": "内白",
          "text": "有哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘氏上。"
        },
        {
          "character": "刘氏",
          "type": "二黄摇板",
          "text": "听一言不由我喜之不尽， 原来是小娇儿寻找娘亲。 刘清蒂本是我老身的名姓， 我的儿叫罗卜不叫莲僧。 望长官你与我盘查细问， 我母子见一面感你的大恩。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "小师父，里面有一个刘氏清蒂，她子不叫目莲僧。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "叫什么？"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "叫什么糖萝菔，醋萝菔。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "敢是傅罗卜。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "不错，傅罗卜。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "请上城楼，我母子相见。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "阎君知道，那还得了。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "行个方便罢。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "使不得。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "唵嘛呢叭咪吽。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "哎呦。哎呦。不要如此。 众鬼卒，将刘氏清蒂押上都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘氏上台子。"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "一见母亲泪眼认， 怎不叫人痛在心。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "长官，将我母亲焰火去了。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "众鬼卒，将刘氏清蒂焰火去了。"
        },
        {
          "character": "刘氏",
          "type": "二黄导板",
          "text": "刘清蒂站都城浑身颤抖，"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "罗卜，我儿，儿啊！"
        },
        {
          "character": "刘氏",
          "type": "回龙",
          "text": "叫一声罗卜儿细听从头："
        },
        {
          "character": "刘氏",
          "type": "二黄正板",
          "text": "儿本是阳世人相隔幽冥， 却缘何来到了酆都城楼？ 我的儿到酆都城将娘搭救， 看不见小娇儿我两泪交流。 娘说道吃长斋恤老怜幼， 竟变了那铁树开花不能保留。 娘不该在佛前我就将誓盟就， 娘不该在阳间打僧骂道，不济贫民，开了五荤，到如今我此幽囚。 我的儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖缓锣鼓〗。"
        },
        {
          "character": "刘氏",
          "type": "二黄原板",
          "text": "儿的父修正道跨鹤西走， 为娘我被阎君地府来收。 娘说道阴曹府报应无有， 又谁知到了阴曹，早晚间我受的是蓬头垢面，披枷带锁，口含阴灯，等何时我 才得出头。 儿求佛尊将娘搭救， 也不枉为娘我就盼儿在心头。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "儿啊，今当四月初八日，阎君赴龙华大会去了。你可哀告掌关，放出都城，我 母子也好相见。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "长官，将我母亲放出都城。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "阎君知道，那还了得？使不得。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "唵嘛呢叭咪吽。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "哎呦，哎呦，不必如此。 众鬼卒，将刘氏清蒂押出都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘氏走下，出城。"
        },
        {
          "character": "刘氏",
          "type": "哭",
          "text": "罗卜，我儿，儿啊！"
        },
        {
          "character": "刘氏",
          "type": "二黄摇板",
          "text": "娘只说阴曹府无报应， 天网恢恢有神灵。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "儿啊，为娘披枷带锁，如何是好？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "有佛法。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "快快使来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "对准西方身拜定， 快将枷锁离娘身。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "为娘双目不明，如何是好？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "有佛法。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "快快使来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "对准西方身拜定， 取来了甘露水付与娘亲。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "儿啊，"
        },
        {
          "character": "刘氏",
          "type": "二黄摇板",
          "text": "数载未见娇儿面， 母子们相逢泪不干。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "儿啊，为娘肚中饥饿，如何是好？"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "还有佛法。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "快快使来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "对准西方身拜定， 取来了干饭付与娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众冤鬼同上。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "儿啊，这些冤鬼，超度他们罢。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "唵嘛呢叭咪吽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众冤鬼同下。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "儿啊，这饭多被鬼抢了去了。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "还有佛法。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "快快使来。"
        },
        {
          "character": "目莲",
          "type": "白",
          "text": "是，"
        },
        {
          "character": "目莲",
          "type": "二黄摇板",
          "text": "二次又把身拜定， 再取干饭付与娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小鬼上。"
        },
        {
          "character": "小鬼",
          "type": "白",
          "text": "阎君回殿来了。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "知道了。 你母子快快分别了罢。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘氏",
          "type": "二黄摇板",
          "text": "听说阎君回都城， 母子就要两离分。"
        },
        {
          "character": "刘氏",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘氏、目莲同下。"
        },
        {
          "character": "大鬼",
          "type": "白",
          "text": "哎呀，且住。这些冤鬼俱已逃生去了。阎君回来，如何是好。也罢，待我也逃 生去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大鬼下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}