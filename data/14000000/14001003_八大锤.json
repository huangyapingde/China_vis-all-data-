{
  "script_id": "14001003",
  "title": "八大锤",
  "alias": [],
  "source": "《戏典》",
  "characters": [
    {
      "name": "王佐",
      "hangdang": "须生"
    },
    {
      "name": "陆文龙",
      "hangdang": "小生"
    },
    {
      "name": "乳娘",
      "hangdang": "老旦"
    },
    {
      "name": "岳飞",
      "hangdang": "生"
    },
    {
      "name": "兀术",
      "hangdang": "净"
    },
    {
      "name": "汤怀",
      "hangdang": "武生"
    }
  ],
  "plot": "王佐是岳飞帐下一员参军。因为岳飞在朱仙镇一仗打得大败而回，王佐问起情由，刚才知道金邦有一员小将，\n名叫陆文龙，十分骁勇。岳飞谈起陆文龙，就是当年镇守潞安州节度使陆登的儿子。陆登尽忠自刎，陆夫\n人尽节悬梁缢死。那时候陆文龙还在襁褓，生下未满三月，就被金兀术掳去。如今长大成人，不但不晓得去\n报父仇，并且帮了仇人来杀自己人。王佐听了岳飞的许多话，私下里砍伤了自己的左臂，又写了一封信，告\n诉了岳飞，连夜跑到金营里去诈降。不久被他见着陆文龙，用言语打动与他，又将陆登全家死得如何可惨，\n陆文龙本人如何被掳，讲经说法的讲给陆文龙听。再加乳娘在旁一证明，陆文龙方才明白，气得咬牙切齿，\n痛哭流泪，立刻就想去杀金人。王佐代为画计，约定岳飞，里应外合，大破金兵。陆文龙本想将金兀术刺死，\n替他父母报仇，因为念他有十几年的养育恩，才成全了金兀术的性命。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王佐上。"
        },
        {
          "character": "王佐",
          "type": "念",
          "text": "欲为天下奇男子，须学人间大丈夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四侍卫引岳飞同上。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "参见元帅。今日出兵胜负如何？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "想俺岳飞，每战金人，未有如此大败。今日一战，被陆文龙伤将数员，此乃天 灭我也。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "想那陆文龙，该莫是当年潞安州陆登之子么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "正是此子。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "闻得他父，命丧金人之手，如今为何反助仇人？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "当年大破潞安州，此子未满三月，又被金人掳去，认为己子。今年才一十六岁， 叫他怎能知晓？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "既然如此，待俺王佐前往番营诈降兀术，顺说那陆文龙前来降宋，岂不是好么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "想那兀术诡计多端，画虎不成反类其犬。用你不着，出账去罢。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四侍卫同应。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "小心防守，掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞下。四侍卫同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "王佐",
          "type": "内二黄导板",
          "text": "听谯楼打初更玉兔东上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌提灯引王佐同上。"
        },
        {
          "character": "王佐",
          "type": "二黄回龙",
          "text": "为国家秉忠心食君禄报皇恩昼夜奔忙。"
        },
        {
          "character": "王佐",
          "type": "二黄原板",
          "text": "想当年在洞庭逍遥放荡， 到如今食君禄未报君王。 岳大哥他待我手足一样， 俺王佐无功劳怎受荣光。 今夜晚思一计番营去闯， 留一个美名儿万代传扬。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "尔等退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同下。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "想俺王佐，自投宋以来，并无尺寸之功。若得一计，私入番营，顺说那陆文龙 前来降宋，岂不是大大的功劳。若有不测，亦能名垂千古。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "王佐",
          "type": "二黄原板",
          "text": "怎能够思巧计番营得进， 前后话对文龙细说分明。 前又思后又想无有计定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐坐在桌旁。"
        },
        {
          "character": "王佐",
          "type": "二黄原板",
          "text": "倒不如上公案观看古今。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐看书。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "汉朝，想那苏武、卫律，同往番营催贡。一个贪生怕死，降顺北国。一个食羶 吮血，执意不降。这才是忠佞各别了。"
        },
        {
          "character": "王佐",
          "type": "二黄原板",
          "text": "汉室中那卫律心术不正， 怎能比那苏武一片丹心。 饥食羶渴吮血忠心耿耿， 天保护地保佑暗有神灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐换书。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "这段不好，待我看看东周列国。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐看念。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "要离断臂刺庆忌。 哎呀且住，想那要离断臂刺庆忌，乃是大丈夫所为。俺王佐今日何不学他一学。 我不免留下书信一封，下在岳大哥帐下，乘此星夜，投降番营去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐磨墨修书。"
        },
        {
          "character": "王佐",
          "type": "二黄摇板",
          "text": "那要离曾断臂颇有志量， 留下了美名儿万古传扬。 俺王佐学要离番营去闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐脱衣执剑站下场门台角，右脚搁台上。"
        },
        {
          "character": "王佐",
          "type": "二黄摇板",
          "text": "顾不得生和死剑作主张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐挥剑斩臂，剑落，臂断，吊毛，倒地昏去。二旗牌同上。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "王将军醒来！"
        },
        {
          "character": "王佐",
          "type": "二黄导板",
          "text": "一霎时只觉得神魂不定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐醒。"
        },
        {
          "character": "王佐",
          "type": "二黄摇板",
          "text": "好似刚刀刺在心。 睁开了昏花眼难以扎挣， 为国家断一臂要留美名。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "王将军这是何意？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "尔等莫要声张，俺这里有书信一封，送至大营。倘若元帅问起，就说我另有公 干去了。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "是！"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "转来。此系机密大事，千万不可泄露。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "遵命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同下。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "看天色渐明，俺不免投降金营去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐拾臂看。〖扫头〗。王佐下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四侍卫引岳飞同上。"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "闷坐帐中心烦恼，梦里君王回故朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同上。"
        },
        {
          "character": "二旗牌",
          "type": "同白",
          "text": "启禀元帅：王将军有书信一封，请元帅观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌同将书呈上。〖三枪〗。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "来，传汤怀进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汤怀上。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "命你巡营嘹哨，不得有误。"
        },
        {
          "character": "汤怀",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞、汤怀、二旗牌同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二番卒同上。"
        },
        {
          "character": "番卒甲",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "番卒乙",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "番卒甲",
          "type": "白",
          "text": "奉了狼主之命，在此巡营嘹哨。你我小心了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐上。"
        },
        {
          "character": "番卒甲",
          "type": "白",
          "text": "拿住了！拿住了！"
        },
        {
          "character": "番卒乙",
          "type": "白",
          "text": "走走走！"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "二番卒",
          "type": "同白",
          "text": "去见我家狼主。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "好，如此走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二番卒拉王佐同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小番引兀术、陆文龙同上。"
        },
        {
          "character": "兀术",
          "type": "西皮摇板",
          "text": "多亏殿下打一仗， 要把宋朝踹平阳。 将身且坐莲花帐， 且听小番报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二番卒押王佐同上。"
        },
        {
          "character": "番卒甲",
          "type": "白",
          "text": "启禀狼主：拿住宋朝奸细。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "讲他绑进帐来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "番卒乙将王佐押进帐。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "唗！胆大奸细，敢来窥探吾营，推出砍了！"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "留头讲话。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "你且讲来。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "南臣王佐，乃湖广长沙人氏，现在岳飞帐下，以为随营参军。昨见岳飞被狼主 杀得大败，劝他归顺狼主。他执意不肯，倒也罢了，反执宝剑，将我的左膀断 去，死也不能，活也是活受罪。因此前来投降，望狼主作主收留。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "我却不信。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐出断臂示兀术。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "现有断臂为证，狼主请看。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哦呵呀！岳飞，降与不降，任凭于你。为何下这毒手？ 你为孤家吃了苦了，孤家留你就是。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "多谢狼主。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "父王必须与他起个名字才是。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "与他起个什么名字呢？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "苦啊！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哦，就叫做苦人儿吧。从今以后，满营之中，任你游玩。吩咐大小三军，不可 拦阻与他。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "多谢狼主！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐下。"
        },
        {
          "character": "兀术",
          "type": "念",
          "text": "恼恨岳飞无仁义。"
        },
        {
          "character": "陆文龙",
          "type": "念",
          "text": "军中哪有斩断臂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兀术、陆文龙、二番卒同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "乳娘上。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "老身周氏，向在陆登陆大老爷府中以为乳娘。那年金人打破潞安州，老爷夫人 尽忠尽节而死，留下公子，未满三月，又被狼主掳入金邦，幸喜不曾伤害，认 为子嗣。如今一十六岁，咳，但不知此仇何日得报哇。"
        },
        {
          "character": "乳娘",
          "type": "二黄原板",
          "text": "何日里才能够冤仇相报， 思想起老主人心如火烧。 撇故乡到他邦谁为倚靠， 费心计要回国无路可逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐挟图上。"
        },
        {
          "character": "王佐",
          "type": "二黄摇板",
          "text": "到番营一月整未遇巧机， 怎能够与文龙把话来提。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "唗，你是何人，在此窥探？小番与我拿下！"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "老太太莫要声张，我就是苦人儿。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "哦，闻得殿下言讲，有一南朝将官，名叫王佐，投顺我国，改名苦人儿的就是 你么？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "正是在下。听老太太之言，不像此地人氏。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "老身乃湖广长沙人氏。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "如此说来，我们是同乡。"
        },
        {
          "character": "乳娘",
          "type": "念",
          "text": "久旱逢甘雨，"
        },
        {
          "character": "王佐",
          "type": "念",
          "text": "他乡遇故知。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "请问老太太因何在此呢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘、王佐同作两边探望。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "我与将军乃是同乡，说也无妨。老身周氏，昔在陆登陆大老爷府中，以为乳娘。 那年打破潞安州，老爷夫人尽忠尽节而死，留下公子未满三月，又被狼主掳 进金邦，故而流落至此。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "听你之言，那陆大老爷还有后么？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "怎说无后？两军阵前枪挑数员宋将，那就是陆公子。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "我王佐来得好机会啊！"
        },
        {
          "character": "王佐",
          "type": "二黄摇板",
          "text": "听罢言来喜心上， 把话说与她知详。 这断臂的情由为公子， 舍死忘生到番邦。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "如此说来，你为我家公子，吃了苦了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘摸王佐臂，王佐作疼痛。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "不妨。"
        },
        {
          "character": "王佐",
          "type": "二黄摇板",
          "text": "这断臂的情由休要讲， 说了出来我的罪难当。 待等公子回营帐， 全仗太太作主张。 若把她父母的冤仇细细讲， 言语打动他心肠。 但愿得文龙归宋往， 扫平了金人把仇偿。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "殿下回来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘下。四番卒引陆文龙同上，四番卒同下。"
        },
        {
          "character": "陆文龙",
          "type": "念",
          "text": "上阵交锋无人敌，管教宋室一扫平。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "参见殿下。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "苦人儿，这几日不见，你往哪里去了？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "这几日蒙那些王爷平章们，这个请我吃酒，那个叫我说评书，故而少来与殿下 请安。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "哦，你还会说评书么？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "诺诺诺，一肚子的评书呢。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "你且稍候。 有请乳娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘上。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "殿下何事？"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "这就是苦人儿。 来来来，苦人儿见过乳娘。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "老太太好哇。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "苦人儿他会说评书。请乳娘出来，叫他说来，大家同听。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "既然说书，必须给他座位才是。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "着哇！ 苦人儿，你且坐下。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "慢来慢来，殿下在此，哪有我的座位。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "不必拘礼，只管坐下。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "如此谢过殿下。请问殿下，喜听文的，喜听武的呢？"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "自然武的好。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "要听忠的，还是要听奸的？"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "小王喜的是忠臣，恶的是奸佞。自然是忠的好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐咳嗽拍案。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "这是做什么？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "这是说书的规矩。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "唔，说书规矩。"
        },
        {
          "character": "王佐",
          "type": "念",
          "text": "道德三皇五帝，功名夏后商周。英雄五霸乱春秋，顷刻兴亡过首。 青史才标名姓，北村无数荒邱。前人田土后人收，说什么龙争虎斗。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "一不讲东西两汉，二不讲五代残唐。单说大宋仁宗在位，朝中有一家忠良，名 唤杨延昭。屡战番邦，杀得落花流水。那时萧后勾通一个奸臣，名叫王钦若， 设计暗害杨家。那王钦若一日上殿启奏一本，言道北国番邦，有骑好马，日行 千里见日，夜走八百不明。宋主见喜，就命杨元帅前去盗马。杨元帅领旨下殿， 回得营来，闷闷不乐。帐下有员虎将，名唤孟良，进帐讨令，愿往番邦盗马。 那孟良能说六国番邦话语，去至北国，不到一月，就将马盗得来了。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "果然是一员虎将。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "那马盗是盗来，可怜那马，眼望北国，七日七夜不食草料，它竟死了。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "那马也不过是思乡啊。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "马且思乡，何况人乎？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘暗泣。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "老太太啊，如今的人，都不如那马了哇！"
        },
        {
          "character": "王佐",
          "type": "二黄摇板",
          "text": "此马倒有思乡意， 如今人生不如它。 父母冤仇他不去报， 反把仇人当自家。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "往下讲。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "完了。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "不好不好，也不热闹。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "这样八大锤，还不热闹？这样办吧，这有画图一幅，将它挂在上面，照图言讲。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "好好，将画图悬挂起来。这画图之上，有些人马，还是南朝兵将？还是我国金 兵？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "这上面么，宋将也有，金兵也有。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "上面有一员大将，乃是南朝打扮，为何拔剑自刎，立尸不倒？他是何人？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "这，就是潞安州节度使姓陆名登，只因与金人交战，屡战不胜，又无救兵前来， 被金人攻破城池，他就拔剑自刎，为国尽忠而死。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "那妇人，悬梁自缢，她是何人？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "那是陆登之妻，见夫尽忠，她也悬梁自缢，为夫尽节而亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乳娘哭。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "啊乳娘，这是为何？"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "老身闻得他全家死得可惨，故而伤心落泪。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "你真是听鼓词儿落泪，替古人担忧啊。 上面有一番将，好像我父王模样。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "正是我国狼主。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "既是我父王，为何拜倒尘埃？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "因见陆登为国捐躯，忠心可敬，故而在那里拜他。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "既是我父拜他，小王也要拜上几拜，可使得么？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "你么，正是拜得啊！"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "陆老先生在上，待小王参拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆文龙拜。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "那旁有一乳娘，抱一小孩童，又是何人？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "那是陆登之子，其时未满三月，故有乳娘抱在怀内。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "此子还在么？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "此子尚在。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "今年多大年纪？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "此子么——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐使眼色，乳娘作手势。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "今年一十六岁。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "此子可有本领？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "若问他的本领么，他能力敌万人。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "既有如此本领，为何不与他父母报仇？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "他非但不与他父母报仇，如今反认仇人为父。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "他叫什么名字？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐含糊。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "他叫陆文龙。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "他叫什么名字？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐含糊。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "他叫陆文龙。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "哎，他到底叫什么名字？"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "他叫陆文龙。"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "唗！胆大苦人儿敢耍小王，休走看剑。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "这就是你家遭害故事，不要反怪他人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆文龙急取图看。"
        },
        {
          "character": "陆文龙",
          "type": "叫头",
          "text": "爹爹！母亲！哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆文龙昏。"
        },
        {
          "character": "王佐、乳娘",
          "type": "同白",
          "text": "殿下醒来！"
        },
        {
          "character": "陆文龙",
          "type": "二黄导板",
          "text": "爹娘被害把命丧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆文龙醒。"
        },
        {
          "character": "陆文龙",
          "type": "二黄摇板",
          "text": "不由小王怒满膛。 手执宝剑往前闯，"
        },
        {
          "character": "王佐、乳娘",
          "type": "同白",
          "text": "哪里去？"
        },
        {
          "character": "陆文龙",
          "type": "二黄摇板",
          "text": "斩尽番奴救宋王。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "且慢。还须定计而行，待我修下书信一封，绑在箭上，射入宋营，请岳元帅调 动兵将，杀他里应外合，何愁那贼不灭？"
        },
        {
          "character": "陆文龙",
          "type": "白",
          "text": "如此，叔父请上，受小侄一拜。"
        },
        {
          "character": "乳娘",
          "type": "白",
          "text": "这才明白了。"
        },
        {
          "character": "王佐",
          "type": "白",
          "text": "我的膀子也完了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王佐、陆文龙、乳娘同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}