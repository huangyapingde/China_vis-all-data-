        {
          "character": "樵夫",
          "type": "白",
          "text": "嗳，你怎么又来了？"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "啊，樵哥，你知道我的儿子，你可知道我儿子他的娘？"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "哪个晓得你儿子的娘？"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "也是前半月的事情。"
        },
        {
          "character": "樵夫",
