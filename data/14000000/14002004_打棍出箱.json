        {
          "character": "樵夫",
          "type": "白",
          "text": "是这样的抢，抢回家去。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "樵哥，前半月在这大路旁边，有一个女娘行——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范仲禹学樵夫描摹状。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "是这样啼啼哭哭。我们这里有一告老太师，带领家下人等，游山观景。见那女 娘行生得几分姿色，吩咐家下人等——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范仲禹学樵夫描摹状。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "是这样的抢，抢回家去。哈哈，我的儿子的娘，也有了下落，待我谢天谢地。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "嗳呀，且住。想那告老太师，乃是个酒色之徒，只恐到了晚上，还要……"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "樵哥，坏了！"
