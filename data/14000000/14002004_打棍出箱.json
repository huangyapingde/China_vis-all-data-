      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "引子",
          "text": "天上白云本无根，又被清风引出来。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "我乃上方土地是也。今有范仲禹妻子孩儿有难，奉了玉帝敕旨，前去点化于他。 待我变作樵夫模样，就此变来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地下，变樵夫上。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "缺少扁担，待我用拐杖变来。一变二变，扁担出现。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樵夫变扁担。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "变好了，就此走走。"
        },
        {
          "character": "樵夫",
          "type": "二黄平板",
          "text": "天上星斗朗朗稀， 休笑贫人穿破衣。 山中树木有长短， 河内荷花有高低。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "来此已是，待我用起功来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范仲禹上。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "走啊！"
        },
        {
          "character": "范仲禹",
          "type": "二黄摇板",
          "text": "山前山后俱找到， 不见妻儿为哪条？"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "卑人府学生员范仲禹。今乃大比之年，进京赴试已毕，行在南山之下，失落妻 室孩儿。是我在这山前山后，寻找半月有馀，并无踪影，叫我哪里去寻？哪里 去找？哦呵呀！看那旁有一樵哥，他必然知晓，待我向前问来。 啊，樵哥，你可曾看见我的儿子？喂，可曾看见我的儿子？喂，你可曾看见。 原来是个聋子，待我来吓他一吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范仲禹大声一喊。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "喂！樵哥！"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "嗳，你这人好生无理，这山上猛虎甚多，我这一斧将你劈死。还是你偿斧的命？ 斧偿你的命？"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "樵夫，你在山中砍柴，可曾看见我的儿子？"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "嗳，我在此砍柴，哪个看见你的儿子。还是个长子？还是个矮子？还是个胖子？ 哪哪，还是个瘦子？"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "此乃是前半月事情。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "前半月的事情。有的。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "有的！有的！"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "有的，有的。"
        },
        {
          "character": "范仲禹、樵夫",
          "type": "同白",
          "text": "有的，有的。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "有在哪里？"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "壮士，前半月在这大路旁边，有一小孩童——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樵夫手指足画作描摹状。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "是这样啼啼哭哭。从南山之上，下来一只猛虎，将那小孩童——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樵夫手指足画作描摹状。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "是这样的吞在口内。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "樵哥，前半月在这大路旁边，有一小孩童——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范仲禹学樵夫描摹状。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "是这样啼啼哭哭。从南山之上，下来一只猛虎，将那小孩童——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范仲禹学樵夫描摹状。"
        },
        {
          "character": "范仲禹",
          "type": "白",
          "text": "是这样的吞在口内。樵哥！我的儿啊！"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "不妨事，还有救。"
        },
        {
          "character": "范仲禹",
          "type": "白",
