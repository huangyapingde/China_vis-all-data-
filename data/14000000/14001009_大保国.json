{
  "script_id": "14001009",
  "title": "大保国",
  "alias": [],
  "source": "《戏典》",
  "characters": [
    {
      "name": "徐延昭",
      "hangdang": "净"
    },
    {
      "name": "杨波",
      "hangdang": "老生"
    },
    {
      "name": "李后",
      "hangdang": "正旦"
    },
    {
      "name": "李良",
      "hangdang": "净"
    }
  ],
  "plot": "明穆宗驾崩，太子万历帝年幼，当由李后艳妃临朝听政。李后的父亲李良心怀叛逆，想用甘言诱惑李后，假\n说太子年幼不能临朝，女皇垂帘听政诸多不便，不如将江山暂时付他执掌，且候幼主长成，那时再行归还就\n是。李后竟听信了他的话，预备实行让位。满朝文武都不敢反对，只有兵部侍郎杨波和中山王裔孙徐延昭二\n人，识破李良的奸谋，入宫当面向李后进谏。二人虽然力争，李后仍是执迷不悟。徐延昭愤极，把太祖所赐\n的铜锤取出，向李良痛打。李后也没奈何他。如是各人，就是这样不欢而散。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引李后同上。"
        },
        {
          "character": "李后",
          "type": "引子",
          "text": "珠帘高卷，金钩高挂，黄罗伞罩定哀家。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "老皇晏驾龙归西，女皇登基世间稀。全凭众卿来扶助，保定哀家立帝基。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "哀家，李艳妃。只因老皇晏驾，太子年幼，众卿扶保哀家，已登大宝。今当早 朝。 内侍，吩咐两班文武，有本早奏，无本卷帘退班。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "领旨。 国太有旨：两班文武，有本早奏，无本卷帘退班。"
        },
        {
          "character": "李良",
          "type": "内白",
          "text": "李良有本启奏。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "随旨上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李良上。"
        },
        {
          "character": "李良",
          "type": "念",
          "text": "全凭不烂舌，打动女儿心。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "臣，李良见驾。国太千岁。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "太师平身。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "太师上殿，有何本奏？"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "启奏国太：今当进宝年号，犹恐各国王子，前来进宝，观见我朝珍珠帘内，女 皇登殿，必起一番风波。有道是一载干戈动，十载不太平。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "依太师之见？"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "依臣之见，将江山付与哪家沾亲带故之臣，执掌三年五载，候幼主成龙，原业 归宗。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "太师说哪里话来？想满朝文武，亲不过你我父女。将江山付与太师执掌，三年 五载，候幼主成龙，原业归宗。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "犹恐满朝文武不服。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "哀家立下合同，满朝文武打下花押，殿角候旨。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "李良",
          "type": "念",
          "text": "今日一本奏的准，大明江山有几分。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "内侍，看文房四宝伺候。 啊，哎呀，老皇啊！"
        },
        {
          "character": "李后",
          "type": "二黄慢板",
          "text": "李艳妃坐早朝龙凤阁下， 文站东武站西朝贺哀家。 哭一声老皇爷宴了龙驾， 撇下了小皇儿难立邦家。 太师爷奏一本进宝年下， 各国的众王子朝贺中华。 将江山付太师权且代驾， 候幼主成了龙原归邦家。 写合同金殿上玉玺来打， 宣太师——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲应。"
        },
        {
          "character": "李后",
          "type": "二黄慢板",
          "text": "金殿上披红插花。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "李良",
          "type": "二黄摇板",
          "text": "在金殿接过了大明天下， 好一似龙盘珠手到擒拿。 一步儿来至在文班角下， 尊一声众大人前来画押。"
        },
        {
          "character": "众臣",
          "type": "内同白",
          "text": "太师到此何事？"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "国太将江山让与老夫执掌三年五载，候幼主成龙，原业归宗。列位大人，请来 画押。"
        },
        {
          "character": "众臣",
          "type": "内同白",
          "text": "江山自有争斗，哪有禅让之理？我等不押。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "现有上方宝剑。"
        },
        {
          "character": "众臣",
          "type": "内同白",
          "text": "太师不必动怒，我等画押。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": "杨波",
          "type": "内包",
          "text": "且慢！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "答话者何人？"
        },
        {
          "character": "杨波",
          "type": "内白",
          "text": "兵部杨波！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "敢是画押？"
        },
        {
          "character": "杨波",
          "type": "内白",
          "text": "不当不押，上殿面奏！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "呸！老夫坐江山，有你不多，无你不少！"
        },
        {
          "character": "李良",
          "type": "二黄摇板",
          "text": "听说是老杨波不肯画押， 有老夫登了基先把你杀。 一步儿来至在武班角下， 尊一声众王侯请来画押。"
        },
        {
          "character": "众臣",
          "type": "内同白",
          "text": "太师驾到朝房，为了何事？"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "国太将江山让与老夫执掌，三年五载，候幼主成龙，原业归宗。列位王侯，请 来画押。"
        },
        {
          "character": "众臣",
          "type": "内同白",
          "text": "江山自有争斗，哪有禅让之理？"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "现有上方宝剑。"
        },
        {
          "character": "众臣",
          "type": "内同白",
          "text": "太师不必动怒，我等画押。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "且慢！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "答话者何人？"
        },
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "定国公徐！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "徐千岁，敢是画押？"
        },
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "不当不押，上殿面奏！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "哦呵，老夫的江山，去了一大半了！"
        },
        {
          "character": "李良",
          "type": "二黄摇板",
          "text": "老杨波不画押哪放心下， 徐延昭喝一声胆战如麻。 一步儿来至在金殿角下， 这江山臣不坐让不得别家！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "满朝文武，俱已画押，惟有徐、杨不押。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "太师殿角伺候，哀家自有道理。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "内侍，宣徐、杨二家上殿！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "国太有旨，宣徐杨二家上殿！"
        },
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐延昭上。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "徐延昭出朝房撩袍抖袖， 尊一声满朝中文武公侯： 老皇爷宴了驾太子年幼， 恨李良起反心谋纂龙楼。 不服者随老夫上殿面奏， 龙国太降下罪老夫保留。 在午门喊得我口干舌锈，"
        },
        {
          "character": "杨波",
          "type": "内白",
          "text": "千岁等着！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "答话者哪部官？"
        },
        {
          "character": "杨波",
          "type": "内白",
          "text": "兵部杨波！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "快上龙楼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨波上。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "正在朝房把本修， 忽听国太让龙楼。 本当上楼把本奏， 怎奈我官卑职小，不敢出头。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "参见千岁！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人慌慌张张，为了何事？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "国太将江山，让与李良，千岁可曾画押？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "老夫岂肯同谋，大人可曾画押？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁不押，小官怎敢画押？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "既然不曾画押，何不上殿保奏？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "本当上殿保奏，怎乃官卑职小，不敢出头。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "不妨，你若上殿保奏，老夫保你无事。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁保学生满门无事，盼住一腔热血，洒落金阶，也要顶他几本！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁请！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "一文一武站朝廊，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "叙叙大明朝锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "站立在殿角下用目观望，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "殿角上坐定了谋朝篡位，奸贼李良。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "那奸贼怀抱住硃红宝剑，哪有一个帝王之相？"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "老皇爷赐铜锤，上打昏君，下打谗臣，谁敢不遵定国王开国的忠良？"
        },
        {
          "character": "徐彦昭、杨波",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "品级台前参皇见驾，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "愿国太福寿永安康。"
        },
        {
          "character": "李后",
          "type": "二黄原板",
          "text": "九龙口内传旨意， 徐、杨二家且平身。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "铜锤三点谢国太，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "四起八拜谢皇恩！"
        },
        {
          "character": "李后",
          "type": "二黄原板",
          "text": "内侍看过金交椅，"
        },
        {
          "character": "徐彦昭、杨波",
          "type": "同二黄原板",
          "text": "大明江山同做商量。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "臣启国太：宜臣等上殿，有何国事议论？"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "今当各国王子朝贺。哀家登殿，恐其观之不雅，因此将江山付与太师执掌，三 年五载，候幼主成龙，原业归宗。满朝文武俱已画押。二卿不押，是何道理？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "臣启国太：江山自有争斗，哪有禅让之理？臣等不押。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "哀家龙心一定，不必多奏。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人有何本章，当殿奏来。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "是。 臣启国太：臣有道太平表章，可容臣一奏？"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "容奏："
        },
        {
          "character": "杨波",
          "type": "念",
          "text": "一时元朝居万里，世上多少古今稀。山崩地裂石鼓响，地裂山崩星斗移。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "臣不奏前三皇后代五帝， 奏的是大明朝一段机密： 太祖爷初登基南京立帝， 四路的反叛贼来夺华夷。 湖广的陈友谅江西起意， 广东贼领人马杀到广西。 只杀得妻寻夫来兄找弟， 只杀得父在东来子在西。 老皇爷坐江山亦非容易， 十八载改国号臣不能全知。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "为何不往下奏？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "臣不能全知。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "何人全知？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "徐千岁知晓。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "谢国太。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "徐王兄。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "可知老皇得的，谁家江山，哪家社稷？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "老皇得的，元朝江山，顺帝社稷。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "容奏："
        },
        {
          "character": "徐延昭",
          "type": "念",
          "text": "七九六十三，我主赶大元，赶到红罗山，偶遇一路断。 海枯铜桥现，七人渡北番，元朝不绝后，"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "国太。"
        },
        {
          "character": "徐延昭",
          "type": "念",
          "text": "我主坐江山。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "容奏："
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "先王爷坐江山风调雨顺， 全凭着驾下臣文武公卿。 文仗着刘伯温八卦有准， 武仗着臣玄祖秉定忠心。 常遇春胡大海百战百胜， 李文忠他本是皇王的内亲。 杀杀杀赶赶赶，赶至在红罗山下， 北海内现铜桥渡过七人。 元朝位爵大明做， 一朝君一朝臣直到如今。"
        },
        {
          "character": "李后",
          "type": "二黄原板",
          "text": "徐王兄你不必将古比今， 哀家是一心心要让龙庭。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "非是臣在金殿将古比今， 那时节全凭着要夺朝廷。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "不准，下殿！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "下殿来便把大人请， 请去上金殿把本争！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "遵命，千岁。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "汉高祖路过芒砀山， 偶遇白蛇把路拦。 拔剑将蟒蛇分为段， 那妖魔化清风奔走云端。 头脱王莽把位篡， 尾脱苏献掌兵权。 到后来问罪在云台观， 何况那李太师想谋江山！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "太师顶本。"
        },
        {
          "character": "李良",
          "type": "二黄摇板",
          "text": "有王莽坐江山全凭苏献， 有老臣并无有心腹之人。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "住了！田子裕，原在你的府中来往，算得你的心腹之人。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "算不得心腹之人！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "算得！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "算不得！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "算得！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "算不得！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "昔日里有一个唐禧宗， 他驾前有一家梁王朱温。 臣弑君子弑父弟霸兄嫂， 君不君臣不臣败坏人伦。"
        },
        {
          "character": "李后",
          "type": "二黄原板",
          "text": "我朝中尽都是仁义父女， 前朝中都是那狗奸谗臣。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "国太道太师爷仁义君子， 臣看他比梁王还奸十分！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "不准，下殿！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "往日里奏本本本准， 今日里却缘何国太不听？ 下殿便把大人请， 去上金殿把本升。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "遵命，千岁！"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "赵太祖登基在汴梁， 身长搭背病龙床。 匡义进宫将兄望， 烛影摇红谋篡家邦。 亲手足他尚且如此形状， 何况那李太师谋位的心肠？"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "太师顶本。"
        },
        {
          "character": "李良",
          "type": "二黄摇板",
          "text": "倘若臣坐江山久坐不让， 责打臣四十板发往高墙。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "你乃皇亲国戚，发不得高墙。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "发得高墙！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "发不得高墙！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "发得！"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "杨波奏本气昂昂！"
        },
        {
          "character": "李良",
          "type": "二黄摇板",
          "text": "我暂坐几载也无妨！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "你坐江山谁保你！"
        },
        {
          "character": "李后",
          "type": "二黄摇板",
          "text": "不用你徐、杨自为皇！"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "龙国太与奸贼作了主， 杨波保本一场空。 回头就把千岁请， 倚老卖老撒撒风！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁何不在金殿之上撒撒风，打打这奸贼！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "老夫年迈，撒不得风，打不动这奸贼。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "撒得风，打得奸贼！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "撒得风？闪开了！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "老龙正在沙滩困， 忽听春雷响一声。 上前抓住袍和带， 老夫金殿打谗臣！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "千岁，臣打不起啊！"
        },
        {
          "character": "李后",
          "type": "二黄摇板",
          "text": "徐、杨作事太屈情， 不该金殿打皇亲。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "皇亲国戚不敢打， 打的谋朝篡位臣！"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "千岁，臣打不起啊！"
        },
        {
          "character": "李后",
          "type": "二黄摇板",
          "text": "手摸胸膛想一想， 他是哀家什么人？"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "太师不过是娘娘的父， 他不该三番两次谋乾坤。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "杨大人，你拉着些！"
        },
        {
          "character": "李后",
          "type": "二黄摇板",
          "text": "江山并非他要坐， 哀家让与有功臣。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "哗喇喇打开功劳簿，"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "功劳簿在此。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人查查，可有奸贼的名讳？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "并无有奸贼的名讳。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "哪哪，那不是老夫的名讳？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李良下，杨波随下。"
        },
        {
          "character": "徐延昭",
          "type": "西皮原板",
          "text": "功劳簿哪有国太令尊？"
        },
        {
          "character": "李后",
          "type": "西皮原板",
          "text": "江山本是先皇挣， 并无有徐、杨半毫分。"
        },
        {
          "character": "徐延昭",
          "type": "西皮原板",
          "text": "江山虽然老皇挣， 也有徐、杨八九分。"
        },
        {
          "character": "李后",
          "type": "西皮原板",
          "text": "老皇爷封你的官职大了， 你把我女皇不放在心。"
        },
        {
          "character": "徐延昭",
          "type": "西皮原板",
          "text": "官大官小是臣的功劳挣， 并不是龙国太恩赐与老臣。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "地欺天来不下雨，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "天欺地来苗不生。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "臣欺君来该何罪，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "君欺臣来不奉君。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "子欺父来寿命短，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "父欺子来逃出门。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "弟欺兄来家不顺，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "兄欺弟来把家分。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "江山莫非你要坐，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "老臣并无有禽兽心。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "哀家传旨将你斩，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "老皇封我不斩臣。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "要让要让偏要让，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "不能不能万不能。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "金镶玉玺朝下打，"
        },
        {
          "character": "徐延昭",
          "type": "西皮快板",
          "text": "铜锤打的碎纷纷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨波上。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁，自盘古以来，哪有臣打君的道理？"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "依大人之见？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "上殿领罪。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人上殿领罪。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "是。 徐、杨有欺君之罪，国太降旨。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "从今以后，有事无事，不用徐、杨二大奸党相干。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "谢国太。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "国太怎样传旨？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "国太传旨下来：从今以后，朝中有事，不用我徐、杨二大奸党相干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐延昭叹。"
        },
        {
          "character": "徐彦昭",
          "type": "白",
          "text": "咳！你我忠心报国，落得奸党二字。你我暂退朝房，看哪个敢坐江山，"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "哪个敢登社稷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李良上。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "啊，千岁，奸贼来了！"
        },
        {
          "character": "徐延昭",
          "type": "三笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐延昭、杨波同下。"
        },
        {
          "character": "李良",
          "type": "白",
          "text": "两个大大的奸臣！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "太师进位。"
        },
        {
          "character": "李后",
          "type": "西皮快板",
          "text": "可恨老皇作事差， 铜锤不该赐与他。 大明江山让与你， 八月十五坐中华。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李后下。"
        },
        {
          "character": "李良",
          "type": "西皮摇板",
          "text": "喜呵呵来笑哈哈， 大明江山我掌着。 八月十五登龙位， 先杀延昭后杀杨波。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李良下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}