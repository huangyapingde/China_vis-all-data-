  "plot": "诸葛亮因为司马懿兵出祁山，料到他定会要夺取街亭。街亭乃是蜀国咽喉之地，必须派一员能将前去驻守。\n参将马谡请令愿去，诸葛亮就再三关照他要十分谨慎，扎营必须要靠山近水，又命王平随伴同去，要他到后\n随即画一地势图形送来。马谡到了街亭，不遵诸葛亮的命令，不听王平的劝谏，竟将营扎在山上，果然被司\n马懿的手下张郃杀得大败。街亭失守，马谡、王平只逃得性命出来。司马懿乘胜一直攻到西城。幸而诸葛亮\n早得了王平的报告和图形，晓得街亭必会失守，连忙差人去调回赵云。但是探子接连报告司马懿的兵已近逼\n西城。这时西城只剩些老弱的兵士在守着，诸葛亮急得什么似的。后来想想只有冒险行一条空城计。索性将\n四门大开，命老军在城外打扫街道，说是好迎接司马懿进城；自己带了琴童两个坐在城楼上抚琴，装做很安\n闲的样子。司马懿一到看了这种情形，生怕城内有了埋伏，竟不敢冒险进城，反命退兵四十里。这时赵云的\n救兵已到西城，总算脱险。于是诸葛亮升帐，将王平责打四十军棍，马谡违令斩首示众。诸葛亮自己因为用\n人不慎也有过失，就请后主将他的官爵武乡侯贬掉，以示忏悔。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "忆昔当年挂铁衣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱上。"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "万马军中无人敌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平上。"
        },
        {
          "character": "王平",
          "type": "念",
          "text": "赤胆忠心扶社稷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "协力同心保华夷。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "马谡。"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "请了。丞相升帐，两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、四侍卫同上。诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "羽扇纶巾，四轮车、快似风云。阴阳反掌定乾坤，保汉家两代贤臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮入帐，坐。"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "少礼。"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "忆昔当年在卧龙，万里乾坤掌握中，扫灭狼烟归汉统，方显男儿大英雄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫复姓诸葛，名亮，字孔明，道号卧龙。先帝爷托孤以来，扫荡中原，扭转 汉室。闻得司马懿兵出祁山，定然夺取街亭。我想街亭乃汉中咽喉之地，必须 派一能将前去防守。 众位将军——"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哪位将军带领人马镇守街亭，敢当此任？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡两望，出帐。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "且住。丞相传下将令，并无一人应声，待俺马谡进帐讨令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡进帐。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "启禀丞相：末将不才，愿带一哨人马，镇守街亭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那司马懿用兵如神，此去并非小任，将军不可轻敌。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相，末将跟随先帝出兵多年，战必胜，攻必取，何况那小小街亭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "街亭虽小，干系甚重啊。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "倘有疏虞，甘当军令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军中无有戏言。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "愿立军令状。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "好，当帐立来。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "遵命。马谡啊！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "后营听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哪位将军帮同马谡镇守街亭？当帐请令。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平愿往。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此番到了街亭，靠山近水，安营扎寨。画一图形速报我知。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "赵老将军听令。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "带领三千人马，镇守列柳城。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马岱听令。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "解押粮草，军中需用，不得有误。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马谡进帐。"
        },
        {
          "character": "四侍卫",
          "type": "同白",
          "text": "马谡进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "末将正在后帐披挂，丞相见谕，有何密令？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今逢大敌，非比寻常。我有一言，将军听了。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮原板",
          "text": "两国交锋龙虎斗， 各为其主统貔貅。 管带三军要宽厚， 赏罚中公平莫要自由。 此一番领兵去镇守， 靠山近水把营收。"
        },
        {
          "character": "马谡",
          "type": "西皮流水板",
          "text": "我主本是汉家后， 南征北战不停留。 躬身领令出帐口， 好似顺水送轻舟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。诸葛亮出帐。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "先帝爷白帝城叮咛就， 诸葛亮怎能够高枕无忧？ 但愿得此一去扫平贼寇， 免老夫亲自里把贼收。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马谡领八蜀兵同上。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "俺、马谡。奉了丞相将令，镇守街亭，不知何人以为副帅？ 来。"
        },
        {
          "character": "八蜀兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平上。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "原来王将军副帅，就请传令。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "元帅传令。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "你我一同传令。 众将官——"
        },
        {
          "character": "八蜀兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "马谡、王平",
          "type": "同白",
          "text": "兵发街亭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八蜀兵同应，同下。马谡、王平同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "司马懿领四魏兵同上。"
        },
        {
          "character": "司马懿",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，传令号，地动山摇，要把狼烟扫。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "钦奉王命去战征，统领貔貅百万兵。胸中韬略安排定，就是神鬼也怕惊。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本督，司马懿。闻听诸葛亮，兵出祁山，据守街亭，必要遣将前去夺取，方能 退得蜀兵。 来——"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "传张郃进帐。"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "张郃进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃上。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "青史标名姓，三国旧有名。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "参见都督。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "命你带领三千人马，夺取街亭，不得有误。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八蜀兵同上。马谡、王平同上，同上桌。马谡大笑。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "元帅为何大笑？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "王将军你看，此山居高临下，有建瓴之势。我军扎在山顶，倘若司马兵到，准 备滚木垒石，以上打下，势如破竹，哪怕魏兵不灭？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "元帅此言差矣。我看此山孤立无援，乃是绝地。倘若魏兵到来，断绝水道，我 军不战自乱矣。我等临行之时，丞相再三吩咐，要靠山近水，安营扎寨，难道 元帅不曾听见么？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "唔。岂不闻兵法有云，“置之死地而后生”？魏兵不来则已，他若来时，我军 自然奋勇当先，以一当百，我料大功必成。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "既是元帅执意要在山上扎营，末将不敢相强。但请元帅，将人马拨与王平一半， 在山下扎一小营。倘若魏兵来时，也好作一准备。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "这有何难，但是一件。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "破敌之后，你不得分我的头功。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "末将怎敢。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "众将官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八蜀兵同应。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "将人马拨王平一半。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平领四蜀兵同下。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "王平无谋，哪知用兵妙计。 众将官——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵同应。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "把住山口。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡、四蜀兵同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵同上。王平上。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "且住。马谡不听我言，一定要在山上扎营。我看街亭难保，倘若失守，怎么回 复丞相？有了，不免画一图形，速速报与丞相，以免我王平的干系。 来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵同应。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "笔墨伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平画图。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "唤旗牌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "这有地理图，速速送与丞相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌应，下。"
        },
        {
          "character": "王平",
          "type": "白",
