{
  "script_id": "14002006",
  "title": "打龙袍",
  "alias": [],
  "source": "《戏典》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "李后",
      "hangdang": "老旦"
    },
    {
      "name": "宋仁宗",
      "hangdang": "小生"
    },
    {
      "name": "王延龄",
      "hangdang": "老生"
    },
    {
      "name": "陈琳",
      "hangdang": "生"
    },
    {
      "name": "郭槐",
      "hangdang": "净"
    },
    {
      "name": "灯官",
      "hangdang": "丑"
    },
    {
      "name": "皇后",
      "hangdang": "旦"
    }
  ],
  "plot": "包拯自辰州放粮回来，路过天齐庙，遇着了李太后（戏情可参看老旦戏中之《断太后》）。回朝想把李后蒙\n冤遭难情节奏明宋仁宗。因怕触怒宋仁宗，就着人扮演花灯，邀请宋仁宗去看。故意扮演些不忠不孝的戏来\n打动宋仁宗，乘机把李后的事申奏出来。宋仁宗闻奏，不但不信，反怪他不该欺君，竟要把他斩首。包拯就\n说老太监陈琳晓得这事本末。宋仁宗召来一问，果然不错。后宫忽报刘太后自尽身死，宋仁宗这才相信这是\n真的。当命包拯迎李后回宫。李后因怪宋仁宗二十年来，还不知生身之母在民间受苦，赐包拯紫金棍一根，\n命他责打宋仁宗。包拯因无臣打君之理，如是叫宋仁宗把龙袍脱下打了几下，算是责罚了宋仁宗。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "平顶冠簪花朵芳，龙廷烟绕御炉香。万国九州朝圣主，满朝文武尽忠良。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤，大宋天子，仁宗在位。自孤登基以来，风调雨顺，国泰民安。今当早朝。 内臣！"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "开放龙门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "念",
          "text": "忙将包拯事，奏与万岁知。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "臣王延龄见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "包拯回朝，已在午门候旨。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "传旨宣包拯上殿。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "万岁有旨：包拯上殿。"
        },
        {
          "character": "包拯",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮流水板",
          "text": "忽听万岁宣一声， 午门来了放粮臣。 撩袍端带我把龙廷进， 品级台前臣见君。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣包拯见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包相平身。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "放粮之事，奏与朕知。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣有散粮表章呈上。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来。 哦呵呀，原来包卿之功。 内侍，光禄寺大排御宴，与包卿贺功。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢。臣出朝之时，在午门许下花灯大会。今日请万岁午门观灯。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家前行，寡人随后。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "万岁爷准了臣的本， 可怜国太受苦情。 午门外巧改扮花灯彩， 暗地打动有道君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。"
        },
        {
          "character": "王延龄",
          "type": "西皮摇板",
          "text": "辞别万岁下殿往， 去到午门看端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄下。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "内侍摆驾回龙廷， 明日早朝观花灯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗、四太监同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "灯官上。"
        },
        {
          "character": "灯官",
          "type": "念",
          "text": "奉了包相命，午门扮花灯。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "在下灯官是也，奉了包相之命，扮齐各样的花灯，远远望见圣驾来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引宋仁宗、包拯、王延龄同上。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "参见万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "将灯名报上来。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "咋。列位休要吵休要闹，细听我把灯名儿报一报。报的是：一团和气灯、和合 二仙灯、三阳开泰灯、四季平安灯、五子夺魁灯、六国封相灯、七财子路灯、 八仙过海灯、九子十成灯、十面埋伏灯。这个灯，不算灯，那旁来了一套灯。 若问此灯什么名，昭君打马过雁门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灯上，过场，下。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "灯又来了。看罢了一层又一层，吕布董卓大闹凤仪亭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灯上，过场，下。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "灯来了。看罢了一套又一套，那旁花灯又来到。亲父母，也要孝，晚父母，也 要孝。为人双亲若不孝，清风亭雷打张继宝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灯上，过场，下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "哎呀！胆大的灯官，扮这样不忠不孝的灯。 校尉，将扮灯官拿下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢！万岁，为何将扮灯官拿下？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "扮这样不忠不孝的灯，故而将他拿下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "慢说不忠不孝之灯，就是不忠不孝之人，我朝也有。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "奏来，寡人将他碎尸万段。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣不敢冒奏龙颜。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "恕卿无罪。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "就是万岁。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "听罢言来怒气生， 藐视寡人为何情？ 内侍摆驾回龙廷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、宋仁宗同下。"
        },
        {
          "character": "王延龄",
          "type": "西皮摇板",
          "text": "回头埋怨小包文。 有本就该当殿奏， 为什么扮灯藐视君？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师啊！"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "老恩师休要胆怕惊， 学生言来听分明。 自古道是忠臣我就不惜命， 怕死焉能作忠臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王延龄、灯官同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监引宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "内侍摆驾金殿进， 唤上包拯问分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "包拯拿到。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押上殿来。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "万岁有旨，将包拯押上殿来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监押包拯同上。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "忽听二次宣一声， 午门外来了犯罪臣。 大摇大摆我把龙廷进， 问我一言答一声。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "包拯作事太屈情， 不该扮灯藐寡人。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "辰州放粮转回京， 赵州桥前路难行。 偶遇狂风吹轿顶， 来了个瞎婆把冤申。 为臣再三来盘问， 才知国太受苦情。 亲生之母你不认， 不忠不孝头一名。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮快板",
          "text": "卿家得下疯癫病， 来在金殿欺寡人。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "休道臣得下疯癫的病， 国太言语听得清。 千言万语你不信， 景阳宫问一问二十年前老陈琳。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监押包拯同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "内侍，金牌宣，银牌召，宣亚父陈琳上殿。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "万岁有旨：金牌宣，银牌召，亚父陈琳上殿。"
        },
        {
          "character": "陈琳",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": "陈琳",
          "type": "内西皮导板",
          "text": "金牌宣来银牌召定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈琳上。"
        },
        {
          "character": "陈琳",
          "type": "西皮流水板",
          "text": "景阳宫来了老陈琳。 扶杖且把金殿进， 朝王驾来问安宁。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢陈琳见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "亚父平身，赐坐。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "陈琳谢坐。二十年未曾宣诏奴婢，今日宣诏，有何国事议论？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "小王有一事不明，要请亚父台前领教。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "何事不明？何为领教二字。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "请问亚父，小王乃何人所生？哪宫所养？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢不敢冒奏。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只管奏来。寡人不罪于你。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "吾主乃李娘娘所生，刘娘娘所养。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "往下奏来。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏：只因癸未年间，李娘娘身怀吾主。宫中有一刘娘娘，与内侍郭槐，姑表 之亲。他二人定下一计，老王面前，讨下收生代劳旨意。将狸猫剥去皮毛，替 换吾主。老大王大怒，将李后推出斩首。多亏满朝文武保奏，死罪已免，活罪 难饶，将李后打在冷宫受罪。他二人一计不成，又生二计，道冷宫不清。约定 八月十五日，火焚冷宫，火光一起，李娘娘不知生死存亡。此事已隔二十馀载， 今日为何又来提起？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只因包拯回朝，见过国太。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "既是国太还在，有老王游玩御花园，赐与李后黄罗手帕。上有寇老先生诗句为 证。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "诗句怎道？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏："
        },
        {
          "character": "陈琳",
          "type": "念",
          "text": "春风得意花前蕊，秋月扬辉桂一枝。天降紫微接宋后，未知生龙并雌雄。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "这就是当年的诗句。啊，万岁，既是包拯回朝，为何不在金殿？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只因巧扮花灯，藐视寡人，将他斩首。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "不好了。"
        },
        {
          "character": "陈琳",
          "type": "西皮二六板",
          "text": "万岁要斩斩奴婢， 午门赦回有功臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包拯赦回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "日落西来又转东， 水流千遭归海中。 百尺高竿得活命， 千层浪里又复生。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁不斩之恩！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿言国母还在，有何为证？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "黄罗诗帕为证，万岁请看。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗接帕看。"
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "春风得意花前蕊，秋月扬辉桂一枝。天降紫微接宋后，未知生龙并雌雄。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "着着着！"
        },
        {
          "character": "陈琳",
          "type": "西皮摇板",
          "text": "亲生之母你不认， 国外道你无道君。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "不是亚父来提醒， 险些斩了有功臣。 内臣与孤忙搀定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗拜跪。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "拜你如同拜先人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同上。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "刘娘娘自尽，郭槐拿到。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "绑上殿来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭槐上。"
        },
        {
          "character": "郭槐",
          "type": "白",
          "text": "原来是一党奸臣在此。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "你这奸贼，当年苦害国太。 殿前武士，推出斩首！"
        },
        {
          "character": "郭槐",
          "type": "白",
          "text": "住了，我乃老王托孤之臣，谁人敢斩？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "你道寡人斩不得你。 武士，将他碎尸万段！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军押郭槐同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿，怎样迎接国太？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "准备龙车凤辇，迎接国太回朝。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "吩咐摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "李后",
          "type": "内西皮导板",
          "text": "龙车凤辇进皇城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军、四太监、宋仁宗、李后同上。"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "御街上来了我讨饭人。 赵州桥前遇包拯， 二十载冤仇报得清。 眼不明观不见花花美景， 看不见汴梁城文武公卿。 叫皇儿搀为娘忙下车轮， 耳边厢又听得接驾声音。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "王延龄见驾，国太千岁！"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "王延龄在我朝忠心秉正，"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢陈琳见驾，国太千岁！"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "二十年又遇着老陈琳。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "包拯见驾，国太千岁！"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "赤胆忠心包文拯，"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "李后",
          "type": "西皮慢板",
          "text": "你是哀家活命恩人。 待等大事安排定， 将你官职往上升。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。二宫女引皇后同上。"
        },
        {
          "character": "皇后",
          "type": "白",
          "text": "儿臣见驾，国太千岁。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "回宫去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引皇后同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿，国太双目不明，如何是好？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "天地堂哀告上苍，天赐光明，也未可知。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "摆驾天地堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、包拯、王延龄、陈琳、宋仁宗、李后同上。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "孤，大宋天子仁宗在位。只因母亲双目不明，望上苍恩赐光明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "母后醒来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李后睁眼。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "皇儿。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "母后。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "众卿。"
        },
        {
          "character": "包拯、王延龄、陈琳",
          "type": "同白",
          "text": "国太。"
        },
        {
          "character": "李后",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、包拯、王延龄、陈琳、宋仁宗、李后同上。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "儿臣见驾，母后千岁。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "哎，我把你这无道的昏君。"
        },
        {
          "character": "李后",
          "type": "西皮流水板",
          "text": "一见皇儿跪埃尘， 开言大骂无道的君。 二十年前娘有孕， 刘妃、郭槐他起下狠毒心。 金丝狸猫来剥定， 他倒说为娘我产生妖精。 老皇爷一见怒气生， 将为娘我推出了那午门以外问斩刑。 多亏了满朝文武来保本， 将为娘我打至在那寒宫冷院不能去见君。 一计不成二计生， 约定了八月十五火焚冷宫庭。 若不是老陈琳他记得正， 险些儿斩坏了那架海金梁擎天柱一根。 我越思越想心头恨， 不由得哀家动无名。 内侍看过紫金棍，"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "包卿！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "李后",
          "type": "西皮摇板",
          "text": "替哀家拷打无道君。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "包拯",
          "type": "西皮流水板",
          "text": "在金殿领了国太命， 背转身来自思忖。 自从盘古历地今， 哪有臣子敢打圣明君？ 万岁爷龙袍忙脱定， 俺包拯打龙袍有如臣打君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗脱下龙袍，王延龄持袍让包拯打袍。"
        },
        {
          "character": "李后",
          "type": "西皮流水板",
          "text": "好一个聪明小包拯， 打龙袍如同臣打君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲与包拯插帽。"
        },
        {
          "character": "李后",
          "type": "西皮流水板",
          "text": "包拯近前听封赠，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯跪。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "包卿。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "李后",
          "type": "西皮流水板",
          "text": "我封你太子太保在朝门。 内侍看过金档翅，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监甲与包拯插翅。"
        },
        {
          "character": "李后",
          "type": "西皮流水板",
          "text": "再赐你尚方剑一根。 三宫六院你管定， 满朝文武任你行。 倘若是皇儿不从命，"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "母后开恩。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "也罢。"
        },
        {
          "character": "李后",
          "type": "西皮摇板",
          "text": "画影图形也要充军。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢国太！"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "叩罢头来谢罢恩，"
        },
        {
          "character": "包拯",
          "type": "西皮流水板",
          "text": "龙国太待我好恩情。 金殿赐我金档翅， 还有那尚方剑一根。 三宫六院任我管， 那五府六部任我行。 哪一家馋臣他不遵我的命， 押定了满朝文武大小官员公子王孙，哪一个不遵，要照剑施行。"
        },
        {
          "character": "李后",
          "type": "白",
          "text": "本后回朝，内帘官，外帘官，加升三级。光禄寺大摆筵宴，与包卿贺功。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "摆驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}