{
  "script_id": "14002007",
  "title": "玉堂春",
  "alias": [],
  "source": "《戏典》",
  "characters": [
    {
      "name": "苏三",
      "hangdang": "青衣"
    },
    {
      "name": "王金龙",
      "hangdang": "小生"
    },
    {
      "name": "刘大人",
      "hangdang": "须生"
    },
    {
      "name": "周大人",
      "hangdang": "须生"
    },
    {
      "name": "崇公道",
      "hangdang": "丑"
    }
  ],
  "plot": "八府巡按王金龙，来到山西太原府洪洞县，查阅案卷。见内有苏三谋杀亲夫一案，随即升堂，请藩台、臬台\n一同陪审。一见犯妇就是自己从前所热恋的妓女玉堂春，不禁吓晕过去，只好暂时罢审。随即请医生诊过，\n精神恢复后才继续审问。不意苏三所供，都是些旧事重提。王金龙听得渐渐忘形，要想跑下位去，和苏三叙\n叙离情。被藩、臬二人识破他的隐秘，向他只管冷嘲热讽。王金龙羞惭得无地自容，只好再装旧病复发，将\n案子索性交与他们二人去审。藩、臬故意只略一盘问就退了堂，看王金龙怎样和苏三会面。王金龙到底因为\n耳目众多，暂时也不敢相认。只不过稍加安慰苏三，说是极力设法来搭救她罢了。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王金龙上。"
        },
        {
          "character": "王金龙",
          "type": "引子",
          "text": "今奉圣旨，来到洪洞。"
        },
        {
          "character": "王金龙",
          "type": "念",
          "text": "今奉圣命出帝京，察访恶霸与刁民。不论皇亲并国戚，王法二字不容情。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "本院王金龙。今奉圣恩，放我八府巡按。出京以来，路过九州八府一百零八县。 来在洪洞县下马，内中有谋杀亲夫一案。少刻等二位年兄来到，一同审问。 来，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子上。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "二位大人到。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周大人、刘大人同上。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "不知二位年兄驾到，未曾远迎，多有得罪。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "我等来得鲁莽，望大人恕罪。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "大人出京以来，路过几州几府？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "路过九州八府，一百零八县。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "哪里下马？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "洪洞县下马。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "内中可有奇巧案件？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "奇巧案件倒有，内中还有谋杀亲夫一案。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "大人今日升堂，不知审问哪一案？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "自然先审谋杀亲夫一案。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "既然大人审问，我等辕门伺候。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "少刻升堂，烦劳二位大人一同审问。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "告辞。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周大人、刘大人同下。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "来，吩咐传点开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王金龙下。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "传点开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四衙役、门子、周大人、刘大人、王金龙同上。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "带长解。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "带长解。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道上。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "参见三位大人。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "可有公文？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "呈上来。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "当堂拆封听点，长解一名崇公道。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "护解一名崇公道。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "哽！一人该当二役，看大刑伺候。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "且慢，封皮上面，没有小人名字，大人再责不迟。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "请问大人，此刑可免？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "免。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "犯妇可曾带到？"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "现在堂口。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "带上堂来。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道起身，向内喊。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "犯妇走动。"
        },
        {
          "character": "苏三",
          "type": "内白",
          "text": "苦啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三上。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "喂呀呀呀。"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "来至在都察院举目往上观， 两旁的刀斧手吓得我胆战心又寒。 苏三此去好有一比，"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "好比那鱼儿落网有去无还。"
        },
        {
          "character": "苏三",
          "type": "哭",
          "text": "啊啊啊，崇爹爹呀。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "此番前去，大人开活你的死罪。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三上堂，跪。"
        },
        {
          "character": "崇公道",
          "type": "白",
          "text": "犯妇带到。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "犯妇因何不抬起头来？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "恕你无罪，抬起头来。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "王金龙",
          "type": "西皮散板",
          "text": "本院举目来观看， 原来苏三到来临。 一霎时不由我神魂不定。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王金龙晕倒。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "带下去，掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周大人、刘大人、四衙役、门子、崇公道、苏三同下。中军引医生上。医生作看病把脉状，诊完欲下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "先生请转。"
        },
        {
          "character": "医生",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "不知我家大人得的什么病症？"
        },
        {
          "character": "医生",
          "type": "白",
          "text": "乃是单思病。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "自来只有相思病，哪有单思病之理？"
        },
        {
          "character": "医生",
          "type": "白",
          "text": "你既知道，何必问我。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "果然是名医。"
        },
        {
          "character": "医生",
          "type": "白",
          "text": "不是名医，头上顶子哪里来？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "果然是高才。"
        },
        {
          "character": "医生",
          "type": "白",
          "text": "不是高才，这个衙门里头，焉能踱出踱进。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "送先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "医生下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "请大人升堂。"
        },
        {
          "character": "王金龙",
          "type": "南梆子",
          "text": "三魂渺渺又还魂。 朦胧举目来观定，"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "大人醒来。"
        },
        {
          "character": "王金龙",
          "type": "南梆子",
          "text": "又听得众衙役喧嚷不停。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "升堂。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "升堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周大人、刘大人、四衙役、门子同上。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "参见大人。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "二位年兄请坐。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "告坐。请问大人，还是新病？还是旧病？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "乃是旧病新发。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "倒把我二人吃了一惊"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "多蒙二位年兄挂念。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "大人此案可问？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "此案乃朝廷重犯，哪有不问之理？"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "真乃爱民如子，你我大家同审。 来，带长解，将犯妇带上来。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "长解，将犯妇带上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道、苏三同上。苏三跪。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "参见三位都天大人。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "可有状？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "呈。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "无。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "唔。问你可有状，你说有。叫你呈，你说无，分明是个刁妇。 二位年兄，与我用刑。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "分明是个刁妇。 来，大刑伺候。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "哎呀，大人呐。犯妇有话，未曾回明。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "朝上回。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "启禀三位都天大人：犯妇此罪，并非犯妇自己所为。乃大娘皮氏，花了银钱， 将犯妇买成一行死罪。起解临行之时，监中有人不平。替犯妇写下伸冤诉状， 又恐皮氏搜去，因此藏在枷内。望大人开一线之恩，将犯妇当堂劈锁开枷。哎 呀，大人呐。犯妇纵死九泉，也是瞑目的了哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三哭。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "请问大人，此刑可免？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "免。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "来，当堂劈锁开枷。"
        },
        {
          "character": "四衙役、崇公道",
          "type": "同白",
          "text": "喳，当堂劈锁开枷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道为苏三开枷。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "三日后领回文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崇公道应，下。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "犯妇，照状子上面，一一诉来。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "大人容禀。"
        },
        {
          "character": "苏三",
          "type": "西皮导板",
          "text": "玉堂春跪至在都察院，"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "唗。状子上面写的是苏三，口称玉堂春，分明是刁妇。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "刘大人用刑。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "看拶。"
        },
        {
          "character": "苏三",
          "type": "哭",
          "text": "啊……"
        },
        {
          "character": "苏三",
          "type": "回龙",
          "text": "大人啊……"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "两厢退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四衙役同下。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "面朝外跪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三朝外面跪。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "犯妇，慢慢地诉来。"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "玉堂春本是公子他取名。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "几岁进院？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "鸨儿买我七岁正，"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "在院中过了几载？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "在院中住了整九春。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "你开怀是哪一个？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "十六岁开怀是那王……"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "王什么？"
        },
        {
          "character": "苏三",
          "type": "西皮慢板",
          "text": "啊，王公子啊。 他本是吏部堂上三舍人。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "唔。审的是谋杀亲夫的案子，谁要听你院中苟且之事。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "啊，大人。谋杀亲夫的案子要审。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "院中苟且之事也要问呐。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "如此说来，审呐？"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "审呐。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "问呐？"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "问呐。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "苏三",
          "type": "西皮快三眼",
          "text": "初次见面三百两， 吃一杯香茶就动身。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "大人。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "年兄。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "想那王公子，初次进院，见面银子三百两，吃杯香茶就走。你我看将起来，可 以算得大大的慷客。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "哪里是慷客，分明是王门中，出了败家之子。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "二位年兄。依我看来，可以算得一个慷客。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "算不得。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "算得。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "年兄。大人说算得，你我就说算得啊。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "苏三",
          "type": "西皮快三眼",
          "text": "公子二次把院进，"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "带来多少银子？"
        },
        {
          "character": "苏三",
          "type": "西皮快三眼",
          "text": "随带三万六千银。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "在你院中住了几时？"
        },
        {
          "character": "苏三",
          "type": "西皮快三眼",
          "text": "在院中未到一年整， 三万六千银一概化了灰尘。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "唔，想那王公子在你院中，未到一年，将三万六千两银子俱已花尽。难道你吃 的银子，穿的银子不成？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "二位年兄，想她的院中有她的支销哇。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "大人，你怎么晓得她的支销？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "这，这状子上面写的支销。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "哦，状子上面写的，不是大人晓得的。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "犯妇自有支销。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "年兄。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "大人。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "你我就审她的支销。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "先买金杯和玉盏， 又买翠盘与翠瓶。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "也用不了这许多。"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "南楼、北楼公子造， 又造一座百花亭。 忘八、鸨儿心太狠， 数九寒天将公子赶出了院门。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "唔。想那王公子在你院中，未过一年，三万六千银子，俱已花尽。数九寒天， 为何将他赶出院去？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "并非犯妇所为，乃是鸨儿之过。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "如此说来，好个狠心肠的鸨儿。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "铁心肠的忘八。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "遇见倒运的嫖客，才会有这无情的婊子。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "公子一怒出了院，"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "哪里安身呢？"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "关王庙内把身存。 那一日金哥来报信， 手把纹银探望情人。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "你可曾看见那王公子？"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "不顾腌臜怀中抱， 在神案底下叙叙交情。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "大人、年兄，想那玉堂春，乃是有义气的。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "想那王公子，身上褴褛。玉堂春不嫌腌臜，怀中抱定。在神案底下，叙叙旧情。 岂不是有义气？"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "哎，哪里是义气。她们娼门之女，一派做作。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "二位年兄。想玉堂春本来有义气的。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "大人说有义气，年兄你我就算她有义气啊。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "打发公子去赶考， 落凤坡前遇着了强人。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "哎，想那王公子实在命苦哇。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "那玉堂春付与他银两，行在途中，又被强人抢去，岂不是命苦？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "咳，也是那王公子时运未到。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "大人，哪里是时运未到，我把他好有一比。"
        },
        {
          "character": "王金龙、周大人",
          "type": "同白",
          "text": "比作何来？"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "好比那望乡台上赏牡丹。"
        },
        {
          "character": "王金龙、周大人",
          "type": "同白",
          "text": "此话怎讲？"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "他至死还要贪花啊。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "公子落得长街讨， 吏部堂上去巡更。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "年兄，想那王公子出身不高。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "王公子乃是吏部堂上之人，又在吏部堂上打更，岂不是不高哇。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "二位年兄，想是那王公子时运未到。当初有个陈庆鸿先生，也是流落。后来时 运一到，得中头名状元。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "此公子比不得那公子。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "将今比古，比得的。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "比不得。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "哎，比得。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "年兄，大人说比得就比得。"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "王金龙、周大人、刘大人",
          "type": "同白",
          "text": "讲。"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "公子三次进了院，"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "三番两次前来则甚？"
        },
        {
          "character": "苏三",
          "type": "西皮原板",
          "text": "拐带银两转回了南京。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "唔，想那王公子在你院中，花了三万六千银子，为何落了个拐带二字？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "并非公子拐带，乃是犯妇自己赠与他的。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "赠他多少？"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "黑夜之间，一无天平，二无戥秤，用手约来，不过三百馀两。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "这就不错了。我在旅店之中，一无天平，二无戥秤，用手约来，不过三百馀两。 哎呀，妻……"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "大人，想她乃是朝廷的重犯，不是大人的宝眷，大人不要错认呐。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "二位年兄，想本院旧病又发，不能审问，烦劳二位与我代审。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "犯妇慢慢地诉来。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "二位大人容禀。"
        },
        {
          "character": "苏三",
          "type": "西皮二六板",
          "text": "自从公子回原郡， 奴在北楼装病人。 公子若是不娶妾， 玉堂春立志我就不嫁人。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "你说不嫁人，怎样嫁与山西沈洪呢？讲。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "大人呐。"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "那一日梳妆来照镜， 楼下来了沈燕霖。 他在楼下夸豪富， 胜比公子强十分。 奴在北楼高声骂， 只骂得燕霖脸绯红。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "他就罢了不成。"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "含羞带愧回店去， 主仆二人又把巧计生。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "生什么巧计？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "做媒的银子三百两，"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "鸨儿呢？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "鸨儿到手一斗金。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "你可曾随他前去？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "鸨儿逼迫奴不允， 才将假书骗奴的身。 他说公子新得中， 得中了皇榜第一名。 奴为他还愿把香进， 又谁知一马就到了洪洞。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "到洪洞住了几载呢？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "在洪洞未到一年整，"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "皮氏待你如何？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "皮氏大娘起毒心。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "起什么毒心？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "一碗药面付奴手， 双手奉与沈官人。 官人不解其中意， 吃一口来哼一声。 昏昏迷迷倒在地， 七孔流血他的命归阴。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "那皮氏就罢了不成？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "皮氏大娘一声喊， 她道犯妇谋害人。 惊动乡邻和地保， 拉拉扯扯到官厅。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "头堂官司怎样审法？"
        },
        {
          "character": "苏三",
          "type": "西皮散板",
          "text": "头堂官司审得好。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "这二堂呢？"
        },
        {
          "character": "苏三",
          "type": "西皮散板",
          "text": "二堂官司就变了心。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "怎样的变了心呢？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "王知县受贿一千两。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "众衙役呢？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "合衙分赃八百银。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "可曾提来对审？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "上公堂先打四十板，"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "可曾招认？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "无情的拶子难受刑。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "打死你也不该招认呐。"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "犯妇本当不招认， 我的大老爷， 皮鞭打断了无数根。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "在监中住了几载？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "在监中住了一年整。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "可有人前来探望？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "并无有一人探望奴的身。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "那忘八、鸨儿呢？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "忘八、鸨儿无踪影。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "你那知心的人呢？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "犯妇哪有这知心的人？"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "那王公子就该探望于你。"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "王公子他一家多和顺， 我与他露水夫妻有的什么情？"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "眼前若有王公子，你可认识于他？"
        },
        {
          "character": "苏三",
          "type": "西皮流水板",
          "text": "眼前若有王公子， 青纱盖脸奴也认也认得清。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "如今那王公子头戴乌纱，身穿大红，他不来认你了。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "大人呐。"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "眼前若有公子在， 死在九泉我也甘心。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "年兄，问来问去，原来是有按院大人在案。你我暂避一时，看他怎样的与她相 认呐。"
        },
        {
          "character": "周大人",
          "type": "白",
          "text": "真真的令人好笑哇。"
        },
        {
          "character": "周大人、刘大人",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "周大人、刘大人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周大人、刘大人同下。四衙役同暗上。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "苏三呐苏三。"
        },
        {
          "character": "王金龙",
          "type": "西皮摇板",
          "text": "适才堂口把话论， 句句说的是真情。 本当下位来相认……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四衙役同吆喝。"
        },
        {
          "character": "王金龙",
          "type": "西皮摇板",
          "text": "王法条条不徇情。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "拿我名帖，请刘大人过衙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子应，下。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "苏三，你且暂时出院。本院想一良计，搭救于你就是。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "谢大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三立起，手揉膝盖。"
        },
        {
          "character": "苏三",
          "type": "西皮二六板",
          "text": "这一堂官司未动刑， 玉堂春才得放宽心。 出得察院回头看，"
        },
        {
          "character": "苏三",
          "type": "西皮快板",
          "text": "这大人好似旧情人。 是公子就该将我来认……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四衙役同吆喝。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "苏三",
          "type": "西皮快板",
          "text": "王法条条不徇情。 上前去说几句之心话， 看他知情不知情。"
        },
        {
          "character": "苏三",
          "type": "西皮散板",
          "text": "玉堂春好比花中蕊，"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "哽，王公子比作何来？"
        },
        {
          "character": "苏三",
          "type": "西皮快板",
          "text": "王公子好比采花蜂。 想当初花开多茂盛， 他好比蜜蜂儿飞来飞去采花心。 到如今不见我那三公——"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "子， 花谢时怎不见蜜蜂儿行。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "快快出院去罢。"
        },
        {
          "character": "苏三",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "苏三",
          "type": "西皮摇板",
          "text": "舍悲忍泪出察院， 看他把我怎样行？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏三下。门子引刘大人同上。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "刘大人到。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "参见大人。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "年兄少礼。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "传卑职过衙，为了何事？"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "只有苏三一案，烦劳年兄审问，必须要谅情一二。"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "卑职照律条而断。"
        },
        {
          "character": "王金龙",
          "type": "白",
          "text": "这个……但凭于你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王金龙下，门子、四衙役同随下。四随侍同上。"
        },
        {
          "character": "刘大人",
          "type": "冷笑",
          "text": "哈哈哈！"
        },
        {
          "character": "刘大人",
          "type": "白",
          "text": "身为八府巡按，作出此事，你头上这顶乌纱，捏在我手中了。 来，开道回衙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四随侍同应，同下，刘大人随下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}