        {
          "character": "施仕伦",
          "type": "白",
          "text": "昨日转马回京。"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "老夫少备夫马。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "好说了。"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "南京儿女百姓，可好教训？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "南京的儿女百姓，都道我的主子，是有道的皇上。"
