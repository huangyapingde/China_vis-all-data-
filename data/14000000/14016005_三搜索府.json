{
  "script_id": "14016005",
  "title": "三搜索府",
  "alias": [],
  "source": "《戏典》",
  "characters": [
    {
      "name": "施仕伦",
      "hangdang": "丑"
    }
  ],
  "plot": "《施公洞庭传》说部，载施仕伦奉康熙帝命，赴南京训民，获奸人单四、单五兄弟。据供当朝太师索百美，\n私造平天冠及蟒袍玉带并弑皇宝剑，有篡位之心。施仕伦将单氏弟兄带进京中，白于康熙帝前。康熙帝命施\n仕伦率众往搜索府，竟未获线索，且受索百美百般侮辱。归奏康熙帝，康熙帝怒其诬告，欲杀施仕伦。幸尚\n书张明格保奏，愿以全家性命作质，命施仕伦再搜索府，仍未得实证。张明格授意于施仕伦，立提单四、单\n五，拷问其索太师之赃证藏于何处。单四、单五以实告。待施仕伦三次往搜，则人赃并获，解于康熙帝前。\n康熙帝割索百美耳而贬为庶民云。",
  "notes": "此剧系当年老三麻子王洪寿之杰作。老生及小丑均可扮施仕伦。南中仅刘斌昆擅长此剧。周信芳亦曾一度搬\n演。本《戏典》所载，即刘艺员所录赠者。而周信芳演此剧时，亦须向刘斌昆商借剧本，请渠任导演焉。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起堂〗，〖水龙吟〗，〖大出场〗。四手下、门子引施仕伦同上。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "哦哦哦哦！"
        },
        {
          "character": "施仕伦",
          "type": "引子",
          "text": "奉命钦差四个字，王法律条不循情。"
        },
        {
          "character": "施仕伦",
          "type": "念",
          "text": "按院出朝，地动山摇。逢龙缺角，遇虎拔毛。 钦命二字，替主代劳。贪官污吏，斩杀不饶。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "咱施仕伦。吾父施万户，康熙主子驾前为臣，官封王位，白御王是我的表弟。 奉王旨意，南京训民。训民已毕，回朝缴旨，打从黄河渡口经过，偶遇单四、 单五两个杂种，强奸民间妇女。是我拿来三拷六问，那两个杂种讲道：施老爷 不用打我们，有好心当献。他讲道我朝索老太师索百美，私造蟒袍玉带、刺王 的宝剑，要谋主子的江山。因此将二贼带回京来，一来与主子问安，二来缴旨， 三来我要参这老奸头一本。 你们来呀！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "这个銮驾，齐备了无有？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "齐备多时。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "齐备了，一路之上，公买公卖，不准马踏青苗。若是儿女百姓遇害，可是要与 你们同罪的。"
        },
        {
          "character": "门子、四手下",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "你们知道么？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "知道。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "晓得么？"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "开道！"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "开道呀！"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "王八蛋！叫你们开道，一个个望什么？打轿伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "轿夫上，施仕伦上轿。〖清水令〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张明格上。"
        },
        {
          "character": "张明格",
          "type": "念",
          "text": "五鼓金鸡唱，月照满栏杆。"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "老夫张明格，今当早朝，理应朝廊伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大出场〗。施仕伦上。"
        },
        {
          "character": "施仕伦",
          "type": "念",
          "text": "南京训民事，报与主子知。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "哎哟！原来是老伯父，侄男拜揖。"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "还礼。公子几时转马回京？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "侄男昨日转马回京。"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "老夫少备夫马。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "好说了。"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "南京的儿女百姓，可好教训？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "南京的百姓都知道咱们主子是有道的皇上。"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "不在南京训民，来京何事？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "一来与主子问安，二来谒见老伯父，三来有个短本儿启奏。"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "香烟渺渺，金驾临朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施仕伦、张明格自两边分下。四龙套、四手下、大太监引康熙同上。"
        },
        {
          "character": "康熙",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "康熙",
          "type": "念",
          "text": "昔日老王从天运，减却闯王李自成。且喜四海浪烟尽，江山一统归大清。"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "孤，康熙在位。登基以来，风调雨顺，国泰民安。今当早朝。 内臣！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "开放龙门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张明格上。"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "启奏万岁：施仕伦回京，已在午门候旨。"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "御卿传旨，宣！"
        },
        {
          "character": "张明格",
          "type": "白",
          "text": "万岁有旨：宣施仕伦上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张明格下。"
        },
        {
          "character": "施仕伦",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施仕伦上。"
        },
        {
          "character": "施仕伦",
          "type": "西皮导板",
          "text": "金牌召来银牌宣，"
        },
        {
          "character": "施仕伦",
          "type": "西皮摇板",
          "text": "部中闪出施不全。 站在殿角用目看， 红红绿绿众卿官。 忠良见我哈哈笑， 奸佞见我咬牙关。 大摇大摆上宝殿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。"
        },
        {
          "character": "施仕伦",
          "type": "西皮摇板",
          "text": "参王驾来问王安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施仕伦参拜。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "臣、施仕伦见驾！"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "表兄平身，赐坐！"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "臣谢坐！"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "南京训民，儿女百姓可好教训？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "南京儿女百姓，都道咱的主子，是有道皇上。"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "不在南京训民，来京何事？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "一来与主子问安，二来缴旨，三来一个短本儿启奏。"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "有什么本章，当殿奏来。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "我朝出了这样一个大臣，要学西汉王莽、东汉曹操、宋朝秦桧、明朝李良等弊， 私造蟒袍玉带、刺王的宝剑，要谋我主子的江山。咱的主子，你知道吗？"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "孤王不知，但不知是那一家？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "我朝中十大清官都不敢，就是索老太师索百美的大驾。"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "哼！来说是非者，便是是非人。孤王赐你金旨一道，前去搜巡。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "领旨，请驾。"
        },
        {
          "character": "康熙",
          "type": "白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "康熙下，四龙套、大太监同下。"
        },
        {
          "character": "施仕伦",
          "type": "西皮摇板",
          "text": "金钟三声王退殿， 文武敢怒不敢言。 辞王别皇驾下金殿， 大胆前去搜索三。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四手下引施仕伦同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "门官甲引索百美同上。"
        },
        {
          "character": "索百美",
          "type": "西皮导板",
          "text": "康熙王子坐北京，"
        },
        {
          "character": "索百美",
          "type": "西皮摇板",
          "text": "风调雨顺坐太平。 私造冲天冠一顶， 要谋吾主锦乾坤。 三、六、九日坐察院， 五阎君驾坐议事厅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四手下引施仕伦同上。"
        },
        {
          "character": "施仕伦",
          "type": "唱",
          "text": "金瓜月斧朝天蹬， 黄罗伞照定施仕伦。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "来此索府。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "下轿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施仕伦下轿。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "看马扎子伺候。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "看手本。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "手本在此。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "前去讲道，施老爷拜。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "是。 噅！我们施老爷求见。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "是哪个？施老爷敢是施跷子？"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "施麻子吗？"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "要站下些。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官甲大声。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "要站下些。 禀太师，施仕伦拜。"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "老夫久安不用见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官甲出。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "太师久安不用见。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "禀老爷，他们回说，久安不用见。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "什么久安不用见，这个老头，他迟不久安，早不久安，施老爷回京，他就久安， 装什么样？你这杂种，这两句话都回答不来。你说我家老爷回京，未曾朝天 子，先来谒相家。久安也要见，不久安也要见，少一时打进府来，我们要强见。 那个贼种他不传见？"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "是！ 我家老爷回京，未曾朝天子，先来谒相家。久安也要见，不久安也要见，少一 时打进府来，我们要强见。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "什么？你们要强奸我们的太师？是一族杂毛！你要强奸我，乃是一个八八胡须。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "我们是强见。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "是强见？站下些，退后些。 禀太师：他家老爷回京，未曾朝天子，先来谒相家。久安也要见，不久安也要 见，少一时他们就要强见。"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "他一定要见？传见。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "转来！有请！"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "咱，什么有请？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施仕伦对四手下。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "你们此番来搜行，这个蟒袍玉带搜出来了，都是有官做的，搜不出来，老爷把 嘴一提，你们都是要跑的。你们知道？"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "知道，晓得！知道，晓得！"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "你们还望着什么？吩咐闪门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。施仕伦进门，拜。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "老伯父请上，受侄男拜揖。"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "但行常礼。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "理当一拜。"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "与公子看座。"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "老伯父在此，哪有侄男的座位？"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "焉有不坐之理？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "太师在上，告坐了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹细堂〗。"
        },
        {
          "character": "索百美",
          "type": "白",
          "text": "公子几时转马回京？"
