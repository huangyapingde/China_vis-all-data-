        {
          "character": "索百美",
          "type": "白",
          "text": "不在南京训民，回京何事？"
        },
        {
          "character": "施仕伦",
          "type": "白",
          "text": "一来与主子问安，二来谒见老太师，三来有一件大事相商。"
