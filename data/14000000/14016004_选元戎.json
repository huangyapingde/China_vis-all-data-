        {
          "character": "程咬金",
          "type": "白",
          "text": "怎么着，你一个人要举两个，想拿双份儿。"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎呀，你要是举不起来，岂不叫你舅舅笑话你吗？"
        },
        {
          "character": "秦英",
          "type": "白",
          "text": "公公！"
