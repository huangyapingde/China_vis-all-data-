    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": "唐太宗",
          "type": "内西皮导板",
          "text": "金阙迢遥殿影重，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军、车夫、四小太监、伞夫、四宫女引唐太宗同上。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "军情阻隔意难通。 国家邦本人人重， 岂肯湮没丧祖功， 可恨苏海夷苗种， 不守王化屡称雄， 扰得来边廷干戈动， 民遭涂炭国帑空。 损兵折将朕心痛， 皇儿被困似鸟窥笼。 若非老将雄心猛， 怎能杀出万马中？ 为此将金牌传与众， 择定了今日选元戎。 龙行虎步上九重，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金、杜如晦、房玄龄、詹龙、詹虎、秦英、罗章、尉迟松、尉迟江、程通、谢寿同上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣等见驾，吾皇万岁，万万岁！ 小将们齐来见驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦英、詹龙、詹虎、罗章、尉迟松、尉迟江、程通、谢寿同参。"
        },
        {
          "character": "秦英、詹龙、詹虎、罗章、尉迟松、尉迟江、程通、谢寿",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "抬起头来。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "举目往下看英雄。 这一个青春如傅粉， 那一个少壮气象凶； 有几个亚赛亭侯样， 有几个何殊翼德公。 看来是人人有智勇， 一个一个有父风。 站立两旁听录用，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "秦英、詹龙、詹虎、罗章、尉迟松、尉迟江、程通、谢寿",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "詹虎。"
        },
        {
          "character": "詹虎",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "有何膂力考挂元戎？"
        },
        {
          "character": "詹虎",
          "type": "白",
          "text": "臣启万岁：臣观殿下有玉石狮子一对，每个重有千斤，谁能搬得举起这狮子， 可以挂帅印。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "依卿所奏，就此下殿搬来。"
        },
        {
          "character": "詹虎",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "詹虎举狮子。詹龙神气。"
        },
        {
          "character": "詹龙",
          "type": "白",
          "text": "大力之神也不过如此。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "你看这武状元，竟将千斤搬起，其力甚大，帅印挂他无疑了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣启万岁：昔年先皇命众家国公赌力，可也是这对狮子，有端膝的，也有抱过 胸的，惟有秦叔宝，双手举过头顶。哎呀，那才算得大力哪。"
        },
        {
          "character": "杜如晦",
          "type": "白",
          "text": "臣启万岁：今日比武夺帅，必须命各家子弟，俱要搬它一般才是。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "依卿所奏。 老皇兄，替孤传旨。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣领旨。 哎呀，我看各家子弟，俱皆年小，倘若是拿不起这个狮子来，这颗帅印岂不教 詹虎挂了吗？他要是挂了帅，我这群孩子都要吃他的亏，这可怎么好，这可怎 么好？"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "吓公公，那詹虎以力夸强，实为匹夫。孙儿要双手举那狮子，与他见识见识。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "怎么着，你要两只手把狮子举起来？"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "孙儿怎敢谬言。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好吓，随我上殿报名吓。"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "小臣罗章，要双手举那狮子。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "呕，你能双手举那狮子？"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "只怕未必。"
        },
        {
          "character": "杜如晦",
          "type": "白",
          "text": "陛下且由他们试试看。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "叫他们试试瞧。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "你且试试看。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "下殿举来。"
        },
        {
          "character": "罗章",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗章举狮子。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "可以啦，搁下罢，这就比他强的多啦。万岁可曾看见罗章？"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "果然罗章英勇，堪称盖世，帅印是他挂定了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "是他挂定了。"
        },
        {
          "character": "杜如晦",
          "type": "白",
          "text": "还有先锋、左右副将，也要试取，方好受职。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "阶下子弟，大家都来搬一搬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟松、尉迟江、谢寿各举。"
        },
        {
          "character": "程通",
          "type": "白",
          "text": "待我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程通举，倒。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "孩子，你才多们大，就要搬个狮子，你也不怕狮子咬了你的手。"
        },
        {
          "character": "程通",
          "type": "白",
          "text": "还闪了我的腰了。"
