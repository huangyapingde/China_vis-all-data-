        {
          "character": "秦英",
          "type": "唱",
          "text": "明日里全凭俺施展本领， 挂帅印征西凉好救严亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦英下。"
        }
      ]
    },
    {
