    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "唐太宗",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监、四小太监引唐太宗同上。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "一年间四时新春光尤盛， 和风暖紫燕飞花笑迎人。 忽报道小秦英力毙国亲。 打死了詹太师目无君亲。 孤一怒要将他枭首抵命， 免死牌岂保得逆罪谗臣？ 龙书案发催牌内侍执领， 到法场斩秦英悬首都门。"
        },
        {
          "character": "整日间卷花帘开怀畅饮、依仗他祖上功官高极品、大太监甲",
          "type": "唱",
          "text": "金殿上领圣命忙下龙廷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "娃们不要啰唣，待老夫上殿面奏吓。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "你持着君命牌所为何情？"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "老国公回朝来了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "回朝来了。我且问你，手持金牌，往哪里公干哪？"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "奉了万岁旨意，催斩秦英的。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "怎么催斩秦英的吗？"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你与我这么一候。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "此乃圣命，咱家不敢挨迟。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "怎么着，你竟敢不做吗？哼哼，你此番若出了朝门，你可知我老程性儿，不用 说是你，就是当今万岁，也不好退却我罢。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "老国公，不必动怒。咱家暂候一时就是。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好哇，你与我暂候一时。 哎呀，事在极急，待我上殿面奏。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "鲁国公回朝。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣咬金见驾，吾皇万岁。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄回朝来了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "回朝来了。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "快快扶起老皇兄。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "内侍赐金墩与老皇兄坐。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣谢坐。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄保定皇儿征伐西凉，怎么样了？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "不想苏海十分猖狂，元帅被伤，众将难以取胜，是老臣单人独骑，杀出重围， 回朝搬兵取救。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "唔，老皇兄是回朝搬兵么？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "朕的皇儿在彼可好？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣临行之时，那驸马秦山对臣言讲，说道程叔父此番回朝搬兵，到家中看看 我儿好与不好。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "原来老皇兄耳沉了，朕问的是太子，你听到哪里去了？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我说的是驸马秦山，问他儿子秦英，在家可好。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "不要提起，倚仗他血性之勇，目无法纪，在渡仙桥竟将国丈詹昆伦打死，朕已 将他绑赴市曹枭首去了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好吓。有其父必有其子，秦英在家不守国法，那秦山在外亦益发的不受王章啦。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "吓，那秦山在外怎么不受王章？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "驸马所作之事，一时难以对我主言讲。万岁若问，请离宝位，待老臣细细奏知。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "如此寡人下位来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好吓，请下位来。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "何必寡人下位，皇兄且讲。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "你下来的好。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "老国公，你莫非是疯啦？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我疯啦，我今天疯啦。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "金殿上疯了旧时性情， 且把事儿评一评。 眼前多败类你全不醒， 要奏的事儿不忍云。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄有话好好说来，何必如此。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣一上金殿，万岁就知道问太子在外可好，不知征夫疆场辛苦。想那秦英乃 是驸马秦山之子，现今秦山保定太子储君，征伐西凉，被苏海困在锁阳城，万 岁若是将秦英斩首，那驸马秦山闻知，必道万岁忘了他父亲的功勋，全无君臣 之义，他也就把太子给杀啦。即同西凉合兵一处，杀到长安，那时节，我看你 这九五的宝位，是坐得稳，是坐不稳。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "君既不分忠与佞， 他还管什么臣不臣。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "非朕故要杀他，奈其子忒无法纪，若不将他抵命，则詹妃之父，何以瞑目？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "想那詹妃，不过桀之妺嬉、纣之妲己，败国亡家，尽出此辈。万岁传旨斩啦， 先将奸妃斩首便罢，以清君侧。如若不然，先把老臣斩首，也免得留于世上， 看这桀纣的故事。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "此女并无过犯，不过为他父亲死在秦英之手，不得不然耳。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "想那国丈詹昆伦，乃是奸险的小人，把女儿献上，希图固宠，前者也曾受过苏 海的厚贿，许做内外细作，秦英今日斩奸削佞，正是为君为国。万岁反听细人 之言，将秦英斩首，柴绍祭鼎，把那些老臣俱已削职为民，这还成什么朝政？"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "倘若是苏海乘虚进， 要想太平万不能。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "朕如酒醉方才醒， 险些误我锦乾坤。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄，朕已知过，你且放了手，待朕出旨赦却他们便了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "可是全赦了他们啦？"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "全都赦了他们。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好哇，这才是有道的明君哪。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "内侍取龙票过来，待朕出旨。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "提笔忙出极急赦， 法场赦回小秦英。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "还有杜、房二位。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "杜、房仍旧官原品，"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "柴绍？"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "柴绍依然老皇亲。 三道赦旨是君命， 谁敢枉行灭满门。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "老臣上得金殿如此逼勒我主，罪大恶极，当问何罪，请我主说罢。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄年将百岁，尚为国家，戴月披星，诸事辛劳，寡人奖之不及，还有何罪 可问？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "些须罪过概不问， 咬金是孤的有功臣。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "拿去看来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "这、老臣眼力不济，求万岁念这么一遍。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "哼，听了。 自者秦英误毙詹昆伦身死，罪依抵偿，孤念驸马秦山远征边外，朕宽恩秦英， 赦其死罪。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "万岁赦了死罪，难道说还有什么活罪吗？"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "严加教诲，效力赎罪。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "这就是了。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "杜如晦、房玄龄、柴绍等仍复原官，概行免议。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "好。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "程咬金。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "待老臣跪下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金跪。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "虽有勒君之愆，实有为国之忠。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "捆打四十御棍罢。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "功过相抵，皇兄平身。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金起。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "速拿此旨，法场前去晓谕。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "大太监甲",
          "type": "念",
          "text": "金殿领圣旨，赦回小秦英。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监甲下。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄，快把西凉之事奏来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "容奏。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "刻下兵困粮草尽， 早发大兵莫稍停。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "竟有这等事么，朕想朝中无人可救西凉之危，只有新科武状元智勇过人，就命 他为三路元帅，即日前往，方可解此重围。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "请问万岁，新科状元是谁？"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "就是国丈詹昆伦次子名叫詹虎。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "臣启奏万岁：想那久战沙场的名将，尚且不能取胜，何况他是个新进的武魁。 臣闻将生将种，虎养虎儿，万岁何不在勋爵之中择选小辈，挂帅前往，方可救 急哇。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "无奈元勋等，有随太子征西去的，也有各处镇守的，其馀尽皆少年子弟，何能 济事？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "万岁不要管他们年大年小，万岁传旨，命各府小将，明日五鼓，齐聚金阶，比 试挂帅。有才能的可以挂帅，次者的为偏将，少不得也有能人啦。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄其言甚善。 内侍，取金牌一面，去到各家公府，选齐小辈，明朝齐集金阶，比试挂帅，不 得有误。"
        },
        {
          "character": "大太监乙",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监乙下。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "老皇兄鞍马劳顿，请回府第，明日同看比武便了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "一声金牌出禁门，"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "各府小将敢不遵。"
        },
        {
          "character": "唐太宗",
          "type": "唱",
          "text": "若能选得元戎定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐太宗下。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "定是马到把功成。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎呀，好险哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。"
        }
      ]
    },
    {
