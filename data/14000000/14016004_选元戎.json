      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引詹虎同上。"
        },
        {
          "character": "詹虎",
          "type": "念",
          "text": "量小非君子，无毒不丈夫。"
        },
        {
          "character": "詹虎",
          "type": "白",
          "text": "某二国舅詹虎，蒙圣恩点我武魁，可恨秦英，将我父打死，圣上正要将他典刑， 又被程咬金保奏。今日比武，俺必须努力当先，倘若挂了帅印，好报父仇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "詹龙内咳。"
        },
        {
          "character": "詹龙",
          "type": "白",
          "text": "话言未了。兄长来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "詹龙上。"
        },
        {
          "character": "詹龙",
          "type": "念",
          "text": "只恨打父仇，何日得报明。"
        },
        {
          "character": "詹虎",
          "type": "白",
          "text": "兄长。"
        },
        {
          "character": "詹龙",
          "type": "白",
          "text": "贤弟。可恨秦英，将父打死，万岁正要典刑，又被程咬金保奏下来，又定了比 武挂帅之策，稍时比武，贤弟必须努力当先，倘若挂了帅印，好报父仇。"
        },
        {
          "character": "詹虎",
          "type": "白",
          "text": "兄长但放宽心，谅那些乳臭小子，怎比得小弟的武艺，此番挂了帅，他等作步 下先锋，慢慢摆布他们。"
        },
        {
          "character": "詹龙",
