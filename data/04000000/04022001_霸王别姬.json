{
  "script_id": "04022001",
  "title": "霸王别姬",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "虞姬",
      "hangdang": "旦"
    },
    {
      "name": "项羽",
      "hangdang": "净"
    },
    {
      "name": "韩信",
      "hangdang": "老生"
    },
    {
      "name": "虞子期",
      "hangdang": "小生"
    }
  ],
  "plot": "西楚霸王项羽有勇无谋，刚愎自恃，听信汉军韩信派来诈降的李左车之言，不顾众将与爱妃虞姬的劝阻，起\n兵伐汉；率大军直入九里山，中韩信诱兵之计，被困垓下。项羽知大势已去，抚骓长叹；虞姬拔剑作舞。时\n汉军攻急，虞姬恐误其行，持剑自刎，以绝项羽恋念。项羽遂领兵出阵，战败，自刎乌江。楚终为汉所灭。",
  "notes": "整理本是依据梅兰芳先生的最近演出本，由许源来先生与本院（中国戏曲研究院）许姬传、何异旭共同整理\n的。最后，并经梅兰芳先生仔细校订。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四汉军、曹参、英布、孔熙、陈贺、彭越、王陵、周勃、樊哙、陈平引韩信同上。"
        },
        {
          "character": "韩信",
          "type": "引子",
          "text": "运筹帷幄，统雄师，一片丹心将汉扶；九里山前十埋伏，决胜策，神出鬼没。"
        },
        {
          "character": "韩信",
          "type": "念",
          "text": "登台拜帅掌兵符，胸中智谋胜孙吴。准备一战灭西楚，山河万里壮宏图。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "本帅，韩信。奉主之命，统领人马，共灭西楚。想我军自出褒中以来，五年之 间，与项王亲临七十余战；劳师动众，千辛万苦。今项王势孤力弱，胜败就在 此一举。 陈平听令。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "带领人马，断项王归路，不得有误。"
        },
        {
          "character": "陈平",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈平下。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "樊哙听令。"
        },
        {
          "character": "樊哙",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "执掌军中大纛旗，不得有误。"
        },
        {
          "character": "樊哙",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "众将官。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "兵发九里山。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小泣颜回〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四御林军、四小太监、二大太监引项羽同上。"
        },
        {
          "character": "项羽",
          "type": "粉蝶儿",
          "text": "大英雄，盖世无敌。 灭嬴秦，复楚地，争战华夷。"
        },
        {
          "character": "项羽",
          "type": "念",
          "text": "嬴秦无道动戎机，吞并六国又分离。项刘鸿沟曾割地，汉占东来楚霸西。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "孤，霸王项羽。孤与刘邦鸿沟割地，讲和罢兵，送回太公、吕氏；不想他反覆 背盟，又来寻战。孤命探马前去打探，未见回报。"
        },
        {
          "character": "项伯",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "项伯上。"
        },
        {
          "character": "项伯",
          "type": "西皮摇板",
          "text": "左车背汉来降顺， 把本奏与圣明君。"
        },
        {
          "character": "项伯",
          "type": "白",
          "text": "臣，项伯见驾，大王千岁！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "项伯",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "上殿有何本奏？"
        },
        {
          "character": "项伯",
          "type": "白",
          "text": "启大王：今有赵国谋臣李左车背汉来降，求臣引见，现在殿外候旨。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "哦！孤此时正少谋士，李左车来降，孤之幸也。只恐他是诈降。 宣他上殿，待孤用言语探其真假。"
        },
        {
          "character": "项伯",
          "type": "白",
          "text": "领旨。 大王有旨，李左车上殿。"
        },
        {
          "character": "李左车",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李左车上。"
        },
        {
          "character": "李左车",
          "type": "念",
          "text": "大胆闯虎穴，引龙入沙滩。"
        },
        {
          "character": "李左车",
          "type": "白",
          "text": "难臣李左车见驾，大王千岁！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "李左车",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "李左车。"
        },
        {
          "character": "李左车",
          "type": "白",
          "text": "大王。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "闻你在齐为韩信做幕客，如今忽然背彼来降，莫非行诈？"
        },
        {
          "character": "李左车",
          "type": "白",
          "text": "啊，大王！臣前辅赵之时，赵王不用臣言，反命陈馀与韩信交战，被韩信斩陈 馀于泜水。臣无棲身之处，遂投韩信帐下。那韩信受封齐王以后，致生骄傲之 心，凡有策划，皆自决断。在帐下者，言不听，计不从；逃去者十之八九。今 闻大王将与刘邦交战，愿投麾下，以效犬马之劳。焉敢行诈？"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "哼！两国交兵之际，诈降甚多；你今此来，定是探孤虚实！"
        },
        {
          "character": "李左车",
          "type": "白",
          "text": "啊，大王此言差矣。想臣乃一谋士，不能披坚执锐，冲锋破敌，不过随在左右， 与大王策划耳；听与不听，尽在大王。楚营虚实，韩信时有探报，不待臣诈 降而后知之。大王若是见疑，是臣误投其主，为不明也；飘荡无依，为不智也。 莫若死在大王之前，以明心迹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李左车欲碰死。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "项羽",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "孤乃相戏耳。久闻广武先生英名，当时欲往赵国约来，为孤划策；今日果然实 心归孤，孤当朝夕与先生商讨破汉之计。"
        },
        {
          "character": "李左车",
          "type": "白",
          "text": "大王留臣，臣当为陛下效死。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "真乃社稷之臣也。"
        },
        {
          "character": "虞子期、周兰",
          "type": "内同白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虞子期、周兰同上。"
        },
        {
          "character": "虞子期",
          "type": "西皮散板",
          "text": "会稽人马离吴郡，"
        },
        {
          "character": "周兰",
          "type": "西皮散板",
          "text": "抗拒王命是周殷。"
        },
        {
          "character": "虞子期、周兰",
          "type": "同白",
          "text": "臣等见驾，大王千岁！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "二卿平身。"
        },
        {
          "character": "虞子期、周兰",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "有何本奏？"
        },
        {
          "character": "周兰",
          "type": "白",
          "text": "臣启大王：前命李宁往会稽搬兵，太守一见檄文，即日起兵前来助战。又往舒、 六调取周殷⑴，怎奈周殷抗拒王命，按兵不动。请大王定夺。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "啊！大胆周殷抗拒孤命，孤誓先灭此贼，然后破汉。"
        },
        {
          "character": "项伯",
          "type": "白",
          "text": "且慢！臣启大王：想那周殷乃癣疥之疾，刘邦乃心腹大患。还请大王三思。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "容孤思之。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟离昧上。"
        },
        {
          "character": "钟离昧",
          "type": "白",
          "text": "启奏大王：韩信贴下榜文，辱骂大王；细作抄来，大王请看。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "呈上来，待孤观看："
        },
        {
          "character": "项羽",
          "type": "念",
          "text": "“倡议会诸侯，先将无道收。人心咸背楚，天意属炎刘。 指日亡垓下，临时丧沛楼。剑光生烈焰，馘斩项王头。”"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "哇呀呀！"
        },
        {
          "character": "项羽",
          "type": "西皮散板",
          "text": "咬定牙关骂韩信， 拿住贼子万刀分。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "众卿，替孤传旨：即日兴兵破汉。"
        },
        {
          "character": "周兰",
          "type": "白",
          "text": "且慢！臣启大王：那韩信恐陛下按兵不动，故尔出此狂言，以激大王之怒。大 王若是出兵，必中韩信诱兵之计。大王三思。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "卿家，想孤纵横天下，未尝一日受辱；今被匹夫辱骂，若按兵不动，岂不被诸 侯耻笑？"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "臣启大王：汉兵势众，又兼韩信多谋。依臣愚见，只可深沟高垒，暂不出兵； 候彼军疲乏，陛下以逸待劳，鼓兵而西，一战可胜。使韩信无以用其谋，张良 无以决其策；荥阳，成皋唾手可得也。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "李左车",
          "type": "白",
          "text": "啊，大王，如不亲征，汉兵必攻彭城；倘不能守，则大王无家可归矣。莫若领 兵亲战，胜则汉兵可破；不胜则可退归彭城。此乃进可以战，退可以守之策。 大王舍此良谋，而欲株守，不亦误乎！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "嗯！先生之言，甚合孤意。 众卿传旨：即日兴兵破汉！"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "还请大王三思！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "孤心已定，不必多奏。 正是："
        },
        {
          "character": "项羽",
          "type": "念",
          "text": "今得先生必制胜，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "即日兴兵破汉军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "且住！我看李左车此来，有些诈意；但是大王发兵之心已定，不能阻止，如何 是好！有了！不免去到后宫与娘娘商议商议，或能阻大王出兵，也未可知。正 是："
        },
        {
          "character": "虞子期",
          "type": "念",
          "text": "金殿不能回上意，再请娘娘劝一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虞子期下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。八宫女持符节、掌扇引虞姬同上。"
        },
        {
          "character": "虞姬",
          "type": "引子",
          "text": "明灭蟾光，金风里，鼓角凄凉。"
        },
        {
          "character": "虞姬",
          "type": "念",
          "text": "忆自从征入战场，不知历尽几星霜。何年得遂还乡愿，兵气销为日月光。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "妾身西楚霸王帐下虞姬。生长深闺，幼娴书剑；自从随定大王，东征西战，艰 难辛苦。不知何日方得太平也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虞子期上。"
        },
        {
          "character": "虞子期",
          "type": "念",
          "text": "忙将军情事，报与娘娘知。"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "来此已是后宫，待我叩环。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "何人叩环？"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "虞子期请见。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "启娘娘：虞子期求见。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "宣他进宫。"
        },
        {
          "character": "宫女",
          "type": "白",
          "text": "是。 虞子期进宫。"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "领旨。 臣，虞子期见驾，娘娘千岁！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "进宫何事？"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "这……耳目甚众。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虞姬向宫女。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "尔等回避。"
        },
        {
          "character": "八宫女",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八宫女自两边分下。"
        },
        {
          "character": "八宫女",
          "type": "stage",
          "text": "虞姬"
        },
        {
          "character": "八宫女",
          "type": "白",
          "text": "有何机密大事？"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "臣启娘娘：今有刘邦、韩信等，统领大兵前来讨战；我军众寡不敌，正宜深沟 高垒，以逸待劳。奈大王听信降臣李左军之言，传旨明日发兵，只恐大王此去 中了他人之计。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "那群臣何不谏阻？"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "群臣屡谏不听。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "这便怎么处？"
        },
        {
          "character": "虞子期",
          "type": "白",
          "text": "欲请娘娘再劝大王，千万不可出兵。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "如此，卿家暂退。大王回宫时节，待我相劝一番就是。"
        },
        {
