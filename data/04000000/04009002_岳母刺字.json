{
  "script_id": "04009002",
  "title": "岳母刺字",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "岳母",
      "hangdang": "老旦"
    },
    {
      "name": "岳飞",
      "hangdang": "老生"
    },
    {
      "name": "李氏",
      "hangdang": "旦"
    }
  ],
  "plot": "原在前线抗金的岳飞，当宗泽元帅死后，不满意朝廷派来接任的杜充，乃私自回家。结果岳母将他训斥一顿，\n要他回营继续杀敌，并在岳飞背上刺了“精忠报国”四字，以坚定岳飞的心志。岳飞后来终于成了我国历\n史上著名的民族英雄。",
  "notes": "《岳母刺字》是一个流传很广的民间故事。岳飞的母亲是我国古代著名的一位英雄母亲。\n京剧中，这个戏的原本有好几种，情节并不一样，但均不流行，内容都很粗糙。这次整理的本子，基本上是\n根据《交印刺字》的情节，并参考了河北梆子和川戏《岳母刺字》而重新改编的。改编本对人物的描写，除\n了在剧本的文字上加工以外，并企图尽量地选用“老旦”一行原来的各种唱法，来更好地帮助刻划岳母。\n本剧由中国京剧团演员李金泉，和本院（中国戏曲研究院）编辑处范钧宏、吴少岳集体改编，并由范、吴同\n志执笔写定的。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "岳飞上。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "满怀忧愤出营门， 恨男儿有志莫能伸！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "俺，岳飞。只因金兵犯境，是俺投效宗泽元帅帐下为将，官居统制。辛蒙元帅 见重，言听计从，方期收复河山，直捣黄龙，不幸元帅为国忧愤，竟自呕血而 死！元帅死后，朝廷派杜充接任，不想此人刚愎自用，不纳忠言，是俺有志难 酬，中心悒郁！想大丈夫既不能标名于凌烟阁上，倒不如归于林下侍奉老母， 也落得个孝亲之名于后世也。"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "心中只把杜充恨， 全无忠义报国心。 宗元帅遗命成泡影！ 倒不如回家侍奉娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "岳母上。"
        },
        {
          "character": "岳母",
          "type": "引子",
          "text": "两鬓苍然，愿得见，光复江山。"
        },
        {
          "character": "岳母",
          "type": "念",
          "text": "忆昔洪涛灌汤阴，夫君不幸命捐生。有儿报国全忠孝，未负劬劳一片心。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "老身姚氏。世居汤阴，只因当年洪水为灾，夫君丧命，我与岳飞孩儿，幸得不 死。是我孤灯独守，将他教养成人，又蒙周侗老师，传授兵法武艺。且喜他文 武兼全，今在宗泽元帅帐下为将，抗金杀敌，屡建奇功，甚得宗老元帅见重。 吾儿壮志得酬好不教人欣喜。正是："
        },
        {
          "character": "岳母",
          "type": "念",
          "text": "有儿能报国，教子喜成名！"
        },
        {
          "character": "岳母",
          "type": "二黄慢板",
          "text": "想当年守孤灯将儿教训， 幸喜他怀忠义奋志鹏程。 但愿他灭贼寇山河重整， 迎二圣转还朝共享太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李氏奉茶上。"
        },
        {
          "character": "李氏",
          "type": "二黄摇板",
          "text": "我夫君为国家勤劳效命， 为妻子奉高堂定省晨昏。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "婆婆请茶！"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "媳妇告坐。啊母亲，这几日未得鹏举家报，不知是何缘故？"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "想是军中事忙，无暇修书。媳妇不必惦念。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "是。啊母亲，金兵如此猖獗，不知何日才得太平？"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "金兵虽然猖獗，且喜宗老元帅执掌兵权，将士用命，鹏举儿随营参赞，言听计 从，光复河山，为期想已不远。有日我儿奏凯回程，阖家团圆，这天伦之乐， 我却不能轻轻地放过去哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母微笑。"
        },
        {
          "character": "岳母",
          "type": "二黄摇板",
          "text": "为娘我虽然是风烛晚景， 我还要听凯歌乐享太平。"
        },
        {
          "character": "岳飞",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞上。"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "宗元帅为国家呕血丧命， 又谁知朝廷中选用非人。 来至再自家门忙下鞍镫，"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母惊喜。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "我儿回来了！一路劳顿。 啊媳妇，快快与你丈夫看座。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "谢母亲！ 娘子！"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "官人。"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "展愁眉放笑脸问母安宁。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "母亲近日身体安否？"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "为娘倒还康健，儿啊，你可好啊！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "孩儿身体甚好，多劳母亲挂念。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "啊，儿啊，你是顺道至此，还是特地回家呢？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "这——儿是特地回家。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "此时军务甚忙，特地回家为了何事？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "只因孩儿久离膝下，思念母亲，故而回家探望。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "嗯……昔日大禹治水，三过其门而不入，儿既以身许国，就该公而忘私，为何 反以为娘为念呢？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞起立。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "孩儿不肖，母亲恕罪！"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿且坐下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞落座。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊，你既从大营而来，不知此时金兵情势如何？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "两河义师到处相应，我军严阵以待，金兵不敢渡河。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "哦，金兵不敢渡河！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "啊，媳妇，方才为娘言道，光复河山为期想已不远，你看如何！"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "婆婆所见不差。"
        },
        {
          "character": "岳母",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "宗老元帅忠心为国，实实令人可敬。 儿啊，你回得营去，在宗老元帅麾下，必须要尽心尽力，赴汤蹈火也不可退后 哟！"
        },
        {
          "character": "岳母",
          "type": "二黄摇板",
          "text": "有忠良做砥柱令人欢庆， 喜的是御金兵天下一心。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "老娘亲他那里满怀高兴， 又谁知军营中主帅非人. 想起了宗元帅心酸难忍！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖行弦〗。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊，为娘提起宗老元帅，你为何暗中落泪？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "这个——"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "有什么心事？就该对为娘说明才是。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "是呀，相公有什么心事，就该对母亲说明才是。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "到此时我只得把话说明。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "哎呀母亲哪！那宗老元帅为国忧愤，染病在床，临终之时，三呼“渡河”，呕 血而死！"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "哦！宗老元帅他，他……死了么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母长叹。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "岳母",
          "type": "念",
          "text": "出师未捷身先死，长使英雄……唉，泪满襟啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母起立。"
        },
        {
          "character": "岳母",
          "type": "二黄散板",
          "text": "宗元帅为国家忧愤丧命， 不由我年迈人珠泪双淋！ 似这等忠良将令人钦敬， 匡社稷保疆土何人继承？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母落座。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊，宗老元帅身死，不知朝廷派何人继任？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "朝廷已派杜充接任。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "那杜充元帅为人如何？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "那杜充刚愎自用，无智无才，孩儿屡次请命杀敌，他不但不允，反将孩儿置于 闲散之地。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊，想是他初到任所，人地生疏，对儿有不周之处，也是有的。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "哎呀母亲哪！想孩儿幼读兵书，精通武艺，指望建功立业，报国尽忠，不想如 今所事非人，有志难酬。为此有意暂归林下，侍奉母亲，已尽为子之道。孩儿 不告而行，还望母亲恕罪。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "哦！儿要回家奉母行孝么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "我儿你此言差矣！自古道君辱臣死，亲玷子亡。如今二圣蒙尘，国家危急，儿 既已出仕朝廷，就该舍命勤王，以身报国。今乃以杜充一人之故，灰心堕志， 踌躇不前，难道这就是你周老恩师的训诲？宗老元帅的遗言？忠孝本无二道， 你既不能尽忠，却又怎的尽孝？儿啊，你，你，你辜负为娘一片苦心哪！"
        },
        {
          "character": "岳母",
          "type": "二黄原板",
          "text": "鹏举儿听为娘把话来论， 休忘了为娘我教养苦心。 儿应当秉忠心为国效命， 莫等闲辜负了年少光阴。 那杜充虽无知儿且耐性， 常言道大丈夫权衡轻重、能屈能伸，方不愧有为之人。"
        },
        {
          "character": "岳飞",
          "type": "二黄原板",
          "text": "儿指望捣黄龙开怀痛饮， 又谁知那杜充一意孤行。 儿空怀报国志无法效命， 倒不如侍奉娘亲终老山林。"
        },
        {
          "character": "岳母",
          "type": "二黄原板",
          "text": "儿说道志难酬无从效命， 岂不知小不忍大谋难成。 既然是有志向黄龙痛饮， 怎能够为一人你堕志灰心，全不想一发千钧！ 我的儿要分明国仇私恨，"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": "岳母",
          "type": "二黄散板",
          "text": "公与私国与家儿要分清。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞起立。"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "老娘亲严教训大义凛凛， 怎能够为一人堕志灰心。 从遗命遵母训我心志拿定，"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "娘子！"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "奉高堂教儿女你要多多费心。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "相公啊！"
        },
        {
          "character": "李氏",
          "type": "二黄散板",
          "text": "尊相公免叮咛宽心放定， 家中事有为妻一力担承。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "好啊！"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "娘子贤德实可敬， 奉亲教子你担承。 辞别老母出家门——"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "我儿转来！"
        },
        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "母亲有话请叮咛。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "母亲还有何言语嘱咐孩儿？"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊，急急忙忙意欲何往？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "孩儿听得母亲一番教训，深知归家非是，故而急想回营。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿既已知过，又何必如此性急，为娘还有言语嘱咐。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "母亲请讲。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "我儿此去，必多险阻，如今刀兵四起，心志若不坚如铁石，焉能为国尽忠，名 标青史。为娘风烛残年，焉能跟儿一世，因此有意在儿背上刺字，使儿永记娘 言，这一生一世怀报国之心，为娘纵死，也含笑九泉了。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "孩儿情愿受教。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "好！ 媳妇看笔砚伺候。"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "岳母",
          "type": "西皮导板",
          "text": "叫鹏举站草堂听娘言讲，"
        },
        {
          "character": "岳母",
          "type": "西皮慢板",
          "text": "好男儿理应当天下名扬。 想为娘二十载教儿成长， 惟望儿怀大志扶保家邦。 逢乱世须忠臣代有名将， 大丈夫立功业来日方长。 怕的是我的儿难坚志向， 刺四字作垂训永记在心旁。 叫媳妇取笔砚，儿宽衣跪在堂上，"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "是"
        },
        {
          "character": "岳母",
          "type": "西皮原板",
          "text": "提羊毫抚儿背仔细端详。 厉节操秉精忠作人榜样， 勤王命誓报国方为栋梁。 我这里把四字书写停当，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母取金簪，手震，迟疑。"
        },
        {
          "character": "岳母",
          "type": "西皮摇板",
          "text": "持金簪不由我手颤心慌。 血肉躯原本是娘生娘养， 为娘的怎忍得将儿的肤发伤！ 无奈何咬牙关把字刺上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母刺字，岳飞身躯微震。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊，莫非刺重了么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "这——母亲还未曾刺下，怎说重了，母亲不必忧虑，就请速速赐训。"
        },
        {
          "character": "岳母",
          "type": "西皮快板",
          "text": "含悲忍泪狠心肠。 一笔一划刺背上， 刺在儿身娘心伤。 我的儿忍痛无话讲， 点点血墨染衣裳。 刺罢四字我的心神恍……"
        },
        {
          "character": "李氏",
          "type": "白",
          "text": "母亲，仔细了！"
        },
        {
          "character": "岳母",
          "type": "西皮摇板",
          "text": "辉煌四字语重心长"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "母亲为儿刺字，多有劳累。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "我儿你也多受痛楚了。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "请问母亲刺训何字？"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "精忠报国。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "哦，精忠报国！"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "谢母亲！"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "母亲刺训在堂前，针针字字记心间，从今杀敌无他念，精忠报国标凌烟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞起立。"
        },
        {
          "character": "岳飞",
          "type": "西皮快板",
          "text": "母亲教训记心上， 男儿立志在疆场。 誓把那金人俱扫荡， 我定要迎回二圣重整家邦。 奏凯归，人敬仰， 天下承平乐安康。 精忠报国永不忘， 落得个凌烟阁上万载名扬！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞拜岳母。"
        },
        {
          "character": "岳母",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "岳母",
          "type": "西皮摇板",
          "text": "我的儿说此话真有志量， 好男儿当奋勉为国争光。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "儿啊，今日天色已晚，阖家团聚一宵，明日再回大营。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "媳妇，后堂安排酒饭，阖家欢叙。正是："
        },
        {
          "character": "岳母",
          "type": "念",
          "text": "今日刺字在草堂，"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "精忠报国记心旁。"
        },
        {
          "character": "李氏",
          "type": "念",
          "text": "刻骨铭心遵母训，"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "不灭金人不还乡！"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "好个“不灭金人不还乡”！鹏举，媳妇，来呀！"
        },
        {
          "character": "岳母",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母、岳飞、李氏同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}