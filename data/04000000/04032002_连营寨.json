{
  "script_id": "04032002",
  "title": "连营寨",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "陆逊",
      "hangdang": "小生"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    }
  ],
  "plot": "三国时，刘备为报关羽、张飞之仇，大举伐吴。战争初期，屡获胜利，东吴震惊。孙权遣诸葛瑾求和，刘备\n不允，誓必灭吴。孙权遂纳阚泽之荐，擢用陆逊为帅，冀挽危局。刘备轻视陆逊年少，不加戒备。复因天气\n炎热，移兵茂林深处，扎下七百里连营。陆逊乘机使用火攻，蜀军伤亡惨重，刘备几不能免。幸诸葛亮差赵\n云来救，始得突围而出，退走白帝城，悔恨而终。",
  "notes": "这个剧本是由中国京剧团演员李宗义、李洪春、徐和才与本院（中国戏曲研究院）编辑处祁野耘共同整理的。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士押范疆、张达引诸葛瑾同上。"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "领君命去求和兼程而走， 到蜀营陈利害化解冤仇。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "下官，诸葛瑾，只因甘宁阵亡，孙桓被困，今奉吴侯之命，押解范疆、张达与 张飞的首级，前往蜀营，求和罢兵。 左右！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "但愿得两下里罢兵息斗， 也免得我吴侯终日里担忧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、关兴、张苞引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "孙仲谋与孤王结下仇寇， 杀得他兵将们尸积山丘。 还望我二贤弟暗中保佑， 扫平了东吴贼方肯罢休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马良上。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "启禀主公：今有东吴诸葛瑾押解范疆、张达等，前来求见。到蜀营陈利害化解 冤仇。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宣他进帐。"
        },
        {
          "character": "马良",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马良下。"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "全凭三寸舌，打动一片心。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "皇叔在上，瑾大礼参拜。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生少礼，一旁坐下。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "皇叔在此，焉有外臣的座位。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "到此是客，有话叙谈，焉有不坐之理。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "子瑜到此何事？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "臣弟久事陛下，故不避斧钺，前来奏荆州之事。前者二千岁在荆州时，吴侯屡 次求亲，二千岁不允。后来二千岁取襄阳，那曹操屡次致书吴侯，使袭荆州， 吴侯本不允许，不想吕蒙与二千岁不睦，擅自兴兵，铸成大错。此乃吕蒙之罪， 非吴侯之过也。今吕蒙已死，冤仇已息，吴侯特命外臣押解范疆、张达，并 三千岁的首级前来，求和罢兵，情愿退还荆州，送归夫人，两下永结和好，同 心破曹。伏乞圣裁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "嗯！你东吴正在危机，敢是命你前来巧言顺说么？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "非臣巧言，容以轻重大小事论之：如今汉室已被曹逆篡夺，陛下乃大汉皇叔， 不图兴汉室，回复山河，置曹魏而不问，反欲伐吴，是舍大义而就小义也。中 原乃海内之地，两都皆创业之方，陛下不取，只为一荆州，屡次兴兵，何失其 重而取其轻也！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "住口！你东吴不仁，害孤二弟，此仇不共戴天，教孤罢兵么，除死方休。若不 看在我家丞相之面，先斩汝头。回去晓谕孙权，孤早晚踏平东吴，教他洗颈待 戮。去罢！"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "告退。"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "用手捧尽湘江水，难洗今朝满面羞。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "关兴、张苞！"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吩咐大小三军，俱穿孝服，摆设灵牌，待为伯亲自极点。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "刘备",
          "type": "哭",
          "text": "孤那好兄弟呀……"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "想当年结桃园对天发咒， 愿同年同日夜共同罢休。 到如今一旦间死别分手， 撇下孤一人好没来由！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手绑糜芳、傅士仁、范疆、张达同上。"
        },
        {
          "character": "范疆",
          "type": "西皮摇板",
          "text": "你做此事悔不悔？"
        },
        {
          "character": "张达",
          "type": "西皮摇板",
          "text": "谁教你去刺张飞。"
        },
        {
          "character": "傅士仁",
          "type": "西皮摇板",
          "text": "平地你把风波起，"
        },
        {
          "character": "糜芳",
          "type": "西皮摇板",
          "text": "事到头来埋怨谁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖哭皇天〗。关兴、张苞同上。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "有请皇伯。"
        },
        {
          "character": "刘备",
          "type": "内西皮导板",
          "text": "白盔白甲白旗号，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、四太监引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "二弟呀……三弟呀……啊啊啊……"
        },
        {
          "character": "刘备",
          "type": "回龙",
          "text": "孤的好兄弟呀！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "满营将官哭嚎啕。 孤王兴兵把仇报， 扫平了东吴恨方消。 请过了灵牌王怀抱——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备抱关羽灵牌，泣。"
        },
        {
          "character": "刘备",
          "type": "反西皮二六板",
          "text": "点点珠泪往下抛。 当年桃园结义好， 胜似一母共同胞。 不幸徐州失散了， 万般无奈暂且归曹。 那曹操待你的情义好， 上马金下马银也曾赠过你红袍。 美女十名你不要， 挂印封金辞奸曹。 匹马单刀保皇嫂， 过五关、斩六将、擂鼓三通把蔡阳的首级枭，可算得盖世的英豪。 单刀赴会天下晓， 英雄美名万古标。 恼恨东吴行奸巧， 害孤的二弟归天曹。 孤王兴兵把仇报， 扫灭了东吴恨方消。 还望二弟神威保，神威……保，"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "孤的好兄弟呀！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "不杀孙权不还朝。"
        },
        {
          "character": "关兴",
          "type": "西皮摇板",
          "text": "伯父不必珠泪掉， 拿住孙权剐万刀。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "非是为伯珠泪掉， 孤与你父生死交。 哭罢了二弟把三弟叫， 翼德呀……桓侯啊……啊啊啊……"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "我那豹头环眼的好兄弟呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备抱张飞灵牌，泣。"
        },
        {
          "character": "刘备",
          "type": "反西皮二六板",
          "text": "叫声三弟听根苗： 当年同把董卓讨， 弟兄们阵前显英豪。 虎牢关曾把那吕布的发冠挑， 长坂坡前喝断了灞桥。 夜战马超胆气好， 义释严颜颇有略韬。 可恨那范疆、张达两个贼强盗， 害孤的二弟二贼脱逃。 愚兄与你把仇报， 杀得孙权魂魄消。 情愿罢兵修降表， 同心合力灭奸曹。 锦绣江山孤不要， 一心与你把恨消。 哭哑了咽喉把三弟叫，三弟……叫，"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "孤的好兄弟呀……"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "拿住了孙权两开交。"
        },
        {
          "character": "张苞",
          "type": "西皮摇板",
          "text": "伯父不必哭嚎啕， 杀了仇人恨方消。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "看酒来，待孤亲自祭奠。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "儿臣等代祭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你等要多拜几拜呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖哭皇天〗。关兴、张苞同拜，刘备奠酒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，将一干仇人，拿去开刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞押范疆、张达、糜芳、傅士仁同下。斩讫。关兴、张苞同上。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "斩首已毕。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "关兴、张苞！"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吩咐大小三军，歇兵三日，兵伐东吴！正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "满腔怒气冲霄汉，要把东吴踏平川！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、阚泽、张昭引孙权同上。"
        },
        {
          "character": "孙权",
          "type": "西皮摇板",
          "text": "刘玄德与孤王仇深似海， 杀得孤损兵折将好不伤怀！ 诸葛瑾到蜀营去求和解， 悔不该夺荆州惹祸招灾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾上。"
        },
        {
          "character": "诸葛瑾",
          "type": "西皮摇板",
          "text": "刘玄德仗兵强不愿和解， 回东吴奏主上早做安排。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "参见主公。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "罢了。子瑜，求和之事如何？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "那刘备不肯罢兵，反出言不逊，誓要踏平东吴，请主定夺。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哦……踏平东吴……唉！可叹父兄基业一旦休矣！"
        },
        {
          "character": "阚泽",
          "type": "白",
          "text": "启禀主公：臣保举一人，可以敌抵刘备。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "德润保举何人？"
        },
        {
          "character": "阚泽",
          "type": "白",
          "text": "九江都尉陆骏之子，名唤陆逊。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "臣启主公：想那陆逊，乃年幼书生，若委重任，恐误国家大事。"
        },
        {
          "character": "阚泽",
          "type": "白",
          "text": "那陆逊虽是书生，实有雄才大略，堪当重任；臣愿以全家保之。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "二卿不必争论，孤亦久闻陆逊颇有才能，德润替孤传旨，宣陆逊上殿。"
        },
        {
          "character": "阚泽",
          "type": "白",
          "text": "领旨。 主公有旨：宣陆逊上殿。"
        },
        {
          "character": "陆逊",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆逊上。"
        },
        {
          "character": "陆逊",
          "type": "念",
          "text": "未展平生志，空怀报国心。"
        },
        {
          "character": "陆逊",
          "type": "白",
          "text": "臣陆逊见驾，主公千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "陆逊",
          "type": "白",
          "text": "千千岁。宣臣上殿，有何国事议论？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "适才阚泽奏到，卿有孙武之才，孤命你总督军马，抵挡刘备，料无推辞了。"
        },
        {
          "character": "陆逊",
          "type": "白",
          "text": "启禀主公：江东文武，皆是主公故旧之臣，尚且无人受此重任；为臣年幼，恐 误国家大事，望主公另选贤能。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤已知卿颇有韬略，阚泽又以全家力保，卿家不必推辞了。"
        },
        {
          "character": "陆逊",
          "type": "白",
          "text": "惟恐文武不服。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "不妨，孤拜卿为大都督，进封娄侯，令掌六郡八十一州兼荆楚诸路军马；赐你 尚方宝剑，倘有不遵者，先斩后奏。"
        },
        {
          "character": "陆逊",
          "type": "白",
          "text": "谢主隆恩。"
        },
        {
          "character": "阚泽、张昭、诸葛瑾、陆逊",
          "type": "同白",
          "text": "请驾还宫。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引孙权同下。"
        },
        {
