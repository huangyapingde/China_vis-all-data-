{
  "script_id": "04022002",
  "title": "描容上路",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "张广才",
      "hangdang": "老生"
    },
    {
      "name": "赵五娘",
      "hangdang": "旦"
    }
  ],
  "plot": "陈留郡士人蔡伯喈奉父命进京赴试，中状元后，被牛丞相藉王命迫招为婿，和家中断绝音讯。当时，陈留郡\n一带正闹灾荒，蔡妻赵五娘乞来白米奉进翁姑，自己则以糠秕充饥。蔡家二老终于饥饿而死。赵五娘卖发埋\n葬了公婆，决意到京城去寻找丈夫。她在月光下凭着记忆描画了公婆的容像，打算带在身旁，作为纪念。蔡\n家近邻张广才，是一个善良热情的老人，听说赵五娘要赴京寻夫，便送她一面琵琶和一些散碎银两。在郊外\n送别赵五娘时，又再三叮嘱她一路小心；并愿意代赵五娘照看二老的坟墓。赵五娘衷心感激，与张广才洒泪\n而别。",
  "notes": "本剧是根据明初大戏曲家高则诚所著《琵琶记》中的一折改编的。\n本剧是根据周信芳先生的演出本，由周先生和华东戏曲研究院编审室严朴共同整理的。整理时仅在个别词句\n上作了一些修改。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘上。"
        },
        {
          "character": "赵五娘",
          "type": "引子",
          "text": "家业凋零，思夫君，日夜忧心！"
        },
        {
          "character": "赵五娘",
          "type": "念",
          "text": "年荒亲死夫无讯，多感大公一亲邻。南山筑坟裙兜土，决意上京把夫寻。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "唉！自从我丈夫蔡伯喈进京赶考，数载未回；陈留郡荒旱三载，公婆双双饿死。 我有心寻找伯喈，一叙别后之苦。斗室无光，不免在月光之下，描画公婆面 容，带在身旁，寻我丈夫便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小过门。赵五娘搬凳出门。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "喂呀，公公婆婆啊！"
        },
        {
          "character": "赵五娘",
          "type": "二黄慢板",
          "text": "手提着羊毫笔思前想后， 想起了二公婆珠泪双流！ 老爹娘盼姣儿功名成就， 谁知他到京都去不回头。 我在家承欢笑奉养姑舅， 遭荒旱他二老撒手西游！ 画起了老公爹面黄肌瘦， 画起了老婆婆背驼腰钩； 画起了老公爹竹杖在手， 画起了老婆婆满面忧愁。 拭泪痕停霜毫遗容画就——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘捧画入门。"
        },
        {
          "character": "赵五娘",
          "type": "二黄摇板",
          "text": "无非是表孝思慈影长留！"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "公婆遗像画好，无有祭礼，这便怎处？唉，只好用凉水一祭便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘挂容，以凉水一杯祭拜。"
        },
        {
          "character": "赵五娘",
          "type": "哭",
          "text": "喂呀，公婆啊！"
        },
        {
          "character": "赵五娘",
          "type": "二黄摇板",
          "text": "但愿得二公婆多多保佑， 与伯喈早相会免得飘流。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘伏几而卧。鸡鸣。张广才内叹息，提琵琶、雨伞上。"
        },
        {
          "character": "张广才",
          "type": "二黄原板",
          "text": "听衰柳鸣寒蝉树枯草瘦， 西风起黄叶落扑面生愁。 赵五娘孤单单京城奔走， 此一去好一似断缆的孤舟。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "老汉，张广才。只因蔡伯喈进京赶考，一去数载，杳无音信；可怜他的二老爹 娘，双双饥饿而死。如今赵五娘子要进京寻找伯喈，只是她一贫如洗，老汉又 无力帮助，是老汉只带来雨伞一把，琵琶一面，还有一些散碎银两，赠送于她。 唉！ 来此已是，五娘开门来。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "外面何人叫门？"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "老汉来了。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "哦，原来大公驾到。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘开门。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "大公请进。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "大公请坐。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "有座。五娘你当真要进京寻找伯喈么？"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "是啊，媳妇去心已定了。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "一路之上，可有盘费？"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "似这样饥荒年景，衣食不保，哪有盘费，只得乞讨而去了……"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "唉，苦煞你了！老汉带来琵琶一面，雨伞一把，还有一些散碎银两，你且收下。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "这个……前恩未报，又蒙恩赐，媳妇不敢领受。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "受人之托，理当帮助，你只管收下吧。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "多谢大公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张广才看画。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "啊五娘，这就是你的不是了。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "怎么是媳妇的不是？"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "你方才言道，饥荒年景，衣食不保，哪里来的银钱，与你公婆画影呢？"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "这个……啊大公，这画像不是画工画的。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "哦，不是画工画的，是哪个画的呢？"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "是媳妇在月光之下，用水墨描画而成的。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "哦，是五娘自己描画而成的？"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "若是旁人画的，老汉不看也罢；既是五娘自己画的，老汉倒要仔细看看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张广才看画。"
        },
        {
          "character": "张广才",
          "type": "叫头",
          "text": "老哥！老嫂！老哥，老嫂啊……"
        },
        {
          "character": "张广才",
          "type": "二黄导板",
          "text": "见容像不由我心酸痛！"
        },
        {
          "character": "张广才",
          "type": "叫头",
          "text": "老哥，老嫂，兄嫂啊……"
        },
        {
          "character": "张广才",
          "type": "二黄散板",
          "text": "滚滚珠泪洒前胸！ 画老哥手扶竹杖难以行动， 画老嫂两鬓白乱发蓬松。 空养你儿蔡伯喈终何用， 生不能养二老死不能送终！"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "收好了。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘收画。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "大公，媳妇要到坟前一走。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "老汉奉陪。将门带好了。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘背起包袱、雨伞、琵琶，与张广才同出门，倒锁门。"
        },
        {
          "character": "张广才",
          "type": "二黄散板",
          "text": "思念双亲绘真容， 生前死后一般同。 五娘贤孝人感动，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘、张广才同走圆场。"
        },
        {
          "character": "张广才",
          "type": "二黄散板",
          "text": "只见坟上柏和松。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "公婆啊！"
        },
        {
          "character": "赵五娘",
          "type": "二黄散板",
          "text": "屈膝躬身哀言禀， 尊声公婆在天灵： 都只为守家门难逃饥馑……"
        },
        {
          "character": "赵五娘",
          "type": "哭头",
          "text": "公婆啊！"
        },
        {
          "character": "赵五娘",
          "type": "二黄散板",
          "text": "到京城寻儿夫归祭双亲！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘看坟。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "啊大公，媳妇不去了。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "为何不去？"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "公婆坟墓，无人看守。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "这个么，五娘只管前去，老汉在一日，与你看守一日。你来看哪，老汉倘有不 测，那时就难以效劳了。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "多谢大公，媳妇拜别了。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "且慢！老汉还有几句言语，你且听了。"
        },
        {
          "character": "张广才",
          "type": "西皮流水板",
          "text": "叫一声五娘且慢行， 老汉言语你且听： 身上背定公婆影， 你身体单弱步难行。 未曾天晚早投宿， 起程必须等天明； 涉水登山心要稳， 行船过渡莫争行； 沟渠之水不洁净， 渴向人家求茶羹； 逢人只说三分话， 未可全抛一片心。 五娘此番京城进， 寻着伯喈把理评； 倘若伯喈不相认， 怀抱琵琶诉苦情。 你莫说公婆丧了命， 你莫说头上剪乌云， 你莫说亲戚朋友来帮衬， 你莫说兜土筑新坟； 你就说公婆现在堂上等， 叫他早早转家门。 五娘此去多谨慎， 但愿早到早回程。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "大公啊！"
        },
        {
          "character": "赵五娘",
          "type": "西皮流水板",
          "text": "大公不必细叮咛， 嘱咐的言语谨记心。 身上背定公婆影， 不顾艰难奔京城。 逢人只说三分话， 怎可全抛一片心。 媳妇此番京城进， 寻着伯喈把理评； 倘若伯喈不相认， 怀抱琵琶诉苦情。 我不说公婆丧了命， 我不说剪乌云，葬双亲， 众亲友来帮衬， 亲自兜土筑新坟。 我只说公婆堂前等， 教他即刻转家门。 拜别大公上路径——"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "回来。"
        },
        {
          "character": "赵五娘",
          "type": "西皮摇板",
          "text": "大公有话快说明。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "五娘啊！"
        },
        {
          "character": "张广才",
          "type": "西皮流水板",
          "text": "叫声五娘且慢走， 荒郊且作片刻留。 你公婆坟墓我看守， 五娘此去莫耽忧。 老汉今年七十九， 比你公公少二秋， 本当与你同行走， 怕的是此去难回头。 但愿你夫妻重聚首， 免得老汉挂心头。"
        },
        {
          "character": "赵五娘",
          "type": "白",
          "text": "大公啊！"
        },
        {
          "character": "赵五娘",
          "type": "西皮散板",
          "text": "我公婆坟墓你看守， 媳妇此去不耽忧。 双膝跪倒忙叩首……"
        },
        {
          "character": "赵五娘",
          "type": "哭头",
          "text": "公婆啊！"
        },
        {
          "character": "赵五娘",
          "type": "西皮散板",
          "text": "含悲忍泪把京投。"
        },
        {
          "character": "赵五娘",
          "type": "叫头",
          "text": "大公！公婆！唉，大公啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵五娘下。"
        },
        {
          "character": "张广才",
          "type": "白",
          "text": "五娘慢走，恕老汉不远送了。"
        },
        {
          "character": "张广才",
          "type": "西皮散板",
          "text": "忘恩负义蔡伯喈， 一去京城不回来。 但愿他回家时我命还在， 见面时问一问这不肖奴才！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张广才下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}