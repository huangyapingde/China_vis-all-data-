{
  "script_id": "04011002",
  "title": "激权激瑜",
  "alias": [
    "激权瑜"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "鲁肃",
      "hangdang": "老生"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    },
    {
      "name": "周瑜",
      "hangdang": "小生"
    },
    {
      "name": "吴国太",
      "hangdang": "老旦"
    }
  ],
  "plot": "东汉末，群雄并起。曹操挟天子以令诸侯，削平了北方群雄。刘备败走江夏。曹操亲率马、步、水军八十三\n万，沿长江下寨，以威胁东吴的孙权。吴文官张昭等主张降曹以自保，而武将黄盖等则坚决主战；权不能自\n决，遣鲁肃往江夏探听曹营虚实。肃邀刘备之军师诸葛亮来见孙权亮欲藉江东之力抗曹，先用言语激动孙权，\n又向吴水军都督周瑜假说曹操欲得大乔、小乔（大乔为孙权之嫂，二乔为周瑜之妻），并将曹操子曹植所\n作《铜雀台赋》中“连二桥于东南兮，若长空之啜蝀”二句改为“揽二乔于东南兮，乐朝夕之与共”，引以\n为证。周瑜本主战者，闻言益怒，乃向孙权力陈曹军此来多犯兵家之忌，虽多必败，以解孙权之疑惧。孙权\n拔剑砍断桌案一角，以示决心，立拜周瑜为帅，率众破曹。",
  "notes": "《激权激瑜》是《三国演义》中的一段故事。本剧是萧长华先生根据他所藏的三庆班本整理的。萧先生在富\n（喜）连成科班教学时曾对旧本有所增删、润色，现又重新加以修订。整理时也吸收了姜妙香先生的意见，\n并由本院编辑处田淞协助进行。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众军士、中军、周瑜同上。"
        },
        {
          "character": "周瑜",
          "type": "引子",
          "text": "水师如潮涌，统领貔貅百万军。"
        },
        {
          "character": "周瑜",
          "type": "念",
          "text": "三韬六略腹内存，职授元戎督水军。扫荡中原归吾主，方显奇谋立功勋。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "本督，姓周名瑜字公瑾，乃舒城人氏。幼习兵机，饱藏经纶，在吴侯驾前为臣， 官拜水军都督，在鄱阳湖操练水军。闻得曹操欲夺江南，兵至汉上，不免急 速回转柴桑，以防紧急。 中军，传令下去，命凌统带兵三千在此驻守，所余全部人马回转柴桑。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "遵命。 下面听者：都督有令，命凌统带兵三千在此驻守，所余全部人马回转柴桑。"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、孙权同上。"
        },
        {
          "character": "孙权",
          "type": "引",
          "text": "虎踞东吴，承霸业，恨贼侵吾。"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "碧睛紫髯貌魁梧，独霸江东立帝都。杀却曹瞒遂孤意，方显男儿大丈夫。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤，姓孙名权字仲谋。承父兄基业，执掌江东六郡八十一州。可恨曹操统领雄 兵直抵汉上，有吞江南之意，写来檄文，邀孤会猎于江夏。也曾命鲁肃去往江 夏探听虚实，怎么还不见回音。正是："
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "文降武战意不定，未决妙计破曹兵。"
        },
        {
          "character": "鲁肃",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃上。"
        },
        {
          "character": "鲁肃",
          "type": "念",
          "text": "探听江夏事，报与吴侯知。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "臣鲁肃参见主公千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "探听江夏虚实如何？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "臣往江夏探听虚实，有一人谋深计广，引来见主。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "乃诸葛瑾之弟诸葛亮，主公一问便知虚实。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "敢是卧龙先生？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "宣来一见。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "全凭三寸舌，打动霸业人。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生，吴侯有请。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有劳引山人相见。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生见了我主，切不可实言曹操兵多将广啊。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "是是是，亮自见机而变，决不有误。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣诸葛亮参见吴侯千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "先生少礼，请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权对鲁肃。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "常闻子敬谈足下之才，今幸相见，敢求教益。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮不才无学，有辱明问。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "足下近在新野辅佐刘豫州，与曹操决战，必深知彼军虚实。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我主刘豫州兵微将寡，新野小县无粮，安能与曹操相持。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "曹兵共有多少？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃向诸葛亮示意。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马、步、水军约有一百余万哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃出乎意料。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "莫非是诈乎？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "非诈也！曹操就兖州已有青军二十万，平了袁绍又得五六十万，中原新招之兵 三四十万，今又收荆诈之兵二三十万；以此计之，不下一百五十余万。亮以百 万言之，恐惊江东之士耳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃对诸葛亮作不满状。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "嗯……"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "那曹操部下战将共有多少？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "足智多谋之士，车载斗量；能征惯战之将，何止一二千员。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "今曹操平了荆楚，复有远图之意乎？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他今沿江下寨，准备战船，不欲图江东，而待图何地？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "若彼有吞并之意，战与不战，请足下为我一决。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮有一言，但恐将军不肯听从。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "愿闻高论。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今曹操新破荆州，威震海内，纵有英雄，无用武之地，故豫州遁逃至此；愿将 军量力处之。若能以吴越之众与中原抗衡，不如早与之绝；若其不能，何不从 众谋士之论，按兵束甲，北面而事之。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃极为失望。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将军外托服从之名，内怀疑贰之见，事急而不断，祸至无日矣。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "诚如君言，你主刘豫州他何不降曹？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是呀！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "昔田横齐之壮士耳，犹守义不辱。况刘豫州帝室之胄，英才盖世，众士仰慕； 事之不济，此乃天也，又安能屈处人下乎？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权怒不可遏，作色而起。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "噫！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权下。四太监同随下。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎，先生你何故出此言语？幸是吴侯宽洪大度，不即面责。先生之言，藐视吾 主甚矣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哈哈哈……大夫，你主何如此不能容物耶？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我自有破曹之计，他不问我，我何必言说；怎么反责我藐视于他。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎呀呀，你不要如此的做作。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我观曹操百万之众，犹如一群蝼蚁耳，但我一举手，则为齑粉矣。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "你果有良策，我便请主公求教。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "任凭……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有请主公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权上。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "主公为何退入？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孔明欺我忒甚。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "臣亦以此责孔明，孔明反笑主公不能容物。破曹之策，孔明不肯轻言，主公何 不求之？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "唔呼呀，原来孔明实有良策，故以言词激我也。我一时浅见，几误大事。 啊先生，孤适来冒渎尊颜，幸勿见罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮言语冒犯，望乞恕罪。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "岂敢，岂敢。请先生后堂叙话。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权、诸葛亮、鲁肃同走圆场，四太监同上，献茶。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "请问先生，有何良策，早要指教于我。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我看将军内怀疑忌，意有未决，恐惧曹操势大，不敢抗而。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哎呀先生！非孤胆怯，曹操平生所恶者：吕布、刘表、袁绍、袁术、刘豫州与 孤耳。今数雄已灭，独你主刘豫州与孤尚在。孤不能以全吴之地受制于人。吾 计决矣！非你主刘豫州莫与挡曹贼；然你主新败之后，安能抗此难乎？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我主虽然新败，然关云长犹率精兵万人，刘琦领江夏战士亦不下万人；曹操虽 然势大，但北军不习水战，且荆州士民附曹操者，迫于势耳，非本心也。今将 军诚能与我主协力同心，破曹操必矣。曹军破，必北还，则荆、吴之势强，而 鼎足形成矣。成败之机在于今日，唯将军裁之。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哈哈哈……先生之言顿开茅塞，吾意已决，更无他疑。即日商议起兵，共灭曹 操。烦先生助孤一臂之力。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "愿为参谋效用。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "子敬，请孔明先生馆驿歇息。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告别。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎先生，我再三嘱咐于你，不可实言曹操兵多将广，你怎么反倒多说出来了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮哑笑。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "诶！你主内怀疑忌，意有未决，忧思寡不敌众，故而言之。你可知那遣将不如 激将啊。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哦！劳驾。请馆驿歇息去吧。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、鲁肃同下。张昭、步隙、薛琮、陆绩同上。"
        },
        {
          "character": "张昭、步隙、薛琮、陆绩",
          "type": "同西皮摇板",
          "text": "诸葛亮劝主公与曹会战， 若用他奸计谋恐惹祸端。"
        },
        {
          "character": "张昭、步隙、薛琮、陆绩",
          "type": "同白",
          "text": "臣等见驾，吴侯千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "张昭、步隙、薛琮、陆绩",
          "type": "同白",
          "text": "千千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "有何事议？"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "闻得主公要兴兵与曹军争锋，主公自思比袁绍如何？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哦……"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "昔日曹操兵微将寡，尚能灭却袁绍，何况今日拥百万之众南征，岂可轻敌！主 公若听诸葛亮之言，妄动甲兵，此谓负薪救火也。"
        },
        {
          "character": "步隙",
          "type": "白",
          "text": "刘备因为曹操所败，故欲借我江东之兵以拒之，主公奈何为其所用乎？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "且自消停，容孤思之。退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "吴国太",
          "type": "内西皮导板",
          "text": "恨曹瞒下江南平吞江汉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女引吴国太同上。"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "挟天子令诸侯作恶多端。 刘玄德携民渡江遭涂炭， 最可叹三县民血染黄泉。 那刘备投襄阳欲脱兵燹，"
        },
        {
          "character": "吴国太",
          "type": "西皮快板",
          "text": "又谁知刘表已死蔡氏不贤。 蔡瑁、张允把心肠变， 荆襄九郡献曹瞒。 那曹贼得荆襄威势大显， 蔡氏母子被刀残。 艨艟战舰兵百万， 水陆并进下江南。 看起来我东吴已在危险， 为疆土昼夜里哪得安然。"
        },
        {
          "character": "孙权",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权上。"
        },
        {
          "character": "孙权",
          "type": "西皮摇板",
          "text": "文要降武要战不同一念， 清宸宫见母后细诉根源。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "儿臣见驾，母后千岁。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "进宫何事？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "启禀母后，今曹操统领雄兵百万，屯于汉上，有窥江南之意。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "吾儿意欲若何？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "欲待战者，恐寡不敌众；欲待降来，又恐曹操不容。因此儿臣犹豫未决，请示 母后定夺。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哎，儿啊，何不记得吾姊临终之语乎？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "先姊遗命云：“儿兄长孙伯符临终有言：‘内事不决问张昭，外事不决问周瑜。’ ”难道吾儿你就忘怀了？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哎呀，不是母后提起，儿臣险些误了大事。待儿臣急召周瑜回朝，商议破敌之 策。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "好哇。儿父兄之基业皆在儿一人身上了，事不可迟延。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "遵命。正是："
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "如醉方醒似梦觉，孙权决意不降曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权下。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "但愿得出良将脱却此难，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女同下。"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "天佑我东吴民灭却曹瞒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴国太下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "周瑜",
          "type": "内白",
          "text": "催军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众军士、中军、周瑜同上，鲁肃迎上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "鲁肃迎接都督。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "人马列开。 瑜有何德能，敢劳大夫相迎。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "奉主公之命，请都督回朝议事。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "你我回府再议。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一翻两翻，众军士、中军同下。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "有劳大夫远接。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "都督为国不惜劳倦，肃焉敢轻慢。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "岂敢。今曹操大军屯于当上，吴侯可有主见？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "唉！我国文臣要降，武将欲战；议论纷纷不一；吴侯犹豫不决，并无主见。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哼，此皆钱躯保妻子之臣，自为谋生之计耳。子敬勿忧，瑜自有主张。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "所以呀，吴侯命鲁肃去往江夏探听虚实，我搬来了诸葛孔明，为此请都督回朝， 共议大事。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦，诸葛亮来了？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "他现在哪里？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "现在馆驿。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "速速请来相见。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃下。中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启都督，张昭、步隙等请见。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张昭、步隙、薛琮、陆绩同上。"
        },
        {
          "character": "张昭、步隙、薛琮、陆绩",
          "type": "同白",
          "text": "都督。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "先生等请坐。"
        },
        {
          "character": "张昭、步隙、薛琮、陆绩",
          "type": "同白",
          "text": "有座。都督鄱阳湖训练水军，多有辛苦。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "为国勤劳，何言辛苦。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "啊都督，可知江东之利害否？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "未知也。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "曹操拥百万之众，屯于汉上，昨传檄文在此，欲请主公会猎于江夏，虽有相吞 之意，尚未露其形。昭等劝主公请降，庶免江东之祸；不想鲁子敬从江夏带刘 备军师诸葛亮至此，彼因自欲雪愤，特下说词以激吴侯，子敬执迷不悟，正欲 待都督一决。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "公等之见皆同否？"
        },
        {
          "character": "步隙",
          "type": "白",
          "text": "所议皆同。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜敷衍。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "唔，吾亦欲降久矣。公等请回，明早见主公自有定议。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "我等告退。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "张昭、步隙、薛琮、陆绩",
          "type": "同白",
          "text": "正是："
        },
        {
          "character": "张昭、步隙、薛琮、陆绩",
          "type": "同念",
          "text": "喜公瑾有降曹之意，笑孔明他枉费心机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张昭、步隙、薛琮、陆绩同下。"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "内同白",
          "text": "走哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄盖、甘宁、韩当、周泰同上。"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同念",
          "text": "文武降战不一，晋见都督便知。"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同白",
          "text": "有人么？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同白",
          "text": "武将等请见都督。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "候着。 启都督，黄盖等求见。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同白",
          "text": "啊。 参见都督。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "列位将军少礼，请坐。"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同白",
          "text": "谢坐。啊都督，可知江东早晚属他人否？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦？未知也！"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同白",
          "text": "我等自随孙将军开基创业以来，大小数百战，方才战得六郡城池。今主公听谋 士之言，欲降曹操，此真可惜可耻之事。我等宁死不辱，望都督劝主公决计兴 兵，我等愿效死战。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众位将军所见皆同否？"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "就将吾头割下，也誓不降曹。"
        },
        {
          "character": "甘宁、韩当、周泰",
          "type": "同白",
          "text": "我等皆不愿降曹。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "好！我正欲与曹操决一死战，安肯投降！将军等请回，瑜见主公自有定夺。"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同白",
          "text": "我等告退。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "黄盖、甘宁、韩当、周泰",
          "type": "同念",
          "text": "为将何惜命，捐躯报国恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄盖、甘宁、韩当、周泰同下。中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "诸葛先生到。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请诸葛先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、诸葛亮同上。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊，卧龙先生！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "周都督！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "先生请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "久闻先生高名，今幸相见，瑜愿领大教。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮不才无学，有辱都督明问。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜沉默。鲁肃着急。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊，都督，今曹操驱兵南侵，和与战二策，主公不能一决，听于将军，都督之 意如何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜故意。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "曹操以天子为名，其师不可拒，且其势大，未可轻敌。战则必败，降则易安。 我意已决，来日见主公便当请降。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃向鲁肃示意。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎，君言差矣！江东基业已历三世，岂可一旦弃于他人！况且孙伯符遗言，外 事付托将军；今正欲仗将军保全国体，为泰山之靠，奈何亦从懦夫之议也？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "江东生灵无限，若罹戈之祸，必有归怨于我，故决计请降。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不然，不然。以将军之英雄，我东吴之险固，那曹操他未必便能得志啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜见鲁肃不解己意，颇觉怏然。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮冷笑。"
        },
        {
          "character": "诸葛亮",
          "type": "笑",
          "text": "呵呵……哈哈……"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "先生何故哂笑？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮不笑别人，笑的是子敬他不识时务耳。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊先生，你怎么反笑我不识时务？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "是啊，孔明先生乃识时务之士，必与我有同心。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎哎哎，孔明，怎么，你也如何说此啊？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你想啊，曹操极善用兵，天下莫挡。向日只有吕布、袁绍、袁术、刘表敢与对 敌；今数人皆被曹所灭，天下无人矣。独刘豫州不识时务，强与争衡，今孤身 江夏，存亡未保。都督决计降曹，甚好哇。喏，可以保妻子，可以全富贵，国 祚迁移付之天命，何足惜哉！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊？你叫我主屈膝受辱于国贼乎！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "愚有一计，并不劳牵羊担酒，纳土献印；亦不用亲自渡江；只须一介之使，扁 舟送两个人到江上，曹操若得此二人，百万之众皆卸甲卷旗而退矣。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦，用哪二人可退曹兵？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "江东去此两个人，如大林中飘落一叶，太仓减一粟耳；而曹操得之必大喜而去。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "果用何二人？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "亮居隆中时，即闻曹操于漳河新造一台，名曰铜雀台，极其壮丽，广选天下美 女以实其中。操本好色之徒，久闻江东乔公有二女——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃摆手示意，诸葛亮不理。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "长曰大乔，次曰小乔，有沉鱼落雁之容，闭月羞花之貌。操曾发誓曰：“吾一 愿扫平四海以成帝业；一愿得江东二乔，置之铜雀台以乐晚年，虽死无恨矣。” 他今虽引百万之众，虎视江南，其实为此二女。啊都督，你休不去寻乔公， 以千金买此二女，差人送与那曹操。他得此二女，必然是称心满意，一定班师 回去了。此乃范蠡献西施之计也。啊都督……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜勉强支应。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "何不速速为之？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜怒。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊？曹操欲得二乔，有何证验？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "是啊，有何证验？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有哇。曹操幼子曹植，字子建，下笔成文；操尝命作一赋，名曰《铜雀台赋》。 赋中之意，单道他家身为天子，誓取二乔。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "此赋先生可记否？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我爱其文华美，尝窃记之。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "试请一诵。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "是。那《铜雀台赋》云：“从明后以嬉游兮，登层台以娱情。见太府之广开兮， 观圣德之所营。建高门之嵯峨兮，浮双阙乎太清。立中天之华观兮，连飞阁 乎城西。临漳水之长流兮，望园果之滋荣。立双台于左右兮，有玉龙与金凤。 揽二乔于东南兮，乐朝夕之与共。”此句呀，就应在那二乔的身上啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜怒极。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊！这老贼欺我太甚！"
        },
        {
          "character": "周瑜",
          "type": "快风入松",
          "text": "闻言怒火三千丈， 奸贼竟敢猖狂！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "曹操哇，曹操！我不杀你，誓不为人也！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊都督，昔单于屡侵疆界，汉天子许以公主和亲，都督何惜民间二女乎？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎，先生有所不知。大乔是孙伯符将军主妇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮佯作吃惊。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "小乔乃瑜之妻也。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎呀，亮实不知，失口乱言，罪该万死。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哎，不知者不怪罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "该死，该死！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "曹操哇，曹操，我与你誓不两立也。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "都督，事须三思，免致后悔呀！"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "咳，吾承孙伯符寄托，安有屈身降曹之理？适才所言，故相试耳。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哎哟，我哪里知道哇。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "吾自离鄱阳湖，便有北伐之心，虽刀斧加头，不易其志也。望孔明先生助我一 臂之力，共破曹操。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "若蒙不弃，愿效犬马之劳，早晚供听驱策。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "来日入见主公，便议起兵。先生请至馆驿。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "奉送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃指诸葛亮，诸葛亮哑然失笑，下。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "啊子敬，孔明见主公可讲些什么？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他道主公内怀疑忌，意有未决等语。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦，他既料主公心事，其计谋高过于我。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "嗯，他非等闲之辈呀。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哼！此人若不早杀，乃江东之患也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "啊都督，不可啊！曹兵未破先杀贤才，乃是自去其助也。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "此人助刘备，日久必为江东后患。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不可，恐人谈论哪。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "不要你管，我自有妙计杀他。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎哎哎，差矣。诸葛瑾乃其亲兄，可令其招孔明来降，同事东吴，岂不美哉？"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "唔，此言甚善，就请诸葛瑾先生来见。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "去请诸葛瑾来见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "子敬请坐。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "众文武与主公怎样议论？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哎，都督请听："
        },
        {
          "character": "鲁肃",
          "type": "西皮导板",
          "text": "我东吴看看遭危险，"
        },
        {
          "character": "鲁肃",
          "type": "西皮原板",
          "text": "尊一声周都督听鲁肃细说一番： 那曹操得荆襄兵屯江汉， 水陆并进下江南。 写来了檄文藏奸险， 吴侯一见心胆寒。 张昭、步隙等见识浅，"
        },
        {
          "character": "鲁肃",
          "type": "西皮流水板",
          "text": "文武议论不一般。 幸得太后有主见， 想起了孙伯符他有遗言。 内事不决问张昭， 外事不决向都督言。 那曹操龙骧虎视吞江汉， 因此如都督回朝班。 军国大事不可缓， 决意须在顷刻间。 我东吴文要降、武欲战， 还望都督定江南。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "周瑜",
          "type": "西皮摇板",
          "text": "子敬休得发长叹， 周瑜自有巧机关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "诸葛瑾先生到。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾上。"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "舍弟离江汉，独自到江南。我料他心意，借力破曹瞒。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "都督。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "先生。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "先生。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "谢座。"
        },
