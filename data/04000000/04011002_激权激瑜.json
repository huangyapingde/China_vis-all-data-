      "utterances": [
        {
          "character": "诸葛亮",
          "type": "内西皮导板",
          "text": "诸葛亮在馆驿牙关笑破，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
