        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "舍弟诸葛亮自汉上来，言刘好象州欲结东吴共伐曹操。今文武商议未定，因舍 弟为使，瑾不敢多言，专候都督来决此事。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "来日见主公自有主张。啊先生，令弟孔明有王佐之才，如何屈身事刘备。今幸 至江东，欲烦先生不惜齿牙余论，使令刘备而事东吴，则主公既得良辅，而先 生兄弟又得相见，岂不美哉？"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "瑾自至江东，愧无寸功，今都督有命，敢不效劳。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "先生幸即一行。"
        },
        {
          "character": "诸葛瑾",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "诸葛瑾",
          "type": "念",
          "text": "即时投驿亭，去说同胞人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛瑾下。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "但愿说得孔明来降，去我周瑜一桩心事。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "唔，那何愁天下不归吴侯矣。"
        },
        {
          "character": "周瑜",
          "type": "白",
          "text": "大夫，今夜已晚，请回安歇，明早一同请见主公。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "告退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周瑜、鲁肃自两边分下。"
        }
      ]
