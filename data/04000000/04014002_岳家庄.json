{
  "script_id": "04014002",
  "title": "岳家庄",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "岳云",
      "hangdang": "小生"
    }
  ],
  "plot": "岳飞之子岳云幼时在家瞒着母亲，练习武艺。一天，金兵突来袭击岳家庄，岳云的祖母与母亲束手无策；岳\n云与其姊银瓶带领家丁出庄拒敌，大败金兵，并生擒金将，全庄得保无恙。",
  "notes": "《岳家庄》是演义小说《精忠岳传》的一段故事。这个戏是由姜妙香先生和本院（中国戏曲研究院）编辑何\n异旭共同整理的。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "岳云上。"
        },
        {
          "character": "岳云",
          "type": "引子",
          "text": "武艺习就，何日里，扫灭金酋。"
        },
        {
          "character": "岳云",
          "type": "念",
          "text": "少年英雄志未酬，凌云气概关斗牛。闻鸡起舞显身手，不灭金人誓不休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳安暗上。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "俺，岳云。乃河南汤阴县人氏。父字鹏举，宋室为臣。奉旨前去剿灭金人未见 捷报。是我自幼爱习武艺，练就白银锤一对，能挡万军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云暗笑。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "好笑我母亲，教我弃武习文，攻读诗书。我想为人子者，自当随父建功立业， 才是正理。为此每日瞒着祖母、娘亲，暗地演习锤法，日后也好帮助爹爹扫灭 金酋。 岳安。"
        },
        {
          "character": "岳安",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "我在此练习武艺，休叫我祖母与娘亲知道。"
        },
        {
          "character": "岳安",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "取银锤过来。"
        },
        {
          "character": "岳安",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳安取锤，拿不动。"
        },
        {
          "character": "岳安",
          "type": "白",
          "text": "回少爷的话，它拿我不动。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "敢是你拿它不动？"
        },
        {
          "character": "岳安",
          "type": "白",
          "text": "不错，我拿它不动。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳安暗下。"
        },
        {
          "character": "岳云",
          "type": "西皮散板",
          "text": "每日里习武艺心中欢欣， 练就了白银锤力敌万人； 非是我背地里违抗母命， 将门子当随父建立功勋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云舞锤。"
        },
        {
          "character": "岳云",
          "type": "西皮散板",
          "text": "上一锤，上一锤打的是插花盖顶， 下一锤，下一锤打的是枯树盘根。 怀揣着报国志要把江山保定，"
        },
        {
          "character": "岳云",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、岳夫人、银瓶同上。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "岳夫人",
          "type": "西皮散板",
          "text": "胆大的小奴才违抗娘亲。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云跪下。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "大胆奴才，为娘怎样嘱咐于你，教儿弃武习文，谁想奴才不听为娘教训。 丫鬟。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "看家法伺候。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "好奴才。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳夫人打岳云。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "母亲哪！"
        },
        {
          "character": "岳云",
          "type": "西皮散板",
          "text": "我的父为元帅军威远震， 统帅着兵和将抗击金人； 望母亲容孩儿习学公瑾， 哎呀母亲哪！ 烧赤壁保东吴得享安宁。"
        },
        {
          "character": "岳云",
          "type": "哭",
          "text": "啊……啊……"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "岳夫人",
          "type": "西皮散板",
          "text": "孔圣人在卫国不对问阵， 孟子曰善战者要服上刑； 把圣贤金石言全然不省！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳夫人打岳云，岳云哭。"
        },
        {
          "character": "银瓶",
          "type": "西皮散板",
          "text": "银瓶女跪尘埃哀告娘亲。 我兄弟有大志从轻责问， 母亲哪！"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云哭下。岳母上。"
        },
        {
          "character": "岳母",
          "type": "西皮散板",
          "text": "年迈人闻悲声坐卧不宁。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "婆婆万福。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云换衣上。"
        },
        {
          "character": "银瓶",
          "type": "白",
          "text": "参见祖母。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "啊，祖母在上，孙儿拜揖……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云哭泣。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "啊，媳妇，为何将岳云打得这般光景？"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "只因奴才不听媳妇训教，故而责打。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "原来如此。 孙儿，你不听教训，应当责打。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "祖母，孙儿乃将门之子，自当随父杀敌立功，才是正理；倘若坐食君禄，岂不 被天下人耻笑？"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "嗯，又来多口。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "从今以后弃武习文，方是正道。我有几句言语，你且听了。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "请祖母训教。"
        },
        {
          "character": "岳母",
          "type": "西皮原板",
          "text": "食君禄当为国把社稷平定， 怎奈是我孙儿幼小年轻； 从今后还须要读书上进， 也不枉为祖母教训殷勤。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "孙儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳安上。"
        },
        {
          "character": "岳安",
          "type": "白",
          "text": "报，牛二爷到。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "有请。 孙儿前去迎接。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "岳安",
          "type": "白",
          "text": "有请牛二爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳安下。"
        },
        {
          "character": "牛皋",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋上。"
        },
        {
          "character": "牛皋",
          "type": "念",
          "text": "战马踏破金邦地，斩将擒王立大功。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "啊，牛叔父！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊，岳云！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋下马。"
        },
        {
          "character": "牛皋",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "几载不见，你倒长成人了。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "叔父夸奖了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "你祖母、娘亲呢？"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "现在堂上。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "往里去传，就说你牛叔父到了。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "遵命。 啊，祖母，牛叔父来了。 啊，母亲，牛叔父来了。"
        },
        {
          "character": "岳母、岳夫人",
          "type": "同白",
          "text": "快快有请。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "有请牛叔父。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "前面带路。 伯母在哪里，伯母在…… 伯母在上，侄儿大礼参拜。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "牛皋，远路而来，只行常礼。一旁坐下。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "啊，二叔。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "嗨，咱牛皋到此，乃是客位，连杯茶都不曾吃，你坐在一旁，这么二叔，二叔 的，这是个啥道理？"
        },
        {
          "character": "岳夫人、岳云",
          "type": "同白",
          "text": "丫鬟，看茶来。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "慢来，慢来。适才在前面饮马的时节，我在马槽上喝了一气凉水。不用了。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "不用了。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "圣上驾安？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "圣上安泰。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "元帅可好？"
        },
        {
          "character": "岳云、银瓶",
          "type": "同白",
          "text": "我爹爹可好？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "元帅好，就是咱牛皋也好。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "为嫂的还未曾问到你呢！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "嫂嫂问过元帅，少不得就要问咱牛皋；一块儿说了，省得您费事啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳夫人向岳云。"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "儿啊，你牛叔父如今是会讲话了。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "是啊，会讲话了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "咱不但会讲话，而且，还认识几个“黑道道儿”！"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云向牛皋。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "嘘……叔父这里来。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "叔父敢莫是认识字了么？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "认识字了。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "但不知认识哪几个？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "待我告诉你说：你爹爹姓岳的那个“岳”字。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "哦，岳字。一个。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "咱牛皋的这个“牛”字。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "两个。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "我是把它认准了。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "还有哪个？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "两个还少吗？"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "哦！叔父只认识这两个字，就在人前夸口，倒叫侄儿好笑哇！哈哈哈……"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "嗨！大人在此讲话，小孩子在一旁张口搭言，好无有规矩啊！"
        },
        {
          "character": "岳夫人",
          "type": "白",
          "text": "岳云，还不向前赔礼。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "侄儿赔礼，侄儿赔礼。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "慢来，慢来。我在营中被你爸爸“呲哒”惯了。谁来怪你？我的傻小子！"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "您吓着了我啦。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "牛皋，不在牛头山前侍奉元帅，回来做甚？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "奉了元帅将令，催押粮草。有平安家书一封，伯母收下。"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "待我收下。 岳云，准备酒筵，与你牛叔父洗尘。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "且慢！军务在身，不敢久停。告辞！"
        },
        {
          "character": "岳母",
          "type": "白",
          "text": "你既有军务在身，就不强留。 岳云，送过你牛叔父。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "岳母、岳夫人、银屏、岳云",
          "type": "同白",
          "text": "正是："
        },
        {
          "character": "岳母",
          "type": "念",
          "text": "儿行千里母担忧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳母下。"
        },
        {
          "character": "岳夫人、银瓶",
          "type": "同念",
          "text": "干戈不知几时休！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳夫人、银屏同下，丫鬟随下。"
        },
        {
          "character": "牛皋",
          "type": "念",
          "text": "元帅自有回朝日，"
        },
        {
          "character": "岳云",
          "type": "念",
          "text": "准备吴钩斩金酋。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "好大的口气！"
        },
        {
          "character": "岳云",
          "type": "白",
