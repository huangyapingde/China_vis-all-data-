{
  "script_id": "04010004",
  "title": "母女会",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "陈氏",
      "hangdang": "老旦"
    }
  ],
  "plot": "自从薛平贵出征以后，王宝钏苦守寒窑。王允以各种方法，甚至说薛平贵战死在西凉，逼女儿改嫁。坚贞不\n屈的王宝钏，对薛平贵的爱情并没有丝毫改变，但因生活很贫困，加之思念薛平贵，终于生了病。她母亲前\n来探望，见王宝钏的憔悴形容以及寒窑里的穷苦光景，劝她一同回家，再享受从前丞相女儿的豪华生活。尽\n管王宝钏很爱她的母亲，并没有因此接受母亲的劝告；她把母亲诓出门去，将窑门紧闭，坚决不回相府。",
  "notes": "这个剧本是根据王瑶卿先生的演出本，由北京戏曲实验学校于玉蘅，中国京剧团演员李金泉与本院（中国戏\n曲研究院）编辑处田淞、吕瑞明共同整理的。因原本就很完整，整理时，仅对个别词句略加修正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、陈氏同上。"
        },
        {
          "character": "陈氏",
          "type": "引子",
          "text": "两鬓如霜，承诰命，身宿华堂。"
        },
        {
          "character": "陈氏",
          "type": "念",
          "text": "可叹相爷不公平，三个女儿两看承。虽然身居在相府，思想姣儿不安宁。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "老身陈氏。配夫王允，官居首相，膝下无儿，所生三女。长女金钏许配苏龙； 次女银钏许配魏虎；三女宝钏彩楼招赘，打中花郎平贵，我家相爷嫌他贫寒， 定要退婚，三女执意不肯，因此父女失和。可叹她性情高傲，搬往城南寒窑居 住。如今闻得平贵命丧西凉，我也曾命家院前去探望三女，未见回报。 丫鬟！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "念",
          "text": "有事来通报，无事不乱言。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "参见老夫人。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "罢了。命你探望三姑娘怎么样了？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘在寒窑身染重病。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘身染重病。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "唉！儿啊！"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "忽听家院报一声， 宝钏姣儿病缠身。 眼望寒窑珠泪滚，"
        },
        {
          "character": "陈氏",
          "type": "哭头",
          "text": "我的儿啊！"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "怎不叫娘痛伤心。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "老夫人不必悲伤，何不去到城南探望三姑娘？"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "如此家院、丫鬟，"
        },
        {
          "character": "家院、丫鬟",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "多带银米裙衫，探望你家三姑娘。吩咐车辆伺候。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "车辆上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上，陈氏上车。"
        },
        {
          "character": "陈氏",
          "type": "西皮慢板",
          "text": "思想起当年事心中悔恨， 大不该叫女儿彩楼招亲。 闻听得薛平贵西凉丧命， 寒窑内抛下了我儿千金。 叫家院你与我前把路引， 见宝钏母女门叙叙衷情。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "来此已是寒窑。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "前去叫门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈氏下车，车夫下。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 三姑娘开门来。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "耳边厢又听得有人声， 想必是左右邻来看我身。 想薛郎想得我身染重病， 这几日未起床思念夫君。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "三姑娘开门来，老夫人来了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "听说是我的母在窑外立等， 这光景怎见得儿的老娘亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏开门，出窑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲在哪里？母亲在……"
        },
        {
          "character": "王宝钏、陈氏",
          "type": "同三叫头",
          "text": "（母亲）（宝钏）！（亲娘）（姣儿）！（喂呀母亲哪）（儿啊）！"
        },
        {
          "character": "陈氏",
          "type": "西皮导板",
          "text": "一见姣儿珠泪滚，"
        },
        {
          "character": "陈氏、王宝钏",
          "type": "同三叫头",
          "text": "（宝钏）（母亲）！（姣儿）（亲娘）！（儿啊）（喂呀娘啊）！"
        },
        {
          "character": "陈氏",
          "type": "西皮流水板",
          "text": "手拉三姐站窑门。 儿在相府多由性， 使女丫鬟陪伴儿的身。 闲来绣楼描花锦， 闷来花园散散儿的心。 儿从前容颜多端正， 到如今你头上无钗、身上无衣、面黄肌瘦、脸带病形，千般苦处都受尽，叫娘 心疼不心疼！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "老娘亲不必两泪淋， 女儿言来听分明： 老爹爹在朝官一品， 生下我姐妹共三人。 大姐二姐遵父命， 许配居官为宦人； 女儿许配花郎汉， 平贵虽穷趁儿的心。 世人都想为官宦， 谁是那耕田种地的人。"
        },
        {
          "character": "陈氏",
          "type": "西皮快板",
          "text": "背地里只把相国恨， 一样女儿两样看承。 回头再对宝钏论： 为娘常把我儿挂在心。 今日母女重相会， 好似枯木又逢春。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲请上，待女儿拜见。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "我儿不必拜了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿久离膝下，少奉甘旨，恕女儿不孝之罪。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "不必拜了。 家院、丫鬟，见过三姑娘。"
        },
        {
          "character": "家院、丫鬟",
          "type": "同白",
          "text": "参见三姑娘。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "罢了。 啊母亲，不在相府，来此寒窑作甚？"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "适才家院报道：我儿身染重病；但不知你的病症从何而起？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "再不要提起。只因那日魏虎回朝，打此寒窑经过，他说薛郎命丧西凉，女儿闻 听，痛哭不止。爹爹又命人前来，要接儿回去另行改嫁，因此身得重病。今见 母亲，儿的病体，哎呀！好了一半了哇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "啊，我把你这老天杀的！为何时常逼我女儿改嫁？ 为娘回的府去，定不与他甘休！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊母亲，不要为了女儿之事，伤了你二老的和气才好。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "看在我儿面上，为娘不与他吵闹就是。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "多谢母亲。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "儿呀，为娘要进得窑去，看看我儿的光景如何？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "这个……寒窑窄小，不看也罢。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "唉！我儿住得，难道为娘就看也看不得么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此女儿打扫打扫。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "何必打扫，与为娘带路进窑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈氏、王宝钏同进。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "画阁雕梁儿不住， 破瓦寒窑怎把身存？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院端饭与陈氏看。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "珍馐美味儿不用， 粗茶淡饭怎渡光阴？"
        },
        {
          "character": "王宝钏、陈氏",
          "type": "同三叫头",
          "text": "（母亲）（宝钏）！（亲娘）（姣儿）！（喂呀母亲哪）（儿啊）！"
        },
        {
          "character": "陈氏",
          "type": "哭头",
          "text": "我哭，哭一声宝钏我的儿啊！"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "我叫，叫一声疼儿的老娘亲！"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "想当初在相府何等光景， 到如今住寒窑娘好心疼！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "只当儿今朝丧了命， 老娘亲何必你、你、你……挂在心！"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "我的儿随为娘把相府来进， 随娘坐来伴娘行。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "二堂与父三击掌， 冻饿死在寒窑也不回相府的门！"
        },
        {
          "character": "陈氏",
          "type": "哭头",
          "text": "宝钏儿！"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "老娘亲！"
        },
        {
          "character": "王宝钏、陈氏",
          "type": "同哭头",
          "text": "啊……（儿的娘）（我的儿）啊！"
        },
        {
          "character": "王宝钏",
          "type": "西皮小导板",
          "text": "老娘亲请上容儿拜禀，"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "母女们在寒窑叙一叙苦情。 为母病奉汤药三年整， 蒙正宫赐绒线抛彩结亲。 彩楼前打着薛平贵， 老爹爹一见怒气生。 前门赶走"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "薛平贵， 后门又赶女儿身。 夫妻双双无投奔， 在破瓦寒窑把身存。 薛郎投军征西去， 儿愿守寒窑等他回程。 老娘回府替儿禀， 从今后不用父操心。"
        },
        {
          "character": "陈氏",
          "type": "西皮快板",
          "text": "我儿不必太伤心， 为娘言来听分明： 休与你父来争论， 休要牵挂平贵身。 儿随为娘相府进， 随娘坐来伴娘行。 倘若你父来争论， 为娘把性命与他拼。 倘若为娘下世去， 儿就是披麻带孝的人。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "老娘不必痛伤心， 女儿言来听分明： 倘若老娘百年后， 儿就是披麻带孝的人。 倘若是爹爹身亡故， 女儿不去哭半声。 非是女儿不孝顺， 他把儿夫不当人。 宝钏心志早已定， 贫困至死也不回相府的门！"
        },
        {
          "character": "陈氏",
          "type": "西皮摇板",
          "text": "我儿立志心拿稳， 但愿不负苦心人。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "家院、丫鬟，将银米裙衫交与你三姑娘。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊母亲，相府之物，女儿不用，叫他们带了回去吧。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "儿啊，难道你就辜负为娘一片心意么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿收下就是。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "这便才是。 家院、丫鬟，你们暂且回去，我在寒窑陪伴你三姑娘住上几日。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊母亲，寒窑肮脏得很，母亲怎能住得？"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "我儿住得，难道为娘就住不得么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀且住！我母亲不回相府，这这这便怎么处？我自有道理。 啊母亲，女儿今日也要同母亲回相府去了。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "我儿愿回相府了么？这便才是。 家院、丫鬟，前面带路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏开门，家院、丫鬟、陈氏同出窑，王宝钏急闭窑门。车夫上。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "哎呀儿啊，你怎么将窑门关闭了？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "母亲哪！二堂与父三击掌，冻饿死在寒窑，哎呀，也是不回去的了哇……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏哭。"
        },
        {
          "character": "陈氏",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "宝钏儿抛为娘心肠太狠，"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "儿在寒窑送娘亲。"
        },
        {
          "character": "陈氏",
          "type": "西皮散板",
          "text": "娘哭儿来痛难忍，"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "女哭娘来类满襟。"
        },
        {
          "character": "陈氏",
          "type": "哭头",
          "text": "宝钏儿！"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "老娘亲！"
        },
        {
          "character": "王宝钏、陈氏",
          "type": "同哭头",
          "text": "啊……（儿的娘）（我的儿）啊！"
