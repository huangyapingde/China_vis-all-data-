{
  "script_id": "04017003",
  "title": "二进宫",
  "alias": [
    "击宫门"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "杨波",
      "hangdang": "老生"
    },
    {
      "name": "徐延昭",
      "hangdang": "净"
    },
    {
      "name": "李艳妃",
      "hangdang": "旦"
    }
  ],
  "plot": "明穆宗死后，太子年幼，李艳妃垂帘听政。其父李良，蒙蔽李妃，企图篡位，定国王徐延昭、兵部侍郎杨波，\n于龙凤阁严词谏阻，李妃执迷不听，君臣争辩甚剧，不欢而散。李良封锁了昭阳院，使内外隔绝，篡位之\n迹已明。徐、杨二人于探皇灵后，二次进宫进谏。此时李妃已悔悟，遂以国事相拖。后杨波发动人马，卒斩\n李良。",
  "notes": "《二进宫》是全部《龙凤阁》剧中的一折，唱腔有特殊成就。此本现由杨宝森与中国京剧团演员雪艳琴、王\n泉奎和本院（中国戏曲研究院）编辑处祁野耘，共同作了一些词句上的修润。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "李艳妃",
          "type": "内白",
          "text": "唉！先王啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宫女、徐小姐、李艳妃同上。"
        },
        {
          "character": "李艳妃",
          "type": "二黄慢板",
          "text": "自那日与徐杨决裂以后， 看一看不觉是八月中秋。 先王爷晏了驾太子年幼， 太师爷起下了篡位奸谋。 他那里父女情全然无有， 竟把我孤儿寡母当作了马牛。 徐小姐把守在宫门口， 怕的是太师爷来把宫搜。"
        },
        {
          "character": "徐延昭",
          "type": "内白",
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "type": "内白",
          "text": "千岁请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐延昭、杨波、杨公子同上。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "探罢皇灵到昭阳，"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "宫门上锁是贼李良。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "铜锤付与大人掌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨波接锤，交付杨公子。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "击开宫门见皇娘。"
        },
        {
          "character": "杨公子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "杨公子",
          "type": "二黄摇板",
          "text": "铜锤一举双环断，"
        },
        {
          "character": "徐小姐",
          "type": "二黄摇板",
          "text": "何人大胆闯昭阳？"
        },
        {
          "character": "徐延昭、杨波",
          "type": "同白",
          "text": "我儿休要动手，此乃（杨四公子）（徐小姐），向前见礼。"
        },
        {
          "character": "杨公子",
          "type": "白",
          "text": "小将有礼。"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "还礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨公子下。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "我儿启奏国太：就说徐、杨二家宫门候旨求见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐小姐进内。"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "启奏国太：徐、杨二家宫门候旨求见。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "宣他二人进宫！"
        },
        {
          "character": "徐小姐",
          "type": "白",
          "text": "国太有旨：徐杨二家进宫。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "领旨。 大人！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "此番进宫，将保国之事，启奏国太。"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "全仗千岁。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁请！"
        },
        {
          "character": "杨波",
          "type": "二黄慢板",
          "text": "千岁爷进寒宫休要慌忙， 站宫门听学生细说比方： 昔日里楚汉两争强， 鸿门设宴要害汉王。 张子房背宝剑把韩信来访， 九里山前摆下战场。 逼得个楚项羽乌江命丧， 到后来封韩信三齐王。 他朝中有一位萧何丞相， 后宫院有一位吕后娘娘。 君臣们摆下了天罗地网， 三宣韩信命丧未央。 九月十三雪霜降， 盖世忠良不能久长。 千岁爷进寒宫学生不往。"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "怕者何来？"
        },
        {
          "character": "杨波",
          "type": "二黄慢板",
          "text": "怕的是辜负了十年寒窗、九载遨游、八月科场、七篇文章，才落得个兵部侍郎， 怕只怕无有下场！"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "说什么学韩信命丧未央， 站宫门听老夫改说一桩： 先王爷怎比得汉高皇上， 龙国太怎比得吕后皇娘； 李良贼怎比得萧何丞相， 大人怎比三齐王。 这寒宫权当作鸿门宴上， 有老夫比樊哙、怀抱铜锤、保驾身旁，料也无妨。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "我好比鱼儿闯过了千层罗网， 受了些惊怕，着了些慌忙。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "只要你忠心把国掌， 老夫保你满门无伤，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "千岁爷保学生满门无伤， 舍死忘生闯进昭阳。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "前面走的开国将，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "后面跟随兵部侍郎。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "站立在宫门朝内望，"
        },
        {
          "character": "李艳妃",
          "type": "哭",
          "text": "先王啊……"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "又只见龙国太怀抱太子、两泪汪汪、口口声声哭的是先王！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "龙国太哭的是江山难掌，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "摆一摆手儿切莫要承当。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "进宫去休行那君臣大礼，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "学一个文站东，"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "武列西，"
        },
        {
          "character": "徐延昭、杨波",
          "type": "同二黄原板",
          "text": "各自分班站立在两厢。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "先王啊！"
        },
        {
          "character": "李艳妃",
          "type": "二黄慢板",
          "text": "李艳妃坐昭阳前思后想， 想起了朝中事无有主张。 耳边厢又听得朝靴底响， 想必是徐、杨进了昭阳。 有几句话儿我不好言讲， 我只得怀抱太子、两泪汪汪、口口声声哭的是先王！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "怀抱着幼主爷江山执掌，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "为什么恨天怨地，假带愁肠所为那桩？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "并非是哀家假带愁肠， 都只为我朝中不得安康。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "我朝中有什么祸从天降？"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "你就该请太师进宫来，父女们商量又待何妨？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "太师爷心肠如同王莽， 他要夺我皇儿锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "太师爷娘娘的父，他本是皇亲国丈，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "未必他一旦无情，起下了篡位的心肠。太师爷忠良！"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "你道他无有那篡位的心肠， 封锁昭阳为的是哪桩？"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "臣七月十三也曾把三本奏上，国太偏偏要让，"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "你言道：大明朝有事无事、不用徐杨二奸党，赶出朝房，龙国太自立为王。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "先前的话儿休要讲， 不看哀家看在先王。 徐王兄保幼主登龙位上， 我封你一字并肩王。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "老臣年迈难把国掌， 要保国还是那兵部侍郎。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "徐王兄年纪迈难把国掌， 转面来叫一声兵部侍郎： 你保幼主登龙位上， 你的名儿万古扬。"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "吓得臣低头不敢望， 战战兢兢启奏皇娘： 臣昨晚修下了辞王本， 今日里进宫来辞别皇娘。 望国太开恩将臣放， 放臣还乡落得个安康。"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "他二人把话一样讲， 倒叫哀家无有主张。 无奈何怀抱太子跪在昭阳，"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "吓坏了定国王！"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "兵部侍郎！"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "自从盘古立帝邦，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "君跪臣来臣怎敢当！"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "非是哀家来跪你， 跪的是我皇儿锦绣家邦。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "锦家邦来锦家邦，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "臣有一本启奏皇娘。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "昔日里有一个李文、李广，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "弟兄双双扶保朝纲；"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "李文北门带箭丧，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "伴驾山前又收李刚。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "收了一将损伤一将，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "一将倒比一将强。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "到后来保太子登龙位上，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "反把那李广斩首在法场。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "这都是前朝的忠臣良将，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "哪一个忠良又有下场？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "有下场来无下场， 细听哀家说个比方： 昔日里有个潘老丞相， 李氏夫人替了皇娘。 紫竹林内生太子， 他的名儿万古扬。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "困龙思想长江浪，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "虎落平阳想奔山岗。"
        },
        {
          "character": "徐延昭",
          "type": "二黄原板",
          "text": "国太思来国太想，"
        },
        {
          "character": "杨波",
          "type": "二黄原板",
          "text": "谁是忠良哪个是奸党？"
        },
        {
          "character": "李艳妃",
          "type": "二黄原板",
          "text": "忠良本是徐、杨将， 奸党本是我父李良。 二卿不把国来掌， 哀家跪死在昭阳！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "铜锤一举娘娘请上，"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "杨波搀起定国王。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "回头来奏一道太平表章， 老杨波搬来了众家儿郎。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李艳妃",
          "type": "二黄摇板",
          "text": "听说是杨波搬兵到， 不由哀家喜眉梢。 太子交与小姐抱，"
        },
        {
          "character": "徐小姐",
          "type": "二黄摇板",
          "text": "双手付与老年高。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "用手接过大明后，"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "你保幼主坐龙楼。"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "用手接过龙一条， 两眼睁睁把臣瞧。 低下头来生计巧……"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "千岁！"
        },
        {
          "character": "杨波",
          "type": "二黄摇板",
          "text": "浑身上下似水浇，难以保朝。"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "大人不必生计巧， 你的心事某猜着， 莫不是保幼主嫌官小……"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "是与不是？"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "徐延昭、杨波",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "徐延昭",
          "type": "白",
          "text": "国太！"
        },
        {
          "character": "徐延昭",
          "type": "二黄摇板",
          "text": "加封杨波好保朝。"
        },
        {
          "character": "李艳妃",
          "type": "白",
          "text": "杨波听封！"
        },
        {
          "character": "杨波",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "李艳妃",
          "type": "二黄摇板",
          "text": "我封你七岁孩童戴纱帽， 九岁女儿进皇朝， 封你太子太保多荣耀，⑴ 子子孙孙爵禄高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李艳妃、徐小姐、宫女同下。"
        },
        {
          "character": "杨波",
