          "type": "白",
          "text": "好大方啊！"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "够大方的。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "吩咐他们谢过侯爷。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "是。 来，跟我谢赏。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "谢侯爷赏！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "罢啦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "问问樊江关有多少人马？"
        },
        {
          "character": "中军乙",
          "type": "白",
