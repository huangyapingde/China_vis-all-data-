        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "不算你哪？"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "那么就是三千。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "启禀侯爷：三千之众。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "三千之众？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "赏他们每人五两银子。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "是。 嘘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军甲以手示意叫中军乙。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "又什么事呀？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "我们侯爷有赏！"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "赏多少呀？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "每人五两银子。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "真大方。 启禀侯爷：樊侯爷有赏。"
        },
        {
          "character": "薛金莲",
