  "plot": "樊梨花挂帅西征，适值唐王和薛仁贵被敌包围，樊梨花的婆母柳迎春奉旨搬兵，同时，其小姑薛金莲亦押粮\n赶到，薛金莲怪樊梨花不立即驰救，同她吵闹。樊梨花竭力忍让，终因薛金莲相欺太甚，争斗起来。柳迎春\n劝解，薛金莲不听，樊梨花就把发兵的命令负气收回。薛金莲无可奈何，只得低头请罪；姑嫂言归于好，同\n往救驾。",
  "notes": "取材于民间所传薛家将征西的故事。\n整理本改动了以下几处：\n这个戏表现了樊梨花和薛金莲的性格矛盾，矛盾的根本原因原本没有点明，现在添了一段薛金莲的说白，表\n明她对樊梨花的挂帅，很不服气，作为她与樊梨花吵闹的心理因素。\n两个中军打架、吃酒闹事，现加强其各以自己的侯爷自负，因而相争；后来樊、薛和好，他们也和好了。这\n样使全剧主题更为集中。\n结尾加了薛金莲讨令做先行一段，使剧情更加完整，并突现了薛金莲的英雄性格。\n这个剧本是在一九五一年由中国京剧团演员云燕铭与本院（中国戏曲研究院）编辑处邱炘整理的，经过实验，\n效果很好，各剧团多已采用。最后并由王瑶卿先生亲自校正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、柳迎春同上。"
        },
        {
          "character": "柳迎春",
          "type": "念",
          "text": "奉了万岁旨，去调威宁侯。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "老身柳迎春。今有番邦苏宝童兴兵入寇，御驾亲征；不料圣上在锁阳关遭困； 我夫薛元帅在白虎关被围；是我奉了圣旨，去到樊江关调取威宁侯救驾解围。 军士们！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。柳迎春、四军士同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、女官、樊梨花同上。"
        },
        {
          "character": "樊梨花",
          "type": "点绛唇",
          "text": "女将英豪，兵机奥妙，威风浩，扶保唐朝，要把强敌扫。"
        },
        {
          "character": "樊梨花",
          "type": "念",
          "text": "杀气腾腾透九霄，战鼓咚咚逞英豪。威名赫赫谁不晓，夫妻双双保唐朝。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "本帅樊梨花。自幼熟读兵书，深通战法，配夫薛丁山；只因屡建奇功，圣上封 我威宁侯之位；统领人马，镇守樊江关一带。前日闻报，番邦苏宝童兴兵入寇， 圣上御驾亲征；为此每日操演人马，准备助战。 站堂军！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军甲上。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "启禀侯爷：圣旨下。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "何人押旨？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "太夫人押旨。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "吩咐香案接旨！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "香案接旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军甲下。四军士、柳迎春同上。四军士同下。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "圣旨下！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "跪听宣读。诏曰：今因番邦苏宝童兴兵入寇，御驾亲征；朕躬在锁阳关遭困， 薛元帅在白虎关被围；特命柳迎春捧旨前来调取威宁侯救驾解围。旨意读罢， 望诏谢恩。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "请过圣旨。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "香案供奉。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "婆婆请上待媳妇大礼参拜。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "不必拜了。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哪有不拜之理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花拜。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "媳妇坐下。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "谢座。婆婆一路行来，多受风霜之苦。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "为国宣劳，何言辛苦。媳妇可好？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "有劳婆婆挂念。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "这有你公爹捎来信一封，拿去观看。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "婆婆请到后帐歇息，待媳妇看过书信，即刻发兵就是。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "柳迎春",
          "type": "念",
          "text": "虽然年纪老，奉命不辞劳。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "送婆婆。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "免。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳迎春下。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "公公有书信到来，待我拆书观看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军甲上。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "报！启禀侯爷：今有铁门关薛侯爷，押解粮草到此交纳！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "噢！薛侯爷到了？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哎呀且住！想我那金莲妹子，平日性情高傲，今日押粮到此，必须与她个全脸。 来呀！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "吩咐摆队相迎！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "摆队相迎！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
