          "character": "薛金莲",
          "type": "白",
          "text": "哎，原赏退回！"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "得，玩儿完！ 嘘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军乙以手示意叫中军甲。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "又有什么事儿呀？"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "我们侯爷也有赏。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "赏多少？"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "照样儿……"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "也是每人五两？"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "原赏退回！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "好劲。 启禀侯爷：薛侯爷有赏。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "赏你们多少？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "照样儿。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "也是每人五两吗？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "原赏退回。把咱们那一份儿又给端回来啦。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "噢！把咱们那一份儿又给端回来啦？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "可不是嘛。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "过去谢赏吧。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "是啦。 来，跟我谢赏。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "谢侯爷赏！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "得啦，得啦，免了吧。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "赏薛侯爷的人马，四个人一桌，校场聚饮。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "是啦。 嘘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军甲以手示意叫中军乙。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "又什么事儿呀？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "我们侯爷，赏你们四个人一桌，校场聚饮。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "怎么着有酒喝？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "有的是，敞开儿乐。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "好啦。 启禀侯爷：樊侯爷又有赏！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "又赏你们什么？"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "赏我们四个人一桌，校场聚饮。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "去吧，可别喝醉了。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "遵命！ 走着，走着！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八军士、中军甲、中军乙同下。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嫂子，我刚才听说母亲到来，不知所为何事呀？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "只因圣上在锁阳关遭困，老元帅在白虎关被围，婆婆捧旨前来调我救驾解围； 还带来公爹书信一封，贤妹请看。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "信上写的都是什么言语哪？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我正待要看，忽听贤妹到来，急忙前去迎接，还没来得及看哪。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "如此待我观看。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "贤妹先请观看，我到后帐吩咐安排酒宴给婆母和妹妹接风，少时即来奉陪。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嫂子请。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "少陪了。"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "去到后帐备酒宴，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花下。"
        },
        {
          "character": "薛金莲",
          "type": "西皮摇板",
          "text": "忙把书信看一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲拆信。"
        },
        {
          "character": "薛金莲",
          "type": "西皮原板",
          "text": "为父修书不尽言， 晓谕梨花仔细观： 只因君父——"
        },
        {
          "character": "薛金莲",
          "type": "西皮二六板",
          "text": "身遭难， 望你发兵来救援； 早来三日还能见， 迟来三日难保全。 看罢书信心伤感！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "樊梨花呀，你可气死我啦！"
        },
        {
          "character": "薛金莲",
          "type": "西皮快板",
          "text": "怎不叫人怒冲冠！ 心中只把梨花怨， 还不发兵你为哪般？ 手指后堂高声喊，"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "樊梨花，你给我走出来吧！"
        },
        {
          "character": "薛金莲",
          "type": "西皮摇板",
          "text": "见死不救你心何安？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你呀！快给我走出来吧！"
        },
        {
          "character": "樊梨花",
          "type": "内西皮导板",
          "text": "看罢婆母忙回转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花上。"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "来到前帐把信观。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "可气死我啦！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "只见金莲沉粉面， 不知她发怒为哪般？ 只得上前问一遍， 贤妹因何怒冲冠？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，我说妹妹，你跟谁生这么大的气呀？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我跟你，我跟你，我简直地跟你嘛！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，为我什么呀！我怎么招妹妹生气啦？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我来问你：圣上在锁阳关遭困，老元帅在白虎关被围，圣旨命你发兵救驾，你 为何按兵不动，是怎么回事情？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "圣旨方才到来，命我锁阳关救驾，白虎关解围，正赶上妹妹你来，未及发兵， 怎见得我按兵不动？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我来问你，爹爹的书信你为什么不立刻观看哪？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "瞧瞧，你怎么这么矫情呀？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我怎么矫情啊？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "刚才我正要看信，忽然来报，说妹妹你来啦；我只顾带人迎接你去啦，信就没 顾得看。但不知信上写的都是什么？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "信上写的是：”早来三天还能见，晚来三天就难保全”。自古道：”救兵如救 火”，你怎么还这么没事人儿似的，拿事不当事哪！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，我多咱拿事不当事啦？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哼，你心里的事儿，我早就明白啦！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你明白什么啦？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "想当年程老千岁，强压着我哥哥三请于你，把你惯成了这么大模大样的。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我又大模大样的啦！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "如今你的官儿大啦，这架子也就更大起来啦。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，我架子又大啦！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我告诉你樊梨花！想当初你在樊江关，不过是个无名的丫头，自打到了我们家 来，你瞧，调兵遣将也是你，解围救驾也是你；皇上给你降旨，公婆求你发兵； 姑奶奶我给你押运粮草；我哥哥也在你帐前听用。你就在我跟前摆起来啦。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你瞧，我又摆起来啦！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "告诉你，你那根底，别当我不知道；你阵前嫁夫，逼父献关，还有脸在这儿摆 架子呢！别不害臊啦！今儿个有姑奶奶在这儿，什么事都得由着我，不能由着 你！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "金莲说话无情面， 出口伤人理不端。 本当与她把脸变，"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "怎么着，你还敢打我吗？给你打，给你打！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你到底不敢哪！"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "婆婆待我恩如山。 忍着怒气将她劝，"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "贤妹！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你少理我！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "贤妹不要乱胡言！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "樊梨花，樊梨花！你不用虚情假意的跟我装糊涂！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哈哈！你怎么张口樊梨花，闭口樊梨花的！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "叫啦叫啦！你敢把我怎么样？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "难道说，我就不敢叫你了吗？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你叫我什么？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我叫你薛……"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "薛什么？薛什么？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "得啦，我惹不起你，你是我一个人儿的薛姑娘，横是成了吧？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你别这儿瞎扯臊啦！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "怎么又瞎扯臊啦？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你想当今圣上管我叫姑娘，堂上父母也管我叫姑娘，合府大小哪一个不管我叫 姑娘。用的着你这儿来奉承！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哈哈！你真是有点儿欺人太甚，逼的哑巴都要说话啦！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你说吧，你说吧！还敢把我怎么样吗？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "瞧你这个横劲儿的，你当我真不敢叫你哪！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你叫我什么？你叫我什么？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我就不许叫你一声”薛金莲”！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哈哈！就凭你这个身份，也敢叫姑娘我的“官印”！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我这个身份怎么就叫不得哪？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你凭什么身份？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你听着！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你说呀！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我自幼熟读兵书，精通武艺；只因屡建奇功，圣上封我为威宁侯，天下都招讨 统兵大元帅。你又算得了什么哪？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我呀，比你可强的多哪！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你说呀！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你听着：我自幼学就了家传的武艺，在阵前屡建奇功，圣上封我为平西侯，镇 守铁门关……"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "还有什么？还有什么？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "什么这个、那个的？告诉你：铁门关的人听你这一套，来到我樊江关，就叫做 摆不开！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "什么！摆不开？我告诉你说：你当你拿出元帅的牌子来，我就怕了你了吗？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我也不能怕你呀！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我怕你吗？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我怕你吗？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你敢过来？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "过来又怎么样？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你呀，接嘴吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲打樊梨花。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "好哇，你要讲打吗？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "打了你啦；怎么样吧？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "好！你可气死我啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花、薛金莲同起打，双收下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
