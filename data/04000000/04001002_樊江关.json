      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八军士、中军甲、中军乙、薛金莲、樊梨花同上。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "贤妹此番押解粮草，多受风霜之苦！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "岂敢，为国勤劳，何言风霜二字哪！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "问问薛侯爷带来多少人马？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "是啦。 嘘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军甲以手示意叫中军乙。"
        },
        {
          "character": "中军乙",
          "type": "白",
          "text": "什么事儿呀？"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "我们侯爷问你们侯爷带来多少人马？"
        },
        {
          "character": "中军乙",
          "type": "白",
