        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "贤妹，贤妹请。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "不敢，嫂子请。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "还是贤妹请。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "还是嫂子请。"
        },
        {
          "character": "樊梨花",
