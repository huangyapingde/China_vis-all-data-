        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲上，樊梨花追上，柳迎春、旗牌同上。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "好蠢才，为着何事撒起野来了？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀，您听我说。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "婆婆，您听我说。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哎，有话慢慢讲。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈，我先说。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "好，就让你先说。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈、我告诉您：我说她，她也说我。我骂她，她也骂我。我打她，妈呀！她也 打我！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哎！岂有此理！ 啊，媳妇，你姑嫂二人这样吵闹，就不怕三军耻笑吗？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "婆婆呀！"
        },
        {
          "character": "樊梨花",
          "type": "西皮流水板",
          "text": "我未曾开言好羞惭， 尊一声婆婆听我言： 她怪儿发兵太迟慢， 她赖儿坐视不救援； 她骂儿逼父献关多轻贱， 她骂儿阵前嫁婿甚不堪。 婆婆请来把理辨， 你看她该言不该言？"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "唉，媳妇哇！"
        },
        {
          "character": "柳迎春",
          "type": "西皮摇板",
          "text": "金莲年幼见识浅， 说出的话儿不周全。 今日且看为娘面， 媳妇发兵莫迟延。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "媳妇遵命。 来呀！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "吩咐大小三军，披挂整齐，校场听点！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "慢着！ 我说妈呀，要说调兵遣将，我也会；要说救驾解围，我也能；干嘛非得她去？ 我就不能去啦吗？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "原令追回！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "唗！你这个丫头！想为娘千辛万苦，到此搬兵，你全不以国事为重，在一旁打 搅。也罢！为娘拼着这条老命不要。我要闯回白虎关去了！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀，您别走。你们快拉着点儿！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哼！可恶的丫头！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳迎春下。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你们快拉着点儿！你们倒是拉着点儿呀！ 妈呀妈呀！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我瞧谁敢拉着！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "这糟不糟！不论怎么说，她是个元帅，我是个小小的督粮官，元帅要是不发兵， 我那能做的了她的主意啊！可真难死我了！这可怎么好哪？不要紧，我们俩 个素常闹着玩惯啦！过去把圆乎脸一拉长乎脸，就完啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲陪笑。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我说嫂子，嫂子！哎哟！我的嫂子，我这儿……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲欲跪。女官暗上。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "薛侯爷请茶。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "不喝。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "喝一点儿吧。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "一点儿也不喝！"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "喝一丁点儿吧。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哎！再要在此打搅，提头来见！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "这女官乃圣上钦赐的，哪个敢杀，叫她杀！"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "我正懒得活着哪，请侯爷杀吧！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我呀，还没有那么大工夫哪！"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "怎么着，侯爷您不杀啦！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "起开吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女官下。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "得啦！嫂子您饶了我吧！我本当跪下给您陪个不是，因为我磕膝盖儿上长了一 个小疙瘩，我又怕格破了……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女官暗上。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "不要紧，给您个垫儿。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你给我下去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女官下。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "得啦！嫂子您别生气啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲跪。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，这是干什么呀？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "唉，嫂嫂啊……"
        },
        {
          "character": "薛金莲",
          "type": "西皮摇板",
          "text": "羞羞惭惭跪堂前， 尊声嫂嫂听我言： 小妹年轻见识浅， 还求嫂嫂你的海量宽。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哎哟！我的姑奶奶！方才还那么横呢，这么一会儿您就入地三尺啦！你跪在我 面前作什么呀？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "求嫂嫂锁阳关救驾，白虎关解围。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你不是说了吗？你的武艺比我高。你也能调兵遣将，你也能救驾解围，干嘛还 用得着我呀！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "那是我跟您吹着玩儿哪，您干嘛跟我们小孩子一般见识？得啦，我们都矬了一 半了！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你不用跟我来这一套“硬打软柔和”。这不成了笑话啦吗！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "薛金莲",
          "type": "西皮摇板",
          "text": "嫂嫂依然怒冲冠，"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "薛金莲",
          "type": "西皮摇板",
          "text": "不如死在你面前。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哎哟，我不活着啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花拦。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "妹妹不可！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我不活着了！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "为嫂我不恼你了！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "怎么着，嫂子不恼我啦？我也没打算死嘛！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你看咱们俩人竟在这儿捣乱啦，快瞧瞧老太太去吧！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "对啦，咱们快瞧瞧去吧。"
