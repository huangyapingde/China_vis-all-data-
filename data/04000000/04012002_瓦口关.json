          "character": "四蜀军",
          "type": "同白",
          "text": "有一贺成功。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "唤他进帐！"
        },
        {
          "character": "四蜀军",
          "type": "同白",
          "text": "贺成功进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺成功上。"
        },
        {
          "character": "贺成功",
          "type": "念",
          "text": "我作匠人手工能，描龙画凤点人形。"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "参见三将军。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "罢了。你叫什么名字？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "我叫贺成功。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你叫啥？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "贺成功。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咱的儿呀！得，叫应了！咱老张一定成功。照咱老张的模样，扎成一人，坐在 帐中眉眼自动，还要自斟自饮，你可会做？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "照您这样我做得来！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "几时做成？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "说得就得。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "快些做来！"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "咋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺成功下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军的！咱老张用计，你们不可走漏风声，听我令下！"
        },
        {
          "character": "张飞",
          "type": "西皮散板",
          "text": "传将令众三军仔细思量， 假意儿饮酒醉来把他诓； 小张郃他若来必定上当， 夺取了瓦口关扶保兄王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺成功上。"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "启三将军，造成了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "搭上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺成功搭上假张飞。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "待咱看来。嘿！为何这样黑啾啾的？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "还没开光哪。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "快些开来！"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "咋，开光啦！三将军请看。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞两看。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "果然不错。贺成功，只是眉眼怎么不能自动？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "有个消息。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "耳朵上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你且演来！"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "您瞧着。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "他怎样自斟自饮呢？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "您拿根棍一捅他腰眼，他就能自斟自饮。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿我的鞭头子来！"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "您的鞭头子我拿不动。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "拿着吧！"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "哎哟！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "怎么样了？"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "没砸着。您看着！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈哈哈！待俺试验。哈哈，果然不错。 来！赏贺成功五两银子，不可走漏消息！"
        },
        {
          "character": "贺成功",
          "type": "白",
          "text": "多谢三将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺成功下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军的！将此麦人搭在后帐，张郃若来，定中老张之计也！"
        },
        {
          "character": "张飞",
          "type": "西皮流水板",
          "text": "正在营中无计行， 魏将军押酒来大营。 咱思量造个假人把计定， 偏偏地营中有个巧匠他叫什么贺成功。 此人生来有本领， 他造得与老张天生一般真真的好威风； 自斟自饮眉眼自活动。 到三更设空营，我定要生擒张郃小儿立奇功。 三军候令齐出动！ 管叫他难逃我的巧计牢笼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八魏军、张郃同上。"
        },
        {
          "character": "张郃",
          "type": "西皮摇板",
          "text": "身在曹营为大将， 岂能轻率无主张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "拿住奸细。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "绑上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范疆、张达同上。"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "参见将军！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "唗！你二人可是张飞营中的奸细？"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "不是，不是！只因张飞好酒贪杯，不理军情鞭打士卒，赏罚不明；我们在他帐 中无有出头之日，特来投降帐下，望将军收录。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "好，将他二人绑至城楼一观。带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃上城。四蜀军同上。"
        },
        {
          "character": "蜀军甲",
          "type": "白",
          "text": "众位请了！可恨张飞好酒贪杯，不理军情，赏罚不明；我们在他帐中无有出头 之日，大家散了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀军同下。"
        },
        {
          "character": "张郃",
          "type": "三笑",
          "text": "啊哈，啊哈，啊哈哈……"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "回营。 来，与他二人松绑！张飞营中混乱，正好袭取。 众将官！今夜饱餐战饭，随我偷营劫寨去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。四马童、张飞搭假张飞同上。八魏军、范疆、张达、张郃同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张飞！死在眼前，你还不知。看枪！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "张郃！咱的儿呀！中了你三爹爹的计了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、张郃同起打，张郃败下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀军、魏延同上。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "某，魏延。奉了三将军之命，埋伏瓦口关西南角下，截杀张郃。就此前往！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。张郃上。张飞追上。魏延上，起打，张郃败下。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "跑了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同追下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀军、黄忠、严颜、刘备、诸葛亮同上。"
        },
        {
          "character": "蜀军",
          "type": "同白",
          "text": "来到瓦口关！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二位老将，上前叫城！"
        },
        {
          "character": "黄忠、严颜",
          "type": "同白",
          "text": "呔！城上儿郎听者：元帅回来，快快开城！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开城。众人同进城。四魏军、张郃同败上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "且住！中了张飞疑兵之计，有此一败，退回关去再作道理。 呔！城上儿郎听者：主帅回来，快快开城！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "张郃来了，二位老将，开城杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、严颜同出城，同起打，张郃败下，黄忠、严颜同进城。四马童、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "张郃哪里去了？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "望风而逃。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "不必追赶，兵取瓦口关！ 呔！城上儿郎听者：你家主帅被咱杀败，快快开城献关，尔等一概免罪！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "城下来的敢是三将军？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊，城上答话，如此耳熟，好像我家先生；他怎么来到此地？待我冒叫一声。 城上答话者，可是诸葛先生？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "正是山人。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生，你倒先来了。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "等候多时了！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你快快地开门吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同进城，同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀军、黄忠、严颜、刘备、诸葛亮、四马童、张飞同上。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟成功，可喜可贺！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "一来大哥洪福，二来先生妙算，小弟何功之有？啊先生，咱老张谢谢你了！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢山人何来？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "谢谢你的美酒。若不是魏将军押酒前来，咱老张安能有计，这瓦口关怎能唾手 而得？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这是三将军之功。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "后帐摆筵，与三弟贺功！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "谢主公！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}