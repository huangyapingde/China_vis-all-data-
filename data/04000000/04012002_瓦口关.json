{
  "script_id": "04012002",
  "title": "瓦口关",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "诸葛亮",
      "hangdang": "生"
    },
    {
      "name": "刘备",
      "hangdang": "生"
    },
    {
      "name": "魏延",
      "hangdang": "净"
    },
    {
      "name": "范疆",
      "hangdang": "丑"
    },
    {
      "name": "张达",
      "hangdang": "丑"
    },
    {
      "name": "张郃",
      "hangdang": "净"
    }
  ],
  "plot": "张飞讨令攻取瓦口关，刘备和诸葛亮怕他酗酒误事，命他戒酒。把守瓦口关的魏将张郃战不过张飞，乃坚守\n不出。张飞使军士辱骂，并终日聚饮以示轻敌。张郃终不出战。张飞的部下将他违令饮酒的情形密报诸葛亮。\n诸葛亮测知其意，反命大将魏延押送美酒给张飞。张飞得到魏延的援军，乃定计命部下假作怨恨离心，以\n诱张郃。张郃果然中计，率兵偷袭，大败。这时刘备、诸葛亮亲率大军已到关前，乘虚占领瓦口关。",
  "notes": "《瓦口关》故事出于《三国演义》。这个剧本是由中国京剧团演员袁世海和本院编辑处朱慕家共同整理的；\n并经郝寿臣先生订正。原本基础较好，整理时只就个别细节略为修改。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀军引刘备、诸葛亮同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "桃园结义聚英雄，协力同心。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "运用机谋晓兵法，攻守皆能。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "家住在大树楼桑，请诸葛三顾山冈。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "学孙武排兵布阵，灭孙曹重整家邦。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "刘备。三顾茅庐，聘请诸葛先生，重整汉室基业。 啊先生，孤有意夺取瓦口关，以通北伐道路，先生有何妙计？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "何不派三将军前往？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我三弟虽勇，只是他性情刚暴，好酒贪杯，恐难胜任。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人自有安排。 来！三将军进帐！"
        },
        {
          "character": "蜀军",
          "type": "同白",
          "text": "三将军进帐！"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "豹头环眼须似钢，大吼一声断桥梁。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "参见大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "罢了！见过先生。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三将军请坐。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "谢座。唤小弟进帐，有何军情议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生有差。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生有何差遣？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公意欲夺取瓦口关。想那瓦口关守将张郃，乃是有名战将；因此命三将军去 到夏口，调四将军回营，大战张郃。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生哪！既要夺取瓦口关，何劳四将军回营？赐某一支将令，愿生擒张郃入帐！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "想那张郃乃曹营有名上将，三将军恐非他人对手！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "先生哪！咱老张出师以来，在虎牢关战吕布，枪挑贼的紫金冠；在当阳桥前， 单人独骑，喝退曹兵百万。何况那张郃匹夫！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟，想那张郃不好饮酒，三弟最爱饮酒，犹恐误了军情大事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "着哇！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哦哦是了，听你们之言，恐咱饮酒误了军情。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "也罢！今当大哥、先生面前，把这酒——"
        },
        {
          "character": "刘备、诸葛亮",
          "type": "同白",
          "text": "怎么样？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我就戒了它。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，三弟要戒酒？ 来，看酒来，看酒来！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊，这是何意呢？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "与三弟戒酒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嘿，上了他们的当了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟呀！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "手挽手儿把话论， 愚兄言来听分明： 今日开怀来畅饮， 戒酒之事要谨记在心。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "接过兄长酒一樽， 戒酒之事记在心； 回头再对大哥论， 夺取瓦口定把功成。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "范疆、张达进帐！"
        },
        {
          "character": "蜀军",
          "type": "同白",
          "text": "范疆、张达进帐！"
        },
        {
          "character": "范疆、张达",
          "type": "内同白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范疆、张达同上。"
        },
        {
          "character": "范疆、张达",
          "type": "同念",
          "text": "将相本无种，男儿当自强。"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "见过军师！"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "参见军师，有何差遣？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "三将军带兵夺取瓦口关，奉令戒酒。命你二人跟随前去；倘若私自饮酒，拿你 二人治罪！"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀，先生，你忒也地小心了！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人不得不小心。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥、先生请至后帐！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟多加小心！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "弟知道了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、诸葛亮同下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "军士们走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四马童、四蜀军同上。"
        },
        {
          "character": "四蜀军",
          "type": "同白",
          "text": "参见三将军！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "站下！咱老张奉命夺取瓦口关，众将必须奋勇当先，听咱一令！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "钢鞭蛇矛威名显， 三军在后己在先。 鼓打三通催前站，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞脱袍、持矛上马。"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "此番定取瓦口关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八魏军引张郃同上。"
        },
        {
          "character": "张郃",
          "type": "点绛唇",
          "text": "河北名将，扶保魏王，韬略广，力战疆场，要把狼烟扫荡。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "瓦口关前旌旗飘，英雄志气比天高。有日卸甲朝金阙，不动掌中七宝刀。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "某，张郃。奉曹洪元帅之命，前来护守东川。昨日马超遣部将出兵葭萌关，被 某战败。今闻巴西守将张飞，兵屯下汴地方，欲来取关；此事不可大意且听探 马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报。 启禀将军：今有张飞带领人马前来取关。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "且住！张飞前来取关，岂肯容他猖狂！ 众将官，带马杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀军、四马童、张飞同上。会阵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "马前来的，可是张郃？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "张郃，咱的儿啊！既知三爹爹兴兵到此，就该献关投降；如若不然，矛下作鬼！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张飞！俺奉魏王钧命，镇守瓦口关；尔有多大本领，敢来取关？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "若问俺的本领，尔且稳坐雕鞍，听俺道来！"
        },
        {
          "character": "张飞",
          "type": "西皮快板",
          "text": "勒住丝缰把话讲， 张郃小儿听端详： 鞭打督邮惊奸党， 虎牢关前把名扬， 长坂坡独把曹贼挡， 大吼一声断桥梁； 劝你早把瓦口让， 稍若迟延枪下亡。"
        },
        {
          "character": "张郃",
          "type": "西皮摇板",
          "text": "老爷河北称名将， 东战西杀扶魏王； 今日相逢战场上， 快快下马来投降！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "胜败不知胡乱讲， 会战三合看谁强！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八魏军、四蜀军、四马童自两边分下，张飞、张郃同起打，张郃败下，张飞追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八魏军、张郃同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "哎呀且住！张飞杀法骁勇。 众将官！兵退岩渠山！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。四蜀军、四马童、范疆、张达、张飞同上。"
        },
        {
          "character": "蜀军",
          "type": "同白",
          "text": "来到岩渠山。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "向前攻打！"
        },
        {
          "character": "蜀军",
          "type": "同白",
          "text": "免战高悬。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！张郃！先前怎样夸口，如今被你三爹爹杀得缩头不出，令人好笑！"
        },
        {
          "character": "张飞",
          "type": "三笑",
          "text": "啊哈，啊哈，啊哈哈……"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军的！暂且回营歇息，少时再来攻打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。八魏军、张郃同上，张郃上城。"
        },
        {
          "character": "张郃",
          "type": "西皮散板",
          "text": "只说张飞性卤莽， 谁知英勇非寻常。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "且住！虽然悬起免战牌，张飞退去，少刻必来骂阵。 众将官！俺如今只要紧守山寨，多置滚木擂石，坐守不战；每日大吹大打，山 头饮酒作乐，以劳其兵，候他粮尽，自然退却，那时下山追杀，张飞纵勇，谅 他难逃此妙计也！"
        },
        {
          "character": "张郃",
          "type": "西皮散板",
          "text": "停兵不战高山上， 多加小心只谨防； 吹打饮酒且欢畅， 候他退兵自有主张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀军、四马童、范疆、张达、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "西皮散板",
          "text": "适才一战贼丧胆， 勇比军中楚霸王。 歇息再把山头抢，"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "众将官！饮酒哇！哈哈哈！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "张飞",
          "type": "西皮散板",
          "text": "又见张郃饮猖狂。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！张郃！尔自称英雄，今日为何不敢出战？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "众将官！饮酒哇！哈哈哈！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀，好欺我也！"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "曹操奸雄枉用将， 这装聋作哑酒饭囊； 张爷说来儿细想， 那缩头的龟儿比你强！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "众将官！张飞乃一勇夫，倘来讨战，不必理他。我们还是饮酒哇！哈哈哈！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "这厮可恶已极！本当抢上攻打，有恐他滚木擂石打将下来，这便怎么处？有了。 三军的！你们可有会骂的？"
        },
        {
          "character": "二蜀军",
          "type": "同白",
          "text": "有会骂的。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好向前骂来！"
        },
        {
          "character": "蜀军甲",
          "type": "白",
          "text": "得令。 呔！张郃！退到山上，战又不战，降又不降，真乃匹夫之辈！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "尽力叫骂那厮！"
        },
        {
          "character": "蜀军乙",
          "type": "白",
