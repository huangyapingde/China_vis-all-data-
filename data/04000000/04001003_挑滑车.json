{
  "script_id": "04001003",
  "title": "挑滑车",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "高宠",
      "hangdang": "武生"
    },
    {
      "name": "牛皋",
      "hangdang": "净"
    },
    {
      "name": "兀术",
      "hangdang": "武净"
    },
    {
      "name": "岳飞",
      "hangdang": "老生"
    }
  ],
  "plot": "金兀术将康王（后来的宋高宗）围困在牛头山。宋军统帅岳飞派牛皋到金营下战书。兀术对牛皋不予礼遇，\n并加以威吓；牛皋毫无畏惧，言辞抗议，兀术不得已待以上宾之礼。两军会阵之日，岳飞败于兀术。在山头\n看守宋军大纛的猛将高宠，见状情急；一马冲下山坡，解了岳飞之围，并奋勇地冲入敌营。兀术急命部下以\n铁滑车自山头滑下，阻击高宠；高宠奋不顾身，连续枪挑滑车多辆，鼓勇冲上，终以力尽战死。岳飞、牛皋\n闻讯，悲愤交加，率兵力战，抢回了高宠的尸体。",
  "notes": "这是源出于《岳传》的一节故事。\n整理本除了个别词句略加润色以外，较重要的改动有下面几点：\n一、旧本下书后，尚有牛皋归途中遇王贵，捉杀小番，以备祭旗，以及兀术问报，哈密蚩献计，亦以张邦昌\n等祭旗等情节。因与剧情关联不大，故删去。\n二、岳飞不派高宠出战，旧本的原因是由于见高宠“印堂发暗”；语涉迷信，故予改动。\n三、现在一般演出，至高宠战死即闭幕，剧情不够完整；整理本保留岳飞、牛皋打败金兵的一场，不仅可表\n现岳飞、牛皋对高宠的情谊，而且可以显出宋军当时的胜利气概。\n四、高宠战死后，旧本有显魂情节，今删去。\n这个本子系北京戏曲实验学校茹富兰及中国京剧团演员王玉让、景荣庆、何金海等与本院（中国戏曲研究院）\n编辑处邱炘共同整理的；李少春在若干具体问题上，也提供了意见。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八金兵推铁滑车引土须龙、土须虎、金光德照、金光普照、黑风利同上。"
        },
        {
          "character": "黑风利",
          "type": "白",
          "text": "催军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同走圆场。"
        },
        {
          "character": "黑风利",
          "type": "白",
          "text": "俺，大平章黑风利。"
        },
        {
          "character": "金光德照",
          "type": "白",
          "text": "金光德照。"
        },
        {
          "character": "金光普照",
          "type": "白",
          "text": "金光普照。"
        },
        {
          "character": "土须龙",
          "type": "白",
          "text": "土须龙。"
        },
        {
          "character": "土须虎",
          "type": "白",
          "text": "土须虎。"
        },
        {
          "character": "黑风利",
          "type": "白",
          "text": "众位平章请了。"
        },
        {
          "character": "土须龙、土须虎、金光德照、金光普照",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "黑风利",
          "type": "白",
          "text": "奉了老王之命，押定铁滑车，牛头山前听用。众位平章请来传令。"
        },
        {
          "character": "土须龙、土须虎、金光德照、金光普照",
          "type": "同白",
          "text": "你我一同传令。"
        },
        {
          "character": "黑风利、土须龙、土须虎、金光德照、金光普照",
          "type": "同白",
          "text": "儿郎的。催军！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵、岳飞同上。"
        },
        {
          "character": "岳飞",
          "type": "引子",
          "text": "忠心赤胆，扫狼烟，还我河山。"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "精忠报国志凌霄，统领雄兵杀气高。但愿早把金人扫，迎请二圣转还朝。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅姓岳名飞字鹏举。宋皇驾前为臣。可恨兀术，屡次兴兵犯境，日前将我主 围困牛头山上；本帅整顿兵马，意欲与他决一死战。不免命牛皋去至番营，投 下战书。 站堂军，请牛将军进帐。"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "牛将军进帐。"
        },
        {
          "character": "牛皋",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋上。"
        },
        {
          "character": "牛皋",
          "type": "念",
          "text": "杀气高千丈，宝剑似秋霜。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "贤弟少礼，一旁坐下。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "谢座。唤末将进帐，有何军情议论？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅意欲与兀术决一死战，有意命贤弟投下战书，贤弟意下如何？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "末将情愿前往，就请元帅传令。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "好，听本帅令下！"
        },
        {
          "character": "岳飞",
          "type": "西皮摇板",
          "text": "前去下书非交战， 礼当扮做文职官。 此番见了兀术面， 见机而行早回还。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "元帅！"
        },
        {
          "character": "牛皋",
          "type": "西皮流水板",
          "text": "元帅但把心放宽， 咱牛皋自有巧机关。 此一番见了番王面， 哪怕他千军万马虎穴与龙潭。 摘去了幞头就忙把乌纱换，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋下。"
        },
        {
          "character": "岳飞",
          "type": "西皮摇板",
          "text": "忙把书信写一番。⑴ 三日之后来交战， 两军会阵牛头山。 修罢书信把牛皋唤，"
        },
        {
          "character": "四宋兵",
          "type": "同白",
          "text": "牛将军进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋上。"
        },
        {
          "character": "牛皋",
          "type": "笑",
          "text": "哈哈哈。"
        },
        {
          "character": "牛皋",
          "type": "西皮流水板",
          "text": "一霎时扮做文职官。 辞别元帅跨雕鞍， 虎穴龙潭走一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵、岳飞同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四金兵、兀术同上。"
        },
        {
          "character": "兀术",
          "type": "西皮摇板",
          "text": "牛头山前打一仗， 宋营将士个个强。 将身坐在牛皮帐， 且听儿郎报端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！启禀狼主：牛皋前来下战书。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哦，牛皋前来下战书！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好！吩咐弓上弦，刀出鞘，牛皋到此，叫他报门而进！"
        },
        {
          "character": "报子",
          "type": "四金兵持刀同暗上。",
          "text": ""
        },
        {
          "character": "牛皋",
          "type": "内白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋上。"
        },
        {
          "character": "牛皋",
          "type": "西皮流水板",
          "text": "元帅帐中将令传， 命俺下书到此间。 来在番营用目看，"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "呔！牛皋，狼主叫你报门而进！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "叫你报门而进！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "小小番营甚威严。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哎呀且住！那兀术传下话来，叫俺报门而进；俺若报门，岂不弱了俺宋营的锐 气？这……有了，俺不免大摇大摆闯进帐去，他有来言，咱有去语。"
        },
        {
          "character": "牛皋",
          "type": "西皮流水板",
          "text": "兀术把人来小量， 不由俺怒气满胸膛。 大摇大摆我把宝帐闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四金兵同举刀作威吓状。"
        },
        {
          "character": "牛皋",
          "type": "唱",
          "text": "生死二字哪在心旁。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "请了，请了！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "唗！大胆牛皋，进得帐来，见了孤家，大摇大摆，难道你不知昌平王的厉害！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哼！我也不管你是长平王啊，还是短平王，咱牛皋也曾做过公道大王。俺今奉 了宋皇圣旨，元帅将令，前来下战书，到此乃是客位，你就该下位迎接你牛将 军才是正理；怎么你反坐在上面，是这样大模大样，自尊自大？想这自大乃是 个臭字，有道是”臭而不可闻也”哟！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "如此说来，你不怕死？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "咱牛皋一生一世就是不怕死。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "不怕死便怎么样？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "你就该下得位来，迎接你牛将军才是。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好，孤家离位。 啊，牛将军！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "狼主！"
        },
        {
          "character": "兀术、牛皋",
          "type": "同笑",
          "text": "啊哈哈……"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "请坐。不知牛将军驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "岂敢。俺来的鲁莽，狼主海涵。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "岂敢。牛将军为何这样打扮？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "俺奉元帅将令，前来下战书，一不交锋，二非骂阵，故而这样文绉绉的。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "战书今在何处？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "战书在此，狼主请看。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "待孤拆书一观。 啊，牛将军，回复你家元帅，照书行事，三日之后，牛头山前会战。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哦，三日之后，牛头山会战。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "好，咱告辞了。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊，狼主，这就是你的不是了。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "怎么是孤家的不是了？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "咱牛皋远路而来，到此连杯水酒都不曾吃，难道说白白的回去不成？"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "啊，牛将军要饮酒？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "有酒我就扰你两盅儿。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "儿郎的，酒筵摆下。 牛将军请。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "狼主请。 啊，狼主，今日你我在帐中饮酒，日后在两军阵前，还不知谁要谁的命哪！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "此乃各为其主。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "好个各为其主。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兀术、牛皋同饮酒。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "牛将军再饮几杯。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "酒已够了，我要回营交令去了。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "不送。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊，狼主，这又是你的不是了。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "怎么又是孤家的不是了？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "你既不接俺进帐，就该送俺出去的才是。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "哦，还要孤家送你一程？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "那个自然。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "好，待孤家相送。请。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊，狼主，咱牛皋今日吃了你的酒，我这心中有些过意不去。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "依牛将军之见呢？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "也罢，日后到了两军阵前，我少打你几鞭头子，也就是了。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "如此说来，孤家倒要承你的情了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "岂敢，岂敢！"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "孤家不远送了。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋暗笑，下。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "且住！宋营之中，竟有这样心粗胆壮之人。只恐宋室江山，一时难以到手。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "诸位平章到。"
        },
        {
          "character": "兀术",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。土须龙、土须虎、金光德照、金光普照、黑风利同上。"
