    }
  ],
  "plot": "蜀、魏之战，司马懿兵至祁山，因街亭是汉中咽喉要地，诸葛亮料定魏军必来夺取，须派大将镇守；帐下参\n军马谡请令，诸葛亮再三叮咛马谡，此去必须小心谨慎，靠山近水安营扎寨，并命王平同往辅之。马谡刚愎\n自用，不听王平谏言，竟在山顶扎营，因而街亭失守。诸葛亮接到王平送来的地理图形，已料到街亭难保，\n闻报果然；时所部精锐都已调遣在外，西城空虚。旋又得报：司马懿挥军乘虚而进，诸葛亮在危急之中，定\n下空城之计；吩咐将城门大开，他羽扇纶巾，稳坐城楼，抚琴饮酒，悠然自若。司马懿素知诸葛亮用兵谨慎，\n从不弄险，误以城中必有埋伏，乃命大军后退四十里，不敢进城。及至探明确是空城，卷土重来时，诸葛\n亮调回的赵云援军已经赶到，西城才得无虞。马谡不遵将令，贻误军机，诸葛亮挥泪斩之。并因自己任人不\n当，奏明幼主，自请罪责。",
  "notes": "《空城计》故事取材于《三国演义》。\n这个剧本是由演员谭富英、裘盛戎、袁世海及郝寿臣先生共同整理的。原剧相当完整，整理时仅对剧中个别\n不通顺的字句稍予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵云上，起霸。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "二十年前挂铁衣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱上，起霸。"
        },
        {
          "character": "马岱",
          "type": "念",
          "text": "万马军中无人敌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平上，起霸。"
        },
        {
          "character": "王平",
          "type": "念",
          "text": "一片丹心扶社稷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上，起霸。"
        },
        {
          "character": "马谡",
          "type": "念",
          "text": "协力同心保华裔。"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "赵云。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "马谡。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "马岱、王平、马谡",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "丞相升帐，你我两厢伺候！"
        },
        {
          "character": "马岱、王平、马谡",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵引诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "羽扇纶巾，四轮车，快似风云；阴阳反掌定乾坤，保汉家，两代贤臣。"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "忆昔当年在卧龙，万里乾坤掌握中。扫荡狼烟归汉统，方显男儿大英雄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老夫，复姓诸葛名亮，字孔明，道号卧龙。先帝托孤以来，扫荡中原，扭转汉 室。闻听司马懿兵至祁山，必然夺取街亭。我想街亭，乃汉中咽喉之地，必须 遣一能将前去防守，方保无虑。 众位将军！"
        },
        {
          "character": "赵云、马岱、王平、马谡",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哪位将军愿带人马，镇守街亭，敢当此任？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "且住！丞相传令：哪位将军愿统领人马镇守街亭？满营将官并无一人应声，待 俺马谡进帐讨令。 启禀丞相：末将不才，愿统领人马，镇守街亭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那司马懿虽然年迈，用兵如神，将军你不可轻敌。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！末将跟随丞相出兵多年，攻无不取，战无不胜；何况那小小的街亭！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "街亭虽小，干系甚重啊！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "末将此去，倘有疏虞，愿当军令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军中无有戏言。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "愿立军令状。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "好，当帐立来！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "遵命。 马谡呵……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。马谡写军令状。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相请看。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "帐外候令。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军！"
        },
        {
          "character": "赵云、马岱、王平",
          "type": "同白",
          "text": "丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哪位将军愿带领兵马，协同马谡共守街亭，当帐请令。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平愿往。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "王将军愿往？"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "当报国恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "此番到了街亭，必须要靠山近水，安营扎寨；扎寨之后，画一图形，送来我看。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王平下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "赵老将军听令！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你带领三千人马，镇守列柳城。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马岱听令！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你解押粮草，军前听用。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "马谡进帐！"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "马谡进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡上。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "谢座。末将正在整顿人马，丞相呼唤，不知有何密令？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今逢大敌，非比寻常。我有一言，将军听了!"
        },
        {
          "character": "诸葛亮",
          "type": "西皮原板",
          "text": "两国交锋龙虎斗， 各为其主统貔貅。 管带三军要宽厚， 赏罚中公平莫要自由。 此一番领兵去镇守， 靠山近水把营收。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "丞相不必叮咛就，"
        },
        {
          "character": "马谡",
          "type": "西皮流水板",
          "text": "马谡忠心扶龙楼。 此番领兵街亭守，"
        },
        {
          "character": "马谡",
          "type": "西皮摇板",
          "text": "好似顺水去行舟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "先帝爷白帝城叮咛就， 汉诸葛扶幼主岂能无忧。 但愿得此一去扫平贼寇， 也免得我亲自去把贼收。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、诸葛亮同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、马谡同上。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "俺，马谡。奉了丞相将令，镇守街亭。不知何人挂了副帅？ 来！"
        },
        {
          "character": "四蜀兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "伺候了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵引王平同上，王平下马。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "参见元帅。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "噢，原来是王将军的副帅。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "伺候元帅。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "此番到了街亭，必须要协力同心，奋勇杀贼！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "那个自然。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "请来传令。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "不敢，元帅传令。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "你我一同传令。 众将官！"
        },
        {
          "character": "八蜀兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "马谡、王平",
          "type": "同白",
          "text": "兵发街亭。"
        },
        {
          "character": "八蜀兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵引司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郞虎豹，传令号，地动山摇，要把西川扫。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "白发苍苍似银条，胸中韬略智谋高。一心要把狼烟扫，丹心一片保皇朝。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本督，司马懿。适才探马报道：诸葛亮令马谡镇守街亭，正好夺取。 来！"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "传张郃进帐！"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "张郃进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃上。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "大将真威勇，上阵立奇功。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "参见都督。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "罢了。命你带领本部人马，夺取街亭，不得有误！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": "四魏兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八蜀兵引王平、马谡同上。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "人马为何不行？"
        },
        {
          "character": "八蜀兵",
          "type": "同白",
          "text": "来到街亭。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "人马列开。"
        },
        {
          "character": "八蜀兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡对王平。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "你我下马登山一望。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡、王平同下马，同上山。马谡望。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "哈哈哈……王将军！你看：街亭形势扶山带水，只有东西通衢，真乃坚固之地。 你我就在山顶扎营，得观四方，战守自便，必成大功。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "啊，元帅，你我临行之时，丞相吩咐我等：必须要靠山近水，安营扎褰。若在 山顶扎营，倘若魏兵到此，将此山团团围住，如何抵挡？"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "司马若是进兵，必从低处而来；我在高峰，多用滚木垒石，从上打下，势如破 竹，你何必多虑呢！"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "元帅此言差矣。我看此山孤立无援，乃是绝地，倘若魏兵到来，断我汲水之路， 我军不战自乱矣！"
        },
        {
          "character": "马谡",
          "type": "白",
