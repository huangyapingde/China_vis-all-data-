        {
          "character": "诸葛亮",
          "type": "西皮散板",
          "text": "退司马保空城全仗此琴。"
        },
        {
          "character": "司马懿",
          "type": "内西皮导板",
          "text": "大队人马往西城，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四魏兵、司马昭、司马师引司马懿同上。司马懿一望。"
