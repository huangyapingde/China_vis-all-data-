{
  "script_id": "04017001",
  "title": "战太平",
  "alias": [
    "花云带箭；一名：太平城"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "花云",
      "hangdang": "老生"
    },
    {
      "name": "陈友谅",
      "hangdang": "净"
    },
    {
      "name": "朱文逊",
      "hangdang": "小生"
    },
    {
      "name": "孙氏",
      "hangdang": "旦"
    },
    {
      "name": "郜氏",
      "hangdang": "旦"
    },
    {
      "name": "花安",
      "hangdang": "丑"
    },
    {
      "name": "陈友杰",
      "hangdang": "副净"
    }
  ],
  "plot": "元末花云辅佐朱元璋之侄朱文逊驻守太平。陈友谅进袭，花云奋勇抵御，但因采石矶守将乏人，被陈友谅暗\n袭破城。花云拟突围，而朱文逊贪恋家眷，贻误时机，与花云同时被擒。陈友谅逼降，朱文逊屈膝被杀。花\n云坚决不降，并在法场上挣断绑绳，力杀多人，卒因中箭伤重，自刎而死。",
  "notes": "《战太平》的故事，取材于《明史》和李冬阳《花将军歌》。这个整理本，中国京剧团演员李少春和本院\n（中国戏曲研究院）编辑处陶君起共同整理的。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（郜氏抱小儿、孙氏同上。）⑴"
        },
        {
          "character": "郜氏",
          "type": "念",
          "text": "夫受皇家禄，"
        },
        {
          "character": "孙氏",
          "type": "念",
          "text": "妻沾雨露恩。"
        },
        {
          "character": "花云",
          "type": "内白",
          "text": "回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、花安、花云同上，花云下马，四军士同下。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "可恼！"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同白",
          "text": "老爷今日回府，为何这等烦恼？"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "夫人有所不知，只因陈友谅带兵夺取太平城，千岁命我回府披挂，埋伏闸子口， 只是采石矶头缺一能将，故而烦恼。"
        },
        {
          "character": "郜氏",
          "type": "白",
          "text": "食王爵禄，当报王恩；老爷请至将房披挂，待妾身等点动人马。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "有劳夫人。正是："
        },
        {
          "character": "花云",
          "type": "念",
          "text": "青龙背上屯军马，"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同念",
          "text": "白虎当头休扎营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同白",
          "text": "花安过来，传我将令：吩咐大小三军齐至二堂听点！"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "得令！ 下面听者：夫人有令，吩咐大小三军齐至二堂听点！"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同二黄导板",
          "text": "在二堂替夫君忙传将令，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士同上。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "参见夫人。"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同白",
          "text": "站立两厢！"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "孙氏",
          "type": "回龙",
          "text": "叫一声众三军细听分明："
        },
        {
          "character": "郜氏",
          "type": "二黄快三眼",
          "text": "都只为陈友谅兴兵犯境，"
        },
        {
          "character": "孙氏",
          "type": "二黄快三眼",
          "text": "千岁爷命将军带兵出征。"
        },
        {
          "character": "郜氏",
          "type": "二黄快三眼",
          "text": "向前者一个个俱有封荫，"
        },
        {
          "character": "孙氏",
          "type": "二黄快三眼",
          "text": "后退者一个个插箭游营。"
        },
        {
          "character": "郜氏",
          "type": "二黄快三眼",
          "text": "耳边厢又听得铠甲声震，"
        },
        {
          "character": "孙氏",
          "type": "二黄快三眼",
          "text": "想必是我老爷披挂来临。"
        },
        {
          "character": "花云",
          "type": "内二黄导板",
          "text": "头戴着紫金盔齐眉盖顶，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上，起霸。"
        },
        {
          "character": "花云",
          "type": "二黄散板",
          "text": "为大将临阵时哪顾得残生！ 撩铠甲且把二堂进—— 有劳夫人点雄兵。"
        },
        {
          "character": "郜氏",
          "type": "白",
          "text": "花安看酒！"
        },
        {
          "character": "郜氏",
          "type": "二黄散板",
          "text": "花安看过酒一樽，"
        },
        {
          "character": "孙氏",
          "type": "二黄散板",
          "text": "我与老爷来饯行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云接酒。"
        },
        {
          "character": "花云",
          "type": "二黄散板",
          "text": "接过夫人得胜饮， 背转身来谢神灵。 辞别夫人足踏镫——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上马，四军士、花安同下。"
        },
        {
          "character": "花云",
          "type": "二黄散板",
          "text": "但愿此去扫荡烟尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        },
        {
          "character": "郜氏",
          "type": "二黄散板",
          "text": "老爷上马威风凛，"
        },
        {
          "character": "孙氏",
          "type": "二黄散板",
          "text": "但愿此去退贼兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郜氏、孙氏同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众军士、陈友杰、花云自两边分上，会阵。"
        },
        {
          "character": "花云",
          "type": "二黄散板",
          "text": "一见贼子怒气发， 不由老爷咬银牙。 我主洪福齐天大， 把尔比做井底蛙！"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "陈友杰",
          "type": "二黄散板",
          "text": "劝你早把太平让， 稍若延迟枪下亡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云、陈有杰同起打。众军士同下。花云、陈友杰同开打，陈友杰败下，花云追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、陈英豹同上。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "俺，陈英豹。元帅出兵未归，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、陈友杰同上。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "参见元帅，胜负如何？"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "大败而回。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "前面什么所在？"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "乃是采石矶头。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "当初朱元璋怎样破得？"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "乃是常遇春藏身桅杆斗内，趁水涨之时抢上矶头呵——"
        },
        {
          "character": "陈友杰",
          "type": "〖急三枪〗。",
          "text": "⑵"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "既然如此，何不学他一学？"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "好，先行听令：命你准备战船，不得有误！"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈英豹下。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "众将官，采石矶去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、王渊同上。"
        },
        {
          "character": "王渊",
          "type": "白",
          "text": "俺，王渊。奉了千岁之命，把守采石矶头。 众将官，就此前往！ （王渊上山。陈英豹、水手甲摇船同上，陈英豹攻打矶头，不胜，下，水手甲随下。陈友杰、水手乙摇船同 上，陈友杰攻矶头，一次不成，二次扯住王渊枪头，乘势登上矶头。王渊、陈友杰拉枪同下。陈英豹、众人 同上，同登矶头，同下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王渊、陈友杰拉枪同上，起打，陈英豹上，助战，杀死王渊。"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "得了采石矶头。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "迎接主公进城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四军士、张定边、陈友谅同上。"
        },
        {
          "character": "陈友谅",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈友谅、张定边、四军士、陈友杰、陈英豹同入城，同下。"
        },
        {
          "character": "陈友杰",
          "type": "白",
          "text": "先行听令啊；就说大元帅陈友杰，保定北汉王得了采石矶头，叫那不怕死的花 云前来鏖战！"
        },
        {
          "character": "陈英豹",
          "type": "白",
          "text": "得令。 下面听者：今有大元帅陈友杰，保定北汉王得了采石矶头，叫那不怕死的花云 前来鏖战！"
        },
        {
          "character": "花云",
          "type": "内白",
          "text": "俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云上，起打，双收下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊、花云自两边分上。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "哎呀卿家呀！那贼兵犹如潮水一般，如何是好？"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "千岁但放宽心，杀出重围，金陵求救。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "卿家，小王还有家眷呢！"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "哎呀千岁呀！事到如今，还顾得什么家眷哪？"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "唗！你为臣的无有家眷，难道我这为君的就无有家眷不成！我要保护家眷去了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊下。花云一望，气急而抖。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "嗳——呀！想他为君的有家眷，难道这为臣的就无有家眷了吗！ 待俺也回去保护家眷去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郜氏、孙氏同上。"
        },
        {
          "character": "郜氏",
          "type": "念",
          "text": "老爷出兵去，"
        },
        {
          "character": "孙氏",
          "type": "念",
          "text": "未见转回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花安上。"
        },
        {
          "character": "华安",
          "type": "白",
          "text": "爹爹回府。 （花云上，下马，花安接马，郜氏、孙氏同搀花云坐，花安关门。四军士自两边分上，过场，同下。花安开 门了望，朱文逊上。）"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "花安，你家爹爹可在里面？"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "现在里面。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "对你爹爹去说，大炮一响，吓死皇老太太，姜氏夫人坠楼而死；叫你爹爹快快 出马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊下。"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "启禀爹爹：适才千岁言道，大炮一响，吓死皇老太太，姜氏夫人坠楼而死；叫 爹爹快快出马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云一惊，晕倒。"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花安关门。四军士自两边分上，过场，同下。花安开门了望，朱文逊上。"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "参见千岁。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "你爹爹可曾出马？"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "尚未出马。"
        },
        {
          "character": "朱文逊",
          "type": "白",
          "text": "哦哦是了！想是你家爹爹有降顺北汉王之意。这有宝剑一口，叫他将小王龙头 割下，降顺那北汉王去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱文逊拔宝剑，掷地，下。花安接剑。"
        },
        {
          "character": "花安",
          "type": "白",
          "text": "哎呀爹爹呀！千岁言道：爹爹有降顺北汉王之意。这有宝剑一口，将千岁龙头 割下，降顺那北汉王去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云一惊，晕倒。"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同白",
          "text": "喂呀！ 老爷醒来！"
        },
        {
          "character": "花云",
          "type": "西皮导板",
          "text": "号炮一响惊天地！"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": "花云",
          "type": "西皮散板",
          "text": "就是雀鸟也难飞！ 叫花安与为父带坐骑——"
        },
        {
          "character": "郜氏、孙氏",
          "type": "同哭",
          "text": "喂呀……"
        },
        {
          "character": "花云",
          "type": "西皮散板",
          "text": "舍不得妻儿两分离。 大夫人请上受一礼， 下官言来听端的： 孙氏姣儿托付你， 这是花家一脉息！ 含悲忍泪跨坐骑—— 落一个青史名标万古题。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云下。"
        },
        {
          "character": "郜氏",
          "type": "西皮散板",
          "text": "花安随后去探信，"
        },
        {
          "character": "孙氏",
          "type": "西皮散板",
          "text": "快到阵前看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郜氏、孙氏、花安自两边分下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花云、朱文逊同上。"
        },
        {
          "character": "花云",
          "type": "白",
          "text": "千岁，你保得好家眷！"
        },
        {
