          "character": "陈友谅",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "陈友谅",
          "type": "西皮散板",
          "text": "花云说话太张狂， 恶言恶语骂孤王。 开弓便把雕翎放——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花云挣脱绑绳，夺刀，跳下。陈友谅、张定边、四军士同急逃下。花云打陈友杰，陈友杰败下，花云追下。"
        }
      ]
