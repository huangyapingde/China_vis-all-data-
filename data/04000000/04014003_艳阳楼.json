{
  "script_id": "04014003",
  "title": "艳阳楼",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "高登",
      "hangdang": "武生"
    },
    {
      "name": "花逢春",
      "hangdang": "武生"
    },
    {
      "name": "徐士英",
      "hangdang": "武净"
    },
    {
      "name": "呼延豹",
      "hangdang": "武生"
    },
    {
      "name": "秦仁",
      "hangdang": "武丑"
    },
    {
      "name": "贾斯文",
      "hangdang": "丑"
    }
  ],
  "plot": "权臣高俅之子高登，倚仗父势，横行乡里；在庙会上把徐士英的妹妹抢走。徐士英情急追赶，路遇花逢春、\n呼延豹、秦仁等；这三个梁山泊后代人物，与徐士英原不相识，及至问明情由，激于义愤，夜间同入高府，\n救出徐妹，杀死高登。",
  "notes": "《艳阳楼》是写梁山泊后一代英雄人物除暴安良的故事。\n这个剧本是演员孙毓堃，北京戏曲实验学校耿明义与本院（中国戏曲研究院）编辑处何异旭共同整理的。除\n个别词句的修正外，主要的改动有以下三点：一、原本高登将徐妹抢回之后，上“张妈”；这一人物很不必\n要，今删去。二、删去原本高妾“小可怜”斯通贾斯文一场。三、原本花逢春等救出徐妹，徐妹又被神仙摄\n去，今亦删去此场。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花逢春上。"
        },
        {
          "character": "花逢春",
          "type": "引子",
          "text": "隐居村庄，怀侠义，惯打不平。"
        },
        {
          "character": "花逢春",
          "type": "念",
          "text": "少小英雄剑气横，爱习拳棒武艺能。苍天若能遂我愿，打尽人间抱不平。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "俺，花逢春。我父花荣，昔日在梁山举义，打富济贫。可恨蔡京、童贯，御酒 改为药酒，毒死梁山好汉；我母子逃在这南阳居住。是俺来在此地，结交两个 好友，一名呼延豹，一名秦仁，我弟兄倒也意气相投。我也曾托他二人挑选良 马，未见到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延豹、秦仁同上。"
        },
        {
          "character": "呼延豹",
          "type": "念",
          "text": "先人结拜忠义堂，"
        },
        {
          "character": "秦仁",
          "type": "念",
          "text": "如今弟兄又同窗。"
        },
        {
          "character": "呼延豹、秦仁",
          "type": "同白",
          "text": "参见大哥。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "二位贤弟少礼，请坐。"
        },
        {
          "character": "呼延豹、秦仁",
          "type": "同白",
          "text": "谢座。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "二位贤弟为何来迟？"
        },
        {
          "character": "秦仁",
          "type": "白",
          "text": "只因挑选良马，故尔来迟。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "原来如此。"
        },
        {
          "character": "呼延豹",
          "type": "白",
          "text": "大哥，今当三月三日蟠桃盛会，约请大哥前去逛会，不知大哥心意如何？"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "正合我意。 带马伺候！"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "三月三日桃花放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春、呼延豹、秦仁同上马。"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "万紫千红馥馥香。"
        },
        {
          "character": "呼延豹",
          "type": "白",
          "text": "大哥！"
        },
        {
          "character": "呼延豹",
          "type": "西皮摇板",
          "text": "咱弟兄学桃园义气不忘，"
        },
        {
          "character": "秦仁",
          "type": "西皮摇板",
          "text": "兄顾弟弟顾兄万载名扬。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "着啊！"
        },
        {
          "character": "花逢春、呼延豹、秦仁",
          "type": "同西皮摇板",
          "text": "弟兄打马往前闯，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "呼延豹、秦仁同下。"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "蟠桃会上散心肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐母、徐佩珠同上。"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "先夫去世早，门前车马稀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐禄暗上。"
        },
        {
          "character": "徐佩珠",
          "type": "白",
          "text": "参见母亲。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我儿少礼，一旁坐下。"
        },
        {
          "character": "徐佩珠",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "儿啊，今当清明佳节，我也曾命你兄长，准备车辆，同去上坟。这般时候怎么 还不见到来？"
        },
        {
          "character": "徐佩珠",
          "type": "白",
          "text": "想必来也。"
        },
        {
          "character": "徐士英",
          "type": "内白",
          "text": "徐福带路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐福、徐士英同上。"
        },
        {
          "character": "徐士英",
          "type": "西皮摇板",
          "text": "清明佳节把坟上， 见了母亲说端详。"
        },
        {
          "character": "徐士英",
          "type": "白",
          "text": "孩儿参见母亲。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "罢了，为娘命你准备车辆，可曾齐备？"
        },
        {
          "character": "徐士英",
          "type": "白",
          "text": "车辆已然齐备。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "徐禄，随带祭礼，坟茔去者。"
        },
        {
          "character": "徐禄",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "吩咐车辆伺候！"
        },
        {
          "character": "徐禄",
          "type": "白",
          "text": "车辆伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "三月三日正清明， 家家户户扫坟茔。 家院头前把路引，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐福、徐禄、徐士英同下。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "去到坟前祭先人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、徐佩珠、车夫同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高登上。"
        },
        {
          "character": "高登",
          "type": "点绛唇",
          "text": "膂力豪强，最爱娇娘，习拳棒，盖世无双，谁敢把某挡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八庄丁自两边分暗上。"
        },
        {
          "character": "高登",
          "type": "念",
          "text": "壮大身躯貌堂堂，虎背熊腰力刚强。懒读诗书习拳棒，最爱艳花女娇娘。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "某，高登。我父高俅，宋室为臣，官居太尉。只因俺不读诗书，爱习拳棒；我 父恐某在家生事惹祸，将俺寄居南阳。是俺来在此地，文武大小官员，乡党富 户，谁不趋奉。这且不言，今当三月三日，乃是蟠桃盛会，俺也曾命贾先生前 去料理会场。不免唤出教师们随同前往；一来逛会，二来选一宽阔之地，将拳 棒演习一番。 来，唤教师们。"
        },
        {
          "character": "八庄丁",
          "type": "同白",
          "text": "有请众位教师。"
        },
        {
          "character": "四教师",
          "type": "内同白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四教师同上。"
        },
        {
          "character": "四教师",
          "type": "同念",
          "text": "富贵门前客，拳棒武艺精。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "参见公爷。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "谢座。将我等唤来，有何吩咐？"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "今当三月三日蟠桃盛会，请出众位教师，一来前去逛会，二来选一宽阔之地， 将拳棒演习一番。不知众位教师心意如何？"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "我等奉陪。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "好，吩咐备马伺候！"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "备马伺候！"
        },
        {
          "character": "高登",
          "type": "西皮摇板",
          "text": "我父在朝为首相， 亚似东京小宋王。 人来带马会场上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八庄丁同带马，八庄丁、四教师同下，高登上马。"
        },
        {
          "character": "高登",
          "type": "西皮摇板",
          "text": "顺者昌来逆者亡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高登趟马。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "闪开了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高登下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文上。"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "府中奉了大爷命， 弹压会场走一程。"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "我，贾斯文。就在高登高府，当了一名代笔的先生。全凭我嘴好舌巧，吃的是 珍馐美味，穿的是绫罗绸缎，可算得丰衣足食。今当蟠桃盛会，乃是我家大爷 的会头，奉命去到会场，一来料理善事，二来与大爷寻访角色女子。就此马上 加鞭。"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "催马加鞭往前进， 去到会场看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "呼延豹、秦仁、花逢春同上。"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "勒马停鞭抬头望，"
        },
        {
          "character": "贾斯文",
          "type": "内白",
          "text": "三位慢走！"
        },
        {
          "character": "呼延豹、秦仁",
          "type": "同西皮摇板",
          "text": "那旁来了贾同窗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文上。"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "催马加鞭往前闯，"
        },
        {
          "character": "呼延豹、秦仁、花逢春",
          "type": "同白",
          "text": "贾先生！"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "再与三位叙衷肠。"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "原来是三位学友。"
        },
        {
          "character": "呼延豹、秦仁、花逢春",
          "type": "同白",
          "text": "贾先生，这几日不见，你往哪里去了？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "我现在高府。"
        },
        {
          "character": "呼延豹、秦仁、花逢春",
          "type": "同白",
          "text": "哪个高府？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "就是当朝高太尉之子。"
        },
        {
          "character": "呼延豹、秦仁",
          "type": "同白",
          "text": "敢是那狗子高登！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春拦住。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "二位，不要在背地里骂人呀！"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "啊，贾先生。想你我俱都是堂堂英雄，为何与高登那厮为奴？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "我是马杓儿上的苍蝇，混饭儿吃而已。三位，要有什么好事提拔提拔小弟，我 是感激不尽。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "贾先生今欲何往？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "今当蟠桃盛会之期，乃是我家大爷的会头，我前去料理料理会场。"
        },
        {
          "character": "花逢春",
          "type": "白",
          "text": "你我一同前往。"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "哎，慢着慢着！三位的马快，我是随后就到。"
        },
        {
          "character": "呼延豹、秦仁、花逢春",
          "type": "同白",
          "text": "哼！"
        },
        {
          "character": "花逢春",
          "type": "西皮摇板",
          "text": "哪有闲言对他讲，"
        },
        {
          "character": "呼延豹、秦仁",
          "type": "同西皮摇板",
          "text": "无知匹夫小儿郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花逢春、呼延豹、秦仁同下。"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "贾斯文",
          "type": "西皮摇板",
          "text": "他三人把话一样讲， 骂得我贾斯文脸上无光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八庄丁、四教师、高登同上。"
        },
        {
          "character": "高登",
          "type": "西皮摇板",
          "text": "逛罢盛会精神爽， 因何不见女娇娘？"
        },
        {
          "character": "八庄丁、四教师",
          "type": "同白",
          "text": "来在郊外。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "勒住了马。好一片宽阔之地。 教师们！"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "将拳棒演习上来。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四教师同演拳。"
        },
        {
          "character": "四教师",
          "type": "同白",
          "text": "演拳已毕。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "起过了。"
        },
        {
          "character": "高登",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文上。"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "大爷，您在这儿高乐哪！"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "贾先生，你从哪道而来？"
