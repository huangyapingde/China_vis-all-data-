        },
        {
          "character": "徐士英",
          "type": "白",
          "text": "咋咋咋，哇呀……"
        },
        {
          "character": "徐士英",
          "type": "西皮摇板",
          "text": "骂一声贼高登胆量不小， 抢去我同胞妹怎肯轻饶！"
