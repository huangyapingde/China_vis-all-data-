          "character": "贾斯文",
          "type": "白",
          "text": "我打会场来呀。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "可有绝色女子？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "您附耳上来。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "咋咋咋！ 马来，马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾斯文引四教师、八庄丁、高登同下。"
        }
      ]
    },
    {
