        {
          "character": "徐禄",
          "type": "白",
          "text": "你怎么又来了？"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "啊！这条道我走熟了嘛。老梆子，刚才我跟你提的那门亲事，你看，这就是我 们高登高大太爷。把你们家小姐，许配我家大爷，马上来，轿上娶，你们的光 彩，我们的体面。"
        },
        {
          "character": "徐禄",
          "type": "白",
          "text": "近前来，着打。"
        },
        {
          "character": "贾斯文",
          "type": "白",
          "text": "哎呦！ 大爷，他打了我啦！"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "与我抢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四教师、八庄丁、贾斯文抢徐佩珠同下，徐母被踢倒。"
        },
        {
          "character": "高登",
          "type": "白",
          "text": "马来。 好不识抬举！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高登下，徐福、徐士英同上。"
        },
        {
          "character": "徐士英",
          "type": "白",
          "text": "母亲，为何这等模样？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "哎呀儿啊！你妹子被那高登他……抢了去了！"
        },
        {
          "character": "徐士英",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "徐母",
          "type": "白",
