{
  "script_id": "04010006",
  "title": "通天犀",
  "alias": [
    "虎救郎；一名：血溅万花楼"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "青面虎",
      "hangdang": "净"
    },
    {
      "name": "许佩珠",
      "hangdang": "旦"
    }
  ],
  "plot": "十一郎在白水滩一时粗心，误助官兵打败了青面虎。谁料官府陷害，十一郎反而因此致祸；同时他的主人程\n老学也被问罪发配。程老学在起解途中，正好遇到许世英的妹妹许佩珠下山。许佩珠杀死解差，把程老学带\n到山寨。许世英在询问程老学的犯罪情由时，得知十一郎已被问成死罪，即将处决。许世英一闻此讯，义愤\n填胸，当即改扮下山，劫了法场，把十一郎救回山寨。",
  "notes": "《通天犀》出于昆曲，描写英雄青面虎许世英不记前仇搭救十一郎的故事。本剧是由中国京剧团演员景荣庆\n与本院（中国戏曲研究院）编辑处何异旭共同整理的。除字上略加修润外，并无其他更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、青面虎同上。"
        },
        {
          "character": "青面虎",
          "type": "点绛唇",
          "text": "占据山冈，自立为王，雄心壮……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小喽兵急上。"
        },
        {
          "character": "小喽兵",
          "type": "白",
          "text": "二寨主回山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小喽兵下。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "喽啰的！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "二寨主回山，你与我请，请，请！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许佩珠上。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "哥哥！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "贤妹！ 喽啰的！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "二寨主回山，必须要这一旁杀牛，那一旁宰羊，与你二寨主迎风掸尘。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "哥哥不用了。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "喽啰的！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "二寨主说罢就罢，说罢就罢，罢，罢，罢！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "罢！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "贤妹下山多受辛苦。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "查访英雄好汉，怎么样了？"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "小妹下山不曾访着英雄好汉，遇见两个解差押着一个老头儿，是我将解差杀死， 将老头儿带上山来，任凭哥哥发落。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "有这等事，贤妹请至后面歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许佩珠下。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "喽啰的，方才二寨主言说有一个老头儿，可有？"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "喽啰的，将那老头儿与我带——"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "带。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "与我带——"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "带。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "带，带，带上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小喽兵押程老学同上。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "喳喳喳！ 呔！这一老头儿家住哪里，姓甚名谁？与我说，咳，与我讲上来！"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "爷爷容禀！"
        },
        {
          "character": "程老学",
          "type": "泣颜回",
          "text": "开言泪婆娑， 尊一声大王听我说。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "呔！这一老头儿，你要与我——讲上来！"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "容禀！"
        },
        {
          "character": "程老学",
          "type": "泣颜回",
          "text": "五柳村中度生活， 小老儿名叫程老学。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "慢着说，慢着说！ 喽啰的！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "方才老头儿言道，他叫什么程，程，程——"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "程老学。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "着，好个响亮的名儿！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "响亮名儿。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "将这名儿记下！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "记下。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "怎说，记下了？"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "记下了。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "呔！老头儿，你要与我说呀！咳，讲上来！"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "爷爷容禀！"
        },
        {
          "character": "程老学",
          "type": "泣颜回",
          "text": "家人拜寿山前过， 不幸起风波。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "那一老头儿，你要与我说！"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "容禀！"
        },
        {
          "character": "程老学",
          "type": "泣颜回",
          "text": "十一郎闯下大祸， 连累老汉受折磨。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "慢着说，慢着说！ 喽啰的！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "方才老头儿言道，他有一家人叫什么十，十，十——"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "十一郎。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "着，好个响亮的名儿！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "响亮名儿。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "将这名儿记下！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "记下。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "记下了？"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "记下了。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "呔！这一老头儿，你将这一往情由，再讲上一遍。"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "小老儿名叫程老学，有个家人名唤十一郎。是他去往绿林庄探亲拜寿，行至中 途，打败官兵，放走贼寇。府台言道，家人犯罪，罪归家主。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "慢着说，慢着说！那十一郎闯下大祸。如今那十一郎他在何处？"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "那十一郎闻得小老儿在监中受罪，是他赶到公堂自首。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "慢着说，慢着说！那十一郎去往公堂自首。如今将他问成了何罪？"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "待到八月中秋，就是这样一刀两断。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "哇呀呀！哇呀呀！"
        },
        {
          "character": "青面虎",
          "type": "西皮快板",
          "text": "闻言不由心头恼， 一腔怒气似火烧。 恨赃官，忒凶暴， 眼见得好汉英雄吃一刀， 本大王换了靴衣帽， 下山搭救小英豪。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "这一老头儿，我有意将你留在山寨，抄写文墨，做个代笔的先生。你意如何？"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "若能将小老儿留在山寨，感恩匪浅。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "咦！他倒依从下来！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "依从下了！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "大大有造化！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有造化！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "下面更衣去吧！"
        },
        {
          "character": "程老学",
          "type": "白",
          "text": "谢大王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程老学下。许佩珠上。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "哥哥，将那老头儿怎样发落？"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "我将他留在山寨，抄写文墨，做个代笔的先生。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "可曾问过他人名姓？"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "方才问过，他叫什么程——程，程，程？"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "程老学。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "着。他还有一个家人，叫什么十——十，十，十？"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "十一郎。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "着哇！但不知这十一郎是怎样一个人？"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "哥哥难道你就忘怀了？"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "忘怀什么？"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "前者大战白水滩，兄长身后被他打了一棍，就是此人。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "呜呼呀！前者大战白水滩，为兄身后是这样咔嚓，就是一棍。就是此人么？"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "嘿，好汉子！好汉子！贤妹，既有这样英雄好汉，为兄就该搭救于他。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "哥哥不记前仇，真乃英雄也！不知怎样前去？"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "我自要改扮前去。贤妹请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎下。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "且住，哥哥下山，恐有不测；不免带领喽兵暗中保护。 众喽兵，听我一令！"
        },
        {
          "character": "许佩珠",
          "type": "西皮导板",
          "text": "许佩珠在大堂忙传一令，"
        },
        {
          "character": "许佩珠",
          "type": "西皮流水板",
          "text": "叫一声众喽兵细听分明： 大王爷下山去救人性命， 命尔等做接应紧紧随行。 此一去必须要小心谨慎，"
        },
        {
          "character": "青面虎",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": "许佩珠",
          "type": "西皮流水板",
          "text": "耳边厢又听见脚步声音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎上。"
        },
        {
          "character": "青面虎",
          "type": "西皮流水板",
          "text": "顷刻之间把衣换， 好似天神降下凡。 甩开大步到前山， 大叫贤妹仔细观。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "兄长改扮虽好，只是不可大意。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "贤妹！"
        },
        {
          "character": "青面虎",
          "type": "西皮散板",
          "text": "贤妹休把兄小量， 愚兄下山料无妨。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎下。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "众喽兵！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "许佩珠",
          "type": "白",
          "text": "带马下山。"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。许佩珠、四喽兵同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "青面虎上，走边。"
        },
        {
          "character": "青面虎",
          "type": "念",
          "text": "英雄生来志量高，腰中常挂镔铁刀。大喝一声惊神鬼，今日下山救英豪。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "许世英。只为搭救十一郎，下得山来。俺不免总镇衙门走走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎走圆场。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "来此已是总镇衙门。里面为何这样静悄悄的？咳！看天时尚早，俺不免寻一酒 馆，沽饮几杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎走圆场。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "来此已是。 酒保！"
        },
        {
          "character": "酒保",
          "type": "内白",
          "text": "来了，来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保跑上，被青面虎迎面撞倒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "好个楞二大爷。 您是干嘛的？"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "我是喝酒的。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我们这儿不卖酒啦。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "为什么不卖？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我们这儿今天要杀人啦。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "杀的是谁？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "这小子真楞。待我蒙蒙他。 要杀的是五六郎。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "酒保，这五六，八成儿是十一郎吧？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哎哟我的爹，您真蒙着啦。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "酒保，他杀他的人，咱喝咱的酒；我也不生事，我也不闯祸，咱是一个老实人。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您幸亏老实，要是不老实，我这屁股就墩两半儿啦。您吃您的酒，他杀他的人 对不对？"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我还是不卖。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "当真不卖？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "不卖。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "果然不卖？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "不卖。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "你不卖吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎举手欲打。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您别动横的，咱们有商量。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "哪里洁净？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "楼上洁净。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "带路。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "跟我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎、酒保同上楼。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "抱酒来！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您坐下。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "你抱酒去吧。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "酒到。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "酒保，杯小不可量。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "有大杯、大坛。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "你与我取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎扔酒具。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您别扔。酒到。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "打去泥头。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "乒、乓、噗呲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保吹泥土。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎揉眼。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "光棍眼里不揉沙子。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "王八日的。斟上！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "不招您生气，我给您斟上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保倒酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "顿，顿，顿。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "满了。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您喝吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎饮酒。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "嘟，嘟…… 真乃是好酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "七八十年的老陈绍。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "斟上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "又来了！顿，顿……"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "满了，都洒了。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我看您怎么喝？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎用胡须沾酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "呵，一点儿不糟践。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎饮酒。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "嘟，嘟…… 真乃是好酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "本来不错。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "斟上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "顿，顿……"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "拿过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎夺坛，饮酒。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "嘿！真乃是好酒，吃了受用。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保在下方用嘴接酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您受用啦，我也差不多啦。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "酒保，我问你，杀人在哪厢？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您问砂仁儿呀？上药铺里买。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "咳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎抬手误撞酒保的下巴。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "没问成砂仁儿，我这儿丢了个豆蔻。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "我问你，是杀人的法场。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您问杀人的法场呀，就在我这楼前面。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "酒保，你把这个楼窗支开，我看个花红热闹，使得使不得？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "杀人有什么瞧头儿？您又没瞧见过，待会儿一害怕，您再嚷，那就坏了！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "谁嚷来着？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "不是，我怕您嚷！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "谁嚷来着？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我怕您嚷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎大声。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "我没嚷啊！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您还没嚷哪，楼都快塌啦！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "你支开吧！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "你等着，我给您支开。 支楼窗啦！ 哎哟，摔着了我啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎示意酒保出去。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "嘘——"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "叫我转一弯儿？"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "嘘——"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我再转一弯儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎向酒保招手。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "怎么，要跟我说话？您说呀！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "你滚了下去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎踢酒保下。〖吹打〗。四兵士、监斩官同上。"
        },
        {
          "character": "监斩官",
          "type": "白",
          "text": "来，将十一郎绑上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二刽子手绑十一郎同上。"
        },
        {
          "character": "监斩官",
          "type": "白",
          "text": "将他绑好。"
        },
        {
          "character": "十一郎",
          "type": "白",
          "text": "天哪，天！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小喽兵、许佩珠暗同上。"
        },
        {
          "character": "十一郎",
          "type": "白",
          "text": "想俺十一郎，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎自语。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "好汉子！"
        },
        {
          "character": "十一郎",
          "type": "白",
          "text": "死得好不瞑目也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "青面虎自语。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "不要紧，都有我哪！"
        },
        {
          "character": "监斩官",
          "type": "白",
          "text": "时辰已到，开刀。 （青面虎跳下楼，开打，众人同败下，青面虎、四喽兵救十一郎同下。四兵士、柏达同上，过场，同下。四 小喽兵、许佩珠、青面虎、十一郎同上。）"
        },
        {
          "character": "十一郎",
          "type": "白",
          "text": "多谢恩公搭救！"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "十一郎",
          "type": "白",
          "text": "看恩公好生面熟，好象在……"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "你在白水滩打了我一杠子，你都忘了吗？"
        },
        {
          "character": "十一郎",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "什么这个那个的，官兵来了，咱们杀吧！"
        },
        {
          "character": "十一郎",
          "type": "白",
          "text": "杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、柏达同上，开打。青面虎杀柏达死。"
        },
        {
          "character": "青面虎",
          "type": "白",
          "text": "好汉子，跟我上山吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}