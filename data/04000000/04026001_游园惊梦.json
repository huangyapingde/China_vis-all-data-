{
  "script_id": "04026001",
  "title": "游园惊梦",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "杜丽娘",
      "hangdang": "正旦"
    },
    {
      "name": "春香",
      "hangdang": "帖旦"
    },
    {
      "name": "柳梦梅",
      "hangdang": "小生"
    },
    {
      "name": "杜母",
      "hangdang": "老旦"
    },
    {
      "name": "大花神",
      "hangdang": "末"
    }
  ],
  "plot": "被爹娘姣养在深闺里的杜丽娘，背着父母和老师，与侍女春香同到南安府的后花园去春游。满园春色，都付\n于断井颓垣，使这位知书守礼的官家小姐顿起伤春之感。杜丽娘游倦归房，朦胧睡去，与一个手持柳枝、口\n称到处寻她的少年书生柳梦梅在园中相会。后花园的花神们并出来保护他们。两人分别后，适杜母来临，见\n女儿昼寝神思困倦；把她叫醒，并嘱咐她：“后花园冷静，以后少去闲行。”",
  "notes": "《游园惊梦》是明朝伟大的戏剧作家汤显祖的名著《牡丹亭》中的一出。剧情紧接着《春香闹学》（见《京\n剧丛刊》第五集）。\n按《牡丹亭》故事，杜丽娘以后终因相思成病而死，葬在后花园梅树之下。柳梦梅拾得杜丽娘的自绘像，亦\n对画中人一往情深，杜丽娘的魂灵竟来和他相会。最后，杜丽娘起死回生；这一对痴情的少年男女终于成为\n夫妇。\n整理本是根据梅兰芳先生的最近演出本，由许源来先生与本院（中国戏曲研究院）许姬传、何异旭协助梅先\n生整理的。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杜丽娘上。"
        },
        {
          "character": "杜丽娘",
          "type": "绕地游",
          "text": "梦回莺啭，乱煞年光遍， 人立小庭深院。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "春香上。"
        },
        {
          "character": "春香",
          "type": "绕地游",
          "text": "炷尽沉烟，抛残绣线， 恁今春关情似去年。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐！"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "晓来望断梅关，宿妆残。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐！"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "你侧着宜春髻子，恰凭栏。"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "剪不断，理还乱，闷无端！"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐！"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "已吩咐催花莺燕借春看。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春香，可曾吩咐花郎扫除花径么？"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "已扫除清净了。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "取镜台、衣服过来。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "云髻罢梳还对镜，罗衣欲换更添香。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，镜台、衣服在此。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "放下。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "好天气也！"
        },
        {
          "character": "杜丽娘",
          "type": "步步娇",
          "text": "枭晴丝吹闲庭院，"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "请小姐梳妆。"
        },
        {
          "character": "杜丽娘",
          "type": "步步娇",
          "text": "摇漾春如线； 停半晌，整花钿， 没揣菱花，偷人半面， 迤逗的彩云偏。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐请行一步。"
        },
        {
          "character": "杜丽娘",
          "type": "步步娇",
          "text": "我步香闺怎便把全身现。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐！"
        },
        {
          "character": "春香",
          "type": "醉扶归",
          "text": "你道翠生生出落的裙衫儿茜， 艳晶晶花簪八宝王真。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春香！"
        },
        {
          "character": "杜丽娘",
          "type": "醉扶归",
          "text": "可知我常一生儿爱好是天然。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春香——"
        },
        {
          "character": "杜丽娘、春香",
          "type": "同醉扶归",
          "text": "恰三春好处无人见， 不提防沉鱼落雁鸟惊喧， 则怕的羞花闭月花愁颤。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "来此已是花园门首，请小姐进去。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "进得园来，你看："
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "画廊金粉半零星，"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "这是金鱼池。"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "池馆苍苔一片青。"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "踏草怕泥新绣袜，惜花疼煞小金铃。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春香。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "不到园林，怎知春色如许。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "便是。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "春香——"
        },
        {
          "character": "杜丽娘、春香",
          "type": "同皂罗袍",
          "text": "原来姹紫嫣红开遍， 似这般都付与断井颓垣。 良辰美景奈何天， 便赏心乐事谁家院。 朝飞暮卷，云霞翠轩， 雨丝风片，烟波画船， 锦屏人忒看的韶光贱。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，这是青山。"
        },
        {
          "character": "杜丽娘",
          "type": "好姐姐",
          "text": "遍青山……"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "这是杜鹃花。"
        },
        {
          "character": "杜丽娘",
          "type": "好姐姐",
          "text": "啼红了杜鹃。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "这是荼蘼架。"
        },
        {
          "character": "杜丽娘",
          "type": "好姐姐",
          "text": "那荼蘼烟丝醉软。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "是花多开，牡丹还早。"
        },
        {
          "character": "杜丽娘",
          "type": "好姐姐",
          "text": "那牡丹虽好，它春归怎占的先。 闲凝眄——"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，你看莺燕叫得好听啊。"
        },
        {
          "character": "杜丽娘",
          "type": "好姐姐",
          "text": "生生燕语明如翦， 听呖呖莺声溜的圆。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，这园子委实观之不足。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "提它怎么！"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "留些余兴，明日再来耍子罢。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "有理。"
        },
        {
          "character": "杜丽娘",
          "type": "隔尾",
          "text": "观之不足由他缱， 便赏遍了十二亭台是枉然； 倒不如兴尽回家闲过遣。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，你身子乏了，歇息片时。我去看看老夫人再来。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "去去就来。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "瓶插映山紫，炉添沉水香。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "春香下。"
        },
        {
          "character": "杜丽娘",
          "type": "念",
          "text": "默地游春转，小试宜春面。春啊春，得和你两留连，春去如何遣！"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "唉，恁般天气，好困人也！"
        },
        {
          "character": "杜丽娘",
          "type": "山坡羊",
          "text": "没乱里春情难遣， 蓦地里怀人幽怨。 则为俺生小婵娟， 拣名门一例一例里神仙眷。 甚良缘，把青春抛的远， 俺的睡情谁见！ 则索要因循腼腆。 想幽梦谁边， 和春光暗流转。 迁延，这衷情怀哪处言！ 淹煎，泼残生除问天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "万年欢牌。杜丽娘入梦，柳梦梅上。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "姐姐！小生哪一处不寻到，却在这里！恰好在花园内，折得垂柳半枝；姐姐你 既淹通诗书，何不作诗一首，以赏此柳枝乎？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "那生素昧平生，因何到此？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "姐姐咱一片幽情，爱煞你哩！"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "则为你如花美眷，似水流年， 是答儿闲寻遍；在幽闺自怜。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "姐姐我和你那答儿讲话去。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "喏！"
        },
        {
          "character": "柳梦梅",
          "type": "山桃红",
          "text": "转过这芍药栏前， 紧靠着湖山石边， 和你把领扣松，衣带宽， 袖梢儿温着牙儿苫也。 则待你忍耐温存一晌眠。"
        },
        {
          "character": "柳梦梅、杜丽娘",
          "type": "山桃红",
          "text": "是哪处曾相见？相看俨然， 早难道好处相逢无一言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳梦梅、杜丽娘同下。众花神引大花神同上。"
        },
        {
          "character": "众花神",
          "type": "同出队子",
          "text": "娇红嫩白，竞向东风次第开， 愿教青帝护根荄， 莫遣纷纷点翠苔。 把梦里姻缘发付秀才。"
        },
        {
          "character": "大花神",
          "type": "念",
          "text": "催花御史惜花天，"
        },
        {
          "character": "众花神",
          "type": "同念",
          "text": "检点春光又一年。"
        },
        {
          "character": "大花神",
          "type": "念",
          "text": "蘸客伤心红雨下，"
        },
        {
          "character": "众花神",
          "type": "同念",
          "text": "勾人悬梦彩云边。"
        },
        {
          "character": "大花神",
          "type": "白",
          "text": "吾乃南安府后花园花神是也。今有杜小姐游春伤感，致辞使柳秀才入梦。吾神 专管惜玉怜香，前去保护者！"
        },
        {
          "character": "众花神",
          "type": "同白",
          "text": "吾等万紫千红，正宜他惜玉怜香。"
        },
        {
          "character": "众花神",
          "type": "同画眉序",
          "text": "好景艳阳天，万紫千红尽开遍。 满雕栏宝砌云簇霞鲜。 督春工连夜芳菲， 慎莫待晓风吹颤。 为佳人谐缱绻， 梦儿中有十分欢忭。"
        },
        {
          "character": "众花神",
          "type": "同滴溜子",
          "text": "湖山畔，湖山畔云缠雨绵。 雕栏外，雕栏外锦簇翠軿。 惹下蜂愁蝶恋， 三生石上缘。 都因梦幻，一枕华胥两下蘧然。"
        },
        {
          "character": "众花神",
          "type": "同鲍老催",
          "text": "单则是混阳蒸变， 看他虫儿般蠢动把风儿煽； 一般儿姣凝翠绽的魂儿颤， 这是景上缘。 想内成、因中见。 怕淫邪展污了花台殿。"
        },
        {
          "character": "大花神",
          "type": "白",
          "text": "待咱拈片落花惊醒他。呀！"
        },
        {
          "character": "大花神",
          "type": "鲍老催",
          "text": "他梦酣春透了怎留连， 待拈花闪碎的红如片。"
        },
        {
          "character": "大花神",
          "type": "白",
          "text": "柳秀才，你梦毕之时，好生送杜小姐仍归香阁。吾神去也。"
        },
        {
          "character": "众花神",
          "type": "同五般宜",
          "text": "一个儿意昏昏梦魂颠， 一个儿心兢兢丽情牵； 一个巫山女趁着这云雨天， 一个桃花阆苑幻成刘阮； 一个精神忒软， 一个欢娱恨浅； 两下里万种恩情， 则随这落花儿早一会儿转。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "万年欢牌。众花神、大花神同下。柳梦梅、杜丽娘携手同上。"
        },
        {
          "character": "柳梦梅、杜丽娘",
          "type": "同山桃红",
          "text": "这一霎天留人便，草藉花眠。 则把云鬟点，红松翠偏。"
        },
        {
          "character": "柳梦梅",
          "type": "山桃花",
          "text": "见了你紧相偎，慢厮连。 恨不得肉儿般和你团成片也！ 逗的个日下胭脂雨上鲜。 我欲去还留恋， 相看俨然，早难道好处相逢无一言。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "姐姐你身子乏了，将息片时。小生去也。正是："
        },
        {
          "character": "柳梦梅",
          "type": "念",
          "text": "行来春色三分雨，"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "秀才。"
        },
        {
          "character": "柳梦梅",
          "type": "白",
          "text": "在。 妙啊！"
        },
        {
          "character": "柳梦梅",
          "type": "念",
          "text": "睡去巫山一片云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳梦梅下。杜母上。"
        },
        {
          "character": "杜母",
          "type": "念",
          "text": "夫婿坐黄堂，娇娃立绣窗。怪她裙衩上，花鸟绣双双。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "啊，秀……"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "儿啊，为娘在此。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "原来是母亲。母亲万福。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "罢了，你方才说什么秀？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "哦……孩儿说剌绣才罢。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "为何昼眠在此？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "告母亲知道：孩儿适才往后花园游玩回来，不觉身子困倦，少睡片时。不知母 亲到来，有失迎接，望母亲恕罪。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "怎么不到学堂中看书？"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "先生不在，且自消停。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "儿啊，花园冷静，少去闲游。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "谨依慈命。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "妇儿家长成了，自有这许多情态。且自由她，我去了。正是："
        },
        {
          "character": "杜母",
          "type": "念",
          "text": "宛转随女儿，"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "孩儿送母亲。"
        },
        {
          "character": "杜母",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "杜母",
          "type": "念",
          "text": "辛勤做老娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杜母下。"
        },
        {
          "character": "杜丽娘",
          "type": "白",
          "text": "娘啊，你教孩儿看书，不知哪一种书，才消得我的闷怀哟！"
        },
        {
          "character": "杜丽娘",
          "type": "绵搭絮",
          "text": "雨香云片，才到梦儿边。 无奈高堂，唤醒纱窗睡不便。 泼新鲜俺的冷汗粘煎， 闪的俺心悠步享单， 意软鬟偏。不争多费尽神情， 坐起谁忺，则待去眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "春香上。"
        },
        {
          "character": "春香",
          "type": "念",
          "text": "晚妆销粉印，春润费香篝。"
        },
        {
          "character": "春香",
          "type": "白",
          "text": "小姐，薰了被窝睡吧。"
        },
        {
          "character": "杜丽娘",
          "type": "尾声",
          "text": "困春心游赏倦， 也不索香薰绣被眠。 春啊！有心情那梦儿还去不远。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "春香扶杜丽娘同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
