        {
          "character": "岳飞",
          "type": "二黄散板",
          "text": "收服了杨再兴好灭金酋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞入睡。起鼓，天明。四兵士同上。"
