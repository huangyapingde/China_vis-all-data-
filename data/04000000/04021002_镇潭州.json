        {
          "character": "岳飞",
          "type": "白",
          "text": "众将官，带马阵前去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞、四兵士同走圆场，四喽兵、杨再兴同上，会阵。"
