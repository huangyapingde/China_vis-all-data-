        {
          "character": "报子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖吹打〗。施全搀岳云同上。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "将军，这是何人？"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "这就是我家元帅的公子，昨日在阵前冒犯将军，回营就要斩首。多亏众将讲情， 死罪已免，活罪难饶，重责四十军棍，来请将军验伤。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "哦！怎么，责打了四十军棍？"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "这才是为帅之道。 公子你受屈了。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "我家元帅言道：上覆将军，明日在阵前相会。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "那是自然。后帐留宴。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "公务在身，不敢久停。告辞。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "奉送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。施全搀岳云同下。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "请！ 岳飞真乃英雄也。"
        },
        {
          "character": "杨再兴",
          "type": "西皮摇板",
          "text": "责打岳云消俺气， 岳飞英雄数第一。 众将暂把营门闭， 明日阵前见高低。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
