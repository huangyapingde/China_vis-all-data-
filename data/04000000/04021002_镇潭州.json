{
  "script_id": "04021002",
  "title": "镇潭州",
  "alias": [
    "九龙山"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "杨再兴",
      "hangdang": "武生"
    },
    {
      "name": "岳飞",
      "hangdang": "老生"
    },
    {
      "name": "岳云",
      "hangdang": "小生"
    },
    {
      "name": "牛皋",
      "hangdang": "净"
    }
  ],
  "plot": "南宋时，金人入寇，岳飞奉命御侮。时杨再兴聚义九龙山，进攻潭州；岳飞率兵往援，知杨再兴为忠良后裔，\n武艺高强，有意收为臂助。进兵潭州后，亲自与杨再兴交锋，双方严令兵将，不准助战。杨再兴精于枪法，\n岳飞几不敌。时其子岳云解粮方回，不知情由，助战犯令。岳飞以军令不严，贻羞于杨再兴，回营欲斩岳\n云，经众将讲情，始免死罪，重责四十军棍，并令亲往杨再兴营中验伤请罪。杨再兴见状，深为感动，遂约\n定再较胜负。次日，岳飞用“撒手锏”击杨再兴落马，杨再兴折服，率所部投岳飞，共御金兵。",
  "notes": "《镇潭州》取材于小说《说岳全传》。这个剧本是中国京剧团叶盛兰、李洪春与本院（中国戏曲研究院）编\n辑处吴少岳共同整理的。除将原本中杨景托梦授锏的情节删改外，并对个别词句略作润色。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "施全、王贵、牛皋、吉青同上，同起霸。"
        },
        {
          "character": "施全",
          "type": "念",
          "text": "恼恨朝中贼专权，"
        },
        {
          "character": "王贵",
          "type": "念",
          "text": "隐姓埋名有数年。"
        },
        {
          "character": "牛皋",
          "type": "念",
          "text": "弟兄怀揣忠义胆，"
        },
        {
          "character": "吉青",
          "type": "念",
          "text": "誓死报国灭谗奸。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "俺，施全。"
        },
        {
          "character": "王贵",
          "type": "白",
          "text": "王贵。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "牛皋。"
        },
        {
          "character": "吉青",
          "type": "白",
          "text": "吉青。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "王贵、牛皋、吉青",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "元帅升帐，你我两厢伺候。"
        },
        {
          "character": "王贵、牛皋、吉青",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四士兵、岳云、张宪引岳飞同上。"
        },
        {
          "character": "岳飞",
          "type": "点绛唇",
          "text": "统领雄兵，狼烟扫尽，军威盛，赤胆忠心，谨遵恩师训。"
        },
        {
          "character": "牛皋、王贵、牛皋、吉青",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众位贤弟少礼。"
        },
        {
          "character": "牛皋、王贵、牛皋、吉青",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "岳飞",
          "type": "念",
          "text": "绣旗丹诏出禁门，武将当思汗马勋。男儿须怀凌云志，迎请二圣方称心。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "本帅，姓岳名飞字鹏举，宋室驾前为臣。只因奸佞弄权，是我退归林下；蒙太 后二次诏宣，官拜天下都招讨、兵马大元帅；恩赐五色锦旗，上写“精忠报国” 。本帅亲承王命，总统六师，扫荡烟尘，恢复山河。前者徐恩师有紧急文书 到来，杨再兴攻取潭州，不免前往救应。 众位贤弟！"
        },
        {
          "character": "牛皋、王贵、牛皋、吉青",
          "type": "同白",
          "text": "元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "牛皋、王贵、牛皋、吉青",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "牛皋听令。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "命你去到潭州晓谕节度使，本帅大兵随后即至。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "得令。马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋下，四兵士随下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "岳云听令。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "押解粮草。"
        },
        {
          "character": "岳云",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳云下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "张宪听令。"
        },
        {
          "character": "张宪",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "催运粮草。"
        },
        {
          "character": "张宪",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张宪下。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "施全听令。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "命你以为总督粮官。传令下去，众将一路之上，不可马踏青苗，骚扰百姓，违 令者斩！余下将官，随营调遣，就此起兵潭州。"
        },
        {
          "character": "施全",
          "type": "白",
          "text": "得令。 下面听者：元帅有令，一路之上，不可马踏青苗，骚扰百姓，违令者斩！余下 将官，随营调遣，就此起兵潭州。"
        },
        {
          "character": "王贵、吉青",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞、施全、王贵、吉青同上马，兵士执“精忠报国”旗暗上，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士引徐仁同上。"
        },
        {
          "character": "徐仁",
          "type": "念",
          "text": "镇守潭州，为国担忧。"
        },
        {
          "character": "牛皋",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、牛皋同上。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "呔！有人无有，走出一个来！"
        },
        {
          "character": "兵士甲",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "往里通禀：就说咱牛皋到了。"
        },
        {
          "character": "兵士甲",
          "type": "白",
          "text": "候着。 启禀元帅，牛将军到。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "说我出迎。"
        },
        {
          "character": "兵士甲",
          "type": "白",
          "text": "元帅出迎。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "恩师。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "牛将军！请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐仁、牛皋同进门。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "请坐！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "将军到此，有何军令？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "元帅奉命征杨再兴，进兵潭州，命俺先来报知，大兵随后就到。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "元帅奉命前来，潭州可保无虞矣。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "请问恩师，可曾与那贼见过阵来？"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "未曾见过。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "待俺牛皋会他一会。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "那贼骁勇，不可前去。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "嗳，休长他人锐气，灭咱自己的威风。 带马，带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、牛皋同下。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "牛皋此去，定不是他人对手。 来，带马迎接元帅去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴上，大起霸，后随纛旗。"
        },
        {
          "character": "杨再兴",
          "type": "引子",
          "text": "十万貔貅镇九龙，将军八面逞威风。腰悬三尺龙泉剑，志气凌云贯长虹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵同上。"
        },
        {
          "character": "杨再兴",
          "type": "念",
          "text": "隐姓埋名八九春，世代簪缨列帝门。朝中出了奸佞贼，勒逼豪杰在山林。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "俺，杨再兴。祖父金刀令公，宋室为臣。只因朝中奸佞弄权，陷二圣于沙漠， 坐井观天，是俺一怒我就反，反至九龙山，齐聚天下英雄。俺意欲杀退金人， 灭却奸佞，重整山河，方不负将门之志。看前面已是潭州，正好夺取。 众将官！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "攻打潭州去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场，四兵士、牛皋同上，会阵，四兵士同下。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "呔，来将通名受死！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "连你牛爹爹都不认识了么？"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "牛皋，前者你在汴梁小校场，岂不知俺杨再兴的厉害，今日又来作甚？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "一派胡言，吃俺一鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨再兴以枪拨开。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "哇呀！"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛皋败下。"
        },
        {
          "character": "杨再兴",
          "type": "白",
          "text": "追！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵同追下，杨再兴随下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四兵士引徐仁自下场门同上，同出城。施全、王贵、吉青、岳飞、纛旗兵同上。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "元帅。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "恩师。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "元帅请。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "不敢，恩师请！"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "你我挽手而行。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "门生斗胆了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。转场，四兵士、施全、王贵、吉青、徐仁、岳飞同上，同入内。吹打止。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "门生有何德能，敢劳恩师迎接十里之外。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "你今亲承王命，统领六师，老朽怎敢轻慢。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "惶恐啊惶恐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳飞两望。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "看什么？"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "我命牛皋前来，为何不见？"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "牛将军到此，未息鞍马亲自立功去了。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "牛皋到此，未息鞍马，亲自立功去了？哼！想他此去，必定大败而归。"
        },
        {
          "character": "徐仁",
          "type": "白",
          "text": "元帅见识不差。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、牛皋同上，牛皋下马，四兵士同下。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "咦，咱的哥，你倒先来了，辛苦你了！"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "贤弟，你与敌人交战，胜负如何？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "咱也不知是胜了，也不知是败了，在两军阵前遇见一个年少的娃娃，被他这么 一枪……"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "怎样？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "把我就送回来了。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "可曾问过敌人的姓名？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "这个……不曾问过。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "嗯！你跟随愚兄出兵多年，还是这样粗鲁，若是打了胜仗，叫愚兄怎上这功劳 簿。"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "无有功劳，什么功劳簿；有功劳咱老牛也不要。那娃娃言道：在汴梁小校场， 会过一次，他叫什么杨……"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "敢是那杨再兴？"
        },
        {
          "character": "牛皋",
          "type": "白",
          "text": "就是那个娃娃。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "此人英勇无敌，你焉能是他人对手，待本帅亲自会他。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "且慢，杀鸡何用牛刀，待某等出马，生擒杨再兴入帐。"
        },
        {
          "character": "岳飞",
          "type": "白",
          "text": "众位贤弟有所不知，想那杨再兴，他乃将门之子，武艺高强，本帅意欲将他收 留帐下，做一膀臂。今日出马，非比寻常，众将只许观阵，不许助战，违令者 斩！"
        },
        {
          "character": "牛皋、施全、王贵、吉青",
          "type": "同白",
