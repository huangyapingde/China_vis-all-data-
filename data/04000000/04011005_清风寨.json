{
  "script_id": "04011005",
  "title": "清风寨",
  "alias": [
    "娶李逵"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "李逵",
      "hangdang": "净"
    }
  ],
  "plot": "梁山好汉李逵、燕青下山打探，在张志善家投宿，见张志善愁容满面，问起情由，才知道清风寨上盗匪刘通、\n刘宏要强抢张女上山成亲。李逵、燕青见义勇为，由李逵乔扮新娘，燕青扮做新娘之弟，混上清风寨，杀\n死刘通、刘宏。",
  "notes": "《清风寨》是水浒传说中的一段故事。这剧本是侯喜瑞先生与本院（中国戏曲研究院）编辑处吕瑞明共同整\n理的。并由高登甲先生帮助。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、小头目、刘通同上。〖快点绛唇〗。"
        },
        {
          "character": "刘通",
          "type": "念",
          "text": "不种桑麻不种田，弟兄独霸在高山。有人打从山前过，必须留下买路钱。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "俺，清风寨大寨主刘通。弟兄二人霸占清风寨，倒也逍遥自在。看今日天气晴 和，不免下山作几件好买卖。 喽啰的！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "带马下山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张志善上。"
        },
        {
          "character": "张志善",
          "type": "引子",
          "text": "忠厚传家久，诗书继世长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院暗上。"
        },
        {
          "character": "张志善",
          "type": "念",
          "text": "人生在世几度春，转眼已是白发人。老来无儿女为贵，膝下承欢度光阴。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "老汉，张志善，不幸妻室亡故膝下无儿，只生一女，尚未婚配。今当清明佳节， 不免将女儿唤出，一同上坟插柳。 家院，祭礼可齐？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "请小姐出堂。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "遵命。 有请小姐出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、张女同上。"
        },
        {
          "character": "张女",
          "type": "念",
          "text": "忽听爹爹唤，向前问根源。"
        },
        {
          "character": "张女",
          "type": "白",
          "text": "参见爹爹。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "张女",
          "type": "白",
          "text": "唤女儿出来，有何训教？"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "今乃清明佳节，随为父上坟插柳，可愿前往？"
        },
        {
          "character": "张女",
          "type": "白",
          "text": "女儿愿往。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "家院，唤车辆伺候。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是，车辆走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上。张女上车。"
        },
        {
          "character": "张女",
          "type": "西皮摇板",
          "text": "桃红柳绿到清明， 家家户户上坟茔。 家院带路往前进， 上坟插柳走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "燕青、李逵",
          "type": "内同白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青、李逵同上。"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "寨中奉了大哥命，"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "山下打探要小心。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "俺，浪子燕青。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "咱，黑旋风李逵。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "李二哥请了。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "奉了大哥之命，山下打探。如今公务已毕，不免回山交令。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "甩开大步朝前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青下。"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "黑旋风李逵紧随跟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "家院、丫鬟、张志善、张女、车夫同上。"
        },
        {
          "character": "张女",
          "type": "西皮摇板",
          "text": "来到坟前停车辆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、小头目、刘通同暗上。"
        },
        {
          "character": "张女",
          "type": "西皮摇板",
          "text": "双膝跪地放悲声。 哭一声去世的娘难得见，"
        },
        {
          "character": "张女",
          "type": "哭头",
          "text": "儿的娘啊！"
        },
        {
          "character": "张女",
          "type": "西皮摇板",
          "text": "怎不叫人痛伤情！"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "你我父女回去了吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善、张女、车夫、丫鬟、家院同下。"
        },
        {
          "character": "刘通",
          "type": "三笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘通向小头目。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "来！速去打探这是谁家的女子？"
        },
        {
          "character": "小头目",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小头目下。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "喽啰的！带马回山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘通、四喽兵同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘宏上。"
        },
        {
          "character": "刘宏",
          "type": "念",
          "text": "大哥下山寨，未见转回来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、刘通同上。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "大哥回来啦！"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "刘通",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "大哥因何发笑？"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "适才下山见一绝色女子，十分美貌；心中欢喜，故而发笑。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "但不知是谁家的女子？"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "已派小头目打探去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小头目上。"
        },
        {
          "character": "小头目",
          "type": "白",
          "text": "启禀大王：那一女子乃前村张家的小姐。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "这就是了。 贤弟，愚兄有意娶那女子作个压寨夫人，只是不能到手，也是枉然。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "大哥备下花红彩礼，待小弟前去提亲。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "好，就命他——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘通指小头目。"
        },
        {
          "character": "刘通",
          "type": "白",
          "text": "头前带路，贤弟前去提亲。正是："
        },
        {
          "character": "刘通",
          "type": "念",
          "text": "花红彩礼交与你，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘通下。"
        },
        {
          "character": "刘宏",
          "type": "念",
          "text": "保管大哥会佳期。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "走着，走着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵、小头目、刘宏同走圆场。"
        },
        {
          "character": "小头目",
          "type": "白",
          "text": "来此已是。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "待我叫门。 嗨！开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "作什么的？"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "对你们员外说：清风寨二大王要见。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有请员外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善上。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "清风寨二大王要见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善惊恐。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "啊！说我不在家中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善欲下。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "员外，还是相见的才是。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "唉！说我出迎。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "员外出迎。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "啊，员外。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "二大王，请到里面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善、刘宏同进内，同入座。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "大王到此，必有所为。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "员外可有个女儿吗？"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "不错，有一个女儿。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "奉了我家大哥之命，前来提亲；将你女儿，许配我大哥做一压寨夫人，员外料 无推辞啦吧！"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "这个……小女已然有了人家，此事不能从命。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "什么有人家没有人家！把花红彩礼给你留下，三日后前来抬亲。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "此事万万使不得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善拦，刘宏推张志善。"
        },
        {
          "character": "刘宏",
          "type": "白",
          "text": "给脸不兜着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘宏、四喽兵、小头目同下。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "唉！正是："
        },
        {
          "character": "张志善",
          "type": "念",
          "text": "闭门家中坐，祸从天上来。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "这是哪里说起！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院扶张志善同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "燕青、李逵",
          "type": "内同白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青、李逵同上。"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "行了一程又一程，"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "家家户户掌上灯。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "李二哥，你看天色已晚，你我弟兄往哪里安身？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "燕小哥，你抬头观看，前面黑洞洞的，必有人家，你我赶到那里投宿便了。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "言之有理。"
        },
        {
          "character": "燕青、李逵",
          "type": "同白",
          "text": "请哪！"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "叫声二哥忙随定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青、李逵同走圆场。"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "不觉来到这小庄村。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "来此已是。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "待我叫门去。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你不会讲话。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "兄弟，如今晚儿我会说话啦。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你好话多讲。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "你交给我啦，没有错。这么大的个儿，我连个门都不会叫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵瞧门。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "瞧！这么早把这个门就关上啦。 呔！有腿的给我走出个来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "作什么的？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我们哥儿俩走在这儿前不着村，后不着店，没什么说的，在你们这儿，我睡一 宿觉。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "这是什么讲话。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我睡觉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵欲打，燕青拦。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "嗳！这是什么讲话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青向家院。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "原来是位都管哥。我们二人行到此间，前不着村，后不着店，要在宝庄借宿一 宵，明日早行。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "请少待，待我禀明员外。 有请员外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善上。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "家院、李逵",
          "type": "同白",
          "text": "（门外来了二人投宿。）（他出来，他怎么又进去了？）"
        },
        {
          "character": "张志善、燕青",
          "type": "同白",
          "text": "（说我心事在怀，叫他们旁处投宿去吧。）（他回禀他的家主。）"
        },
        {
          "character": "家院、李逵",
          "type": "同白",
          "text": "（是。）（他有主儿，咱们哥儿俩今儿可没有主儿啦。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院出门。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "我家员外有心事在怀，叫你们别处投宿去吧！"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "呔！叫睡也要睡，不叫睡也要睡，在你们这儿，我睡定啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青拦。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "这是什么讲话！"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "没地方睡觉，我着急。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "烦劳通禀：我弟兄有一席之地即可安身。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "请少待。"
        },
        {
          "character": "家院、李逵",
          "type": "同白",
          "text": "（啊员外，他二人言道：有一席之地，即可安身。）（燕兄弟，他怎么又进去 啦？）"
        },
        {
          "character": "张志善、燕青",
          "type": "同白",
          "text": "（好，说我出迎。）（他回禀他的家主。）"
        },
        {
          "character": "家院、李逵",
          "type": "同白",
          "text": "（员外出迎。）（睡宿觉这么麻烦，我真急啦。我要打——）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善出门。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "啊二位！"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "员外！"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "二位请进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青、李逵同进内。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "请问员外上姓高名？"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "小老儿张志善。"
        },
        {
          "character": "燕青、李逵",
          "type": "同白",
          "text": "张员外，失敬了。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "岂敢！请问二位尊姓大名？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "在下萧乙。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我姓李——"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "他叫李二。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "不错，卖豆儿的小二哥，就是我。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "二位可曾用过酒饭？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "这饭——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青拦。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "前面用过了。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "他愣说在头里吃啦。我这老肚有点委屈。 嗳，都管哥，饭，我们在头里吃过啦，你们这儿有酒没有？弄点来，我叨扰叨 扰。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "看酒伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院摆酒。"
        },
        {
          "character": "燕青、李逵",
          "type": "同白",
          "text": "叨扰了！"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "弟兄二人饮琼浆，"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "多吃几杯又何妨。"
        },
        {
          "character": "燕青",
          "type": "西皮摇板",
          "text": "猛然抬头用目望，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善叹气。李逵摔杯。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "嗨！"
        },
        {
          "character": "李逵",
          "type": "西皮摇板",
          "text": "咳声叹气为哪桩？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "呔！我弟兄二人在此饮酒，你那里咳声叹气，是何道理？"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "壮士不要如此，小老儿有心事在怀。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "怎么着，你有心事？好，你慢慢地告诉他说；你说你的，我喝我的，你慢慢说， 我慢慢喝。你说吧！"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "二位有所不知，只因清风寨上有二家大王，要将我的女儿抢上山去，作个压寨 夫人。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "咋咋咋，哇呀呀！燕小哥！此地出了这等恶霸，待我打死这个囚抓的！"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你又来多事。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我不言语。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "啊员外，我弟兄二人在哪里安歇？"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "家院，请二位到书房安歇。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善下，家院、燕青、李逵同走圆场，同进内。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "都管哥请便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "李二哥请坐。 啊李二哥你可曾听见？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "听见什么？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "员外言道，此地出了恶霸，要将员外之女抢上山去，作一个压寨的夫人。想条 妙计搭救他女儿才是。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "刚才你嫌我多事；我，没有主意。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你吃了人家的酒，就该与人家分忧解愁。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "嗳，燕兄弟，酒，我是喝啦；菜，我是吃啦；你要主意，一点儿没有。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "小弟倒有一计在此。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "你有什么主意？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你我二人，一个扮作新人，一个扮作新人之弟；混上山去，杀他一个措手不及。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "兄弟，你这个主意不错，咱们就这么办啦。谁扮新人？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "这新人么？自然是二哥你扮。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "哎，咋咋咋。兄弟，你瞧二哥，挺长的胡子，漆黑的脑壳，我怎么像个新人。 我看兄弟你年纪又轻脸又白，还是你把新娘子扮起来。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你扮上就像了。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我不能扮。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你当真不扮？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我不扮。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青举拳。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "你等等，你打完了我，我还扮不扮？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "打完了你，还叫你扮。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "我怎么那么贱骨头呢？那么着，我就扮新人。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你走过来！"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "唉！我这一道儿，净受他的窝囊气。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "有请员外。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善上。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "我二人意欲搭救你家小姐，不知意下如何？"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "倘能如此，小老儿感恩非浅，但不知有何妙计？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "少时自然明白。请借凤冠霞帔一用。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "丫鬟快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "来啦，来啦。什么事情？"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "见过壮士。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善下。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "参见壮士。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "丫鬟姐，借你家小姐凤冠霞帔一用。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "你这儿等着，我给你取去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟取衣。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "啊李二哥，你扮新人。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "好啦，我脱这个，穿那个。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵脱衣。丫鬟取出衣服。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "这是什么？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这是裙儿。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "这叫裙儿，来来来，穿上。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "嗳，这是系的。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "系的？好，你给我系上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵系裙。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "还有什么？你拿去。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "给你这个。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "这是什么？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这是衫儿。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "哦，裙儿他妹妹衫儿。你给我系在后头。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "嗳，这是穿的。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "好，那么我把它穿上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵穿衫。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "还有什么？你去拿去。穿这个多别扭！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "给你这个。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "这叫什么？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "这叫凤儿。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "哦，衫儿他妹妹凤儿。不用说这个是戴的。劳你驾，你给我戴上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵戴冠，转身向燕青。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "蒙儿——嘿，燕兄弟你瞧哥哥我扮的像不像？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "扮的倒像。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "叫你就冤苦了我啦。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "李二哥，可会妇人家行走？"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "那个，咱们会。你走开这儿！妇人家行走，必须这样走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵走。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "不像。丫鬟姐教导于他。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "你瞧着点：我们小姐出得门来，要这么一摆，要这么二摆，还有这么一捂；一 叉腰，要走一个跳三步。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "行啦，行啦。我学学：你们小姐出得门来，要这么一摆，要这么二摆。这是二 百啦；还有这么一捂，这叫二百五。一叉这个腰，来啦！要走一个跳三步。哎 哟，我岔了气啦。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "有请员外。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "嗳，兄弟！你请员外干嘛？你瞧我人不人、鬼不鬼的，这够多“寒蠢”！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟下，张志善上。李逵见张志善，遮面。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "哎呀，咋、咋、咋。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "因何这样打扮？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "我二人，一人扮作新人，一人扮作新人之弟；混上山去，杀他一个措手不及， 也好搭救你家小姐。"
        },
        {
          "character": "张志善",
          "type": "白",
          "text": "多谢二位壮士。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张志善下。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "燕青",
          "type": "念",
          "text": "安排打虎牢笼套，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青下。"
        },
        {
          "character": "李逵",
          "type": "念",
          "text": "准备金钩钓海鳌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵下。"
        }
      ]
    },
