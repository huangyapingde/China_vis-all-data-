{
  "script_id": "04010002",
  "title": "三击掌",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "王宝钏",
      "hangdang": "旦"
    },
    {
      "name": "王允",
      "hangdang": "老生"
    }
  ],
  "plot": "王宝钏与薛平贵的婚姻遭到王允的坚决反对。王宝钏指责父亲嫌贫爱富，不守信义。最后，她毅然地脱下\n“日月龙凤袄”、“山河地理裙”，同父亲三击掌，离开相府，到寒窑和薛平贵结婚。",
  "notes": "这个剧本是根据王瑶卿先生的演出本，由北京戏曲实验学校于玉蘅、常少亭与本院（中国戏曲研究院）编辑\n处田淞、吕瑞明共同整理的。因原本就很完整，整理时，仅对个别词句略加修正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王允上。"
        },
        {
          "character": "王允",
          "type": "引子",
          "text": "调和鼎鼐，位列三台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二家院同上。"
        },
        {
          "character": "王允",
          "type": "念",
          "text": "金殿伴至尊，文武献殷勤。膝下无有子，富贵等浮云。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "老夫，王允。在唐室驾前为臣，官居首相。膝下无儿，所生三女：长女金钏， 许配苏龙；次女银钏，许配魏虎；惟有三女宝钏尚未婚配。只因夫人染病在床， 宝钏侍奉不离左右，且喜夫人病愈。是老夫奏明圣上，圣上见喜，赐我儿日 月龙凤袄，山河地理裙；后宫娘娘闻知，又赐我儿五色绒线，绣成彩球；择定 二月二日在十字街前，高搭彩楼，抛球招赘。唉！不想我儿打中花郎平贵。想 老夫乃当朝首相，岂肯与花郎结亲；今日下朝观见新科状元才貌双全。我意欲 将这门亲事打退，将我儿许配状元为妻，不知我儿心意如何？ 家院！"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "后堂传话，三姑娘出堂。"
        },
        {
          "character": "二家院",
          "type": "同白",
          "text": "后堂传话，请三姑娘出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟、王宝钏同上。"
        },
        {
          "character": "王宝钏",
          "type": "引子",
          "text": "正宫赐绒线，抛球配良缘。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹万福。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "告坐。唤女儿出堂，有何训教？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "恭喜我儿，贺喜我儿！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿喜从何来呢？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "我儿抛球招赘，可知打中哪家王孙公子？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿不知打中哪家王孙公子。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "什么王孙公子，就是那花郎平贵。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "花郎平贵！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿命该如此。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿啊，为父今日早朝，观见新科状元才貌双全，我意欲将这门亲事打退，将我 儿许配状元为妻，不知我儿意下如何？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "爹爹在上，女儿先告不孝之罪。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "有话坐下讲。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "启禀爹爹：只因那年母亲染病，女儿每日在床前侍奉汤药，直到三载，母亲病 体痊愈。后宫娘娘见喜，赐儿五色绒线，绣成彩球，择定二月二日，在十字街 前，高搭彩楼，抛球招赘。打贫随贫，打富随富；慢说是打着花郎平贵，就是 打着一块顽石，女儿也要抱……"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "抱什么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "抱它三载，以表温暖之情。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "嗳！想那彩球乃是玩物，抛球招赘，犹如儿戏一般，难道说把我儿的亲事就定 死在花郎身上不成？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "啊爹爹，昔日孔夫子，绝粮陈蔡间；太公避纣乱，磻溪垂钓竿。二大古人尚且 如此，何况那平贵乎？女儿一言既出驷马难追。 打坐向前！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "啊？为父与你讲话，为何背过脸去，敢是与为父致气不成？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿怎敢与爹爹致气，怎奈婚姻已定，是万难更改！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "万难更改！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "儿就该掌嘴！"
        },
        {
          "character": "王宝钏",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "小奴才说此话全不思想， 只气得年迈人怒满胸膛。 儿大姐配苏龙户部执掌， 你二姐配魏虎兵部侍郎。 惟有儿失训教性情倔强， 千金体配花郎怎度时光。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "老爹爹请息怒容儿细讲： 儿命苦怎配得状元才郎。 父道那薛平贵是花郎模样， 落魄人得了志比父还强。"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "薛平贵生来命不济， 每日里在街头讨饭充饥。 破衣褴衫遮不住体， 遮住了肩头就露出了髁膝。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "昔日里有一个孟姜女， 曾与那范郎送寒衣。 哭倒了长城有数万里， 至今留名万古题。"
        },
        {
          "character": "王允",
          "type": "西皮原板",
          "text": "我的儿本是丞相女，"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "就该配济世安邦定国臣。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "张良、韩信与苏秦， 俱都是安邦定国臣； 韩信乞食于漂母， 登台拜帅第一人； 商鞅不中苏季子， 在六国封相人上人。"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "登台拜帅是韩信， 未央宫斩的是什么人？"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "未央宫斩的是韩信， 难道说文官就不丧身？"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "小奴才真个不孝顺， 仙姬女配的什么人？"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "仙姬女配的是董永， 大孝之人也受贫。"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "奴才说话言语拧， 句句顶得父心疼。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "非是孩儿言语拧， 爹爹为何你要退婚？"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "要退要退偏要退！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "不能不能万不能！"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "你若不把亲事退， 两件宝衣脱下身。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "请问爹爹，这两件宝衣是从何而来的？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "乃是圣上赐与为父的。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "圣上赐与爹爹所为何用？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "不过是念在君臣之义。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "却又来！圣上倒有君臣之义，难道爹爹你……就无有父女之情了么？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "只要我儿将这门亲事打退，慢说这两件宝衣，就是府下的金银也任儿搬取。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "儿不要了！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "先脱日月龙凤袄， 后解山河地理裙。 两件宝衣齐脱下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏脱衣。"
        },
        {
          "character": "家院甲",
          "type": "白",
          "text": "啊相爷，保重身体要紧，不要与三姑娘致气了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "哼！不用你管。"
        },
        {
          "character": "家院乙",
          "type": "白",
          "text": "啊相爷，不要与三姑娘致气了。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "哼！不用你管。"
        },
        {
          "character": "王宝钏",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "交与了嫌贫爱富的人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏扔衣与王允，王允扔回。王宝钏扔与丫鬟。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "前堂不与父争论。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "后堂去见儿的老娘亲。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "住了！前堂无有儿的父，后堂焉有儿的母。 家院，丫鬟，哪个带你三姑娘去往后堂，打断尔的狗腿！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "儿不去了！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "老爹爹你把心死了！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "怎见得为父把心死了？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "想大姐出嫁也有奁妆，二姐出嫁也有陪房，女儿今日出嫁，这两件宝衣都不叫 儿穿去，又不叫儿拜别母亲，岂不是把心死了么？"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "为父方才言过，只要我儿将这门亲事打退，慢说是两件宝衣，就是府下的金银， 任儿搬取，为父决不心疼。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "儿不要了！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "全不怕笑你无信人。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "嗳！笑女不笑父。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "笑父不笑女。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "笑为父何来？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "笑爹爹嫌贫爱富。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "为父嫌贫爱富，我为的是哪一个？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿不知。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "就为的是你这小奴才。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "女儿之事，何劳爹爹挂念，你……与我坐定了！"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "手摸着胸膛想一想， 膝下还有什么人？"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "膝下无儿怨我的命， 女儿家养不得老来也送不得终。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "若是母亲百年后， 女儿是披麻带孝人。"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "倘若为父下世去， 不用宝钏哭半声。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "倘若爹爹身亡故， 宝钏不来哭半声。"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "父死不把三女见，"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "女死不见老爹尊。"
        },
        {
          "character": "王允",
          "type": "西皮快板",
          "text": "日后谁把谁来见，"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "用手挖去儿双睛。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "为父不信哪！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "父不信与儿三击掌，"
        },
        {
          "character": "王允",
          "type": "西皮散板",
          "text": "活活气坏年迈人。 无奈何与儿三击掌， （王宝钏、王允欲击掌，家院、丫鬟相拦。王宝钏、王允欲击掌，家院、丫鬟相拦。王宝钏、王允同三击掌， 王允踹王宝钏跌地。）"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "哼！轰了出去！"
        },
        {
          "character": "王宝钏",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "一霎时失了父女情。"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "实可恨爹爹做事心太狠， 竟将我亲女赶出了府门。 可叹老娘疼儿甚， 现在后堂无所闻。 眼望后堂深施礼，"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "喂呀，儿的娘啊！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "一朝断肠两离分。 悲悲切切出府门，"
        },
        {
          "character": "众丫鬟",
          "type": "同白",
          "text": "三姑娘！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "又听丫鬟唤一声。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你们前来作甚？"
        },
        {
