    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "夏侯尚",
      "hangdang": "丑"
    },
    {
      "name": "张郃",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    }
  ],
  "plot": "蜀老将黄忠，当曹操攻打西蜀重镇葭萌关时，发挥老当益壮的精神，向诸葛亮讨令拒敌，打退了敌将张郃，\n乘胜攻占了曹军屯粮的天荡山，又再接再厉地用计斩了曹军大将夏侯渊，夺取了曹军大本营所在的定军山。",
  "notes": "《定军山》是《三国演义》中的一段故事。这个剧本的整理工作是演员谭富英与本院编辑处陶君起共同进行\n的。在研究过程中，北京戏曲实验学校教员贯大元也参加了意见。主要的修改处如下：\n一、原本中对于谁攻谁守葭萌关，有好几处混淆不清；现根据《三国演义》，确定葭萌关为刘备所辖。\n二、原本第一场上赵云，只作传令、传话，与身份不合，现改为张著。若与《阳平关》连演，人物亦可前后\n一致。\n三、原本第二十一场“走马换将”时，黄忠说：“老夫若有二意，死在药箭之下。”若作为一般设誓，本无\n不可；但在《伐东吴》剧中，黄忠果然死于药箭，未免有迷信之嫌。现改为“丈夫一言，岂肯失信于你！”\n四、原本词句一般地比较粗糙，而且有几处情节，前后略有矛盾，整理时曾加以修润。此外，原本中有的地\n方称“军师爷”为“师爷”，称“我”为“某”，均因有关唱法，未予更动。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引张著、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "点绛唇",
          "text": "汉末三分，干戈不宁，领人马，抵挡曹兵，要把乾坤定。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "巴蜀稳定仗荆襄，联吴拒曹守边疆。一片丹心扶社稷，扭转汉室锦家邦。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人，诸葛亮。闻听张郃攻打葭萌关，必须派一能将，前去迎敌。 来，张著听令。"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传令下去：可有能将，去至阆中，替回三将军，大战张郃？"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "得令。 令出——下面听者：军师有令，可有能将，去至阆中，替回三将军，大战张郃？"
        },
        {
          "character": "黄忠",
          "type": "内白",
          "text": "慢着。"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "何人阻令？"
        },
        {
          "character": "黄忠",
          "type": "内白",
          "text": "黄忠。"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "随令进帐。"
        },
        {
          "character": "黄忠",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "报，黄忠告进。 参见军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "黄老将军少礼。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "谢军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军因何阻令？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "军师！闻听张郃攻打葭萌关，何劳三将军前往。末将不才，带领要马，大战张 郃。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军年迈，岂是那张郃的对手？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "军师！"
        },
        {
          "character": "黄忠",
          "type": "念",
          "text": "末将年迈勇，血气贯长虹。斩将如削草，跨马走西东。 两膀千斤力，能开铁胎弓。若论交锋事，还算老黄忠。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "帐下有一铁胎弓，你若开得，就命你前去。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "黄忠",
          "type": "西皮二六板",
          "text": "师爷说话言太差， 不由黄忠怒气发。 一十三岁习弓马， 威名镇守在长沙。 自从归顺皇叔爷的驾， 匹马单刀取过了巫峡。 斩关夺寨功劳大， 师爷不信在功劳簿上查一查。 非是我黄忠夸大话，"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "弓来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠取弓。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "铁胎宝弓手中拿。 满满搭上朱红扣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠拉弓，众人同喝采。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "帐下儿郎个个夸。 二次再用这两膀力，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠拉弓，众人同喝采。"
        },
        {
          "character": "黄忠",
          "type": "西皮快板",
          "text": "人有精神力又加。 三次开弓秋月样，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠拉弓，众人同喝采。黄忠收弓。"
        },
        {
          "character": "黄忠",
          "type": "西皮散板",
          "text": "再与师爷把话答。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "帐外候令。"
        },
        {
          "character": "黄忠",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传令下去：可有能将，辅佐黄老将军，大战张郃？"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "得令。 令出——下面听者：可有能将，辅佐黄老将军，大战张郃？"
        },
        {
          "character": "严颜",
          "type": "内白",
          "text": "严颜愿往。"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "随令进帐。"
        },
        {
          "character": "严颜",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜上。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "报，严颜告进。 参见军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "严老将军少礼。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "谢军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军进帐何事？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "末将不才，情愿辅佐黄老将军，大战张郃。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "老将军年迈，岂是张郃的对手？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "军师！"
        },
        {
          "character": "严颜",
          "type": "念",
          "text": "老将今年八十一，拔山举鼎力有余。万马军中无人敌，斩将杀贼哪算奇。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "多日未曾出兵，不知你枪法如何？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "若论枪法，取上将的咽喉，犹如探囊取物一般。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "当帐演来。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "严颜",
          "type": "西皮快板",
          "text": "军师休道我年纪大， 有几辈老将听根芽： 赵国廉颇通兵法， 汉室马援定邦家。 虎头金枪耍一耍——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "军士抬枪上，严颜舞枪。"
        },
        {
          "character": "严颜",
          "type": "西皮散板",
          "text": "我比黄忠也不差。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传黄老将军进帐。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "黄老将军进帐。"
        },
        {
          "character": "黄忠",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "参见军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "黄老将军以为正帅。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "严老将军以为副帅。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "听我令下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士暗同上。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮流水板",
          "text": "一个西川英名大， 一个威震在长沙； 二位老将齐上马， 得胜回来把功加。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "黄忠接令把帐下，"
        },
        {
          "character": "严颜",
          "type": "西皮摇板",
          "text": "不由严颜笑哈哈。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "一不用战鼓咚咚地打，"
        },
        {
          "character": "严颜",
          "type": "西皮摇板",
          "text": "二不用副帅把队押。"
        },
        {
          "character": "黄忠",
          "type": "西皮摇板",
          "text": "事不宜迟把马跨——"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠上马，下。四军士同下。"
        },
        {
          "character": "严颜",
          "type": "西皮摇板",
          "text": "要把张郃一马踏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜下。"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "此番大战，军师为何单派二位老将前往？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二位老将，有勇有谋，此去必然成功。命你押解粮草，军前听用，不得有误。"
        },
        {
          "character": "张著",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "退帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引陈式同上。"
        },
        {
          "character": "陈式",
          "type": "念",
          "text": "阵前打败仗，含羞脸无光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "二位老将军到。"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。黄忠、严颜、四军士同上，黄忠、严颜同下马，入帐分坐。"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "参见二位老将军。"
        },
        {
          "character": "黄忠、严颜",
          "type": "同白",
          "text": "罢了，一旁坐下。"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "可曾与那贼见过阵来？"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "见过一阵，大败而归。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "唗！无能之将，败我头阵，推出斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈式跪。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "且慢，军家胜败，古之常理。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "敢是与他讲情？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "不敢，老将军开恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜向陈式。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "还不谢过黄老将军！"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "多谢黄老将军。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "陈式听令：城楼高扯红旗二面，上写黄忠、严颜，那贼闻名丧胆。"
        },
        {
          "character": "陈式",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈式下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报。 张郃讨战！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "老将军，张郃小儿来了，你我会他一会。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "众将官，带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、严颜同上马，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。四军士引张郃同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "某张郃。奉了魏王旨意，攻打葭萌关。探马报道：黄忠、严颜兴兵前来，岂肯 容他猖狂。 众将官，杀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士引黄忠、严颜同上。会阵。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "老夫黄忠。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "老夫严颜。"
        },
        {
          "character": "张郃",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈。"
        },
        {
          "character": "黄忠、严颜",
          "type": "同白",
          "text": "尔为何发笑？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "我道黄忠、严颜天神下界，原来是两个老匹夫！"
        },
        {
          "character": "黄忠",
          "type": "白",
