        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "萧天佐摆天门一百单八， 难道说她阵阵都能去杀？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "嗳，我去问她。 啊，穆小姐，天门阵一百单八，难道说阵阵你都能杀吗？"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "自幼儿学武艺深通兵法， 纵有那千万阵也能斩杀。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哼，是个好嗒。 元帅，一千阵一万阵，她都能杀。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哦，她都能？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "她都能。"
