        {
          "character": "孟良",
          "type": "白",
          "text": "小本官进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保、穆桂英同上。"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
          "text": "我这里向前去心中害怕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保跪。"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
          "text": "孩儿我永不敢再犯军法。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "谁叫你违父命私犯军法， 险些儿辕门外命染黄沙。 恨不得这一足将儿踏！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "使不得！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "你不爱他我爱他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保、穆桂英同下。"
        },
        {
          "character": "焦赞",
