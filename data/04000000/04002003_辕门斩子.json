          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "本帅收了穆桂英，赦了杨宗保，有保状者，呈上。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "下面听着。"
        },
        {
          "character": "四兵士",
          "type": "内同白",
          "text": "啊。"
        },
        {
          "character": "孟良、焦赞",
