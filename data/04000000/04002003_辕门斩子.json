{
  "script_id": "04002003",
  "title": "辕门斩子",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "赵德芳",
      "hangdang": "老生"
    },
    {
      "name": "孟良",
      "hangdang": "净"
    },
    {
      "name": "焦赞",
      "hangdang": "净"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "穆桂英",
      "hangdang": "旦"
    },
    {
      "name": "穆瓜",
      "hangdang": "丑"
    }
  ],
  "plot": "杨宗保回营后，由于他私去穆柯寨临阵招亲，杨延昭盛怒之下，一定要按军法将杨宗保斩首。孟良、焦赞、\n佘太君、八贤王讲情都无效果；最后穆桂英赶来献出降龙木，并自称能破天门阵，杨延昭才准了她的人情，\n饶恕了杨宗保。",
  "notes": "本剧是由中国京剧团演员李和曾与本院（中国戏曲研究院）编辑处祁野耘共同整理的。\n主要修改的地方：一，原本为了突出穆桂英，过分地强调了杨延昭见到穆桂英而害怕，这样来刻画杨延昭这\n个英雄人物显然是很不恰当的；整理本恢复了杨延昭的主帅风度。二，原本八贤王讲情不准，写杨延昭过于\n剑拔弩张，为了更合情合理，整理本把“刖马足”的情节改成了“交印”。三，删去了把杨家将的爱国行为\n都归之于天意的“天书”。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵士、孟良、焦赞、杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "山东把阵败，怒气满胸怀。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，这里来。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "元帅今日升帐，与往日大不相同，你我要小心伺候了。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "大家小心。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "宗保到来，叫他报门而进！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊，二哥，小本官不见回转，如何是好？你我出营瞭望瞭望。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "好，瞭望瞭望。"
        },
        {
          "character": "杨宗保",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "离了穆柯寨，来此是宋营。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "参见二位叔父。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "罢了。小本官回来了。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "我爹爹可曾升帐？"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "升帐多时了。元帅今日升帐，与往日大不相同，你要小心了。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "带我转去。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎，大丈夫只有向前，哪有退后之理。 二哥与他报门。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "小本官告进。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "参见父帅。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "小本官当面。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "下跪可是杨宗保？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将，掌起面来。 好奴才！"
        },
        {
          "character": "杨延昭",
          "type": "西皮散板",
          "text": "怒恼杨延昭， 蠢子听根苗。 命儿巡营哨， 私自把亲招。 枪挑穆天王， 桂英下山巢。 将父擒下马， 这笑……笑坏了众英豪。 焦、孟一声叫， 将奴才绑辕门定斩不饶！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，这里来。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "小本官犯罪，乃是你我兄弟二人的引诱，必须进帐与他讲个人情。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "恐怕这个人情，讲不下来。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "不要紧，元帅喜欢的是我。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "好，一同进帐。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "焦、孟二将，与元帅扣头。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你二人施礼为何？"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "小本官犯罪，理当斩首，念在我兄弟二人鞍前马后，有些小的功劳，望求元帅 开恩饶恕！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "敢是与他讲情？"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "元帅开恩。"
        },
        {
          "character": "杨延昭",
          "type": "冷笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞向孟良。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "行，有门儿。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唗！宗保犯罪，乃是你二人的引诱，先斩宗保，然后再取你二人的首级！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "咋咋咋……"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我说这个人情讲不下来，你说有你！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你说有你！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "呸！招打！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥别着急，你看好了小本官，我去请老太太去，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞下。焦赞扶佘太君同上。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "慢着点儿，慢着点儿。"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "听说是斩宗保把我吓坏， 行一步险些儿跌倒尘埃。 见孙儿绑至在帐门以外， 但不知因何事要把刀开？"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
          "text": "都只为招亲在穆柯山寨， 因此上绑辕门要把刀开。"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "劝孙儿免悲声休要急坏， 待祖母进帐去把情讲来。 叫焦赞和孟良前把路带， 大胆的杨延昭不下位来。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "太君到！"
        },
        {
          "character": "杨延昭",
          "type": "西皮导板",
          "text": "忽听得老娘亲来到帐外，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "太君到！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵士同下。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "元帅他知道啦。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "知道啦？原要他知道，知道的好。"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "杨延昭下位去迎接娘来。 见老娘施一礼躬身下拜——"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "不消！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "不消！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "问老娘驾到此所为何来？"
        },
        {
          "character": "佘太君",
          "type": "西皮原板",
          "text": "娘进帐我的儿理应自解， 反把这假殷勤问娘何来！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "老娘亲进帐来怒气难解， 莫不是为宗保他不肖的奴才？"
        },
        {
          "character": "佘太君",
          "type": "西皮原板",
          "text": "小孙儿他犯了何条律戒， 为什么绑辕门要把刀开？"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "提起来把儿的肝肠气坏， 恨不得将奴才斧劈刀开。 儿命他领人马巡查边界， 谁叫他穆柯寨私配裙钗。 因此上儿将他捆绑营外， 问老娘儿斩他该是不该？"
        },
        {
          "character": "佘太君",
          "type": "西皮原板",
          "text": "犯将令本应当斩首营外——"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "谢母亲。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "斩不得。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "佘太君",
          "type": "西皮原板",
          "text": "还看他年纪小无知的奴才。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "娘道他年岁小孩童气概，"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "说几个年幼人娘且听来： 秦甘罗十二岁身为太宰； 石敬瑭十三岁拜将登台； 三国中周公瑾名扬四海， 十岁上学兵法颇有将才， 十二岁掌东吴水军元帅， 他看着曹孟德如同婴孩； 在赤壁用火攻神鬼难解， 烧曹兵八十万无处葬埋。 这都是父母生非神下界， 难道说小奴才是禽兽投胎！"
        },
        {
          "character": "佘太君",
          "type": "西皮快板",
          "text": "听罢言不由娘牙根咬坏， 骂一声杨延昭不肖奴才。 你的父抗辽兵尸留北塞， 一家人只死得好不伤怀。 到如今只剩下宗保血块， 眼睁睁还要他祭扫坟台。 倘若是小孙儿有个好歹， 那时节管教儿悔不转来！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "昨日里斩八将头挂营外， 老娘亲你为何不讲情来？ 今日里斩宗保娘把儿怪， 哭啼啼坐帐中珠泪满腮。 叫焦赞……"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "将宝剑悬挂帐外——"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞持剑下。"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "老娘亲再讲情儿自刎头来。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "杨延昭性倔强令人可恼， 他不把母子情放在心梢。 眼睁睁小孙儿性命难保，"
        },
        {
          "character": "佘太君",
          "type": "哭头",
          "text": "孙儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞引赵德芳同上。孟良对佘太君。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君下。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "赵德芳急忙忙下了鞍鞒。 御外甥把什么军令犯了， 却为何绑辕门定斩不饶？"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
          "text": "穆柯寨招亲事把军令犯了， 因此上我父帅定斩不饶。"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "劝外甥休得要心中烦恼， 待为王进帐去与你讨饶。 叫焦赞与孟良前面引道—— 杨延昭不下位藐视当朝。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "贤爷到！"
        },
        {
          "character": "杨延昭",
          "type": "西皮导板",
          "text": "耳边厢又听得贤爷驾到，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "贤爷到！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "元帅他又知道啦。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "他又知道啦？原要他知道，知道的好。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "无故的到虎帐所为哪条？ 见千岁施一礼躬身拜倒——"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "臣延昭接驾迟贤爷恕饶。"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "赵德芳坐虎帐满脸陪笑， 尊一声御妹夫细听根苗： 御外甥把什么军令犯了， 却为何绑辕门定要开刀？"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "臣命他领人马巡营瞭哨， 又谁知穆柯寨他私把亲招。 临阵上招亲事军令犯了， 因此上绑辕门定斩不饶。"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "御外甥犯将令理当斩了——"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "念为王讲人情将他恕饶。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "君有命臣当领怎敢违了， 哪有个食君禄不顺当朝。 赦却了小宗保事也还小， 宋王爷降下罪谁敢承招？"
        },
        {
          "character": "赵德芳",
          "type": "西皮原板",
          "text": "慢说是我叔王圣旨来到， 纵有那塌天祸有我承招。"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "八千岁休得要性情高傲，"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "为什么在帐中絮絮叨叨。 斩不斩乃是我军中令号， 并不曾犯千岁哪件律条！"
        },
        {
          "character": "赵德芳",
          "type": "西皮快板",
          "text": "曾记得你七弟打死潘豹， 潘仁美上金殿启奏当朝。 我叔王龙颜怒降旨一道， 要将你一满门拿去开刀。 若不是为王我把本来保， 到如今你焉有这玉带紫袍！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "我大哥替宋王把忠尽了， 我二哥丧剑下血染征袍， 我三哥被马踏尸骨难找， 我四哥与八弟无有下梢， 我五哥弃红尘削发修道， 我七弟被潘洪射死芭蕉， 只剩下杨延昭南征北剿， 论功劳才挣下这玉带紫袍。"
        },
        {
          "character": "赵德芳",
          "type": "西皮散板",
          "text": "臣有功君有赏乃是正道， 我面前岂容你卖弄功劳！"
        },
        {
          "character": "杨延昭",
          "type": "西皮散板",
          "text": "你把你南清宫忒看大了，"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "本来的不小。"
        },
        {
          "character": "杨延昭",
          "type": "西皮散板",
          "text": "哪把我杨元帅放在心梢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭入座。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "八千岁！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "杨元帅！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "赵德芳！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "延昭，大胆！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来此什么所在？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "小小的白虎节堂。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "既知是白虎节堂，为何在此摆来摆去？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "慢说是小小的白虎节堂，就是我叔王的金銮宝殿，我也要摆上几摆。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "擅闯辕门，就该斩！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哪个敢斩？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "杨延昭",
          "type": "西皮散板",
          "text": "赵德芳出此言我难以答话， 不由得杨延昭心乱如麻。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "杨延昭",
          "type": "西皮散板",
          "text": "我这里捧帅印忙把位下。"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "尊千岁听为臣再把话答： 既然是南清宫势力浩大， 又何必我杨家东挡西杀； 杨延昭为元帅难以执法， 你就该掌兵权自把令发。 怒冲冲将印信急忙交下——"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "使不得，使不得！"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "破天门保江山你另选别家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "杨延昭交帅印令我害怕， 破天门保江山还要仗他。 眼睁睁御外甥不能救下……"
        },
        {
          "character": "赵德芳",
          "type": "哭头",
          "text": "御外甥哪！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "贤爷请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳、孟良、焦赞同下。穆瓜、穆桂英同上。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "穆桂英下山来投效皇家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖行弦〗，〖锣鼓声〗。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "耳边厢又听得锣鸣鼓打， 辕门外摆刀枪剑戟如麻。 我这里叫穆瓜前去问话， 或斩兵或斩将细问根芽。"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "穆瓜",
          "type": "西皮摇板",
          "text": "穆小姐她那里把令传下， 辕门外吩咐我大将穆瓜。 我这里走向前观看一下，"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "哎呀，不好了！"
        },
        {
          "character": "穆瓜",
          "type": "西皮摇板",
          "text": "辕门外绑的是我家姑爷，你的他，你快去救他！"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "听一言不由我急忙下马，"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "是不是穆柯寨招亲事发？"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "将军，将军哪！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "我这里问他言他不答话， 转面来叫一声大将穆瓜。"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "三千担粮草哪？"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "辕门堆下，"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "五百名兵丁哪？"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "暂且安札。"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "这降龙木哪？"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "交与我，"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "那么我哪？"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "你且退下。"
        },
        {
          "character": "穆瓜",
          "type": "白",
          "text": "咋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆瓜下，穆桂英进帐，跪。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "他那里问一声我再把话答。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞、孟良同上。杨延昭暗上"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，这里来。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "适才太君讲情，贤爷讲情，元帅他都不准，你我且到帐外看守小本官，看他是 怎样的发落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞见穆桂英跪帐下，招呼孟良报知杨延昭。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "女将跪帐！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "适才间与贤爷帐中叙话， 只气得杨延昭咬碎钢牙。 睁双眼我这里观看帐下，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "女将跪帐！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "宝帐下跪的是女将娇娃。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦赞！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "叫焦赞近前来急忙传话， 问女将名和姓哪里有家？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "咋。 那一女子，家住哪里，姓甚名谁？你慢慢的讲来！"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你讲啊。"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "家住在山东地穆柯寨下， 我的名穆桂英……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞大惊。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "咋咋咋……"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "宗保的浑家。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊，元帅。这就是穆桂英，她她……来了。哇呀呀……"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "听说是穆桂英来到了白虎帐下，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，元帅听说穆桂英来了，连嗓子眼儿都吓小啦。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "宋营中来了个杀人的夜叉！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦赞！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "问小姐她不在山中潇洒， 来至在宋营中有何话答？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "咋。 穆小姐，我家元帅问你：你不在山东穆柯寨，来到我宋营做甚哪？"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "咋。"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "三千担干粮草辕门堆下，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "五百名勇兵丁营外安札；"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "穆桂英",
          "type": "西皮原板",
          "text": "随带来降龙木此宝无价， 特地里到宋营献与皇家。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊，元帅，她是进宝来的。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "杨延昭",
          "type": "西皮原板",
          "text": "听罢言来笑开怀，"
        },
        {
          "character": "杨延昭",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "焦赞将宝呈上来。 我为你终日里愁眉不解， 破天门不得安排， 我为你山东把阵败， 要斩小奴才。 焦赞将宝后帐摆—— 且候五哥下山来。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "三千粮草？"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "堆在营外，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "五百兵丁？"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "改换腰牌。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "穆小姐？"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "暂回那穆柯山寨， 奏明了宋天子接进营来。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊，穆小姐，我家元帅言到：叫你暂回山寨，奏明了宋天子，再将你接进营来。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "我还有话讲。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊，元帅——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞学穆桂英口气。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "我还有话讲。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "这是她说的。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "小将军他犯了何条军法， 为什么绑辕门要把头杀？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "元帅，她是为小本官而来。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "斩宗保只因他犯了军法， 穆小姐回山寨休要管他。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "元帅说：小本官犯了军令，叫你少管闲事。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "我还有话讲。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "小将军犯军令理当斩杀， 看在我进宝功饶恕于他。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "着啊，要看在她进宝的功劳。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "若不看进宝的功劳大， 连小姐与宗保一齐斩杀！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊，穆小姐，元帅言到：若不念你进宝有功，连你带他一块儿杀。这个事儿， 净说不行；干脆，你拿这个家伙儿——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞指刀。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "吓唬吓唬他。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "嗳——"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "老元戎他不把人情准下，"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "拔宝剑杀一个血染黄沙！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "啊，元帅！那穆桂英她、她……杀来了！"
        },
        {
          "character": "杨延昭",
          "type": "西皮导板",
          "text": "叫焦赞和孟良急忙招架！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "招架不住啦！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "为什么在帐中舞爪张牙？ 我若是将她的人情准下， 萧天佐天门阵哪个去杀？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "元帅言到：若是将你的人情准下，那天门阵何人去杀呀？"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "听了。"
        },
        {
          "character": "穆桂英",
          "type": "西皮摇板",
          "text": "老元戎他若把人情准下， 天门阵自有我前去征杀。"
