{
  "script_id": "04010003",
  "title": "平贵别窑",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "武生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    }
  ],
  "plot": "薛平贵降伏了红鬃烈马，唐王封他为“后军都府”，王允却故意将他改为“马前先行”，并派他远征西凉。\n这一对新婚不久的夫妇，不得不忍痛地分别了。",
  "notes": "这个剧本是由中国京剧团演员李洪春、云燕铭与本院（中国戏曲研究院）编辑处吕瑞明共同整理的。因原本\n就很完整，整理时，仅对个别词句略加修正。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "引子",
          "text": "身居寒窑，终日里，愁锁眉梢。"
        },
        {
          "character": "王宝钏",
          "type": "念",
          "text": "思念萱堂泪滔滔，爹爹枉自伴当朝。嫌贫爱富世间少，父女恩情一旦抛。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我，王宝钏。我父王允，唐室为臣，官居首相，膝下无儿，所生我姐妹三人： 大姐金钏许配苏龙；二姐银钏许配魏虎。只因母亲身染重病，是我每日在床前 侍奉汤药，直到三载，我母亲病体痊愈。后宫娘娘闻知此事，亲赐五色绒线， 绣成一球，在十字街前，高搭彩楼，抛球招赘，打中薛郎平贵。我父嫌贫爱富， 叫我退去平贵婚姻，改配新科壮元赵宣。是我不允，与爹爹三击掌，誓死不 回相府，与薛郎来在寒窑，苦度光阴。自离相府，每日思念母亲，也不知我母 亲身体是否安泰？思想起来，好不闷煞人也！"
        },
        {
          "character": "王宝钏",
          "type": "二黄慢板",
          "text": "王宝钏思萱亲伤心泪掉， 老爹爹枉为了一品当朝。 嫌贫寒爱富贵世间稀少， 他把那父女情一旦相抛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏出窑，望。"
        },
        {
          "character": "王宝钏",
          "type": "二黄慢板",
          "text": "薛郎他虽贫寒志量非小， 去投军我料想定显英豪。 将身儿回寒窑将门闭了， 候薛郎投效归细说根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上，起霸。"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "头戴金盔一点红，身披铠甲扣玲珑。自从降了红鬃马，唐王驾前立大功。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "俺，薛平贵。只因降了红鬃烈马，唐王见喜，将俺封为后军督府。西凉下国打 来连环战表，要夺我主江山社稷。可恨王允老贼，上殿奏本，保苏龙魏虎以为 正副元帅；将俺后军督府，改为马前先行。为此全身披挂，回至寒窑，辞别三 姐。天哪，天！困煞俺英雄也！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "恼恨王允太不仁，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上马。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "屡害平贵所为何情？ 催马加鞭往前进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵下马。"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "叫声三姐快开窑门。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "忽听门外有人唤， 想是薛郎回窑前。 开开窑门用目看，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵进窑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "薛郎怎得荣耀还？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎，回来了！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "回来了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你哪里来得这身荣耀？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "只因降了红鬃烈马，唐王见喜，将俺封为后军督府。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "噢！如此说来，你作了官了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "作了官了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待我谢天谢地。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "且慢！慢谢天地，其中有变。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "此话从何说起？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！只因西凉下国，打来连环战表，要夺我主江山社稷；可恨你父上殿奏本， 保苏龙魏虎以为正副元帅，将俺后军督府改为马前先行。为此全身披挂回至 寒窑，辞别三姐，我就要启程了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "就要启程了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏晕倒。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐醒来！"
        },
        {
          "character": "王宝钏",
          "type": "西皮导板",
          "text": "听一言吓得我魂魄飘洒，"
        },
        {
          "character": "王宝钏、薛平贵",
          "type": "同三叫头",
          "text": "（薛郎）（三姐）！（我夫）我妻）！（夫哇）（妻呀）！"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "不由人一阵阵泪流如麻。 父好比秦赵高指鹿为马， 父好比汉萧何私造律法。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "说什么秦赵高指鹿为马， 讲什么汉萧何私造律法。 你的父与平贵冤仇结下， 害得我夫妻们各奔天涯。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "手指着相府高声"
        },
        {
          "character": "王宝钏",
          "type": "西皮二六板",
          "text": "叫骂， 爹爹作事理太差， 好端端鸳鸯遭棒打，"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "狠心的爹爹呀！"
        },
        {
          "character": "王宝钏",
          "type": "西皮摇板",
          "text": "你去后为妻我怎度生涯？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "三姐不必泪双流， 平贵言来听从头： 干柴十担米八斗， 你在寒窑苦度春秋。 守得住来将我守，"
        },
        {
          "character": "薛平贵",
          "type": "哭头",
          "text": "三姐呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "难度光阴你将我丢。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "薛郎说话没来由， 为妻言来听从头： 干柴十担米八斗， 留在寒窑度春秋。 夫妻恩深情义厚， 饿死寒窑也不回头。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "三姐情义世少有， 倒叫平贵脸含羞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "平贵听令！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "在！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵出窑。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "元帅初点大卯，不可违误卯期，速到校场听点！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "将军不下马！"
        },
        {
          "character": "薛平贵",
          "type": "念",
          "text": "各自奔前程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下，薛平贵进窑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎，外面何人到此？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！中军到此传令：元帅初点大卯，不可违误卯期。一卯不到一捆四十；二 卯不到两捆八十；三卯不到人头落地。军务紧急，我就要启程了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎你……这就要走么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "军务要紧哪！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你有什么言语，嘱咐为妻几句吧！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "唉！此时我心如刀割，纵有满腹的言语，一时也讲不出来了。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎啊！你今此去，不定三年五载，才得回来，撇下为妻何以度日呀？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "三姐！方才言得明白，寒窑现有干柴十担，老米八斗，你在寒窑苦度贫寒……"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "若是不够呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "若是不够，你……回转相府去吧！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎啊！你可记得我在相府与我爹爹三击掌，纵然饿在死寒窑，也是不回去的 了哇……"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "好哇！三姐心如铁石，令人可敬。为丈夫此番出征，不定三年五载，才得回来， 你在这窑前、窑后、窑左、窑右，与人家浆浆洗洗，缝缝连连，耐等为丈夫 回来，我是一家一家地登门叩谢。话已讲明，我就要启程了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "薛郎当真要走？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "当真要走。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "果然要走？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "军务紧急呀！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "待为妻送你一程。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "外面风大，不送也罢。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我一定要送。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "如此有劳了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵出窑门，头碰门上。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "碰着了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不妨事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵、王宝钏同出窑，薛平贵牵马。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "王宝钏送薛郎心酸难忍，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "倾刻间夫妻们就要离分。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "但愿得此一去旗开得胜，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "自有那探马儿来报信音。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "一路上必须要保重谨慎，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "你在这寒窑内苦度光阴。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "送薛郎送至在三岔路口，"
        },
        {
          "character": "王宝钏",
          "type": "哭头",
          "text": "喂呀，我的夫啊！"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "叫人难舍又难分。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "从空降下无情剑"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "斩断人间夫妻情。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "流泪眼观流泪眼，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "断肠人送断肠人。"
        },
        {
          "character": "王宝钏",
          "type": "西皮快板",
          "text": "宝钏舍不得薛平贵，"
        },
        {
          "character": "薛平贵",
          "type": "西皮快板",
          "text": "平贵难舍妻宝钏。"
        },
        {
          "character": "王宝钏、薛平贵",
          "type": "同哭头",
          "text": "夫妻们只哭得泪如雨降， 我的——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏、薛平贵同相望。"
        },
        {
          "character": "王宝钏、薛平贵",
          "type": "同哭头",
          "text": "（夫）（妻）呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "号炮三声。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "又听号炮响连声。 不辞三姐跨金蹬，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏扯住薛平贵，薛平贵、王宝钏同走圆场。"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "扯住薛郎不放行。 你要走来将我带！"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "你苦苦的拉我为何来？"
        },
        {
          "character": "王宝钏",
          "type": "西皮散板",
          "text": "你去不定三五载， 你把为妻怎安排？"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
