{
  "script_id": "04017004",
  "title": "五台山",
  "alias": [
    "五台会兄"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "杨延德",
      "hangdang": "净"
    },
    {
      "name": "杨延昭",
      "hangdang": "老生"
    }
  ],
  "plot": "六郎杨延昭到北国昊天塔盗取了他父亲令公的遗骨，兼程而归。行至五台山，夜宿古庙中，遇见了在沙滩赴\n会时看破朝廷权奸用事，愤而削发出家的五郎杨延德。因阔别日久，彼此不敢贸然相认；几经盘询，始知是\n弟兄相遇。悲痛未已，北国追兵已临山下。五郎延德持杖下山，战退追兵，弟兄二人遂挥泪而别。",
  "notes": "本剧是《杨家将》传说中的一节，是一个流传较广的传统剧目，各剧种中多有这一剧目。并且有的剧本对人\n物性格、思想、感情，都作了很细致、生动的刻画与描写。如川剧就是其中很好的一个。而在京剧中，基本\n情节虽然相同，但在这一方面的描述，却比较简略、粗糙，这也是本剧在近年京剧舞台上已不太流行的原因\n之一。因此在进行整理时，针对以上缺点，参考了地方剧本，适当地吸收了川剧、湘剧的优点，特别是在\n“兄弟初见”、“六郎盘兄”等情节上，都作了一些补充和改动。\n本剧的整理是由中国京剧团演员赵文奎、杨少龙与本院（中国戏曲研究院）编辑处吕瑞明、何旭异共同进行\n的。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "休赶哪，休赶！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "打开玉笼飞彩凤， 挣断金锁走蛟龙。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "俺，六郎延昭。奉了母亲之命，去到北国昊天塔，搬请爹爹骸骨。且喜骸骨到 手，不想又被辽兵赶来；是俺杀退追兵，行至此处，天色不早，前面有一古庙， 不免前去借宿一宵便了。"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "催马加鞭往前进， 不觉来到古庙门。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来此已是古庙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下马。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父有么？"
        },
        {
          "character": "老僧",
          "type": "内白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧上。"
        },
        {
          "character": "老僧",
          "type": "念",
          "text": "扫地不伤蝼蚁命，爱惜飞蛾纱罩灯。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "是哪一位？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧开门。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父！"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "原来是位壮士，到此何事？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "俺乃行路之人，行至此处，天色已晚，意欲在宝刹借宿一宵，明日早行。望求 师父方便方便！"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "请问壮士，从哪道而来？要往何方而去？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "从北国而来，要往南朝而去。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "原来如此。出家人慈悲为本，方便为门。来来来，待老僧与壮士牵马。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "这就不敢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭拉马，进内。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "壮士可用斋饭？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "前面用过了。请借明灯一盏。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "请少待。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧取灯。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "灯到。 我有一徒儿性情不好，少时回来你要留心一二。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "有劳了。师父请便。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "贫僧失陪了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧下。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看师父已去，不免取出爹爹骸骨一观便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭取包裹。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "令公！我父！爹爹呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "一见骸骨两泪淋， 怎不叫儿痛伤情。 哭一声老爹爹，啊……老爹爹呀！ 可叹你为国家命丧番营。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看天色不早，待我安歇了吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭收好包裹，搜殿，关门，睡。"
        },
        {
          "character": "杨延德",
          "type": "内白",
          "text": "好酒！"
        },
        {
          "character": "杨延德",
          "type": "二黄导板",
          "text": "五台山出了家当了和尚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德醉上。"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "天波府抛却了年迈萱堂。"
        },
        {
          "character": "杨延德",
          "type": "念",
          "text": "脱去蟒袍换袈裟，金刀割去顶上发。不愿在朝陪王驾，五台山上出了家。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "洒家，五郎延德。适才在山下赴牛羊大会去了，那些施主们取来大坛的酒，这 个敬俺一杯，那个敬俺一盏，不觉吃得这般醺醺大醉。看天色不早，犹恐师父 悬望，不免回山便了！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "忆昔当年幽州闯， 杨家死得好惨伤。 冷眼看破君王面， 弃官削发换僧装。 层层叠叠山岗上——"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "只见红日落西方。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "看山门紧闭，待我向前叫门。 开门来，嘚！开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧上。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "外面喧哗，想是徒儿回来了。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "为何这样慢腾腾的，待俺打了进去……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧开门，扶杨延德入内。杨延德看。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哎呀呀，我道是谁，原来是师父！"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "啊，徒儿，哪里吃得这样醺醺大醉？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "师父哪里知道，适才弟子下山，那些施主们取来大坛的酒，这个敬俺一杯，那 个敬俺一盏，不觉吃得这般……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德吐。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "喔……我有偏师父了。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "你我乃是出家之人，下次不可。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "弟子记下了。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "来来来随为师禅堂打坐。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "弟子尊命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德欲下。〖马嘶声〗。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "啊师父，清静的禅院，缘何有这马嘶之声？"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "徒儿哪里知道，有一壮士从北国而来，往南朝而去，天色已晚，在此借宿一宵。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哦，北国而来，南朝而去？ 啊师父，你可曾盘问于他？"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "今晚借宿一宵，明日即行，盘问做甚？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "嗳！恐他来路不明，待弟子盘他一盘。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "他明早即行，你不要生事。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "弟子不敢生事。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "你不要闯祸。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "弟子不敢闯祸。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "依为师的看来，还是不去的好。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德甩袖几乎碰倒老僧。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "哎呀呀！真真的莽撞！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧下。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "阿弥陀佛！"
        },
        {
          "character": "杨延德",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "咱家师父乃是个好人。待我大殿走走。 来此已是伽蓝殿，待我进入。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德进内看。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "好一个高大的汉子！ 壮士醒来，壮士醒来！ 行路之人睡着了，待我那厢去唤。 壮士醒来，壮士醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭惊醒拔剑。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德架住。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哪道而来？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "来道而来。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哪道而去？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "去道而去。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "洒家好言来询问， 持剑行凶忒欺人！ 扫地我不伤蝼蚁命，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哦，如此说来师父是个好人？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "阿弥陀佛！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "出家人无歹意切莫疑心。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "这是我睡朦胧不能相认， 望师父须念我是远路行人。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "听壮士讲话不是此地人氏。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "原本不是此地人氏。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哪里人氏？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "大宋朝京城人氏。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哦，你是京城人氏？洒家也是京城人氏。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父也是京城人氏？如此说来，你我是乡里呀！"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "是乡里。"
        },
        {
          "character": "杨延德、杨延昭",
          "type": "同笑",
          "text": "啊哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延德对看，同自语。"
        },
        {
          "character": "杨延德、杨延昭",
          "type": "同白",
          "text": "哎呀且住，看这（壮士）（师父）有些面熟，好象在哪里会过？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延德同想。"
        },
        {
          "character": "杨延德、杨延昭",
          "type": "同白",
          "text": "嗯，不要莽撞，待我盘他一盘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭抢先。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊师父，你即是京城人氏，我就要盘你。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我就要问你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德自语。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "嘿嘿！我正要盘他，他倒盘起洒家来了。 你盘洒家何来？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "京城之中有个天波杨府，师父可知？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "不提天波杨府，还则罢了；提起了天波杨府，洒家的酒，去了一大半了……"
        },
        {
          "character": "杨延德",
          "type": "二黄导板",
          "text": "大宋朝有一个天波杨府，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父请讲。"
        },
        {
          "character": "杨延德",
          "type": "回龙",
          "text": "杨家将俱都是保国忠良。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我来问你，那杨家祖居何处？一一讲来。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "壮士听了！"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "那杨家住在磁州山后， 火塘寨上有家乡。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那老令公？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "老令公在朝中官高极品，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "夫人姓字名谁？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "佘氏太君教子名扬。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "老太君生下几男几女？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "壮士听了！"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "老太君生下了七男二女，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "这就不对了，分明是八男二女，怎说是七男二女？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "壮士听了！"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "内有个义子小八郎。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我来问你，杨大郎往哪里去了？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "大郎？壮士听了！"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨大郎替宋主长枪命丧，长枪命丧……好汉哥！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "二郎？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨二郎短剑下一命身亡。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "三郎？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨三郎被马踏尸如泥酱，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "四郎哪里去了？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "杨四郎失落在番邦。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "如今我要从小问大。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "你问哪一个？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "八郎呢？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "壮士听了！"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "八郎随同幽州闯， 失落番邦音信渺茫。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "七郎哪里去了？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "七郎么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延德同自语。"
        },
        {
          "character": "杨延德、杨延昭",
          "type": "同白",
          "text": "唉！（七兄弟呀）（好兄弟呀）……"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊师父，为何面带泪痕哪？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "我自有我的心事。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "七郎怎么样啊？"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "提起了杨七郎泪如雨降！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德自语。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "七兄弟呀……"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "他到底怎么样了？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "杨延德",
          "type": "二黄原板",
          "text": "叹七郎、死得苦、被潘洪用计诓，乱箭穿身甚惨伤！提起此事，好叫人痛断肝 肠！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唉！说的不错。那六郎呢？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "六郎？壮士啊！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "弟兄唯有六郎在， 还在三关受风霜。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父说得是。那五郎你可晓得？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "壮士问的是那五郎么？不曾会过。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "嗳，杨家七将你都知道，怎么就不晓得那五郎呢？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "五郎他……他死了吧！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭想。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父贵姓？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "我姓和。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "法号？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "和尚。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我问你的俗姓。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "我姓僧。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父不必见疑，我是好人。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "我要重见一礼。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "刚才见过礼的。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "洒家带了酒，定要恭敬，阿弥陀佛！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "还礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德乘机拔去杨延昭佩剑。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "师父为何拔去我的宝剑？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "有话叙谈，何必带剑。我与你放在那厢就是了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德放剑。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "重见一礼。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你的礼也忒多了。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "礼多人不怪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德乘机摸杨延昭身上有无兵器。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "壮士！你是个好人啊！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "你要问洒家的名和姓， 我就是延德杨五郎。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "果然他是五兄长， 怎不叫人痛悲伤！ 撩衣忙跪佛殿上——"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "壮士跪我为哪桩？"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "五哥不必多言讲， 弟就是镇守三关的杨六郎。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哦，你是六弟？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "延昭？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "唉！贤弟呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德哭。"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "忆昔分别俱少壮， 如今你须髯飘胸膛。 手拉贤弟禅堂上——"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "弟兄对坐叙衷肠。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "六弟不在天波杨府侍奉高堂，到此何事？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "奉了母亲之命，去到北国昊天塔，搬请爹爹骸骨。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "骸骨可曾到手？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "骸骨在此，五哥请看。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "唉！爹爹呀！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "一见骸骨两泪淋， 好似钢刀刺在心。 实可叹老爹爹为国丧命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内擂鼓声〗。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "又听得山下呐喊声。 回头便把贤弟问， 六弟带来多少兵？"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "小弟未带兵和将， 想是韩昌发来兵。"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "六弟且在禅堂等， 愚兄下山挡贼兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。杨延德持棍出山门。四辽兵、辽将同上，同起打。四辽兵、辽将同败下。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "好贼子！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "杨家与你何仇恨， 苦苦追赶为何情？ 迈步且把山门进——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "五哥可曾退贼兵？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "贼兵已退，就在寺中宽住几日。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "犹恐老母悬望。不敢久留。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "唉！如此弟兄洒泪而别！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "洒泪别弟痛难忍，"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "实难割舍同胞情。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "六弟此番回到天波杨府，多多拜上你我那疼儿的老娘，就说愚兄远离膝下不能 在老母面前尽孝了！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "啊五哥，何不回家见母一面，再来修行也还不迟。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哎呀六弟呀！有道是：出家容易回家难。请上受愚兄一拜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延德同拜，杨延昭上马。"
        },
        {
          "character": "杨延德、杨延昭",
          "type": "同三叫头",
          "text": "（六弟）（五哥），（延昭）（兄长），唉！（贤弟）（五哥）啊……"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "六弟！延昭！"
        },
        {
          "character": "杨延德",
          "type": "哭头",
          "text": "啊……贤弟啊！"
        },
        {
          "character": "杨延德",
          "type": "二黄散板",
          "text": "一见六弟下山林， 怎不叫人痛伤心。 迈步且把山门进， 抛却凡念苦修行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}