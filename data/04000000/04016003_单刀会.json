        {
          "character": "鲁肃",
          "type": "白",
          "text": "众将走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽与周仓耳语，周仓会意。吕蒙、三将同上，周仓上前挡住。关羽捉住鲁肃手，拔剑示威。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，你莫非有诈？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不……不敢有诈。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你抬头观看。这些将士何用？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他们是护送君侯你登舟的。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哦，是护送关某登舟的？多谢大夫盛情；今日关某酒醉，烦劳大夫相送，来日 在荆州还席。关某告辞了！"
        },
        {
          "character": "关羽",
          "type": "煞尾",
          "text": "江边饮宴多叨扰， 孙刘本是旧故交， 若不是子敬情好， 俺怎肯将你轻饶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽拉鲁肃同下，周仓挡住吕蒙、三将同退下。"
        }
      ]
