    }
  ],
  "plot": "宋太祖赵匡胤死后，其弟赵光义篡位称帝。贺后因夫死因不明，乃命长子赵德昭上殿质问，赵光义羞恼成怒\n欲行问斩，赵德昭气愤之下，触阶自尽。贺后闻讯携次子赵德芳赶来，当殿痛斥赵光义；赵光义理屈谢罪，\n愿奉为太后并赐上方宝剑，封赵德芳为八贤王。至此贺后乃愤然下殿而去。",
  "notes": "这个传统剧目是程砚秋同志生前代表作之一。这个剧本曾经他仔细校订。剧中赵光义剧词系根据贯大元先生\n口述本整理。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "潘洪、赵普、曹彬、苗宗善同上。"
        },
        {
          "character": "潘洪、赵普、曹彬、苗宗善",
          "type": "同点绛唇",
          "text": "静鞭声敲，金门待诏，趋金阙，新主临朝，山呼齐拜倒。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "下官潘洪。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "下官赵普。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "下官曹彬。"
        },
        {
          "character": "苗宗善",
          "type": "白",
          "text": "下官苗宗善。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "赵普、曹彬、苗宗善",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "新主登基，一同上殿朝贺。"
        },
        {
          "character": "潘洪、赵普、曹彬、苗宗善",
          "type": "同白",
          "text": "请。 看香烟缭绕，圣驾临朝，分班伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖二黄小开门〗。四小太监、大太监、潘疆、潘豹引赵光义同上。"
        },
        {
          "character": "赵光义",
          "type": "引子",
          "text": "兄亡侄幼，众文武，扶孤登基。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义上高台。"
        },
        {
          "character": "潘洪、赵普、曹彬、苗宗善",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "潘洪、赵普、曹彬、苗宗善",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牌子止。"
        },
        {
          "character": "赵光义",
          "type": "念",
          "text": "兄王晏驾龙归西，全仗争先一着棋。满朝文武随孤意，才得面南立帝基。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "孤，赵光义。兄王晏驾，太子年幼，众文武扶孤登基。 啊，众卿！"
        },
        {
          "character": "潘洪、赵普、曹彬、苗宗善",
          "type": "同白",
          "text": "万岁。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "孤今新登大宝，不知当降何国号？"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣启万岁：弟承兄业，国号还是大宋。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "就命卿家颁行天下。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "卿家听封。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封卿为左班丞相。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "潘卿听封。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封卿为右班丞相，卿女执掌昭阳。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "曹彬听封。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封卿为孝义侯，代掌禁军。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "苗宗善听封。"
        },
        {
          "character": "苗宗善",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封卿为护国军师，子继父职。"
        },
        {
          "character": "苗宗善",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "潘疆、潘豹封为镇殿将军，其余大小文武官员加升三级，大赦天下。有本早奏， 无本退班！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "哎呀且住！新主登基，满朝文武俱来朝贺，惟有杨继业未到，趁此机会参他一 本。 臣启万岁：我主新登大宝，新主登基，满朝文武俱来朝贺，惟有杨继业未到， 请旨定夺。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "卿家替孤传旨，宣杨继业上殿！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "领旨。 万岁有旨，宣杨继业上殿！"
        },
        {
          "character": "杨继业",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "忽听万岁宣，"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "珠帘卷起！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业看。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "唔呼呀，我道老王升殿，原来是新主登基。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "迈步上金銮。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "臣杨继业见驾，吾皇万岁。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "唗！大胆杨继业，孤王新登大宝，为何不来朝贺？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "臣朝贺来迟，我主恕罪。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣启万岁：杨继业哪里是朝贺来迟，分明是见我主登基，他心中不服，我主降 旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同暗上。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "唗！你哪里是朝贺来迟，分明是见孤登基，心中不服。 殿前武士。"
        },
        {
          "character": "潘疆、潘豹",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "推出斩了！"
        },
        {
          "character": "潘疆、潘豹",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军、潘疆、潘豹押杨继业同下。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "四御林军",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "我主将杨继业斩首，倘若他七个虎狼孩儿反上金殿，老夫是大大的不便……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘洪想。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "有了，不免上殿保他一本。 臣启万岁：杨继业斩不得。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "怎么斩不得？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "若是将杨继业斩首，北国兴兵前来，无人抵挡。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "依卿之见？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "不如将他削职为民。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "嗯！参本是你，保本又是你！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣乃为主江山。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "好个为主江山。将杨继业赦回！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "将杨继业赦回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军、潘疆、潘豹引杨继业同上。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "法场得活命，死而又复生。"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "不是我保本，焉有你命存！"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "要斩任他斩，何劳你讲情！"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "好心来救你，反倒不知情。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "忠臣不怕死，怕死不忠臣。"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "你既不怕死，随我去面君。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哪个惧你不成！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "如此，一同上殿，走！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哼！ 谢万岁不斩之恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "非是孤王不斩于你，念你在朝有十大汗马功劳，今将你削职为民，贬在百亩花 园；无事不许入朝，限三日出京，三日不走，其罪还在。领旨下殿！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "杨继业",
          "type": "二黄摇板",
          "text": "万岁传旨如刀切， 金殿贬了杨继业。 含悲忍泪下金阙， 汗马功劳一旦撇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。赵德昭上。"
        },
        {
          "character": "赵德昭",
          "type": "二黄摇板",
          "text": "老王晏驾归泉壤， 我朝出了篡位王。 请出母后把话讲，"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "有请母后。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后扶赵德芳同上。"
        },
        {
          "character": "赵德昭",
          "type": "二黄摇板",
          "text": "快与孩儿作主张。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "老王不幸把命丧， 二主篡位谋家邦。 大皇儿忙把金殿上， 要回社稷自为王。"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后扶赵德芳同下。"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "迈步且把金殿上， 快快还我锦家邦。"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "大皇儿金殿高声嚷， 口口声声要家邦。 本当下位把国让，"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣启万岁：江山只有争斗，哪有禅让之理。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "皇侄年幼难承当。 回头便对皇儿讲， 孤不负你封为王。"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "江山本应我执掌， 哪个要你乱封王。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "奴才说话太猖狂， 开口便把孤王伤！ 吩咐潘豹与潘疆， 快将奴才绑法场！"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "听一言来怒满腔， 奸王作事狠心肠。 满朝俱是贼奸党，"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "不如一死见先王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德昭碰死，贺后拉赵德芳急同上。"
        },
        {
          "character": "贺后",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "一见皇儿把命丧， 怎不叫娘痛断肠。 将尸首搭至在白虎堂停放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军同将赵德昭抬下。贺后向赵德芳。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "随娘到金殿骂昏王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后拉起赵德芳同进殿。"
        },
        {
          "character": "贺后",
          "type": "三叫头",
          "text": "昏王，篡位王，昏王啊！"
        },
        {
          "character": "贺后",
          "type": "二黄导板",
          "text": "有贺后在金殿一声高骂。"
        },
        {
          "character": "贺后",
          "type": "三叫头",
          "text": "昏王，篡位王，昏王啊！"
        },
        {
          "character": "贺后",
          "type": "回龙腔",
          "text": "骂一声无道君细听根芽："
        },
        {
          "character": "贺后",
          "type": "二黄正板",
          "text": "老王爷为江山足踢拳打， 老王爷为山河奔走天涯。"
        },
        {
          "character": "贺后",
          "type": "二黄快三眼",
          "text": "遭不幸老王爷晏了御驾， 贼昏王篡了位谋乱邦家。 把一个皇太子逼死殿下， 反倒说为嫂的拦阻有差。 贼好比王莽贼称孤道寡， 贼好比曹阿瞒一点不差， 贼好比秦赵高指鹿为马， 贼好比司马师搅乱中华。 只骂得贼昏王装聋作哑， 只骂得贼昏王扭转身躯、闭目合睛、羞羞惭惭一语不发， 只骂得贼昏王无言对答， 两旁的文武臣珠泪如麻。 搬一把金交椅娘且坐下， 你叔王不让位再去骂他。"
        },
        {
          "character": "赵光义",
          "type": "二黄正板",
          "text": "自盘古立帝邦天子为重， 老皇嫂骂孤王情理难容。 论国法就该把残生断送——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘疆、潘豹同拔剑趋前，逼近贺后。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "谁敢！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "退班！ （四小太监、大太监、潘疆、潘豹、潘洪、赵普、曹彬、苗宗善自两边分下。赵光义下高台，向贺后一揖到 地。）"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "皇嫂！"
        },
        {
          "character": "赵光义",
          "type": "二黄碰板三眼",
          "text": "还念你与兄王掌印中宫。 兄王爷晏了驾钟鼓齐动， 满朝中文武臣议论皆同： 都说道大皇儿年轻无用， 一个个保孤王驾坐九重。 孤虽是登大宝依然大宋， 并非是外姓人来坐金龙。 走向前打一躬把皇嫂尊敬， 昭阳院改作了养老宫。 把皇嫂当作了太后侍奉， 崇上徽号容也不容？"
        },
        {
          "character": "贺后",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "贺后",
          "type": "二黄原板",
          "text": "享荣华受富贵要它何用， 倒不如带皇儿务农耕种，受的什么荣封！"
        },
        {
          "character": "赵光义",
          "type": "二黄原板",
          "text": "老皇嫂说什么务农耕种， 普天下俱都是先王荣封。 享荣华受富贵你母子们同共， 并非是叔为君侄为臣各分西东。 孤赐你上方剑泰山压众， 管三宫和六院、大小嫔妃若有违背任你施行，从是不从？"
        },
        {
          "character": "赵德芳",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义向赵德芳。"
        },
        {
          "character": "赵光义",
          "type": "二黄原板",
          "text": "赵德芳我的儿休要悲痛！ 近前来听叔王将儿来封： 孤赐你金镶白玉锁， 加封你一钦王、二良王、三忠王、四正王、五德王、六靖王、上殿不参王、下 殿不辞王；再赐你凹面金锏，上打昏君，下打谗臣，压定了满朝文武、大小官 员谁敢不遵？你是个八贤王，带管朕躬。"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "皇儿休要再悲痛， 皇嫂请回养老宫。"
        },
        {
          "character": "贺后",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "辞别二王下殿口，⑴"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳下。潘洪暗上。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "送国太！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后回望。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "回头只见贼奸谋。 有朝犯在哀家手，"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "贼子！"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "三尺龙泉不容留！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后下。四小太监、大太监、潘疆、潘豹同暗上。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "潘卿。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "孤今登基心中不安，不知是何缘故？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "我主新登大宝，理应修造太庙，春秋二祭，以保稷永固，万寿无疆。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "就命卿家监造。"
        },
        {
          "character": "潘洪",
          "type": "白",
