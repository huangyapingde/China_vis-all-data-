{
  "script_id": "04011004",
  "title": "阳平关",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "黄忠",
      "hangdang": "老生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "赵云",
      "hangdang": "武生"
    }
  ],
  "plot": "黄忠斩了夏侯渊以后，刘备为他设筵庆功。忽报曹操率领重兵至阳平关报仇，因粮草不足，把米仓山存粮移\n屯北山。诸葛亮闻报，意欲先断曹兵粮道。黄忠讨令；赵云因恐他连日临阵劳倦，拟替他一行。黄忠不听，\n仍请令前去；果然在烧粮之后，曹军涌至，被困核心；幸得诸葛亮事前派遣的赵云援军到来，才得突围而出。",
  "notes": "《阳平关》取材于《三国演义》，和《定军山》故事是衔接的；但也经常单独演出。\n整理本是由中国京剧团演员叶盛长、茹元俊、景荣庆和本院（中国戏曲研究院）编辑处陶君起共同整理的。\n主要的改动有以下两点：\n一、原本曹操闻夏侯渊阵亡后，曾引用当年管辂占卜所谓“定军之南，伤折一股”的谶词，因有宿命论的意\n味，故删改。\n二、过去演出有一些不严肃的舞台形象（如赵云刺死焦炳、慕容烈，二人死后“出殃”），兹删去。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、王平、曹洪、许褚、焦炳、慕容烈同上，同起霸，分唱〖点绛唇〗。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "俺徐晃。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "曹洪。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "许褚。"
        },
        {
          "character": "焦炳",
          "type": "白",
          "text": "焦炳。"
        },
        {
          "character": "慕容烈",
          "type": "白",
          "text": "慕容烈。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "列位将军请了。"
        },
        {
          "character": "王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "魏王自得军报，张郃攻打葭萌关不利，刘备直犯汉中，为此亲统大军，来决雌 雄；前有手书命夏侯渊坚守拒敌，尚无回报。好生怀念也。"
        },
        {
          "character": "王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同白",
          "text": "且待魏王升帐，你我请兵前往相助便了。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "言之极是，你我两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八魏军引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "只手独擎天，奇勋早已建。虚名扶汉祚，时势魏将迁。"
        },
        {
          "character": "徐晃、王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同白",
          "text": "参见魏王。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位将军少礼。"
        },
        {
          "character": "徐晃、王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "三台入虎帐，九列冠朝缨。今朝僭銮舆，不日九五登。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孤，魏王曹。⑴赫耀天下，位加九锡。诸镇俱已服顺，孙刘沿未翦除；近闻汉 中被侵，为此亲临南郑；前者夏侯渊往定军开兵示武，此时未闻回报，好生犹 疑也。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "魏王既虑夏侯将军无有回报，何不再遣别将前去助守。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "且自稍停，容孤思之。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报，探子告进。 参见魏王，今有定军山失守，夏侯将军被黄忠刀劈马下！"
        },
        {
          "character": "徐晃、王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "那老贼怎样斩孤的夏侯将军？你、你、你起来讲！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "魏王容禀："
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "讲来。"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "夏侯自得军令，仗威便欲提兵；张郃苦谏不肯听，独自领兵逞胜。 彼军射伤我将，我军追赶不停。门旗闪出黄汉升，哗啦啦人头瓜滚。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操晕。"
        },
        {
          "character": "报子",
          "type": "风入松",
          "text": "真果是天崩地殒， 使得俺将军丧命。"
        },
        {
          "character": "徐晃、王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同风入松",
          "text": "听言来怒火如焚， 这愤恨，怎能平！ 这愤恨，怎能平！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "徐晃、王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同白",
          "text": "魏王醒来！"
        },
        {
          "character": "曹操",
          "type": "西皮导板",
          "text": "听凶报痛得孤二目呆瞪，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "渊弟，妙才，渊弟呀！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "一旦间使得孤足折手分！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "刘备呀，大耳贼！孤不杀你，誓不为人也！"
        },
        {
          "character": "曹操",
          "type": "西皮散板",
          "text": "眼望西蜀咬牙根， 指着大耳骂几声； 孤一怒将你踏齑粉， 看是谁强哪个能！"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "魏王且免悲愤，何不亲率大军，夺转定军山，拿住刘备、黄忠，为夏侯将军报 仇。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "如此命你为前部，诸将副之；即日拔寨，大张銮舆，人马速往定军进发。"
        },
        {
          "character": "徐晃、王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐晃、王平、曹洪、许褚、焦炳、慕容烈同上马。"
        },
        {
          "character": "徐晃、王平、曹洪、许褚、焦炳、慕容烈",
          "type": "同八声甘州",
          "text": "怒气填膺，一霎里旌旗盖地遮云。 三军涌跃，试看战马奔腾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张郃、杜袭同上。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "俺，张郃。"
        },
        {
          "character": "杜袭",
          "type": "白",
          "text": "杜袭。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "将军请了。"
        },
        {
          "character": "杜袭",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "前番定军失守，夏侯将军丧命，已命飞骑，报与魏王。今日魏王大兵至此，你 我到魏王台前请罪便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八魏兵、徐晃、王平、曹洪、许褚、焦炳、慕容烈、曹操同上。"
        },
        {
          "character": "张郃、杜袭",
          "type": "同白",
          "text": "参见魏王。死罪呀，死罪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此乃吾弟不纳忠言，与你二人无干。起来。"
        },
        {
          "character": "张郃、杜袭",
          "type": "同白",
          "text": "谢魏王。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孤今领兵，实为夏侯将军报仇。今定军山已失，可将米仓山粮草，屯积北山脚 下。喘息定了，再看虚实而动。听孤号令！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "口传将令泪珠倾，"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "尊一声股肱众将军： 孤自从起兵东留郡， 都只为逆臣董卓目无君； 东荡西除亲临阵， 南征北剿自劳形； 甘苦辛劳不辞任， 扫得群雄似晨星； 只剩孙刘未归顺， 看来也在孤的手掌心。 只要尔等奋勇进， 谅他插翅难飞腾。 今晚暂且各自安顿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八魏兵、徐晃、王平、曹洪、许褚、焦炳、慕容烈、张郃、杜袭众兵将同下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "选择黄道一战功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、刘备、诸葛亮、赵云、张著、刘封、孟达同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "非孤劳形，怎敢辞戎马辛勤。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "鼎足三分，西蜀稳定。"
        },
        {
          "character": "赵云",
          "type": "引子",
          "text": "唯愿取——"
        },
        {
          "character": "刘备、诸葛亮、赵云、张著、刘封、孟达",
          "type": "同引子",
          "text": "四海安宁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "军师、众卿请坐。"
        },
        {
          "character": "诸葛亮、赵云、张著、刘封、孟达",
          "type": "同白",
          "text": "告坐。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "扬眉掀髯笑颜开，喜得将军斩贼来。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "今日同饮功臣宴，"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "我军齐唱凯歌回。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赖先生妙算，汉升智勇，果然拔取定军山；为此大帐摆筵，庆贺功臣。黄老将 军为何还不见到来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "黄老将军离营不远！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吩咐摆队相迎。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖吹打〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蜀兵、大纛手、黄忠同上。"
        },
        {
          "character": "黄忠",
          "type": "三笑",
          "text": "哈哈，哈哈，啊哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四蜀兵、孟达、刘封、张著、赵云、诸葛亮、刘备同上。四蜀兵、大纛手、黄忠同上。黄忠下马，刘备敬"
        },
        {
          "character": null,
          "type": "text",
          "text": "酒，黄忠拜领，向诸将拱手，众人同下。）"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八蜀兵、孟达、刘封、张著、赵云、黄忠、诸葛亮、刘备同上。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "老臣奉命，已斩了那夏侯渊，特来交令。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "老将军之功也。老将军听封！"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "加封卿为征西大将军之爵。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "谢主隆恩。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "看筵来，待孤把盏。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "这就不敢。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "我儿代敬。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "折杀老臣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "众卿请。"
        },
        {
          "character": "黄忠、诸葛亮、赵云、张著、刘封、孟达",
          "type": "同白",
          "text": "主公请。"
        },
        {
          "character": "黄忠、诸葛亮、赵云、张著、刘封、孟达",
          "type": "同玉芙蓉",
          "text": "张筵赏功臣， 阖帐欢声震！ 羡尔雄纠纠不坠精神。 扬鞭揽辔功勋趁。 翦暴锄奸事业兴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄忠、诸葛亮、赵云、张著、刘封、孟达同离席，分坐。"
        },
        {
          "character": "黄忠、诸葛亮、赵云、张著、刘封、孟达",
          "type": "同合头",
          "text": "今朝庆古稀迈伦， 惟愿恁长生， 同寿享遐龄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "今有曹操亲领大兵二十万，来与夏侯渊报仇，命张郃将米仓山粮草，搬运北山 脚下，特来报知。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众位将军。"
        },
        {
          "character": "黄忠、赵云、张著、刘封、孟达",
          "type": "同白",
          "text": "军师。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "曹操自领大兵，要与夏侯渊报仇；恐粮草不足，故而勒兵不进。若得一人，深 入其境，烧其粮草，夺其辎重，则操锐气自堕；谁能当此重任？"
        },
        {
          "character": "黄忠",
          "type": "白",
          "text": "黄忠愿往。"
        },
        {
