{
  "script_id": "04037003",
  "title": "钟馗嫁妹",
  "alias": [],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "钟馗",
      "hangdang": "净"
    },
    {
      "name": "杜平",
      "hangdang": "小生"
    },
    {
      "name": "大鬼卒",
      "hangdang": "净"
    },
    {
      "name": "钟妹",
      "hangdang": "旦"
    },
    {
      "name": "梅香",
      "hangdang": "旦"
    }
  ],
  "plot": "唐代，终南进士钟馗与同里杜平进京赴试，途中，钟馗误入鬼窟，面貌变俊为丑，因此落第，愤而自杀。钟\n馗死后，感杜平埋其尸骨之恩，乃乘夜回家，以妹嫁杜平，并率众小鬼将其妹亲自送往杜家。",
  "notes": "《钟馗嫁妹》是《天下乐》传奇中的一折。在京剧和昆曲舞台上，是一出载歌载舞的优秀节目。\n这个剧本系依据中国京剧院演员景荣床演出本，并参考传统演出原本，由该院文学组加以修订。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大鬼卒捧平安吉庆宝瓶上。"
        },
        {
          "character": "大鬼卒",
          "type": "点绛唇",
          "text": "如意康宁，平安吉庆，丰年盛，四海升平，天下齐欢庆。"
        },
        {
          "character": "大鬼卒",
          "type": "念",
          "text": "山河天子寿，日月圣人心。时时多吉庆，岁岁乐丰登。"
        },
        {
          "character": "大鬼卒",
          "type": "白",
          "text": "俺乃钟馗老爷麾下大鬼头儿是也。今日老爷吩咐，命俺准备琴剑书箱，笙箫鼓 乐，不知为了何事！呀，一言未了，俺老爷出堂来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖走马〗。四小鬼卒分别持灯、担琴剑书箱、牵驴、持破伞引钟馗同上。"
        },
        {
          "character": "钟馗",
          "type": "念",
          "text": "驰驱万里到神州，准拟文章夺状头。沦落功名奇男子，雄风千古尚含羞。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "吾乃终南山进士钟馗。只因上京求名，途中误入鬼窟，将俺容颜改变。昏君见 俺面貌丑陋，不中俺状元及第，是俺一怒，我就触——触死后宰门，捐躯殒命。 多蒙杜大郎将俺尸首埋葬，感他大恩，尚未报得。是我生前曾将我妹许配于 他，我死后，此事无人料理。今当杜平衣锦还乡，正好将小妹送往到彼，与他 成其百年之好。 呔，众鬼卒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大鬼卒、四小鬼同应声。"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "一壁厢准备笙箫鼓乐，一壁厢准备琴剑书箱，随爷嫁妹走遭。带蹇驴！"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "钟馗",
          "type": "粉蝶儿",
          "text": "摆列着破伞孤灯， 对着这平安吉庆； 光灿烂，剑吐寒星， 伴书箱，随绿绮， 乘着这蹇驴儿趷蹬。 俺这里一桩桩写上丹青， 似一幅梅花春兴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引杜平同上。"
        },
        {
          "character": "杜平",
          "type": "泣颜回",
          "text": "顿首拜彤庭， 兄弟尽叨荣幸， 金章紫绶，白面乌纱相称。"
        },
        {
          "character": "杜平",
          "type": "白",
          "text": "下官杜平。叨蒙圣恩特授四路都总管，执掌天下帑藏金银。今日告假还乡，果 然好气象也！"
        },
        {
          "character": "杜平",
          "type": "泣颜回",
          "text": "春风自生， 气轩昂，衣锦还乡井， 道旁人喝采连声， 杜员外富贵齐鸣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大鬼卒、四小鬼引钟馗同上。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "钟馗",
          "type": "石榴花",
          "text": "俺只见枝头鸟语弄轻声， 小桥边残雪报春晴。 又只见梅花数点助雪精神， 梅花逊雪白， 雪却逊梅馨， 两下里品格奇清， 两下里品格奇清， 与骚人才子添诗兴。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "钟馗",
          "type": "石榴花",
          "text": "今来古往有许多评论。"
        },
        {
          "character": "大鬼卒",
          "type": "白",
          "text": "已到村口。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "带住蹇驴！"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "你等村口伺候，一唤即至！"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大鬼卒、四小鬼自两边分下。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "钟馗",
          "type": "合头",
          "text": "趁着这月色微明， 趁着这月色微明， 曲弯弯绕逼荒燕径，"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "钟馗",
          "type": "合头",
          "text": "又只见门庭冷落倍伤情。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "来此已是自家门首。 妹子开门来！"
        },
        {
          "character": "钟妹",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起定更鼓〗。钟妹上。"
        },
        {
          "character": "钟妹",
          "type": "泣颜回",
          "text": "听樵楼早已报初更， 刁斗无声寂静。 我是孤儿寡女， 是何人叩我柴门？"
        },
        {
          "character": "钟馗",
          "type": "夹白",
          "text": "愚兄回来了。"
        },
        {
          "character": "钟妹",
          "type": "泣颜回",
          "text": "我闻言战惊， 丧黄泉复现生时影。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "妹子不要害怕，就是你哥哥钟馗回来了。"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "哦，既是哥哥回来，妹子焉能害怕，待我与你开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟妹开门。钟馗进入。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "妹子在哪里？"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "哥哥在哪里？"
        },
        {
          "character": "钟馗、钟妹",
          "type": "同白",
          "text": "哎呀，（妹子）（哥哥）呀！"
        },
        {
          "character": "钟妹",
          "type": "泣颜回",
          "text": "兄和妹手足关情， 却为何改变容形？"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "请。 哥哥可将别后之事说与小妹知道。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "妹子听了！"
        },
        {
          "character": "钟馗",
          "type": "黄龙滚",
          "text": "想当初自离门庭， 想当初自离门庭， 到中途瘧妖作症。 一路上寒热恹恹， 一路上寒热恹恹， 误入在阴山鬼径， 改变了旧日容颜赴帝京； 因此上殿试把君惊，"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "昏君呵！"
        },
        {
          "character": "钟馗",
          "type": "黄龙滚",
          "text": "将俺来黜落功名， 将俺来黜落功名，"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "一时愤怒！"
        },
        {
          "character": "钟馗",
          "type": "黄龙滚",
          "text": "后宰门捐躯殒命。"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "不知何人将哥哥尸骸埋葬？"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "多蒙杜大郎将俺尸骸埋葬，感他大恩，未曾报得。向在京师曾将我妹许配于他， 为此今晚，特备笙箫鼓乐，将我妹送往到彼，与他成其百年之好。不知你心 意如何？"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "哥哥此言差矣！"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "何差？"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "哥哥呀！"
        },
        {
          "character": "钟妹",
          "type": "千秋岁",
          "text": "论婚姻从古须媒证， 圣贤言礼法须遵。 裙布荆钗， 裙布荆钗， 仓卒里苟合难以从命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅香提灯上。"
        },
        {
          "character": "梅香",
          "type": "千秋岁",
          "text": "夜深沉人声静， 小窗前喃喃应， 清白言行径， 通宵聒絮剔起残灯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅香见钟馗面貌，吓倒。"
        },
        {
          "character": "梅香",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "梅香休得害怕，这是我钟馗哥哥回来了。向前见过你钟老爷！"
        },
        {
          "character": "梅香",
          "type": "白",
          "text": "是。 梅香与钟老爷叩头。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "不消。 啊，妹子，这是何人？"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "这是杜大郎送来陪伴小妹的。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "妹子，你方才言道无有媒证，如今就把这小娘子呵！"
        },
        {
          "character": "钟馗",
          "type": "扑灯蛾",
          "text": "权当个冰人系赤绳， 权当个月老为盟定， 权当作氤氲使巧撮合， 权当作斧柯媒证。 算不得屏开孔雀， 算不得御沟红叶往来情。 俺与他一朝契合， 凭与他五百年前石上桔三生。"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "如此，小妹遵命了。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "妹子请到后面更衣。"
        },
        {
          "character": "钟妹",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅香扶钟妹同下。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "众鬼卒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大鬼卒、四小鬼自两边分上。"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "与俺冠带伺候！"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟馗下，大鬼卒、四小鬼同作舞。〖小工调工尺上〗。钟馗换红官衣执扇上，作舞。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "俺钟馗今日嫁妹，好不洒乐人也！"
        },
        {
          "character": "钟馗",
          "type": "笑",
          "text": "哧嘻嘻，哧嘻嘻，呵哈哈哈……"
        },
        {
          "character": "钟馗",
          "type": "越凭好",
          "text": "与俺把—— 车轮马足， 车轮马足， 匆匆趱去程途，旌旂掩映， 烧绛烛，引纱灯， 听鸾凤和鸣， 听鸾凤和鸣， 响龙笛，敲象板鼍鼓凤笙， 敲象板鼍鼓凤笙； 一声声美听， 一声声美听， 暖溶溶香蔼蔼百媚自生。 伞儿下驴儿上坐个降魔圣， 后本中裁一个弱质娉婷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅香、钟妹同乘车下，大鬼卒、四小鬼引钟馗同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杜平上。"
        },
        {
          "character": "杜平",
          "type": "上小楼",
          "text": "看皎皎月色明， 寂悄悄人声静。"
        },
        {
          "character": "杜平",
          "type": "白",
          "text": "下官杜平。适才与众家弟兄宴罢而归。看今夜月色溶溶，不免在此闲步一番！"
        },
        {
          "character": "杜平",
          "type": "上小楼",
          "text": "最喜这月色如银， 最喜这月色如银， 月光如水，月圆如镜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内乐声〗。〖节节高〗。"
        },
        {
          "character": "杜平",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杜平",
          "type": "上小楼",
          "text": "听何处箫鼓喧声， 听何处箫鼓喧声， 旌旂摇曳灯光掩映， 乱纷纷马嘶人影。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大鬼卒、四小鬼引钟馗同上。"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同白",
          "text": "唔！"
        },
        {
          "character": "大鬼卒、四小鬼",
          "type": "同红绣鞋",
          "text": "车轮伊哑连声，连声。 马蹄步似流星，流星。 祥光驾，彩云乘， 香馥郁，气氤氲。 顷刻间，到门庭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟馗上高台。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "杜恩兄请了。"
        },
        {
          "character": "杜平",
          "type": "白",
          "text": "啊？空中有人讲话，莫非是鬼魅妖邪？"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "俺非鬼魅妖邪，乃终南山进士钟馗，生前受你大恩，未曾报得，为此今晚，特 备笙箫鼓乐，将我妹送到府中，成共百年之好。"
        },
        {
          "character": "杜平",
          "type": "白",
          "text": "既是钟兄到此，就该请来叙话。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "且慢！你我幽明相隔，后会有期，那旁小妹车辆来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅香扶钟妹同上，在钟馗的〖叠子犯〗歌唱中，与杜平同拜天地。"
        },
        {
          "character": "钟馗",
          "type": "叠子犯",
          "text": "哎灿—— 灿的鬼灯光荧， 哎闪—— 闪的鬼旗掩映； 一对对大鬼狰， 一双双小鬼狞， 捧着平安， 顶着吉庆， 咚咚的鬼敲画鼓， 呜呜的鬼弄箫笙， 哎挨—— 挨挨挤挤鬼头厮混， 从今后斩妖除魅志平生。"
        },
        {
          "character": "钟馗",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "杜平",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "杜平",
