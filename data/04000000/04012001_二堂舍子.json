        {
          "character": "刘彦昌",
          "type": "白",
          "text": "我劝你放手的好！"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "我不放手！"
        },
        {
          "character": "刘彦昌",
          "type": "白",
