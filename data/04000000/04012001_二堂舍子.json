        {
          "character": "刘彦昌",
          "type": "二黄散板",
          "text": "去到秦府把命拼。"
        },
        {
          "character": "王桂英",
          "type": "白",
          "text": "你的儿子逃走，叫我的儿子前去抵命，此事万万不能。"
