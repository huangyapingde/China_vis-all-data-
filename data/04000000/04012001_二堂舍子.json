        {
          "character": "沉香、秋儿",
          "type": "同白",
          "text": "是孩儿打死的。"
        },
        {
          "character": "刘彦昌、王桂英",
          "type": "同白",
          "text": "嗯……我谅你也不敢。我这才明白了。我这才明白了……"
