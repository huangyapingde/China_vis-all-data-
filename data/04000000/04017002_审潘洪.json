{
  "script_id": "04017002",
  "title": "审潘洪",
  "alias": [
    "清官册"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "寇准",
      "hangdang": "老生"
    },
    {
      "name": "寇夫人",
      "hangdang": "旦"
    },
    {
      "name": "赵德芳",
      "hangdang": "老生"
    },
    {
      "name": "潘洪",
      "hangdang": "净"
    },
    {
      "name": "马牌",
      "hangdang": "丑"
    },
    {
      "name": "驿丞",
      "hangdang": "丑"
    },
    {
      "name": "班头",
      "hangdang": "丑"
    },
    {
      "name": "校尉",
      "hangdang": "净"
    }
  ],
  "plot": "宋将杨继业，忠勇抗敌，因被主帅潘洪陷害，致粮尽援绝，碰死于李陵碑。其子杨延昭，进京告下御状。此\n案初由刘御史审问，因受潘妃（潘洪之女）贿赂，被八王赵德芳勘破，用金锏打死。宋王又调寇准进京复审。\n寇准时为县令，闻金牌急调，甚为疑惧，终宵不能成寐。陛见时，擢升为御史。潘妃又往行贿，寇准坚辞\n不受，并告之赵德芳。开审时潘洪甚为傲慢，且供词狡赖，坚不吐实。寇准乃佯言开脱其罪，另与赵德芳密\n议，设酒劝醉潘洪，假设阴曹，夤夜提审，诱以甘言，潘始实供，案情遂大白。",
  "notes": "此本系杨宝森根据其演出本与本院（中国戏曲研究院）编辑处祁野耘合作，共同在词句上进行了必要的修润。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "校尉上。"
        },
        {
          "character": "校尉",
          "type": "念",
          "text": "人行千里路，马走万重山。"
        },
        {
          "character": "校尉",
          "type": "白",
          "text": "俺，金牌校尉是也。奉了圣上旨意，去往霞谷县提调寇准，连夜进京。看天时 不早，就此马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四衙役引寇准上。"
        },
        {
          "character": "寇准",
          "type": "引子",
          "text": "做清官民之父母，积功德留与儿孙。"
        },
        {
          "character": "寇准",
          "type": "念",
          "text": "读诗书智广才高，中进士青史名标；三杯御酒加封号，被权臣一本参掉。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "下官寇准，陕西华州人氏。蒙圣恩得中一甲一名，不想被权臣参掉。是我在吏 部效力三载，蒙八千岁提拔，才得职授霞谷县正堂。自到任以来，黎民倒也好 训。今当三六九日，放告之期。 左右，"
        },
        {
          "character": "四衙役",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "将放告牌抬出！"
        },
        {
          "character": "校尉",
          "type": "内白",
          "text": "金牌下！"
        },
        {
          "character": "四衙役",
          "type": "同白",
          "text": "金牌下！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉上。"
        },
        {
          "character": "校尉",
          "type": "白",
          "text": "金牌下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准跪。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "校尉",
          "type": "白",
          "text": "跪听宣召：圣上有旨，提调寇准连夜进京，不得有误！"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "校尉",
          "type": "念",
          "text": "金牌如火速！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉下。"
        },
        {
          "character": "寇准",
          "type": "念",
          "text": "即刻便登程。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "转堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四衙役同下，院子上。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟、寇夫人同上。"
        },
        {
          "character": "寇夫人",
          "type": "念",
          "text": "夫受皇家禄，妻沾雨露恩。"
        },
        {
          "character": "寇夫人",
          "type": "白",
          "text": "老爷。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "夫人，请坐。"
        },
        {
          "character": "寇夫人",
          "type": "白",
          "text": "有座。 啊老爷，适才金牌到此，为了何事？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "金牌调我连夜进京，不知为了何事。"
        },
        {
          "character": "寇夫人",
          "type": "白",
          "text": "想是老爷为官清正，圣上与你加官授爵。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "但愿如此。"
        },
        {
          "character": "寇夫人",
          "type": "白",
          "text": "不知老爷几时起程？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "即刻起程。"
        },
        {
          "character": "寇夫人",
          "type": "白",
          "text": "老爷请至后面更衣，待我吩咐人役备马伺候。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "有劳夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准下。寇夫人向院子。"
        },
        {
          "character": "寇夫人",
          "type": "白",
          "text": "吩咐马牌备马伺候。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "马牌走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌上。"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "什么事呀？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "老爷即刻进京，夫人命你备马伺候。"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌下。寇准更衣上。"
        },
        {
          "character": "寇夫人",
          "type": "白",
          "text": "丫鬟，看酒。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "寇夫人",
          "type": "二黄原板",
          "text": "叫丫鬟看过酒一樽， 我与老爷来饯行。 此一番老爷把京进， 但愿得加官进禄步步高升。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "接过了夫人酒一樽， 背转身来谢神灵。 转面来再与夫人论， 下官言来你是听： 高堂老母多孝顺， 早晚侍奉要殷勤。 辞别了夫人足踏镫——"
        },
        {
          "character": "寇准",
          "type": "二黄摇板",
          "text": "披星戴月奔都城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌、院子、寇准同下。"
        },
        {
          "character": "寇夫人",
          "type": "二黄摇板",
          "text": "一见老爷跨鞍镫， 但愿他此去早回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇夫人、丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马牌、院子、寇准同上。"
        },
        {
          "character": "寇准",
          "type": "二黄摇板",
          "text": "马蹄踏遍路边草， 不觉来至馆驿中。"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "嗨！有人吗？出来一个！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驿丞上。"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "干什么的？"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "喝！不认得我呀？说出来吓破了你的苦胆！"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "哟喝！你是干什么的呀？"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "我们老爷姓寇名准，陕西人氏，现为霞谷县的正堂。我是霞谷县上上下下，里 里外外，“总葫芦库”的这么一个……"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "什么呀？"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "马牌子。"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "喝！马牌子。你也不打听打听我是谁！"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "你是干什么的呀？"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "我是这儿的驿丞官儿，专管你们这马牌子。 来呀，拿张草纸，把这小子给我捏出去！"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "哎呀，上司老爷！"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "混帐！"
        },
        {
          "character": "马牌",
          "type": "白",
          "text": "老爷！"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "你给我滚下去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马牌下。"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "参见老爷。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "用些什么？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "前途俱已用过；今晚小心更鼓。"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "是。 人役们，小心更鼓啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "驿丞下。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "家院，四更时分，冠带伺候。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "想我寇准，职授霞谷县令，为官以来，上不欺君，下不亏民。圣上金牌调我连 夜进京，不知为了何事？今晚独宿馆驿，好不愁闷人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄慢板",
          "text": "一轮明月早东升， 想起了高堂上老娘亲； 伴君犹如羊伴虎， 尽得忠来难把孝行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "移星换斗二更尽， 坐不安来睡不宁； 霞谷县并不曾亏负百姓， 金牌调我所为何情？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "听谯楼打罢了三更时分， 一轮明月照街心。 有寇准独宿馆驿心中愁闷， 想起了在衙内审理民情： 早堂接状早堂审， 午堂接状审得清； 到晚来接下无头状， 一盏红灯审到天明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准看书，院子捧茶上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "老爷用茶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寇准用茶。〖起四更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "耳边厢又听得四更尽， 家院与爷改换衣巾。"
        },
        {
          "character": "寇准",
          "type": "院子、寇准同下。驿丞上，照料室内外。",
          "text": "⑴"
        },
        {
          "character": "驿丞",
          "type": "白",
          "text": "人役们，小心更鼓啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子捧笏，寇准更衣上。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "转面来再对家院叫， 老爷言来你是听： 我命你回衙报一信： 一路上急走莫少停。 倘若是太夫人将你来问， 你就说你老爷不久回程； 倘若是少夫人将你来问， 你就说你老爷进都城、一步一步往上升，切莫要挂心。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。寇准捧笏出馆驿。〖起五更鼓〗。"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "朝臣待漏五更冷， 铁甲将军夜渡津。 东华门本是文官走， 西华门本是武将行； 有寇准打从这东华门进——"
        },
        {
          "character": "众文武",
          "type": "内同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "寇准",
          "type": "二黄原板",
          "text": "又听得文武发笑声。 他笑我寇准官职小， 七品县令怎见当今！ 有才不在官大小， 无才枉受爵禄恩。 撩袍端带把龙廷进——"
        },
        {
          "character": "寇准",
          "type": "二黄摇板",
          "text": "三呼万岁臣见君。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "臣，寇准见驾，吾皇万岁！"
        },
        {
          "character": "宋王",
          "type": "内白",
          "text": "卿家进京来了？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "调臣进京，为了何事？"
        },
        {
          "character": "宋王",
          "type": "内白",
          "text": "调卿进京，只为潘杨二家之事，命卿审问。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "臣启万岁：潘杨二家，一家是当朝太师，一家是皇家郡马；臣官卑职小，难以 审问。"
        },
        {
          "character": "宋王",
          "type": "内白",
          "text": "不妨。就封卿为西台御史，外赐圣旨一道，审明回奏，领旨下殿。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监捧旨上，将旨交与寇准，下。"
        },
        {
          "character": "寇准",
          "type": "念",
          "text": "捧旨下龙廷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监、赵德芳同上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "咋！贤爷在此啊！"
        },
        {
          "character": "寇准",
          "type": "念",
          "text": "叩见八贤君。"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "恕臣有王命在身，不能全礼，贤爷千岁！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "卿家进京来了？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "进京来了。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "我叔王调你进京，为了何事？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "调臣进京，审问潘杨二家之事。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "他两家，一家是当朝太师，一家是皇家郡马，卿家七品县令，如何问得？"
        },
        {
          "character": "寇准",
          "type": "白",
          "text": "蒙圣恩，七品县令升为西台御史。"
        },
