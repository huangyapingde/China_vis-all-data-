{
  "script_id": "04026002",
  "title": "铡美案",
  "alias": [
    "明公断"
  ],
  "source": "《京剧丛刊》",
  "characters": [
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "秦香莲",
      "hangdang": "旦"
    },
    {
      "name": "陈士美",
      "hangdang": "老生"
    },
    {
      "name": "皇姑",
      "hangdang": "旦"
    },
    {
      "name": "国太",
      "hangdang": "老旦"
    }
  ],
  "plot": "“铁面无私”的包拯，接受了秦香莲对她丈夫陈士美的控诉——“杀妻灭嗣”，在公堂上，教秦香莲与陈士\n美当对质。陈士美倚仗驸马身份，强词狡辩，包拯秉公处断，不顾皇姑、国太的阻挠，铡死了陈士美。",
  "notes": "《铡美案》是一个流传很广的民间故事，也是一个优秀的传统剧目。这个剧本是以中国京剧团演出的《秦香\n莲》中的《铡美案》一折为底本，由中国京剧团王泉奎、娄振奎、赵文奎、郑亦秋与本院编辑处邱炘、吕瑞\n明共同整理的。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四侍卫、张龙、赵虎引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "引子",
          "text": "赤胆忠心，保宋主，锦绣龙廷。"
        },
        {
          "character": "包拯",
          "type": "念",
          "text": "乌纱罩铁面，与民断屈冤。眼前皆赤子，头上有青天。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "老夫，包拯。宋室驾前为臣，官拜龙图阁大学士，兼理开封府府尹。适才朝罢 而归，偶遇秦香莲拦轿喊冤，状告当朝驸马陈士美，杀妻灭嗣。老夫也曾命她 前去写状，这般时候，未见到来。 左右，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉、秦香莲携冬哥、春妹同上。"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "参见相爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "呈状上来。"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊？老夫命你前去写状，因何白纸呈上？"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "状告当朝驸马，无人敢写。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哦！状告当朝驸马，就无人敢写？"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来！将她带在官代书写状，哪个不写抓来见我！"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉、秦香莲携冬哥、春妹同下，同上。"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "状纸写毕，相爷请看。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "呈上来。 “具告状人秦氏香莲，年三十二岁，状告当朝驸马陈士美，杀妻灭嗣”……"
        },
        {
          "character": "秦香莲",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "带下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲携冬哥、春妹同下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "拿我名帖，请陈驸马过府一叙。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "太监",
          "type": "内白",
          "text": "驸马到。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "驸马不请自到。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哦，我正要寻他，他倒来了。 有请。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、大太监引陈士美同上。四校尉同下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "明公。"
        },
        {
          "character": "陈士美、包拯",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "不知驸马驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "岂敢，本宫来得鲁莽，明公海涵。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "岂敢。驸马到此，必有所为。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "我命韩琪出京办事，不想被响马杀死。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "响马可曾拿获？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "现在堂下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "何不带上堂来，一同审问。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "那是自然。 来！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "带响马。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "带响马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉带王朝同上。四校尉同下。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "参见相爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊，你可是王朝？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "正是小人。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "为何身带绑绳？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "驸马言道，韩琪是小人杀死。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "可曾招认？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "招认了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "嗯！人命关天，你就不该招认。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "小人若不招认，驸马焉能过府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯点头。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊，驸马。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "明公。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "此人乃是我府的王朝，怎说是杀人的响马？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "明明是杀人的响马，怎道你府的王朝！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "王朝也罢，响马也罢。 来，与他松绑。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "且慢，走脱响马，哪个担待？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马你来看！走脱了响马，走不了包拯！ 来，与他松绑。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "谢相爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊，驸马，真响马倒被我拿获了。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "倒被明公拿获了？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "正是。并非一人。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "莫非三五成群？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "正是三五成群。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "就该带上堂来，你我一同审问。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "原要一同审问。 来！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "带响马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯向王朝示意。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "秦香莲母子上堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲携冬哥、春妹同上。"
        },
        {
          "character": "秦香莲",
          "type": "西皮摇板",
          "text": "忽听相爷一声叫， 走上前来问根苗。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "一见贱人心头恼， 三番两次为哪条？ 三尺龙泉出了鞘， 管叫你母子命难逃！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯拦，秦香莲、冬哥、春妹同下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马，你太莽撞了，莽撞了，啊哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、陈士美同落座。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马，她母子既然找进京来，你就该相认才是。"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "嗯！本宫命你审问响马，你倒盘问起本宫来了。 来，顺轿！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯拦。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "回府。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "只恐你来得就去不得！"
        },
        {
          "character": "包拯",
          "type": "西皮导板",
          "text": "包龙图打坐在开封府，"
        },
        {
          "character": "包拯",
          "type": "西皮原板",
          "text": "尊一声陈驸马细听端的： 曾记得端午日朝贺天子， 我与你在朝房曾把话提。 提起了招赘事你神色不定， 我料你在原郡定有那结发妻。 到如今她母子前来寻你， 你为何不相认反把心欺。 我劝你认香莲是正理， 祸到临头悔不及。"
        },
        {
          "character": "陈士美",
          "type": "西皮原板",
          "text": "明公说话言太偏， 细听本宫说根源： 甲子年间开科选， 天下举子来求官， 头一名进士陈士美，"
        },
        {
          "character": "陈士美",
          "type": "西皮快板",
          "text": "御笔亲点为状元； 跨马三日游宫院， 才将公主配良缘。 一无证来二无见， 你叫我相认为哪般？"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "驸马不必巧言讲， 现有凭据在公堂。 人来看过香莲状——"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "驸马近前看端详： 上写着秦香莲三十二岁， 状告当朝驸马郎。 抛妻子、藐皇上， 后婚男儿招东床。 状纸押至在我的大堂上—— 咬定牙关你为哪桩！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "既然有人将我告， 你何不升堂问根苗！"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "你劝我升堂有什么好， 霎时叫你的魂魄消。 王朝击鼓带原告！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "击鼓升堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四衙役、四刽子手自两边分上。包拯入座。"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "带上了香莲看他招不招！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "香莲上堂！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦香莲携冬哥、春妹同上。"
        },
        {
          "character": "秦香莲",
          "type": "西皮散板",
          "text": "母子三人把堂进， 包相爷与我把冤伸。"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "那旁坐的陈士美， 上前对质这负义人。"
        },
        {
          "character": "秦香莲",
          "type": "西皮散板",
          "text": "你如今来到开封府， 包相爷不饶负义人！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "你冒认官亲将我告， 公堂之上还放刁。"
        },
        {
          "character": "秦香莲",
          "type": "西皮散板",
          "text": "我身上穿的是公婆孝， 你身上穿的是蟒龙袍； 恨你不过剜尔眼！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "一足要你命一条！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "你差韩琪行刺到， 来到开封还不招！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "我差韩琪有谁晓？"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "现有你府杀人刀！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "为何有刀无有鞘？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "这……"
        },
        {
          "character": "秦香莲",
          "type": "白",
          "text": "相爷！"
        },
        {
          "character": "秦香莲",
          "type": "西皮散板",
          "text": "刀鞘现在韩琪腰！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "着着着！"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "王朝与爷取刀鞘！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、秦香莲携冬哥、春妹同下。王朝上。"
        },
        {
          "character": "王朝",
          "type": "西皮散板",
          "text": "取来刀鞘相爷瞧。"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "大堂之上刀对鞘， 件件是实你还不招！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "大堂之上刀对鞘， 心想一计我要脱逃。 内侍与我快顺轿！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "陈士美",
          "type": "白",
          "text": "明公啊！"
        },
        {
          "character": "陈士美",
          "type": "西皮散板",
          "text": "我有本章奏当朝。"
        },
        {
          "character": "包拯",
