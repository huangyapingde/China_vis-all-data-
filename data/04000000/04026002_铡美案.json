        {
          "character": "皇姑",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "国太一旁来阻拦。 有心不铡陈士美——"
        },
        {
          "character": "秦香莲",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "倒叫我包拯两为难。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯摘冠。"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "拼着官儿我不作， 塌天大祸我承担。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "刽子手！"
        },
        {
          "character": "包拯",
          "type": "西皮散板",
          "text": "将陈士美搭在铜铡案， 铡了这负义贼再见龙颜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刽子手抬陈士美同上，过场，同下。国太、皇姑同急扑，包拯拦阻。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "开铡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。堂鼓。开铡。"
