{
  "script_id": "10002001",
  "title": "南天门",
  "alias": [],
  "source": "《戏考大全》",
  "characters": [
    {
      "name": "曹富",
      "hangdang": "老生"
    },
    {
      "name": "曹玉莲",
      "hangdang": "青衣"
    },
    {
      "name": "掌柜甲",
      "hangdang": "丑"
    },
    {
      "name": "掌柜乙",
      "hangdang": "生"
    },
    {
      "name": "赶驴",
      "hangdang": "丑"
    }
  ],
  "plot": "明朝熹宗时太监魏忠贤奸恶非常，权势很大，党羽极多，他常想纂夺君位。只有吏部堂曹正邦，却是忠直之\n臣，不肯附合魏忠贤。但是知道魏忠贤必要害他，所以就告老回乡。魏忠贤知道他要回去，就在路中埋伏许\n多刺客，要将他刺死。等到曹正邦走到官庄铺，果然遭害，夫人也投井而死。只剩女儿曹玉莲被老仆曹富救\n出，要送她到大同，投奔夫家。路中千辛万苦，困难万分，走到广华山，天又降下大雪，二人身上衣服单薄，\n饥寒交迫。曹富看见小姐受不了这种痛苦，将自己的外衣脱下，送与她穿，自己因此冻死。王母娘娘因他\n忠义可嘉，就叫八仙来接引升天，封为南天门都土地。曹玉莲正在悲痛无法之时，幸而夫家得到了消息，派\n人前来接了回去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "曹玉莲",
          "type": "内西皮导板",
          "text": "急急忙忙走得慌，"
        },
        {
          "character": "曹富",
          "type": "内白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富搀曹玉莲同上。"
        },
        {
          "character": "曹富",
          "type": "西皮摇板",
          "text": "点点珠泪洒胸膛。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮摇板",
          "text": "似鱼儿逃出千层网，"
        },
        {
          "character": "曹富",
          "type": "西皮摇板",
          "text": "虎口内逃出了两只羊。"
        },
        {
          "character": "曹玉莲",
          "type": "哭",
          "text": "喂呀。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "小姐不必啼哭。且喜逃出虎口，待老奴搀扶小姐慢慢的行走。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "搀扶了。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮原板",
          "text": "恼恨那魏忠贤贼子奸党，"
        },
        {
          "character": "曹富",
          "type": "西皮原板",
          "text": "我朝中出谗臣扰乱家邦。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮原板",
          "text": "天启爷坐早朝天还未亮，"
        },
        {
          "character": "曹富",
          "type": "西皮原板",
          "text": "太老爷作天官吏部上堂。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮原板",
          "text": "老爹爹上金殿把本奏上，"
        },
        {
          "character": "曹富",
          "type": "西皮原板",
          "text": "丢了官罢了职转回故乡。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮原板",
          "text": "一家人逃性命官庄铺上，"
        },
        {
          "character": "曹富",
          "type": "西皮原板",
          "text": "狗奸贼领人马暗地埋藏。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮原板",
          "text": "我的父命丧在宝剑之下，"
        },
        {
          "character": "曹玉莲",
          "type": "哭头",
          "text": "老爹爹！"
        },
        {
          "character": "曹富",
          "type": "哭头",
          "text": "太老爷呀！"
        },
        {
          "character": "曹玉莲",
          "type": "哭头",
          "text": "啊啊，老爹爹！"
        },
        {
          "character": "曹富",
          "type": "哭头",
          "text": "啊啊，老太爷呀！"
        },
        {
          "character": "曹富",
          "type": "西皮原板",
          "text": "最可叹忠良臣无有下场。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮原板",
          "text": "我的母跳在井一命身亡，"
        },
        {
          "character": "曹玉莲",
          "type": "哭头",
          "text": "老娘亲呀！"
        },
        {
          "character": "曹富",
          "type": "哭头",
          "text": "太夫人哪！"
        },
        {
          "character": "曹玉莲",
          "type": "哭头",
          "text": "啊啊，老娘亲！"
        },
        {
          "character": "曹富",
          "type": "哭头",
          "text": "啊啊。"
        },
        {
          "character": "曹富",
          "type": "西皮原板",
          "text": "就是那铁石人也要悲伤。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮原板",
          "text": "这一阵走得我——"
        },
        {
          "character": "曹玉莲",
          "type": "西皮二六板",
          "text": "足痛腿涨， 我腹内饥饿了甚是难当。 将身儿坐至在土台之上， 思想爹娘好不悲伤。"
        },
        {
          "character": "曹玉莲",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "小姐为何不走？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "腹中饥饿难以行走。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "这个……老奴只顾逃命，身旁分文末带，这便如何是好？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "曹富但放宽心，这里有金耳环一对。拿去换些银两，也好使用。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "你问此地可有大米水饭无有。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "晓得了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富向左内幕喊。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "掌柜的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜甲上。"
        },
        {
          "character": "掌柜甲",
          "type": "白",
          "text": "这老头干什么？"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "是里有金耳环一对，调换银两使用。"
        },
        {
          "character": "掌柜甲",
          "type": "白",
          "text": "拿来我瞧瞧。分明是黄铜。你来哄我不成？"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "分明是金子，怎说是黄铜？"
        },
        {
          "character": "掌柜甲",
          "type": "白",
          "text": "看你有了年纪，不然我就要打你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜甲下。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "呀呀呸！人不在时中，黄金变成铜。待我那厢去换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富走向右幕内喊。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "掌柜的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜乙上。"
        },
        {
          "character": "掌柜乙",
          "type": "念",
          "text": "生意兴隆通四海，财源茂盛达三江。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "作什么的？"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "我这里有金耳环一对，换些银钱使用。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "拿来我看。 哎呀好赤金。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "好眼力！"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "待我与你平平看。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜乙向右幕内。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "伙计们，这有金耳环一对，平平多重。"
        },
        {
          "character": "伙计",
          "type": "内白",
          "text": "金耳环一对三钱重，我们这里金子十四换：三得三，三四一两二，合成银子四 两，外找大钱二百。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜乙由内取出一包钱。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "兑得不错。"
        },
        {
          "character": "伙计",
          "type": "内白",
          "text": "不错。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜乙取钱交与曹富。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "老人家来，你的耳环三钱重。我们这里金子十四换：三得三，三四一两二，合 成银四两，外找大钱二百。拿去。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "有劳了。啊，请问掌柜的，你们这里有大米水饭无有？"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "没有。只有面食饽饽。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "面食饽饽也好。请去取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜乙向幕内喊。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "伙计们，拿面食饽饽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜乙盛饽饽交与曹富。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "老人家，面食来了。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "有劳了。少时给钱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富走向曹玉连。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "小姐，他们这里金子十四换：金耳环三钱重，三得三，三四一两二，银子四两， 外找大钱二百。请小姐收下。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "你收下了罢。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "是。小姐。此处大米水饭无有，现有面食饽饽，小姐请用。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富将盘递与曹玉莲。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "拿来我用。"
        },
        {
          "character": "曹玉莲",
          "type": "哭",
          "text": "哎呀，爹娘呀！"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "小姐为何不用？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "想起爹娘，吞吃不下。你拿去用吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹玉莲将盘递与曹富，曹富接盘。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "曹富",
          "type": "哭",
          "text": "啊太老爷、太夫人啊！"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "曹富为何你也不用？"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "思想太老爷、太夫人，也是吞吃不下。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "如此还与他们吧。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "问问此地可有往大同的脚程？"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "晓得了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富拿盘还与掌柜乙。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "掌柜的，面食饽饽未曾用，现有大钱二百请你收下。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "未曾用不算钱。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "多谢了。请问掌柜的，你们这里可有奔大同的脚程无有？"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "那边厢有的。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": "掌柜乙",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "掌柜乙下。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "这是哪一个的脚程啊？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赶驴上。"
        },
        {
          "character": "赶驴",
          "type": "白",
          "text": "上哪儿去？"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "上大同去。"
        },
        {
          "character": "赶驴",
          "type": "白",
          "text": "大同正凑巧，我是回头驴。走大路呢？走小道呢？"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "大路怎讲？小道怎说？"
        },
        {
          "character": "赶驴",
          "type": "白",
          "text": "大路远三天。小道近三天。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "当然是走近不走远。"
        },
        {
          "character": "赶驴",
          "type": "白",
          "text": "不好不好。走小道要走广华山，山上惯出豺狼虎豹。吃了你的人事小，吃了我 的驴谁赔得起。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "多把银钱与你。"
        },
        {
          "character": "赶驴",
          "type": "白",
          "text": "留着钱子你买棺材罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赶驴下。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "呀呸！这是怎么讲话！吃了人倒是一桩小事，吃他的牲口倒赔还不起？真真岂 有此理！待我瞒哄小姐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富走向曹玉莲。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "啊，小姐，他们这里无有往大同的脚程。待老奴搀扶小姐挨到前面再作道理。"
        },
        {
          "character": "曹玉莲",
          "type": "白",
          "text": "搀扶了。"
        },
        {
          "character": "曹玉莲",
          "type": "西皮二六板",
          "text": "三家店未曾把饭用， 心猿意马归旧踪。 曹富与我把路引， 主仆双双奔大同。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹玉莲下。"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "曹富",
          "type": "西皮快板",
          "text": "恨奸贼把我的牙咬坏， 可叹老爷无良才。 忠良反被奸贼害， 害得我一家好不悲哀。 拿住了奸贼用刀斫， 挖尔的心肝祭扫坟台。"
        },
        {
          "character": "曹玉莲",
          "type": "内白",
          "text": "曹富，快来呀！"
        },
        {
          "character": "曹富",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹富下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四家将同上。"
        },
        {
          "character": "家将甲",
          "type": "西皮摇板",
          "text": "打罢春来又逢秋，"
        },
        {
          "character": "家将乙",
          "type": "西皮摇板",
          "text": "洛阳桥下水倒流。"
        },
        {
          "character": "家将丙",
          "type": "西皮摇板",
          "text": "将军战马今何在，"
        },
        {
          "character": "家将丁",
