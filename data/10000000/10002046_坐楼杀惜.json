{
  "script_id": "10002046",
  "title": "坐楼杀惜",
  "alias": [],
  "source": "《戏考大全》",
  "characters": [
    {
      "name": "宋江",
      "hangdang": "老生"
    },
    {
      "name": "阎惜姣",
      "hangdang": "花旦"
    },
    {
      "name": "阎婆",
      "hangdang": "老旦"
    }
  ],
  "plot": "宋江为郓城县书吏，昵土娼阎惜姣，为营乌龙院以居其母女，给衣食。宋江有徒张文远，性佻健，喜冶游，\n常乘间入院，与阎惜姣言笑取乐。阎惜姣亦爱张文远年少风流，遂与之通。久之，乐张文远而厌宋江。人言\n啧啧，宋江有所闻，责阎惜姣忘恩负心。阎惜姣不服，反唇相讥，宋江大受奚落。宋江在郓城，常勾结梁山\n大盗晁盖等，私相往还。一日，晁盖遣刘唐至宋江处下书赠金，宋江藏书金于招文袋。夜宿乌龙院，黎明即\n匆匆出门。至中途，忽悟招文袋遗失在院，大惊，急回院搜索不得，意必为阎惜姣所匿。问之，阎惜姣直认\n不讳。宋江哀恳再三，许尽与其金，而求将书掷还。阎惜姣掉头不允，逼宋江亲立笔据，许与张文远来往，\n不准宋江再来院。宋江不得已允之。立据后，阎惜姣谓盗书当呈县令，论宋江当堂领取。宋江急甚，苦求不\n已，而阎惜姣置若罔闻。宋江怒不可遏，遂拔刀刺死阎惜姣，取书而去。阎婆见女为宋江所杀，即控宋江于\n县。县令稔知宋江为人诚实宽厚，欲偏袒之。无奈张文远伤其所欢横罹惨酷，欲为之伸雪，坚执宋江罪，并\n嘱阎婆上控，以胁县令。县令乃科宋江以误杀罪，流至江州。后张文远为阎惜姣活捉去，亦不得善终云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宋江上。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "出门只见红日下， 玉兔明亮甚潇洒。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "卑人宋公明。自从那日离了乌龙院，与惜姣吵闹，永不到她处，这且不言。今 日诸位贤弟，邀我衙前议论，不知为了何事？不免衙前走走。"
        },
        {
          "character": "宋江",
          "type": "西皮摇板",
          "text": "丈夫休要变心意， 岂能叫那妇人欺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "阎婆上。"
        },
        {
          "character": "阎婆",
          "type": "念",
          "text": "良言一句三冬暖，恶语伤人六月寒。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "老身妈儿娘。只因女儿惜姣，性情不好。这几日也不见宋大爷到乌龙院中走走。 我不免到大街之上，找寻找寻便了。"
        },
        {
          "character": "阎婆",
          "type": "二黄摇板",
          "text": "行至大街四下看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江上。"
        },
        {
          "character": "阎婆",
          "type": "二黄摇板",
          "text": "只见大爷宋三郎。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "哎呀呀，这倒巧得很。偏偏遇见着了。 啊，宋大爷，请回，请回。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "哦，我道是谁，原来是妈儿娘。少陪了，少陪了，改日再见！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎婆拉住宋江。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "宋大爷，回来回来！不要走！我这有话讲。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "有话改日再谈，我衙前有事，不要这样拉拉扯扯，被旁人看见，像什么样儿？"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "你等一等，不要走，我有话说。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你有什么话，快说！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "宋大爷为何这几日不到乌龙院走走？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我衙前有事，无有工夫。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "我那女儿在那里想你。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我怕她不是想我吧！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "嗳，她想的是你！你随我走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎婆拉宋江走。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你不要拉拉扯扯！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "走哇，走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎婆拉宋江同进门。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "吓，宋大爷，你在此请坐，我叫我女儿下来。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你不要叫她，我就要走。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "你不要走哇，待我叫她下楼。 吓，儿啊！"
        },
        {
          "character": "阎惜姣",
          "type": "内白",
          "text": "什么事？"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "三郎来了，快些下楼来吧！"
        },
        {
          "character": "阎惜姣",
          "type": "内白",
          "text": "哪一个三郎？"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "是你心腹上的三郎！"
        },
        {
          "character": "阎惜姣",
          "type": "内白",
          "text": "哪一个心腹上的三郎？"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "你不要管他哪一个，你下楼来便明白了。"
        },
        {
          "character": "阎惜姣",
          "type": "内白",
          "text": "母亲问他这几日为何不到乌龙院走走？快将他罚跪庭前。等女儿梳洗一毕，再 来发放。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "哦，是了。 啊，宋大爷，我的女儿将你怪了下来。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怪我何来？"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "她说道：这几日为何不到乌龙院走走？将你罚跪庭前。梳洗一毕，再来发放。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "只怕不是想我吧！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "她是想你。我来看看她梳洗完了没有。 啊，女儿，梳洗完了没有？"
        },
        {
          "character": "阎惜姣",
          "type": "内白",
          "text": "梳洗完了。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "下楼来吧！"
        },
        {
          "character": "阎惜姣",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": "阎惜姣",
          "type": "内二黄平板",
          "text": "忽听三郎到来临，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣上。"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "轻移莲步下楼行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣下楼。"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "我这里上前来观定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江、阎惜姣对看，阎惜姣作气恼状。"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "抬头只见对头人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣将椅搬开，独自坐。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "宋大爷，我女儿下来了，你上前说几句。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江推阎婆。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "要去你去，我是不去！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "哦呦，说两句话，也就完了，这样推推撞撞。你不去，我叫我的女儿来。 啊，儿呀，你去与宋大爷说上几句。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣推阎婆。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "要去你去，我是不去！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "他二人俱是一样的脾气。我再叫宋大爷去。 啊，宋大爷，若要好，大让小。她小你大，说两句好话，也就完了。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我是不去！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "你去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江使劲推阎婆。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "太啰嗦了！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "不去拉倒！你一推，她一撞，把我推个三长两短，看你们怎样得了！ 啊，儿啊，想我母女二人，吃的是宋大爷的，穿的是宋大爷的，你若不去，叫 我怎么样呢？来来来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎婆一手拉阎惜姣，一手拉宋江。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "啊，宋大爷，请到楼上去。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我是不去。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "你来呀！"
        },
        {
          "character": "阎婆",
          "type": "二黄平板",
          "text": "今日里好比七月七， 牛郎、织女会佳期。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎婆、宋江、阎惜姣同上楼。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我走，我走！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "不要走，不要走！"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "我走，我走！"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "嗳，你也不要走！你二人坐在这里，我去拿茶来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎婆出门，锁门。"
        },
        {
          "character": "阎婆",
          "type": "白",
          "text": "我将门儿倒扣，怕你二人不说话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎婆下楼，下。宋江、阎婆对看，作气状。阎惜姣睡。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我说不来，我倒又来了。哦，我好悔也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "听谯楼打罢了初更时分， 忽然想起狗贱人。 我本当将她来搂抱，"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "公明岂是下贱人，啊，下贱人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "听谯楼打罢了二更时分， 那一旁坐定了有情之人。 我这里上前来将他搂抱，"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "我惜姣岂是那下贱之人，嗳，下贱之人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "三更三点月正明， 越思越想越愁人。 这里一刀要你的命，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江取刀，作刺状，收起。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "宋江",
          "type": "二黄平板",
          "text": "大丈夫做事三思而行，啊，三思而行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "听谯楼打罢了四更时分， 惜姣起下杀人心。 我这里将他来刺死，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣取剪刀，作刺状，收起。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "阎惜姣",
          "type": "二黄平板",
          "text": "惜姣做事要三思行，嗳，要三思行！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "天也明亮，她还睡在那里。待我走了吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江开门，口袋落地，宋江没有留意，下楼。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我真的不来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江下。阎惜姣醒。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "他走了，待我回床睡觉去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣看口袋，拾起。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "这是什么东西？原来是个讨饭的叫化袋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣伸手进去摸。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "这是一锭金子，待我收下。还有书信一封，待我看来： “上写梁山晁盖拜……” 啊呦，慢着！闻听人说，宋江私通梁山。宋江啊，宋江，无有此事便罢；若有 此事，这就是你的对头到了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣睡。宋江急上。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "走啊！啊呦且住！适才我从乌龙院走后，失落黄金、书信。这黄金事小，信若 被人拾去，我的性命难保！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江急。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊呀且住！我不免去到乌龙院寻找便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江进门，寻找不到，呆，做出门时各种姿势，发急，起。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江走向阎惜姣。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊，阎大姐醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阎惜姣醒。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "宋大爷，你不是走了么？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "不错，我是走了，又回来了。"
        },
        {
          "character": "阎惜姣",
          "type": "白",
          "text": "你回来干什么来了？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "我失落一样东西，大姐可曾看见？"
