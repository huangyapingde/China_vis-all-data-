{
  "script_id": "70904208",
  "title": "西游记·胖姑学舌",
  "alias": [],
  "source": "马祥麟剧本选",
  "characters": [
    {
      "name": "胖姑",
      "hangdang": "贴旦"
    }
  ],
  "plot": "唐玄奘从长安出发，前往西天取经。胖姑、王留姐弟两个前去观看送行的盛会，回家来给爷爷胡老头描述看\n到的情形。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "胡老头内嗽，上。"
        },
        {
          "character": "胡老头",
          "type": "念",
          "text": "县令怜我缺断粮，吏胥不敢下村庄。年年麻麦收成足，半炷名香答上苍。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "小老头，长安城外太平庄，胡老头的便是。今有大唐师父，要往西天印度雷音 寺，求取大藏真经，唐家一十八路总管都到十里长亭，饯行发路。我家有一胖 姑儿、王留儿，都去看盛会去了。我在家中，轧下粉饸饹，等他二人回来，大 家好用。看，天到这般时候，还不见回来，带我出庄一望。"
        },
        {
          "character": "王留",
          "type": "内白",
          "text": "胖姑儿走哇。"
        },
        {
          "character": "胖姑",
          "type": "内白",
          "text": "王留儿走哇。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "咦，哈哈哈……看他二人，笑嘻嘻的来了。"
        },
        {
          "character": "王留",
          "type": "内白",
          "text": "胖姑儿走哇。"
        },
        {
          "character": "胖姑",
          "type": "内白",
          "text": "王留儿走哇。咦，哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胖姑、王留同上。"
        },
        {
          "character": "胖姑",
          "type": "豆叶黄",
          "text": "胖姑儿、王留儿走得来个偏急， 王大、张三去得个偏迟。 胖姑儿天生得这人意， 姊弟相随，庄王儿离了官厅自到个这家里。"
        },
        {
          "character": "胖姑",
          "type": "白",
          "text": "爷爷，我们回来啦。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "哦，你们回来了。看的什么盛会，瞧的什么热闹，学来爷爷听啊。"
        },
        {
          "character": "胖姑",
          "type": "白",
          "text": "爷爷，我先说"
        },
        {
          "character": "王留",
          "type": "白",
          "text": "爷爷，我先说。"
        },
        {
          "character": "胖姑",
          "type": "白",
          "text": "爷爷，我先说。"
        },
        {
          "character": "王留",
          "type": "白",
          "text": "爷爷！"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "我先说、我先说。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "王留儿，你姐姐大，还是让姐姐先说。 胖姑儿，讲来，爷爷听啊。"
        },
        {
          "character": "胖姑",
          "type": "白",
          "text": "爷爷。"
        },
        {
          "character": "胖姑",
          "type": "一缕儿麻",
          "text": "不是俺胖姑儿心精细， 只见那官人们簇拥着一个大擂捶。 那擂捶上天生的有眼共眉， 我只到瓠子头葫芦蒂， 这个人儿也算得跷蹊。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "什么跷蹊，那是唐僧。"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "什么唐僧不唐僧，原来是个和尚，我二人枉去这一遭哇。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "胖姑、王留",
          "type": "同一缕儿麻",
          "text": "恰便似不敢道的东西。"
        },
        {
          "character": "胖姑、王留",
          "type": "同夹白",
          "text": "枉被旁人。咦，哈哈…"
        },
        {
          "character": "胖姑、王留",
          "type": "同一缕儿麻",
          "text": "笑耻。"
        },
        {
          "character": "胖姑、王留",
          "type": "同乔牌儿",
          "text": "一个个手执着白木尺， 身穿着紫褡臂，白石头，黄铜片紧紧在腰中系， 一双脚只踹在黑窝里。"
        },
        {
          "character": "胖姑、王留",
          "type": "同新水令",
          "text": "官人们腰屈共头低， 吃得个醉醺醺脑门着地。 咿咿呜呜吹竹管， 扑咚咚打着牛皮， 我见几个回回，他笑一回，"
        },
        {
          "character": "胖姑、王留",
          "type": "同夹白",
          "text": "咦，哈哈。"
        },
        {
          "character": "胖姑、王留",
          "type": "同新水令",
          "text": "嗳，他闹一回。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "啊哈哈哈，啊，他笑一回。"
        },
        {
          "character": "胖姑",
          "type": "白",
          "text": "笑一回。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "闹一回。"
        },
        {
          "character": "王留",
          "type": "白",
          "text": "闹一回。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "还有什么热闹，学与爷爷听啊。"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "爷爷，还有哪。"
        },
        {
          "character": "胖姑、王留",
          "type": "同雁儿落",
          "text": "见几个粉搽的白面皮横拴着油鬏髻， 他笑一声便打一棒锤，跳一跳高似田地。"
        },
        {
          "character": "胖姑、王留",
          "type": "同夹白",
          "text": "爷爷！"
        },
        {
          "character": "胖姑、王留",
          "type": "同川拨棹",
          "text": "好叫我便笑，"
        },
        {
          "character": "胖姑、王留",
          "type": "同夹白",
          "text": "咦，哈哈哈。"
        },
        {
          "character": "胖姑、王留",
          "type": "同川拨棹",
          "text": "哎呀微微。 一个汉似木雕成两条腿， 我见几个武职，他舞着一面旌旗， 忽喇喇口儿里不知说些甚的，装着一个鬼。 人多我也看不得仔细，"
        },
        {
          "character": "胖姑、王留",
          "type": "同七兄弟",
          "text": "我走到这壁那壁， 无奈何自身躯， 滚将一个碌碡，在我的跟底， 脚踏着才看得真是， 百般样儿千般戏。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "哈哈，百般样儿千般戏，还有什么热闹，学来爷爷听听啊。"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "爷爷，只见一个人儿，手提着墨线儿，他叫这个这个……这个、这个……"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "你们倒是说呀。"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "爷爷，我们忘啦。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "一个人儿，手提着墨线儿，噢，想这个么，你们说的不是耍傀儡的罢？"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "对啦，是耍傀儡的。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "好，学与爷爷听啊。"
        },
        {
          "character": "王留",
          "type": "白",
          "text": "胖姑学呀。"
        },
        {
          "character": "胖姑",
          "type": "白",
          "text": "王留来呀。"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "来来来呀。"
        },
        {
          "character": "胖姑、王留",
          "type": "同梅花酒",
          "text": "哎它，它唤做甚傀儡， 它唤做甚魁垒。 墨线儿穿的红白粉儿装的什么样的东西嗖嗖的呼啸起咚咚的鼓声催， 见几个舞着大旗，"
        },
        {
          "character": "胖姑、王留",
          "type": "同夹白",
          "text": "爷爷！"
        },
        {
          "character": "胖姑、王留",
          "type": "同梅花酒",
          "text": "他坐着吃堂食， 俺立着看筵席。 两条腿半僵直， 肚皮中似春雷， 要吃也不得吃。"
        },
        {
          "character": "胖姑、王留",
          "type": "同收江南",
          "text": "呀。 好教我坐而立而耐着饥， 去时乘兴转时迟， 说了半日，肚皮耐着饥， 霎时间日西，霎时间日西， 可正是席前花影座闲移。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "喂呀，把我累坏了。"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "爷爷，我们饿了。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "你们饿了，后面去吃饸饹去罢。"
        },
        {
          "character": "胖姑、王留",
          "type": "同白",
          "text": "多谢爷爷。"
        },
        {
          "character": "胖姑",
          "type": "煞尾",
          "text": "雨余云罢芝麻地，"
        },
        {
          "character": "王留",
          "type": "夹白",
          "text": "爷爷！"
        },
        {
          "character": "王留",
          "type": "煞尾",
          "text": "我到那沤麻坑里洗个澡去。"
        },
        {
          "character": "胡老头",
          "type": "夹白",
          "text": "不许去。"
        },
        {
          "character": "胖姑",
          "type": "煞尾",
          "text": "唐三藏今日取经去，"
        },
        {
          "character": "胖姑",
          "type": "夹白",
          "text": "爷爷！"
        },
        {
          "character": "胖姑",
          "type": "煞尾",
          "text": "都是俺胖姑儿从头到尾告诉了你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胖姑跑下。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "嘟，嘟，嘟。你瞧，又给打哭啦。王留儿不要哭啦，叫我么，你答应，他还不 打你，起来到后面吃饸饹去罢。"
        },
        {
          "character": "王留",
          "type": "白",
          "text": "爷爷背着。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "呃，这么大还叫背着。"
        },
        {
          "character": "王留",
          "type": "白",
          "text": "爷爷背着。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "我偌大年纪，背不动了。"
        },
        {
          "character": "王留",
          "type": "白",
          "text": "爷爷背着。"
        },
        {
          "character": "胡老头",
          "type": "白",
          "text": "淘气。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡老头背王留下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}