{
  "script_id": "70904207",
  "title": "西游记·认子",
  "alias": [],
  "source": "马祥麟剧本选",
  "characters": [
    {
      "name": "殷氏",
      "hangdang": "正旦"
    },
    {
      "name": "玄奘",
      "hangdang": "小生"
    }
  ],
  "plot": "唐代洪州太守陈光蕊携眷赴任，中途被水贼刘洪杀害，其妻殷氏亦被霸占，生下遗腹子，曲名江流儿，被迫\n投入江中，为金山寺的和尚救起抚养，法名玄奘，十八年后前来寻母。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "殷氏上。"
        },
        {
          "character": "殷氏",
          "type": "念",
          "text": "世人似我几多愁，忆念儿夫化石头。心如快鹞拖着线，身似浮鱼吞了钩。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "妾身殷氏。自从抛弃丈夫、孩儿，早又是十八年矣。这几日，耳热心跳，神思 不安。嗳，多因思想丈夫、孩儿，恹恹成病。啊呀！不知几时，才有个出头日 子吓。啊呀，我那江流儿吓！"
        },
        {
          "character": "殷氏",
          "type": "北集贤宾",
          "text": "恁趁着这碧澄澄大江东去得紧， 如失却宝和珍。 白日里鱼行也那虾队， 到晚来与鹭友鸥群。 黑漫漫翠雾连山， 白茫茫雪浪堆银。 只俺这跳龙门的丈夫，畅好是千转的稳， 便重生十八岁为人。 目穷明月渡， 肠断碧天云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷氏下。玄奘上。"
        },
        {
          "character": "玄奘",
          "type": "念",
          "text": "迢迢路途休嫌远，但能早见慈亲面。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "我玄奘。奉师父之命，来到此间，寻访母亲。一路问来，说此间黑楼子内就是。 不知我母亲可在里面？待我打坐在此，只做化斋访问便了。 阿弥陀佛！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷氏上。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "不免登楼一望。"
        },
        {
          "character": "殷氏",
          "type": "逍遥乐",
          "text": "倚危楼高峻， 瞑眩药难痊，志诚心较谨。 我见一个小沙弥来往踅门， 念一声阿弥陀佛心意真， 策杖移踪似有因， 恰便似塑来的诸佛世尊。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "师父做什么的？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "是化斋的。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "如此俺家斋你哩。"
        },
        {
          "character": "殷氏",
          "type": "逍遥乐",
          "text": "我有那做袈裟的绸绢，供佛像的斋粮，御严寒的衲裙。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "师父从哪里来？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "金山寺来。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "哦，金山寺来，几时可到？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "风顺二十日可到，风不顺要行一月才到。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "金山寺可是大刹之所？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "是大刹之所，万众可容。"
        },
        {
          "character": "玄奘",
          "type": "金菊香",
          "text": "金山寺至此有二三旬， 宝殿能容千万人。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "师父请。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "女菩萨请。"
        },
        {
          "character": "玄奘",
          "type": "金菊香",
          "text": "问询向前施礼勤。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "师父请里面用斋。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "多谢女菩萨，贫僧告斋了。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "殷氏",
          "type": "金菊香",
          "text": "觑着他清气逼人， 恰便似一溪流水澈云根。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "好奇怪！这和尚的面庞，好似我丈夫陈光蕊模样。"
        },
        {
          "character": "殷氏",
          "type": "梧叶儿",
          "text": "他眉眼全相似， 身材忒煞真， 霞脸绛丹唇。 莫不是石上三生梦， 天台一化身。 我心下自如亲， 我心下自如亲。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "请问师父法算多少？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "贫僧今年十八岁了。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "俺孩儿若在，也是十八岁了。"
        },
        {
          "character": "殷氏",
          "type": "梧叶儿",
          "text": "啊呀儿呵！恁十八岁在波翻得这浪滚！"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "师父！"
        },
        {
          "character": "殷氏",
          "type": "醋葫芦",
          "text": "我问恁何处是家？哪个是亲？ 几年上落发做僧人？"
        },
        {
          "character": "玄奘",
          "type": "夹白",
          "text": "贫僧出胞胎就做僧人的。"
        },
        {
          "character": "殷氏",
          "type": "醋葫芦",
          "text": "出胞胎怎生便离了世尘？ 也是恁那前生有分？ 与俺从头一一说个原因。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "我父姓陈，母姓殷，曾任洪州太守。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "殷氏",
          "type": "醋葫芦",
          "text": "他道是父姓陈，母姓殷， 为官为吏是当军， 几年上此间来治民？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "贞观三年八月间，被水贼刘洪推入江中的。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "殷氏",
          "type": "醋葫芦",
          "text": "这一句道得咱心迷眼晕！ 他道是江上遇着强人。那时你怎生得活？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "贫僧在母腹中才得八个月。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "你怎知许多备细？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "师父丹霞禅师，在金山下拾得一个漆匣，内有金钗两股，血书一封，送至寺中， 蒙长老收留。七岁能文，十五岁通经，今年一十八岁，师父着我来到洪州， 寻访母亲的。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "殷氏",
          "type": "醋葫芦",
          "text": "听说罢口内词， 扫除了心上尘。 悠悠的顶门上失了三魂！ 原来是江流儿远方来认亲。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "师父！"
        },
        {
          "character": "殷氏",
          "type": "醋葫芦",
          "text": "非是俺言多语峻， 告吾师心下莫生嗔。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "你既来寻亲，有何为证。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "有血书为证。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "你那血书，可曾带来？"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "既来寻亲，怎生不带？"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "如此，我有钞写的墨书在此，你可念来，看可是一样的。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "待贫僧跪读。殷氏血书：此子之父，乃海州弘农人也，姓陈名萼，字光蕊，官 拜洪州太守。携家小至任，买舟江上，遇贼刘洪，将夫推入江中，那贼冒认洪 州太守。殷氏有遗腹之子，才得满月，被贼人逼勒投入江中，身系金钗两股， 血书一封，望仁者怜而救之。此子乃贞观三年十一月十五日子时建生。"
        },
        {
          "character": "殷氏",
          "type": "夹白",
          "text": "一些也不差！"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "别无名字，唤做江流儿。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "嗳，江流儿！是我孩儿了！"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "是我母亲了！"
        },
        {
          "character": "殷氏、玄奘",
          "type": "同白",
          "text": "啊呀（儿）（娘）呀！"
        },
        {
          "character": "殷氏",
          "type": "醋葫芦",
          "text": "尘昏了老绢白， 惊荒了旧血痕。 这的是一翻提起一翻亲。 与俺那十八年的泪珠儿都挣了本， 善和恶在乎方寸。 恰便似花开枯树再逢春！"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "母亲，师父说寻见母亲，即便回山，商量报仇要紧。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "噤声！儿吓，那贼手足较多，须要小心。待我收拾些盘缠与你，星夜回山，请 师父到来，商量报仇便了。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "谨依母亲慈命。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "殷氏",
          "type": "后庭花",
          "text": "我这里便收拾下金共银， 哎呀！只要恁早分一个冤与恩。 俺孩儿经卷能成事， 陈光蕊呵！恁说什么文章可立身。 莫因循，疾忙前进， 下水船风力稳， 报仇心似火焚， 去程忙如箭紧。"
        },
        {
          "character": "玄奘",
          "type": "后庭花",
          "text": "去程忙如箭紧。"
        },
        {
          "character": "殷氏",
          "type": "柳叶儿",
          "text": "啊呀儿呵！ 又想起当年，当年时分， 哭啼啼送你到江滨， 今日个蒲帆百尺西风顺， 休辞困，暂劳神。 天吓！谁承望血修书弄假成真。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "来此已是江边，孩儿就此拜别。"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "殷氏",
          "type": "浪里来煞",
          "text": "才得个掌上珍， 又提起心头闷。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "母亲！"
        },
        {
          "character": "玄奘",
          "type": "浪里来煞",
          "text": "今宵何处去安身？"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "殷氏",
          "type": "浪里来煞",
          "text": "明日里风波可也无定准。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "母亲，孩儿是去了！"
        },
        {
          "character": "殷氏",
          "type": "白",
          "text": "路上小心。"
        },
        {
          "character": "玄奘",
          "type": "白",
          "text": "母亲在家保重。"
        },
        {
          "character": "殷氏、玄奘",
          "type": "同白",
          "text": "啊呀（儿）（娘）吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玄奘下。"
        },
        {
          "character": "殷氏",
          "type": "浪里来煞",
          "text": "眼睁睁看得他有家难奔， 空教人断肠人送——"
        },
        {
          "character": "殷氏",
          "type": "夹白",
          "text": "哎呀！"
        },
        {
          "character": "殷氏",
          "type": "浪里来煞",
          "text": "断肠人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "殷氏下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}