{
  "script_id": "70904214",
  "title": "九莲灯·焚宫烧狱",
  "alias": [],
  "source": "马祥麟剧本选",
  "characters": [
    {
      "name": "火灵圣母",
      "hangdang": "武旦"
    }
  ],
  "plot": "上帝因晋室皇帝逆天不道，乱法滥刑，敕命火灵圣母率火部众神下凡，焚烧宫闱刑狱。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "天使上。〖神仗儿〗。"
        },
        {
          "character": "天使",
          "type": "白",
          "text": "玉旨下，火灵圣母接旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙童引火灵圣母同上。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "迎接天使。"
        },
        {
          "character": "天使",
          "type": "白",
          "text": "玉帝有旨，大仙听宣。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "无量佛。"
        },
        {
          "character": "天使",
          "type": "白",
          "text": "诏曰，君为民表，民为君依，赤子之亡，惟敬尚在知命。今者晋室皇帝司马邺， 逆天不道，乱法滥刑，信任奸邪，专恃狂惑。谗佞谣毒宫廷，义士捐魂狱底。 有负民望，天不佑焉。命尔火灵圣母，率火部众神，齐下尘凡。将三宫六院 及三司法、刑狱，尽行烧烟，以警将来。只有忠良义所当救。另行议奏。尔其 钦哉。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "圣寿无疆。"
        },
        {
          "character": "天使",
          "type": "白",
          "text": "大仙即刻兴师，俺回复上帝去也。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "送天使。"
        },
        {
          "character": "天使",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "天使下。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "传谕火部诸神，尘凡去者。"
        },
        {
          "character": "众仙童",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "火灵圣母",
          "type": "淘金令",
          "text": "仙舆下尘凡， 静闭琼宫岛。 云兴雾行， 鸾鹤相随绕。 离了清琼， 投寻烦恼。 堪笑君王行暴， 子庶飘摇。 忠臣义士皆已凋， 如今焚也怎逆天条。 六院三宫尽教一扫。 （火灵圣母下。〖水龙吟〗。宫娥扶晋帝同上，过场，同下。〖水龙吟止〗。风火旗、火鸦军引火炬星君同 上。火灵圣母上。）"
        },
        {
          "character": "火灵圣母",
          "type": "一枝花",
          "text": "一轮明月出海陬， 万古江山秀。 一片价清光兴玉岛，果然是瑞霭之秋， 雾净云收。 恨那些谗臣权相，搅乱了社稷江山， 哪里有为国的把天心转扭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火灵圣母上高台，入座。"
        },
        {
          "character": "火灵圣母",
          "type": "念",
          "text": "一片星辰浸月光，满天风露夜茫茫。谗臣惑主邦家乱，玉帝震怒降灾殃。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "俺乃，火灵圣母是也。今有晋室无道，玉帝大怒。命俺下凡焚宫烧狱。 火炬星君。"
        },
        {
          "character": "火炬星君",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "焚宫者。"
        },
        {
          "character": "火炬星君",
          "type": "白",
          "text": "遵法旨。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "可笑那晋帝呵。"
        },
        {
          "character": "火灵圣母",
          "type": "四块玉",
          "text": "他他他，才罢了楚游， 又入了阳台岫。 这火打断了鸳鸯锦帐两绸缪， 打断了梦入三更候。 哪里有粉黛讴， 哪里有娇娥宿， 哪里管瑞霭之秋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "风火旗、火鸦军引火炬星君同上。宫娥、晋帝同上，过场，同逃下。"
        },
        {
          "character": "火灵圣母",
          "type": "幺篇",
          "text": "呀呀呀，倾刻间晋国喧如吼， 闹嚷嚷乱煞了公与侯，闹嚷嚷乱煞了公与侯。 一霎时铁壁铜监成尘垢， 一霎时金银玉石都付横流。 一霎时广寒宫变作凄凉周， 一霎时五方六界四海光收。 天崩地裂鬼笑神愁， 似斜阳朱殷血透。 眼见得人间灰烬， 好教那宫廷作了荒丘。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "富奴啊富奴。"
        },
        {
          "character": "火灵圣母",
          "type": "幺篇",
          "text": "说什么拿云手， 救死囚机缘凑。 若不是道德莲灯怎得天庭恩宥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "富奴、闽觉、戚轻霞同上，过场，同下。风火旗、火鸦军引火炬星君同上。"
        },
        {
          "character": "火炬星君",
          "type": "白",
          "text": "烧牢已毕。"
        },
        {
          "character": "火灵圣母",
          "type": "白",
          "text": "回复玉帝者。"
        },
        {
          "character": "火炬星君、风火旗、火鸦军",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火灵圣母、风火旗、火鸦军、火炬星君同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}