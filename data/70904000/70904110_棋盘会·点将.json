      "hangdang": "生"
    },
    {
      "name": "管和",
      "hangdang": "净"
    }
  ],
  "plot": "春秋战国时期，楚国有一白猿丞相擅长弈棋，因请齐王来赴棋会。齐王由王后钟无盐（著名丑女）护驾同行。",
  "notes": "《点将》一折是钟无盐提防楚国请赴棋会，而有诱兵之计，为此登台点将，提防不测。表现出钟无盐虽丑但\n机智过人。果然不出所料，一场凶战终于齐王冲出重围，回到齐国。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "田常、田玉同上。"
        },
        {
          "character": "田常、田玉",
          "type": "同点绛唇",
          "text": "整顿熊羆，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田能、管和同上。"
        },
        {
          "character": "田能、管和",
          "type": "同点绛唇",
          "text": "刀枪锐利。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田昆上。"
        },
        {
          "character": "田昆",
          "type": "点绛唇",
          "text": "三军齐，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廉赛花上。"
        },
        {
          "character": "廉赛花",
          "type": "点绛唇",
          "text": "谁敢轻敌，"
        },
        {
          "character": "田常、田玉、田能、管和、田昆、廉赛花",
          "type": "同点绛唇",
          "text": "到处降书递。"
        },
        {
          "character": "田常",
          "type": "念",
          "text": "战马交驰日月黄，"
        },
        {
          "character": "管和",
          "type": "念",
          "text": "披星戴月渡边疆。"
        },
        {
          "character": "田昆、廉赛花",
          "type": "同念",
          "text": "夫妻双双归临淄，"
        },
        {
          "character": "田常、田玉、田能、管和、田昆、廉赛花",
          "type": "同念",
          "text": "赤胆衷心保齐邦。"
        },
        {
          "character": "田常、田玉、田能、管和、田昆、廉赛花",
          "type": "同白",
          "text": "俺！"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "田昆。"
        },
        {
          "character": "廉赛花",
          "type": "白",
          "text": "廉赛花。"
        },
        {
          "character": "田常",
          "type": "白",
          "text": "田常。"
        },
        {
          "character": "田玉",
          "type": "白",
          "text": "田玉。"
        },
        {
          "character": "田能",
          "type": "白",
          "text": "田能。"
        },
        {
          "character": "管和",
          "type": "白",
          "text": "管和。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "田常、田玉、田能、管和、廉赛花",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "国母登台点将，你我两相伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵、大刀手引钟无盐同上。"
        },
        {
          "character": "钟无盐",
          "type": "端正好",
          "text": "没来由，风波起， 急忙忙催趲征驹。 都只为保定了俺东齐， 楚王他暗设杀机， 俺必须紧紧防提。"
        },
        {
          "character": "田常、田玉、田能、管和、田昆、廉赛花",
          "type": "同白",
          "text": "参见国母。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "众位将军少礼。"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "宝剑霜威耀苍穹，霓旌慢卷午西风。一声呼啸貔貅肃，龙驹飞腾天下惊。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "哀家钟离春，别号无盐，扶保齐王，且喜言听计从，方得国泰民安，四海实服， 人人敬仰。 众将官。"
        },
        {
          "character": "田常、田玉、田能、管和、田昆、廉赛花",
          "type": "同白",
          "text": "国母。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "可恨楚邦，暗生诡计，养一个猴头，封为丞相，自负弈棋，无敌于天下，他今 邀请吾主与哀家前去赴棋盘大会，我想此乃三分请会七分战，只恐到时必有一 场风波颠险。位此今日登台点将，以防不测。"
        },
        {
          "character": "田常、田玉、田能、管和、田昆、廉赛花",
          "type": "同白",
          "text": "国母。有用臣等之处，理当尽心尽力，以报我主之恩。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "好，听我道来。"
        },
        {
          "character": "钟无盐",
          "type": "叨叨令",
          "text": "哪怕他重重的罗网奇， 俺今番可也难回避。 他那里分明是擒凤牢笼计， 说什么意重心诚兄弟谊。 兀的不恨煞人也么哥， 兀的不恼煞人也么哥， 告诸臣须记取棋盘会不是待客的筵席。"
        },
        {
          "character": "齐王",
          "type": "内白",
          "text": "圣驾到。"
        },
        {
          "character": "田常、田玉、田能、管和、田昆、廉赛花",
          "type": "同白",
          "text": "驾到。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "啊，是我背了大王点齐众将，以防不测，不想大王驾到，随我接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、二大太监引齐王同上。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "参见大王！千千岁。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "梓童，众将为何披挂整齐，聚至教场？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "这，妾身要登台点将，调遣人马，预做埋伏，以防万一。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "梓童差矣。想我齐邦威镇列国，诸侯丧胆，楚邦与我力求和好，此番江楼会棋， 乃是衣冠之会，如此大兴人马，岂不有碍邦交？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "大王，想列国争强，各怀心机，外托宴乐之名，内藏甲兵，前车之鉴，大王不 可不妨。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "如此，梓童小做安排就是。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "是。 吩咐击鼓登台。"
        },
        {
          "character": "田常",
          "type": "白",
          "text": "击鼓登台。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "田常、田玉听令。"
        },
        {
          "character": "田常、田玉",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "命你二人改扮马童模样，随哀家前去赴会。"
        },
        {
          "character": "田常、田玉",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田常、田玉同下。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "田能、管和听令。"
        },
        {
          "character": "田能、管和",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "命你等带领人马，埋伏在丹凤岭。"
        },
        {
          "character": "田能、管和",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "田昆听令。命你带领三千人马在盘龙山接应，不得有误。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "啊梓童，盘龙山既有埋伏，又何必如此兴师动众，此事倘被列国闻之，不笑我 齐邦忒胆小了。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "大王，岂不知既防其一，必防其二，有备无患，方为万全。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "就依梓童，急速启程，荆楚一游。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "且慢，还有一事，必须吩咐。 廉赛花听令。"
        },
        {
          "character": "廉赛花",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "此番赴会，命你保护主公，倘会中有诈，急忙保护主公下楼。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "哈哈……想孤身经百战，力敌万人，会中纵然有诈，孤何惧哉？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "啊大王，你可知骄者必败，备者无失？"
        },
        {
          "character": "棋王",
          "type": "白",
          "text": "就依你。梓童，怎么样了？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "妾身身怀有孕了。"
        },
        {
          "character": "齐王",
          "type": "笑",
          "text": "哈……"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "啊，廉赛花，你还要备些鲜果，随身携带，不得有误。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "梓童，棋盘会上，珍馐甚多，自带鲜果何用啊？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "著棋之时，我自有妙用。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "看你有何妙用。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "众将官。"
        },
        {
          "character": "田能、管和、田昆、廉赛花",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "本宫之令。务必小心在意，倘有疏虞，定按军法行事。"
        },
        {
          "character": "钟无盐",
          "type": "上小楼",
          "text": "正趐起戈戟旌旗， 振作起三军刚毅， 这期间自有藏机， 运筹帷幄不需狐疑， 胆愈大，心愈细， 俺的兵法也神奇， 纵有那万马千军， 俺则能知己知彼， 俺则能料定忧危， 到头来应记取， 有功的论功行赏， 违令的难逃刑辟。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "护驾前往。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "众将官，护驾前往。"
        },
        {
          "character": "田能、管和、廉赛花",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐王、二大太监、四小太监、四女兵、大刀手同下。田常、田玉扮马童同上。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "马童，带马！"
        },
        {
          "character": "钟无盐",
          "type": "尾声",
          "text": "动三军举旌旗， 日光寒驱征骑， 此一番去赴棋盘会， 管教那楚国君臣得知俺兵强将勇不可欺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟无盐、田常、田玉同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}