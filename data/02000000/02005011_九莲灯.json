      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四神将、四神童、昊天上帝同上。"
        },
        {
          "character": "昊天上帝",
          "type": "点绛唇",
          "text": "万福来朝，千祥普照，祥光耀，雨顺风调，五谷丰登好。"
        },
        {
          "character": "昊天上帝",
          "type": "念",
          "text": "三十三天我为尊，驾坐凌雷镇天庭。统辖天宫众神圣，赏罚公平善恶分。"
        },
        {
          "character": "昊天上帝",
          "type": "白",
          "text": "吾乃上帝昊天是也。今当三十三天，诸神齐来朝驾。 众神将，展开凌霄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太白金星上。"
        },
        {
          "character": "太白金星",
          "type": "念",
          "text": "迈步上凌霄，把本奏根苗。"
        },
