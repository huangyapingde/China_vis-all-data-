        {
          "character": "闵觉",
          "type": "二黄摇板",
          "text": "朝罢圣驾即回转， 择选黄道谢苍天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、闵觉同进门，四青袍自两边分下。"
        },
        {
          "character": "闵远",
          "type": "白",
          "text": "参见爹爹。"
