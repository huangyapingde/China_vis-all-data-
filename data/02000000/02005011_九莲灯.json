          "character": null,
          "type": "stage",
          "text": "闵觉笑。"
        },
        {
          "character": "闵觉",
          "type": "白",
          "text": "儿吓，随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵觉、闵远同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈氏、田奶公、田奶母、田翠兰、单洪同上。"
        },
        {
          "character": "单洪",
          "type": "唱",
          "text": "不想在此身染病， 且喜痊愈病离身。"
        },
        {
          "character": "单洪",
          "type": "白",
          "text": "啊，奶公、奶母、陈妈、小姐请坐。"
        },
        {
          "character": "陈氏、田奶公、田奶母、田翠兰",
          "type": "同白",
          "text": "请坐。"
        },
        {
          "character": "单洪",
          "type": "白",
          "text": "这几日多有骚扰陈妈妈。且喜我病体痊愈，只是心中悬挂爹爹、妹子，意欲将 小姐托付奶公、奶母照应。小姐我要往京都探望天伦、妹子，此去多则一月， 即便回来迎接小姐。奶公、奶母、陈妈妈同居一处，不知奶公、奶母、小姐意 下如何？ 中国京剧戏考 《九莲灯》【六本】 10"
        },
        {
          "character": "田奶公、田奶母",
          "type": "同白",
          "text": "公子既然要尽孝道之心，我们焉能拦阻？且请放心，小姐全有我夫妻二人照应。 但不知公子几时起身？"
        },
        {
          "character": "单洪",
          "type": "白",
          "text": "今乃黄道吉日，正好起程。"
        },
        {
          "character": "田奶公、田奶母",
          "type": "同白",
          "text": "如此我夫妻略备薄酒，与公子饯行。"
        },
        {
          "character": "单洪",
          "type": "白",
          "text": "俺单洪多谢奶公、奶母了！"
        },
        {
          "character": "田奶公、田奶母",
          "type": "同白",
          "text": "岂敢。大家后面议论。"
        },
        {
          "character": "田奶公、田奶母",
          "type": "同唱",
          "text": "但愿此去身安稳， 公子即回传好音。"
        },
        {
          "character": "单洪",
          "type": "唱",
          "text": "奶公、奶母心放定， 多则一月便回程。"
        },
        {
          "character": "田翠兰",
          "type": "唱",
          "text": "公子此去多谨慎， 诸事格外加小心。"
        },
        {
          "character": "单洪",
          "type": "唱",
          "text": "小姐不必细叮咛， 此去我必见机行。 大家后面把酒饮， 即去即回即回程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单洪、田翠兰同笑，同下。"
        }
      ]
    },
    {
