{
  "script_id": "02005026",
  "title": "观阵",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "秦琼",
      "hangdang": "生"
    },
    {
      "name": "罗周",
      "hangdang": "小生"
    },
    {
      "name": "程咬金",
      "hangdang": "净"
    },
    {
      "name": "尤俊达",
      "hangdang": "生"
    },
    {
      "name": "徐勣",
      "hangdang": "外"
    }
  ],
  "plot": "秦琼被押在登州城内，程咬金、徐勣、罗成等群往搭救。适与秦琼相遇，但均佯作不识，暗递信息。后罗周\n又领秦琼观八卦连环阵、绝命桥等。",
  "notes": "此剧为《三家店》以后，《打登州》以前之情形。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "登州城困住了秦叔宝， 游来游去好心焦。 眼看那八月中秋到， 并无亲朋把咱瞧。 我好比明月浮云照， 沙滩困住浪里蛟。 三家店内有人到， 史大奈贤弟把书捎。 恨徐勣把俺书按了， 全不念金炉把香烧。 提起单通心好恼， 无义之人不可交。 程咬金你把心死了， 全不念救你出狱牢。 我为你定下苦肉计， 我为你两腿扎钢刀。 想罗成八弟他不到， 不念结拜念姑表。 姑表弟兄相交好， 骨肉相连筋一条。 我母年高妻年少， 还有秦山小根苗。 将身坐在马鞍鞒， 又听有人闹吵吵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金、尤俊达同上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "打打打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗周上。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "哪是主拿哪是客？"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "我是主他是客。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "主人低头客人讲来。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我本是贩牛汉，今晚住了他的店，要米无有米，要面无有面，我怎么不打这个 忘八旦！"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "客人低头，主人讲话。"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "他今住了我的店，讲的一位三钱银子一顿饭，吃了我的八十包子六十面，一个 小钱也无有给，请王爷断一断。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "王爷心中有事，若是无事，重责一百皮鞭，还不下去！"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "虎。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "豹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尤俊达、程咬金同下。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "二哥，方才过去那是什么人？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟不认识？稳坐雕鞍听愚兄道来！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "贤弟莫把来人问， 青面红发似天神。 要问此人名和姓， 班鸠店内程咬金。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "南京收了南京去，北京收了北京游。南北二京全不收，条河两岸度春秋。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "大哥魏徵，二哥李靖，三弟茂公为母许愿，舍药三年，舍了二载，还有一春， 用药这厢来。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "来者敢是茂公？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "怎么说，贤弟冒了风了？"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "三片生姜两段葱，一晚温汤用腹中，盖上被子出身汗，哪管你冒风不冒风！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你是徐勣？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "怎么方才冒了风，你又得了食积？下马来，我与你号脉。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "下马去了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "明白了，上马去罢。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "有罪了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "这是狗皮膏药四张，前心一张，后心一张，左膀一张，右膀一张，这是大红丸， 一付用在腹中，药往外发，膏药往里发，好似两军阵前，冲锋打仗一般，出 一身冷汗，你这病就好了。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "请问用何药引？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "只顾与兄台讲话，把药引都忘记了。虎的心，豹的胆，虎豹二字牢牢紧记，请 吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣下。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "二哥方才过去那是什么人？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟不认识？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "不认识。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "将马勒后，听愚兄道来！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "在大街不敢通名姓， 物吞八卦阴阳能。 袖儿里常拿三才打， 梨阳县里徐茂公。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟你我游来游去，并无比艺，你我回去罢。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "请二哥观阵。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "甚么？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "请二哥观阵。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "闻听说观阵心纳闷， 十分精神少九分。 我在这登州城里命该尽， 想起了高堂老娘亲。 哭一声老娘心难忍，我的娘吓！ 何人送进秦家坟？ 别听那绿林兄弟同来问， 他说我秦家是绝门。 催动黄骠往前进， 那边来了卖马人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "卖马吓卖马！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "来者敢是罗成？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "一匹马未从讲价，就说成与不成。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "为兄是秦琼。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你穷算你命苦，哪个周济你不成？我这马如同虎豹一般，虎豹二字，牢牢紧记， 请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "一言未尽罗成到， 倒叫豪杰喜眉梢。 杨龄贼呀时衰了， 八弟花枪命难逃。 喜盈盈来催黄骠， 再叫贤弟听根苗！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟此为何阵？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "金锁八卦连环斗底大阵。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哪门进？哪门出？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "生门进，休门出。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "为兄杀在昏迷之间，哪晓得生门、休门？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "为弟枪头之上，挂着三尺红罗，随罗而进随罗而出。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "愚兄马上多谢了。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "观此阵我把雄心退， 用枪一指骂老贼！ 杏马旗插在青龙背， 摆下八卦九重雷。 营门外大炮摆几对， 中营安下振天雷。 众家兄弟阵前对， 设谋定计拿老贼。 低下头来想半悔， 细思想朋友还要为。 佐黄骠闯在紫金对， 再叫贤弟听明白！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟此为何桥？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "绝命桥。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "何为绝命桥？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "杨龄与二哥交战，胜过二哥则罢了，胜不过二哥，将桥梁拆断，把二哥活活淹 死在内。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你二哥一死倒也罢了，岂不害了看桥之人？ 杨龄贼吓！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "观此阵把我的胆唬破， 上是桥来下是河。 你二哥一死还罢了， 苦了看桥小哥哥！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟此为何炮？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "振中胆。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "何为振中胆？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "杨龄与二哥交战，胜不过二哥，将此炮点着，把二哥活活振死在内。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你二哥一死还在罢了，岂不苦了看炮之人？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "只要二哥一死，哪管看炮之人？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "杨龄贼吓。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "勒马我把贤弟叫， 叫声贤弟听根苗： 说与你伯母与嫂嫂， 就说愚兄功成了， 来世与你把香烧。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、罗周同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}