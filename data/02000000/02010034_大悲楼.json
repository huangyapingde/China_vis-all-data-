{
  "script_id": "02010034",
  "title": "大悲楼",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "济公",
      "hangdang": "丑"
    },
    {
      "name": "华云龙",
      "hangdang": "武生"
    },
    {
      "name": "云飞",
      "hangdang": "武丑"
    },
    {
      "name": "韩秀",
      "hangdang": "武丑"
    },
    {
      "name": "王通",
      "hangdang": "净"
    },
    {
      "name": "雷鸣",
      "hangdang": "武净"
    },
    {
      "name": "陈亮",
      "hangdang": "武生"
    }
  ],
  "plot": "济公派王通、雷明、陈亮捉拿华云龙，虽擒得四大名盗。但华云龙脱逃，王通、雷明、陈亮三人亦均被华云\n龙的毒镖所伤。济公将四名大盗押于灵隐寺内后，只好先给王通等三人医治镖伤。华云龙逃走，念其四位寨\n主被擒，心有不甘。乃邀请其师叔华清风前来帮助，想去救四位寨主，并刺杀济公。无如济公早已知晓。乃\n派人四方准备，华云龙所预定之火烧灵隐寺亦因菩萨暗中保佑，并未得逞。彼此大战后，华云龙又得脱逃云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四镖客、四上手背王通、雷明、陈亮同上。〖牌子〗。四门、杨明、杨志、苗庆、何清、济公同上。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "将你们三位师兄扶到后面西客堂，少时待我与他们医治镖伤便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手扶王通、雷明、陈亮同下。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "将四将绑上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郎天寿、李殿元、熊黑虎、孙太立同上。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "你们四人既然被擒，听我相劝，何必助强为恶。那华云龙乃是酒色之徒，自行 不正，你们何不皈依正道，免得后悔。"
        },
        {
          "character": "郎天寿、李殿元、熊黑虎、孙太立",
          "type": "同白",
          "text": "住了。我等既已被擒，一死何惧，说什么“皈依”二字。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "好，无知孽障，我劝尔等皈依，不过是与你们解却此冤。不听我言，也怪不得 我出家人了。 来，将他四人锁在后面空房之内，自有定夺。带下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人押郎天寿、李殿元、熊黑虎、孙太立同下。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "徒弟们，你们三位师兄的镖伤怎么样了吓？"
        },
        {
          "character": "杨明",
          "type": "白",
          "text": "他三人昏迷不醒。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "待我与他们将镖伤治好，然后再拿华云龙，与他三人报仇便了。正是："
        },
        {
          "character": "济公",
          "type": "念",
          "text": "他今伤三友，"
        },
        {
          "character": "杨明",
          "type": "念",
          "text": "结冤怎罢休！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "华云龙",
          "type": "内西皮导板",
          "text": "豪杰怒气冲牛斗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "法元僧、韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦、四下手同上，同站门。华云龙上。"
        },
        {
          "character": "华云龙",
          "type": "西皮二六板",
          "text": "两下仇恨怎罢休。 马行狭路难退后， 杀却凶僧解冤仇。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "众位寨主。想俺镖伤王通、雷明、陈亮，谁想四位寨主被擒，济颠和尚使法， 虽是我等逃脱，但不知四位寨主生死，倒叫俺心神不定也。"
        },
        {
          "character": "法元僧、韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦",
          "type": "同白",
          "text": "寨主。前面离凤凰岭不远，大家回山商议，救出四位寨主，然后灭却凶僧。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "众位寨主，言之有理。一同回山。"
        },
        {
          "character": "华云龙",
          "type": "西皮二六板",
          "text": "只为英雄难搭救， 倒叫豪杰无计谋。 虎落平阳难回首， 今日定要报此仇。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "众位寨主请。"
        },
        {
          "character": "法元僧、韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "法元僧、韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "王通、雷明、陈亮中我镖伤，料想性命难保。只是四位寨主被擒，恐怕性命有 伤，你我必须早作安排方好。"
        },
        {
          "character": "法元僧",
          "type": "白",
          "text": "想那济颠和尚，身入空门，岂能伤害人命。你我只要奋勇齐心，救出四位寨主， 然后灭却凶僧，以除绿林后患。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯三上。"
        },
        {
          "character": "侯三",
          "type": "白",
          "text": "走哇。"
        },
        {
          "character": "侯三",
          "type": "念",
          "text": "两脚飞奔到山冈，报与大王作商量。"
        },
        {
          "character": "侯三",
          "type": "白",
          "text": "叩见大王。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "命你打探那济颠和尚，将那四位寨主绑到何处去了？"
        },
        {
          "character": "侯三",
          "type": "白",
          "text": "那济颠和尚将四位寨主绑到灵隐寺而去。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "既然如此，我等今晚去到灵隐寺，救出四位寨主，将那济颠和尚杀死，岂不是 好？"
        },
        {
          "character": "法元僧、韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦",
          "type": "同白",
          "text": "那济颠和尚法力无边，倘然行刺不能成功，岂不是作了画虎不成反类犬也。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "不妨，我叔父华清风现在铁牛山紫霞洞，待我修书请他到来，何愁济颠和尚不 灭。"
        },
        {
          "character": "韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦",
          "type": "同白",
          "text": "但不知何人前往？"
        },
        {
          "character": "法元僧",
          "type": "白",
          "text": "寨主就将书信修起，待俺前去走遭。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "好，浓墨伺候。"
        },
        {
          "character": "华云龙",
          "type": "西皮正板",
          "text": "提笔修书心暗想， 拜上叔父看端详： 小侄霸占凤凰岭上， 王通与我结义山岗。 只恨济颠行狂妄， 江要路上战一场。 王通镖下把命丧， 雷明、陈亮俱带伤。 擒去宾朋心难放， 定与凶僧拼刚强。 书信如侄亲身往， 还望叔父下山岗。 一封书信忙修上， 杀了仇人除祸殃。"
        },
        {
          "character": "法元僧",
          "type": "唱",
          "text": "寨主但把宽心放， 为救宾朋在心旁。 辞别众位把马上， 性急加鞭下山岗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "法元僧下。"
        },
        {
          "character": "华云龙",
          "type": "唱",
          "text": "见他上马登程往， 不由豪杰喜心旁。"
        },
        {
          "character": "华云龙",
          "type": "白",
          "text": "你我安排已定，且到后面改装各带器械，待等黄昏时候，前去行事便了。"
        },
        {
          "character": "韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "华云龙",
          "type": "念",
          "text": "安排巧计如铁纲，"
        },
        {
          "character": "韩秀、刘元彪、徐天义、安道士、云飞、刘应龙、张振邦",
          "type": "同念",
          "text": "哪怕他人暗提防。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手背王通、雷明、陈亮同上，济公上。"
        },
        {
          "character": "济公",
          "type": "西皮摇板",
          "text": "前生造定冤魔障， 可叹门徒带镖伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨明上。"
        },
        {
          "character": "杨明",
          "type": "白",
          "text": "师父来了，弟子们参拜。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "杨明",
          "type": "白",
          "text": "师父，弟子们闻华云龙的毒镖，打在身上，三日必亡。还求师父搭救他三人的 性命。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "我瞧他三人面带杀气，原不叫他们前去，他们一定要去。谁知中了那华云龙的 毒镖。哎，罢了，该有血光之灾，我这里有三丸子药，每人一丸服下就好了。"
        },
        {
          "character": "杨明",
          "type": "白",
          "text": "师父，此是什么药？"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "这叫大力丸，一半吃在腹内，一半上在镖伤之处，即刻就好。"
        },
        {
          "character": "杨明、杨志、苗庆、何清",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨明与王通、雷明、陈亮吃药。"
        },
        {
          "character": "杨明",
          "type": "白",
          "text": "大哥、贤弟醒来！"
        },
        {
          "character": "王通",
          "type": "西皮导板",
          "text": "三魂渺渺神不定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王通、雷明、陈亮同醒。"
        },
        {
          "character": "王通、雷明、陈亮",
          "type": "同白",
          "text": "哎呀，哎呀。"
        },
        {
          "character": "雷明、陈亮",
          "type": "同唱",
          "text": "双膝没在地埃尘。"
        },
        {
          "character": "王通",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "王通",
          "type": "唱",
          "text": "多蒙师父救我命，"
        },
        {
          "character": "雷明、陈亮",
          "type": "同唱",
          "text": "杀身难报今日恩。"
        },
        {
          "character": "雷明、陈亮",
          "type": "同白",
          "text": "多谢师父救命之恩！"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "三位贤徒受惊了。"
        },
        {
          "character": "王通",
          "type": "白",
          "text": "师父。弟子擒来四寇，师父怎样发落？"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "我把他们锁在后面空房里面命人看守。"
        },
        {
          "character": "王通",
          "type": "白",
          "text": "师父。弟子要将这四寇破腹剜心，然后拿住华云龙碎尸万段，方消弟子心头之 很。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "使不得。想这冤仇，只可解不可结，况灵隐寺乃是善地，岂作杀生害命之事？ 且候拿住华云龙，为师自劝他皈依正道。他若不从，但凭你们把他怎样发落， 不与我出家人相干。"
        },
        {
          "character": "王通、雷明、陈亮",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "不好，不好。"
        },
        {
          "character": "杨明、杨志、苗庆、何清、王通、雷明、陈亮",
          "type": "同白",
          "text": "师父，却是为何？"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "一时心血来潮，今晚华云龙必要前来行刺。"
        },
        {
          "character": "杨明、杨志、苗庆、何清、王通、雷明、陈亮",
          "type": "同白",
          "text": "待弟子们暗地埋伏，擒拿狂徒。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "要擒拿华云龙，非我帮你们不能成功。杨明、杨志、苗庆、何清。"
        },
        {
          "character": "杨明、杨志、苗庆、何清",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "命你四人埋伏在松林之内，头插黄旗为号，听锣声响亮，奋勇杀出便了。"
        },
        {
          "character": "杨明、杨志、苗庆、何清",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "王通、雷明、陈亮。"
        },
        {
          "character": "王通、雷明、陈亮",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "命你三人埋伏飞来峰，等华云龙到来，休要轻放。为师自有法力擒他。"
        },
        {
          "character": "王通、雷明、陈亮",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "济公",
          "type": "念",
          "text": "任他胸藏奸谋计，"
        },
        {
          "character": "杨明、杨志、苗庆、何清、王通、雷明、陈亮",
          "type": "同念",
          "text": "怎比佛门法力高！"
        },
        {
          "character": "济公",
          "type": "白",
          "text": "待我使起法力者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "观音",
          "type": "内西皮导板",
          "text": "落伽山法莲台祥云飘绕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四云童、二金童、二玉女、观音同上。"
        },
        {
          "character": "观音",
          "type": "西皮正板",
          "text": "观自在救苦难佛法今朝。 叹世间无义人不行正道， 半空中有神灵暗查分毫。"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "吾乃观音大士是也。适才朝罢佛祖而归，莲台打坐，慧眼观见杭州灵隐寺，今 晚有火光之灾，吾神理当前去保佑。 四大金刚何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大天王同上。"
        },
        {
          "character": "四大天王",
          "type": "同白",
          "text": "来也。有何法旨？"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "今晚灵隐寺有火光之灾，命你等前去暗地保佑殿庭，听吾吩咐。"
        },
        {
          "character": "观音",
          "type": "西皮正板",
          "text": "施慈悲暗保佑灵光普照， 必须要用法力降下重宵。 有吾神在莲台佛旨宣诏， 南海中紫竹林慈航法高。"
        },
        {
          "character": "四大金刚",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "观音",
          "type": "白",
          "text": "众云童，架起祥云，往灵隐寺去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "华清风上。"
        },
        {
          "character": "华清风",
          "type": "点绛唇",
          "text": "法力无边，神通广显，铁牛山，潇洒清闲，假意来修炼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八小老道自两边暗分上。"
        },
        {
          "character": "华清风",
          "type": "念",
          "text": "道法无穷志广谋，虎目圆睁神鬼愁。江湖之中俺为首，英雄四海把名留。"
        },
        {
          "character": "华清风",
          "type": "白",
          "text": "某，华清风，乃是浙江人氏。自幼身在绿林，是俺看破红尘，来在铁牛山紫霞 洞出家，修真养性。我有侄儿名叫华云龙，身在绿林霸占凤凰岭以为首领。前 者命头目送来美貌女子十余名，每日饮酒欢乐，这且不言。今日闲暇无事。 徒弟们，"
        },
        {
          "character": "八小老道",
          "type": "同白",
          "text": "师傅。"
        },
        {
          "character": "华清风",
          "type": "白",
          "text": "你们将拳棒演习一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑老道上。"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "启禀老师父：今有神拳罗汉法元僧前来，有要事求见老师傅。"
        },
        {
          "character": "华清风",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "有请法师傅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑老道下。法元僧上。"
        },
        {
          "character": "法元僧",
          "type": "白",
          "text": "啊，华师傅。"
        },
        {
          "character": "华清风",
          "type": "白",
          "text": "啊，贤弟。"
        },
        {
          "character": "法元僧、华清风",
          "type": "同笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "法元僧",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "华清风",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "法元僧",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "华清风",
          "type": "白",
          "text": "不知贤弟到来，未曾远迎，当面恕罪。"
        },
        {
          "character": "法元僧",
          "type": "白",
          "text": "岂敢。弟来的鲁莽，华师傅海涵。"
        },
        {
          "character": "华清风",
          "type": "白",
          "text": "岂敢。贤弟此来，必有所为。"
