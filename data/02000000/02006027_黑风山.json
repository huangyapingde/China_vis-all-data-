{
  "script_id": "02006027",
  "title": "黑风山",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "孙悟空",
      "hangdang": "武生"
    },
    {
      "name": "熊精",
      "hangdang": "净"
    }
  ],
  "plot": "黑风山黑风洞内黑熊大王，闻知唐僧有宝袈裟并了然欲烧死唐僧等事，乃乘火势将袈裟摄去。唐僧醒后，见\n了然虽烧死，而袈裟又失。乃责孙悟空不应向人夸耀，至有此失。孙悟空乃向唐僧保证取回。",
  "notes": "此剧即《西游记》第十六回“黑风山怪窃袈裟”故事，与原书完全相同。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "熊精上。"
        },
        {
          "character": "熊精",
          "type": "念",
          "text": "黑风山下惯藏妖，相貌狰狞胆气豪。一片雄心收未得，且施小计恣贪饕。"
        },
        {
          "character": "熊精",
          "type": "白",
          "text": "吾乃黑风山、黑风洞黑熊大王是也。今有唐三藏借宿在观音禅院。那寺僧了然， 意欲谋取他的袈裟。叫徒弟们三更时分放起火来，将他师徒烧死。我不免借 他的火力，将他得袈裟摄来，作一个佛衣圣会，有何不可。"
        },
        {
          "character": "熊精",
          "type": "念",
          "text": "良善称君子，山中号大王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "熊精下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "了然、众僧同上。"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "放火去咧。"
        },
        {
          "character": "了然",
          "type": "白",
          "text": "啊，放火也是嚷得的？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众僧同嘘。"
        },
        {
          "character": "了然",
          "type": "白",
          "text": "啊，徒弟们。听听几更了。"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "六更了。"
        },
        {
          "character": "了然",
          "type": "白",
          "text": "哪里来的六更？"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "钟三下，鼓三下，可不是六更？"
        },
        {
          "character": "了然",
          "type": "白",
          "text": "那还是三更。啊，徒弟们。今晚放火好有一比。"
        },
        {
          "character": "众僧",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "了然",
          "type": "扑灯蛾",
          "text": "好一似周郎破赤壁， 赤壁东风一阵起。 田单恢齐地， 连人带马一齐烧死也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火部同上，出烟彩。熊精上，拿袈裟下。"
        },
        {
          "character": "了然",
          "type": "白",
          "text": "不好了。"
        },
        {
          "character": "了然",
          "type": "扑灯蛾",
          "text": "连天火拥四下里， 烟雾腾空，真个是好叫人奔走， 魂散与魂飞，魂散与魂飞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "了然烧死，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "唐僧上。"
        },
        {
          "character": "唐僧",
          "type": "锁南枝",
          "text": "安心睡，梦正酣。 安心睡，梦正酣。 窗前燕燕语呢喃。 梦破鼠窥灯，懒起将他撼。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "呀，天明了。"
        },
        {
          "character": "唐僧",
          "type": "锁南枝",
          "text": "因何不听钟声沸， 不见僧了然，不见僧了然？ 且到圣像前， 礼一回千佛忏，礼一回千佛忏。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "呀。夜来失火烧得这等光景。阿弥陀佛。 悟空哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上。"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "善有善报，恶有恶报。若还不报，时辰未到。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "悟空，昨夜失火，你可晓得么？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "弟子怎么不晓得？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "我睡熟了，竟不晓得。可曾烧坏了人么？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "师父，你不问袈裟，问人怎么？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "岂不闻孔子云：厩焚问人不问马。火是怎么起的？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "师父，你问起火的缘故么，真个可恼。那了然呵！"
        },
        {
          "character": "孙悟空",
          "type": "锁南枝",
          "text": "他的心不善，起恶端， 心不善，起恶端。 袈裟一见蓄意安。 他面上起春风，腹内三昧暗。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "师父。不但了然见了袈裟意欲谋求，还吩咐众和尚放火，要把你我烧死。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "那时弟子听得，将火神召来，用火罩将师父的睡处罩住，故此师父无恙。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "孙悟空",
          "type": "锁南枝",
          "text": "喜得天有耳，火反弹。 喜得天有耳，火反弹， 烧得秃光头，一个个额头烂， 一个个额头烂。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "如此，唤了然来。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "呔，了然哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众僧同上。"
        },
        {
          "character": "众僧",
          "type": "同念",
          "text": "暗地损人伦，放火烧自身。"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "爷爷饶命啊。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "了然哪里去了？"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "我那老和尚呵！"
        },
        {
          "character": "众僧",
          "type": "同锁南枝",
          "text": "他的年华迈，两鬓黲， 年华迈，两鬓黲。"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "见了袈裟呵！"
        },
        {
          "character": "众僧",
          "type": "同锁南枝",
          "text": "金光夺目锦又灿。"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "要谋袈裟是实。故此叫我们放火。害得二位师父呵！"
        },
        {
          "character": "众僧",
          "type": "同锁南枝",
          "text": "谁料自烧身，送死全无怨。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "袈裟放在哪里？"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "那袈裟呵！"
        },
        {
          "character": "众僧",
          "type": "同锁南枝",
          "text": "藏在观音院，韦陀龛。 观音院，韦陀龛。"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "方才取去，又不见了。"
        },
        {
          "character": "众僧",
          "type": "同锁南枝",
          "text": "伏乞念同衣，饶恕头颅汉。 饶恕头颅汉。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "胡说。料你们这些秃厮，也不肯实说。吃老孙一棒！"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "爷爷饶命。我们常闻听老和尚说，这院南有个黑风山，黑风洞，有个黑熊大王。 想是他见火光起处，被他摄去，也未见得。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "这等说，自然是他摄去了。老和尚既死，与你们无干。去罢。"
        },
        {
          "character": "众僧",
          "type": "同白",
          "text": "多谢爷爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众僧同下。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "想起来，都是你这猴头，卖弄我的宝贝，惹出这场祸来。不管。只问你要袈裟。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "师父！"
        },
        {
          "character": "孙悟空",
          "type": "锁南枝",
          "text": "你休埋怨，骂再三。 追取袈裟全在俺。 料相如赴秦庭， 赵璧依无憾。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "那妖怪凶狠，你如何是他的对手？"
        },
        {
          "character": "孙悟空",
          "type": "锁南枝",
          "text": "任他狰狞貌，恶势憨。 狰狞貌，恶势憨。"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "若还说出老孙名，"
        },
        {
          "character": "孙悟空",
          "type": "锁南枝",
          "text": "管叫吓破他的胆，吓破他的胆。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "不管。只问你要。"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "师父莫再生嗔。"
        },
        {
          "character": "唐僧",
          "type": "念",
          "text": "去还须用心。"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "不必再嘱咐。"
        },
        {
          "character": "唐僧",
          "type": "念",
          "text": "看你这猴孙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐僧、孙悟空同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}