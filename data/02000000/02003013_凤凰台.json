{
  "script_id": "02003013",
  "title": "凤凰台",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "孙策",
      "hangdang": "武生"
    },
    {
      "name": "大乔",
      "hangdang": "旦"
    }
  ],
  "plot": "孙策自父丧之后，退居江南。后被刘繇所逼，带领旧将程普，投奔袁术。袁术因与孙坚交谊素好，又见孙策\n少年英俊，为挫其傲气，并未重用。孙策乃用朱治计，将孙坚留下传国玉玺，送予袁术为质，借兵数千，渡\n江救母。路经凤凰台，系乔公之女大乔、小乔姊妹据守。时小乔与其父出外收粮，只大乔在山。孙策向山寨\n借粮，大乔大怒，亲自出马应战。彼此通名后，大战数十合，不相上下。最后大乔用绊马索将孙策擒上山寨。\n并告孙策部下，公子虽被擒住，决不加害。请暂且扎营，静候好音云。",
  "notes": "按此剧本，似尚未完，容再搜觅考证。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四文堂、四大铠、袁术同上。"
        },
        {
          "character": "袁术",
          "type": "引子",
          "text": "四世三公，镇东南，名高望重。"
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "一自虎牢定帝都，风云万里胜三吴。英雄事业英雄做，董卓原来不丈夫。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "某，寿春太守袁术是也。自虎牢关后，退兵此地，蓄精养锐，欲取霸业。正是："
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "人事盖棺方论定，莫把英雄说败成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱治、吕范同上。"
        },
        {
          "character": "朱治",
          "type": "念",
          "text": "孙策今来干父蛊，"
        },
        {
          "character": "吕范",
          "type": "念",
          "text": "终军不独请长缨。"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "佐吏（朱治）（吕范）参见。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "请二位少礼。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "今有长沙太守孙坚之子，名曰孙策，带领旧将程普等前来相投，辕门候见。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "哦，孙坚之子孙策前来相投？"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "那孙策有多大年纪了？"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "不过十馀岁。却是豪气过人。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "如此传他进见。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "是。 有请孙公子。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策上。"
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "气吐虹霓三万丈，胸怀忠孝五尺身。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "太守在上，小侄孙策参见。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "孙郎少礼。何处而来？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "小侄自父丧之后，退居江南，在丹阳太守母舅吴景处安住。为因兵微将寡，被 扬州刺史刘繇所逼。小侄无所倚望，带领旧将程普等特投麾下，以效驱策。未 知明公肯收留否。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "观尔形像魁武，英气泼泼，将来必有大用。既来投我，且拜尔为怀义校尉，帐 下听候调遣。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "谢明公。 咳！"
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "早知贤豪皆虚誉，何必英雄奔矮檐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策下。"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "明公今看此子如何？"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "此乃少年英雄。若老夫有子如孙策，死复何恨。"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "吓！明公既以英雄许之，如何不甚为礼？"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "我与孙坚乃是同辈，故踞傲待之，以灭其少年豪气。且待日后，自当重用。"
        },
        {
          "character": "朱治、吕范",
          "type": "同白",
          "text": "原来如此。请明公退帐。"
        },
        {
          "character": "袁术",
          "type": "念",
          "text": "曾闻洗足骄英布，"
        },
        {
          "character": "朱治、吕范",
          "type": "同念",
          "text": "未可婴儿待项王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "孙策",
          "type": "内唱",
          "text": "听画角韵悠扬夜声静悄，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策箭衣带剑上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "又只见初生月斜挂树梢。 可叹我怀宝剑失了计较， 投袁术他却似泥塑木雕。"
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "欲卧怕多愁，夜看山衔斗。搔首问青天，心事可知否？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "咳，天哪天！我孙策好错也！因甚误投此地，以致袁术待我如同小儿。想我父 亲在日，何等英雄？生我不才如此沦落。追思往事，好不伤心人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "天地间古今来令人难料， 也不知埋没了多少英豪。 周室衰五霸强七雄扰扰， 风云起怎不教追思汉高？ 三尺剑过芒砀灭秦除暴， 鸿门宴险中了范增笼牢。 好一个张子房烧绝栈道， 萧相国荐韩信平步青霄。 九里山逼霸王一身荣耀， 方显得男儿汉盖世功劳。 到如今这三杰何处去了？ 空留下英雄恨泪湿征袍。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "且住！昔日董卓烧毁洛阳之时，我父曾于建章殿月下，为国挥泪。我今悮投袁 术，亦在月下为家伤情。流泪虽一般，心惨各别。正是："
        },
        {
          "character": "孙策",
          "type": "念",
          "text": "我有一片心，诉与天边月。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "苍天吓吓吓！月之感人如此之甚也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策哭。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "对明月忆往事神情飘渺， 想亡亲创功业胆落魂消。 扶不起大厦倾将星落早， 遗留我无用才不能续貂。 哭不尽功名事——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "羞愧年少， 哭不尽诸侯们胡行乱扰， 空悬着三尺剑两行泪掉， 孙伯符做不得玉关班超。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱治上。"
        },
        {
          "character": "朱治",
          "type": "唱",
          "text": "年少郎自痛哭真正可笑， 莫不是在月下怀想风骚？"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "吓吓伯符，何故对月痛哭？尊翁在日也曾用我朱治之谋，你今有甚不快之事， 何不向我决之。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "吓先生！请坐。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "请问公子何故如此？请道其详。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "咳先生！策所哭者，恨不能继先父之志耳。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "哭吾父破黄巾威名浩浩，"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "哭孙策失祖业水落花飘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策哭。"
        },
        {
          "character": "朱治",
          "type": "白",
          "text": "呀！孙郎真乃英雄，令人可敬。何不告求袁术借兵数千，前往江东假名保救吴 景，就便暗图大业。何必在此困于人下？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "吓，感承先生指教，开我愚蒙也！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "深感谢金石言承蒙指教， 借雄兵往江南起凤腾蛟。"
        },
        {
          "character": "朱治",
          "type": "唱",
          "text": "照此行方能够鳌鱼脱钓， 到长江兴风云何等道遥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起五更鼓〗。吕范上。"
        },
        {
          "character": "吕范",
          "type": "唱",
          "text": "他二人意欲往南山变豹， 我何难驸骥尾同上云霄。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "哈哈哈！二公之言吾早已听见了！"
        },
        {
          "character": "朱治、孙策",
          "type": "同白",
          "text": "原来吕范先生。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "吾手下现有精壮百人，愿助伯符一臂之力。但恐袁术不肯借兵，如何是好？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "吾先父留下传国玉玺，就此送与袁术为质，必然应允。"
        },
        {
          "character": "吕范",
          "type": "白",
          "text": "着吓！公子将无用之物，换有用之兵。袁术若得了此宝必能见允，有此相质必 肯发兵。天已明了，可同往相求便了。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "有劳二公。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "得二公是天赐机缘合巧， 谅必能成大事列土分茅。"
        },
        {
          "character": "朱治",
          "type": "唱",
          "text": "辅公子我二人义同管鲍，"
        },
        {
          "character": "吕范",
          "type": "唱",
          "text": "愿求个功业事凌烟阁标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策、朱治、吕范同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、袁术同上。"
        },
        {
          "character": "袁术",
          "type": "唱",
          "text": "自昨日退帐后仔细思想， 在虎牢忌孙坚转瞬时光。 不意他有此子十分异相， 只怕是灭秦的西楚霸王。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "我想孙坚当日何等英雄，不料被荆州刘表射死。今其子孙策虽然年幼，倒是气 慨可爱。既来投我，必当拢络待之。"
        },
        {
          "character": "袁术",
          "type": "唱",
          "text": "千里驹当必要加意蓄养， 谨防他化龙去霖雨沧桑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策、朱治、吕范同上。"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "求借兵占江东假意惆怅，"
        },
        {
          "character": "朱治、吕范",
          "type": "同唱",
          "text": "附合他创功名龙入长江。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "孙策有求明公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策拜哭。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "吓孙郎，为何如此？"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "小侄父仇不能得报。今母舅吴景，又被扬州刺史刘繇所逼。策之老母幼弟，俱 在曲阿地方，必然被害。敢借雄兵数千，渡江救难。特此拜求，俯乞见允。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "话虽如此。但你年幼，如何领得大兵？这却断断不可。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "哎呀明公！自古有志者事竟成，明公不信，策有先父遗下玉玺一封，权为质当。 恳乞收存。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "吓哈哈哈！果然汉家传国玉玺。孙郎非吾要你玉玺，不过权留在此。请起讲话。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "吾今借与你精兵三千，良马五百匹，渡江平定之后，可速回来。你职位卑微， 难掌大权。我拜你为折冲校尉，殄寇将军。就同朱治、吕范一同前去勿误。"
        },
        {
          "character": "孙策",
          "type": "白",
          "text": "谢明公！"
        },
        {
          "character": "孙策",
          "type": "唱",
          "text": "拜谢了明公恩提兵调将， 权在手还得要男儿自强。 有劳了二先生一路同往，"
        },
        {
          "character": "朱治、吕范",
          "type": "同唱",
          "text": "笑袁术他不及年少孙郎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙策、朱治、吕范同下。"
        },
        {
          "character": "袁术",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "袁术",
          "type": "唱",
          "text": "好容易传国玺归于吾掌， 承汉家锦社稷事有可商。"
        },
        {
          "character": "袁术",
          "type": "白",
          "text": "某久思此玉玺，不料今日到了吾手。称帝之兆，有几分稳妥了。"
        },
        {
          "character": "袁术",
          "type": "唱",
          "text": "我且去暗自里整顿粮饷， 趁机会学王莽这又何妨？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "袁术笑下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程普、黄盖、韩当、周泰同上。"
        },
        {
          "character": "程普",
          "type": "念",
          "text": "一剑空横几度秋，"
        },
        {
          "character": "黄盖",
          "type": "念",
          "text": "少年义气许相投。"
        },
        {
          "character": "韩当",
          "type": "念",
          "text": "英雄漫说开疆土，"
        },
        {
          "character": "周泰",
          "type": "念",
          "text": "智在江南八十州。"
        },
        {
          "character": "程普、黄盖、韩当、周泰",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "程普",
          "type": "白",
          "text": "程普。"
        },
        {
          "character": "黄盖",
          "type": "白",
          "text": "黄盖。"
        },
        {
          "character": "韩当",
          "type": "白",
          "text": "韩当。"
        },
        {
          "character": "周泰",
          "type": "白",
          "text": "周泰。"
        },
        {
          "character": "程普",
          "type": "白",
          "text": "请了！我等前随孙坚太守为将，太守被荆州刘表射死。今公子孙策，借得袁术 兵马，前往江南，暗图功业。你我须当同往。"
