{
  "script_id": "02008060",
  "title": "双沙河",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "杨仙童",
      "hangdang": "小生"
    },
    {
      "name": "高能",
      "hangdang": "小生"
    },
    {
      "name": "卫小申",
      "hangdang": "丑"
    },
    {
      "name": "毗卢大仙",
      "hangdang": "外"
    },
    {
      "name": "玉芙蓉",
      "hangdang": "正旦"
    }
  ],
  "plot": "宋杨家将玉芙蓉征西，路过花马天齐庙，产生一子，落地即死。经毗卢大仙救活，带往山上，取名仙童，传\n授兵法。后玉芙蓉又与番邦交战，被困于双沙河。毗卢大仙乃令杨仙童下山急救，母子相会。行至途中，适\n与前往救援其母之高能与卫小申相会。言谈之后，得知系表亲兄弟，遂一同至玉芙蓉处报到听命。玉芙蓉乃\n令卫小申为先锋，杨仙童及高能在后接应。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "谒帝神将、护法同上。"
        },
        {
          "character": "护法",
          "type": "引子",
          "text": "峰斧开山，丁甲第一班。"
        },
        {
          "character": "护法",
          "type": "白",
          "text": "俺乃毗卢大仙麾下护法神是也。今当甲辰日大仙陞坐之期，只得在此伺候。"
        },
        {
          "character": "谒帝神将、护法",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。四童子引毗卢大仙同上。"
        },
        {
          "character": "毗卢大仙",
          "type": "唱",
          "text": "俺今日驾祥云跨鹤邀游， 满山顶生光华瑞云锦绣。 你看那仙禽鸟凤凰鸣啾， 这仙根有谁人参透机谋？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毗卢大仙上高台，坐。"
        },
        {
          "character": "毗卢大仙",
          "type": "念",
          "text": "天上七星七宝台，仙花仙果满山栽。清风乍起祥云现，一派仙音瑞鸟来。"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "吾乃毗卢大仙是也。只因当年杨家玉芙蓉征西，路过花马天齐庙，产生一子， 落地而亡。是我救上山来，取名仙童，传授兵法，武艺精通。今玉芙蓉被困番 邦，危难之极，不免命仙童下山到双沙河，使他母子相认，日后辅保宋室。 护法神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "护法应。"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "唤杨仙童。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "护法应。"
        },
        {
          "character": "护法",
          "type": "白",
          "text": "杨仙童哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童上。"
        },
        {
          "character": "杨仙童",
          "type": "念",
          "text": "山中修法术，不愿染红尘。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "弟子参见。"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "谢坐。师父唤弟子，有何法旨？"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "你在山上习练兵法已成，你仙缘已满。现今你母被番邦，围困双沙河，使你救 援，母子相逢，日后辅保宋室江山。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "弟子蒙师父慈悲，一心修炼，今又染红尘，岂不半途而废？"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "此乃天数，不必推辞。听为师吩咐。"
        },
        {
          "character": "毗卢大仙",
          "type": "唱",
          "text": "我今日在洞中把话来云， 我命你到沙河救援你娘亲。 我赐你防身宝临阵使用， 中国京剧戏考 《双沙河》【头本】 2 随带着在身旁须要小心。 倘若是在阵前不能取胜， 全凭着此宝物定下输赢。"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "叩谢了我师父养育恩情， 此一去又不知何日相逢？"
        },
        {
          "character": "毗卢大仙",
          "type": "唱",
          "text": "仙缘本无儿的分， 你又何必苦修行？ 此去把番邦来扫尽， 好保宋室定乾坤。"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "杨仙童，此番下山，有花就采。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "护法神。"
        },
        {
          "character": "谒帝神将、护法",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "毗卢大仙",
          "type": "白",
          "text": "护送仙童下山。"
        },
        {
          "character": "谒帝神将、护法",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同唱〖清江引〗，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高能上。"
        },
        {
          "character": "高能",
          "type": "引子",
          "text": "少年英雄未出头，不识烽烟何日休？"
        },
        {
          "character": "高能",
          "type": "念",
          "text": "凛凛威风四海闻，曾随祖父杀贼人。仙传秘授黑风帕，保定宋室锦乾坤。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "俺，高能。祖父高旺，在宋王驾下为臣。俺只因奸臣挡道，退居林下。前日杨 家姑母有信到来，被困番邦，围在沙河，内无粮草，外无救兵，着俺弟兄前去 解围。俺也曾命人约会表兄卫小申，在青莲洞相会。 来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高院子上。"
        },
        {
          "character": "高院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "卫爷可曾请了？"
        },
        {
          "character": "高院子",
          "type": "白",
          "text": "早已请过了。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "几时起程？"
        },
        {
          "character": "高院子",
          "type": "白",
          "text": "即日起程。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "如此准备器械干粮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高院子应，下。"
        },
        {
          "character": "高能",
          "type": "念",
          "text": "但愿蝼蚁全扫尽，才得成功定太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高能下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "卫小申上。"
        },
        {
          "character": "卫小申",
          "type": "念",
          "text": "适才离了六龙潭，不要拔剑斩蛟龙。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "俺，卫小申。在宋王驾前为臣。因俺面目丑陋，贬在家下，永不敍用。哪知我 再没这样逍遥自在。前日忽然我姑妈有书到来，命我去往沙河救援。高弟约会 我中途青莲洞相会。 来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫院子上。"
        },
        {
          "character": "卫院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "行囊可曾齐备了？"
        },
        {
          "character": "卫院子",
          "type": "白",
          "text": "齐备多时。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "即刻起程，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申、卫院子同下。"
        },
        {
          "character": "卫小申",
          "type": "stage",
          "text": "中国京剧戏考 《双沙河》【头本】 3"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童上。"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "辞别了师父下山林， 去到沙河认母亲。 行过千山并万岭， 且自消停落下云。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "俺，杨仙童。奉师父之命，搭救母亲回朝。天色尚早，驾云前往。"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "母子今日团圆庆， 才信仙家道法精。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高能上。"
        },
        {
          "character": "高能",
          "type": "唱",
          "text": "行过一程又一程， 心忙似箭奔宋营。 从空使起黑风帕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申内叫。"
        },
        {
          "character": "高能",
          "type": "唱",
          "text": "又听有人叫一声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申上。"
        },
        {
          "character": "卫小申",
          "type": "唱",
          "text": "几年不曾与贼战， 盔不明来甲不鲜。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "表兄来了。你难道不知救兵如救火，如何误得时刻？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "你看涧下有水，你我吃些再走。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "你去吃些，我在此等你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申下。杨仙童上。"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "大路之上有黑风， 按落云头看分明。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "面前有黑风，俺不免驾起五色祥云穿风而过。"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "风内必是妖和怪， 先斩一剑命归阴。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "高能",
          "type": "唱",
          "text": "高叫道童休动手， 饶你不死留下名。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "你这道童，好生无礼，穿风就过，使剑就砍，是何理也？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "中途路上使起黑风，想必是妖魔鬼怪。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "原来如此。你就通上名来！"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "你要问俺名姓，你且听了：我母玉芙蓉，当日征西路过花马天齐庙，产生下我， 落地而亡，多蒙毗卢大仙救去，取名仙童，传俺兵法武艺，一十一载。今母 亲围困沙河，师父命我下山搭救。你是何人阻路？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "原来是表弟。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "俺乃高能，与你乃姑表之亲。为因姑母有书到来，命我齐集表兄表弟前往搭救。 不想此地相会，真乃天幸。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "原来是表兄，如此按落云头相敍。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "过场。"
        },
        {
          "character": "杨仙童、高能",
          "type": "同白",
          "text": "（表兄有礼）（表弟免礼）。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童、高能同见礼。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "还有何人同行？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "还有你亲表兄卫小申。 中国京剧戏考 《双沙河》【头本】 4"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "他往哪里去了？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "涧下饮水去了。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "你我且等他些。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申上。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "哪里来的这么一个黑杂宗？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "吓吓吓，骂不得。这就是你表兄，如何骂得？ 你不知道，只因当年姑母征西路过花马天齐庙，产生一子，落地而亡。蒙毗卢 大仙救下，取名仙童，传授兵法武艺，前往沙河母子相会。这才是你嫡嫡亲亲 表兄到了。上前见过。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "那作什么？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "表兄为什么打我？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "你为什么骂我？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "谁的见证？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "高大哥的见证。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "待我问来。 高大哥，卫表兄说我骂了他，你可听见？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "你骂他，我不曾听见。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "站着！你方才骂我小王八旦！"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "高大哥的见证。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "大哥，我骂他没有？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "不用说了。正事要紧。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "我会奇门遁法，六甲灵文，呼风唤雨，撒豆成兵。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "我会使黑风。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "我会变猫变狗。撒谎不是东西，咱们大家试演试演。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "天灵灵，地灵灵，我奉毗卢大仙法，豆兵速降。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鬼兵上。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "勒退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鬼兵下。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "黑风速降。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八风旗同上。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "勒速退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八风旗同下。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "该你变了。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "变！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申下，猫形上。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "好一大猫，待我着一死老鼠与你吃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猫形下，卫小申上。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "变。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申下，狗形上。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "好一只大犬，待我撒泡尿与它。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "狗形下，卫小申上。"
