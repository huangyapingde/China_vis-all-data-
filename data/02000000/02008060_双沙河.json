        {
          "character": "玉芙蓉",
          "type": "白",
          "text": "有人么？"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "相烦通禀：说仙山杨道童求见。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "少待。 启元帅：营门外有仙山道童求见。"
        },
        {
          "character": "玉芙蓉",
          "type": "白",
          "text": "引进来。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "吓。 道童呢？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "着你进去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童应，进。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "元帅在上，道童即见。"
        },
        {
          "character": "玉芙蓉",
          "type": "白",
          "text": "你是何处仙童，到此何干？"
