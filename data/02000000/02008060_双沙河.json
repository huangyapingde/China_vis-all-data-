        {
          "character": null,
          "type": "stage",
          "text": "卫小申下。"
        },
        {
          "character": "高能",
          "type": "唱",
          "text": "先到就要印在掌， 各使妙法逞豪强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高能下。"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "一见表兄都前行， 驾起祥云奔番营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童下。卫小申上，高能随上，推倒高能，高能下，卫小申随下。杨仙童上。"
        },
        {
          "character": "杨仙童",
          "type": "stage",
          "text": "中国京剧戏考 《双沙河》【头本】 5"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "我母那里必挂望， 赶至大营见萱堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童下。"
        }
