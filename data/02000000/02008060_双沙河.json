    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "兵卒引玉芙蓉同上。"
        },
        {
          "character": "玉芙蓉",
          "type": "唱",
          "text": "二国不合动刀兵， 领了圣命来战争。 前与胡兵打一阵， 擒我上将十馀名。 也曾命人去取救， 不知何日来救兵？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童上。"
        },
        {
          "character": "玉芙蓉",
          "type": "唱",
          "text": "按落云头来看真， 旌旗展展是大营。"
