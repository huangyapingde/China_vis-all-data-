{
  "script_id": "02001026",
  "title": "米注山",
  "alias": [
    "付剑印·摘印"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "斗越椒",
      "hangdang": "净"
    },
    {
      "name": "公子茷",
      "hangdang": "武生"
    },
    {
      "name": "斗贲凰",
      "hangdang": "净"
    }
  ],
  "plot": "楚庄王为报父仇，令斗越椒为帅伐郑，并以其弟公子茷为副。斗越椒以公子茷性情高傲，恐有不便。楚庄王\n乃赐斗越椒兵符剑印，不遵令者，军法从事。惟斗、茷向有宿怨，公子茷又想早立功勋，未经禀报，私自先\n行发兵。致被困于米注山，自缢身死。楚庄王闻信后，既恸胞弟之身死，又怪斗氏之不救，大加叱责。斗越\n椒不服，致君臣争吵。无法收场。最后斗越椒始听蒍贾之劝，将剑印解下，自请处分，楚庄王亦不咎既往，\n令其退朝，不令再预问国事。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蒍贾、苏从、潘尩、乐伯同上。"
        },
        {
          "character": "蒍贾、苏从、潘尩、乐伯",
          "type": "同点绛唇",
          "text": "忠心朗朗，扶保朝纲，皇恩荡，圣寿无疆，永把安康享。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "老夫，上大夫蒍贾。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "老夫，下大夫苏从。"
        },
        {
          "character": "潘尩",
          "type": "白",
          "text": "下官，右将军潘尩。"
        },
        {
          "character": "乐伯",
          "type": "白",
          "text": "下官，谏议乐伯。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "列公请了！"
        },
        {
          "character": "苏从、潘尩、乐伯",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "大王今日登殿，我等分班伺侯。"
        },
        {
          "character": "苏从、潘尩、乐伯",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍贾、苏从、潘尩、乐伯归两边站。〖小吹打〗。四执殿、四小太监同上，同站门。楚庄王上。"
        },
        {
          "character": "楚庄王",
          "type": "引子",
          "text": "尧舜有道称圣君，河清海宴庆升平。"
        },
        {
          "character": "蒍贾、苏从、潘尩、乐伯",
          "type": "同白",
          "text": "臣等见驾，愿大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "蒍贾、苏从、潘尩、乐伯",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "三年号令从未伸，每日宫中饮杯巡。凡鸟长翅虽不展，飞则冲天也惊人。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤，楚庄王熊羽。承祖先宏图，得膺大宝。只因先帝穆王，征伐郑邦，中途得 中国京剧戏考 《米注山》【头、二本】 2 病而回，不幸身故。因此众卿扶孤登基。三年以来，号令未伸。日事田猎，夜 夜笙歌。被大夫苏从谏奏。乃绝钟鼓之欢，重整朝纲大典。 众卿，"
        },
        {
          "character": "蒍贾、苏从、潘尩、乐伯",
          "type": "同白",
          "text": "臣。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "寡人意欲兴兵伐郑，报先帝之仇。众卿意下如何？"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "吾主欲报先帝之仇，此乃天伦之义，并非妄动刀兵，正当兴师。何为不可？"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "启奏大王：此番兴兵，非比寻常。况我军三载未动，兵将懈驰，须得智勇之将， 当此重任。操练士卒，训演战法，方可兴师。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "苏大夫言之极是。哪员大将可以当此重任？"
        },
        {
          "character": "乐伯",
          "type": "白",
          "text": "启奏大王：今有斗司马智勇兼全，熟知郑国山川险易，堪当此任。望祈圣裁。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿家之言，正合孤意。即刻传旨，宣斗越椒上殿。"
        },
        {
          "character": "乐伯",
          "type": "白",
          "text": "领旨。 大王有旨：宣大司马斗越椒上殿。"
        },
        {
          "character": "斗越椒",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒上。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "世代缙缨蒙君宠，权倾满朝第一臣。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "臣，大司马斗越椒见驾。大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "赐座"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "谢座。宣臣上殿，有何国事议论？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "朕为先帝之仇，至今未报。孤欲命将出师征讨郑国，非卿不能当此重任。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "臣斗氏三世附楚，重蒙君恩。未尝落后。既蒙大王初委重任，敢不剖心竭力， 以报国恩。但不知命哪家臣子以为副帅？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤二弟公子茷，英勇驰名，可为副帅。与卿同征郑国。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "二千岁英雄盖世，可以去得。只是二千岁情性高傲，军法无私，恐有不便。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "这有何妨。寡人赐卿兵符剑印，一应大小将官，不遵号令者，依军法施行。即 日兴师，下殿去吧。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "为雪先主恨，协力把功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒下。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "启大王：斗越椒状如熊虎声似狼。此人心怀叵测，不当以兵符相委。吾主参详。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤王以仁义待人，岂有反复之意？孤命二弟为副帅，以为监察。越椒虽然奸诈， 料无妨碍。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "大王可宣二千岁上殿，面论一番。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "如此，宣公子茷上殿。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "领旨。 大王有旨：宣二千岁上殿。"
        },
        {
          "character": "公子茷",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷上。"
        },
        {
          "character": "公子茷",
          "type": "念",
          "text": "纬武惊天雄心壮，弓马娴熟膂力强。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "臣公子茷参见兄王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "御弟平身。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "千千岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤命斗越椒统兵伐郑，报先帝之仇。命二弟为副帅先行，凡事共同商议。毋得 逞勇恃强性，有违军令。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "自古父母之仇不共戴天。小弟久已有心伐郑，既然兄王降旨，拚死何恨。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "愿御弟马到成功。回府披挂去吧。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "公子茷",
          "type": "念",
          "text": "为雪父仇恨，要把郑国平。 中国京剧戏考 《米注山》【头、二本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子茷下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众卿各按职份，治理国政。退班。"
        },
        {
          "character": "蒍贾、苏从、潘尩、乐伯",
          "type": "同白",
          "text": "请驾回宫。"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "朝暮修国政，"
        },
        {
          "character": "蒍贾、苏从、潘尩、乐伯",
          "type": "同念",
          "text": "从此楚邦兴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍贾、苏从、潘尩、乐伯分班下，楚庄王下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰上。"
        },
        {
          "character": "斗贲凰",
          "type": "念",
          "text": "父子将相才文武，威名四海镇帝都。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "俺，斗贲凰。今日大王宣俺爹爹上殿，不知有何军国大事。且待吾父回来便知 端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、斗越椒同上。〖水底鱼〗。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "谢座。大王宣诏爹爹，有何国事议论？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "只因大王要报先帝之仇，命为父领兵伐郑，公子茷为副帅。我想此人武艺高强， 必占头功。你我父子此行，空费一场心血也。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "爹爹就忘怀了在息地之时夺功比胜，羞辱我父子么？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "着哇！我儿提醒为父之恨，今日兴兵，看他如何行事，再做道理。我儿速速披 挂，教场伺侯，为父即刻兴兵。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "恨小非君子，"
        },
        {
          "character": "斗贲凰",
          "type": "念",
          "text": "无毒不丈夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒、斗贲凰同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "公子茷",
          "type": "内西皮导板",
          "text": "兄王金殿传将令，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手、旗夫、公子茷同上。"
        },
        {
          "character": "公子茷",
          "type": "西皮摇板",
          "text": "命我领兵伐郑城。 越椒挂了元帅印， 皇亲反倒作先行。"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "俺，公子茷。奉了兄王将令，带领人马征讨郑国，与先父报仇。斗越椒为帅， 俺为副军，共同带兵前往。想我与越椒向有仇恨，惟恐他奸计多端，为此不与 他商议，独攻郑界。倘若一战成功，叫他束手而回。 众将官，催动人马。"
        },
        {
          "character": "公子茷",
          "type": "西皮摇板",
          "text": "昔日郑城夺权柄， 奸贼不敢胡乱行。 我为父仇报前恨， 赫赫威名在郑城。 此番一战大功定， 他父子羞愧怎收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《米注山》【头、二本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰上，起霸。"
        },
        {
          "character": "斗贲凰",
          "type": "念",
          "text": "父子英名遍宇宙，攻城斩将神鬼愁。跨下乌骓如虎吼，手持金枪似龙游。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "俺，斗贲凰。爹爹发兵，在此伺侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、旗夫、斗越椒披蟒上。"
        },
        {
          "character": "斗越椒",
          "type": "引子",
          "text": "心怀篡逆久有谋，机会不遇使人愁。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "啊？怎么不见副军前来商议起兵？"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "孩儿打听得他早已前行兵动半日矣。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "吓！这厮又与我父子做对。就命我儿打听公子茷消息，回报我知。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰下。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "众将官，人马缓缓而行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手同上。〖急急风〗。公子坚开虎脸虎头盔无须披蟒上。"
        },
        {
          "character": "公子坚",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，军威浩，地动山摇，要把楚庄扫。"
        },
        {
          "character": "公子坚",
          "type": "念",
          "text": "豹头环眼似铜铃，身驱丈余赛天神。郑邦也是周朝后，不服楚国自称尊。"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "某，郑国大将公子坚是也。今有楚庄王无故命斗越椒为帅、公子茷为副军，兵 伐我国。奉了大王钧旨，带领铁骑三千与楚兵对敌。 众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂、四下手、旗夫、公子茷同上。会阵。"
        },
        {
          "character": "公子坚",
          "type": "白",
          "text": "呔！来者敢是熊茷！"
        },
        {
          "character": "公子茷",
          "type": "白",
          "text": "王爷正是。来将通名！"
        },
