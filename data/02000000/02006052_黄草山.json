{
  "script_id": "02006052",
  "title": "黄草山",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "薛刚",
      "hangdang": "净"
    }
  ],
  "plot": "薛刚被薛义押入囚车，解往长安，欲讨封赏。行至黄草山，占据山寨之吴奇、马赞将薛义拿获。解救薛刚上\n山，结为兄弟，并将薛义杀死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四将官扎靠同上。〖牌子〗。"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "众位将军请了。你我奉大老爷将令，押送叛逆薛刚，去到长安，你我去至辕门 伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四将官同下。四短刀手、四长枪手、中军引薛义同上。"
        },
        {
          "character": "薛义",
          "type": "引子",
          "text": "人有善念，天必佑之。"
        },
        {
          "character": "薛义",
          "type": "念",
          "text": "时来运也来，拜将即登台。不是心肠好，怎称栋梁才。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "本镇薛义，拿住薛刚，今解往长安，请旨升赏。 中军，传众将进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将官自两边分上。"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "元帅在上，末将打躬。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "站立两旁。众将官，今解薛刚进朝，一路之上，必要小心押送。须要刀枪锐利， 以防打劫之人，将囚车抬往前行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二将官抬囚车、薛刚同下。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "催动人马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖发点〗。四喽兵、四头目、四马甲、吴奇、马赞同上。〖点绛唇〗。"
        },
        {
          "character": "吴奇",
          "type": "念",
          "text": "赤发冲冠声如雷，豹头环眼放光辉。"
        },
        {
          "character": "马赞",
          "type": "念",
          "text": "拔山举鼎无人敌，万马军中任所为。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "吴奇。"
        },
        {
          "character": "马赞",
          "type": "白",
          "text": "马赞。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "贤弟，你我弟兄，在这黄草山上，每日打劫经商，无忧无愁，好不逍遥自在。"
        },
        {
          "character": "马赞",
          "type": "白",
          "text": "这倒果然。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "日前有京兆三原兴唐魏国公李靖大仙对我二人言道：今日乃英雄集义之期，怎 么还未见动静？"
        },
        {
          "character": "马赞",
          "type": "白",
          "text": "且听喽啰报来。"
        },
        {
          "character": "报子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启大王：山下来了一支人马，押着囚车，有多少将官把守。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同笑",
          "text": "哈哈！"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "李大师乃活神仙也，果然不误时刻。你我就此下山，断住他的去路。"
        },
        {
          "character": "马赞",
          "type": "白",
          "text": "兄长传令。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "众喽啰杀下山去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。吴奇、马赞、四喽兵、四头目、四马甲同走圆场。"
        },
        {
          "character": "四喽兵、四头目、四马甲",
          "type": "同白",
          "text": "来此三岔路口。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "埋伏松林。"
        },
        {
          "character": "四喽兵、四头目、四马甲",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四将官、囚车、薛刚引薛义同上，囚车在前。〖一条龙〗。〖内喊声〗。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "哪里人马呐喊？"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "强人挡道。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "囚车打入松林。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二将官抬囚车、薛刚自上场门同下。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴奇、马赞、四喽兵、四头目、四马甲自上场门同上，撞阵。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "呔，来的官兵，留下三千黄金，以作买路钱，放你过去。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "呔，大胆的响马，你要买路钱，也要打听明白，或是客商孤单，便可行劫。我 押解钦犯，上长安去的，哪有银钱与你？"
        },
        {
          "character": "马赞",
          "type": "白",
          "text": "呔，俺知道你是泗水关总兵，尽有金银去送奸臣。怎说没有？"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "我是献功讨赏的，哪有什么金银？"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "你既没有银钱，将钦犯留下作为赏头，转去拿些金银来取。"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "大胆强盗，吃你侯爷一枪，众将退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将官自两边分下，薛义跑下。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "哪里走！ （吴奇、马赞同追下。一对二杀打，同下。薛义上，前走，吴奇、马赞同追上。薛义倒地。四喽兵、四头目、 四马甲自两边分上，同绑薛义。）"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "众喽啰，先将这贼押回山寨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四喽兵押薛义同下。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "快将囚车内薛爵主请出来。"
        },
        {
          "character": "四头目、四马甲",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四头目、四马甲同下，四头目、四马甲随薛刚同上。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "哎呀，多谢二位英雄搭救。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "搭救来迟，爵主恕罪。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "请爵主同上山寨。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "可曾拿住薛义？"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "已押上山去了。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "有劳二位。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "喽啰回山。"
        },
        {
          "character": "四头目、四马甲",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同走圆场。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "爵主请坐。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "请问二位高姓尊名？"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "俺吴奇。"
        },
        {
          "character": "马赞",
          "type": "白",
          "text": "马赞。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "怎么知道薛刚至此？"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "前有李靖大仙言道，有泗水关总兵薛义负义忘恩，叫我等在此相救爵主，权避 此山，后整唐皇天下。许我二人蟒袍玉带。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "哎呀，感谢大仙恩德，又蒙二位搭救，俺薛刚何日答报？"
        },
        {
          "character": "吴奇、马赞",
          "type": "白",
          "text": "我弟兄要与爵主结为异姓同胞，不知爵主意下如何？"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "承蒙搭救，又结昆仑，俺怎好高攀。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "岂敢。 来，吩咐杀猪宰羊，准备香案伺候。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "承蒙不弃，只是我要往长安祭扫丘坟，要相烦同往。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "我二人愿随三哥去祭坟台，回山齐集人马，杀上长安，与一门报仇。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "多谢贤弟。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "请三哥先吃一杯接风酒，然后再拜金兰。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "多谢贤弟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。三桌齐坐。"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "三哥请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "请问三哥，将薛义怎么发落？"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "吩咐将他绑上来。"
        },
        {
          "character": "四头目、四马甲",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四头目、四马甲绑薛义同上。"
        },
        {
          "character": "四头目、四马甲",
          "type": "同白",
          "text": "薛义当面！"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "哇呀，贼子啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛刚打薛义。"
        },
        {
          "character": "薛刚",
          "type": "唱",
          "text": "负义昧心将我害， 尔是人面兽投胎。 得了富贵忘恩债，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛刚打薛义。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "乌纱紫袍是哪里来？"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "你不记得在长安卖与张天佑为奴，只因那奸贼看上你妻子花容，要她为妾。你 妻子守节不从，将你送到法堂，五刑拷打，追比身价银两。你妻子杨氏街坊求 乞。我一股仗义，与你完了身价，救你出监，认你同宗弟兄，又与你干此总兵。 不思知恩报恩，反诓我进府，以酒迷我，拿住解京，贪图万户侯。不料天理 昭昭，我命不该死，有人搭救。俺薛刚虽然烈性，待你却是恩厚，为何反要害 我？俺是哪些待你不好，你讲！"
        },
        {
          "character": "薛义",
          "type": "白",
          "text": "我讲什么呢？这算我的错，只好请副香纸，叩一个头就是。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "哎呀，贼子啊！"
        },
        {
          "character": "薛刚",
          "type": "唱",
          "text": "人心不足蛇心坏， 螳螂捕蝉反受灾。 上苍不绝薛后代，"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "哎呀贼子啊！"
        },
        {
          "character": "薛刚",
          "type": "唱",
          "text": "善恶昭彰救星来。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "三哥，这等无义之人，还有什么理与他讲？将这贼碎尸万段就是了。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "言之有理. 喽啰将薛义剐了！"
        },
        {
          "character": "四头目、四马甲",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛义脱衣。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "看刀来！"
        },
        {
          "character": "薛刚",
          "type": "唱",
          "text": "你我冤仇如沧海， 刀下将你碎尸骸。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "狼心贼子，待俺来看你心肝五脏，是怎么生长？"
        },
        {
          "character": "薛刚",
          "type": "唱",
          "text": "从前报我如犬马， 如今设计将某拿。 英雄虎胆比天大，"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "吴奇、马赞",
          "type": "同白",
          "text": "好好拿来下酒。"
        },
        {
          "character": "薛刚",
          "type": "唱",
          "text": "抛入松林赏乌鸦。 粉身碎骨刀尖下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛刚乱砍。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "薛刚",
          "type": "唱",
          "text": "一还一报果无差。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "来来，将这贼尸首抛入山前，赏了猪羊犬马，搭了下去。"
        },
        {
          "character": "四头目、四马甲",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四头目、四马甲抬薛义同下。"
        },
        {
          "character": "吴奇",
          "type": "白",
          "text": "大哥冤仇已报，后寨准备香案，你我弟兄拜过，打点好上长安。"
        },
        {
          "character": "薛刚",
          "type": "白",
          "text": "贤弟请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。薛刚、吴奇、马赞同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}