          "text": "我的太爷。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哪里还有功夫吓？"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "腿上有功夫。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好，要站稳了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松打陆怀。"
        },
        {
          "character": "老西",
          "type": "白",
          "text": "哎呀，我的老西的老老。"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "你要打，打蒋忠去罢。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好，他今在何处？"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "在松林内演拳。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "闪开了。"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "好丧气。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陆怀下。"
        },
        {
          "character": "蛮子",
          "type": "白",
          "text": "哎呀，老兄，咱们一边养伤去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蛮子、老西同下。"
        }
      ]
