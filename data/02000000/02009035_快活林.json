        {
          "character": "陆怀",
          "type": "白",
          "text": "我们这没有妓者。"
        },
        {
          "character": "女主人",
          "type": "白",
          "text": "陆怀。那一大汉，他说什么？"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "他说没带钱记上。"
        },
        {
          "character": "女主人",
          "type": "白",
          "text": "那就是了，与他记上，打发他走罢。"
