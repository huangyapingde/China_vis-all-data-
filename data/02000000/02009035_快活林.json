        {
          "character": "女主人",
          "type": "白",
          "text": "他又说什么？"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "他说叫您哪陪酒。"
        },
        {
          "character": "女主人",
          "type": "白",
          "text": "与我打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松与女主人起打，打倒女主人。"
        },
        {
          "character": "蛮子",
          "type": "白",
          "text": "哎呀，干爸爸，你不要生气。"
        },
        {
          "character": "老西",
