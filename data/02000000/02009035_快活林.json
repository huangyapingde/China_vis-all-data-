        {
          "character": "陆怀",
          "type": "白",
          "text": "就上在你的帐的。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "陆怀，看酒来。"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "吓，二太爷，你那酒醉，改日再喝罢。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "一定要喝。"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "改日再喝。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "俺要喝。"
        },
        {
          "character": "陆怀",
          "type": "白",
