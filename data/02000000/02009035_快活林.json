        {
          "character": "武松",
          "type": "白",
          "text": "陆怀，他是何人？"
        },
        {
          "character": "陆怀",
          "type": "白",
          "text": "他乃是我们大奶奶。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "叫他前来，陪你二太爷吃酒。"
