        {
          "character": "徐盛",
          "type": "白",
          "text": "你我跟随查办宁夏，必须留神隄防刺客。听里面击鼓，大人升堂，两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四刽子手、邱成、胜奎、武显、武元、武方同上，同站门。彭朋上。"
        },
        {
          "character": "彭朋",
          "type": "引子",
          "text": "查办宁夏，秉忠心，扶保皇家。"
        },
        {
          "character": "徐盛、石柱、武国兴、纪逢春、胜官保、刘得太、高通海、邱成、胜奎、武显、武元、武方",
          "type": "同白",
          "text": "参见大人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭朋归坐。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "众位英雄免礼。"
        },
        {
          "character": "徐盛、石柱、武国兴、纪逢春、胜官保、刘得太、高通海、邱成、胜奎、武显、武元、武方",
          "type": "同白",
          "text": "呵，谢大人！"
        },
        {
          "character": "彭朋",
          "type": "念",
          "text": "钦奉圣命出帝京，查办宁夏费辛勤。番王摆下木羊阵，昼夜寻思无计行。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "本院，彭朋。在大清康熙圣主驾下为臣。钦奉圣命，查办宁夏一带等处。只因 飞云、清风、焦家二鬼，乃是奉旨要犯，四贼擒拿，总未得手。闻得四贼逃在 贺兰山慕天王那里躲避，这且不言。他贺兰山有二位公主，一名慕秀莲，一名 慕秀玉，俱到本院公馆，戏弄我手下差官，被玉龙擒住。我想既已两国交好， 不可伤害他二公主性命。本院意欲遣人前往贺兰山，与慕天王送信。哪位老英 雄可愿前往？"
        },
        {
          "character": "胜奎",
          "type": "白",
          "text": "老朽情愿往贺兰山送信。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "如此待我修书。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "彭朋写书。〖牌子〗。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "这有一封书信，烦劳老英雄辛苦一程。"
        },
        {
          "character": "胜奎",
          "type": "白",
          "text": "草民当得効劳。"
        },
        {
          "character": "胜奎",
          "type": "唱",
          "text": "辞别大人出公馆， 送信前往贺兰山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胜奎下。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "众位老英雄，我看胜老英雄此去，本院放心不下。烦劳老英雄等暗地保护。"
        },
        {
          "character": "邱成、武显、武元、武方",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": "彭朋",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
