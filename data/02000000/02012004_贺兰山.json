          "type": "白",
          "text": "慕金豹。"
        },
        {
          "character": "慕金龙",
          "type": "白",
          "text": "众位贤弟请了。"
        },
        {
          "character": "慕金凤、慕金麟、慕金豹",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "慕金龙",
          "type": "白",
          "text": "爹爹坐寨，你我两厢伺候。"
        },
        {
          "character": "慕金凤、慕金麟、慕金豹",
          "type": "同白",
          "text": "请！"
