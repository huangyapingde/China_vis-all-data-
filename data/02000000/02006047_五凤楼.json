{
  "script_id": "02006047",
  "title": "五凤楼",
  "alias": [
    "易位"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "武则天",
      "hangdang": "旦"
    },
    {
      "name": "李显",
      "hangdang": "生"
    }
  ],
  "plot": "武则天听奸臣张天佐、张天佑之言，斩薛氏满门，废新君为卢陵王，赶出宫廷，垂帘听政，改为垂拱元年。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引武则天同上。"
        },
        {
          "character": "武则天",
          "type": "唱",
          "text": "孤单凄凉坐深宫， 日落西城带晚风。 从前欢乐嫌夜短， 切莫更长锦帐空。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天佐上。"
        },
        {
          "character": "张天佐",
          "type": "唱",
          "text": "新君柔弱成何用，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天佑上。"
        },
        {
          "character": "张天佑",
          "type": "唱",
          "text": "不斩薛氏我难容。"
        },
        {
          "character": "张天佐、张天佑",
          "type": "同白",
          "text": "臣张（天佐）（天佑）见驾，愿太后千岁！"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "二卿平身。"
        },
        {
          "character": "张天佐、张天佑",
          "type": "同白",
          "text": "千千岁。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "张天佐、张天佑",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "二卿进宫，有何本奏？"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "启太后：新君昏懦，忘先帝之遗恨。惟乞降旨。"
        },
        {
          "character": "张天佑",
          "type": "白",
          "text": "容留叛臣家，日与群小荒淫酒色，不理国政，岂能执掌天下？乞太后以社稷为 重，早定大计，庶天下太平。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "新君有道，本后岂可将他废却？"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "那薛刚身遭不赦之罪，应该将丁山满门，既行诛戮。为何纵容叛逆之臣，岂不 忘先君之恨？"
        },
        {
          "character": "张天佑",
          "type": "白",
          "text": "薛刚逃走，未曾拿获，丁山又在天牢，朝中功臣，与薛家尽是一党，惟恐暗扶 薛刚，杀到长安。不但社稷难保，恐有惊太后龙驾。今日废新君，斩薛氏方得 天下太平，国正民顺。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "今废新君，江山何人执掌？"
        },
        {
          "character": "张天佐、张天佑",
          "type": "同白",
          "text": "太后临朝执政，统领社稷，有何难哉？"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "恐有文武保奏，本后如何降旨？"
        },
        {
          "character": "张天佐、张天佑",
          "type": "同白",
          "text": "只要太后龙心已定，哪怕他文武保奏。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "依卿所奏，本后即废新君，立斩薛氏满门。出宫去罢。"
        },
        {
          "character": "张天佐、张天佑",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "张天佐",
          "type": "念",
          "text": "不怕虎生三只眼，"
        },
        {
          "character": "张天佑",
          "type": "念",
          "text": "只愁人起两样心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天佐、张天佑同下。小太监、二大太监引李显同上。"
        },
        {
          "character": "李显",
          "type": "念",
          "text": "龙心嗟叹思忠勇，寡人常怀薛氏功。 中国京剧戏考 《五凤楼》【四本】 2"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "儿李显见驾，愿母后千岁！"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "皇儿平身。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "儿吓，薛氏满门，可曾诛戮？"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "启奏母后：薛刚虽有不赦之罪，可念忠武王薛仁贵，有许多功劳。就是先君， 哪件不赦薛家？今日特求母后赦却忠良满门，只拿薛刚一人治罪，乞母后降旨。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "吓，那薛刚踢死殿下，惊死你父，此乃不共戴天之仇，与逆叛同罪，理当诛戮 九族，为何反要赦他，这是何恩德？"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "踢死御弟，乃一时酒醉，儿也曾绘影图形拿薛刚问罪。特求国母恩赦薛氏一门， 那忠武王在九泉之下，感恩无尽矣。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "哎，你不诛父遗恨，容留叛逆，懦弱为君，怎掌天下大事？今废你为卢陵王， 贬往湖广房州。若无旨意，不可擅入长安。将御印交出，速行去吧！"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "哎呀，孩儿为君，并无失政，不过求赦忠良之心，为何将儿贬出长安？"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "哎，你无父王之仇，为娘哪有母子之意？ 内侍，快到韦后宫内，请御印前来。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监下。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "你即出长安。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "哎呀，母后吓！"
        },
        {
          "character": "李显",
          "type": "唱",
          "text": "孩儿为君非失政， 为何谪贬出都城？ 今日奉诏泄母恨， 母后吓， 大唐社稷付何人？"
        },
        {
          "character": "武则天",
          "type": "唱",
          "text": "为娘临朝比儿胜， 汉室吕后女为君。 懦弱怎掌天下任， 可知成汤亡百春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、二太监捧印引韦后同上。"
        },
        {
          "character": "韦后",
          "type": "唱",
          "text": "主上为君如尧舜， 为救薛氏一满门。"
        },
        {
          "character": "韦后",
          "type": "白",
          "text": "国母千岁。进宫何事？"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "主上柔弱，夫妻早出长安便罢，若是迟延，提头来见。 内侍，快将他夫妻赶出去。"
        },
        {
          "character": "李显、韦后",
          "type": "同白",
          "text": "哎呀母后吓！"
        },
        {
          "character": "李显",
          "type": "西皮滚板",
          "text": "儿承父业风雨顺，"
        },
        {
          "character": "韦后",
          "type": "西皮滚板",
          "text": "人在尧天舜日中。"
        },
        {
          "character": "李显",
          "type": "西皮滚板",
          "text": "国母废业社稷送，"
        },
        {
          "character": "韦后",
          "type": "白",
          "text": "国母吓！"
        },
        {
          "character": "韦后",
          "type": "西皮滚板",
          "text": "哀告膝下求乞恩。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "哎，无用之辈，怎为天子，再不出宫，提头来见。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "李显",
          "type": "唱",
          "text": "甜言蜜语全无用，"
        },
        {
          "character": "韦后",
          "type": "唱",
          "text": "再三哀告总是空。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "李显",
          "type": "唱",
          "text": "大唐江山无我分，"
        },
        {
          "character": "韦后",
          "type": "唱",
          "text": "眼含珠泪出皇宫。"
        },
        {
          "character": "李显、韦后",
          "type": "同白",
          "text": "哎呀，国母吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李显、韦后同下。"
        },
        {
          "character": "李显、韦后",
          "type": "stage",
          "text": "中国京剧戏考 《五凤楼》【四本】 3"
        },
        {
          "character": "武则天",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "武则天",
          "type": "唱",
          "text": "临朝执掌唐一统， 女王天子独为君。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "内侍，速传旨意：新君已废，本后登基，改元为垂拱元年。朝内大事，付与天 佐、天佑执掌；命武三思统领都城禁军。打扫法场，将薛家满门正法；再命武 承嗣，在丁山中殿上，掘一深坑，以便埋葬叛臣尸首。恐有文武保奏，谏者提 头来见。"
        },
        {
          "character": "二太监",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监同下。"
        },
        {
          "character": "武则天",
          "type": "白",
          "text": "皇儿已废，本后执掌江山，谁敢搭救薛氏满门！"
        },
        {
          "character": "武则天",
          "type": "唱",
          "text": "称制重把山河整， 一朝公卿换新君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武则天下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}