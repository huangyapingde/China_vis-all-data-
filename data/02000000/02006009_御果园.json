          "type": "白",
          "text": "启父王：儿臣要闲游一番。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "何人保驾？"
        },
        {
          "character": "徐茂功",
          "type": "白",
          "text": "臣保驾。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生带马。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "端阳佳节艳阳天， 家家户户笑声喧。"
