        },
        {
          "character": "李世民",
          "type": "白",
          "text": "何人把守？"
        },
        {
          "character": "徐茂功",
          "type": "白",
          "text": "单雄信把守。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "雄信哪里去了？"
        },
        {
          "character": "徐茂功",
          "type": "白",
          "text": "今乃端阳佳节，想必庆节去了。"
        },
