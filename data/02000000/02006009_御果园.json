{
  "script_id": "02006009",
  "title": "御果园",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "王云",
      "hangdang": "副净"
    },
    {
      "name": "李建成",
      "hangdang": "杂"
    },
    {
      "name": "李元吉",
      "hangdang": "丑"
    },
    {
      "name": "李渊",
      "hangdang": "外"
    },
    {
      "name": "徐茂功",
      "hangdang": "末"
    },
    {
      "name": "皮可能",
      "hangdang": "副净"
    }
  ],
  "plot": "唐秦王李世民，欲进兵洛阳，拿王世充。适遇端午佳节，停兵一日，秦王乃与徐茂公入御果园游玩。单雄信\n正在洛阳城上望见之，乃戎装出城。徐茂公情急，大呼求救。时尉迟恭赤身在涧内洗马，即策马往救。秦王\n大喜，奏闻高祖，论功行赏。殷王李建成与齐王李元吉谗之，谓为虚构。秦王乃奏请试演之。时值腊月寒天，\n尉迟恭以李靖所赠丹药服之，身如火焚，汗如雨下，仍赤身洗马于涧内。高祖命秦王与徐茂公游园，又令\n李建成与李元吉传命王云，扮单雄信追杀秦王。正在危急之时，尉迟恭赶至，将王云打死。并将李建成、李\n元吉击毙鞭下。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引皮可能同上。"
        },
        {
          "character": "皮可能",
          "type": "念",
          "text": "沙漠胡地逞威风，可恨南蛮聚英雄。心中只把秦琼恨，要拿唐童尉迟恭。"
        },
        {
          "character": "皮可能",
          "type": "白",
          "text": "某，皮可能。可恨敬德，单鞭扶主，将唐童救出。孤王不服，练就雄兵百万， 二次报仇。 番儿们，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、秦琼同上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "披抡锏英雄盖世，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "水磨鞭扶保唐家。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "请了。千岁征战皮可能，在此伺候。"
        },
        {
          "character": "龙套甲",
          "type": "内白",
          "text": "圣驾到。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "圣驾到。"
        },
        {
          "character": "秦琼、尉迟恭",
          "type": "同白",
          "text": "接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。李世民上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "秦琼、尉迟恭",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、皮可能同上。"
        },
        {
          "character": "皮可能",
          "type": "念",
          "text": "任他英雄将，难比某家强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报。唐将讨战。"
        },
        {
          "character": "皮可能",
          "type": "白",
          "text": "再探吓。 唐将讨战。岂肯容他猖狂。 来，起兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上，众人同杀下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李世民上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "钦承王命出都城， 阵前观看皮可能。 三军打道高风岭， 看他谁输哪个赢。 来日小王打一仗， 探听虚实假和真。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、皮可能同上，同杀下。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "一个为是把主保， 一个为是锦乾坤。 叫众将安下地雷与火炮， 就是鹊鸟难飞腾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、皮可能同上，同杀。皮可能死，下。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "皮可能已死。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "班师回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李建成、李元吉同上。"
        },
        {
          "character": "李建成",
          "type": "念",
          "text": "心中思想千条计，"
        },
        {
          "character": "李元吉",
          "type": "念",
          "text": "恼恨秦王李世民。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "御弟。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "皇兄。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "只因世民征战皮可能有功，若是父王重用，这江山与你我无分了。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "御弟，我有一计。父王若是封赠敬德，皇兄奏道他日抢三关，夜夺八寨，许多 钱粮用尽，封不得国公。将御花园改为御果园，效昔日三跳涧的故事，演试与 父王观看。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "好倒好，只是眼前无有雄信。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "我宫中有一人，名叫王云，他的面貌倒似雄信。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "来，传王云。"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "有，传王云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王云上。"
        },
        {
          "character": "王云",
          "type": "念",
          "text": "生上貌相狰狞，亚赛雄信单通。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "小人叩头。"
        },
        {
          "character": "李建成、李元吉",
          "type": "同白",
          "text": "起来。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "千岁呼唤，哪厢使用？"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "命你扮作单雄信，将御花园改为御果园，效昔日三跳涧的故事，演试与万岁观 看。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "又恐他保驾的臣子甚多。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "这怕他什么。保驾的臣子，不过是尉迟敬德。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "此乃是数九寒天，待我将他调至午门外，金井边洗马，冻也冻坏了这个黑贼。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "下去扮来。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "王云",
          "type": "念",
          "text": "怎学专诸首，难效昔金洛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王云下。"
        },
        {
          "character": "李建成",
          "type": "念",
          "text": "计就月中擒玉兔，"
        },
        {
          "character": "李元吉",
          "type": "念",
          "text": "谋成日里提金乌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李建成、李元吉同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，李渊上。"
        },
        {
          "character": "李渊",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李建成、李元吉同上。"
        },
        {
          "character": "李建成",
          "type": "念",
          "text": "忙将机密事。"
        },
        {
          "character": "李元吉",
          "type": "念",
          "text": "奏与父王知。"
        },
        {
          "character": "李元吉、李建成",
          "type": "同白",
          "text": "儿臣见驾，愿父王万岁。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "上殿何事？"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "今有秦王得胜回朝，已在午门侯旨。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、尉迟恭、秦琼、徐茂功同上。"
        },
        {
          "character": "李世民、尉迟恭、秦琼、徐茂功",
          "type": "同念",
          "text": "征战皮可能，齐唱凯歌声。"
        },
        {
          "character": "李世民、尉迟恭、秦琼、徐茂功",
          "type": "同白",
          "text": "臣等见驾，愿吾皇万岁。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "众卿征战皮可能有功，徐茂公封为英国公。"
        },
        {
          "character": "徐茂功",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "秦琼封为护国公。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "敬德封为鄂国公。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "启父王：尉迟敬德日抢三关，夜夺八寨，费了许多兵马钱粮，封不得国公。将 御花园改御果园，效昔日三跳涧的故事，演试与父王观看。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "好倒好，只是没有单雄信。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "儿臣宫中有一人，名叫王云，貌似单雄信。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "领旨。 父王有旨：宣王云上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王云上。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "王云",
          "type": "念",
          "text": "忽听万岁宣，忙步上金銮。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "王云见驾，愿吾皇万岁。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "皇儿下殿看来。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "面貌倒也还相。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "王云。命你假扮雄信，与二主比试，效昔日三跳涧的故事，演来与孤王一观。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "但不知那雄信见了千岁，怎样行事？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "见了小王百般叫骂。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "小人不敢。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "比武图幸，恕你无罪。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "李世民、尉迟恭、秦琼、徐茂公",
          "type": "同白",
          "text": "请驾。"
        },
        {
          "character": "李渊",
          "type": "唱",
          "text": "孤王一字押群僚，"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "文武百官且退朝。"
        },
        {
          "character": "徐茂功",
          "type": "唱",
          "text": "这才是没事又有事，"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "又该敬德立功劳。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "此事只恐旁人笑，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "这黑贼中了你我计笼牢。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "王云。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "你把战饭要吃饱，"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "拚着儿命与他交。"
        },
        {
          "character": "李建成",
          "type": "唱",
          "text": "你若是把我父王来杀了，"
        },
        {
          "character": "李元吉",
          "type": "唱",
          "text": "保我皇兄坐九朝。"
        },
        {
          "character": "王云",
          "type": "唱",
          "text": "愁只愁无头来带乌纱帽，"
        },
        {
          "character": "李建成、李元吉",
          "type": "同白",
          "text": "哎。"
        },
        {
          "character": "李建成、李元吉",
          "type": "同唱",
          "text": "泄漏了机关计不高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黑月奴、白月姣同上。"
        },
        {
          "character": "黑月奴、白月姣",
          "type": "同引子",
          "text": "举案齐眉，夫唱妇随。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "打道。"
        },
        {
          "character": "黑月奴、白月姣",
          "type": "同白",
          "text": "老爷万福。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "坐下。"
        },
        {
          "character": "黑月奴、白月姣",
          "type": "同白",
          "text": "告坐。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "可恼吓，可恼！"
        },
        {
          "character": "黑月奴、白月姣",
          "type": "同白",
          "text": "王爷今日下朝回来，为何怒气不息？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "二位夫人有所不知。只因征战皮可能有功，圣上见喜，加封国公。可恨建成小 儿一旁阻本，道某日抢三关，夜夺八寨，费了许多兵马钱粮。将御花园改为御 果园，效昔日三跳涧的故事，因此着恼。"
        },
        {
          "character": "黑月奴、白月姣",
          "type": "同白",
          "text": "王爷就该顺从与他。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "夫人吓！"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "忆昔当年投太主， 元吉见俺怒冲冠。 彼时将某推出斩， 乔公山救我活命还。 转投山后刘武主， 晋阳王待我恩如山。 降马打死宋金玉， 宋金刚与某结下冤。 日抢三关夺八寨。 美良川下锏对鞭。 撵鞭解带投唐主， 端阳节救驾御果园。 到今日要效三跳涧， 此乃数九腊月天。 赤身划马难交战。 活活冻坏将一员。"
        },
        {
          "character": "黑月奴、白月姣",
          "type": "同唱",
          "text": "李靖赐你一封简，"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "有劳二位夫人贤。 拆开锦囊观书简， 一一从头往下观： 自从分别金銮殿， 丸药二粒带身边。 一丸将军吃腹内， 一丸把与乌骓餐。 神尧腊月二十四， 御花园中救贞观。 叫夫人取银汤把药捻， 这一丸把与乌骓餐。 霎时浑身俱是汗， 数九天好比三伏天。 解带宽衣把身现， 赤身露体手执鞭。 叫人来带过乌骓马， 二次救驾御果园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "黑月奴、白月姣",
          "type": "同唱",
          "text": "但愿此去把名显， 灭却奸贼整朝班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑月奴、白月姣同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王云上。"
        },
        {
          "character": "王云",
          "type": "念",
          "text": "两眼明星朗朗，一身虎背昂昂。"
        },
        {
          "character": "王云",
          "type": "白",
          "text": "某，王云。奉了万岁旨意，假扮雄信，与二主比试。远远望见万岁来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊、李世民、徐茂功同上。〖牌子〗。"
        },
        {
