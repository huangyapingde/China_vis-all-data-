{
  "script_id": "02002017",
  "title": "昭君出塞",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "王昭君",
      "hangdang": "旦"
    },
    {
      "name": "王龙",
      "hangdang": "丑"
    },
    {
      "name": "马夫",
      "hangdang": "武生"
    }
  ],
  "plot": "汉元帝时，匈奴时常犯边，抵御无人，乃用和番之策，将宫女嫁与单于。王昭君以绝世之姿，因不肯贿赂画\n工毛延寿，致所画王昭君之像，极为丑陋。临行时，元帝召见，始大惊讶，然已挽回乏术矣。",
  "notes": "剧中情节，全系描写昭君出塞时情形，凄凉悲愤，感慨俱深。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵卒引王龙同上。"
        },
        {
          "character": "王龙",
          "type": "引子",
          "text": "蟒衣三爪，玉带垂腰。一生富贵乐滔滔。谁似我，一品当朝，一品当朝。"
        },
        {
          "character": "王龙",
          "type": "念",
          "text": "马备征鞍将挂袍。柳梢枝上月儿高。男儿要挂封侯印，腰下常悬带血枪。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "倒了韵了。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "咱家。倒运的王龙便是。今有昭君娘娘，往北和番。 手下的，车辇可曾齐备？"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "带往十里长亭吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兵卒同允，行。"
        },
        {
          "character": "王龙",
          "type": "唱",
          "text": "朝臣待漏五更冷，"
        },
        {
          "character": "兵卒",
          "type": "同唱",
          "text": "五更冷，"
        },
        {
          "character": "王龙",
          "type": "唱",
          "text": "铁甲将军去跳井，"
        },
        {
          "character": "兵卒",
          "type": "同唱",
          "text": "去跳井。"
        },
        {
          "character": "王龙",
          "type": "唱",
          "text": "一连跳了个七八个，"
        },
        {
          "character": "兵卒",
          "type": "同唱",
          "text": "七八个，"
        },
        {
          "character": "王龙",
          "type": "唱",
          "text": "啊噗嘤。噗嘤，噗嘤，噗嘤，又噗嘤。"
        },
        {
          "character": "兵卒",
          "type": "同唱",
          "text": "啊噗嘤。噗嘤，噗嘤，噗嘤，又噗嘤。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "来到十里长亭了。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "伺候了。 娘娘有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王昭君上。"
        },
        {
          "character": "王昭君",
          "type": "风入松",
          "text": "别离泪涟， 怎忍舍汉宫的辇。 无端反贼弄朝权， 汉刘王，特煞柔软。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "文官齐齐，护送娘娘。"
        },
        {
          "character": "王昭君",
          "type": "风入松",
          "text": "那文官齐齐全无用，"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "武将森森，护送娘娘。"
        },
        {
          "character": "王昭君",
          "type": "风入松",
          "text": "就是那，是那武将森森也是枉然。 却将我红粉去和番， 臣僚呵，于心怎安，于心怎安。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "御弟王龙参见娘娘。愿娘娘千岁，千岁，千千岁！"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "御弟免礼。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "御弟，"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "千岁。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "车辇可曾齐备？"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "齐备多时。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "吩咐看辇。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "咳。 手下的，看辇哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王昭君上辇。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "咳，手下的，娘娘上了辇了。一路上。要你们快快儿的，慢慢儿的，吓，跑哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兵卒同允。"
        },
        {
          "character": "王昭君",
          "type": "山坡羊",
          "text": "王昭君，一俟海枯石烂， 手挽着金镶玉嵌的琵琶儿一面。 俺这里便思刘想汉， 眼睁睁，眼睁睁盼不到南来雁。 南来雁，哎呀雁儿吓。你与我把书传， 你与我多多拜上刘王天子， 道昭君要见也无由见。 恨只恨毛延寿，误写丹青， 教奴家红粉亲自——"
        },
        {
          "character": "众人",
          "type": "同山坡羊",
          "text": "去和番。 伤吓惨， 放声哭出雁门关。 心哪酸， 心在南朝身在北番。 昭君哪，去和番， 要见刘王难上难。"
        },
        {
          "character": "王昭君",
          "type": "山坡羊",
          "text": "要见刘王只是难上难。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "启上娘娘：来此沙漠之地。车辇难行。请娘娘换了马罢。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "吩咐住辇。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "咳，手下的，住辇哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王昭君、兵卒同下。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "马夫哪里，哪里？咳，马夫哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫上，跳。"
        },
        {
          "character": "马夫",
          "type": "念",
          "text": "奔腾千里荡尘埃，荡尘埃，渡水扒山紫雾开。拽断丝缰溜玉辔，火龙飞下九天 来。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "马夫叩头。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "抬起头来。 吓，你是娘个什么东西？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "小的是个马夫。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "你是个马夫。可有良马？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "良马俱已差尽。只剩得一匹劣马。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "良马俱已差尽了，只剩得一匹劣马了。你可降得来？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "降得来。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "咳。马夫你与我降吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫降马。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "马到。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "好马。真乃的好马。可有鞍辔？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "有鞍辔。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "带下去备来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫允，备。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "真乃人是衣衫，马是鞍辔。备上鞍辔益发好看了。马夫，带紧了。待你老爷试 个试个。马夫，与你老爷加了鞭儿。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "咳，咳，咳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王龙行，栽。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "这样马，也是你娘娘骑跨得的？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "肚带不曾收紧。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "肚带不曾收紧。待你老爷，煞个煞个肚带。 娘娘有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王龙下。王昭君上。"
        },
        {
          "character": "王昭君",
          "type": "念",
          "text": "昭君扶玉鞍，上马啼红血。今日汉宫人，明朝胡地妾。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "马夫与我加鞭。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "咳，咳，咳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王昭君、马夫同行。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "这是哪里了？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "汉陵了。"
        },
        {
          "character": "王昭君",
          "type": "楚江吟",
          "text": "汉陵云横雾迷， 撇下朔风吹透征衣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王昭君、马夫同行。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "又是哪里了？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "汾关了。"
        },
        {
          "character": "王昭君",
          "type": "楚江吟",
          "text": "人到汾关珠泪淋，"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "马为何不行？"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "南马不过北。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "与我加鞭。"
        },
        {
          "character": "马夫",
          "type": "白",
          "text": "咳。咳，咳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王昭君、马夫同行。王龙换衣上。"
        },
        {
          "character": "王昭君",
          "type": "楚江吟",
          "text": "慢说道人有思乡之意， 马呵，岂无恋国之心，何况人乎？ 慢说是个人，就是马到关前， 马到关前，它就步懒移。 人影稀， 只见北雁南飞。 冷清清，朔风似箭， 又只见旷野云低。 细雨与姣枝，在皇宫多尊贵， 受洪福与天齐。 自少儿在闺阁之内， 哪曾受，哪曾受这风霜劳意。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "御弟。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "千岁。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "可曾望的见家乡。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "来路远了，望不见了。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "带转马头。"
        },
        {
          "character": "王昭君",
          "type": "牧羊关",
          "text": "哎呀，爹娘啊！ 孩儿今日别了你， 又未知，何年何月，何日何时， 再见得我那爹娘啊！ 转眼望家乡， 飘渺以似云飞。 又只见，海水连天， 野花满地。 愁似，雁门关上望长安， 总有那，巫山十二难寻觅。 怀抱琵琶别汉君， 西风飒飒走胡尘。 朝中甲士千千万， 始信功劳在妇人。 愁默默，恨沉沉， 咬牙切齿恨奸臣。 今朝别了刘王去， 若要相逢，若要相逢，一似海样深。 思我君来想我主， 想主实指望，凤枕鸾衾同欢会。 又谁知，凤只鸾孤， 都作了一样肚肠碎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内锣鼓响。"
        },
        {
          "character": "王昭君",
          "type": "牧羊关",
          "text": "又听得金鼓连天震地， 人似彪，马似龙驹。 旌旗闪闪， 黑白以似云飞。 见他们，好似群羊队， 发似枯松，脸似黑漆，鼻似鹰钩，须卷山眉。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "御弟。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "千岁。"
        },
        {
          "character": "王昭君",
          "type": "牧羊关",
          "text": "叫他们，一个一个下阵到关前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王昭君、马夫同下。二小番同上。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "压捕。"
        },
        {
          "character": "王龙",
          "type": "唱",
          "text": "臊达子臊达子， 娘娘嫌你们腥膻气。 叫你们一个一个下阵到关前去。"
        },
        {
          "character": "二小番",
          "type": "同唱",
          "text": "呜哩哇，哩哇，咯呜哩蒙董， 吃杀乙呀，吱吱呀呀儿杀。 呀。呀。吓得嘞呜杀呀。杀呀。"
        },
        {
          "character": "二小番",
          "type": "同白",
          "text": "厄吉儿。你这个王八日的，打那个王八日的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番乙下。"
        },
        {
          "character": "小番甲",
          "type": "白",
          "text": "一个蒙古。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "不懂的。"
        },
        {
          "character": "小番甲",
          "type": "白",
          "text": "照苏。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "不懂的。"
        },
        {
          "character": "小番甲",
          "type": "白",
          "text": "蒙古你不懂的，照苏你也不懂的。亲爹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王龙允。小番甲打王龙。"
        },
        {
          "character": "小番甲",
          "type": "白",
          "text": "蒙古，你不懂的；照苏，你也不懂的。叫你亲爹，你懂的。他那个王八日的， 叫我这个王八日，打你这个王八日的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小番甲打王龙。小番甲下。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "臊达子已去。 娘娘有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫、王昭君同上。"
        },
        {
          "character": "王昭君",
          "type": "白",
          "text": "御弟。我有五怨难舍。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "哪五怨？"
        },
        {
          "character": "王昭君",
          "type": "唱",
          "text": "第一来，难忘父母恩， 第二来，难，难割舍同衾人。 第三来，损害黎民， 第四来，国家粮草都输尽。 第五来，百万铁骑，为我昼夜辛勤。 今日昭君舍了身， 万年羞辱汉元君。"
        },
        {
          "character": "王龙",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "王龙",
          "type": "唱",
          "text": "我想吓，他那里，也是个娘，娘吓， 我这里，也是个娘，娘吓。 他那里，也是国母唯， 我这里，也是国母唯。 一般样的荣华， 一般样的受用。 何须愁闷，何须悲泪。 我的娘娘吓，娘娘，娘娘。我的娘娘吓。"
        },
        {
          "character": "王昭君",
          "type": "唱",
          "text": "姣容貌，瘦损腰， 手托香腮，泪珠流落。 我宁作南朝黄泉客， 不作夷邦掌国人。 洒泪如珠，洒泪如珠， 恨只恨，毛延寿歹心人， 又谁知助国无成。 碧天连水水连云， 泪斑斑。带月披星。 这头儿望不见汉长城。"
