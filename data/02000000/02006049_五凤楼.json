{
  "script_id": "02006049",
  "title": "五凤楼",
  "alias": [
    "法场"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "薛丁山",
      "hangdang": "老生"
    },
    {
      "name": "樊梨花",
      "hangdang": "旦"
    },
    {
      "name": "武三思",
      "hangdang": "净"
    }
  ],
  "plot": "武三思监斩，太乙山宝青老祖及黎山老母，将薛蛟及樊梨花救去。",
  "notes": "按此剧与《法场换子》故事完全相同，但人名等均异，故一并印存。因《法场换子》可与《双狮图》及《徐\n策跑城》等剧连串上演也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "四刀斧手",
          "type": "内白",
          "text": "闪开了！"
        },
        {
          "character": "薛丁山",
          "type": "内二黄导板",
          "text": "这其间才息我凌云壮志，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手、薛丁山同上。"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "哎呀，圣上啊！"
        },
        {
          "character": "薛丁山",
          "type": "唱",
          "text": "枉争战数十年扶保华夷。 太宗皇承高祖开基创业， 扫北番平辽蛮御驾征西。 仁慈君待薛家君臣大义， 沐天恩三辈王世代锦衣。 生逆子小薛刚英雄无比， 仗王爵每日里惹祸招非。 一家人俱遭下叛逆法律， 叹功劳到头来烟灭灰飞。 忠良臣为国家岂把命惜，"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "哎呀，圣上啊！"
        },
        {
          "character": "薛丁山",
          "type": "唱",
          "text": "大限到谁顾得儿女夫妻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛丁山坐下场椅。二刽子手、樊梨花同上。"
        },
        {
          "character": "樊梨花",
          "type": "唱",
          "text": "薛门中生薛刚祸根又起， 此乃是天注定谁敢改移。 掌权臣尽都是一群叛逆，"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "啊王爷，哎呀夫呀！"
        },
        {
          "character": "樊梨花",
          "type": "唱",
          "text": "夫与妻顷刻间一命归西。"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "哎呀，夫人呀！"
        },
        {
          "character": "薛丁山",
          "type": "唱",
          "text": "这是你养娇儿长他志气， 祸临头才知道后悔也迟。"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "哎呀，夫人，这是你生的好子，连累一门，刀刀见血，尽作无头之鬼呀。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哎呀，王爷，这是前世之孽，今生来报。可记得在西凉滴泪斩杨凡？转世杀尽 薛氏一门，这是冤冤相报了。"
        },
        {
          "character": "樊梨花",
          "type": "唱",
          "text": "前世里结冤仇今生难避， 善与恶福与祸到头无亏。"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "夫人呀！"
        },
        {
          "character": "薛丁山",
          "type": "唱",
          "text": "法场上绑得我头晕眼迷， 一家人遭诛戮血泪湿衣。 中国京剧戏考 《五凤楼》【六本】 2"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军牢、四枪手引武三思同上。"
        },
        {
          "character": "武三思",
          "type": "唱",
          "text": "奉王旨监斩的罪臣叛逆， 法场上只哭得日色昏迷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武三思进内案坐，二刽子手同迎接。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "时辰已到，将薛家满门开刀。"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "啊，请王爷升天。"
        },
        {
          "character": "薛丁山",
          "type": "白",
          "text": "哎呀，圣上啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二刽子手押薛丁山同下。八云童自两边分上，黎山老母上桌，上桌上椅。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "樊梨花开刀。"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三通鼓。"
        },
        {
          "character": "二刽子手",
          "type": "同白",
          "text": "招刀！"
        },
        {
          "character": "黎山老母",
          "type": "白",
          "text": "梨花快上云端。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "烟火。樊梨花上桌，八云童拥樊梨花同下。"
        },
        {
          "character": "四刀斧手",
          "type": "白",
          "text": "哎呀，不好了。樊梨花腾空而去。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "哎，樊梨花腾空而去。唔，她原有异术，不可惊声。将薛猛夫妻开刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手两边搀薛猛、张夫人分上。"
        },
        {
          "character": "薛猛",
          "type": "白",
          "text": "哎呀，夫人啊！"
        },
        {
          "character": "薛猛",
          "type": "唱",
          "text": "我尽忠来你尽节， 阴曹地府切莫离。 薛家一死何足惜，"
        },
        {
          "character": "薛猛",
          "type": "白",
          "text": "奸贼呀奸贼！"
        },
        {
          "character": "薛猛",
          "type": "唱",
          "text": "奸贼误国万载提。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "开刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张夫人回头、抱下子，二刽子手、薛猛、张夫人自两边分下。宝青老祖、众云童同上，宝青老祖站桌。"
        },
        {
          "character": "四刀斧手",
          "type": "同白",
          "text": "启爷：还有一婴儿薛蛟。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "抱来看看。 呀，好个孩儿呀。待我抱去抚养。 哎，又道斩草除了根，萌芽永不生。 来，将他斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "烟火。四刀斧手往上抛，宝青老祖接。众云童拥宝青老祖同下。"
        },
        {
          "character": "四刀斧手",
          "type": "同白",
          "text": "哎呀，薛蛟飞上天去了。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "呀，想是樊梨花作法，将薛蛟摄去。将薛氏一门开刀。"
        },
        {
          "character": "四刀斧手",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四刀斧手自两边分下，自两边分上。"
        },
        {
          "character": "四刀斧手",
          "type": "同白",
          "text": "尽行斩首。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "将叛臣全家尸首抬到辽王府，上殿复旨去者。"
        },
        {
          "character": "四刀斧手",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}