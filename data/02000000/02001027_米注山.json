        {
          "character": "斗贲凰",
          "type": "白",
          "text": "不用就罢吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰下。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师请。"
