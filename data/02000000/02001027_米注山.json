        },
        {
          "character": "蒍贾",
          "type": "唱",
          "text": "是个人面兽心肠！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "我儿向前！"
        },
        {
          "character": "斗贲凰",
          "type": "唱",
          "text": "老贼早把印献上， 叫你一命丧无常！"
