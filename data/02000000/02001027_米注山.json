{
  "script_id": "02001027",
  "title": "米注山",
  "alias": [
    "伐陆浑"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "斗越椒",
      "hangdang": "净，紫蟒苍满紫金冠雉翎"
    },
    {
      "name": "蒍贾",
      "hangdang": "外，相貂白满白蟒"
    },
    {
      "name": "斗贲凰",
      "hangdang": "净，黑脸软扎中内黑靠"
    },
    {
      "name": "蒍夫人",
      "hangdang": "老旦"
    },
    {
      "name": "蒍子",
      "hangdang": "小生"
    },
    {
      "name": "蒍家将",
      "hangdang": "副净"
    },
    {
      "name": "斗家将",
      "hangdang": "丑"
    }
  ],
  "plot": "斗越椒自被楚庄王夺去剑印，削官为民后，心怀不平，乘楚庄王亲自出征陆浑之际，邀蒍贾赴宴，并逼蒍贾\n将剑印交出。蒍贾不从，乃将蒍贾杀死，派兵至蒍贾家中搜回剑印。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同上，斗越椒上。"
        },
        {
          "character": "斗越椒",
          "type": "引子",
          "text": "一腔懊恼在心头，泄却怨气方罢休。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "罢斥私衙常带忧，胸中烦闷几时休。昏王不念功勋后，金殿解印结冤仇。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "某，斗越椒。三世扶楚，累代功勋，袭荫司马剑印。为伐郑国，兵败而归。昏 王不念功臣，将我司马剑印削除，付与蒍贾执掌。朝纲之内，不许我父子出头。 至今恶气未消，为此设下一计，诓请老贼蒍贾过府，饮宴索还司马剑印。他 若不肯，就将老贼杀死。庄王征战陆戎未回，除了老贼，这江山岂不是唾手而 得。已命我儿贲凰打听昏王消息。待他回报便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰上。"
        },
        {
          "character": "斗贲凰",
          "type": "念",
          "text": "打听庄王事，回复爹爹知。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "罢了，坐下。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "谢座。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "打听昏王可曾回朝？"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "打听庄王征战陆戎尚未回朝。此乃天赐良机，爹爹早早准备。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "好。为父修帖诓请老贼过府便了。"
        },
        {
          "character": "斗贲凰",
          "type": "念",
          "text": "蒍贾不来非君子。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "准备枪刀夺皇朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒、斗贲凰同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蒍贾上。"
        },
        {
          "character": "蒍贾",
          "type": "引子",
          "text": "位列朝纲，忠心扶保家邦。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "老夫蒍贾，在楚庄王驾前为臣，官居大司马之职。只因陆戎造反，大王御驾亲 征，尚未回朝，朝中大事交与老夫执掌。且喜边庭安靖，朝野清平。只虑越椒 父子，怀有异心。老夫也曾命人暗地打听，并无动静。正是："
        },
        {
          "character": "蒍贾",
          "type": "念",
          "text": "常将国家事，时刻挂在心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗家将上。"
        },
        {
          "character": "斗家将",
          "type": "念",
          "text": "奉了司马命，来请鼎鼐臣。"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "门上哪位？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "斗家将",
          "type": "stage",
          "text": "中国京剧戏考 《米注山》【三本】 2"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "奉斗司马所差，有帖在此。请相爷观看，即等回音。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请少待。 启相爷：斗司马差人有帖在此，请相爷观看。来人即等回音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍贾接书看。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "“国事少暇，特备樽俎，伏乞台驾光临一叙——斗越椒顿首。” 批有小字，待我看来。 “来者君子，不来小人。” 哦，回复来人：说我即来赴宴，决不食言。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓。 相爷即来赴宴，决不食言。"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "有劳了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗家将下。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "吓，斗越椒与老夫素无会宴，今日之事，甚有蹊跷。 来，请夫人、公子出堂。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "夫人、公子出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍夫人上。"
        },
        {
          "character": "蒍夫人",
          "type": "引子",
          "text": "阀阅经纶，受皇封，难报君恩。"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "相爷。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "夫人请坐。"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "有座。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍子上。"
        },
        {
          "character": "蒍子",
          "type": "引子",
          "text": "父为忠良扶国政，效斑衣侍奉双亲。"
        },
        {
          "character": "蒍子",
          "type": "白",
          "text": "爹爹、母亲在上，孩儿拜揖。"
        },
        {
          "character": "蒍贾、蒍夫人",
          "type": "同白",
          "text": "罢了，儿且坐下。"
        },
        {
          "character": "蒍子",
          "type": "白",
          "text": "孩儿告座。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "相爷何故发此长叹？敢是与哪部大臣争斗么？"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "非也。只因斗越椒设下宴席，请老夫过府叙谈。想此人的诡计多端，恐有歹意。 故此心中疑忌。"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "相爷既是心中疑忌，辞却不去也就是了。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "那厮在帖后写了几行小字，这“来者君子，不来小人”。我蒍贾世代忠良，岂 惧奸佞？我今此去无事便罢，倘有不测，你母子可逃奔齐国梦泽山，务农去罢。"
        },
        {
          "character": "蒍子",
          "type": "白",
          "text": "爹爹，有道是宴无好宴，会无好会。既知那贼心怀歹意，尚该不去的为妙。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "我儿哪里知道为父的呵！"
        },
        {
          "character": "蒍贾",
          "type": "二黄慢板",
          "text": "自幼儿读圣言忠孝为本， 博得个美名儿后世留存。 斗越椒为的是金殿解印， 因此上设筵宴巧计来生。 想为父为国家一死何恨， 我若是不会宴笑煞他人。"
        },
        {
          "character": "蒍夫人",
          "type": "唱",
          "text": "老相爷秉丹心朝纲主正， 斗越椒仗权柄倚势横行。 在金殿解印信皇王之命， 看将来是一个贪利小人。 你过府赴宴席倘有伤损， 我母子眼睁睁骨肉离分。"
        },
        {
          "character": "蒍子",
          "type": "白",
          "text": "爹爹吓！"
        },
        {
          "character": "蒍子",
          "type": "唱",
          "text": "尊爹爹莫逞刚直之性， 听孩儿禀一言察理详情： 且不要许奸贼去把宴饮， 等侯那圣驾回辨理分明。 中国京剧戏考 《米注山》【三本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗家将上。"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "有人么？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是哪个？"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "斗司马差人，有催帖在此，请相爷就行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗家将下。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "斗司马差人，有催帖在此，请相爷就行。"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "相爷，依妾身之言，不去为妙。"
        },
        {
          "character": "蒍子",
          "type": "白",
          "text": "是吓，爹爹不去的为妙。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "咳，你母子说哪里话来！人生天地之间，岂能不死？但恐不得其名。我今为国 捐生，理所当然。你等不必做此儿女之态。只愿我儿后来得学为父之志，我死 九泉亦足甘心矣！"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "相爷执意要去，可命家将保护前往。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "这却使得。"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "来，唤家将走上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "家将走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍家将上。"
        },
        {
          "character": "蒍家将",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": "蒍家将",
          "type": "念",
          "text": "忽听相爷唤，急忙到堂前。"
        },
        {
          "character": "蒍家将",
          "type": "白",
          "text": "家将叩头！"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "起来。命你同相爷前去赴宴，倘若有变速回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍家将允。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "带马来，随老夫前往。"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "愿相爷平安无事而回。"
        },
        {
          "character": "蒍子",
          "type": "白",
          "text": "爹爹此去，必须见机生情，休堕奸计。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "不必多言，老夫去也。"
        },
        {
          "character": "蒍贾",
          "type": "唱",
          "text": "辞别夫人上能行，"
        },
        {
          "character": "蒍夫人、蒍子",
          "type": "同白",
          "text": "（相爷）（爹爹）！"
        },
        {
          "character": "蒍贾",
          "type": "唱",
          "text": "夫人、我儿休悲声。 此去吉凶未可定， 惟愿平安转家门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍贾下，蒍家将随下。"
        },
        {
          "character": "蒍夫人",
          "type": "白",
          "text": "相爷小心了！"
        },
        {
          "character": "蒍子",
          "type": "白",
          "text": "爹爹吓！"
        },
        {
          "character": "蒍夫人",
          "type": "唱",
          "text": "相爷为国忠心耿， 但愿两下得和平。 我儿自去探一信， 或吉或凶方安宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍夫人下。"
        },
        {
          "character": "蒍子",
          "type": "唱",
          "text": "堂前领了母亲命， 探听爹爹信和音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒍子下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒、斗贲凰同上。"
        },
        {
          "character": "斗越椒",
          "type": "念",
          "text": "妙计安排定，要夺锦乾坤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗家将上。"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "启老爷：太师到。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "我儿准备便了。"
        },
        {
          "character": "斗贲凰",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰下。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "有请老太师！ 中国京剧戏考 《米注山》【三本】 4"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "有请老太师！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。蒍贾、蒍家将同上，蒍贾看。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "吓，老太师！"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "司马公！"
        },
        {
          "character": "蒍贾",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "蒍贾、斗越椒",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "有座"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师驾到，未曾远迎，面前恕罪。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "岂敢！老朽来得卤莽，司马公海涵。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师，大王御驾亲征陆戎未回，朝纲之事，全亏老太师护理。可谓国之栋梁 也！"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "一来大王洪福，二来司马公威名，因此外邦不敢犯境。"
        },
        {
          "character": "斗越椒",
          "type": "笑",
          "text": "啊，哈哈哈哈哈哈！"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师昼夜辛劳，某家特备薄酌，与老太师叙谈叙谈。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "叨扰司马公了！"
        },
        {
          "character": "斗家将",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "看宴。待某把盏。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "不消，摆下就是。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "从命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。定席。"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师请。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "司马公请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "画眉序牌。斗贲凰上，舞枪。蒍家将拦。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "这却为何？"
        },
        {
          "character": "斗越椒",
          "type": "白",
          "text": "老太师饮酒不乐耍枪敬酒。"
        },
        {
          "character": "蒍贾",
          "type": "白",
          "text": "不用。"
