{
  "script_id": "02006045",
  "title": "五凤楼",
  "alias": [
    "彩楼"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "薛强",
      "hangdang": "小生"
    },
    {
      "name": "孟九环",
      "hangdang": "旦"
    },
    {
      "name": "公子甲",
      "hangdang": "丑"
    }
  ],
  "plot": "薛强被李靖大仙救往大宛国，适大宛国公主孟九环，搭彩楼抛球招婿。薛强接得彩球，遂与孟九环结婚云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四御林军执事、四侍卫挂刀、四太监、四宫女、孟九环同上。"
        },
        {
          "character": "孟九环",
          "type": "点绛唇",
          "text": "凤阙云霞，龙辇风驾，鹊桥架，瑞彩捻华，屏开天台下。"
        },
        {
          "character": "孟九环",
          "type": "念",
          "text": "众星捧月离深宫，春风送暖玉芙蓉。玉叶金枝蓝田种，牛女停梭七夕中。"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "奴孟九环是也。父讳孟方，乃大宛国主。母亲吴氏，单生奴家一人，未曾招赘。 父王传旨，在校场高搭彩楼，命我抛球婚配。 侍女们，吩咐御林军，往彩楼去者。"
        },
        {
          "character": "四宫女",
          "type": "同白",
          "text": "彩楼去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟九环下。搭台。薛强上。"
        },
        {
          "character": "薛强",
          "type": "唱",
          "text": "多感得李大仙活命恩典， 指引我有一段宿世良缘。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "俺，薛强。蒙李靖将我送到大宛国，又是一番光景。适才店主人言道，国王有 一女，姓孟名九环，在校场高搭彩楼，抛球招赘。哎，莫非我的姻缘就在公主 身上了？"
        },
        {
          "character": "薛强",
          "type": "唱",
          "text": "离中原别故土愁眉难展， 思想起父母亲好不惨然。 我好比秋暮天失群孤雁， 满怀内千般苦向谁诉言？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众公子同上。"
        },
        {
          "character": "众公子",
          "type": "同唱",
          "text": "姻缘事月老仙红丝牵线， 自古言美嫦娥喜爱少年。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "吓，列位请了。"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "请了。我们看你不像本国的人吓。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "我乃大唐中原人氏。"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "哎呀，山水远隔，因甚至此？"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "我在此做买卖的。"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "哎呀，这是雁飞不到处，人为名利牵。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "列位贵乡何处？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众公子分用各自本地语答。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "你们这样装扮，往哪里去？"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "都往彩楼，抢夺绣球，好招驸马。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "哎呀，看他们这般嘴脸，未必公主还看得他上哎。 列位，我可去得？"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "不论本国外国之人，都是去得的。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "既然去得，你我一路同行。"
        },
        {
          "character": "公子甲",
          "type": "白",
          "text": "哎哎哎，你们都不用去，这个驸马，是我定了。"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "怎见得？"
        },
        {
          "character": "公子甲",
          "type": "白",
          "text": "我衣才、貌才、人才、文才，四才全了，这驸马不是我还有谁？ 中国京剧戏考 《五凤楼》【二本】 2"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "哎，姻缘大事，不可强求，少时便知。一同前往。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "薛强",
          "type": "唱",
          "text": "观他们似夜叉牛头马面， 贪新婚也去到彩楼台前。 丑容颜与鬼怪一般嘴脸，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛强、众公子同下。"
        },
        {
          "character": "公子甲",
          "type": "白",
          "text": "哎、哎、哎！"
        },
        {
          "character": "公子甲",
          "type": "唱",
          "text": "论才貌我是个头名状元。"
        },
        {
          "character": "公子甲",
          "type": "白",
          "text": "咳、咳、咳，驸马爷来了，让开道。哈、哈、哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子甲下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四御林军、四侍卫、四太监、四宫女引孟九环同上。〖牌子〗。孟九环上楼，四宫女同站楼上，四太监分"
        },
        {
          "character": null,
          "type": "text",
          "text": "站两边板凳，四御林军、四侍卫同台下一字站。）"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "宫娥，摆开香案！"
        },
        {
          "character": "四宫女",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。宫女摆桌。"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "神圣在上，孟九环今日抛球招赘，以定终身。但愿绣球落于有缘之人也。"
        },
        {
          "character": "孟九环",
          "type": "西皮导板",
          "text": "御香飘绕霞光现， （月中老人、四云童、四云旗同上，月中老人站孟九环背后椅子，四云童分站两边，四云旗分站四角四椅子。 薛强、众公子自两边分上，众公子同闲话。）"
        },
        {
          "character": "孟九环",
          "type": "唱",
          "text": "祝告上苍含笑颜。 国色天姿难择选， 高结彩楼配良缘。 月老早降红丝线， 休负牛女古渡边。 婚姻岂惧程途远， 百岁和谐咫尺间。 即赐仙妃遇刘阮， 鸾凤相引并头莲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟九环抬桌，下台。"
        },
        {
          "character": "四侍卫",
          "type": "同白",
          "text": "呔，你等不要罗咤，接着彩球者，即招驸马。站定了。"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "吓。 （〖吹打〗。孟九环抛球，薛强接。众公子同拥薛强，薛强笑，众公子同闲话，四侍卫赶众公子同下，薛强 下。）"
        },
        {
          "character": "四宫女",
          "type": "同白",
          "text": "恭喜贵人：彩球中了一美貌少年。请公主启奏大王，择日婚配。"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四宫女、四太监、孟九环同下台。"
        },
        {
          "character": "四宫女",
          "type": "同白",
          "text": "起驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。薛强捧彩球上。"
        },
        {
          "character": "薛强",
          "type": "唱",
          "text": "李药师真个是仙目如电， 天相助接彩球得配良缘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众公子同上。"
        },
        {
          "character": "公子甲",
          "type": "白",
          "text": "哎呀，你是个中原人怎么招得驸马？快快与我走开，让我好去成亲。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "呔，这绣球落在我手，此乃天赐姻缘，谁敢争夺？"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "我们要抢！"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "谁敢来抢？"
        },
        {
          "character": "众公子",
          "type": "同白",
          "text": "我就抢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛强打众公子，众公子同下。侍卫甲上。"
        },
        {
          "character": "侍卫甲",
          "type": "白",
          "text": "吓，那壮士不用打，此乃天缘相助。随到馆驿，将家乡名姓，写一庚帖，待宫 女呈奏大王。随我来。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "请。 中国京剧戏考 《五凤楼》【二本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。薛强、侍卫甲同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、二大太监、孟方同上。"
        },
        {
          "character": "孟方",
          "type": "引子",
          "text": "玉镜人间传和璧，银河天上渡双星。"
        },
        {
          "character": "孟方",
          "type": "念",
          "text": "北斗挂城边，南山倚殿前。龙凤金阙地，风绕戴尧天。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "孤，孟方，威镇大宛国为君。所生一女，乳名九环。高搭彩楼，招赘佳婿。还 未交旨。"
        },
        {
          "character": "四宫女",
          "type": "内同白",
          "text": "公主朝参。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "公主朝参。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "宣上金殿。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "公主上殿。"
        },
        {
          "character": "孟九环",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。孟九环上，四宫女同上。"
        },
        {
          "character": "孟九环",
          "type": "念",
          "text": "莺歌闻太液，风吹绕瀛州。"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "儿九环见驾，愿父王千岁。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "儿吓，彩球落在谁人之手？可问姓名？他容貌如何？"
        },
        {
          "character": "孟九环",
          "type": "白",
          "text": "父王吓！"
        },
        {
          "character": "孟九环",
          "type": "唱",
          "text": "羞得我低下头不敢明讲， 虽择婿还有那父母在堂。 问姓名儿怎好直言奉上， 观庚帖自有了梁鸿孟光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟九环下，四宫女同随下。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "哎呀，他乃大唐薛仁贵之孙，名曰薛强。哈哈，真乃女儿之福也。 内侍，请薛爵主上殿。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "薛爵主上殿。"
        },
        {
          "character": "薛强",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛强上。"
        },
        {
          "character": "薛强",
          "type": "念",
          "text": "传来纶音飞鹦鹉，乐奏箫笙引凤凰。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "小将薛强见驾，愿国主千岁。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "爵主平身。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "四爵主不在长安，因甚至此？"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "只因三哥薛刚，大闹花灯，踢死殿下，惊动朝廷。我蒙仙人相救，到此误闯彩 楼之下。国主恕罪！"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "真乃千里姻缘一线牵。已遂小女之愿也。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "小将不敢玷辱金枝。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "乃天配良缘，何必推辞？今日吉日良辰，就在金殿拜完花烛。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "哎呀，既不嫌弃，父王请上，儿臣拜过。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "不用拜。 内侍，请驸马后宫更衣。"
        },
        {
          "character": "薛强",
          "type": "白",
          "text": "谢父王。"
        },
        {
          "character": "薛强",
          "type": "念",
          "text": "喜作乘鸾客，本为跨凤人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛强下。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "宣鸿胪寺上殿。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "鸿胪寺上殿。 中国京剧戏考 《五凤楼》【二本】 4"
        },
        {
          "character": "林光碧",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林光碧上。"
        },
        {
          "character": "林光碧",
          "type": "念",
          "text": "百年琴瑟好，千载凤麟祥。"
        },
        {
          "character": "林光碧",
          "type": "白",
          "text": "臣林光碧见驾，愿大王千岁。"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "林光碧",
          "type": "白",
          "text": "千千岁。宣微臣上殿，有何国事？"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "今与公主完婚，好好赞礼上来。"
        },
        {
          "character": "林光碧",
          "type": "白",
          "text": "领旨。伏以："
        },
        {
          "character": "林光碧",
          "type": "念",
          "text": "百尺红丝千里牵，婚姻好合是前缘。天南地北成佳偶，始信安居两周全。"
        },
        {
          "character": "林光碧",
          "type": "白",
          "text": "请新贵人台升。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女扶薛强、孟九环自两边分上，同拜堂。上半段尾声。四宫女、薛强、孟九环同下。"
        },
        {
          "character": "孟方",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "孟方",
          "type": "白",
          "text": "且喜女儿终身有托，孤王才得放心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下半段尾声。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}