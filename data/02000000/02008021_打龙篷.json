{
  "script_id": "02008021",
  "title": "打龙篷",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "郑恩",
      "hangdang": "净"
    },
    {
      "name": "柴荣",
      "hangdang": "老生"
    },
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "高怀德",
      "hangdang": "小生"
    }
  ],
  "plot": "柴荣登基后，国号曰大周，各国俱有贡奉。独南唐李号王，抗命不朝。且派其三子李豹，前来摆下百日擂台。\n经过九十九日，仍无人打下。满擂之日，柴王特派二位御弟，赵匡胤与郑子明前往探看，并派靠山侯石魁\n前往打擂。结果石魁被打下。正在危急之时，忽有一壮士高怀德上擂，将李豹打下。于是赵匡胤、郑子明回\n朝复旨。但知高怀德系柴王杀父仇人，柴王必报杀父之仇。乃先由郑子明向柴王讨封。讨得大赦圣旨，不杀\n高怀德之命令后，始令高怀德晋见柴王。",
  "notes": "事虽不见经传，但剧情则颇有情趣云。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。四小太监、二大太监同上，同站门。柴荣上。"
        },
        {
          "character": "柴荣",
          "type": "引子",
          "text": "天开文运，万国称尊孤一人。"
        },
        {
          "character": "柴荣",
          "type": "念",
          "text": "殿前殿后是芦州，俱是寡人出旨修。惟愿外邦皆供奉，一统山河庆千秋。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "寡人，大周天子柴荣，国号显德在位。自登基以来，各国皆有供奉，只有南唐 李号王，罢贡不朝，寡人出旨，命靠山侯石魁前去催供，谁知那厮进贡三子李 豹，来在吾国，摆下百日擂台，打了九十九日，只剩一擂，未能成功。今当满 擂之期，也曾命二家御弟前去探看，未见交旨。 内侍，展放龙篷。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。 展放龙篷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "保擂进龙篷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩上。"
        },
        {
          "character": "郑恩",
          "type": "念",
          "text": "各表各的功。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟，来此午门，一同进去。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥，请。"
        },
        {
          "character": "赵匡胤、郑恩",
          "type": "同白",
          "text": "臣，（匡胤）（子明）见驾，愿吾皇万岁！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "二位御弟平身。"
        },
        {
          "character": "赵匡胤、郑恩",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "赵匡胤、郑恩",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "二位御弟，把擂台之事，一一奏知。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "容奏。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥你奏。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟启奏。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "恭喜咱们皇上，贺喜咱们的万岁！他国三子李豹不得胜，我国石魁不曾败，平 空来了一位壮士走上擂台，把那三子李豹，这一拳一脚，打、打、打下擂台。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "打擂壮士今在哪里？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "已在午门候旨。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "宣来听封。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "领旨。 呔，打擂壮士听者：万岁爷宣上，龙篷听封吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德上。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "吾道是谁，原来是高御妹夫也，可亲。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "吾道是谁，原来是三千岁。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "高妹夫，你擂台之上，耍的好拳，使的好枪吓！"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "三千岁夸奖。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你在哪里出府？"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "花园出府。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "往哪里而去？"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "上殿讨封。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "上殿讨封，你看上面坐的，是你杀父的仇人。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "待吾回去。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "慢着。大丈夫只有向前，哪有退后之理，有咱保你无事，你且随咱来。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "呔，擂台壮士，你家住哪里，姓甚名谁，一一的奏来。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "容奏！"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "万岁在上容臣禀， 臣是当年有罪人。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "住奏。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "三弟为何叫他住奏？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "这打擂壮士，不知在哪里得罪万岁爷，要万岁出下赦条，方可奏明。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "言之有理，拿去。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "哎，上面花溜溜，下面流流花，一字儿黑圈圈，他认的我，我就不认他。咳， 一个字儿也不认得。哦，有了，问问咱的二哥。 吓，二哥。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟何事？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥，你看这个赦条可用得么？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这个赦条，慢讲一个，就是十张百张，也是无用。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "怎样无用？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "要个邀天大赦总赦条。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "何谓总赦条？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "抓破皇后脸，打落太子牙，一拳一脚打死先王老主，以往不究，名为邀天大赦 总赦条。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "着着着，二哥请坐，待小弟奏来。 咳，臣的万岁爷，这个赦条，慢说一张，十张百张也是无用的。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "怎么用不得？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "要个邀天大赦总赦条。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "何谓邀天大赦总赦条？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "万岁的龙爪，抓住御笔写，待微臣一一的奏。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "容奏：周室元年出赦条，晓谕黎民皆知晓：一赦欠粮与钱钞，二赦囚犯出天牢。 三赦这抓破皇后脸，打落太子牙，一拳一脚打死先王老主，以往不究，就叫 作邀天大赦总赦条。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "三弟奏之差矣。难道当初打死先王老主，御犯高怀德到了，叫寡人也赦他不成？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "哎，吾的万岁爷，慢说吾主见了高怀德不赦，就是为臣见了他，这一把抓进龙 篷，也是不饶。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "奏之有理。 周室元年出赦条，晓谕黎民皆知道：一赦欠粮与钱钞，二赦囚犯出天牢。只赦 打擂壮士，不赦高怀德，拿去。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咳，你赦了总是一样，管他高怀德不高怀德吓，又添几个小字，越发不认得了。 啊，二哥来，来，来。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你看这个可用得。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这个也用不得。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "怎样又用不得？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "上面只赦打擂壮士，不赦怀德怎么处？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "这便怎么处？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哦，有了。将这“不”字改为“本”字，“本赦怀德”，就赦着了。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "啊，赦着了？二哥，想柴大哥，乃初世为君，有些翻嘴皮，将这买卖三去到五 府六部之中，刻下榜文，一张改为十张，十张改为百张，晓谕天下黎民知等， 等他翻不过嘴皮吓。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "言之有理。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥，你请坐，兄弟去也。 呔，打擂壮士听者：皇上出有赦条在此，你当奏就奏，不当奏的也只管奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖三记锣鼓〗。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "那厢有赵二千岁，这厢有咱，你只管奏！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖抽头〗。郑恩笑，下。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "打擂壮士一一奏来。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "容奏！"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "家住在山东东平府， 高平关上有吾家门。 吾父名唤高鹞子， 吾名唤怀德字燕平。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "柴王闻言绉双眉， 骂声怀德是叛贼！ 高平关不该伤害孤的父， 你隐姓瞒名哄着谁？ 只指望天涯逃了命， 尔又到京城夺武魁。 你好似扑灯蛾自投火， 醉汉骑驴被鬼推。 吩咐两旁武士手， 推出斩首要首级回！"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "领旨！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "有本回奏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士同下。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "急水滩头难留月， 钢刀不斩无罪人。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "臣启万岁：打擂壮士身犯何罪，推出午门取斩？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "打擂壮士，就是御犯高怀德到了，故而取斩。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "启万岁：就是御犯高怀德，念在擂台之上，一拳一脚打走三子李豹，吾朝又添 一国进贡，也只可以赦，不可以斩。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "寡人龙心己定，不必多奏。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "万岁还是赦的好。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "斩的好。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "万岁吓！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "吾主登基天下扬， 各国来贺吾君王。 南唐李号心反上， 三子李豹乱朝纲。 天降怀德来打擂， 才保吾主福寿长。 龙篷内闷坏了赵匡胤，"
        },
        {
          "character": "郑恩",
          "type": "内白",
          "text": "来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩上。〖阴锣〗。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "龙篷外又来了北平王。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "啊啊，二哥，高妹丈封了多大的官？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "封了个平头王。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "啊，这平头王有多大？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "斩了。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "一个保一个，还保不住被他斩了？咱说你不中用，你就是真个的不中用！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟息怒，愚兄还保得在。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "怎么讲，还保得在？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "保得在。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "着着着，二哥请坐。待小弟前去。 咳，万岁！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "三弟上殿有何本奏？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "万岁爷，那打擂壮士，封他个什么前程？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "打擂壮士，就是御犯高怀德到了，寡人将他取斩。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "万岁，御犯高怀德理当取斩，念他在擂台之上，一拳一脚，打走三子李豹，吾 朝又添一家进贡。也只可以赦，不可以斩。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "有道是父仇不共戴天，定斩不赦。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "求万岁赦旨。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "一定要斩。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你真个要斩你就斩他娘的！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "且慢，斩了御妹夫不值紧要，御妹终身无靠。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "着着着，斩了御妹夫不值紧要，御妹终身无靠。 哦，有了。二哥，想昏王在关西路上，被咱的枣牙槊打怕了的，待咱回到北平 府，取了枣牙槊，他赦了便罢；他若不赦，咱就给他一槊！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哪有臣打君的道理？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥说的是，哪有臣打君、子杀父的道理？少时上得龙篷，那时节咱打的快， 你那里挡得快，也不过是吓唬他之意，哪有打王之理。少时咱的手快，你的眼 快，吓，请哪！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "二人奇谋把计定， 莫待君王斩良臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩下。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "那厢去了郑子明， 再上龙篷把本申。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "启万岁：高怀德是实实斩不得。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "怎么斩不得？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "他有一弟名唤高怀亮，现在火山王驾下为螟蛉义子，此人有万夫不当之勇，闻 知斩了他的胞兄，他若兴兵前来，吾朝中无人对敌，只恐江山有失。只可以赦， 不可以斩。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "就是怀亮兴兵前来，寡人江山不要，怀德一定要斩。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "求主赦的是。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "斩的是。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "万岁吓！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "昔日楚汉来争强， 鸿门设宴害高皇。 霸王不听范增讲， 后来自刎在乌江。 万岁休把怀德斩， 他是架海紫金梁。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "不必多奏。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "龙篷内昏迷了周室王， 不听忠良把本上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哦，有了！"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "龙篷外假传一道旨， 北平府再宣郑三王。"
        },
        {
          "character": "郑恩",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖阴锣〗。郑恩上。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "枣牙槊俺一举诸侯皆怕， 乌骓马跑遍了锦绣中华。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥来了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟来了。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥，他可曾赦？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "定斩不饶。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "呔，咱就打！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "遵王法。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "遵王法枣牙槊急忙落地， 怒冲冲进龙篷把本来提。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩冷笑。"
        },
        {
          "character": "郑恩",
          "type": "笑",
          "text": "啊，哈哈哈。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "三弟进得龙篷，怒气不息，与哪家王子争斗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩冷笑。"
        },
        {
          "character": "郑恩",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "吾的万岁爷，那打擂壮士，实实斩不得！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "怎么斩不得？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "他有一弟名唤怀亮，在火山王驾下为螟蛉义子，此人有万夫不当之勇，闻听斩 了他的胞兄，兴兵前来，吾朝无人对敌，只恐江山有失。只可赦，不可斩。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "就是怀亮兴兵前来，寡人江山不要，怀德一定要斩。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "哎，你这江山不要，也是要斩？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "也是要斩。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "罢罢罢，我给你磕几个头赦了罢。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "定斩不赦。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "吓，你一定要斩，这个买卖三，是何人出的？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "寡人出的。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你赦的谁吓？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "赦的打擂壮士，不是怀德。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "赦了总是一样，管他怀德不怀德。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "哎，有道父仇不共戴天，一定要斩！"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "世上哪有你这量小的天子？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "哪有你这叛逆的臣子？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咱便要你赦！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "偏要斩！"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "偏要赦！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "再若多奏，同高怀德一同取斩。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "吓，你斩谁？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "斩你！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖抽头锣鼓〗。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "反了哇，反了！"
        },
        {
          "character": "郑恩",
          "type": "二黄导板",
          "text": "在金殿立下唬王势，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖抽头锣鼓〗。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩坐地。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "好气人吓！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，哪个敢欺三千岁？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "柴荣吓！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咱要骂了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "使不得。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咱要打了！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "使不得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖攒掇头锣鼓〗。"
        },
        {
          "character": "郑恩",
          "type": "二黄慢板",
          "text": "上压昏君下打谗臣。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "柴荣！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "郑恩！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "你曾记初相逢路过棋盘阵， 那时你爱咱、咱就爱着他，你咱他三人拜为昆仑。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "柴荣你许得咱！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "许你什么？"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "你许咱泰山倒弟兄们不散， 咱许你海水干弟兄们不分。 虽然异姓来结盟， 胜似同胞一母生。 到如今山也没倒海也没干，你就说分离话， 翻过那脸皮不认得人。 你坐江山亏哪个？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "难道亏了你不成？"
        },
        {
          "character": "郑恩",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "可也不咱！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "亏了那五湖四海众宾朋。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "今日一枪，明日一刀，赵二哥的红拳——"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "打就的花世界，"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "老郑靴尖——"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "踏就了锦乾坤。 挣来的江山你柴家坐， 身登九五不认旧宾朋。 动不动你就把贤臣斩， 斩断了擎天柱一根。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "柴荣！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "你不会为王死了罢， 那天宫又降紫微星。 再若不会为王你与我请，请、请、请下了位，"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥来、来、来，你好相做得朝廷了。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "吾保你坐几年红脸的朝廷。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "坐不得。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "坐得。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "坐不得。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "叫你坐来你又不肯坐，"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥，你看兄弟可以坐得朝廷么？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你也坐不得。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "待俺老郑坐几年瞎眼的朝廷。 迈步儿就把这龙篷进，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖阴锣〗。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咳，坐不得吓！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "霎时头疼眼又昏。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "罢，二哥你来、来、来呀！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "倒不如打顿皮拳散了罢。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "散不得吓！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "各人归家各干各的旧营生。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "柴荣！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "你回去推你的车来，把你伞来卖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖阴锣一段〗。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "推车吓，车来了，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩推。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "推车贩伞，姓柴的人。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥，来、来、来呀！"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "你回关西路上，把你的光棍耍， 到那赌博场中，上一买么三，三下一买红，五六么快快快，也饿不死姓赵人。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟也有。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咱也有。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "咱回山西把香油卖，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖阴锣〗。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "卖油吓，卖油吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩挑。"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "惯卖香油郑子明。 咱——"
        },
        {
          "character": "郑恩",
          "type": "西皮快板",
          "text": "说着心头怒， 咱在龙篷打昏君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑恩打。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "三弟息怒，寡人赦了就是。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你赦了他，咱就饶了你。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "内侍，将高怀德赦回。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "高怀德赦回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德上。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "谢万岁不斩之恩。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "哪里是寡人不斩与你，念你二家千岁保奏不斩与你，下殿去罢。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "慢着。万岁，这打擂壮士，有功之人，大小还要封个官儿。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "寡人不斩他，也就罢了，哪里还封他官儿。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你可封不封？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "不封。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你不封，呸，咱就打！"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "三弟不要打，寡人封他就是了。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你封他，咱也不打你了，大大的封。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "唔！"
        },
        {
          "character": "柴荣",
          "type": "二黄导板",
          "text": "吾坐江山由不得吾，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤叫板。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "半由天子，"
        },
        {
          "character": "郑恩",
          "type": "唱",
          "text": "半由臣。"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "叫内侍看过了封官薄， 一一从头听朕封： 封你七品郎官为知县， 四品黄堂管庶民。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "我把你这昏君，当真昏了。他是个武将，怎么往文官部内封？"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "被三弟一鞭唬昏了。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "你这个胆量也不该坐朝廷。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "被他一鞭唬昏了， 吾武官当作文官封。 眉来眼去赵匡胤， 惯打寡人郑子明。 封你游击并参将，"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "小了，小了！"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "孤封你海外做总兵。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "咳，远了远了！"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "封你前殿司，"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "不要，不要。"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "一十二家总殿司。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "也不要。要同咱弟兄们一样。"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "孤封官职你嫌小， 难道怀德与你有什么故旧亲？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "说起亲来有亲，提起故来有故。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "何亲？何故？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "这故，昔日二哥下燕京，刺杀刘化王，高伯父的人头，作了人情，可算得一故。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "何亲？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "昨日在南宋府招了御妹，可算得一亲。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "早为何不奏？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "早奏，也免得咱弟兄们讨气了。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "咳，老王吓！"
        },
        {
          "character": "柴荣",
          "type": "唱",
          "text": "南宋府里招亲事， 杀父的冤仇报不成。 别的官员不封你， 封你万里侯陪伴寡人。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "谢恩，谢恩。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "叩罢头来谢罢恩， 谢过二家千岁讲人情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德下。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "去罢，去罢。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟哪里去？"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "回北平府去。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你我方才有欺君之罪，上殿请罪。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥请。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "臣等有欺君之罪，求万岁赦却。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "只要下次少打些就是。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "我的万岁爷，情是情，法是法，打是打，赦是要赦。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "恕卿无罪。"
        },
        {
          "character": "赵匡胤、郑恩",
          "type": "同白",
          "text": "谢主龙恩。朝事毕，请驾回宫。"
        },
        {
          "character": "柴荣",
          "type": "白",
          "text": "退班。"
        },
        {
          "character": "柴荣",
          "type": "念",
          "text": "寡人有道坐君王，三子李豹乱朝纲。"
        },
        {
          "character": "赵匡胤、郑恩",
          "type": "同念",
          "text": "天降怀德来打擂，五湖四海把名扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥来！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "三弟！"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "二哥，你道高妹夫这万里侯，亏着谁？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "亏了三弟。"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "也不亏咱，也不亏你，亏了这买卖三吓！"
        },
        {
          "character": "赵匡胤",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "郑恩",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、郑恩同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}