{
  "script_id": "02001028",
  "title": "米注山",
  "alias": [
    "清河桥"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "斗越椒",
      "hangdang": "净"
    },
    {
      "name": "养由基",
      "hangdang": "小生"
    },
    {
      "name": "大将乙",
      "hangdang": "丑"
    }
  ],
  "plot": "斗越椒杀死蒍贾，夺回剑印后，恨犹未消。乃乘势直攻楚庄王，所向无敌。庄王在高坡上督战，被斗越椒暗\n射一箭，险遭不测。庄王为免君臣互攻，贻笑外人起见，乃令老臣苏从往劝斗越椒息兵，亦无效果。庄王不\n得已，高挂免战牌，并在营门外揭出榜文，招求天下英雄豪杰。适养由基由罗泊帐下逃出，一见榜文，大为\n喜悦，当将榜文揭下，声称可擒斗越椒。庄王召见，并试令表演刀箭，无不出众。乃收却免战牌，令养由基\n出战，终将斗越椒射死云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "适才大战在荒丘， 一来一往统貔貅。 为王的打马高坡走， 擂鼓催军斩虎猴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒上。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "大喝一声如雷吼， 眉头一皱神鬼愁。 身披铠甲连环扣， 坐下战马赛龙游。 金枪一杆蛟龙走，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大将甲上，斗越椒、大将甲同开打。楚庄王下。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "来了一将白了头。 老将何必把势斗， 稳坐雕鞍听从头： 某与庄王结仇寇， 为的是金殿解印仇。 将军若肯卸甲胄， 不封王位定封侯。"
        },
        {
          "character": "大将甲",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "大将甲",
          "type": "唱",
          "text": "勒马停蹄骂反寇， 越椒匹夫听原由： 欺君罪恶该斩首， 管叫你一命丧荒丘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒打大将甲。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "昏王无道结仇寇， 某家言来听根由： 有日江山归吾手， 越椒早晚坐龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大将甲下。大将乙上。"
        },
        {
          "character": "大将乙",
          "type": "唱",
          "text": "丧家之犬学虎走， 泥鳅也想变龙游。 中国京剧戏考 《米注山》【四本】 2 山鸡焉敢把凤凰斗， 哈巴狗儿怎能滚绣球！"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "老爷勇战无对手， 拿住庄王报冤仇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒、大将乙同开打，大将乙下，斗越椒下。楚庄王上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "两下交兵日色不透， 尸横遍野血水流。 忙摧战鼓与贼斗， 拿住了逆贼把筋抽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王上高坡。斗贲凰上。"
        },
        {
          "character": "斗贲凰",
          "type": "唱",
          "text": "战鼓咚咚如雷吼， 旌旗招展半空游。 杀气昂昂威风抖，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大将甲、大将乙同上，大将甲、大将乙、斗贲凰同开打，大将甲、大将乙同下。"
        },
        {
          "character": "斗贲凰",
          "type": "唱",
          "text": "二将败阵走荒丘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗贲凰追下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "只杀得天昏地暗迷宇宙， 这乌鸦也不敢把翅收。 老天爷助我成功就， 拿住了逆贼剔骨熬油。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒上。"
        },
        {
          "character": "斗越椒",
          "type": "唱",
          "text": "豪杰阵前把志斗， 不知庄王何处投。 坐在雕鞍用目瞅， 高坡上一人戴冕旒。 老天爷助我成功就， 箭射庄王一命休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "斗越椒射。土地上，拥护。三朝臣、苏从同上，斗越椒下。土地下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "越椒本是英雄后， 一杆金枪赛龙游。 你看他越杀越勇实难斗， 杀得孤王无处投。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！ 启大王：斗越椒要战！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "报子",
          "type": "唱",
          "text": "大胆越椒太逞雄， 藐视孤王理难容。 免战高悬兵休动， 欺压我国少英雄。"
        },
        {
          "character": "三朝臣、苏从",
          "type": "同白",
          "text": "大王受惊了！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "适才孤王，在高坡之上，亲自擂鼓助阵。不想那斗越椒，暗放一箭。不是众卿 家保护，险遭不测。"
        },
        {
          "character": "三朝臣、苏从",
          "type": "同念",
          "text": "圣天子百灵拥护，"
        },
        {
          "character": "楚庄王",
          "type": "念",
          "text": "大将军八面威风！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "有人训说越椒来降，孤无忧也。"
        },
        {
          "character": "朝臣甲",
          "type": "白",
          "text": "他乃叛逆之臣，说他则甚？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "众卿家，不是这样讲。倘若外国闻知，我国君臣厮杀，其理不周。 中国京剧戏考 《米注山》【四本】 3"
        },
        {
          "character": "三朝臣",
          "type": "同白",
          "text": "真乃仁德之君。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "老臣愿往，训说越椒来降。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "老将军若去，须要小心。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "苏从",
          "type": "唱",
          "text": "好一个仁德楚庄王， 君臣厮杀理不当。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏从下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "训说越椒兵休动， 去了老将名苏从。 细想那斗氏三代功劳重， 东荡西除逞英雄。 孤王执掌楚国政， 也是我一时赏罚不公平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏从上。"
        },
        {
          "character": "苏从",
          "type": "唱",
          "text": "越椒反贼逆王命， 辜负我主羡恩荣。"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "老臣交旨。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "老将军，说降一事如何？"
        },
        {
          "character": "苏从",
          "type": "白",
          "text": "逆贼无礼，要与大王，决一死战。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "哎呀！这逆贼真乃可恶。待孤出下榜文，招聚天下英雄好汉，定要灭却此贼。 众卿家，后帐歇息去罢！"
        },
        {
          "character": "三朝臣、苏从",
          "type": "同白",
          "text": "谢大王！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三朝臣、苏从同下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "御林军，取黄绫照伺侯。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "“庄王榜示”。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "将这榜文悬挂营门以外，有人揭榜，速报孤王知道。掩门。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "呵呵呵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "养由基上。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "自幼生来八字差， 到处奔驰走天涯。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "俺养由基，乃远阳人氏。在罗泊帐下，当了一名步卒。可恨那贼，目不识人。 是俺逃出营来，闻听斗越椒，在朝谋反，杀了司马蒍贾。带领人马，搜宫杀院。 庄王回朝，出下榜文，招聚天下英雄。乃是俺好汉出头之日也。正是："
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "要为天下奇男子，须在世间立大功。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "时运不至困豪家， 罗泊看俺是小娃。 天边捞月如戏要， 下海拴龙何足夸。 男儿立志安天下， 要与皇王定邦家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王、四龙套同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "昨日阵前把仗打， 中国京剧戏考 《米注山》【四本】 4 越椒放箭射孤家。 不是为王的洪福大， 险些一命丧黄沙。 闷厌厌坐在宝帐下， 旌旃飘渺两眼花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基上。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "蛟龙无水困浅沙， 时运不至走天涯。 营门揭榜如戏耍， 见了大王把话答。"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "呔！你这小将，有何本领，擅揭黄榜！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "相烦通禀：就说养由基求见大王。"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "候着。 启大王：营门外有一小将揭榜。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "命他进来。"
        },
        {
          "character": "龙套甲",
          "type": "白",
          "text": "哦。 小将呢，大王命你进见，须要小心了。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "晓得。 大王在上，小人叩头。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "小将家住哪里，姓甚名谁，有何本领，敢揭孤的黄榜？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "小人养由基，乃远阳人氏。自幼学习一十八般武艺，件件皆能。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "那斗越椒，甚是骁勇，你敢前去对敌？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "大王吓！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "一颗明珠土内藏， 数载未曾放毫光。 越椒他是英雄将， 铁打的金钢碍何妨。 眼前若有千岁令， 管叫逆贼丧无常。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "那贼子恶箭伤人。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "小人能射凤凰夺窝。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "何为凤凰夺窝？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "小人能射五箭，箭劈箭杆。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤王不信，下帐演来。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "大王帐内把令传下， 看视某家演箭法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "一见小将喜气发， 亚赛当年小哪吒。 御林军与孤带过马， 看视小将演箭法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王上高坡，坐。养由基上，射。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "两手弓开如月牙， 射转乾坤定邦家。"
        },
        {
          "character": "楚庄王",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "怪不得小将把口夸， 凤凰夺窝果不差。 此乃是孤王的洪福大， 天遣小将把贼拿。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "你用什么兵器？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "青铜刀。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "好，耍来孤王观看。 中国京剧戏考 《米注山》【四本】 5"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基耍刀。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "奉王旨意把刀耍， 困龙从此襄天涯。 青铜大刀安天下， 定把越椒父子拿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基耍刀。"
        },
        {
          "character": "楚庄王",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "不要耍了。孤王赐你银盔银甲，命你大战斗越椒。快走快走。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王帐内把令发， 大小三军听根芽： 免战不用营外挂， 只等小将把贼拿。 拿住了逆贼碎尸万剐， 将他九族尽灭正孤的王法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王、四龙套同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}