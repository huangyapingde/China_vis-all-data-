          "text": "宇文成都拐三四。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "娃娃，你这是练就的功夫，算不了什么！"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "哦，算不了什么？"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "算不了什么！"
        },
