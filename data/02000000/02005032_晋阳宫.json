{
  "script_id": "02005032",
  "title": "晋阳宫",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李元霸",
      "hangdang": "武生，黑脸金眉，雷公嘴，公子头，黑线穗子，黑龙箭袖，杏黄花褶子"
    },
    {
      "name": "杨广",
      "hangdang": "净"
    },
    {
      "name": "李渊",
      "hangdang": "老生"
    },
    {
      "name": "宇文成都",
      "hangdang": "净"
    },
    {
      "name": "窦氏",
      "hangdang": "老旦"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "李建成",
      "hangdang": "丑"
    },
    {
      "name": "李元吉",
      "hangdang": "丑"
    }
  ],
  "plot": "隋炀帝听宇文化及之言，令李渊在三月内兴建晋阳宫，否则全家问斩。李世民正焦灼无计时，袁天罡乃荐李\n淳风会同建筑，邀请鲁班诸神及搬运鬼工，未及一月即行完工。隋炀帝到后，本拟嘉奖李渊，宇文化及又从\n中陷害，隋炀帝遂下令将李渊斩首。李世民闻信后，随即击龙鼓申冤。隋炀帝见其年幼胆大，且所言各节，\n均甚有理。不但赦免李渊，反认李世民为义子，封为秦王。其大哥及三弟、四弟亦均封王，可谓因祸得福云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、大太监、杨广同上。"
        },
        {
          "character": "杨广",
          "type": "引子",
          "text": "孤王坐龙朝，每日里，快乐逍遥。"
        },
        {
          "character": "杨广",
          "type": "念",
          "text": "自从孤王坐龙楼，四方军起战不休。但愿扫灭群雄寇，一统山河乐无忧。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "孤大隋杨广。自孤登基以来，风调雨顺，国泰民安。这且不言。孤王有意驾下 扬州，亦曾命宇文丞相预备龙船，不知可曾齐备。 内侍。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "宣宇文丞相上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 万岁有旨：宣宇文丞相上殿。"
        },
        {
          "character": "宇文化及",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宇文化及上。"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "臣宇文化及见驾，陛下万岁！"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "万万岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "寡人有意驾下扬州，龙船可曾齐备？"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "臣早已打发民夫十万，已至龙池。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "龙池哪里所管？"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "太原所管。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "想太原乃李渊镇守，寡人无计杀害。"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "万岁要杀李渊，在此一举。命他修盖晋阳宫一座，照我长安禁地一样，命他三 个月完工。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "倘若三个月工程不完？"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "万岁传旨，将他斩首。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "倘若完了工呢？"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "就说他先造成了的，有谋反之意，将他斩首，也还不迟。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "卿家替孤修诏。"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宇文化及写旨。〖牌子〗。"
        },
        {
          "character": "宇文化及",
          "type": "stage",
          "text": "中国京剧戏考 《晋阳宫》【头本】 2"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "修诏已毕，万岁传旨。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "李渊吓李渊！寡人这道旨意一去，管叫你性命难保。 内侍，命你去到太原，晓谕李渊，不得有误。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "臣启万岁：驾下扬州，何臣保驾？"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "孤驾前有众将保驾无事。"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "想四方军起，天下荒荒，各霸一方，必须找一无敌上将，保护龙驾无事。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "这样人哪里有？"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "想臣子成都，那年在南阳关杀败伍云召百万雄兵，可以算得无敌上将，保护龙 驾无事。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "卿家传旨，宣成都上殿。"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "臣领旨。 万岁有旨：宣宇文成都上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宇文成都上。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "领旨！"
        },
        {
          "character": "宇文成都",
          "type": "念",
          "text": "风吹荷叶千层浪，拳打猛虎谁敢当！"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "臣子宇文成都见驾，吾皇万岁！"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "万万岁。宣臣子上殿。万岁有何圣谕。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "寡人有意驾下扬州，你父言道命你保孤前去，但不知你有何武艺？"
        },
        {
          "character": "宇文成都",
          "type": "念",
          "text": "臣两膀膂力似重瞳，全凭金镋逞威风。上阵未有三合将，谁敢与臣来争锋！"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "孤命众将在殿前与你比武，你意如何？"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "就请万岁传旨。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "小爱卿殿下伺候。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "臣子领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宇文成都下。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "内侍宣诏，众将上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 万岁有旨：宣众将上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大将同上。"
        },
        {
          "character": "四大将",
          "type": "同白",
          "text": "领旨！ 臣等见驾，吾皇万岁。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "孤命你等在殿前与宇文成都比武，殿下伺候。"
        },
        {
          "character": "四大将",
          "type": "同白",
          "text": "臣等领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大将同下。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "内侍，宣宇文成都上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 万岁有旨：宣宇文成都上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宇文成都上。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "领旨！ 参见万岁。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "命小爱卿在殿前与众将比武，不得违误。"
        },
        {
          "character": "宇文成都",
          "type": "白",
          "text": "领旨。 呔！殿前众将听者：哪一个有胆量，与俺比武来。"
        },
        {
          "character": "四大将",
          "type": "内同白",
          "text": "俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大将同上。宇文成都、四大将同起打。四大将同倒。宇文成都三笑。"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "看众将不胜小爱卿之器械，真乃无敌上将。封卿以为天保无敌大将军，你父子 回府披挂，候驾起程，退班。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、大太监、杨广自两边分下。"
        },
        {
          "character": "宇文化及、宇文成都",
          "type": "同白",
          "text": "请驾回宫！"
        },
        {
          "character": "宇文化及",
          "type": "白",
          "text": "无敌大将军儿，随为父来呀！ 中国京剧戏考 《晋阳宫》【头本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宇文化及笑。宇文化及、宇文成都同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "紫阳真人上，童儿持锤暗上。"
        },
        {
          "character": "紫阳真人",
          "type": "引子",
          "text": "法术无穷玄机妙，修真养性苦用功。"
        },
        {
          "character": "紫阳真人",
          "type": "念",
          "text": "昔日莲台打坐，今朝要显术学。算就天文地理，暗定唐室山河。"
        },
        {
          "character": "紫阳真人",
          "type": "白",
          "text": "山人紫阳真人。自幼修真养性，要成正果。只因大隋杨广无道，天下荒荒，真 主当兴，大隋气尽。唐室李渊，有九五之尊。我不免前去，将紫金铜锤传授铁 石星君，后来他保护大唐天下。 童儿！"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "紫阳真人",
          "type": "白",
          "text": "随我前往太原去者。"
        },
        {
          "character": "紫阳真人",
          "type": "西皮摇板",
          "text": "大隋江山当气尽，⑴ 天下荒荒不太平。 大唐理应承天运， 前去点化铁石星。 童儿与我把路引，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿下。"
        },
        {
          "character": "紫阳真人",
          "type": "西皮摇板",
          "text": "赐他金锤扫奸臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫阳真人下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李元霸上。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "啊哈！"
        },
        {
          "character": "李元霸",
          "type": "念",
          "text": "我父在朝纲，威名谁敢当。两膀千斤力，何日把名扬？"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "俺李元霸，我父李渊，身授太原侯。只因朝中奸臣当道，我父告职还乡，恐怕 俺在外面生事，将我圈在花园，好不闷杀人也！"
        },
        {
          "character": "李元霸",
          "type": "西皮摇板",
          "text": "每日花园心烦闷， 不能外面去散心。 霎时一阵心倦困，"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "咳好困哪！"
        },
        {
          "character": "李元霸",
          "type": "西皮摇板",
          "text": "打睡片刻困沉沉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫阳真人、童儿同上。"
        },
        {
          "character": "紫阳真人",
          "type": "西皮摇板",
          "text": "隋尽唐兴社稷整， 群雄谋反乱乾坤。 趁风且把花园进， 唤醒星君说原因。"
        },
        {
          "character": "紫阳真人",
          "type": "白",
          "text": "元霸醒来！"
        },
        {
          "character": "李元霸",
          "type": "西皮摇板",
          "text": "耳旁听得人唤应，"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "李元霸",
          "type": "西皮摇板",
          "text": "面前站定一道人。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "呔！哪里来的野道，擅进花园，是何道理？"
        },
        {
          "character": "紫阳真人",
          "type": "白",
          "text": "啊元霸，不可喊叫，山人我是你师父，乃紫阳真人是也。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "哦原来师父到了，到此何事？"
        },
        {
          "character": "紫阳真人",
          "type": "白",
          "text": "只因杨广无道，你父后来有九五之尊。山人特地前来，将这紫金锤传授与你。 有仙丹一粒，吃在腹内。我有一言嘱咐与你：若遇黄脸之人，千万不可伤他性 命，后来还有用他之处，记下了。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "多谢师父，弟子遵命。"
        },
        {
          "character": "紫阳真人",
          "type": "白",
          "text": "元霸你看那旁有人来了。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "紫阳真人",
          "type": "白",
          "text": "在那里。 中国京剧戏考 《晋阳宫》【头本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "紫阳真人、童儿同下。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "看师父已去，待我望空一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "咳！俺不免演习金锤一番便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李元霸耍锤，三笑。"
        },
        {
          "character": "李元霸",
          "type": "白",
          "text": "哎，有了这身武艺，何愁大隋不灭！不免去到前厅，说明真人赐锤之事便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李元霸下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李渊上，院子暗上。"
        },
        {
          "character": "李渊",
          "type": "引子",
          "text": "告职回太原，居家乐安然。"
        },
        {
          "character": "李渊",
          "type": "念",
          "text": "忆昔当年临潼山，我与杨广结仇冤。多亏神圣来保佑，本爵才得回太原。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "本爵李渊，大隋炀帝驾前为臣，官居太原侯。先王晏驾，杨广篡位，朝中又有 奸臣当道，是俺早已告职还乡，倒也安然自在。今日闲暇无事，不免请出夫人， 一同饮宴。 家院。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "有请夫人、公子出堂。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。 有请夫人、公子出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李建成、李元吉、李世民、窦氏同上。"
        },
        {
          "character": "窦氏",
          "type": "念",
