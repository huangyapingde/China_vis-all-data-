        },
        {
          "character": "李渊",
          "type": "白",
          "text": "谢万岁不斩之恩！"
        },
        {
          "character": "杨广",
          "type": "白",
          "text": "非是寡人不斩与你，你儿执意讲情，但不知你府中还有几子？"
