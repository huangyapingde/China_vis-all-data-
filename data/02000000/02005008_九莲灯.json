      "name": "第一场",
      "utterances": [
        {
          "character": "闵远",
          "type": "内西皮导板",
          "text": "独自一身往前奔， 中国京剧戏考 《九莲灯》【三本】 2"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵远上。"
        },
        {
          "character": "闵远",
          "type": "西皮正板",
          "text": "一心只要奔都城。 此去吉凶难定准， 成败祸福任苍穹。 傅奴去闯阴阳界， 安心要请九莲灯。 催马气喘心不定， 只觉遍体骨肉疼。 只为尽孝奔路径，"
        },
        {
          "character": "闵远",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "闵远",
          "type": "唱",
          "text": "眼黑头昏不安宁。"
        },
        {
          "character": "闵远",
          "type": "白",
          "text": "小生姓闵名远，字玉良。傅奴去往昆仑山仙果洞，拜求九莲灯。路过阴阳界， 未知能否过去。若过不去，不知等到何时，才能回来。昨晚夜宿古庙，神圣惊 梦。是我思念天伦，南牢生死未定。看前面有一村庄，只得催马到了那里，下 马歇息歇息再行。就此马上加鞭。"
        },
        {
          "character": "闵远",
          "type": "西皮二六板",
          "text": "春夏秋冬四季分， 功名何必苦劳心。 闲来曲指寻坟算， 土下人多土上人。 一阵昏迷心难忍，"
        },
        {
          "character": "闵远",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "闵远",
          "type": "唱",
          "text": "精神散乱为何情？"
        },
        {
          "character": "闵远",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵远病，下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟、单彩屏同上。"
        },
        {
          "character": "单彩屏",
          "type": "引子",
          "text": "孝子是王祥，烈女是孟姜。"
        },
        {
          "character": "单彩屏",
          "type": "念",
          "text": "终朝描凤费辛勤，绣阁闷坏女钗裙。堪叹人生在世景，光阴似箭日月轮。"
        },
        {
          "character": "单彩屏",
          "type": "白",
          "text": "奴家单彩屏。年方一十八岁。爹爹单有缘，所生兄妹二人。爹爹年迈，心慈好 善，念佛看经。母亲郑氏，前数载亡故。只撇得兄妹二人。兄长单洪，年交二 十一岁，性烈刚强，专好习武。这且不言。母亲去世数载光景，思想起来好不 伤感奴也。"
        },
        {
          "character": "单彩屏",
          "type": "二黄正板",
          "text": "想起了我的母心内酸痛， 不由得一阵阵珠泪盈盈。 叹娘亲遭不幸命归幽境， 撇下了父儿女甚是惨情。 可叹我女钗裙缺母照应， 终日里想亲娘睡卧不宁。 虽说是父与兄痛爱深重， 总不如萱堂在有恃无恐。"
        },
        {
          "character": "单彩屏",
          "type": "白",
          "text": "丫鬟。"
        },
        {
          "character": "二丫鬟",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "单彩屏",
          "type": "白",
          "text": "看天色已晚，你二人安歇去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "二丫鬟",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二丫鬟同下。"
        },
        {
          "character": "单彩屏",
          "type": "哭",
          "text": "哎呀娘吓！"
        },
        {
          "character": "单彩屏",
          "type": "二黄正板",
          "text": "可叹亲娘早命染， 女有委屈对谁言？ 越思越想心好惨， 秋波杏眼泪连连。 中国京剧戏考 《九莲灯》【三本】 3 又悲又痛迟吁叹， 双眉皱锁带愁烦。 眼看夜深天色晚，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "单彩屏",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "单彩屏",
          "type": "二黄正板",
          "text": "谯楼已交三更天。 不觉一时身困倦， 牙床之上睡安眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单彩屏困，入帐子。〖阴锣〗。烟火。虎形上，扑帐子。"
        },
        {
          "character": "单彩屏",
          "type": "二黄导板",
          "text": "耳旁听得风狂荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "烟火。"
        },
        {
          "character": "单彩屏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "单彩屏",
          "type": "唱",
          "text": "见一猛虎煞气昂。 双睛一瞪魂胆丧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形追小圆场，虎形下。单彩屏怕。"
        },
        {
          "character": "单彩屏",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "单彩屏",
          "type": "唱",
          "text": "霎时吓倒在床旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单彩屏入帐子。〖起四更鼓〗。二丫鬟同上。"
        },
        {
          "character": "二丫鬟",
