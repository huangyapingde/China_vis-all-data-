{
  "script_id": "02007030",
  "title": "目莲记",
  "alias": [
    "五瘟路"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "大瘟神",
      "hangdang": "净"
    }
  ],
  "plot": "罗卜之父傅斋公在世，不但信佛甚笃，对其他神祇，亦均焚香供养。五瘟神赫赫相公兄弟，即其一例。傅斋\n公死后，刘青提认为行善并无善报，乃破戒开荤，打僧骂道，将五瘟神兄弟牌位一律毁弃。刘青提恶贯满盈，\n死期将至之前，赫赫相公兄弟闻讯，乃前来报复云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "大瘟神上，拉挑。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "身在荒凉，身在荒凉， 阴司作伤亡。 或在平川地， 或在险峻岗， 或在孤村里， 或在官道旁。 恶妇阳寿满， 降祸又降殃，降祸又降殃。"
        },
        {
          "character": "大瘟神",
          "type": "念",
          "text": "咱是西方一魔头，乍寒乍热把筋抽。怎奈恶妇真无礼，这番叫她一命休！"
        },
        {
          "character": "大瘟神",
          "type": "白",
          "text": "吾乃赫赫相公是也。当日傅斋公在日，将俺兄弟五人的牌位，供在当中，进献 斋仪素供，焚化银锭钱纸。自从斋公升天去后，刘青提将俺五人的牌位，摔在 一旁。她也不瞅，她也不睬。今当她阳寿将终，我不免招聚众家兄弟，一同前 去！"
        },
        {
          "character": "大瘟神",
          "type": "念长声",
          "text": "魔障他——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大瘟神招。"
        },
        {
          "character": "大瘟神",
          "type": "念长声",
          "text": "伤亡吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小瘟神双上。"
        },
        {
          "character": "四小瘟神",
          "type": "同念长声",
          "text": "伤亡吓，伤亡吓！"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "伤亡身，伤亡身， 乍寒乍热苦难禁。 时高遇我供供手， 运低逢我降灾星。 听得到，听得到， 兄弟们都来到。 或在山林中， 或在古神庙。 伸一伸，头脑疼， 缩一缩，魂都掉。 缩一缩，魂都掉。"
        },
        {
          "character": "四小瘟神",
          "type": "同念长声",
          "text": "伤亡吓！"
        },
        {
          "character": "四小瘟神",
          "type": "同白",
          "text": "大哥招我们出来，有何吩咐？"
        },
        {
          "character": "大瘟神",
          "type": "白",
          "text": "众兄弟。"
        },
        {
          "character": "四小瘟神",
          "type": "同白",
          "text": "大哥。"
        },
        {
          "character": "大瘟神",
          "type": "白",
          "text": "当日傅斋公在日，将你我五人的牌位，供在当中。自从傅斋公亡故，将你我五 人的牌位，摔在一旁，她也不瞅，她也不睬。今当她阳寿将终，特邀你们到此， 一同前去！"
        },
        {
          "character": "大瘟神",
          "type": "念长声",
          "text": "要魔障她。"
        },
        {
          "character": "四小瘟神",
          "type": "同白",
          "text": "我们前去—— 中国京剧戏考 《目莲记》【三本】 2"
        },
        {
          "character": "四小瘟神",
          "type": "同念长声",
          "text": "魔障她。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "众兄弟，你们听哥说之，"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "众兄弟，我们听哥说之。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "刘青提，她冒犯了天威，"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "刘青提，她冒犯了天威。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "你们各自用心机，"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "是我们各自用心机。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "把一个躲在她的门外， 把一个躲在她的门里。 把一个躲在她的床上， 把一个躲在她的床底。"
        },
        {
          "character": "大瘟神",
          "type": "夹白",
          "text": "众兄弟——"
        },
        {
          "character": "大瘟神、四小瘟神",
          "type": "同鬼令",
          "text": "急忙前去， 不可迟滞。 管教她魄散与魂飞。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "忒叵奈，刘氏青提， 违誓愿，杀害猪鸡。 今朝祸到难逃避，"
        },
        {
          "character": "小瘟神甲",
          "type": "鬼令",
          "text": "我去剜她的一脑髓，"
        },
        {
          "character": "小瘟神乙",
          "type": "鬼令",
          "text": "我去抽她的一肚肠。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "弄得她，活不活，死不死，苦楚难支。"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "吓，活不活，死不死，苦楚难支。"
        },
        {
          "character": "大瘟神",
          "type": "夹白",
          "text": "众兄弟——"
        },
        {
          "character": "大瘟神、四小瘟神",
          "type": "同鬼令",
          "text": "急忙前去， 不可迟滞， 管教她魄散与魂飞。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "堪叹世人不得善良，"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "吓，不得善良。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "作恶的人儿没了下场。"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "吓，没了下场。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "怎禁得不改过恶心肠， 这个狠，那个狠，苦楚难当。"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "吓，苦楚难当。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "悄悄行过小村庄，"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "悄悄行过小村庄。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "休惹得，休惹得，犬吠㕵㕵，"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "犬吠㕵㕵。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "行善的，到阴司， 过金桥，过银桥， 逍遥路，请他升天。"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "作恶的，到阴司， 上刀山，下油锅， 锯来解，磨来碾， 倒肚抽肠。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "不恓惶处也恓惶。"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "不恓惶处也恓惶。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "我要她头上疼，"
        },
        {
          "character": "小瘟神甲",
          "type": "鬼令",
          "text": "我有金钢钻。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "我要她背上痛，"
        },
        {
          "character": "小瘟神乙",
          "type": "鬼令",
          "text": "我有铜锤揎。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "我要她身上寒， 中国京剧戏考 《目莲记》【三本】 3"
        },
        {
          "character": "小瘟神丙",
          "type": "鬼令",
          "text": "我有凉风扇。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "我要她身上热，"
        },
        {
          "character": "小瘟神丁",
          "type": "鬼令",
          "text": "我有火桶罐。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "我要她肚里疼，"
        },
        {
          "character": "四小瘟神",
          "type": "同白",
          "text": "俱用抽肠断。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "头上痛，"
        },
        {
          "character": "小瘟神甲",
          "type": "鬼令",
          "text": "金钢钻。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "背上痛，"
        },
        {
          "character": "小瘟神乙",
          "type": "鬼令",
          "text": "钢锤揎。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "身上寒，"
        },
        {
          "character": "小瘟神丙",
          "type": "鬼令",
          "text": "凉风扇。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "身上热，"
        },
        {
          "character": "小瘟神丁",
          "type": "鬼令",
          "text": "火桶罐。"
        },
        {
          "character": "大瘟神",
          "type": "鬼令",
          "text": "肚里疼，"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "抽肠断。"
        },
        {
          "character": "大瘟神、四小瘟神",
          "type": "同鬼令",
          "text": "铜锤铁扇齐举起， 管叫刘氏真魂散。 齐举起， 管叫刘氏真魂散。"
        },
        {
          "character": "大瘟神",
          "type": "白",
          "text": "众兄弟。为哥的也乏了。你们攒起手轿来，抬我走一程。"
        },
        {
          "character": "四小瘟神",
          "type": "同白",
          "text": "使得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小瘟神同架大瘟神。"
        },
        {
          "character": "四小瘟神",
          "type": "同鬼令",
          "text": "劝世人，早念阿弥， 行善事，奉敬神祇。 空中报应无差疑， 恶业相缠不放伊，细察取。 为善之人，自有善神相助， 作恶之人，自有恶鬼相随。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小瘟神同放大瘟神在地，同惊。四小瘟神自两边分下。大瘟神起，招。"
        },
        {
          "character": "大瘟神",
          "type": "念长声",
          "text": "伤亡吓，伤亡吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小瘟神双上。"
        },
        {
          "character": "四小瘟神",
          "type": "同念长声",
          "text": "伤亡吓，伤亡吓。"
        },
        {
          "character": "四小瘟神",
          "type": "同白",
          "text": "好厉害犬哪！"
        },
        {
          "character": "大瘟神",
          "type": "白",
          "text": "大家前去。"
        },
        {
          "character": "大瘟神、四小瘟神",
          "type": "同金钱花",
          "text": "青提实恶难当，难当， 如今寿数终阳，终阳。 劝君莫使歹心肠， 头顶上有三光。"
        },
        {
          "character": "四小瘟神",
          "type": "同白",
          "text": "已到花园。"
        },
        {
          "character": "大瘟神",
          "type": "白",
          "text": "越墙而过。"
        },
        {
          "character": "大瘟神、四小瘟神",
          "type": "同白",
          "text": "远远望见青提来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大瘟神上高座，四小瘟神同立下座等。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}