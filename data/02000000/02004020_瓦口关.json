{
  "script_id": "02004020",
  "title": "瓦口关",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "张郃",
      "hangdang": "净"
    },
    {
      "name": "魏延",
      "hangdang": "净"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "丑将甲",
      "hangdang": "丑"
    },
    {
      "name": "丑将乙",
      "hangdang": "丑"
    }
  ],
  "plot": "张飞镇守巴西，张郃奉曹洪命，前往进攻，屯兵瓦口关。张飞除命雷同阵后埋伏外，亲自应战。前后夹攻，\n张郃不得已，退回岩渠山，不再出战。且当张飞骂阵时，即在高处饮酒，表示闲雅镇静，刺激张飞。张飞无\n奈，亦每日饮酒。刘备派来之探事官，见张飞每日饮酒，恐误大事，乃面报刘备。刘备大惊，令诸葛亮速派\n人相助。诸葛亮听后，不但不想派人，且反令选购美酒，由魏延押运前方。张飞见酒后，一面派雷同、魏延，\n左右埋伏，一面更令将士亦大饮特饮。张郃遥见张飞军中混乱情形，乘机前来劫寨。张飞、魏延、雷同四\n面围攻，张郃大败，狼狈逃走。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠同上，同站门，曹洪上。"
        },
        {
          "character": "曹洪",
          "type": "引子",
          "text": "虎头金印，镇长安，剑气纵横。"
        },
        {
          "character": "曹洪",
          "type": "念",
          "text": "丞相精忠佐汉朝，英雄得志绣旗飘。何年卸甲辞金阙，不动腰间七宝刀。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "本帅曹洪。奉曹丞相钧命，前往护守东川。昨日马超遣部将兵出葭萌关，被某 战败。今闻巴西守将张飞兵屯下办地方，欲来取关。此事不可忽略。左将军张 郃在此镇守已久，必知详细。 左右，传左将军张郃进帐！"
        },
        {
          "character": "四红文堂、四红大铠",
          "type": "同白",
          "text": "张郃进帐。"
        },
        {
          "character": "张郃",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃上。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "袁绍无谋事不成，英雄弃暗俺投明。曹家承运钟汉鼎，赢得今朝豪杰名。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张郃参！"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "将军少礼。请座！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "谢座。传末将进帐，有何将令？"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "只因巴西守将张飞兵屯下办，必来侵犯东川。将军熟习此地路径，应当如何抵 御？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "兵以先发制胜。俺虽不才，愿领本部兵马先取巴西地方，直捣成都。何虑张飞 之有！"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "将军此言差矣。那张飞勇冠三军，非此等闲。将军虽然猛勇，只恐难以轻进。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "元帅差矣！人皆惧怕张飞，俺却视他如同小儿。此番出兵，必要生擒此人也！"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "接战斗勇数百阵， 何惧张飞武艺能！ 此番不但必定胜， 鞭稍一指西蜀平。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "话虽如此，倘有疎失，有伤我军锐气。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "若有疎失，敢当军令。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "军中无有戏言。你既要去，可立下军令状。得胜回来，本帅这条玉带乃圣上所 赐，情愿送与将军。将军若有疎失，定以军法从事。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "遵命。 看纸墨文房四宝伺候！"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "丈夫一言重九鼎， 提笔书写气风云。 此去只看红旗信， 军状元帅且收存。"
        },
        {
          "character": "曹洪",
          "type": "唱",
          "text": "将军志壮甚可敬， 但愿马到便成功。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "张将军听令！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "命你带领本队人马收取巴西。小心在意！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "得令！ 马来！"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "跨马提枪威风凛，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂同带马下。"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "何必叮咛说小心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃下。"
        },
        {
          "character": "曹洪",
          "type": "唱",
          "text": "张郃此去难拿稳， 把守关隘防川兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪、四红大铠自两边分下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "雷同上。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "马来！ 俺西川张将军麾下副将雷同是也。奉令打探曹洪军情，今闻张郃领兵前来瓦口 关，欲图巴西。只得飞马回营，报知主将便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。雷同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四蓝大铠、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "点绛唇",
          "text": "阆中守将，义照三光，忠心朗，汉室惆怅，恨曹瞒横张。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "良将古今有几人，岂贪残生剪横争！谁似桃园忠义气，饶他愚妇也知名。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "俺张飞。自桃园结义以来，在荆州请了孔明军师。老张在巴州义收严颜，得了 西川。奉令镇守巴西阆中。闻得曹洪兵出汉中，未知真假。亦曾命雷同前去探 听。且待他回来，便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷同上。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "走哇！ 将军在上。雷同交令。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "命你打听曹洪之事如何？"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "末将奉令打听，果然曹洪命张郃领兵已出汉中，扎营岩渠寨，屯兵瓦口关，欲 来夺取巴西。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔张郃小儿，敢来犯俺边界。传令众将前去迎敌那贼。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "且慢！阆中地恶山险，正好埋伏。将军领兵出战，末将带兵抄其后面，两下夹 攻，可擒那张郃。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "此计甚好。命你带兵先去埋伏。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷同下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！ 张郃讨战。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "带马伺候。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "镇守阆中多名望， 黎民爱某三军强。 张郃擅敢行狂妄，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝大铠、四蓝文堂同带枪带马下。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "叫儿血染点钢枪！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。四红文堂、四下手、张郃、四蓝大铠、四蓝文堂、张飞同上，同会阵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔张郃。尔明知你三爹爹镇守在此，你敢前来送死！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "张飞！俺奉魏王之命，前来收取西蜀。劝你好好下马归降，献了阆中，饶你性 命！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔张郃。你可知道你三爹爹历来之事？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "唗！俺乃堂堂大将，不知无名小卒！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔张郃。儿稳坐雕鞍，听你三爹爹道来！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "皇叔、关、张离范阳，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "俺初破黄巾姓名扬。 怒鞭督邮惊奸党， 虎牢关前显老张。 长板坡前能挡百万将， 那时儿似犬与羊。 曹操见俺魂魄丧， 何况你无知小儿郎！"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "老爷河北称名将， 血战功劳扶魏王。 今日相逢逃休想， 十合之内枪下亡！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "死活不知敢乱讲，"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "抖擞威风看谁强！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、张郃同起打，众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、雷同同上。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "俺、雷同。奉三将军之命，抄杀张郃后阵劫杀。 众将官。杀上前去。 （四文堂、雷同同下。张飞、张郃同上，同起打。雷同暗上，杀。张郃败下。张飞、雷同同追下。四红文堂、 张郃同上。）"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "且住！张飞杀法骁勇，正在难敌。又遇雷同后面杀来，难以敌挡。 众将官！退回岩渠山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张郃、四红文堂同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、张飞、雷同同上。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "张郃败岩渠山去了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "向前攻打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖锣鼓〗。内挂免战牌。"
        },
        {
          "character": "雷同",
          "type": "白",
          "text": "张郃挂了免战牌。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔张郃！儿夸了大口，被咱老子杀得免战牌高悬。 众将官，暂将人马退回，少时再来攻打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、雷同同下。张飞三笑，下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、二小军、张郃同上。"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "只说张飞一卤莽， 谁知智勇非寻常。 不该夸口写军状， 败回难对众儿郎。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "且住！虽然免战牌高悬，张飞退去，少时必来骂战。 众将官！"
        },
        {
          "character": "四红文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "俺如今只得紧守山寨，多备滚木雷石，守山不战。俺每日山头饮酒作乐，等他 粮尽自然退去。那时下山追杀张飞，谅他难逃此计也！"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "停兵不战高山上， 多置炮石谨守防。 吹打饮酒且欢畅， 他岂奈我何有主张。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张郃上桌子。斜摆山子石。张郃饮酒。四蓝文堂、二丑将、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "适才一战真豪爽， 智比军师勇霸王。 歇息前来将山抢，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "只见张郃饮猖狂。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔张郃！你自称英雄，今日为何不敢出战？"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "三军的！斟酒来！"
        },
        {
          "character": "四红文堂",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "想那张飞乃是一勇之夫，倘来讨战，不用管他，只管饮酒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，张郃好欺人也！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "曹操奸雄枉用将， 装聋作哑酒饭囊。 张某说来儿细想， 那缩头龟儿比你强！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "斟酒来！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "吓，这厮可恶！"
        },
        {
          "character": "丑将甲",
          "type": "白",
          "text": "啊啊不错不错。桃园结义，大破黄巾，是几时怕过人的！你这忘八羔子既怕出 战，该当早降。如今战又不战，降又不降，要我们老爷劳唇劳舌叫骂。你若知 天命，快些下山投降。稍若迟延，三爹爹一怒，便骑坐下马追曹操。杀你们曹 操的祖宗！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "骂得好！骂得痛快呀！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "吓，这厮骂得可恶。 三军的咱们也骂！"
        },
        {
          "character": "小军甲",
          "type": "白",
          "text": "呔，下面听者！你说不怕人，怎么抛徐州，败当阳，奔夏口？如今得了区区西 川之地，自称大头子。晓得俺张将军今日不战，自有妙计破你巴西。劝你们早 早退兵，免作刀头之鬼！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "张郃无能空狂妄， 骂死不出气老张。 眉头一皱心暗想，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "何用妙计要假装。 三军暂且回营往，"
        },
        {
          "character": "二丑将",
          "type": "同白",
          "text": "啊便宜你们！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、二丑将同下。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "俺也去饮酒醉颠狂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞三笑，下。"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "张飞不能将山上， 酒且消停再商量。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "哈哈！张飞果然退去。 众将官。好生把守山寨，打听张飞撤兵即便追杀。"
        },
        {
          "character": "张郃",
          "type": "唱",
          "text": "三军暂且归营帐， 把守山寨要紧防。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "马来！ 俺西川刘主驾下探事官是也。今有张将军大战张郃，每日开营饮酒，醉骂不休。 恐误大事，只得飞马报与主公知道。 马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。报子下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、刘备、诸葛亮同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "鱼龙归大海，鸿鹄上青云。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "鞠躬扶刘主，尽瘁报汉朝。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公在上，诸葛亮参！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生少礼。请坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请问军师：吾三弟出兵巴西去抵张郃，未知胜负。却当如何接应方好？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且候探马报来，再作计较。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！ 启主公、军师：张郃被三将军杀败岩渠山寨，并不下山。三将军连日饮酒大醉， 坐据山前辱骂。只恐有误大事。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓，这还了得。再去打听！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "喴呀三弟如何这等贪杯？岂不误事！先生快些差人前去救应方好。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哈哈。原来三将军如此贪杯。军前恐无好酒，不能尽量。成都佳酿极少，吩咐 可将五十瓮装作四车，送到军前与三将军痛饮。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊啊先生。吾三弟自来饮酒误事，军师何故还送酒与他，却是不解。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哈哈哈。主公与翼德做了多年弟兄，还不知其为人。那翼德虽是刚强，前于收 川之时，义释严颜，此非勇夫所为也。今与张郃相踞五十馀日，酒醉之后便坐 山前辱骂，旁若无人。此非贪杯，乃败张郃之计也。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "虽然如此，未见真假，到底不可大意。必须命魏延前往助之，才可放心。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公既然忧虑，着魏延前去亦可。 来。传魏延进见。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "魏延进见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延上。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "来也！"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "智在精忠胆，勇凭斩将刀。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "魏延参见主公、军师！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将军少礼。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "唤末将有何将令？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "命你押解美酒五十瓮，前赴张翼德军中。车上可插黄旗，大书军前公用美酒。 照此即速前去，不得有误。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "魏延",
          "type": "念",
          "text": "助战擒曹将，赐酒壮军威。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "魏延解酒前去，可能保得无事？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公但放宽心。魏延此去，三将军必破张郃也。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "但愿如此。请先生到后帐议事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "曾记昔年打曹豹，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "偏能今日破张郃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、诸葛亮、四文堂同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第十场",
      "utterances": [
        {
          "character": "张飞",
          "type": "内西皮导板",
          "text": "怒气不息三千丈，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、二丑将、张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "张郃不战又不降。 五十馀日酒拚量， 贼偏乖巧不受诓。 闷恹恹且坐军中帐， 此事难坏俺老张。"
