        {
          "character": "魏延",
          "type": "白",
          "text": "应分当然。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "文长既来，可与雷同各引一支人马，左右埋伏。只看俺中军红旗高起，各自杀 出擒拿张郃。不得有误。"
        },
        {
          "character": "魏延、雷同",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏延、雷同同下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "众将官！将酒摆列帐前，大开旗鼓，尽量而饮。"
        },
        {
          "character": "四蓝文堂",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。张飞饮酒。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "小军的。哑酒无趣，你们一对相样为戏代俺饮酒。哈哈哈哈。俺真好乐也！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "饮酒作乐开营帐， 试问谁敢比老张。 开怀畅饮杯休放，"
