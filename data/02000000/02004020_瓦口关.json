        {
          "character": "张飞",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "名将风流古无双。"
        },
        {
          "character": "丑将甲",
          "type": "白",
          "text": "禀三将军：我们会唱当子音韶。"
        },
        {
          "character": "张飞",
