        {
          "character": "丑将甲",
          "type": "白",
          "text": "得了。开了光了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好。重重有赏。回避了。"
        },
        {
          "character": null,
          "type": "stage",
