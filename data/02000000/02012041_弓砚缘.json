{
  "script_id": "02012041",
  "title": "弓砚缘",
  "alias": [
    "护行程"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "纪献唐",
      "hangdang": "净"
    },
    {
      "name": "安骥",
      "hangdang": "小生"
    }
  ],
  "plot": "海马周德胜经十三妹说劝，与邓九公和好后，又回莽牛山。一日喽啰来报山下生意可作，乃火速下山预备抢\n劫。安骥乃将十三妹之弹弓，令周德胜看后，周德胜不但不抢，反谓前途不靖，派人护送，直至淮阳始归。\n当纪献唐派其子纪多文，带大批金银，进京行贿时，朝廷有令调纪献唐进京。纪献唐恐有意外，乃派人追回\n其子，预备万一。纪多文行至淮阳附近，适遇周德胜喽啰。周德胜等遂下山将纪多文之车辆金银，全数抢劫。\n纪多文欲尾追，适其父信到，乃不追周德胜等，火速回家。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、李茂、吕芳、韩永、郝武、周德胜同上。"
        },
        {
          "character": "周德胜",
          "type": "唱",
          "text": "我与九公去较量， 不想遇着女豪强。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "李茂。"
        },
        {
          "character": "吕芳",
          "type": "白",
          "text": "吕芳。"
        },
        {
          "character": "韩永",
          "type": "白",
          "text": "韩永。"
        },
        {
          "character": "郝武",
          "type": "白",
          "text": "郝武。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "周德胜。实指望去邓九公处报复前仇，谁想那里有一女子名唤十三妹，武艺高 强，我等难以取胜。此女甚是慷慨，不肯加害于俺，反与我同邓九公和好，永 不相犯。为此辞别彼等，大家就此回山去者。"
        },
        {
          "character": "周德胜",
          "type": "唱",
          "text": "一同催马回山岗， 从此和好两不伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众喽兵自下场门同上，同接。李茂、吕芳、韩永、郝武、周德胜同下马，同进。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "众喽兵，这几日山上有事没有？"
        },
        {
          "character": "众喽兵",
          "type": "同白",
          "text": "并无甚事。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "命你们下山打探，若有买卖到此，速报我知，不得有误。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安骥上。"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "幸喜脱离天罗网，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张乐世上。"
        },
        {
          "character": "张乐世",
          "type": "唱",
          "text": "亏得遇着女豪强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张夫人、张金凤、车夫同上。"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "十三妹生得好貌相，"
        },
        {
          "character": "张金凤",
          "type": "唱",
          "text": "可称文武世无双。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "不料在能仁寺遇害，多亏十三妹女英雄，救得我们大家性命，我只恐我爹爹朝 夕盼望于我，大家急速趱行者。"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "急忙催车阳关上， 但愿一时到淮阳。"
        },
        {
          "character": "张金凤",
          "type": "唱",
          "text": "思想恩姐实难忘， 不知后会在何方？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥、张乐世、张夫人、张金凤同下。"
        },
        {
          "character": "张金凤",
          "type": "stage",
          "text": "中国京剧戏考 《弓砚缘》【五本】 2"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周德胜、四下手、李茂、吕芳、韩永、郝武同上。"
        },
        {
          "character": "周德胜",
          "type": "念",
          "text": "弟兄同结义，绿林逞英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑报子上。"
        },
        {
          "character": "丑报子",
          "type": "白",
          "text": "回禀寨主：山下来了买卖了。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "一同下山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德胜、四下手、李茂、吕芳、韩永、郝武同归下场门站。张夫人、张金凤、车夫、张乐世、安骥同上。"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "勒住丝缰抬头望，"
        },
        {
          "character": "张夫人、张金凤、张乐世",
          "type": "同唱",
          "text": "只见多人在路旁。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "呔，留下买路金银，放你们过去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥向张乐世。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "哎呀，又有劫路的了！如何是好？"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "何不拿弹弓与他们观看。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "哎呀，事到临头，我倒忘怀了。 吓，列位好汉不必如此，请看此弓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥拿弓，周德胜接弓。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "此弓何人所赠？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "十三妹所赠。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "吓，原来如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德胜交弓。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "请问公子要往哪里去？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "我要往淮阳去。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "要往淮阳去，路途甚远。我辈英雄甚多，倘若再有人劫抢，如何是好？"
        },
        {
          "character": "安骥、张乐世、张夫人、张金凤",
          "type": "同白",
          "text": "这个……"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "也罢，我烦李、韩二位保护你们送到淮阳就是。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "如此多谢众位了！"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "多承众位侠气广， 后会再谢好情肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李茂、韩永、张乐世、张夫人、张金凤、车夫、安骥同下。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "呔，众喽兵，暂且回山，等他二人回音便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德胜、四下手、吕芳、郝武同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四家将引纪多文同上。"
        },
        {
          "character": "纪多文",
          "type": "唱",
          "text": "奉令解宝京都往， 暗听消息好隄防。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "俺，纪多文。奉吾父之命，押解金珠去京都公干，行了几日，幸喜平安。看前 面已是淮阳。 众家将，速速趱行者。"
        },
        {
          "character": "纪多文",
          "type": "唱",
          "text": "催促车辆往前进， 但愿急早到都京。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文趟马下。四下手、四家将同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李茂、韩永、张乐世、张夫人、张金凤、车夫、安骥同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《弓砚缘》【五本】 3"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "思亲遭难心怅惘， 紧急加鞭马蹄忙。"
        },
        {
          "character": "李茂、韩永",
          "type": "同白",
          "text": "吓，安公子，你看前面已是淮阳，我弟兄不能护送了。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "既是如此，有劳二位鞍马劳顿远路护送。理当相请二位一同盘桓几日，二位既 要回山，我也不便强留。烦劳二位英雄回去拜上周寨主，容改日面谢，你我后 会有期。"
        },
        {
          "character": "李茂、韩永",
          "type": "同白",
          "text": "公子请趱路罢。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "如此告辞了。"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "感谢一路全仰仗， 日后拜谢到山岗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张乐世、张夫人、张金凤、车夫、安骥同下。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "你我回山去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喊声〗。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "你看那边来了许多车辆，你我登高一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李茂、韩永同站桌。四下手、四家将、纪多文同上，过场，同下。李茂、韩永同下桌。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "贤弟，你看纪多文押解车辆，尘土飞扬，定有金银财宝。你我回山报告三哥知 道便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李茂、韩永同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、李尉同上。〖牌子〗。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "下官，李尉。因九卿连本参奏大将军纪献唐九十二款，下官奉圣命前往调纪献 唐将军回京面圣。 左右！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同应。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "趱行者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四青袍、李尉同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、纪献唐同上。"
        },
        {
          "character": "纪献唐",
          "type": "点绛唇",
          "text": "职受封疆，文武敬仰，调兵将，任我施扬，升迁归吾掌。"
        },
        {
          "character": "纪献唐",
          "type": "念",
          "text": "坐镇州郡辖文武，升迁调遣谁不尊。风闻朝中有内奏，特命吾儿探信音。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "老夫，纪献唐只因风闻朝中有人入奏，曾命多文进京打听虚实，也好防范。 站堂军，侍候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "有事忙传报，无事不乱言。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启老爷：圣旨到。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "唔，有圣旨到来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "可知是何人押旨。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是李尉大人押旨。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "吩咐香案接旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。李尉、四青袍同上。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "圣旨下，跪。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "跪听宣读诏曰：朕思念大将军纪献唐，镇守边外，多受劳苦。朕命李尉调卿回 京，有军国大事要与大将军面议。旨意到达，即日来京。将尚方宝剑、九头狮 子印随身带来交代军务回都朕另有升赏。旨意读罢，望诏谢恩。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "万万岁！ 中国京剧戏考 《弓砚缘》【五本】 4 大人请坐。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "大将军请上，押旨官李尉参拜。 谢坐。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "有劳大人捧旨远来，一路多受风霜之苦。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "为国勤劳，何言风霜二字。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "吓，大人可知圣上诏我回都，究为何事？"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "圣上思念大将军久镇外疆，饱受辛苦，故调大将军回都，定然另有升赏。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "老夫军务重大，不敢擅离。大人暂居馆驿，候我将军务料理妥当，定日回都就 是。 中军，李大人同到馆驿歇息，小心侍候。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。 李大人随我来。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "下官暂别，听候行期。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "大人请。恕不奉陪。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李尉、中军同下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "且住。今有圣旨到来，要将老夫九头狮子印、尚方宝剑解进京都，又调老夫面 圣，其中恐有异变，必须早作防备，免得有误。 来，传旗牌进见。"
        },
        {
          "character": "文堂甲",
          "type": "白",
          "text": "传旗牌进见。"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "念",
          "text": "辕门听候传见，定有紧急军情。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "参见师爷，有何差遣？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "命你星夜去往京都，追赶少爷，急速回衙，不得有误。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "来，吩咐门军，若见李尉来见，就说老夫料理军务，不能相见。掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
