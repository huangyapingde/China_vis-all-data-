{
  "script_id": "02011047",
  "title": "刺虎",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "费贞娥",
      "hangdang": "旦"
    },
    {
      "name": "李固",
      "hangdang": "净"
    }
  ],
  "plot": "闯贼既已进宫，各处搜寻。有一个宫女叫费贞娥，穿了公主的衣服，假装公主。身藏利刃，让贼兵捉去，想\n乘机刺死李自成。哪知闯贼命不该绝，将费宫娥赐给大将李固，当夜成亲。即进洞房，费贞娥假意殷勤，用\n酒将李固灌醉，将他刺死，她自己也自杀了。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥上。"
        },
        {
          "character": "费贞娥",
          "type": "端正好",
          "text": "蕰君仇，含国恨，切切地， 蕰君仇，愤愤地，含国恨。 誓捐躯，要把那仇人手刃， 因此上苟且偷生一息存。 这就里谁知悯，"
        },
        {
          "character": "费贞娥",
          "type": "滚绣球",
          "text": "俺切着齿点绛唇， 揾着泪施脂粉。 故意儿花簇簇巧梳着云鬓， 锦层层穿蓍衫裙。 怀儿里冷飕飕匕首寒光喷， 俺佯娇假媚妆凝蠢巧语花言诌佞人。 纤纤玉手剜仇人目， 细细银牙啖贼子心。 要与那漆肤豫让争声誉， 断臂要离争智能。 拼得个身为齑粉， 拼得个骨化飞尘。 誓把那九重帝主沉冤泄， 四海苍生怨气伸。 方显得大明朝有个女佳人。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奴家费氏，小字贞娥。自幼选入宫闱，以充嫔御。蒙国母娘娘命我服侍公主， 不想流贼篡夺我国，逼死君父，一家骨肉死于非命。可笑那些臣子，竟没有一 个为国报仇泄恨，难道如此奇冤，就干休了不成？我想忠义之事，男女皆可做 得，为此我在宫中将那一匕首藏于身旁，又假装公主模样，指望得近闯贼，杀 此巨寇，替君父报仇。不想又将奴赐与他兄弟一只虎为配。罢，且待他来时， 奴自有道理。呀！听鼓乐之声，是此贼来也，我不免乔装欢笑去对他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小军、李固同上。"
        },
        {
          "character": "李固",
          "type": "引子",
          "text": "拓地开疆胆气豪，从龙附凤佐皇朝。龙潜且作赵匡义，有日天心属我曹。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "俺，李固。蒙皇兄赐我公主与俺成婚，众将备了筵宴，与俺称贺，被他们你一 杯，我一盏，吃得大醉，方才放我回营。呸！好不知趣也！"
        },
        {
          "character": "四小军",
          "type": "同白",
          "text": "二大王回营。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "回避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小军同下。二宫女暗同上。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "二大王回营，公主娘娘有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥上。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主，拜揖。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军万福！"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "啊哈哈哈哈！妙啊！这一福，就酥了俺半边。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军乃盖世英雄，皇朝栋梁。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "不敢，愚夫不才，怎当公主称羡。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "奴家乃亡国之女，不堪侍寝宫闱。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "好说。公主乃金枝玉叶，凤女龙孙，万望勿嫌愚夫粗莽，就是千万之幸。今后 宫中之事，悉凭公主掌握。凡有吩咐，小将一一从命。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "但夫妇乃人伦之始，当行花烛之礼，合卺之仪，方成大礼。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主说得是。 侍女们，摆宴过来。待俺与公主交拜。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "喜筵俱已完备。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主请。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军请。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "银台上好辉煌也！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "费贞娥",
          "type": "叨叨令",
          "text": "银台上煌煌的凤烛墩， 金猊儿袅袅香烟喷。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主，我和你一夜夫妻百夜恩呀。"
        },
        {
          "character": "费贞娥",
          "type": "叨叨令",
          "text": "恁道一夜夫妻百夜恩， 试问恁三生石上可有良缘分？"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主，早些睡了吧。"
        },
        {
          "character": "费贞娥",
          "type": "叨叨令",
          "text": "他只待流苏帐暖洞房春， 高堂月满巫山近。 恁便逗上了蓝桥几层， 还只怕飘飘渺渺的波涛滚。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军请。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主请。干！哈哈哈！我好乐也！"
        },
        {
          "character": "费贞娥",
          "type": "叨叨令",
          "text": "恁道是乐煞人也么哥，"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "我好喜也！"
        },
        {
          "character": "费贞娥",
          "type": "叨叨令",
          "text": "又道是乐煞人也么哥。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "待俺回敬公主一杯。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军所赐，奴家自当遵命。也要将军奉陪一大杯。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "当得。 侍女们，取巨觥来。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主请。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李固吐。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "费贞娥",
          "type": "叨叨令",
          "text": "赤紧的蠢不喇沙叱利， 也学些丰和韵。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军，将军。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主，俺醉得紧了，安寝了吧。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军，侍女们皆辛苦了，将喜筵分散她们去吧。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "也要留几个房中服侍。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "房中奴家自能侍奉巾栉，可叫她们去吧。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "想是公主害羞，不好解衣就寝。 也罢，侍女们，公主賞你们酒宴，谢了公主，各自去吧。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "多谢公主娘娘。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "掌灯送入洞房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军，为何今日还披此铠甲？"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "向在皇兄帐中护卫，提防奸细，日夜不能卸甲。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "如今天下已定，还虑甚奸细？况今宵乃是将军百年喜日，岂可穿此不祥之服。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "有理。待我唤侍女们来卸甲。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "不消唤她们，待奴亲与将军卸甲，才是妇道。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "只是劳动不当。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "费贞娥",
          "type": "脱布衫",
          "text": "除下了铁兜鍪凤翅鳞峋， 放下了宝龙泉偷看利刃。 松下了狮鸾带玉扣双扪， 卸下了煻猊铠锁子龙鳞。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "啊呀呀呀！"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军尊臂为何如此？"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "前日在宁武关被周遇吉打了一鞭，至今尚未痊愈。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "原来如此。待奴扶将军入帐安寝。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "公主，我欲火如焚，按纳不定，求你早些睡吧。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "待奴除了簪珥，脱了袍服就来。"
        },
        {
          "character": "李固",
          "type": "白",
          "text": "就要来的呀。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "就来的。"
        },
        {
          "character": "费贞娥",
          "type": "小梁州",
          "text": "除下了翠翘宝髻耳珰瑱， 脱却了凤滚龙氲氤。 俺把那金莲儿扎凤鞋跟， 防滑褪紧扎起绣罗裙。"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "听听房栊寂寂悄无人，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内打更。"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "又听得戍漏频频。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "将军，将军。"
        },
        {
          "character": "费贞娥",
          "type": "么篇",
          "text": "觑着他瞇醉眼醒还昏， 休惊盹心窝内把宝刀抡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥刺李固。"
        },
        {
          "character": "费贞娥",
          "type": "快活三",
          "text": "钢刀上冤气伸， 银灯下冤家殒。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "叹苍天不佑。"
        },
        {
          "character": "费贞娥",
          "type": "快活三",
          "text": "不能够把巨寇刃， 便便死向泉台。 犹兀自含余恨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同上。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "二大王与公主成亲，为何房中喧嚷，我们进去看看。 哎呀！二大王为何满身鲜血倒在地下？呀，原来被人刺死了。 啊，你为何将二大王刺死？拿你去见大王。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "唗！谁敢来！我原非公主。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "你是何人？"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "我乃费氏宫人。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "呀啐！原来也是我辈。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "今日杀此逆贼，替君父报仇，便将我凌迟碎剐，亦不畏惧。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "你配了二大王，享荣华，受富贵，也不辱没了你。况何等将你庞爱，你也不该 将他剌死。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "费贞娥",
          "type": "朝天子",
          "text": "恁道谎阳台雨云， 哎呀莽巫山秦晋， 可知俺女专诸不解江皋韵。 俺含羞怯酬语揾泪擎樽，遇冤家难含忍。 拼得个柳憔花翠，可也珠残玉殒。 哎呀早难道，贪恋荣华，忘却终天恨。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "拿你去见大王，就是个哩。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": "费贞娥",
          "type": "朝天子",
          "text": "一任他碎骨粉身， 一任他扬灰碾尘。 今日里含笑归泉。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "哎呀费贞娥呀，费贞娥，可惜你大才小用了。"
        },
        {
          "character": "费贞娥",
          "type": "朝天子",
          "text": "喔又又何必多磨吻。"
        },
        {
          "character": "费贞娥",
          "type": "白",
          "text": "呀，你看此贼又活了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费贞娥自刎下。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "哎呀，她竟自刎了。好个烈性女子。我们将尸首抬过一边，报与大王知道。正 是："
        },
        {
          "character": "二宫女",
          "type": "同念",
          "text": "三寸气在千般用，一命无常万事休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}