          "character": "孟明视、公孙枝、西乞术、白乙丙",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "孟明视、公孙枝、西乞术、白乙丙",
          "type": "同白",
          "text": "俱已齐备。"
