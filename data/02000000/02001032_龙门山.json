        {
          "character": "晋王",
          "type": "白",
          "text": "打探秦兵消息怎么样了？"
        },
        {
          "character": "梁繇靡",
          "type": "白",
          "text": "秦兵蜂拥而来，千岁早定良策。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "孤有战车六百乘，何惧于他。"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "千岁，与秦交好，莫要失了和气。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "咳！孤今领兵，哪用你奏？众卿吩咐下去，兵发龙门山。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "众将官，兵发龙门山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（孟明视、公孙枝、西乞术、白乙丙、四龙套、秦王、梁繇靡、庆郑、吕饴甥、屠岸夷、四龙套、晋王同上，"
        },
        {
          "character": null,
          "type": "text",
          "text": "对阵。）"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "秦穆公，你差冷志到我邦借粮，允与不允，孤自有主张。你今领兵前来是何理 也？我借何理家人万下。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "夷吾哇，夷吾！不记当年来至我国，我差子桑送你回去。你国遭荒旱，差人向 我借粮，是我差人送去万石粟米。今日不幸我国天旱粮缺，差冷志向你借粮。 你不肯借粮，还则罢了，反将冷志重打四十，赶下殿来。无义的匹夫，有何面 目前来见我？"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "一派胡言！杀！ （众人同开打。梁繇靡、庆郑、吕饴甥、屠岸夷、四龙套、晋王同败下，孟明视、公孙枝、西乞术、白乙丙、 四龙套、秦王同追下。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵卒、公孙枝同上，登高台。晋王、梁繇靡同上。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "什么人挡住孤的去路？"
        },
        {
          "character": "公孙枝",
          "type": "白",
          "text": "西秦大将公孙枝。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "公孙将军，你看你国连年荒旱，此乃天亡你国。不如投了孤家，不失封侯之位。"
        },
        {
          "character": "公孙枝",
          "type": "笑",
          "text": "哈哈哈。"
        },
        {
          "character": "公孙枝",
          "type": "白",
          "text": "吾有片言，晋侯听着：君想还国，吾主纳之；君想吃粮，吾主与之；今君想战， 焉敢违命乎？"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "真乃不知时务。 国舅，何不上前？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梁繇靡、公孙枝同开打。晋王、梁繇靡同败下。公孙枝、四兵卒同追下。"
        }
      ]
    },
