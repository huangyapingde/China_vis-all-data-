        {
          "character": null,
          "type": "stage",
          "text": "四龙套引晋王同上。"
        },
        {
          "character": "晋王",
          "type": "唱",
          "text": "昨夜一梦大不祥， 梦见乌云遮太阳。 又梦见身在高山上， 猛虎赶散一群羊。 将身且坐中军帐， 再与众将说端详。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "孤王晋惠公。前者秦国冷志，来在我邦借粮，含恨而回，必然不肯干休。 梁大夫，"
        },
        {
          "character": "梁繇靡",
          "type": "白",
          "text": "臣。"
