{
  "script_id": "02001032",
  "title": "龙门山",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "公孙枝",
      "hangdang": "老生"
    },
    {
      "name": "秦王",
      "hangdang": "老生"
    },
    {
      "name": "晋王",
      "hangdang": "小生"
    },
    {
      "name": "梁繇靡",
      "hangdang": "净"
    }
  ],
  "plot": "秦穆公时，连年荒旱，乃派冷志至晋国借粮。晋惠公听郤芮、梁繇靡等之言，不但不肯借粮，反把冷志重打\n四十大棍，放回秦国。秦穆公大怒，随即发兵龙门山，进攻晋国。晋惠公闻言后，亲自带兵应战，终被秦生\n擒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郤芮、梁繇靡、庆郑、吕饴甥同上。〖点绛唇〗。"
        },
        {
          "character": "郤芮",
          "type": "白",
          "text": "上大夫郤芮。"
        },
        {
          "character": "梁繇靡",
          "type": "白",
          "text": "中大夫梁繇靡。"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "正大夫庆郑。"
        },
        {
          "character": "吕饴甥",
          "type": "白",
          "text": "下大夫吕饴甥。"
        },
        {
          "character": "郤芮",
          "type": "白",
          "text": "众位大人请了。"
        },
        {
          "character": "梁繇靡、庆郑、吕饴甥",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "郤芮",
          "type": "白",
          "text": "千岁临殿，小心伺候。"
        },
        {
          "character": "郤芮、梁繇靡、庆郑、吕饴甥",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郤芮、梁繇靡、庆郑、吕饴甥同过场。大庙龙门。四内侍引晋王同上。"
        },
        {
          "character": "晋王",
          "type": "引子",
          "text": "凤篆龙章，宝鼎玉炉香。"
        },
        {
          "character": "晋王",
          "type": "念",
          "text": "冤气冲天只为仇，每日怀恨在心头。若要孤把冤仇解，杀却重耳才罢休。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "孤王晋惠公在位，御名夷吾。只因丽姬在朝专政，药酒摆死申生。皇兄重耳逃 奔翟国，孤穷逃往秦邦。多蒙秦穆公仁义，差上大夫公孙枝纳孤还朝，重掌晋 室基业。闻得重耳今在翟国，翟王有女许耳婚姻。孤想重耳不死，总是孤的大 患。孤已差人行刺，日久未见回来。今坐早朝。 众卿！"
        },
        {
          "character": "郤芮、梁繇靡、庆郑、吕饴甥",
          "type": "同白",
          "text": "臣！"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "有本早奏，无本退班。"
        },
        {
          "character": "吕饴甥",
          "type": "白",
          "text": "启奏主上：今有秦邦使臣冷志午门候旨。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "替孤传旨：唤他上殿。"
        },
        {
          "character": "吕饴甥",
          "type": "白",
          "text": "冷志上殿。"
        },
        {
          "character": "冷志",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冷志上。"
        },
        {
          "character": "冷志",
          "type": "念",
          "text": "忽听晋主宣，上殿把驾参。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "臣秦邦使臣冷志参见大王。千岁！"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "贵卿平身。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "千千岁!"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "贵卿不在你邦，来到晋阳为了何事？"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "千岁容禀。"
        },
        {
          "character": "冷志",
          "type": "唱",
          "text": "我秦邦天不幸遭下荒旱， 吾的主曾设场龙王庙前。 乞甘霖恨天空全无半点， 差为臣借粮饷来到此间。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "贵卿乃是为借粮而来？"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "为借粮前来。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "你且下殿，容孤商议。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冷志下。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "众卿，秦邦今遭荒旱，差人前来借粮。孤有心应允，众卿心意如何？"
        },
        {
          "character": "郤芮",
          "type": "白",
          "text": "千岁不可！借粮如借地，国之土地，岂可借与他人？"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "孤予秦粟，以报当年泛舟之役耳。"
        },
        {
          "character": "郤芮",
          "type": "白",
          "text": "君以泛舟为秦德，则昔年纳君，其德更大。君舍大以报小何也？"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "千岁当年差臣到他邦借粮，秦王慷慨应允，并不推辞，其意甚美。他今向我邦 借粮，如若不允，秦王必然归罪于我矣。"
        },
        {
          "character": "吕饴甥",
          "type": "白",
          "text": "千岁不与秦粟，秦怒必然举兵伐我。我曲彼直，焉能敌挡。"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "千岁幸人之灾，乃为不仁；忘人之恩，乃为不义。不仁不义，难以保国。"
        },
        {
          "character": "梁繇靡",
          "type": "白",
          "text": "千岁。去年天饥晋以授秦，秦不知取，又资我粟，是其愚也。今年天饥秦以授 晋，晋奈何逆天而不取乎？以臣愚见，不如会同梁伯，乘机伐秦，共分其地， 乃为上策。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "国舅言之有理。冷志上殿。"
        },
        {
          "character": "吕饴甥",
          "type": "白",
          "text": "千岁有旨：冷志上殿。"
        },
        {
          "character": "冷志",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冷志上。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "参见大王。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "贵卿，孤本该济粟，奈我邦连年荒旱，粟米缺少。回报秦王就说孤不能从命。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "这个……千岁曾记得去年晋遭荒旱，差人借粟我国，吾主念其至亲，差臣送来 米粟万石。不料秦邦今遭荒旱，差臣前来借粮，千岁闭粟不与，使臣实难回复 王命。"
        },
        {
          "character": "吕饴甥",
          "type": "白",
          "text": "唗！好一冷志，从前与我国平郑父同谋作乱。幸喜奸谋败露，斩了平郑父，将 尔放回。今番又来我国摇唇鼓舌，真真大胆！"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "吕饴甥呀，吕饴甥！尔为大夫。不思报国，反助君非，是何道理？"
        },
        {
          "character": "冷志",
          "type": "唱",
          "text": "恨奸贼助君非出言横乱， 既不仁又不义怎立朝班？ 不过是吕娘娘驾坐宫院， 携带你食君禄肆意贪残。"
        },
        {
          "character": "郤芮",
          "type": "白",
          "text": "好一冷志！吾主命你回国交旨，竟敢当殿饶舌。尔若要想食晋粟，除非兴兵来 取。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "郤大夫，郤芮！鹿得食而鸣其群，蜂见花而聚其众。既为同类，祸福共之。亲 人善邻古之常理，有道是唇亡齿寒。秦晋既为邻邦，理当患难相助。你今逢君 之恶，背义忘恩，是何理也？"
        },
        {
          "character": "冷志",
          "type": "唱",
          "text": "曾记得晋邦你遭了荒旱， 差使臣到我国去把粮搬。 吾的主念亲情送米万石， 那时节你君民才得安然。 今日里我秦邦也遭荒旱， 你为何逢君恶袖手旁观？ 无义贼你真乃狼心狗胆， 全不怕到后来遗臭万年！"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "晋王",
          "type": "唱",
          "text": "骂匹夫尔真乃包天大胆， 毁孤众并文武罪犯弥天。 叫侍臣你速传武士上殿， 将冷志推下去项上刀餐！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "武士上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士同上。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "将冷志推出斩首！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士、冷志同下。"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "刀下留人！ 大王，冷志斩不得！"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "为何斩不得？"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "斩了冷志，惹恼秦王，会合诸侯前来伐我，晋国危矣！"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "匹夫叫骂孤家，难道说就罢了不成？"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "依臣之见，死罪恕过，活罪难免。重责四十，以消主公之恨。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "就依卿家。"
        },
        {
          "character": "庆郑",
          "type": "白",
          "text": "大王有旨：将冷志放回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士、冷志同上。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "谢千岁不斩之恩。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "非孤不斩于你，多亏庆大夫奏请。死罪恕过，活罪难免，扯下重打四十。"
        },
        {
          "character": "武士",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士同打冷志。"
        },
        {
          "character": "武士",
          "type": "同白",
          "text": "四十打完。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "叉出去！"
        },
        {
          "character": "武士",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冷志下。"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "吓！我想冷志，回到他邦，必然拨弄唇舌，兴兵犯境。 梁大夫，"
        },
        {
          "character": "梁繇靡",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "晋王",
          "type": "白",
          "text": "命你打探秦兵消息，回禀我知。"
        },
        {
          "character": "梁繇靡",
          "type": "白",
          "text": "请驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "冷志上。"
        },
        {
          "character": "冷志",
          "type": "唱",
          "text": "可恨夷吾太无理， 无故不该把我欺。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "吓。好一夷吾，不肯借粮也还罢了，反将我重打四十，推出朝门。此番回去， 定要请我主发兵扫灭晋国。夷吾呀小竖子，我不杀你誓不为人也！"
        },
        {
          "character": "冷志",
          "type": "唱",
          "text": "恼恨夷吾太欺天， 不仁不义肆凶残。 此去见了吾主面， 发兵要报山海冤！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冷志下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、秦王同上。"
        },
        {
          "character": "秦王",
          "type": "唱",
          "text": "众百姓一个个饥寒叫唤， 倒教孤一阵阵愁锁眉尖。 将身儿且坐在银安宝殿， 等冷志回国来细问一番。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "孤王秦穆公在位，驾坐咸阳。不幸我国天遭荒旱，三载五谷不收。孤差冷志前 往晋国借粮，日久不见回转，教孤时刻在心。 内侍，展放龙门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冷志上。"
        },
        {
          "character": "冷志",
          "type": "念",
          "text": "怀抱无穷恨，上殿见主君。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "冷志叩见大王。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "谢大王。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "孤命你晋阳借粮，为何这般光景？"
        },
        {
          "character": "冷志",
          "type": "白",
          "text": "大王容禀。"
        },
        {
          "character": "冷志",
          "type": "唱",
          "text": "提起来借粮事教人可恼， 尊我主听为臣细奏根苗： 晋夷吾不借粮还则罢了， 他君臣在殿上叫骂我朝。 要斩臣多亏了庆郑作保， 重打我四十棍赶出城郊。 望主公发人马将冤仇来报， 灭晋国杀夷吾方把恨消。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "好恼！"
        },
        {
          "character": "秦王",
          "type": "唱",
          "text": "听一言不由人气往上撞， 可恨夷吾小昏王！ 从前之恩全不想， 不仁不义似豺狼。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "卿吓！"
        },
        {
          "character": "秦王",
          "type": "唱",
          "text": "将令传在午门上， 晓喻文武听其详： 兵对兵来将对将， 孤与晋国动刀枪。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "冷志听命：吩咐大小将官，全装披挂，教场听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孟明视、公孙枝、西乞术、白乙丙同上，同起霸。"
        },
        {
          "character": "孟明视、公孙枝、西乞术、白乙丙",
          "type": "同白",
          "text": "俺，"
        },
        {
          "character": "公孙枝",
          "type": "白",
          "text": "公孙枝。"
        },
        {
          "character": "孟明视",
          "type": "白",
          "text": "孟明视。"
        },
        {
          "character": "西乞术",
          "type": "白",
          "text": "西乞术。"
        },
        {
          "character": "白乙丙",
          "type": "白",
          "text": "白乙丙。"
        },
        {
          "character": "公孙枝",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "孟明视、西乞术、白乙丙",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "公孙枝",
          "type": "白",
          "text": "大王发兵，你我两厢侍候。"
        },
        {
          "character": "孟明视、公孙枝、西乞术、白乙丙",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、秦王同上。"
