        {
          "character": "秦王",
          "type": "白",
          "text": "卿家为主江山，受尽辛苦。 公孙枝，用汤药灌下，将孤的锦袍袍裹体，扶入后营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二兵卒扶白乙丙同下。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "此是何人？"
        },
        {
          "character": "公孙枝",
          "type": "白",
          "text": "此人名屠岸夷，当年连杀奚齐、卓子，就是此人。"
        },
        {
          "character": "秦王",
          "type": "白",
          "text": "真乃不忠之辈，推出斩了。传令下去，班师。"
        },
        {
          "character": "公孙枝",
          "type": "白",
          "text": "回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
