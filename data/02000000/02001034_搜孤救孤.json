{
  "script_id": "02001034",
  "title": "搜孤救孤",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "程婴",
      "hangdang": "老生"
    },
    {
      "name": "韩厥",
      "hangdang": "武生"
    },
    {
      "name": "太后",
      "hangdang": "老旦"
    },
    {
      "name": "庄姬",
      "hangdang": "旦"
    },
    {
      "name": "屠岸贾",
      "hangdang": "净"
    },
    {
      "name": "程妻",
      "hangdang": "旦"
    },
    {
      "name": "太医",
      "hangdang": "丑"
    }
  ],
  "plot": "春秋时，晋国有佞臣屠岸贾，晋景公宠之。屠岸贾与赵氏不睦，诬赵盾以弑君之罪，将赵氏抄斩。赵朔之妻，\n公之庶妹也，怀孕走入宫中，得免。后生赵武，托门客程婴、公孙杵臼，设法保护。屠岸贾为斩草除根计，\n严索孤儿。程婴适生子，公孙杵臼请将婴儿伪作孤儿，应屠岸贾索。程婴许之。公孙杵臼乃抱程婴子藏于\n首阳山边，嘱程婴出首。屠岸贾带校尉搜山，果得公孙杵臼及孤儿，立将孤儿掷死，又命程婴举鞭击公孙杵\n臼，以试虚实，以程婴与公孙杵臼，同为赵氏家客也。程婴忍泪痛击公孙杵臼，屠岸贾乃信，杀公孙杵臼。\n后景公崩，成公立，赵武为上卿，将屠岸贾剐戮。以报昔日之仇。赵武既成立，程婴乃自杀以报公孙杵臼。\n赵武感二客义侠，立位宗庙，配享祖先。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "唱",
          "text": "心中有事感叹多， 不知孤儿事如何。 眼望宫院不能到， 只恐后来受折磨。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "在下程婴，曾为赵家门客。只因赵相与屠贼结仇，三百余口，被屠贼斩尽杀绝。 只留庄姬一人，逃进宫去，产生一子。闻听屠贼带领校尉，进宫搜寻。倘若 将孤儿搜出，苍天哪苍天！眼见得忠良就无有后了。吓，那厢好似韩将军，待 我迎上前去。"
        },
        {
          "character": "韩厥",
          "type": "内白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥上。"
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "奉了太后旨，怎敢有迟延。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "吓，程兄。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "吓，将军，闻听屠贼，进宫搜寻孤儿。可曾被他搜去？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "孤儿不曾搜去。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "谢天谢地。此地并非讲话之所，将军这里来。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "好。"
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "转过背静所，"
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "今有大事托。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "程兄何事？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "我想孤儿在宫，终无了日。何不抱出宫来，命一人私自抚养。日后好与赵相报 仇。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "某早有此心，只是无人抚养。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "我程婴情愿抚养。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "难道你有加害之意？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "老天在上，我若有加害孤儿之心，天诛地灭。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "改祸成祥。如今有个机会在此。 中国京剧戏考 《搜孤救孤》【二本】 2"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "有什么机会？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "奉了太后之命，去请太医院，与公主诊脉。太医院带有药箱，待我将药箱腾空， 将公子装在箱内，抱出宫来，付与程兄抚养。岂不安然无事。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "将军快去办来。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "小心了。"
        },
        {
          "character": "程婴",
          "type": "唱",
          "text": "但愿救得忠良后， 洗手焚香把神酬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        },
        {
          "character": "韩厥",
          "type": "唱",
          "text": "我将大事安排就， 要救孤儿出龙楼。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "有人么。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童子上。"
        },
        {
          "character": "童子",
          "type": "白",
          "text": "什么人？ 啊，将军来了。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "快快通禀。"
        },
        {
          "character": "童子",
          "type": "白",
          "text": "有请老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太医上。"
        },
        {
          "character": "太医",
          "type": "念",
          "text": "神农尝百草，轩辕执衣巾。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "童子",
          "type": "白",
          "text": "韩将军到。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "童子",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "将军在哪里？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "先生。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "将军请进。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "将军到此何事？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "公主偶得疾病，请先生进宫诊脉。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "来，带了药箱，随我进宫。"
        },
        {
          "character": "童子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "太医",
          "type": "念",
          "text": "仙丹产在深山内，"
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "妙药生于幽谷中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥、太医、童子同走小圆场。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "来此已是。稍候。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "退下。"
        },
        {
          "character": "童子",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童子下。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "有请国太。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太后、庄姬同上。"
        },
        {
          "character": "太后",
          "type": "念",
          "text": "吾儿平安稳，"
        },
        {
          "character": "庄姬",
          "type": "念",
          "text": "且喜病离身。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "太医院到。"
        },
        {
          "character": "太后",
          "type": "白",
          "text": "公主病已痊愈。看过赏封，打发来人去罢。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "先生，公主病已痊愈。国太有赏。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "多谢。正是："
        },
        {
          "character": "太医",
          "type": "念",
          "text": "趁我十年运，有病早来医。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "药箱呢？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "随后送去。"
        },
        {
          "character": "太医",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太医下。"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "母后在上，想那屠贼搜寻孤儿不着，只恐又生别计。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "国太，公主。为臣去请太医，中途路上遇见程婴，他倒有扶养公子之意。 中国京剧戏考 《搜孤救孤》【二本】 3"
        },
        {
          "character": "太后",
          "type": "白",
          "text": "儿吓，程婴为人如何？"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "乃忠义之人。只是孤儿不能出宫。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "太医院现有药箱在此。将公子装在里面，抱出宫去，付与程婴抚养。岂不安然 无事？"
        },
        {
          "character": "太后",
          "type": "白",
          "text": "此计甚好，你母子速速分别了吧！"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "儿吓，想你一家三百余口，被屠贼斩尽杀绝。但愿你出得宫去，长大成人，拿 着屠贼，冤冤相报。母子们就此一别，不知何日才得相见了。"
        },
        {
          "character": "庄姬",
          "type": "唱",
          "text": "怀抱姣儿珠泪滚， 才出娘胎就离分。 孤儿交与忠义士， 痛断肝肠对谁明。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "公主。"
        },
        {
          "character": "韩厥",
          "type": "唱",
          "text": "公主但把心放定， 救孤之事我担承。 药箱之内藏孤稳， 谅奸贼难解其中情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥下。"
        },
        {
          "character": "太后",
          "type": "唱",
          "text": "孤儿出宫情难忍，"
        },
        {
          "character": "庄姬",
          "type": "唱",
          "text": "好似钢刀刺娘心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太后、庄姬同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "唱",
          "text": "眼望韩厥不得见， 好叫我两眼都望穿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥上。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "韩厥",
          "type": "唱",
          "text": "怀抱孤儿往前奔， 见了程兄说分明。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "孤儿可曾抱出宫来？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "抱出宫来了。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "娘子在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程妻上。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "官人何事？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "快快抱了进去。"
        },
        {
          "character": "程妻",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程妻下。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "程兄，出宫之时，太后言道：须要用心抚养。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "那个自然。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "将军请转。此事只有你知我知，千万不可泄漏。请。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥下。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "哎呀且住，我想左邻右舍，谁人不知：我程婴只生一子。如今多了一个婴儿， 倘若有人出首，如何是好？哦，有了，我想公孙兄，乃是赵相门客，不免与他 商议商议。正是："
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "要救孤儿命，须寻仗义人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四校尉、屠岸贾同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《搜孤救孤》【二本】 4"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "且住。方才进宫搜孤，为何不见踪影？想是藏在民间，老夫自有道理。 来呀！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "传谕在外：十日之内，有人献出孤儿，赏赐千金；十日一过，若无孤儿，晋国 之中，与孤儿同庚者，尽行斩首。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}