{
  "script_id": "02006056",
  "title": "醉写",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李白",
      "hangdang": "正生"
    },
    {
      "name": "杨国忠",
      "hangdang": "副净"
    },
    {
      "name": "高力士",
      "hangdang": "丑"
    },
    {
      "name": "贺知章",
      "hangdang": "外"
    },
    {
      "name": "孟浩然",
      "hangdang": "末"
    },
    {
      "name": "唐明皇",
      "hangdang": "小生"
    }
  ],
  "plot": "唐明皇欲考天下英才，由杨国忠与高力士主考。贺知章推荐李白参加考试，杨国忠、高力士二人不但不肯取\n中，反藉故赶出贡院。适白海国使臣送来番文表章，满朝文武无人能解。贺知章谓李白能读，唐明皇乃宣李\n白上殿。李白谓须杨国忠磨墨、高力士脱靴，唐明皇均一一应允。李白除读解番表外，并回复番邦进贡安分，\n免惹天兵征讨云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李白上。"
        },
        {
          "character": "李白",
          "type": "引子",
          "text": "满腹经纶，何日一举成名。"
        },
        {
          "character": "李白",
          "type": "念",
          "text": "锦绣战策论兵机，百般诗句任我题。饮酒作对哪在意，游遍天涯世间稀。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "卑人李太白，乃西蜀人氏。生平不喜加官受爵，只爱饮酒游乐，吟诗作对。前 日来至贺人大人府中，蒙他优礼相待。今早大人上朝未回，独坐书斋，好不寂 寞人也。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "平生志气比天高， 不愿为官结富豪。 只爱饮酒游山道， 清闲自在乐逍遥。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "外面喧哗，想是大人下朝来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引贺知章同上。"
        },
        {
          "character": "贺知章",
          "type": "念",
          "text": "朝罢忙回府，只恐慢宾朋。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "大人回来了，学生拜揖。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "先生少礼，请坐。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "有坐，大人上朝，圣上有何旨意？"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "圣上传下旨意，考选天下奇才。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "但是不知是何人的宗师？"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "乃贵妃之胞兄杨国忠。此人乃贪财爱宝之徒。先生何不前去打干打干？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "大人说哪里话来？难道叫学生用金帛前去打干功名不成？"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "不妨，待我修书一封，去到那厢，他必定重用与你。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "如此待学生磨墨。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "不敢。 来！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "磨墨伺候。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "贺知章",
          "type": "唱",
          "text": "贺知章修书多拜上， 拜上高、杨二大人。 西蜀李白才学广， 胜似谪仙下凡尘。 我今修书无别事， 二位大人好看承。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "有书一封到高、杨二大人那里投递。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "我的书信前去，他必重用与你。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "若是侥幸，先敬你一个状元杯。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "十二红。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白、贺知章同笑。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "说来说去，又说到酒上来了。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "来，看酒伺候。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "先生请。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "大人请。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "和你畅饮作诗对， 斗酒百篇紧相随。"
        },
        {
          "character": "贺知章",
          "type": "唱",
          "text": "十二蟾宫来折桂， 帽押宫花衣锦归。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白、贺知章同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众军士引杨国忠、高力士同上。"
        },
        {
          "character": "杨国忠",
          "type": "引子",
          "text": "势压群僚，论奸谋，志量高。"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "每日金殿走三遭，见皇爷扬尘舞蹈。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "老夫杨国忠。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "咱家高力士。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "尊贵。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "老太师。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "你我奉旨考选天下奇才，科场里面，必须检点明白。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "那个自然。 来，伺候了。"
        },
        {
          "character": "军士甲",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "念",
          "text": "领了家爷命，前来下书文。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "门上有人么？"
        },
        {
          "character": "军士甲",
          "type": "白",
          "text": "哪里来的？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "贺府差人下书。"
        },
        {
          "character": "军士甲",
          "type": "白",
          "text": "候着。 启爷：贺府差人前来下书。"
        },
        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "命他进来。"
        },
        {
          "character": "军士甲",
          "type": "白",
          "text": "哦。 下书人呢？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "军士甲",
          "type": "白",
          "text": "命你进去，小心了。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 下书人叩头。"
        },
        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "你奉何人所差？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "奉贺爷所差。有书呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨国忠看书信。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "回去拜上你家爷，老夫这里照书行事。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "尊贵。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "老太师。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "贺知章有书前来，不知所为何事？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "想是他有孙男弟侄赴考。故此差人来孝敬老太师。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "同拆一看，便知明白。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "老太师请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。杨国忠、高力士同看书信。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "原来西蜀李白，才高北斗，叫老夫重用与他。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "且到科场，看过文字，便知明白。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "打道科场。"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同走圆场。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四举子同上。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "众举子可曾到齐？"
        },
        {
          "character": "四举子",
          "type": "同白",
          "text": "俱已到齐"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "领卷各归号房。"
        },
        {
          "character": "四举子",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四举子同下。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "众举子照题。"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "起鼓催卷。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "鸣金收卷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四举子同上，交卷，同下。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "老太师，请看这就是李白的文字。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "待老夫观看。 呀！你看李白的文字，远看是花，近看是字，万岁一看必定重用与他。这便如 何是好？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "不妨，老太师重宣李白，再入科场，在文章上面盘得两三桩，将他的文字扯破， 赶出贡院。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "说得有理。 来，传李白重赴科场。"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "哦。李白重赴科场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白上。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "李白",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "李白",
          "type": "念",
          "text": "醉眼胧朦天未晓，笑煞人间锦绣高。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "上面敢是宗师大人？学生拜揖，请了呀请了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同笑。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "你就是西蜀李白？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "区区便是。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "老夫见你的文字，也不足为奇。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "老大人想是心中不服，再请出题，待学生做上几篇，方知我胸中奇才。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "老夫磨砚的小厮比你还高些。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "你与咱家脱靴，还嫌你的手儿粗呢。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "来，将文章扯碎，把他赶出贡院。"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "哦。出去。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "呀，你看这两个奸贼，好生无礼。将我的文章扯碎，反将我赶出贡院。正是："
        },
        {
          "character": "李白",
          "type": "念",
          "text": "不怕文章高天下，只要文章中试官。"
        },
        {
          "character": "李白",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白下。"
        },
        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "吩咐外厢开道。"
        },
        {
          "character": "众军士",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小番引马天申同上。"
        },
        {
          "character": "马天申",
          "type": "念",
          "text": "领了狼主命，押表到天朝。"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "咱家马天申是也。奉了狼主旨意，押有乌兽字表，去到天朝。有人识认，年年 进贡，岁岁来朝；若无人识认，反上天朝。 众番儿！"
        },
        {
          "character": "四小番",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "押表前行者。"
        },
        {
          "character": "四小番",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨国忠、高力士、贺知章、孟浩然同上。"
        },
        {
          "character": "杨国忠",
          "type": "念",
          "text": "待漏五更寒，"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "撩衣上金銮。"
        },
        {
          "character": "贺知章",
          "type": "念",
          "text": "物华天未晓，"
        },
        {
          "character": "孟浩然",
          "type": "念",
          "text": "明月满栏杆。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "老夫杨国忠。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "咱家高力士。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "下官贺知章。"
        },
        {
          "character": "孟浩然",
          "type": "白",
          "text": "下官孟浩然。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "今有白海国使臣前来进表，候万岁升殿，一同启奏。"
        },
        {
          "character": "杨国忠、高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "香烟霭霭，圣驾临朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引唐明皇同上。"
        },
        {
          "character": "唐明皇",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "唐明皇",
          "type": "念",
          "text": "平顶冠上九龙头，太阳一出照九洲。南天门下朝北斗，文武百官拜冕旒。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "寡人唐明皇在位。自登基以来，风调雨顺，国泰民安。刀枪入库，马放南山。 乃朕之福泽也。今当早朝，内臣展放龙门。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "领旨。 万岁有旨，展放龙门。"
        },
        {
          "character": "杨国忠、高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "臣等见驾，愿吾皇万岁！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "杨国忠、高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "臣启万岁：今有白海国使臣前来进表，无旨不敢上殿。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "领旨。 万岁有旨：宣白海国使臣见驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天申上。"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "马天申",
          "type": "念",
          "text": "头顶太平表，天朝见圣君。"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "臣偏邦使臣见驾，愿仁君万岁。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "头顶何物？"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "太平表章。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "呈上来。下殿午门候旨。"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "马天申",
          "type": "念",
          "text": "拆开狼主表，文武胆战惊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天申下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "众卿一同观看。"
        },
        {
          "character": "杨国忠、高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨国忠、高力士、贺知章、孟浩然同看。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "卿等可认识此表？"
        },
        {
          "character": "杨国忠、高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "臣等一字不识。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宣使臣上殿。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "宣使臣上殿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天申上。"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "唔，大胆番奴，进来乌兽字表，敢是藐视寡人么？"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "启大国皇帝：我国狼主进来乌兽字表，若有人认识者，年年进贡，岁岁来朝， 若无人认识呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "杨国忠、高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "唗！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "下殿候旨。"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天申下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "众卿家，难道寡人朝中，就无一人认识此字？"
        },
        {
          "character": "杨国忠、高力士、贺知章、孟浩然",
          "type": "同白",
          "text": "启奏万岁：臣等皆读孔圣之书。此乃乌兽字迹表章，臣等一字不识。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "如此，好叫寡人忧虑也！"
        },
        {
          "character": "唐明皇",
          "type": "唱",
          "text": "番邦进来乌兽表， 文武不识半分毫。 夜梦贤臣李白到， 若能开读早来朝。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "万岁夜梦贤臣，莫非应在西蜀李太白？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "正是此人。"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "此人去岁赴过科场，被高、杨二位大人赶出贡院。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "高、杨二卿，为何隐贤误国？"
        },
        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "启奏万岁：去岁科场之中，他乃酒醉狂生，扰乱科场，是臣等将他赶出贡院。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宣他前来开读，再议你等之罪。"
        },
        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "谢万岁。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "卿家，贤臣今在何处？"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "现在臣家中。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "贺、孟二卿，赐李白学士公之职，命他冠带上殿。"
        },
        {
          "character": "贺知章",
          "type": "念",
          "text": "金殿领圣旨，"
        },
        {
          "character": "孟浩然",
          "type": "念",
          "text": "宣召栋梁臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺知章、孟浩然同下。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "若得贤臣开读，使孤无忧也。"
        },
        {
          "character": "唐明皇",
          "type": "唱",
          "text": "有寡人在金殿自嗟自想， 恨番邦进异表藐视孤王。 你二人权且下殿往，"
        },
        {
          "character": "杨国忠",
          "type": "念",
          "text": "夜梦贤臣进，"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "羞煞二大臣。"
        },
        {
          "character": "唐明皇",
          "type": "唱",
          "text": "候贤臣来开读方免愁肠。"
        },
        {
          "character": "贺知章、孟浩然",
          "type": "内同白",
          "text": "先生请。"
        },
        {
          "character": "李白",
          "type": "内唱",
          "text": "杏花村好一似琼林赴宴，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白、贺知章、孟浩然同上。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "勒住了龙驹马醉眼细观。 唐天子因何故将我召选？"
        },
        {
          "character": "贺知章、孟浩然",
          "type": "同白",
          "text": "今有白海国进来乌兽本章，特请先生上殿开读。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "你等不解？"
        },
        {
          "character": "贺知章、孟浩然",
          "type": "同白",
          "text": "我等不解。"
        },
        {
          "character": "李白",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "杨国忠、高力士可在朝班？"
        },
        {
          "character": "贺知章、孟浩然",
          "type": "同白",
          "text": "万岁大怒，将他二人赶下金殿。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "非是我瞒名姓不把君见， 圣天子夜得兆三生有缘。"
        },
        {
          "character": "贺知章、孟浩然",
          "type": "同白",
          "text": "离此金殿不远，请先生下马。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "眼望着金銮殿离此不远， 李太白今日里跨马朝天。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "哈，我当是谁，原来是国舅大人。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "还认得老夫。学士公，贡院之事休要怪我。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "学士老爷心如大海，谁来怪你，是谁来罪你。 原来是高公公。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "怎么，还认得咱家吗？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "你学士老爷怎不认识与你，前者在贡院也领过与你的教了，也会过你的高才。 少时见了万岁，还要领教。哈哈哈！还要领教！"
        },
        {
          "character": "贺知章",
          "type": "白",
          "text": "李白宣到。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "贺知章、孟浩然",
          "type": "同白",
          "text": "万岁有旨，宣李白上殿！"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "霎时间管叫你羞愧难言， 怎知道李太白袖内机关。 忽听得宣李白忙上金殿， 手拿定象牙笏拜倒君前。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "臣西蜀李白见驾，愿吾皇万岁！"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "卿家何不抬起头来？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "唐明皇",
          "type": "唱",
          "text": "仰面朝天貌英发， 夜梦贤臣就是他。 赐卿平身且坐下， 君臣们慢慢叙根芽。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "卿家有本，当面奏来。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "谢罢了万岁爷稳坐金殿， 杨国忠、高力士二大奸臣。 被他们扯文章赶出贡院， 罪为臣枉在那天地之间。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "宣臣上殿，有何国事议论？"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "今有白海国进来乌兽本章，特请卿家上殿开读。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "那也不难，依臣一件。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "高、杨二卿，与臣站班，赐臣御酒三杯。"
        },
        {
          "character": "杨国忠、高力士",
          "type": "同白",
          "text": "启奏万岁：臣乃皇亲国戚、穿宫太监，岂是与他站班之人。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "唔，你敢违抗圣旨么？"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨国忠",
          "type": "念",
          "text": "站在矮檐下，"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "怎敢不低头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨国忠、高力士同站班。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "扬尘舞蹈叩拜君前， 二大奸臣来站班。 大喝一声高内监， 与我宣上押表官。"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "哈，使臣上殿，殿角伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天申上，在上场门台口举表章。李白饮酒，笑。"
        },
        {
          "character": "李白",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "谢万岁！"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "谢罢了万岁爷三杯御宴， 怎知道李太白海量宽。 番邦臣子把表献，"
        },
        {
          "character": "李白",
          "type": "西皮快板",
          "text": "醉眼朦胧仔细观。 “白海国来把表献， 献与天朝御驾前。 大唐若是有人念， 岁岁进贡到朝班。 天朝若是无人念， 偏邦小国起狼烟。” 忙将蛮诗念一遍， 龙书案前奏君言。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "臣启奏万岁：被臣解开蛮语，请我主定夺。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "宣使臣上殿。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "使臣上殿。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "一字可差？"
        },
        {
          "character": "马天申",
          "type": "白",
          "text": "一字不差。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "推出午门斩首。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "且慢。两国相争不斩来使。修下飞龙草诏，回复他邦才是。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "就命卿家修下飞龙诏。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "那也不难。依臣一件。"
        },
        {
          "character": "唐明皇",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "高力士与臣脱靴，杨国忠与臣磨墨。"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "启奏万岁：臣乃皇亲国戚，岂是与他磨墨之人？"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "臣乃穿宫太监，岂是与他脱靴之人？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "唔，你敢违抗圣旨？该当何罪？"
        },
        {
          "character": "杨国忠",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "杨国忠",
          "type": "念",
          "text": "冤仇不可结，"
        },
        {
          "character": "高力士",
          "type": "念",
          "text": "结下无休歇。"
        },
        {
          "character": "李白",
          "type": "念",
          "text": "谅人还自谅，何必把冤结。"
        },
        {
          "character": "李白",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "口代天言替君行，"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "高力士，"
        },
        {
          "character": "高力士",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "李白",
          "type": "白",
