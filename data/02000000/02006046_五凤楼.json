{
  "script_id": "02006046",
  "title": "五凤楼",
  "alias": [
    "换子"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李敬犹",
      "hangdang": "老生"
    },
    {
      "name": "薛猛",
      "hangdang": "老生"
    },
    {
      "name": "张夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "武则天欲杀薛丁山满门，李敬犹念忠良不可绝后，因效程婴、杵臼故智，托名查监，将其子孝思，换出薛蛟\n云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、二院子、李敬犹同上。〖牌子〗。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "本爵李敬犹。只为薛氏满门，尽入天牢，是我会同公卿，保救忠良，以赦薛氏 之罪。奈武氏要杀尽忠良。又有一班权臣，屡进谗言，武氏竟要废帝。只是新 君一废，可叹忠良无救也。"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "堪叹忠良屡代贤， 薛刚惹祸胆包天。 扶保唐室东西战， 单戟匹马哪清闲。 今朝诛戮无恩典， 眼见公卿绝后传。 昼夜忧愁难合眼， 并无良谋救出监。 思量心碎身体倦， 步入书房观书篇。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "吓，晋君无道，听信屠岸贾之言，大肆荒淫。有上大夫赵宣子数谏，与岸贾两 下结仇，每每设计，逼走了赵宣子，杀了赵氏一门。赵朔之妻，乃灵公之公主， 住于冷宫，产下遗腹孤儿。宣子门下程婴，救出孤儿。岸贾四下缉拿。程婴 将孤儿养藏别所，将亲生之子金哥出首，说是孤儿。岸贾杀了假孤儿，以为大 患除根。至后孤儿长大成人，冤冤相报，杀尽岸贾一门。哎，要存薛氏一后， 须得一个小儿可换薛蛟也。"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "观罢前朝心起念， 有子可救薛后传。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "我长子孝德五岁，在花园被妖风摄去，至今并无下落；次子孝思，与薛蛟同年。 若去换了薛蛟，我又绝了后代。这便怎么处？哎，昔日程婴若爱其子，如何 存得赵氏孤儿？我今若惜孝思，怎救薛氏之后？我兄现有三子，可以接代宗枝。 我不免舍子去天牢，换出薛蛟子罢了。"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "暗施阴功天有眼， 存个忠义万古传。 我不舍子他绝后， 忠良无人接香烟。"
        },
        {
          "character": "李敬犹",
          "type": "哭",
          "text": "哎呀，儿吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李敬犹下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四禁子、狱官同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《五凤楼》【三本】 2"
        },
        {
          "character": "狱官",
          "type": "念",
          "text": "监狱和班房，牢房有囚床。长板带夹棍，拷打犯法郎。 无钱休告状，有钱理也长。若问阴曹府，我是活阎王。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "我，天牢狱官是也。只因薛刚罪大于天，他倒不知逃往哪里去了，可怜他一门 尽在天牢。这三百八十五口，分作四监，四监又分四牢，又有许多的字号。武、 张二家，命我昼夜紧守。 来，天也晚了，小心牢门吓。"
        },
        {
          "character": "四禁子",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家丁抬竹笼子内藏李孝思同上，家院上，李敬犹乘马上。"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "静悄悄不要高声道， 恐惊奸佞查天牢。"
        },
        {
          "character": "四家丁",
          "type": "同白",
          "text": "来此天牢监门。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "众家丁外面伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家丁带马同下。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "家院叫开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院放抬盒。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "开门。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "看是何人，这时候还来叫门？问他是谁。"
        },
        {
          "character": "禁子",
          "type": "白",
          "text": "呔，叫门的是谁？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "江淮侯前来查监。"
        },
        {
          "character": "禁子",
          "type": "白",
          "text": "吓，乃是江淮侯前来查监。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "快快开门迎接。"
        },
        {
          "character": "禁子",
          "type": "白",
          "text": "是。 侯爷请进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李敬犹进。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "狱官迎接侯爷。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "有钦犯在内，速闭监门。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "是、是、是。 闭门闭门。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "薛猛在哪一号？"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "在这星字号内。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "那薛猛诡计多端，本爵要亲自查点。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "但凭侯爷。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "家院将果盒留下，酒肴尽赏他们去罢。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 狱官，侯爷赏你酒肴，抬下去饮。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "吓，谢侯爷。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "不用你们伺候，下去吃酒罢。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "吓，多谢侯爷。 来、来、来，抬下去。"
        },
        {
          "character": "四禁子",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四禁子同抬下，狱官下。李敬犹望。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "快请薛家大爵主出来。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 大爵主，老爷有请。"
        },
        {
          "character": "薛猛",
          "type": "内白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛猛、张夫人同上。"
        },
        {
          "character": "薛猛",
          "type": "唱",
          "text": "罪同叛逆无人保，"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "三叔惹祸惧法逃。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启老爷：江淮侯在此。"
        },
        {
          "character": "薛猛",
          "type": "白",
          "text": "吓，大人在哪里？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "爵主出来了。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "在哪里？ 哎呀，爵主！夫人！ 中国京剧戏考 《五凤楼》【三本】 3"
        },
        {
          "character": "薛猛、张夫人",
          "type": "同白",
          "text": "大人吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛猛、张夫人同跪。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "不见你带露随朝早，"
        },
        {
          "character": "李敬犹",
          "type": "叫头",
          "text": "爵主！夫人吓！"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "不见你与主立功劳。 忠良非是知心少，"
        },
        {
          "character": "李敬犹",
          "type": "哭头",
          "text": "哎呀，爵主吓！"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "怎奈犯罪法不饶。"
        },
        {
          "character": "薛猛",
          "type": "白",
          "text": "大人吓！"
        },
        {
          "character": "薛猛",
          "type": "唱",
          "text": "罪犯天条当承受，"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "可叹公婆在天牢。"
        },
        {
          "character": "薛猛",
          "type": "唱",
          "text": "同监阻隔万山道，"
        },
        {
          "character": "薛猛",
          "type": "哭头",
          "text": "哎呀，大人吓！"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "父母恩高一旦抛。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "爵主、夫人请坐了。"
        },
        {
          "character": "薛猛",
          "type": "白",
          "text": "大人黑夜到此，有何见教？"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "我等功臣俱已保奏，奈太后不准，无法可救。因此悄悄前来，救令郎出去。"
        },
        {
          "character": "薛猛、张夫人",
          "type": "同白",
          "text": "大人吓，监中查得紧急，怎么救得小儿出去？"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "实不相瞒，我儿孝思，与令郎同年。我特来掉换。 快抱公子与我。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院抱出薛蛟。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "在此。"
        },
        {
          "character": "薛猛",
          "type": "白",
          "text": "大人此言差矣。我薛氏并无恩德，如何以亲生代替小儿，舍其一死？薛家就该 存后，大人就该绝了宗嗣么？"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "况令郎清白无罪，为何代替小儿一死？此事断断使不得吓。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "哎呀，爵主、夫人吓！仗义替死，亦为忠义之鬼。实非虚情假意，不可迟延。 倘若被人知觉，反为有害。"
        },
        {
          "character": "薛猛",
          "type": "白",
          "text": "哎呀，夫人吓，大人有此天高地厚之恩，你我感恩不尽。 大人请上，受我夫妻一拜！"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "哎呀，这就不敢吓。"
        },
        {
          "character": "薛猛",
          "type": "唱",
          "text": "夫妻九泉必相报，"
        },
        {
          "character": "张夫人",
          "type": "白",
          "text": "大人吓！"
        },
        {
          "character": "张夫人",
          "type": "唱",
          "text": "舍子代死恩天高。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "爵主、夫人吓！"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "一朝奉君相交好， 异姓骨肉胜同胞。 舍子代替天有报， 愁眉展放免悲劳。 悲切切将儿抱，"
        },
        {
          "character": "李敬犹",
          "type": "哭头",
          "text": "哎呀，儿吓！"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "为父送你归阴曹。"
        },
        {
          "character": "薛猛、张夫人",
          "type": "同唱",
          "text": "感大恩，"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "舍亲生，"
        },
        {
          "character": "薛猛、张夫人、李敬犹",
          "type": "同唱",
          "text": "神明相照，"
        },
        {
          "character": "四禁子",
          "type": "内同白",
          "text": "请吓！ 中国京剧戏考 《五凤楼》【三本】 4"
        },
        {
          "character": "薛猛、张夫人、李敬犹",
          "type": "同白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院收薛蛟入盒内。"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "狱官、禁卒喊声高。 且待君主圣旨到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛猛、张夫人同回头，同叹。"
        },
        {
          "character": "薛猛、张夫人",
          "type": "同唱",
          "text": "还念薛家汗马劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛猛、张夫人、李敬犹各回头，薛猛、张夫人同下。"
        },
        {
          "character": "李敬犹",
          "type": "三叫头",
          "text": "哎呀，爵主！孝思！哎呀儿吓！"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "舍子搭救薛氏后，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四禁子、狱官抬酒盘同上。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "多谢侯爷！"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "本藩一言你听着： 天牢钦犯须紧守，"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "开门。"
        },
        {
          "character": "四禁子",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "狱官",
          "type": "白",
          "text": "送过侯爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四禁子同下，狱官下。四家丁带马同上。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "马来。"
        },
        {
          "character": "李敬犹",
          "type": "唱",
          "text": "聊尽大义学前朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李敬犹回头。"
        },
        {
          "character": "李敬犹",
          "type": "白",
          "text": "哎呀，儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}