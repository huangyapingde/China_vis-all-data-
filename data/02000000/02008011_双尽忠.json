          "type": "白",
          "text": "小人有交。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "交与何人？"
        },
        {
          "character": "抓地虎",
          "type": "白",
          "text": "交与丫鬟。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "叫丫鬟来。"
        },
        {
          "character": "抓地虎",
          "type": "白",
          "text": "丫鬟走来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟上。"
        },
        {
