          "type": "白",
          "text": "丫鬟叩头。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "丫鬟。剥皮厅那一汉子哪里去了。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "不知。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "着打。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "丫环有交。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "交与何人？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "交与太夫人。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "请太夫人。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "请太夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "班氏上。"
        },
        {
          "character": "班氏",
          "type": "白",
          "text": "请我何事？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "大王有请。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "孩儿拜见母亲。"
        },
        {
          "character": "班氏",
          "type": "白",
          "text": "罢了。坐下。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "儿告坐。母亲。那一汉子哪里去了？"
        },
        {
          "character": "班氏",
          "type": "白",
          "text": "那就是你常常思念的李广兄长来了。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "噢，那个就是我李广兄长么？可容我兄弟一会？"
        },
        {
          "character": "班氏",
          "type": "白",
          "text": "丫鬟。请大老爷。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有请大老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李广上。"
        },
        {
          "character": "李广",
          "type": "念",
          "text": "只因龙国母，终日长挂怀。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "这就是李广兄长？"
        },
        {
          "character": "李广",
          "type": "白",
