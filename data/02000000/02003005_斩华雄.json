          "character": "曹操",
          "type": "白",
          "text": "吓将军，樽酒尚温，请饮干了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "多谢骁骑。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "待我口占一首，庆贺将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起鼓〗。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "威震乾坤第一功，辕门架鼓响咚咚。云长今日施英勇，酒尚温时斩华雄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哈哈哈承赞了。"
        },
        {
          "character": "关羽",
          "type": "唱",
          "text": "敢蒙骁骑美言加， 些小微功何足夸。 丈夫志在安天下， 乱臣贼子岂容他。 辞别骁骑把帐下， 燕雀敢笑鸿鹄家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "关云长秀雅真潇洒， 斩华雄好比井底蛙。"
        },
        {
          "character": "袁绍",
          "type": "白",
          "text": "列公，今日斩了华雄，董卓锐气已挫，吩咐大排筵宴，与刘、关、张贺功。"
        },
        {
          "character": "公孙瓒、袁术、韩馥、张超、孔融、鲍信、马腾、陶谦",
          "type": "同白",
          "text": "言之有理。"
        },
        {
          "character": "袁绍",
          "type": "念",
          "text": "若要天下奇男子，"
        },
        {
          "character": "公孙瓒、袁术、韩馥、张超、孔融、鲍信、马腾、陶谦",
          "type": "同念",
          "text": "须立人间未有功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
