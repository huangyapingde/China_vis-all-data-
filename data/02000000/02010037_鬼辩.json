{
  "script_id": "02010037",
  "title": "鬼辩",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李慧娘",
      "hangdang": "旦"
    },
    {
      "name": "贾似道",
      "hangdang": "净"
    }
  ],
  "plot": "贾似道杀死李慧娘，囚禁裴生后，李慧娘之鬼魂将裴生放走。贾似道认为系其他婢女放走，遂令将所有婢女\n吊起各鞭打一百。李慧娘鬼魂认为冤枉其他婢女，于心不安，遂挺身而出见贾似道，说明原委而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四院子同上，同喝道。贾似道上。"
        },
        {
          "character": "贾似道",
          "type": "引子",
          "text": "烂醉归来明月下，看万条银烛笼纱。"
        },
        {
          "character": "贾似道",
          "type": "念",
          "text": "才罢朝餐，又排家宴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "启爷：三鼓了。"
        },
        {
          "character": "贾似道",
          "type": "念",
          "text": "早不觉三更初下。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "老夫，贾似道。官拜平章之职，与圣上玩月而归，不觉大醉。廖应忠报道：后 花园中，放走裴生，也不知是哪个贱婢。 院子，"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "后堂传话：将众姬妾吊在两廊，各打一百。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "啊。 后堂传话，老爷吩咐：将众姬妾吊在两廊，各打一百。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子自两边分下。"
        },
        {
          "character": "众人",
          "type": "内同白",
          "text": "哎哟！"
        },
        {
          "character": "李慧娘",
          "type": "内北一枝花",
          "text": "忽听得中堂人语喧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李慧娘上。"
        },
        {
          "character": "李慧娘",
          "type": "北一枝花",
          "text": "把俺这幽怯里魂灵诈。 太师坐当衙。 俺这里闪过了，靠边些， 我则道为甚唧喳。 却原来为花园事发。 堂堂宰相坐官衙， 一声儿怒发如雷， 一声儿怒发如雷， 把俺这怯生生小胆儿唬杀。"
        },
        {
          "character": "李慧娘",
          "type": "白",
          "text": "妾乃生前李慧娘。只因鬼魂放走裴生，贼子不知，拷打众家姐妹。我若不向前 厮认呵！"
        },
        {
          "character": "李慧娘",
          "type": "梁州第七",
          "text": "怎忍见，姊妹们受无端拷打， 好一部肉骨吹，唧唧喳喳， 呀呀呀，仗威风，不唬得阎浮乍。 似这等三更签押，五鼓排衙， 荆条竹板，玉锁金枷。 呀呀呀，这壁厢只少个拨云堆牛头夜叉， 那壁厢只少个哨锋尖鸟侩獠牙。 呀呀呀，到阴司少不得一桩桩，一件件，把善恶来稽查， 少不得明晃晃把业镜查。 早料到葫芦提一笔勾，拿一笔勾， 拿死不当要，拿死不当要。 针尖事儿，谎的有天来大， 恁粗豪将神鬼诈。 唔，贼呀，只怕相报冤冤定不差， 迟早争些，迟早争些。"
        },
        {
          "character": "李慧娘",
          "type": "白",
          "text": "老爷在上，贱妾叩头。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "我把你这贱婢，一向躲在哪里，今日才来见我？"
        },
        {
          "character": "李慧娘",
          "type": "白",
          "text": "夜已深了，老爷不在后堂将息贵体，为何在此发怒？"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "后花园中放走裴生，敢是你这贱婢？从实招上来，免得我三推六问。"
        },
        {
          "character": "李慧娘",
          "type": "白",
          "text": "老爷容禀。"
        },
        {
          "character": "李慧娘",
          "type": "牧羊关",
          "text": "一犬声还吠， 千牛在那家。 似这等重重朱户锁窗纱， 怎生得羊肠路，羊肠路，去奔走天涯。 动不动钢刀一下， 俺可也不害些儿怕。 迟和急，一死无加， 却原来有亏心的也怕杀。 怎不自保身家？ 小妮子从来心胆大， 因此上拚残生，拚残生来调牙。"
        },
        {
          "character": "李慧娘",
          "type": "四块玉",
          "text": "脱牢笼，尽是咱， 怎掇陷，在他名下。 只恁的，把书生冷禁在官衙。 妾听他一句句诉向， 都是伤情话。 他说道，穷秀才，分无缘， 住在相府家。 多拜上老平章， 且放了先生假。 他思家，这其间， 是奴方便了他。"
        },
        {
          "character": "李慧娘",
          "type": "骂王郎",
          "text": "俺与他欢会在西廊下， 行了些云雨，勾了些风花。 这些时一死， 一死干休罢。 待今宵跟着他呀，呀，呀， 厮撞着叫人难停踏。"
        },
        {
          "character": "李慧娘",
          "type": "哭皇天",
          "text": "休，休，休，这话儿提他， 怎么说将来叫奴痛杀。 则他在断魂桥， 盻上个人情雅。 少年郎瞥见了冷嗟呀， 又不曾背地里通些情话。 又不曾向人前， 眼角眉梢去调弄他。 恰怎生半生纳纳彩， 一剑分花，一剑分花。"
        },
        {
          "character": "李慧娘",
          "type": "鸟夜啼",
          "text": "手提着明晃晃钢刀一把， 下场头轮到奴家。 把奴的尸骸， 仍葬在牡丹花。 俺可也作鬼， 作鬼风流杀。 伴艳艳朝霞， 冉冉春华， 与他把天姿国色向人夸， 怕的是风僝雨僽香魂乍。 早些儿发付， 有甚么争差，有甚么争差。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "我自动手，倒便宜你这贱婢，我有宝剑一口，拿去刎下头来见我。"
        },
        {
          "character": "李慧娘",
          "type": "白",
          "text": "从命了。"
        },
        {
          "character": "李慧娘",
          "type": "尾声",
          "text": "好一会诉不尽伤情话，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内鸡鸣。"
        },
        {
          "character": "李慧娘",
          "type": "尾声",
          "text": "忽听金鸡报晓衙。"
        },
        {
          "character": "李慧娘",
          "type": "念",
          "text": "吹得他冷风头齿寒毛乍，老爷呵，饶恕了这般俊娃，难将罪加。 真个要寻消问息，只索向半闲堂牡丹花下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李慧娘下。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "院子快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子同上。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "老爷怎么样了？"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "方才讲话的，好像生前李慧娘。"
        },
        {
          "character": "二院子",
          "type": "同白",
          "text": "正是呢。"
        },
        {
          "character": "贾似道",
          "type": "白",
          "text": "喂呀，世间竟有这样出壳的活鬼，明日请些高僧高道，超度她的亡魂便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二院子同允。"
        },
        {
          "character": "贾似道",
          "type": "念",
          "text": "从来说鬼不分明，鬼魅原来却有灵。一点香魂独未散，三千云水广超生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贾似道、二院子同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}