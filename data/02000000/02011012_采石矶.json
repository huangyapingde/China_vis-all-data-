        },
        {
          "character": null,
          "type": "stage",
          "text": "胡大海下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "常遇春听令！"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "命你带领三千火炮手，五十号战船，先抢牛石渚，后破采石矶，听我一令！"
        },
        {
          "character": "徐达",
          "type": "江儿水",
          "text": "拚将忠义相酬，自送头颅， 怎惜血溅沙场。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "得令。 令出，唗，带马！"
        },
        {
          "character": "众士卒",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "中军，"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "将台撤至江口。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。 呔！众将官！"
        },
        {
          "character": "众士卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "将台撤至江口。"
        },
        {
          "character": "众士卒",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同走圆场，同下。"
        }
      ]
    },
