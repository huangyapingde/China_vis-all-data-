          "text": "元大将上。"
        },
        {
          "character": "元大将",
          "type": "念",
          "text": "令行山岳动，言出鬼神惊。"
        },
        {
          "character": "元大将",
          "type": "白",
          "text": "俺奉都督将令，把手牛石渚，远远望见，战船无数，想必敌人来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡大海上，战，杀元大将，下。铁木耳上，众士卒同上。"
        },
        {
          "character": "铁木耳",
          "type": "念",
          "text": "大将扬威武，雄似山头虎。杀人汤泼雪，斩将如截土。"
        },
        {
          "character": "铁木耳",
          "type": "白",
          "text": "某，铁木耳。大元驾前为臣。奉狼主之命带领人马，镇守采石矶，以防贼人攻 取。 唗，巴都鲁。"
        },
        {
          "character": "众士卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "铁木耳",
          "type": "白",
          "text": "打道矶头去者。"
        },
        {
          "character": "众士卒",
          "type": "同白",
          "text": "吓。 已到矶头。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "铁木耳上城，坐。"
        },
        {
          "character": "铁木耳",
          "type": "白",
          "text": "多备滚木擂石，小心防守者。"
        },
        {
          "character": "众士卒",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "徐达",
          "type": "内唱",
          "text": "离大营上战船风狂浪大，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达上。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "有本帅为江山戴月披星。 奉圣命平采石畿辅宁静， 对大江设将台扎下行营。 中军帐传号令舟师攻进， 专待看众儿郎各逞其能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭英、众士卒同上，杀，同下。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "小郭英年虽幼骁勇非常， 可算得我朝中驾海金梁。 万军中取上将犹如反掌， 扶江山保社稷四海名扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李文忠、众士卒同上，杀，同下。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "李文忠生长在宦室豪门， 他乃是万岁爷御前外甥。 只今番若能把干戈平定， 五凤楼专与他画影图形。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡大海、众士卒同上，杀。"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "啊，看采石矶，山高水深，怎能得破。也罢，船上有桅，桅上有斗，不免将身 藏在斗内，纵上矶头便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "铁木耳举石打胡大海。"
        },
        {
          "character": "铁木耳",
          "type": "白",
          "text": "招打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡大海跌。"
        },
        {
          "character": "胡大海",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "胡大海下。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "胡大海生的来性如烈火， 大江中统舟师破浪冲波。 牛石渚斩贼将英雄不弱， 被擂石打落水怎生奈何。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春、众士卒同上，杀，同下。"
        },
        {
          "character": "徐达",
          "type": "唱",
          "text": "常遇春他本是明辅上将， 在豪梁夺状元定国安邦。 只杀得元朝中人人胆丧， 全凭他保皇朝辟土开疆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众士卒同上，同杀，同下。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "且住！你看采石矶，这等坚固，何时得破？有了，我想重赏之下，必有勇夫。 待本帅传下将令。 五营四哨，大小将官，听者！"
        },
        {
          "character": "众士卒",
          "type": "内同白",
          "text": "吓！"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "有人破得采石矶，功为第一，先锋大印，付他执掌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐达下。常遇春上。"
        },
        {
          "character": "常遇春",
          "type": "白",
          "text": "啊，方才元帅传下将令，有人破得采石矶，功为第一，先锋大印，付他执掌。 又道是一人拚命，万夫难挡。船上有桅，桅上有斗，待我将身藏在斗内，纵上 矶头便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常遇春登城，杀铁木耳，下。众人同上，杀，同下。徐达、众人同上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "启元帅：采石矶已破。"
        },
        {
          "character": "徐达",
          "type": "白",
          "text": "就此班师复命。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大尾声。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}