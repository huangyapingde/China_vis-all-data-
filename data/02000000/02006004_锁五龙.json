      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四卒引李世民、徐勣同上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "为王的领兵征洛阳， 人马纷纷摆战场。 三军奋勇谁敢挡， 只为父王锦家邦。 中国京剧戏考 《锁五龙》【全本】 5"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！启千岁：单雄信单人独骑，前来踏营，勇不可挡，请令定夺。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "再去打探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "呀，不好了！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "洛阳反了单雄信， 不由小王心内惊。 开言便把先生叫， 还望皇兄把计行。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "听说反了单雄信， 倒把徐勣着了惊。 我本待急忙传军令， 难灭当年结拜情。 若待要按兵不发令， 有碍我主锦乾坤。 罢罢罢，咬定牙关忙传令， 宣上幽州小罗成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "正在后帐把兵论， 军师呼唤为何情？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "有何差遣？"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "洛阳反了单雄信， 单人独骑踏唐营。 本帅与你一支令， 把守东门要小心。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "罗成上马踏金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "再传后帐黑夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑月奴上。"
        },
        {
          "character": "黑月奴",
          "type": "唱",
          "text": "方才后帐饮杯巡， 忽听军师传一声。"
        },
        {
          "character": "黑月奴",
          "type": "白",
          "text": "有何将令？"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "雄信单骑踹唐营， 命你把守在南门。"
        },
        {
          "character": "黑月奴",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "黑月奴",
          "type": "唱",
          "text": "黑夫人上马笑盈盈，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑月奴下。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "再传丑陋程咬金。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "唱",
          "text": "忽听一声传将令， 阵阵不离俺老程。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "有何将令？"
        },
