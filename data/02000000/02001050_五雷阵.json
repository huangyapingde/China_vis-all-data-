{
  "script_id": "02001050",
  "title": "五雷阵",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "孙膑",
      "hangdang": "老生"
    },
    {
      "name": "毛蕡",
      "hangdang": "净"
    },
    {
      "name": "王翦",
      "hangdang": "净"
    },
    {
      "name": "王禅",
      "hangdang": "老生"
    },
    {
      "name": "太上老君",
      "hangdang": "老生"
    }
  ],
  "plot": "此剧系出列国，秦始皇遣王翦并吞六国之时，从妖道毛蕡助王翦攻齐起，其大概为孙膑侄为毛蕡所败，孙膑\n亲自出阵杀退毛蕡，不意被毛蕡败回作法，设下五雷阵，将孙膑魂摄入，将殛死之。幸孙膑道数高，真元不\n动，卒破毛蕡阵，用鬼谷师所遗太极图击死毛蕡云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡、王翦、五雷孕妇同上，同摆阵。孙膑上，打阵，入阵，跪，挂双拐。"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "眼前一阵红光现， 阴风吹得透体寒。 醉卧埃尘神魂乱， 放却青牛在那边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂上。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥醒来！"
        },
        {
          "character": "孙膑",
          "type": "西皮导板",
          "text": "耳边听得人叫喊，"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "又见贤弟在面前。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "贤弟到此何事？"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "小弟前来搭救三哥出阵。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "有劳贤弟。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥，头上鲜花，往哪里去了？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "被那贼道，押在阵内了，三日内就要丧命。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "这便如何是好？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "要愚兄出阵，这也不难，除非有太上老君九转还魂丹、南极真人的太极图，才 能出阵。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥，这有何难？小弟前去，盗来法宝，救三哥出阵便了。"
        },
        {
          "character": "孙膑、毛遂",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑、毛遂同下。毛蕡、王翦、五雷孕妇同暗下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王禅上。"
        },
        {
          "character": "王禅",
          "type": "引子",
          "text": "久住深山，抛却尘缘。"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "山人王禅，只因孙膑被打在五雷阵中。今有金眼毛遂，来盗仙丹，不免助他成 功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂上。"
        },
        {
          "character": "毛遂",
          "type": "唱",
          "text": "足踏祥云到高山， 大胆来盗九转丹。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "来此已是云蒙山。我想王禅，炼成仙丹，焉肯送我？不免变作老君模样，诓他 中国京剧戏考 《五雷阵》【四本】 2 丹药便了。变！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂下。太上老君上。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "徒儿在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王禅跪。"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "弟子王禅，迎接仙师。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "谢仙师。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "你在洞中作什么来？"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "弟子炼丹。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "炼了多少？"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "两粒半。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "拿来我看。"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "是。仙师请看。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "呔！小心着看守洞门，我毛遂去也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太上老君下。"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "你看这畜牲胆大，戏耍山人。若不是念他为孙膑而来，焉能放他而去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王禅下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "太上老君上。"
        },
        {
          "character": "太上老君",
          "type": "引子",
          "text": "执掌三清，法令施行。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "山人，太上老君是也。今有毛遂，前来盗取太极图，救孙膑出阵。不免到洞外 打坐，假装睡熟，让他盗去便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂上。"
        },
        {
          "character": "毛遂",
          "type": "念",
          "text": "离了水帘洞，又盗八卦图。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "且住。你看这老儿睡着，待我盗来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂盗图。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "且住。我毛遂一生不作暗事，不免将他唤醒。 呔！毛遂盗了你的八卦仙图，救那孙膑，即刻送来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂下。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "你看这贼仙，将图盗去，不免去到云端，收回此宝便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太上老君下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡、王翦、五雷孕妇同上，同摆阵。孙膑上，入阵。"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "盼想家园难得见， 寸断肝肠不安然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛遂上。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥，小弟盗了金丹来了。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "盗了多少？"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "两粒半。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "与兄一粒，青牛一粒，剩下半粒，贤弟衔在口内。无有太极图，也是枉然。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "三哥请看。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "好哇！"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "见图犹如天开眼， 贤弟恩情重如山。 打开了太极祥光现， （孙膑起，杀。毛蕡、王翦、五雷孕妇同暗下。孙膑用图照。王翦、毛蕡同上，同开打。孙膑打死毛蕡，毛 蕡下。孙膑擒王翦。太上老君、王禅同暗上。）"
        },
        {
          "character": "孙膑",
          "type": "唱",
          "text": "阵中逃出了大罗神仙。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "且慢。他乃奉敕旨之人，不可伤他。 中国京剧戏考 《五雷阵》【四本】 3"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "看在师父面上，饶尔去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王翦下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "参拜师父。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "毛遂，我的太极图呢？"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "多谢太极图。"
        },
        {
          "character": "王禅",
          "type": "白",
          "text": "毛遂，还我金丹。"
        },
        {
          "character": "毛遂",
          "type": "白",
          "text": "金丹，被我三哥吞在肚内了。"
        },
        {
          "character": "王禅、太上老君",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "多谢师父搭救。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "回营去罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王禅、太上老君同下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "贤弟随我来。"
        },
        {
          "character": "孙膑",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑、毛遂同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}