{
  "script_id": "02001019",
  "title": "攻潼关",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "姜子牙",
      "hangdang": "净"
    },
    {
      "name": "余女",
      "hangdang": "武旦"
    }
  ],
  "plot": "姜尚第一次奉命攻打潼关，被余化龙用瘟药将士兵全行迷倒。赖慈航道人救援，始得脱险。本剧系第二次进\n兵，无奈余化龙十分骁勇，杨戬等均相继败下，最后由雷震子腾空遥击，始将余化龙打死。余化龙之五子一\n女，亦均战死沙场。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同上。"
        },
        {
          "character": "杨戬",
          "type": "粉蝶儿",
          "text": "甲胄随身， 小英雄甲胄随身。 凭着俺猛勇奇能， 今日里到疆场冲锋陷阵。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "杨戬。"
        },
        {
          "character": "韦陀",
          "type": "白",
          "text": "韦陀。"
        },
        {
          "character": "杨任",
          "type": "白",
          "text": "杨任。"
        },
        {
          "character": "龙须虎",
          "type": "白",
          "text": "龙须虎。"
        },
        {
          "character": "金吒",
          "type": "白",
          "text": "金吒。"
        },
        {
          "character": "木吒",
          "type": "白",
          "text": "木吒。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "哪吒。"
        },
        {
          "character": "雷震子",
          "type": "白",
          "text": "雷震子。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "众位师兄请了！"
        },
        {
          "character": "韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "今日师叔发兵，命你我两厢伺候。"
        },
        {
          "character": "韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "请。 （杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子分归两边站。四文堂、四大铠、四上手、姜子牙 同上。）"
        },
        {
          "character": "姜子牙",
          "type": "引子",
          "text": "昆仑嫡派，顺天命宇宙重开。甲子年，成汤衰败。戊午期周室运来。"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "参见师叔。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "姜子牙",
          "type": "念",
          "text": "两仪四象分阴阳，女娲炼石补上苍。三教共议封神榜，吾奉法旨灭成汤。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "老夫姜子牙，前奉王命攻打潼关，不料被余化龙暗用瘟药将我军迷倒，多亏慈 航道人相救，方得无事。今日整齐兵将与他见个胜负。 众弟子听吾一令！"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "姜子牙",
          "type": "二黄正板",
          "text": "自三皇开关后乾坤荡荡， 尧传舜舜传禹降至商汤。 殷纣王宠妲己酒色淫荡， 诛发妻杀亲子令人惨伤。 女娲庙去拈香欺灭神像， 粉壁墙题诗句触怒上苍。 女娲氏聚齐了妖群一党， 灭成汤兴周室国运永昌。 有老夫奉法旨肩背神榜， 保武王开山河一统无疆。 临潼关余化龙兵多将广， 用瘟药迷将士险把命亡。 感天恩不绝我周营兵将， 解三灾救八难多亏慈航。 吾今日整雄威重发兵将， 托上苍保佑着得胜疆场。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "杨戬。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "type": "二黄正板",
          "text": "仗玄功多变化奇才无两， 移深山倒大海妙术高强。 此一番去出兵谁人敢挡， 三尖刀嚎天犬带在身边。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "韦陀。"
        },
        {
          "character": "韦陀",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "type": "二黄原板",
          "text": "你七世神通体天地恩养， 自幼儿修道法显应无疆。 降魔杵打神将天仙难挡， 建奇功吾将你威名表扬。"
        },
        {
          "character": "韦陀",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "杨任。"
        },
        {
          "character": "杨任",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "type": "二黄原板",
          "text": "你在那紫阳洞修成法像， 蒙师恩赐与你宝扇神枪。 到阵前必须要神眼观望， 管教那余化龙无处躲藏。"
        },
        {
          "character": "杨任",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "金吒。"
        },
        {
          "character": "姜子牙",
          "type": "二黄原板",
          "text": "你本是将门子英雄上将， 一朝君一朝臣子胜父强。 今日里逢劫运乾坤改样， 必须要秉忠心扶保武王。"
        },
        {
          "character": "金吒",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "木吒。"
        },
        {
          "character": "木吒",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "type": "二黄原板",
          "text": "兄刚强弟好汉血气勇壮， 遇见那余化龙谨慎提防。 与周室建奇功谁人不仰， 方显你将门子非比寻常。"
        },
        {
          "character": "木吒",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "哪吒。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "type": "二黄原板",
          "text": "你本是莲花体变化多广， 乾坤圈火尖枪盖世无双。 风炎轮如闪电霞光万丈， 生三头并六臂无人能当。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "龙须虎。"
        },
        {
          "character": "龙须虎",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "type": "二黄原板",
          "text": "周室兴成汤败刀兵不让， 吾主爷行仁义兵伐商汤。 但愿得干戈静万民欢畅， 享尧天乐舜日天下安康。"
        },
        {
          "character": "龙须虎",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "雷震子。"
        },
        {
          "character": "雷震子",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "姜子牙",
          "type": "二黄原板",
          "text": "黄金棍重如山奥妙多广， 费辛劳兴周室保定家邦。 兄与弟弟和兄富贵安享， 功劳薄名不朽高载清香。 众弟子传吾令回归营帐，"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "姜子牙",
          "type": "二黄摇板",
          "text": "这一阵使商纣国破家亡。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "众将官起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四大铠、余达、余兆、余光、余先、余德同上，同站门。〖牌子〗。旗夫、余化龙同上。"
        },
        {
          "character": "余化龙",
          "type": "白",
          "text": "某，余化龙。前者用瘟药将姜子牙人马迷倒，数日不见动静，适才探马报道， 姜尚复又兴兵前来，岂肯容他猖狂。 众儿郎！城楼去者！ （〖牌子〗。余化龙上城。姜子牙、杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子、四文堂、四 大铠、四上手同上，同斜一字。）"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "来此已是临潼关。"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "安营下寨。"
        },
        {
          "character": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "安营下寨。哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜子牙、杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子、四文堂、四大铠、四上手同下。"
        },
        {
          "character": "余化龙",
          "type": "白",
          "text": "啊，儿啊，看姜尚人马犹如潮水一般，如何是好？"
        },
        {
          "character": "余达",
          "type": "白",
          "text": "啊，爹爹，想是他国出了能人，解开瘟药也是有的。你我父子领兵出城与他决 一死战。"
        },
        {
          "character": "余化龙",
          "type": "白",
          "text": "好啊！ 众将官，开城迎敌者。 （四蓝文堂、四大铠、余达、余兆、余光、余先、余德、余化龙同出城。姜子牙、杨戬、韦陀、杨任、龙须 虎、金吒、木吒、哪吒、雷震子、四文堂、四大铠、四上手同上，会阵。）"
        },
        {
          "character": "余化龙",
          "type": "白",
          "text": "呔！马前来的敢是姜尚？"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "唗！胆大余化龙，前者暗用瘟药将我军迷倒，今日整齐兵将与你分个胜负。"
        },
        {
          "character": "余化龙",
          "type": "白",
          "text": "姜尚，劝尔等早些下马投降，少时被擒，悔之晚矣！"
        },
        {
          "character": "姜子牙",
          "type": "白",
          "text": "众弟子与我杀！ （四蓝文堂、四大铠、余达、余兆、余光、余先、余德、姜子牙、韦陀、杨任、龙须虎、金吒、木吒、哪吒、 雷震子、四文堂、四大铠、四上手自两边分下，余化龙、杨戬对刀双下。）"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（金吒、木吒、哪吒、雷震子与余兆、余光、余先、余德打单对，同下。余化龙上，打败杨戬下，杨戬、韦"
        },
        {
          "character": null,
          "type": "text",
          "text": "陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同败下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同上，同挖门。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "众位师弟，余化龙杀法厉害，大家用法宝擒他便了。"
        },
        {
          "character": "韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子",
          "type": "同白",
          "text": "言之有理。杀！ （杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同下。余达上，杨戬败，变嚎天犬咬死余达下。 连场赶活羊，余兆、余光、余先、余德同死，同下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（杨戬上，金吒、木吒、雷震子、余化龙同上，同打，杨戬、金吒、木吒、雷震子同败下。哪吒、雷震子同"
        },
        {
          "character": null,
          "type": "text",
          "text": "上。）"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "余化龙十分骁勇，如何是好？"
        },
        {
          "character": "雷震子",
          "type": "白",
          "text": "待俺展翅腾空，将他打死。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "雷震子",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷震子下。余化龙上。"
        },
        {
          "character": "余化龙",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨戬、金吒、木吒同败下。"
        },
        {
          "character": "余化龙",
          "type": "三笑",
          "text": "哧嘻嘻，哇哈哈，哇呀呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷震子上。"
        },
        {
          "character": "雷震子",
          "type": "白",
          "text": "呔！着打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷震子打死余化龙下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝文堂、四下手、余女同上，同挖门。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！老元戎落马！"
        },
        {
          "character": "余女",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "余女",
          "type": "白",
          "text": "众将官，杀上前去！ （会阵。杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同上，与余女对刀双下，上下手打档子， 余女起打连环，打出手。）"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同上，同摆阵。九龙风火罩擒住余女死。〖尾声〗"
        },
        {
          "character": null,
          "type": "text",
          "text": "。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}