{
  "script_id": "02006037",
  "title": "法场明冤",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "孙悟空",
      "hangdang": "武生"
    }
  ],
  "plot": "柏宪大将军将唐僧、沙悟净押入法场，正要行刑，适孙悟空同猪悟能赶至。乃将唐僧、沙悟净救出，并令百\n花羞与花香洁与其父及其丈夫相见。柏宪至此，始知其东床黄袍郎，真为妖怪云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "地方上。"
        },
        {
          "character": "地方",
          "type": "念",
          "text": "惧法朝朝乐，欺公日日忧。"
        },
        {
          "character": "地方",
          "type": "白",
          "text": "自家，西市口总甲胡斯闹便是。今日奉令旨，处决一只妖虎，一个妖僧。要把 虎来剥皮示众，道是妖僧变来的。为此到市曹号令。这一桩事，委厉新奇。比 往常行刑，更加严肃。这是我的干系。系大家小户所者。 今日大将军亲自监斩，不是玩耍的，你们各家闭户，休连累人们。小心要紧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "地方下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上。"
        },
        {
          "character": "孙悟空",
          "type": "端正好",
          "text": "旧行为重抛扬， 救师父同上西方。 迤逦的扫除妖洞，消灾障， 猛轮着金箍棒。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "俺，孙悟空。为救师父，重复下山。同了八戒先到妖精洞里略显神通。飞身来 到这宝象国。好风景也！"
        },
        {
          "character": "孙悟空",
          "type": "滚绣球",
          "text": "虽然属外邦， 却也山河壮。 碧辉煌宫廷高敞， 六市中扰扰攘攘。 管弦接，按的新腔， 花柳巷，扮好艳妆。 不枉唤国名宝象， 只可惜柏将军卖弄王章。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内鸣锣声〗。"
        },
        {
          "character": "孙悟空",
          "type": "滚绣球",
          "text": "猛听一声锣震天响， 则见那四面兵围匝地长。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "原来是妖魔诬奏将军，我师父在此典刑哩！"
        },
        {
          "character": "孙悟空",
          "type": "滚绣球",
          "text": "且待俺闯入法场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众小军抬囚笼、众刽子手同上，囚笼内虎形。柏宪上，绕场。众小军分持。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "刽子手，就此开刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众刽子手同应。孙悟空闯上，虚白。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "你是哪里来的野和尚？擅闯法场！ 左右，与我拿下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众小军同拿。孙悟空打。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "这等无礼。报名来！"
        },
        {
          "character": "孙悟空",
          "type": "叨叨令",
          "text": "俺，休得要问俺短和长， 笑你肉眼光不亮。 怎便把鸱鸮做凤凰， 将砥鹗加在瑚琏上。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "真凤真玉在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空指虎形。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "这不是么！"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "这是真正妖魔，你怎么不是？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你好欠明白也！"
        },
        {
          "character": "孙悟空",
          "type": "叨叨令",
          "text": "痛周公难免流言讲， 叹仲尼怎避狐裘谤。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "据你说妖魔是谁？"
        },
        {
          "character": "孙悟空",
          "type": "叨叨令",
          "text": "兀不是贵东床也么哥， 兀不是贵东床也么哥。 把妖魔反认作嫡亲半子， 配着珠擎掌。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "这也难相信。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "俺不与你闲讲。且救了我师父，你自明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空作吹气。虎形下，唐僧上。众刽子手、囚笼自两分分下。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "徒弟，不是你来，我险些丧了命了。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "弟子救护来迟，致令师父受此魔难，皆弟子之罪也。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "闻得齐天大圣孙悟空，原来就是尊驾么？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "造化。你今认识俺孙爷爷了！我师父呵！"
        },
        {
          "character": "孙悟空",
          "type": "脱布衫",
          "text": "救人心反受灾殃， 说法体几致危亡。 不是俺前来救将， 怎认出大唐朝取经三藏。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "下官有眼无珠，多有得罪。大圣既能救令师返本还原，必知小女下落。"
        },
        {
          "character": "孙悟空",
          "type": "小梁州",
          "text": "俺在那黄金塔院会红妆， 是君家爱女堪伤。 可怜她香消粉退减容光， 常把归期望，盼亲舍，泪千行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柏宪哭。"
        },
        {
          "character": "孙悟空",
          "type": "么篇",
          "text": "你不念亲生骨肉遭魔， 一谜价蛊惑妖王。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "我那儿苦煞你了！"
        },
        {
          "character": "孙悟空",
          "type": "么篇",
          "text": "你何必假慈想，空惆怅，"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "圣僧，下官知罪了！令徒处，望乞方便。令我父女早得团圆，莫大恩德。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "悟空，他的令嫒，你可救她一救。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "师父，那百花羞呵！"
        },
        {
          "character": "孙悟空",
          "type": "么篇",
          "text": "俺提出了天罗地网。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "几时得？"
        },
        {
          "character": "孙悟空",
          "type": "么篇",
          "text": "顷刻里便知端详。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪悟能、百花羞、花香洁、闻仁同上。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "住了。请开眼。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "这是哪里了？"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "那个不是你的父亲！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "那个不是你女儿！"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "果然是我女儿！"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "此女是谁？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "这就是受冤枉闻道泉的妻子。 你二人过来，见过大将军。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "下官得罪。闻娘子同小女到府中相会寒荆。闻生随下官入朝，奏明圣上。定当 一力保奏，管取荣华。前者受惊，下官着实抱疚了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上，百花羞、花香洁、车夫同下。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "大圣，有劳神力，令我父女团圆。下官何以为报？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "大将军！"
        },
        {
          "character": "孙悟空",
          "type": "煞尾",
          "text": "今朝喜得花无恙， 笑杀邻家蝶自忙。 乍地里团圆一堂， 结果了两下悽怆。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "八戒，沙僧，随师父进朝去见国王。"
        },
        {
          "character": "孙悟空",
          "type": "煞尾",
          "text": "俺再去剪妖狼， 才不负孙爷爷重下降！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}