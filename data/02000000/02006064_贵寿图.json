{
  "script_id": "02006064",
  "title": "贵寿图",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "郭子仪",
      "hangdang": "净，素蓝箭袖，青团龙马挂，荷叶盔，黑三髯，扎靠腿子"
    },
    {
      "name": "李白",
      "hangdang": "老生，学士衣，戴学士盔，黑三髯"
    },
    {
      "name": "史思明",
      "hangdang": "净，扎白靠，披蟒白，软扎巾，戴蛾子翎尾，白粉脸，黑满髯"
    },
    {
      "name": "向导",
      "hangdang": "丑，穿旧布箭袖，套卒褂，戴将巾，白四喜"
    },
    {
      "name": "织女",
      "hangdang": "占旦"
    },
    {
      "name": "史将甲",
      "hangdang": "净，扎靠，戴扎巾盔"
    },
    {
      "name": "史将乙",
      "hangdang": "副净，扎靠，戴扎巾盔"
    },
    {
      "name": "史将丙",
      "hangdang": "末，扎靠，戴扎巾盔"
    },
    {
      "name": "史将丁",
      "hangdang": "丑，扎靠，戴扎巾盔"
    },
    {
      "name": "马童",
      "hangdang": "小生，箭袖卒挂将巾"
    }
  ],
  "plot": "郭子仪因延误军粮，被戈书翰押解进京，按军情定罪。因李白上殿保本，蒙皇帝不咎既往，并授为衙门副将，\n带领亲军，前往河东听候差遣。起程之日，李白特备酒宴，至长亭饯行。到差之日，正安禄山造反，史思\n明进攻之时，节度使特命郭子仪率领少数精兵，夜登高冈，探看史军动静。郭子仪乃传唤向导，问史营驻扎\n地名，及进攻道路。得悉绕道路远，直道多山。路过红山口，又名天台阶。乃每年七夕织女必经之地，遇有\n造化者，当可与织女讲话。该日正为七夕，郭子仪乃独身前往。及至正心庄，果然天现红光。郭子仪乃下马\n虔心拜祷，织女从云中下降，赐郭子仪贵寿全图。并嘱忠心保国，重整大唐。先拜将，后封王，夫荣妻贵，\n福寿绵长。旋闻鼓鸣马叫，史思明正演阵场。郭子仪一一探明，翌日乃出与史思明讨战。史军大败，弃营逃\n走。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖发点〗。四红龙套。四白龙套各执标旗同上，四史将同上，同站门。史思明上。"
        },
        {
          "character": "史思明",
          "type": "点绛唇",
          "text": "统领雄兵，百战百胜，施英勇，惯战能争，令出山摇动。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。史思明坐高台。"
        },
        {
          "character": "史思明",
          "type": "念",
          "text": "威风凛凛镇河东，统领三军十万兵。令出犹如山摇动，要夺唐室锦江洪。"
        },
        {
          "character": "史思明",
          "type": "白",
          "text": "俺史思明。奉吾主安千岁之命，统领三军，将在河东起义，要夺唐室天下。且 喜到处连捷获胜。今当乘此军威大振，正好兴兵前进。 嘟，众将官。"
        },
        {
          "character": "四史将",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "史思明",
          "type": "白",
          "text": "点齐大队，吩咐响炮拔营。"
        },
        {
          "character": "四史将",
          "type": "同白",
          "text": "得令。 嘟，众将官。响炮拔营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "手下与史思明带马。四史将同上马。〖醉太平〗。众人同走大圆场，同斜门，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖朝天子〗打两段。二马牌子青布箭稍子帽背文书骑马同上，同跑圆场。旗牌官素箭马挂将巾黑满骑马上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "旗牌官归中场站。）"
        },
        {
          "character": "旗牌官",
          "type": "白",
          "text": "俺河东节度麾下旗牌官是也。今有安禄山，命史思明招服三镇兵将，造逆谋反。 连夺十府州县，势甚猖狂。节度大人命俺押本进京驰奏去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。二马牌子同跑绕圆场，二马牌子、旗牌官同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小锣打上〗。李白上。"
        },
        {
          "character": "李白",
          "type": "引子",
          "text": "沉津浓郁，一管笔，画现硃矶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白坐外中场。"
        },
        {
          "character": "李白",
          "type": "念",
          "text": "文章光辉气芬芳，诗书含英滋味长。只可润身怡情赏，休以翰墨治家邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "下官李白，乃陇西人氏。昔年赴考，被高、杨二人赶出贡院。多蒙孟、贺二公， 荐入唐室为臣。圣上钦赐翰林学士，特命开读蛮诗，饬修飞龙草诏。甚蒙圣 恩宠渥，诏赋清平调三章。只因朝中高、杨专政，安禄山居心叵测。我也曾奏 过数本，怎奈圣上不肯垂允。如今酿成跋扈之势，现在据有河东三镇，大逆猖 獗。我虽寄情诗酒，岂肯失于臣下之志？前者与郭子仪邂逅相识，因他误慢军 粮，被戈书翰奏解进京，要按军情定罪。是我看他相貌非俗，晚成大器，因此 上殿保本。蒙圣上洪恩，赦宥既往之咎，授职为衙门副将。命他带领亲军，前 往河东，听候委用。昨日他与我辞行，今日正当起程之日。我不免亲到长亭， 一来与他饯行，二来劝他勉力图报君王。 家院！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "吩咐预备佳宴美酒，随我往长亭去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖慢长锤〗。四青袍带小皂隶帽抬食盒酒坛自两边分上。院子带马，众人同走四门。"
        },
        {
          "character": "李白",
          "type": "西皮慢板",
          "text": "翰墨文章似海渊， 才子风流莫求官。 我也曾跨马朝金殿， 钦赐御酒写吓蛮。 高、杨二人分班站， 在金殿脱靴把墨研。 我平生好酒尝夜晏， 金马门醉骂安禄山。 到如今养痈成巨患， 我岂肯袖手坐旁观？ 得遇英雄怀赤胆， 理当与国荐英贤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同领下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四帽钉甲罐子盔执月华旗同上，马童上。〖长锤〗。郭子仪上，站门。郭子仪上。"
        },
        {
          "character": "郭子仪",
          "type": "西皮摇板",
          "text": "志秉忠心怀赤胆， 知遇多蒙李青莲。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "俺郭子仪。只因误慢军粮，被戈书翰将我解进京来问罪。幸遇学士李青莲上殿 保本，蒙圣上洪恩赦宥。今有安禄山在河东造反，又蒙学士青莲保我为衙门副 将，命我带领亲军，去到河东听候委用。昨日我亲到学士府中，一来辞行，二 去请教。今日正当起程。闻听学士，亲往长亭与俺饯行。想此知遇之恩，何日 得报也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四帽钉甲、马童、郭子仪同扯四门。"
        },
        {
          "character": "郭子仪",
          "type": "西皮慢板",
          "text": "忆昔当年奉差遣， 误慢军粮罪难宽。 只因为督检官戈书翰， 他将我解进京问罪囚监。 多亏了李青莲垂青眼， 待我的恩德重如山。 此去到河东听差遣， 逢争遇战我要当先。 扫荡了群凶诛逆叛， 上报国恩下报青莲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同领下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗，〖六幺令打段〗。李白、四青袍、院子同上，同挖门至中场。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启爷：已到长亭。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "将酒筵摆在亭上。郭将军来到，速禀我知。 （李白下。四青袍同摆宴。正场设冲场桌对面椅子。四青袍、院子同归下场门一字站。〖合头〗接〖吹打〗。 郭子仪、四帽钉甲、马童同上，同站小边一字。郭子仪下马。院子看，向下场门。）"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启爷：郭将军到！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白自下场门上，见郭子仪。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "吓将军！"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "大人请上，待晚生一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪跪一膝。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "学生不敢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白挽起郭子仪。〖吹打〗，〖吹打住〗。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "晚生何德，枉劳大人台驾到此！"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "今为将军戎行远战，学生特备薄酒，与将军饯行。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "晚生受大人知遇之恩，过蒙重爱，异日何以答报？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "知己相交，何言如此。将军请上坐一叙。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "晚生乃一介征夫，焉能与学士大人抗坐？"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "将军必为社稷之臣，理当上坐。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "晚生万万不敢与大人对坐。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启禀将军：此是我家老爷至诚敬意。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "着哇！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "将军，有道是恭敬不如从命。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "既然如此，晚生不敢辜负大人的盛意了。 （〖吹打〗。众人同挖门。四帽钉甲、马童同归大边。四青袍、院子同归小边。郭子仪、李白对坐。院子斟 酒。〖吹打住〗。）"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "将军请！"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "大人请！"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "李白",
          "type": "西皮慢板",
          "text": "知己相逢休太谦， 尊一声将军细听我言： 都只为逆贼辜恩造反， 望将军到河东扫灭狼烟。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "郭子仪",
          "type": "西皮原板",
          "text": "仰蒙大人恩非浅， 荐保我郭子仪免罪为官。 将在谋不在勇要随机应变， 我读过孙武子兵法十三篇。 怕的是到军中不得差遣， 枉负了大人的恩，徒增罪愆。"
        },
        {
          "character": "李白",
          "type": "白",
          "text": "将军！"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "叫家院与将军把酒斟满，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。院子斟酒，李白执杯，李白、郭子仪同出席至中场。"
        },
        {
          "character": "李白",
          "type": "西皮慢二六板",
          "text": "尊将军听我对你讲实言： 皆因为高、杨二人行奸险， 勾串逆贼安禄山。 我也曾奏本递上龙书案， 天子的心意中不以为然。 大不该命他出入皇宫院， 大不该命他执掌兵权。 到如今跋扈不臣为了患， 因此我寄情诗酒乐清闲。 得遇着将军是个有才有智的英雄汉， 我才肯保举将军免罪为将官。 带领着亲军骁将去到河东听差遣， 我早已为你寄去了书一函。 只要你一秉忠心发赤胆， 勉力图报杀贼立功我保你的官职必升迁。 今在这长亭我敬将军得胜酒一盏， 愿将军马到成功奏凯还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪接杯。"
        },
        {
          "character": "郭子仪",
          "type": "唱",
          "text": "我双手接过酒一盏，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖望家乡〗。郭子仪饮酒。"
        },
        {
          "character": "郭子仪",
          "type": "西皮快板",
          "text": "蒙大人深恩美周全。 既到军前得差遣， 我必要竭力图报临阵攻敌每战必争先。 仰仗着圣上的洪福齐天， 扫灭了贼反叛，也不枉大人忠诚为国一片好心田。 克日颁师奏凯回朝转， 我就便肝脑涂地以报知遇理当然。 我拜辞了恩公上雕鞍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪上马，四帽钉甲、马童同领下。"
        },
        {
          "character": "郭子仪",
          "type": "唱",
          "text": "郭子仪再不忘大人的恩德如天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪拱手，下。四青袍、院子随锣鼓同挖，分归两边。"
        },
        {
          "character": "李白",
          "type": "西皮二六板",
          "text": "郭子仪本是英雄汉， 相貌魁梧真非凡。 河东的万民遭涂炭。 皆因为高、杨结党奸。 看起来天心有回转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子带马，四青袍、院子同领下。"
        },
        {
          "character": "李白",
          "type": "唱",
          "text": "大唐朝得此安邦一英贤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李白下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小锣打上〗。二侍女同上，同站门。织女上。"
        },
        {
          "character": "织女",
          "type": "引子",
          "text": "云汉为乡，工织纺，巧制天装。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "织女坐外正场。"
        },
        {
          "character": "织女",
          "type": "念",
          "text": "云机巧织难整妆，敕配牵牛误锦裳。责归河西神惆怅，限制七夕会成双。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "吾乃河西天孙织女星是也。只因织献天衣，不暇妆饰。蒙玉帝垂怜，配嫁河东 牵牛星为夫妇。因为怠误云裳，玉帝见罪，依然责归河西。正是离多会少，每 年限制七夕，以待鹊鸟搭桥，渡河一会。今当时届佳期，钦奉玉帝敕旨：下界 有一郭子仪，他乃南极门下福星降世，应运重整朝纲，匡扶唐室社稷，使他将 来位极人臣，受享富贵。特命我渡过银河，从天下降，赐他贵寿全图，福荫世 代。正是："
        },
        {
          "character": "织女",
          "type": "念",
          "text": "一声春雷动，际会乘风云。"
        },
        {
          "character": "织女",
          "type": "西皮慢板",
          "text": "郭子仪他本是福星下降， 应运时临凡界扶保大唐。 时运未至多魔障， 气数亨通泰运昌。 玉柱擎天为福将， 匡扶唐室定家邦。 贵寿全图从天降， 玉帝命我赠祯祥。 叫侍女预备云辇上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二侍女同领起，同下。"
        },
        {
          "character": "织女",
          "type": "唱",
          "text": "渡过银河下天堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "织女下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖长锤〗。四帽钉甲同上，同站门。郭子仪换开氅上。"
