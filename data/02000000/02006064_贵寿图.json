        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土地拿蝇甩儿上，倒退走作引路式。郭子仪骑马随上，站上场斜门。土地下。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "郭子仪",
          "type": "二黄摇板",
          "text": "适才暗走青龙岗， 不觉行通正心庄。 进得山口抬头望，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "下场门空中洒火彩。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "郭子仪",
          "type": "二黄摇板",
          "text": "只见空中现红光。"
        },
        {
          "character": "郭子仪",
          "type": "叫头",
          "text": "哦呵且住！"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "方才过了正心庄，不觉进了红山口。果然是山路崎岖，难以跨马行走。忽然天 现红光，莫非此地就是天台堦福寿驿，果真有天孙下降之应验么？"
        },
        {
          "character": "郭子仪",
          "type": "叫头",
          "text": "哦呵有了！"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "我不免就此下马，一秉虔心，望空叩拜。上为国家，下为自身。倘蒙天孙下降， 得赐福寿双全，也不枉人生一世也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪下马。"
        },
        {
          "character": "郭子仪",
          "type": "二黄摇板",
          "text": "弃蹬下马挂丝缰， 一秉虔心求上苍。 望求天孙神星降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖锣鼓〗。郭子仪向正场正朝里跪叩。"
        },
        {
          "character": "郭子仪",
          "type": "二黄摇板",
          "text": "弟子愿求福寿长。"
        },
        {
          "character": "织女",
          "type": "西皮导板",
          "text": "银河渡过下天堂，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放火彩，开帷幙。现头一层切末。"
        },
        {
          "character": "织女",
          "type": "西皮慢板",
          "text": "五色祥云现福光。 七宝云辇从空降， 只见福星跪在下方。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "下界何人，跪此作甚？"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "凡夫郭子仪。因奉令差遣，暗探敌营，行来至此。冒污星君仙范，望求恕罪！"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "你且跪在一旁，听我吩咐。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "遵神命。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "你乃南极门下福星降世，应运重整朝纲，匡扶唐室社稷。将来位极人臣，享受 全福之贵。我今钦奉玉帝勅旨，指点与你。必须勉力竭忠，与国报効。今赐你 贵寿全图，以示终身之兆。你今跪在天堦之侧，抬头一看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪起，另跪大边，侧向正场，面朝内望，看。当场放火彩，变现二层彩切末。"
        },
        {
          "character": "织女",
          "type": "西皮二六板",
          "text": "叫福星抬头望， 贵寿全图现祯祥。 天赐你功名成就福安享， 位极人臣受封汾阳王。 天赐你夫荣妻贵寿共颐年无灾恙， 七子八婿笏满床。 天赐你帝室联姻皇恩荡， 金玉堆积福满堂。 天赐你五世同堂子子孙孙多兴旺， 代代不断翰墨继书香。 天赐你光前裕后登金榜， 长承紫绶共金章。 天赐你名标凌阁美旌奖， 功绩垂帛附史永流芳。 你跪进前来再听谕降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪起，至中场面向里跪。"
        },
        {
          "character": "织女",
          "type": "西皮慢二六板",
          "text": "你本是应运的福星降下方。 大唐一统太平象， 只为天子乱朝纲。 贪欢游戏宠奸党， 叛逆贼官反朝堂。 避乱在西蜀遭罗网， 万民涂炭受灾殃。 兵权付与你执掌， 先拜将，后封王，全仗你一秉忠心重整大唐。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "叩谢天恩！"
        },
        {
          "character": "郭子仪",
          "type": "唱",
          "text": "我叩谢天恩把福寿降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖望家乡〗。郭子仪叩拜，站起。挡帷幙撤切末。织女暗下。"
        },
        {
          "character": "郭子仪",
          "type": "西皮快板",
          "text": "郭子仪心中喜非常。 贵寿全图得瞻仰， 天赐我先拜大将后封王。 夫荣妻贵家兴旺， 可算得福寿双全享绵长。"
        },
        {
          "character": "郭子仪",
          "type": "叫头",
          "text": "哦呵且住！"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "俺今蒙天孙织女颁赐贵寿全图，命俺重整朝纲，匡扶社稷。我今何不趁此吉星 照庇，速奔大红山，探看贼营的消息，急早回营请令。正是："
        },
        {
          "character": "郭子仪",
          "type": "念",
          "text": "天缘感应，攻战必胜。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "有理呀有理！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内作战鼓声〗。郭子仪作听。"
        },
        {
          "character": "郭子仪",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "郭子仪",
          "type": "唱",
          "text": "忽听山前战鼓响， 莫非贼寇摆战场。 我扯动丝缰把马上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪上马。"
        },
        {
          "character": "郭子仪",
          "type": "唱",
          "text": "大红山上探虎狼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭子仪下。"
        }
      ]
