        {
          "character": "袁文敬",
          "type": "白",
          "text": "我有符法。你带我去。"
        },
        {
          "character": "刘来",
          "type": "白",
          "text": "我带你去。随我来。 到了。先生请进。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "刘来哥不要走，等我一路走。 中国京剧戏考 《双尽忠》【六本】 5"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子暗上。"
        },
        {
          "character": "袁文敬",
          "type": "白",
