          "character": "袁文敬",
          "type": "白",
          "text": "来此已是。三千岁在此。三千岁。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "原来是扁先生。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "唉，袁先生。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "呔，要你圆就圆，要你扁就扁。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "扁扁扁。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "到此何事。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "闻听大千岁兴师，特来相凑。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "兄长，袁先生到。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "先生在哪里？"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "大千岁在哪里？ 请。有礼。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "还礼。请坐。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "三千岁请。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "先生驾到，少迎有罪。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "岂敢。来得慌忙，望乞海涵。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "岂敢。请问先生，但不知我的盔铠，失落何方？"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "少时有人送盔铠到此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王君可上。"
        },
        {
          "character": "王君可",
          "type": "念",
          "text": "千里来路远，扬鞭恨马迟。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "来此已是。哪位在？"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "送盔铠人求见。 中国京剧戏考 《双尽忠》【六本】 8"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "候着。 兄长。送盔铠人要见。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "传见。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "传见。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "送盔铠人告进。 小人叩头。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "站起来讲话。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "盔铠收下。姓甚名谁？"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "吾父王俊，小人王君可。吾父昔年在朝官居中郎将，因为奸臣所害，隐住林下。 拾了千岁盔铠，特来献上。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "公卿之后。请坐。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "本爵兴师夺取庆阳，凑我一膀之力。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "情愿効劳。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "先生。但不知国母可能相见？"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "少时有人来报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "乞老上。"
        },
        {
          "character": "乞老",
          "type": "白",
          "text": "有人么？"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "乞老",
          "type": "白",
          "text": "乞老要见千岁。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "候着。 兄长，乞老要见。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "传见。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "传见。"
        },
        {
          "character": "乞老",
          "type": "白",
          "text": "小人叩头。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "所报何事？"
        },
        {
          "character": "乞老",
          "type": "白",
          "text": "有一妇人携带婴孩，要千岁头顶香盘，下山迎接。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "这就是国母到了。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "赏银一锭。去罢。"
        },
        {
          "character": "乞老",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "三弟，看香盘伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨国贞上。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "国母千岁！"
        },
        {
          "character": "杨国贞",
          "type": "白",
          "text": "卿家。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "臣见驾国母千岁。"
        },
        {
          "character": "杨国贞",
          "type": "白",
          "text": "卿家平身。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "谢国母。三弟前来参驾。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "臣见驾。"
        },
        {
          "character": "杨国贞",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "谢国母。"
        },
        {
          "character": "杨国贞",
          "type": "白",
          "text": "卿家还要大破庆阳。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "就请先生发令。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "才疏学浅，恐误国家大事。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "休要过谦。 三弟打扫将台。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "小弟遵命。"
        },
        {
          "character": "袁文敬",
          "type": "念",
          "text": "一朝权在手，便把令来行。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "王君可听令。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "逢山开路。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "三千岁听令。 中国京剧戏考 《双尽忠》【六本】 9"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "带领人马大破庆阳。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "大千岁听令。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "保定千岁驾坐庆阳。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "众将官。兵发庆阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、四下手、四将、石彦龙同上。〖点绛唇〗。"
        },
        {
          "character": "石彦龙",
          "type": "念",
          "text": "日出山头起，乌鸦就地飞。百鸟来朝凤，龙虎见高低。"
        },
        {
          "character": "石彦龙",
          "type": "白",
          "text": "孤石彦龙。探子来报，李广兴兵大破庆阳，岂可容尔猖獗。 众将官，杀上前去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四龙套、四上手、王君可同上，同会阵。四将杀王君可下。李刚上，杀死石彦龙，四将死。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李广、袁文敬同上。〖点绛唇〗。卧龙上。"
        },
        {
          "character": "卧龙",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "卧龙",
          "type": "念",
          "text": "母难走天涯，父王染黄沙。李广相扶助，依然旧邦家。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "小王卧龙。多亏众卿夺了庆阳。 先生可降国号。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "天降国号，兰王在位。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "李广进位听封。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "封为一字并肩王，亚父相称。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "李刚进位听封。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "封为太平侯，三皇叔相称。当殿赐爵。"
        },
        {
          "character": "李刚",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "袁文敬听封。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "封为护国军师。当殿赐爵。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "王君可听封。"
        },
        {
          "character": "王君可",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "封为镇殿将军。"
        },
        {
          "character": "刘来",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "卧龙",
          "type": "白",
          "text": "封不到改日再封。二皇叔为国亡身，封为阴列侯。午朝门外立忠臣庙，小王春 秋二祭。众卿，金殿摆宴，与众卿贺功。"
        },
        {
          "character": "李广、李刚、袁文敬、王君可",
          "type": "同白",
          "text": "臣等把盏。请驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
