        {
          "character": "刘来",
          "type": "白",
          "text": "好，贴在饭甑上。"
        },
        {
          "character": "袁文敬",
          "type": "白",
          "text": "呯呯当，这道符贴在小姐的房门上。"
        },
        {
          "character": "刘来",
          "type": "白",
          "text": "先生。别的符我去贴，小姐房门上，我不去。"
