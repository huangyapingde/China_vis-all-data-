        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "有意栽花花不发， 无心插柳柳发芽。 一则是孤王洪福大， 二来是御外甥有缘法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        }
      ]
