      "name": "刘金定",
      "hangdang": "旦"
    },
    {
      "name": "赵匡胤",
      "hangdang": "净"
    },
    {
      "name": "秦不及",
      "hangdang": "丑"
    },
    {
      "name": "高俊保",
      "hangdang": "小生"
    },
    {
      "name": "刘母",
      "hangdang": "老旦"
    },
    {
      "name": "丫鬟",
      "hangdang": "贴旦"
    }
  ],
  "plot": "高俊保保宋乾德皇帝，即宋太祖，下南唐游玩，被李颢王围困。适高俊保又得卸甲风寒病，不能应战。高俊\n保之妻刘金定，因高俊保外出，久无音信，正焚香祈祷时，香烟直起，神风忽起。刘金定乃算定高俊保得病。\n于是披甲上马，前往营救。及至南唐，卒将围兵击退，救出乾德皇帝，夫妇团圆云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘金定上，丫鬟随上。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "将军一去杳无音， 怎不叫奴挂在心。 他只为君父南唐遭围困， 别下了奴家救父亲。 实指望夫妻同欢乐， 又谁知今日两离分。 但愿他得胜回朝转， 满斗焚香谢神明。 叩罢头谢罢恩起身站定，"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "刘金定",
          "type": "西皮流水板",
          "text": "一霎时线香起一阵神风。 抓风头摆风尾掐指一算， 却原来奴夫主染病在身。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "呀，且住。却原来小将军得了卸甲风寒，要奴前去搭救。 丫鬟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟允。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "吩咐马童，备马伺候。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "哦。 马童，备马伺候。"
        },
        {
          "character": "马童",
          "type": "内白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、丫鬟同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马童上，洗马。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "姑娘有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定上。"
        },
        {
          "character": "刘金定",
          "type": "西皮导板",
          "text": "刘金定离綉房披挂上阵，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘母上。"
        },
        {
          "character": "刘母",
          "type": "白",
          "text": "我儿披挂何往？"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "哎呀，母亲吓！"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "为将军得重病渴盼救应。 在堂上拜别生身母， 搭救儿夫转汴京。 叫马童与姑娘抬枪带马， 去到那南唐逞威风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、马童同下。"
        },
        {
          "character": "刘母",
          "type": "唱",
          "text": "我的儿生来性情高傲， 全不怕贼兵众闯入虎巢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘母下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四手下引秦不及同上。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "喂喂，喂喂，嗯喂喂。"
        },
        {
          "character": "秦不及",
          "type": "念",
          "text": "大将来生盖世穷，"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "雄。"
        },
        {
          "character": "秦不及",
          "type": "念",
          "text": "万马营中逞鸡笼。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "逞威风。"
        },
        {
          "character": "秦不及",
          "type": "念",
          "text": "上阵全凭胭脂美，"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "马。"
        },
        {
          "character": "秦不及",
          "type": "念",
          "text": "要与吾主挑尿桶。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "定江洪。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "不错，定江洪。俺——"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "什么人？"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "秦琼。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "不是。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "秦季武。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "也不是。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "一十七八代玄孙，秦不及是也。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "这倒差不多。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "那日在教场挑土。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "比武。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "是俺使尽平生之力，一手能举二十四条龙。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "什么龙？"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "灯笼。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "可有蜡烛？"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "在外。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "好大气力。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "颢王见得你老爷英雄该死。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "盖世。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "封我一把大夜壶之贼。"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "大都督之职。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "不错，大都督之职。吓别挑字眼。今有双锁山，反来了刘金定，又道是兵来将 挡，水来将挡，我不将挡，谁肯将挡。我的人！"
        },
        {
          "character": "四手下",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "将挡，将挡。"
        },
        {
          "character": "秦不及",
          "type": "唱",
          "text": "头戴盔，身穿甲， 玲珑铠，打结搭。 打将锤，好长靶， 拿住颢王打嘴巴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、马童同上。秦不及见。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "哎呀，我只说天神下界，却原来是一个婆娘。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "呔，姑娘！"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "哦，姑娘。 请问姑娘上姓？"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "姓刘。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "刘姑娘又上姓？"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "呔，就姓刘。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "哦，没得二姓。你看刘姑娘，生得龙眉凤眼，瑞气千条，她把那双眼睛，飘了 不几飘，莫非她肚子里有了我？又道是姻缘不可错过，不如当面说破。 刘姑娘且停战马，听小生一言衷告。"
        },
        {
          "character": "秦不及",
          "type": "唱",
          "text": "勒马停蹄站阵前， 尊一声姑娘听我言： 你我不必来交战。 拜完花烛成就姻缘。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定战。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "刘姑娘且慢。小生还有话告禀：我想你那一刀，刀死了我，你于心何忍？我心 何安？若是我这一锤，锤死了你，你心何酸？我心何苦？如若不然吓，总要死 在你手。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "与我擒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童杀四手下。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "嗐，唬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定追秦不及同下。秦不及上，慌。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "杀败了吓，杀败了。你看刘金定，这丫头杀法甚是厉害，这便怎么处？也罢， 事到如今，不免拜谢圣恩，寻个自尽罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖半牌子〗。"
        },
        {
          "character": "秦不及",
          "type": "白",
          "text": "吓，有些疼，拉倒，留这条命唱戏罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦不及逃下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四御林军引赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "西皮导板",
          "text": "想当初离龙巢千差万错，"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "悔不该听谗言游玩山河。 到今日身遭困怎生逃脱， 李颢王打战表诓龙离窝。 下南唐设下了空城一座， 君臣们一个个闯进网罗。 擒五王和七侯留孤一个， 内无粮外无兵怎生奈何？ 耳旁内又听得人马通过， 想必是余洪贼又动干戈。 叫内臣与孤王摆驾城楼去躲， 看一看唐营中兵势如何。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四御林军引赵匡胤同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、马童同冲杀上。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "马童，前去问来。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "城楼下将官请了。"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "请了。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "借问一声：营中可有姓高之人？"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "我营中没有姓高之人。待孤与你东门查问。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "杀往东门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、马童同杀下。四御林军、赵匡胤同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "桃花宫饮御酒一时大醉， 为韩龙斩三弟逼反弟媳。 陶三春带众将人马无敌， 好一个高御亲片言退敌。 城楼上取黄袍龙目落泪， 打七七罗天醮才把兵息。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "吓吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、四御林军同下。刘金定、马童同杀上。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "马童，前去问来。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "呔。城楼上将官请了。"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "请了。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "借问一声：营中可有姓高之人？"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "我营中没有姓高之人。待孤与你西门问来。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "杀往西门。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、马童同杀下。赵匡胤、四御林军同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "为王的到边庭心中无计， 修龙诏回京都搬兵解危。 有韩奇搬救兵令人可喜， 搬来了小高琼英雄第一。 孤只望救兵到驾回京地， 又谁知进御营得下重疾。 见女将在马上如同耍戏， 战唐兵犹如那杀羊宰鸡。 叫寡人一霎时难明底细， 是何方反来了女将英魁？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、四御林军同下。刘金定、马童同杀上。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "马童，前去问来。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。 城楼上将官请了。"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "请了。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "借问一声：你营中可有姓高之人么？"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "我营中没有姓高之人。待孤与你南门查问。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "杀往南门。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、马童同杀下。赵匡胤、四御林军同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "孤好比孔圣贤忍饥受饿， 孤好比汉关公身困土坡。 孔圣贤哭颜渊未闻好学， 周文王遇姜尚渭水池河。 齐景公哭钟后国运衰厄， 有国母在桑园题诗暗合。 三国中汉刘备十分义气， 哭关公众文武白袍白衣。 诸葛亮哭周瑜一派假意， 作祭文对灵牌妙算神机。"
        },
        {
          "character": "四御林军",
          "type": "同白",
          "text": "吓吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、四御林军同下。刘金定、马童同杀上。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "马童，前去问来。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。 城楼上将官请了。"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "请了。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "借问一声：你营中可有姓高之人么。"
        },
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "我营中没有。待我与你北门问来。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "杀往北门。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘金定、马童同杀下。赵匡胤、四御林军同上。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "耳边厢又听得人喧马嘶， 想必是余洪贼要攻城池。 乾德王在城楼忙传旨意， 宋营中众将官且听端的： 与孤王忙准备狼烟火炮， 运滚木和雷石小心防危。 御林军上城楼忙观仔细， 看一看余洪贼怎样进逼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、四御林军同下。刘金定、马童同杀上。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "姑娘，来此已是北门。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "前去问来。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。 城楼上将官请了，借问一闻，你营中可有姓高之人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、四御林军同上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "叫你主将，上前答话。"
        },
        {
          "character": "马童",
          "type": "白",
          "text": "哦。 有请姑娘，上前答话。"
