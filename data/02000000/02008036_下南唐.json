        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "臣妾要去探病，无旨不敢前去。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "内侍。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "可引女将前去病房。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "谢过万岁。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "在营中领了万岁旨， 要到病房探夫君。"
