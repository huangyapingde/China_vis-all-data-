          "character": "刘金定",
          "type": "唱",
          "text": "听说是大宋乾德君， 刘金定跌跪地埃尘。"
        },
        {
          "character": "赵匡胤",
          "type": "唱",
          "text": "小姐马上多劳顿， 孤王传旨且平身。"
        },
        {
          "character": "刘金定",
          "type": "唱",
          "text": "叩头三呼把龙恩谢， 停兵不战为何因？"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "启奏万岁：停兵不战，却是为何？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "只因御外甥，进得营来，得下卸甲风寒。"
        },
        {
          "character": "刘金定",
          "type": "白",
          "text": "现在哪里？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
