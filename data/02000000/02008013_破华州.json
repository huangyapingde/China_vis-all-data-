          "character": "刘月娥",
          "type": "白",
          "text": "哎呀，刀啊，从今以后，竟是无用之物了。"
        },
        {
          "character": "刘月娥",
          "type": "唱",
          "text": "奴本女躯胆量小， 祝告神明与宝刀。 军中取胜功非小， 何故与贼共同巢。 手拿宝刀心惊跳，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘月娥污刀。"
        },
        {
          "character": "刘月娥",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "刘月娥",
          "type": "唱",
          "text": "恶贼睡卧气冲霄。 拚着一死把仇报，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘月娥将刀挂帐上。"
        },
        {
          "character": "刘月娥",
          "type": "白",
          "text": "刀呀！"
        },
        {
          "character": "刘月娥",
          "type": "唱",
          "text": "以后何能把兵交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军急上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "报！"
        },
        {
          "character": "刘月娥",
          "type": "白",
          "text": "呔，你是何人，擅自闯入内室。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "帐下中军，有紧急公文，禀报元帅。"
        },
        {
          "character": "刘月娥",
          "type": "白",
          "text": "你且站住。 啊，元帅快醒，元帅快醒。"
        },
        {
          "character": "雷冲",
          "type": "白",
          "text": "啊，何事惊慌？"
        },
        {
          "character": "刘月娥",
          "type": "白",
          "text": "中军求见。"
        },
        {
          "character": "雷冲",
          "type": "白",
          "text": "叫他进来。"
        },
        {
          "character": "刘月娥",
          "type": "白",
          "text": "元帅唤你进来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。 启元帅：周兵星夜四门攻打，事在危急，请爷出马。"
        },
        {
          "character": "雷冲",
          "type": "白",
          "text": "快传合城兵将，饱餐战饭，奋勇捉贼者。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是，遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军下。"
        },
        {
          "character": "雷冲",
          "type": "白",
          "text": "美人，你且安歇，某家星夜出兵擒贼。正是，"
        },
        {
          "character": "雷冲",
          "type": "念",
          "text": "展开擎天手，哪怕万军来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷冲下。"
        },
        {
          "character": "刘月娥",
          "type": "白",
          "text": "呀，看贼子此去，有死无生。恐我丈夫回来，有何脸面立于人世，也罢！不如 自尽了吧。"
        },
        {
          "character": "刘月娥",
          "type": "唱",
          "text": "跌跪上房珠泪掉， 雷贼强逼入笼牢。 夫妻不能同偕老， 枉在人间走一遭。 今生不能把仇报， 留得名节赴阴曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘月娥死，下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四将官同上，同站门。干牌子。"
        },
        {
          "character": "将官甲",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "三将官",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "将官甲",
          "type": "白",
          "text": "干殿下敖欢相召，你我同到校场，也不知有何军情？"
        },
        {
          "character": "三将官",
          "type": "同白",
          "text": "同到校场，便知分晓。"
        },
        {
          "character": "将官甲",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "三将官",
          "type": "同白",
          "text": "话言未了，干殿下来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四五札头、四上手、李维信、敖欢同上。"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "参见殿下！"
        },
        {
          "character": "敖欢",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "敖欢",
          "type": "白",
          "text": "某，干殿下敖欢是也。大将军重兴周室，飞令前来搬兵，同灭雷冲。 众位将军，你我会同李元帅，得了庆阳，攻取华州，必要人人奋勇，个个争先。 若有后退者，军法施行。"
        },
        {
          "character": "四将官",
          "type": "同白",
          "text": "末将等深受皇恩，敢不竭力报效皇家。"
        },
        {
          "character": "敖欢",
          "type": "白",
          "text": "人马华州去者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四车夫同上，同站门，王焕上。"
        },
        {
          "character": "王焕",
          "type": "唱",
          "text": "解押粮草差遣我， 华州城内起干戈。"
        },
        {
          "character": "王焕",
          "type": "白",
          "text": "俺，王焕。奉令解押粮草。闻得人言，雷冲将我妻子抢入帅府，逼勒成亲，也 不知是真是假，为此急急回来探听明白。雷冲，雷冲呀，尔无此事便罢，倘有 此事，唔，怎肯与你干休！"
        },
        {
          "character": "王焕",
          "type": "唱",
          "text": "自随军营无差错， 何故强逼刘月娥？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、李维忠、葛梁、葛柱同上，同站门，李广上。"
        },
        {
          "character": "李广",
          "type": "念",
          "text": "丹心扶周室，一意灭强敌。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "本帅，李广。兴兵恢复庆阳，一路斩关，势如破竹。兵抵华州，被雷冲祭起飞 刀，杀得我军大败。亦曾命李维信，搬召干殿下敖欢，统领雄兵，前来灭贼。 听人马轰轰，想必来也。"
        },
        {
          "character": "李维信",
          "type": "内白",
          "text": "干殿下到！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗，〖牌子〗。四上手、四五札头、四将官、李维信、敖欢同上。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "感劳千岁，星夜前来。"
        },
        {
          "character": "敖欢",
          "type": "白",
          "text": "元帅飞令，怎敢迟延。雷冲有何厉害？"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "他有两口飞刀，祭起空中伤人性命，甚是难敌。"
        },
        {
          "character": "敖欢",
          "type": "白",
          "text": "人马合兵一处，星夜攻城。 呔，众将官，分开攻城者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四蓝文堂、四蓝大铠、四下手、傅宣、雷冲同上，会阵。"
        },
        {
          "character": "雷冲",
          "type": "白",
          "text": "呔，小将通名受死！"
        },
        {
          "character": "敖欢",
          "type": "白",
          "text": "听者。俺乃干殿下敖欢是也。呔，雷冲，某家到此，尔当拱手归降，还敢大胆 抵敌么？"
        },
        {
          "character": "雷冲",
          "type": "白",
          "text": "原来与李广一党，看刀！ （四红文堂、四五札头、四将官、李维忠、李维信、葛梁、葛柱、李广、四蓝文堂、四蓝大铠、傅宣同钻烟 筒下，四上手、四下手同打连环，同下。敖欢、雷冲同架，双下。）"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（王焕冲上，两望，上桌子。起打，连环。敖欢、雷冲同上，同起打，敖欢败下。王焕接打，雷冲死，下。"
        },
        {
          "character": null,
          "type": "text",
          "text": "四红文堂、四五札头、四将官、四上手、李维忠、李维信、葛梁、葛柱、李广自两边分上。）"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "你是何人，暗刺雷冲？"
        },
        {
          "character": "王焕",
          "type": "白",
          "text": "末将王焕，乃华州百总。雷冲强抢小将家室，故此刺死奸贼，以除朝廷之害。"
        },
        {
          "character": "敖欢",
          "type": "白",
          "text": "幼主驾坐庆阳，自有用尔之处。"
        },
        {
          "character": "李广",
          "type": "白",
          "text": "众将官，人马一起进城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}