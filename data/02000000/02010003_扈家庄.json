{
  "script_id": "02010003",
  "title": "扈家庄",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "扈三娘",
      "hangdang": "武旦，头戴红福巾，红帘红绒球，七星金额，雉翎狐尾，身穿红女甲，红绦带，红裤红裙，足登小"
    },
    {
      "name": "脚红弓鞋木跷",
      "hangdang": "未知"
    },
    {
      "name": "林冲",
      "hangdang": "武老生，黑三髯，白虎瞌脑银额，翎尾，白银甲"
    },
    {
      "name": "吴用",
      "hangdang": "末，黑三髯，九梁道巾，八卦衣，绦，方靴，持云绋"
    },
    {
      "name": "宋江",
      "hangdang": "生，黑三髯、黑大镫、盔，雉翎，狐尾，红蟒，玉带，方靴"
    }
  ],
  "plot": "宋江因扈家庄女将扈三娘，协助祝家庄，与梁山泊为敌。乃奉晁盖命令，率领花荣、邓飞、欧鹏、马麟、戴\n宗、穆弘、王英等攻打扈家庄。并派花荣、邓飞打头阵，欧鹏、马麟为二队接应，戴宗、穆弘押运粮草，王\n英后队接应。李逵闻知，未曾派他参加，气愤不平，私自找一酒楼饮酒。俟半醉后，好参加争战，一现身手，\n而立大功。及至扈家庄，王英首先出战，被扈三娘生擒。花荣、马麟、邓飞、欧鹏四人亦均败下。正追宋\n江时，李逵从酒楼闯入，挡住扈三娘，交战以后，被刺伤左腿。最后林冲来，始将扈三娘生擒回山。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "花荣、邓飞、马麟、欧鹏、戴宗、穆弘、王英、李逵背后旗写姓名绰号同上。"
        },
        {
          "character": "花荣、邓飞、马麟、欧鹏、戴宗、穆弘、王英、李逵",
          "type": "同粉蝶儿",
          "text": "将勇兵齐，梁山泊将勇兵齐， 众英豪雄威盖世。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "俺，神箭手小李广花荣。"
        },
        {
          "character": "邓飞",
          "type": "白",
          "text": "俺，绿面夜叉火眼狻猊邓飞。"
        },
        {
          "character": "马麟",
          "type": "白",
          "text": "俺，紫煞神铁笛仙马麟。"
        },
        {
          "character": "欧鹏",
          "type": "白",
          "text": "俺，金腮牛摩天金翅欧鹏。"
        },
        {
          "character": "戴宗",
          "type": "白",
          "text": "俺，赛秦琼神行太保戴宗。"
        },
        {
          "character": "穆弘",
          "type": "白",
          "text": "俺，蓝鳞虬没遮拦穆弘。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "俺，黄面地丁矮脚虎王英。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "俺，双斧将黑旋风李逵。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "众位兄弟请了。今有二寨主宋江大哥排山点将升坐忠义堂，你我分班侍立。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文堂、军卒、上手同上，吴用上，宋江抱令旗上。"
        },
        {
          "character": "宋江",
          "type": "粉蝶儿",
          "text": "忠义堂，整全军，排列雄师。 定要把，扈家庄，踏如平地。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江归正中军帐坐，吴用左侧坐。"
        },
        {
          "character": "花荣、邓飞、马麟、欧鹏、戴宗、穆弘、王英、李逵",
          "type": "同白",
          "text": "参见大哥。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众位贤弟免礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花荣、邓飞、马麟、欧鹏、戴宗、穆弘、王英、李逵同允，归左右立。"
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "忠义堂前聚众英，杏黄旗纛立威名。替天行道施仁政，水泊梁山战法精。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "吾，及时雨呼保义宋江。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "某，灵机军师智多星吴用。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "只因扈家庄女将三娘，身高力大，刀戟精通，帮助祝家庄同与我梁山作对，为 此遵奉大哥晁盖钧令，命我率领众家弟兄，调兵排队，一齐下山，攻打扈家庄， 擒拿女将。 请军师点将传令。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "遵令。 嘟，花荣、邓飞听令，命你二人率领军兵往扈家庄攻打头阵。"
        },
        {
          "character": "花荣、邓飞",
          "type": "同白",
          "text": "遵令。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "马麟、欧鹏听令，命你二人二队接应。"
        },
        {
          "character": "马麟、欧鹏",
          "type": "同白",
          "text": "遵令。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "戴宗、穆弘听令，命你二人押解粮草。"
        },
        {
          "character": "戴宗、穆弘",
          "type": "同白",
          "text": "遵令。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "王英听令，命你后队接应。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "遵令。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "启大哥：派将已毕。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众军士，此去攻打扈家庄，必须人人奋勇，各个当先，但愿此去旗开得胜。"
        },
        {
          "character": "花荣、邓飞、马麟、欧鹏、戴宗、穆弘、王英、李逵",
          "type": "同白",
          "text": "马到成功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵自上场门下。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "整齐队伍，往扈家庄去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江出位，众人同出门，同上马。"
        },
        {
          "character": "宋江",
          "type": "泣颜回",
          "text": "点将统雄师， 率强兵勇似熊罴， 鸣锣响鼓下梁山，队伍排齐， 众军兵抖威， 要争强奋勇擒仇敌。"
        },
        {
          "character": "众人",
          "type": "同泣颜回",
          "text": "逞干戈呐喊摇旗， 把扈家庄荡作灰泥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同领下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李逵上。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "走哇。"
        },
        {
          "character": "李逵",
          "type": "皂罗袍",
          "text": "我今日山中无事， 上酒楼沽饮美酒酴醿。 醉醺醺前往扈家庄去， 生擒扈氏大破重围。 一定要显俺惊人武艺。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "俺，黑旋风李逵。正在后寨分金厅饮酒，忽听大哥宋江陞坐忠义堂，排山聚将， 众家弟兄理应分班听令，军师派将攻打扈家庄，众位哥弟皆有差遣，只是不 用俺李逵。俺心中不忿，私下山寨，寻一酒楼，畅饮琼浆，喝的醉醺醺的前往 扈家庄迎战，倘遇机会得遇扈三娘交阵，俺将那婆娘擒获，绑回山寨，是俺大 功一件也。教合山弟兄佩服俺李逵刚强志气。天色尚早，须索走遭也。"
        },
        {
          "character": "李逵",
          "type": "皂罗袍",
          "text": "俺一双铁斧，万人难敌， 钢须铁面，猛勇出奇， 黑旋风威武人恐惧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李逵踢腿，下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、军卒引宋江、王英同上，斜一字，众人同上。"
        },
        {
          "character": "众人",
          "type": "同六么令",
          "text": "雄兵骁骑， 下山林，率队长驱。 争强奋勇整军威。 擒女将，闯重围， 旗开得胜须努力。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "前军因何止队？"
        },
        {
          "character": "军卒",
          "type": "同白",
          "text": "来至扈家庄外。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "人马列开旗门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众军卒同挖门分立，宋江归中立，王英归左立。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "且住。看此庄周围坚固，安排谨严，又兼女将骁勇，甚实不易攻打，人马撤回。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "且慢。启禀大哥：休长他人威武，灭俺自己英名。王英不才，情愿讨令，擒拿 扈三娘，想你我堂堂男子，何惧小小女流，定然将婆娘擒来，显俺英勇。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "你有此胆量。王英听令，命你率领军兵，会战扈三娘，须要谨慎，不可大意。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "遵令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英领四上手同下。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众军士，将扈家庄团团围住，择选吉地安营下寨。"
        },
        {
          "character": "宋江",
          "type": "黄龙滚",
          "text": "施计策运用兵机， 传军令谴将擒敌， 安营寨择选吉地。 把将扈家庄紧紧团围。 把将扈家庄紧紧团围。 必须得逢强智取。 矮王英逞能讨令擒魔女， 战场上胜败难知， 俺亲自临阵观兵， 催军卒向前奋力。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人扯斜门同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘上，女兵执红四方旌旗上绣“扈三娘”三字随上，扈三娘起威拉式。"
        },
        {
          "character": "扈三娘",
          "type": "醉花阴",
          "text": "披挂整齐飘凤翅。 耀旌旗灿烂，也那云霞碧。 凭俺这神威，迫忙里， 五记炮似雷轰，猛冲入罗网重围， 也顾不得临阵前万将雄威。 急加鞭——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘走圆场。"
        },
        {
          "character": "扈三娘",
          "type": "醉花阴",
          "text": "龙骑云催。 管叫他血染战袍回。"
        },
        {
          "character": "扈三娘",
          "type": "念",
          "text": "赤甲红袍艳女娘，全身甲胄整戎装。扈家庄上排军队，扫荡梁山灭宋江。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "侬家一丈青扈三娘是也。今早正在花园游玩，忽听丫鬟报道，有梁山宋江，率 领一群毛贼，前来搅乱我庄，侬岂能容他猖獗，为此全身披挂甲胄戎装，齐队 排兵，以防御敌。 唗，庄丁、女兵们走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四女兵各持刀枪自两边分上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "参见姑娘，有何吩咐？"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "今有梁山宋江，率领贼兵前来搅乱，命你等各持刀枪器械，随姑娘出庄会战迎 敌者。"
        },
        {
          "character": "扈三娘",
          "type": "喜迁莺",
          "text": "俺只见旌旗蔽日， 猛听得鼍鼓声擂。 雄也么奇， 堪笑他飞熊谷里， 怎能够生双翅飞出重围。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一击。报子持令旗上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启禀姑娘：今日宋江在庄外讨战，特来报知。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "丫鬟，看金戟过来。"
        },
        {
          "character": "扈三娘",
          "type": "喜迁莺",
          "text": "我提画戟， 管教他人头落地。 呀，俺俺俺， 可也勇冠会敌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘领起走大圆场扯斜门，众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手引王英同上，王英起威拉式。"
        },
        {
          "character": "王英",
          "type": "念",
          "text": "上阵不用战马，生就身材矮小。胸中志量颇高，交战不用枪与刀，全凭双棒巧 妙。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "俺，矮脚虎王英。遵奉大哥将令，征战扈三娘，闻得此女生得十分貌美，姣艳 风流，俺今上阵将她擒获，成为夫妻，也是俺三生之幸。 军士们，你等须要奋勇当先，擒得扈三娘，头功一件，急速杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘执戟上，舞。"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "呀， 又只见阵势飘飘绕旌旗， 这战场等闲看戏。 不许他拔寨归山里， 侬可也扬眉吐气。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英持双棒上，归右边，扈三娘持金戟归左边，会阵。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "呔，矮汉少往前进。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "好一个高大婆娘。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "原是个矬小矮汉。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "呔，扈三娘闻知你武艺高强，画戟双刀出众，今日见俺，为何怯战？"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "呔，黄脸矮汉通名受死。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "听者。俺乃梁山好汉黄面地丁矮脚虎王英，特来擒你。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "呔，王英。侬看你身不满三尺，黄胖矬矮，力小气单，软弱无能，焉能与你姑 娘交战，快快逃命去罢。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "呔，扈三娘，你看我身体虽小，武艺高强。自古道秤锤小能压千斤，教你试试 俺双棒厉害。如若战你不过，情愿与你作——"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "与你作个女婿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘怒恼。"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "我笑——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "抽头。"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "笑着你小毛贼无见识， 侬可也刀戟无敌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "抽头。"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "觑着你汗淋淋忙躲过， 侬这里何曾用力。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "抽头。"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "侬今日只手扫平你， 一霎时气吐虹霓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘、王英同战，扈三娘三点手舞戟，作假败下。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "且住，我战她不过，因何她倒败去？哦，是了。这婆娘与我眉来眼去，虚点一 戟，转马走去。定是心中爱我，绝妙机会，不可错过，今日俺得一个好老婆， 急急赶上前去。 呔，扈三娘，慢走，俺王英来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英追下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "文堂、军卒引宋江、众将同上，过场，同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "扈三娘上，王英追上，瞒扈三娘头，战。扈三娘打，归右边，王英归左边。扈三娘打倒王英，指王英。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "呔，贼子呀！"
        },
        {
          "character": "扈三娘",
          "type": "刮地风",
          "text": "这的是狭路相逢难回避。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "唗，女兵庄丁们。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四女兵自两边分上，作捆王英。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "你等将这矮汉绑进庄内，吊在高杆之上，不得违误。"
        },
        {
          "character": "庄兵",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王英叹气。"
        },
        {
          "character": "王英",
          "type": "白",
          "text": "哎，罢了，罢了。"
        },
        {
          "character": "王英",
          "type": "刮地风",
          "text": "这的是狭路相逢难回避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庄兵绑王英同下。"
        },
        {
          "character": "扈三娘",
          "type": "白",
          "text": "女兵们，随你姑娘去踏破宋江营盘者。"
        },
        {
          "character": "扈三娘",
          "type": "水仙子",
          "text": "恨恨恨，小毛贼， 恨恨恨，小毛贼。 怎怎怎，怎逃俺虎穴龙潭地， 他他他，他那里珠泪惨凄凄。 俺俺俺，俺生擒拔贼悬提， 杀杀杀，杀得他无路奔，血染马蹄。 斩斩斩，斩尽了残兵败卒， 管管管，管教他片甲不存，死如泥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女兵同下。扈三娘舞戟下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
