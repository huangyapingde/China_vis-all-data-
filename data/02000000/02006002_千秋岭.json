{
  "script_id": "02006002",
  "title": "千秋岭",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "罗成",
      "hangdang": "小生"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "徐勣",
      "hangdang": "老生"
    },
    {
      "name": "李世民",
      "hangdang": "小生"
    }
  ],
  "plot": "李世民率领徐勣、秦琼、尉迟恭攻打王世充。时罗成仍在王世充处为将，出面应战。徐勣原知罗成威武，尉\n迟恭等均非是其对手，但尉迟恭过于骄傲，思挫其傲气。乃奏明李世民，令尉迟恭出马。尉迟恭苦战不胜，\n而又无面目回营。徐勣看明情形，乃鸣金收兵。独自前往说劝罗成投降唐营。罗成投降后，李世民称为御弟\n赐座，尉迟不服，惹起秦琼、程咬金公愤。尉迟见志不得逞，又思离唐造反。李世民乃阻拦说和，大家欢宴\n而罢。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗成上，起霸。四白龙套自两边分上。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "头戴银盔明灿亮，身穿铠甲似秋霜。跨下战马无人挡，掌中银枪世无双。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "俺姓罗名成字士信，在王世充帐下为将。可恨唐将兴兵而来，岂肯容他猖狂。 众将官，抬枪带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套引罗成同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "披抡锏盖世无双，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "水磨鞭保定唐王。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺，护国公秦琼。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "俺，鄂国公敬德。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "将军请了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "今日大战王世充，主公升帐。你我两厢伺候。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、尉迟恭分归两边外椅子坐。四红文堂、四大铠、徐勣同上，李世民上。"
        },
        {
          "character": "李世民",
          "type": "点绛唇",
          "text": "将众英豪，杀气冲霄，军威浩，地动山摇，要把世充扫。"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "奉了父王旨，征战洛阳城。虽然俺为主，全仗众公卿。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "小王，李世民。奉了父王旨意，争战洛阳城。可恨王世充战又不战，降又不降。 先生妙计安在？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "且听探马一报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报。 启主公：罗成讨战。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "吓，先生，罗成讨战，命何将出马？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "启主公：命马三保攻打头阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭怒。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "先生就此传令，命马三保大战罗成。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "得令。 令出。呔，下面听者：主公有令，命马三保大战罗成，不得违误。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四蓝龙套同上，同站门，马三保上。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "俺，马三保。奉了二主将令，顺说罗成降唐。 众将官，起兵前往。"
        },
        {
          "character": "四蓝龙套",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套、罗成同上，会阵，"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "马三保，前番饶尔不死，你又来则甚？"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "奉了二主将令，顺说罗成降唐。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "要俺归顺，除非日从西起。"
        },
        {
          "character": "马三保",
          "type": "白",
          "text": "一派胡言，看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成打败马三保，马三保下，罗成追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、秦琼、尉迟恭、徐勣、李世民自两边分上。探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报。 启主公：马三保败阵。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "吓，先生，马三保败阵，命何将出马？"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "待臣思忖回话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭怒。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "看这黑贼进得唐营，这样耀武扬威。待我在二主跟前搬动是非，叫这黑贼打一 败阵，也好灭灭他的火性。 启主公：将营盘倒退四十里，打本进京，奏与老王，另派别将出马。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "如此先生传令。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "得令。 令出。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "尉迟因何阻令？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哦呵呵先生！你道那罗成天上少有，地下难寻？眼前若有二主将令，我定要擒 那罗成进帐。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "你若擒了罗成进帐，我的这军师大印，付与你执掌。你呢？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "也罢，我若擒不了罗成，愿输与你项上人头。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "敢与山人击掌？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。尉迟恭、徐勣同三击掌。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "尉迟恭听令。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "命你带领本部人马，大战罗成，不得违误。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "皇兄须要小心。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "主公吓。"
        },
        {
          "character": "尉迟恭",
          "type": "西皮二六板",
          "text": "二主不必挂心肠， 出兵事儿某承当。 哪怕罗成是好将， 强中更有强中强。 某若此去打胜仗， 军师大印我执掌； 俺若此番打败仗， 愿将人头挂营房。 辞别二主出宝帐，"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "大战罗成。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你不能取胜。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你是怎么知道？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "我们乃是姑表之亲，故尔知晓。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "原来你们俱是一党吓。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "战鼓咚咚下教场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "尉迟接令出营门， 回头埋怨徐先生： 明知罗成多骁勇， 不该调唆他出兵。 先生传令我出马，"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "你也不能取胜。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "不得胜落个两太平。"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "尉迟进营威风凛， 屡次欺压众弟兄。 此番叫他败一阵， 看他逞能不逞能。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "好个仁义徐先生， 把俺弟兄看得真。 辞别主公出唐营， 且听探马报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "一见尉迟出营门， 不知胜败与谁赢。 三军带过马能行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人带马同领下。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "去到阵前看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "尉迟恭",
          "type": "内西皮导板",
          "text": "跨下一匹乌骓马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四蓝龙套同上，同挖门，一字。尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "西皮二六板",
          "text": "打将钢鞭手中拿。 催马来在战场下， 大叫儿郎听根芽： 别的将官休出马， 专会罗成小娃娃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套自下场门同上。"
        },
        {
          "character": "罗成",
          "type": "内西皮导板",
          "text": "正在后帐习兵文，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "忽听贼人来骂营。 三军带过马能行， 定与来将赌输赢。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你少爷罗成！"
        },
        {
          "character": "尉迟恭",
          "type": "三笑",
          "text": "吓哈呀，哈呀，哇呀呀呀呀！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呔，黑贼，你为何发笑？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "匹夫！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "我道你这罗成，天上少有，地下难寻，眼前看你原来是个黄毛小子。 三军的，回营报与二主知道，赏你老爷大大的头功。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "黑贼，一战未交，为何赏尔大大头功？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃，慢说与你交战，提起某家威风，就吓破尔的胆。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "如此尔要讲！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你要听吓！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "你要讲吓！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你要听吓！"
        },
        {
          "character": "尉迟恭",
          "type": "西皮二六板",
          "text": "勒住丝缰慢交战， 细听老爷表家园： 家住在山西麻衣县， 志田庄上有家园。 一十八岁中武举， 练就雌雄两只鞭。 慢说与尔来交战，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃！"
        },
        {
          "character": "尉迟恭",
          "type": "西皮二六板",
          "text": "命儿就在倾刻间。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "一见黑贼夸大话， 不由豪杰咬银牙。 我不交战回去吧，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "娃娃，你敢是怯战！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "再把大话吓唬他。 十一二岁燕山打， 十三四岁学枪法。 十五岁扬州夺状元谁不怕， 赫赫威名扬天涯。 少爷今年十六岁，"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "尔也该死了！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "擒你犹如井底蛙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、罗成同起收双打下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂同上，同挖门。李世民、徐勣同上。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "为江山跑坏了白龙马，"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "为社稷累坏保驾臣。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "三军带路高岗进，"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "看看两家赌输赢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上，罗成上，同打起。尉迟恭败下，罗成追下。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "罗成好比南山豹，"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "尉迟比做北海鲛。"
        },
        {
