{
  "script_id": "02004018",
  "title": "战合肥",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    },
    {
      "name": "张辽",
      "hangdang": "老生"
    },
    {
      "name": "甘宁",
      "hangdang": "武生"
    }
  ],
  "plot": "曹操领兵扫灭张鲁，占领东川，正拟进兵汉中。适孙权攻下宛城，杀曹将朱光，继续进攻合肥。被张辽击败，\n不得已退守濡须口，曹操为镇定江南计，乃亲率大军，前往救援。孙权听张昭之计，令凌统应战，又被张\n辽击败。最后甘宁只带一百人马，夜袭曹营，始将曹兵击退。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊、徐晃、张郃、曹洪同上，同起霸。"
        },
        {
          "character": "夏侯渊",
          "type": "念",
          "text": "红日照盔缨，"
        },
        {
          "character": "徐晃",
          "type": "念",
          "text": "英雄胆气横。"
        },
        {
          "character": "张郃",
          "type": "念",
          "text": "双眉斜插鬓，"
        },
        {
          "character": "曹洪",
          "type": "念",
          "text": "昆外大将军。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "俺，夏侯渊。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "俺，徐晃。"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "俺，张郃。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "俺，曹洪。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "列位将军请了。"
        },
        {
          "character": "徐晃、张郃、曹洪",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "丞相升帐，两厢伺候。"
        },
        {
          "character": "徐晃、张郃、曹洪",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "夏侯渊、徐晃、张郃、曹洪分归两边。四文堂、四大铠同上，曹操上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "志满定乾坤，拥铁钺，虎卫镇。匡扶社稷，秉丹心。昆吾驱逐獐麇。"
        },
        {
          "character": "夏侯渊、徐晃、张郃、曹洪",
          "type": "同白",
          "text": "众将参。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位将军少礼。"
        },
        {
          "character": "夏侯渊、徐晃、张郃、曹洪",
          "type": "同白",
          "text": "谢丞相。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "栉风沐雨己酉年，扫荡英雄寰宇坚。仗天威福随人愿，转戈跃马整归鞭。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操，奉主之命统领雄师，扫荡张鲁。日前夺了阳平关，且喜已得东川。 正是："
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "虽到驱鲁得重地，心患蛟龙扫江南。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛弟上。"
        },
        {
          "character": "薛弟",
          "type": "念",
          "text": "心怀报国志，来报霸业人。"
        },
        {
          "character": "薛弟",
          "type": "白",
          "text": "报！薛弟告进。丞相在上，薛弟叩首。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "罢了。闻听孙权兵抵宛城，直取合肥，张辽如何抵敌？"
        },
        {
          "character": "薛弟",
          "type": "白",
          "text": "只因攻破宛城，朱将军命丧阵前。张将军为失宛城，又恐合肥有失，只得坚守。 孙权带兵又攻合肥，却被张将军等一战，孙权兵败濡须口去了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孙权夺去了宛城，吾不恕之。朱光命丧阵前，老夫奏知天子，自有旌奖。"
        },
        {
          "character": "薛弟",
          "type": "白",
          "text": "闻知丞相得了东川，张将军差小将问丞相可取西川否？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫犹疑未决。 吓，先生，当何以进兵？"
        },
        {
          "character": "刘晖",
          "type": "白",
          "text": "启丞相：蜀中稍定，已有防备，不可急也。莫若撤兵去救合肥，以定江南。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生之言正合吾意。 夏侯渊听令。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你镇守定军山隘口等处，不得有误。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "徐晃听令。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命你镇守蒙头寨隘口等处，不得有误。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "其余将士随我去救合肥。听吾号令。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "莲花宝帐把令委， 列位将军听指挥： 各守关口须防备， 休叫贼寇逞雄威。 虚设旗帜扎营垒， 莫待临时燃须眉。 令出如山休违背，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同领下。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "送丞相。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "必须小心凯歌回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "夏侯渊",
          "type": "白",
          "text": "徐将军，你我各守关隘，须要小心汛地。 众位将军，就此分兵各处去者。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四下手、张辽同上。"
        },
        {
          "character": "张辽",
          "type": "引子",
          "text": "职任藩篱镇雄关，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李典、乐进同上。"
        },
        {
          "character": "李典、乐进",
          "type": "同引子",
          "text": "未用干戈定凶蛮。"
        },
        {
          "character": "张辽",
          "type": "引子",
          "text": "腹内藏经史，"
        },
        {
          "character": "乐进",
          "type": "引子",
          "text": "三千猛儿汉，"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同引子",
          "text": "同镇肥城。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "俺，张辽。"
        },
        {
          "character": "李典",
          "type": "白",
          "text": "俺，李典。"
        },
        {
          "character": "乐进",
          "type": "白",
          "text": "俺，乐进。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "李典、乐进",
          "type": "同白",
          "text": "请坐。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "吓，二位将军，你我奉命镇守合肥，不想朱光失去宛城，吴兵乘势攻打合肥逍 遥津前者一战，若非二位之勇，吾兵焉能全胜也？"
        },
        {
          "character": "李典、乐进",
          "type": "同白",
          "text": "此乃将军虎威，末将何功之有？只是朱光命丧阵中，失去宛城，某等有不克之 罪，如何见得丞相矣？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "我想丞相豁达大度，必不降罪。闻听也得东川，曾命薛弟去请丞相收伏西川之 事。待他回来，便知分晓。"
        },
        {
          "character": "李典、乐进",
          "type": "同白",
          "text": "将军所见不差。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "军校们伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛弟上。"
        },
        {
          "character": "薛弟",
          "type": "念",
          "text": "云掩旌旗靖，风吹刁斗寒。"
        },
        {
          "character": "薛弟",
          "type": "白",
          "text": "末将参见。"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "将军少礼吓。"
        },
        {
          "character": "薛弟",
          "type": "白",
          "text": "丞相大兵已到。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "哦，丞相大兵到了。吩咐摆队相迎。"
        },
        {
          "character": "薛弟",
          "type": "白",
          "text": "啊。 摆队相迎。 （众人同下。四文堂、四大铠、曹操同上，过场，同下。张辽、李典、乐进、薛弟、四文堂、四下手同上， 接。曹操、四文堂、四大铠同上，同下。众人同上，同挖门。）"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "丞相在上，末将参见。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位将军少礼。"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "谢丞相。丞相领兵远来，受尽风霜之苦。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此乃老夫分内之事。列位威镇敌国，老夫不胜之喜。"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "皆赖丞相虎威。只是朱将军失去宛城，命丧阵前。末将等特此请罪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孙权闻吾兵入汉中，不得首尾相顾，乘胜而取，与公等何罪？"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "谢丞相。闻知已得东川，何不乘胜夺去西蜀？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "公等不知。既得陇何必望蜀？士卒远途跋涉，暂在后帐歇息。吩咐摆宴，与公 等贺功。"
        },
        {
          "character": "张辽、李典、乐进",
          "type": "同白",
          "text": "多谢丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小太监同上，同站门，孙权上。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "旌旗蔽日虎帐号， 巍巍剑气透九霄。 逍遥津中摆战道， 张辽算得将英豪。 马跳桥南兵败了， 军回濡须重整袍。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孤家孙仲谋，日前夺了宛城，直取合肥。被张辽一战，兵败濡须，整顿船只， 以待水陆进兵。已曾命人回头搬取人马，一去许久，未见到来。 内侍伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张昭上。"
        },
        {
          "character": "张昭",
          "type": "唱",
          "text": "曹操领兵把战道， 见了主公奏根苗。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "臣张昭见驾，主公千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。赐坐。"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "谢坐。适才探士报来，曹操自汉中领统大兵救护合肥。请旨定夺。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "曹操领兵来攻合肥，先生妙计安在？"
        },
        {
          "character": "张昭",
          "type": "白",
          "text": "曹操领兵远来，为失宛城之怨。我军须挫其锐气，曹贼必罢兵矣。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "此言不差。 内侍，宣众将进帐。"
        },
        {
          "character": "内侍、张昭",
          "type": "同白",
          "text": "众将进见哪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程普上。"
        },
        {
          "character": "程普",
          "type": "念",
          "text": "四海九州多蛮戎，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘宁、董袭同上。"
        },
        {
          "character": "甘宁、董袭",
          "type": "同念",
          "text": "常将战业叹锦彭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐盛、凌统同上。"
        },
        {
          "character": "徐盛、凌统",
          "type": "同念",
          "text": "何年卸甲天河洗，"
        },
        {
          "character": "程普、甘宁、董袭、徐盛、凌统",
          "type": "同念",
          "text": "一解干戈见太平。"
        },
        {
          "character": "程普",
          "type": "白",
          "text": "程普。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "甘宁。"
        },
        {
          "character": "董袭",
          "type": "白",
          "text": "董袭。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "徐盛。"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "凌统。"
        },
        {
          "character": "程普",
          "type": "白",
          "text": "主公相招，一同进见。"
        },
        {
          "character": "甘宁、董袭、徐盛、凌统",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "程普、甘宁、董袭、徐盛、凌统",
          "type": "同白",
          "text": "臣等见驾，主公千岁。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "程普、甘宁、董袭、徐盛、凌统",
          "type": "同白",
          "text": "千千岁。宣臣等进帐，有何军情？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "今有曹操自汉中领兵前来，我兵先当挫其锐气。谁敢破敌？"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "启主公：俺凌统愿往。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "将军愿往，要带多少人马？"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "只要三千人马，可以破敌张辽。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "哎，甘宁只要百骑人马，可能破敌曹兵。何须三千人马？"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "呔，甘宁你好无礼。"
        },
        {
          "character": "凌统",
          "type": "唱",
          "text": "凌统怒发三千丈， 旌旗队队摆刀枪。 走进前来把话讲， 叫声甘宁听端详： 军家胜败休乱讲， 临阵还须自主张。 患难之中得此往， 大丈夫一死又何妨？"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "咳。"
        },
        {
          "character": "甘宁",
          "type": "唱",
          "text": "凌统休得发狂言， 甘宁言来听心间： 你我英雄人曾见， 难比张辽一勇贤。 非是甘宁夸口献， 百骑人马得胜还。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "二位将军。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "二卿不必来争论， 赤心为孤锦乾坤。 曹操势大兵将勇， 不可轻视比他人。 凌统近前听孤令， 带兵三千破曹兵。"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "凌统",
          "type": "唱",
          "text": "主公驾前颁将令， 不由豪杰喜盈盈。 辞别主公上能行， 大破曹兵显奇能。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "凌统下。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "凌统威武出营门， 叫声徐盛听令行： 带领人马暗接应， 他若有失便回营。"
        },
        {
          "character": "徐盛",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "徐盛",
          "type": "唱",
          "text": "帐中领了主公令， 暗地接应要小心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐盛下。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "后帐摆宴君臣饮， 柔能克钢记在心。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四下手、张辽、李典、乐进同上，同站门。曹操上。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "常怀赤胆秉忠政， 英雄韬略立功勋。 满腹珠玑战策论， 镇定四方扫群雄。 麒麟阁上标名姓， 食君爵禄报主恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！凌统讨战。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "凌统讨战，何人出马？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "末将愿往。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好，听我一令。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "将令一出山摇动， 张辽将军听详情： 三千人马你带领， 濡须坞口暗埋存。 等那凌统兵马近， 杀他片甲不回营。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "张辽",
          "type": "唱",
          "text": "中军帐内领将令， 生擒凌统立头功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同领下，张辽下。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "张辽韬略似管仲， 好比乐毅不差分。 各归队伍旌旗整， 且听探马报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、凌统同上。"
        },
        {
          "character": "凌统",
          "type": "唱",
          "text": "适才帐内领将令， 不由豪杰咬牙根。"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "俺，凌统。可恨甘宁在主公面前要占我的头功，为此夸口大战张辽。 呔，众将官听我一令。"
        },
        {
          "character": "凌统",
          "type": "唱",
          "text": "坐立雕鞍传将令， 大小儿郎听详情： 刀枪剑戟要齐整， 盔甲各个要鲜明。 奋勇上前有赏赠， 退后军法不容情。 三军对对往前进， 要与张辽定雌雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "张辽",
          "type": "内西皮导板",
          "text": "号炮一响如雷震，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四上手、张辽同上。"
        },
        {
          "character": "张辽",
          "type": "唱",
          "text": "戈甲层层将纷纷。 旌旗飘绕摇日影， 刀枪闪闪电光荧。 豪杰威风冲霄汉， 天昏地暗杀气生。 勒住丝缰传一令， 大小三军听分明： 自古军令如山重， 奋勇当先抖精神。 冲锋对垒休恤命， 冒犯矢石忘其身。 人马扎住坞尘领， 等候吴兵定输赢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "凌统、四下手同上。"
        },
        {
          "character": "凌统",
          "type": "唱",
          "text": "提枪勒马战场道， 两眼睁睁把他瞧。 堂堂一表非凡貌， 真是将中一英豪。 冲马来将通名号， 通上姓名把兵交。"
        },
        {
          "character": "张辽",
          "type": "唱",
          "text": "盗贼休得逞强暴， 老爷张辽将英豪。 泼胆擎天谁不晓， 敢向军前藐吾曹。 叫声来将把名报， 某家擒你在今朝。"
        },
        {
          "character": "凌统",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "凌统",
          "type": "唱",
          "text": "大将凌统谁不晓？ 顷刻擒你献功劳。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "张辽",
          "type": "唱",
          "text": "凭你南山一虎豹， 凭你北海浪里蛟。 某家今日领兵到， 管叫尔人头血染刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽、凌统同杀，凌统败下。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "凌统大败。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "列开旗门。"
        },
        {
          "character": "张辽",
          "type": "唱",
          "text": "撤焰光使宝刀轰声倒下， 明亮亮刀枪勇风飘雪花。 逞威风勒住了跨下战马， 看旌旗耀日光掩暗云霞。 这一个好一似泰山倒下， 杀得他君臣们血染黄沙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四值殿、甘宁、董袭、孙权同上。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "战鼓咚咚连声响， 探马不住报端详。 为王且坐莲花帐， 未知谁弱是谁强？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐盛上。"
        },
        {
          "character": "徐盛",
          "type": "唱",
          "text": "张辽英雄难抵挡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "凌统上。"
        },
        {
          "character": "凌统",
          "type": "唱",
          "text": "败阵回营脸无光。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "军家胜败，古之常理，何必如此？平身。"
        },
        {
          "character": "徐盛、凌统",
          "type": "同白",
          "text": "谢主公。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "启主公：末将只要一百人马，今晚去劫曹营。若损折一人，情愿军法从事。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "啊，将军有此刚毅，喏，这满营将士凭你调选一百人马，今晚去劫曹营。孤赐 百人酒食与将军立功。孤遣大兵在后。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "甘宁",
          "type": "笑",
          "text": "哈哈哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘宁下。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "凌统、徐盛、董袭、程普四人听令：见曹营火起，齐勇杀出，听我吩咐。"
        },
        {
          "character": "孙权",
          "type": "唱",
          "text": "降旨一道众将晓， 孤王言来听根苗： 此番出兵非关小， 将士必须立功劳。 晓谕已毕归营道， 走马成功兴吾朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四上手、甘宁同上。"
        },
        {
          "character": "甘宁",
          "type": "唱",
          "text": "帐中夸口领将令， 百骑人马劫曹营。 暂摆擒王破敌阵， 甘宁今日显技能。 三军摆酒且同饮， 你我要学乐毅能。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "列位坐下。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "我等告坐。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "请哪。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "请哪。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "啊，列位，俺仅奉命带你等百人，今晚三更时分去劫曹营。吾公赐赏酒食，你 等各自欢饮一场。努力争先，以酬报国之劳。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "哎呀，将军，我想曹兵百万之众，我们百人焉能劫得曹营？只恐难哪。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "唔，为大将者，岂可贪生惜命？你等何敢迟疑？如不遵者，立刻斩之。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "是是是。将军如此忠勇，我等愿出死战，以报国家。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "好哇，你等既然协力，不枉食君之禄。看酒来。列位请。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "甘宁",
          "type": "白",
          "text": "列位今晚三更时分，头插白鹅翎为号，各执器械去劫曹营，不负你我麒麟阁上 标名也。"
        },
        {
          "character": "甘宁",
          "type": "唱",
          "text": "一令说与列公晓， 养军千日用一朝。 你我须要齐报效， 麒麟阁上把名标。 廉颇战霸功劳好， 他的名姓扬九朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "曹操",
          "type": "内二黄导板",
          "text": "营门外起初更提灯发号，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四藤手、四长枪手、四大铠、张郃、李典、乐进、张辽、曹操同上。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "摆旌旗列门道观看六韬。 有前营摆朱雀威风号炮， 后营队摆元武志略广韬。 左青龙右白虎层层飘渺， 虎金枪白玉罩驮鼓声高。 众将官靠山峰安营下道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "起鼓。安营。内喊声。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "防奸细必须要紧记心牢。 为大将食君禄当全忠孝， 执兵权威镇主要立功劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "猛听得大营内二更已到， 矇眬睡心劳碌龙上九霄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二更夫同上。"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "咳，伙计，留点神。小心火烛，防备奸细。走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二更夫同下。〖急急风〗。四文堂、四上手、甘宁同上，过场，同下。二更夫同上。"
        },
        {
          "character": "更夫甲",
          "type": "白",
          "text": "伙计留点神，小心火烛奸细。 （四文堂、四上手、甘宁同上，杀二更夫。四文堂、四藤手、四长枪手、四大铠同上，同败下。四文堂、四 上手、甘宁同追下。内喊。）"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张辽上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "哎呀，不好了，前营为何有了火了？三营又有喊杀之声，却是为何？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启将军：吴兵已劫前营，看看杀进大营来了。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "哎呀，丞相，不好了。吴兵已劫前营，要杀进大营来了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "快快命将士迎上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "迎上前去。 （四文堂、四上手、甘宁同上，会阵，起打，同下。众人同败下，张辽败下。四文堂、四上手、甘宁同追下。 〖急急风〗。八手下同上。凌统、徐盛、董袭、程普同上。）"
        },
        {
          "character": "凌统、徐盛、董袭、程普",
          "type": "同白",
          "text": "众将官，迎上前去。 （众人同下。四文堂、四上手、甘宁同上。张辽、众人同上，八手下、凌统、徐盛、董袭、程普同上，会大 阵，起打。张辽、众人同败下。四太监引孙权同上。〖牌子〗。四文堂、四上手、甘宁同上。）"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哎呀，将军，如此奋勇一战，曹兵败去，此功非小。人马回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}