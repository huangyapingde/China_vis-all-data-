{
  "script_id": "02006048",
  "title": "五凤楼",
  "alias": [
    "送君"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李显",
      "hangdang": "生"
    },
    {
      "name": "韦后",
      "hangdang": "旦"
    }
  ],
  "plot": "卢陵王被贬出京，群臣恭送。武三思奉旨监斩薛氏满门。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "内同白",
          "text": "请吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马周、程万牛、罗章、李敬犹同上。"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同唱",
          "text": "不是献帝禅台命， 哪有君王贬出京？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四宫女引李显、韦后同上。"
        },
        {
          "character": "李显",
          "type": "唱",
          "text": "眼含珠泪离宫禁，"
        },
        {
          "character": "韦后",
          "type": "唱",
          "text": "主为天子作公卿。"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同白",
          "text": "臣等见驾，愿陛下万岁，娘娘千岁。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "卿等来至宫门，有何国事？"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同白",
          "text": "闻陛下谪贬湖广房州，臣等进宫保奏。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "哎呀众卿吓，朕母后传旨，但有文武保本，即便提头来见。"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同白",
          "text": "主往房州，江山何人执掌？"
        },
        {
          "character": "李显、韦后",
          "type": "同白",
          "text": "母后临朝执政。"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同白",
          "text": "太后焉能执掌江山？主公、娘娘停龙驾，臣等舍死谏奏便了。 中国京剧戏考 《五凤楼》【五本】 2"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "哎呀，众卿吓，太后不念母子之情，岂留君臣之义？但朕去后，全仗卿等整理 皇唐天下，寡人在房州，静听好音。"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同白",
          "text": "既然如此，臣等送驾起行。"
        },
        {
          "character": "李显",
          "type": "白",
          "text": "卿家吓！"
        },
        {
          "character": "李显",
          "type": "唱",
          "text": "朕遭谪贬尊母命，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马周、程万牛、罗章、李敬犹同摆驾，四太监、四宫女、韦后同下。"
        },
        {
          "character": "李显",
          "type": "唱",
          "text": "可叹薛家无救星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李显下。"
        },
        {
          "character": "马周、程万牛、罗章、李敬犹",
          "type": "同唱",
          "text": "武氏传国心已定， 眼见唐室一旦倾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马周、程万牛、罗章、李敬犹同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军牢、八刽子手、武三思同上。"
        },
        {
          "character": "武三思",
          "type": "念",
          "text": "威权势力沐君恩，统辖军马第一臣。剪除逆叛消君恨，立斩薛氏灭满门。"
        },
        {
          "character": "武三思",
          "type": "白",
          "text": "某，武三思。奉太后旨意，监斩薛氏满门。 刀斧手，打道天牢去者。"
        },
        {
          "character": "八刽子手",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。四短刀、四长枪、武承嗣同上。〖牌子〗。"
        },
        {
          "character": "武承嗣",
          "type": "白",
          "text": "某，武承嗣。奉太后懿旨，往两辽府掘一深坑，埋葬薛氏尸首。 众将官，即往辽府去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八云童、四神将、窦青老祖同上。〖牌子〗。"
        },
        {
          "character": "窦青老祖",
          "type": "白",
          "text": "吾乃太乙山窦青老祖是也。法眼观见江淮侯李敬犹，舍子替换薛蛟。但李孝思 命不该绝，吾今前去救他上山，扶养成人后，扶皇唐天子。 众神将，驾云前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}