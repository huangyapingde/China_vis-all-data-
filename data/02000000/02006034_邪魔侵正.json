{
  "script_id": "02006034",
  "title": "邪魔侵正",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "唐僧",
      "hangdang": "老生"
    },
    {
      "name": "百花羞",
      "hangdang": "旦"
    },
    {
      "name": "猪悟能",
      "hangdang": "净"
    },
    {
      "name": "沙悟净",
      "hangdang": "净"
    },
    {
      "name": "化身",
      "hangdang": "小生"
    }
  ],
  "plot": "黄袍大仙，即黄袍郎（虎精）将唐僧卷入洞中，拟三日后由外归来，再吃唐僧之肉，暂由小妖看守。小妖等\n告知娘娘百花羞。百花羞甚为诧异。问明情由，始知亦系被黄袍郎卷来者，极为同情。遂言明系宝象国大将\n军柏宪之女，被妖卷来，强逼成婚。遂将唐僧释放，托带信父母，想法营救。并令花香洁亦写信其丈夫闻仁，\n由唐僧一同带去。黄袍郎归后，发现百花羞等将唐僧放出，必托带信其父母，想法营救。于是先发制人，\n变作美俊少年，往谒柏宪，言其女百花羞被伊救出，暂留渠家中。柏宪见黄袍郎少年英俊，且系救女恩人，\n一面令其入赘，一面带令朝见国王，封为都尉。正在庆贺欢宴时，家院报告唐僧带其女儿百花羞之信至。黄\n袍郎大窘，乃用妖法，喷水唐僧身上，使唐僧立时变成猛虎，装入槛中，听候国王命令处决。",
  "notes": "按此剧纯系由《西游记》第三十回“邪魔侵正法，意马忆心猿”而来，特结构较西游记稍为简略。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小妖押唐僧同上。〖牌子〗。"
        },
        {
          "character": "四小妖",
          "type": "同白",
          "text": "娘娘有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花羞上。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "什么事情？"
        },
        {
          "character": "四小妖",
          "type": "同白",
          "text": "小的们奉大王之命，禀上娘娘：大王与白骨夫人建造道场，三日不得回府，命 小的们启上娘娘知道。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "为白骨夫人建什么道场？这和尚为什么绑他？"
        },
        {
          "character": "四小妖",
          "type": "同白",
          "text": "白骨夫人被孙悟空打死。因此追荐。这和尚是孙悟空的师父，大王拿他替白骨 夫人报仇，要杀他来吃。命小的们绑在剥皮厅上，候大王令下，就要开刀。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "你们不要胡为。放了绑，待我问个明白。"
        },
        {
          "character": "四小妖",
          "type": "同白",
          "text": "和尚，来见娘娘。叩头。 好大胆秃驴，我家大王见了娘娘，尚且跪拜。哪像你这和尚这等胆大，不跪就 要打了！"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "不要啰唣。回避了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小妖同下。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "师父你从何处而来，为什么被他拿住？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "不消问得。我是该死之人，既被拿住，就是你们口中之物了。问他则甚？"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "我不是妖怪。我是宝象国柏大将军之女，名唤百花羞。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "原来是位小姐。女菩萨听禀！"
        },
        {
          "character": "唐僧",
          "type": "唱",
          "text": "贫僧开言忙告禀， 女娘菩萨听分明： 大唐差我往西境， 竺乾拜佛求真经。 你若果是真小姐， 设计放我早逃生。 若得残躯保全命， 也显慈悲一片心。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "百花羞",
          "type": "唱",
          "text": "想奴被妖卷此洞， 家中哭坏老年人。 今日将他来放行， 趁便托寄书一封。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "师父，但请放心。我这里放你出去。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "多谢女菩萨，一生不忘此大恩。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "奴有一言，奉启师父。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "女菩萨有何言语，贫僧愿闻。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "师父此去两天，必由宝象国经过。奴欲寄书一封，与我父母。烦劳带去，不知 肯否？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "既有家书，贫僧愿带。但不知令尊大人，官居何职？"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "我父亲姓柏名宪字慕林，官居大将军之职。奴是他亲生之女，名叫百花羞。那 年元宵观灯，被妖怪黄袍郎卷到此地。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "贫僧记得了。请小姐快修罢。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "姐姐快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花香洁上。"
        },
        {
          "character": "花香洁",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "这位师父，要到宝象国去的。我托他寄信与爹娘，姐姐你可也修书与姐夫，烦 师父带去，或者有缘，也未可知。"
        },
        {
          "character": "花香洁",
          "type": "白",
          "text": "原来如此。但不知这位师父，因何到此？"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "也是被妖人卷来的。我今释放了他，他往西天拜佛求经。"
        },
        {
          "character": "花香洁",
          "type": "白",
          "text": "既如此，妹子你在这里修书，我到里面去写便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花香洁下。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "咳，我那爹娘吓！"
        },
        {
          "character": "百花羞",
          "type": "唱",
          "text": "未曾提笔泪先降， 思之叫人痛断肠。 自从那年登楼上， 母女双双观春光。 忽然一阵狂风降， 妖魔卷我到此方。 强逼姻缘偕俪伉， 偷生忍辱任癫狂。 今遇法师唐三藏， 托他寄信与爹娘。 儿想家园难脱却， 哭断咽喉迸裂肠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花香洁上。"
        },
        {
          "character": "百花羞、花香洁",
          "type": "同白",
          "text": "烦师父寄去。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "但不知娘子高姓？"
        },
        {
          "character": "花香洁",
          "type": "白",
          "text": "奴家花香洁。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "尊夫高姓大名？"
        },
        {
          "character": "花香洁",
          "type": "白",
          "text": "我丈夫姓闻名仁字道泉，安乐镇人也。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "既如此，二位女菩萨请上，受贫僧一拜。"
        },
        {
          "character": "唐僧",
          "type": "唱",
          "text": "多蒙二位女娘行， 释放贫僧命不忘。 前往贵府书寄上， 管保脱此转回乡。"
        },
        {
          "character": "百花羞、花香洁",
          "type": "同白",
          "text": "不敢。 小妖们哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小妖同上。"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "护送了这位师父出去，不许拦阻。"
        },
        {
          "character": "四小妖",
          "type": "同白",
          "text": "大王叫管押的，怎生放得？"
        },
        {
          "character": "百花羞",
          "type": "白",
          "text": "胡说。大王问时，只说是我释放的，也就是了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "百花羞下。"
        },
        {
          "character": "四小妖",
          "type": "同白",
          "text": "晓得。 这里来。"
        },
        {
          "character": "唐僧",
          "type": "唱",
          "text": "好似鱼儿离罗网， 猛虎口内逃犬羊。"
        },
        {
          "character": "四小妖",
          "type": "同白",
          "text": "那里走就是大路了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐僧、四小妖同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "猪悟能、沙悟净同上。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "好恨妖怪！"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "哥吓，不要看这般光景，你我抖起精神，救出师父要紧。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "救不成。妖怪如此厉害，天色昏暗，往哪里去救？"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "救不成，难道就罢了不成。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "不要忙，我自有主意。"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "有什么主意？"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "把师父拿去，料来不得活命。如今我们取不成经，你往流沙河，我往高老庄。 就是这个主意。"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "又来说呆话。到底想计救师父，才是道理。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "我是莫有什么计。兄弟你有计，我跟你走就是了。"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "我两人如今找到妖怪门首，向他要我师父。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "放你二十四个臭驴子屁。妖怪若肯放师父出来，他就不来拿师父了。"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "和尚是软弱法门。小心去求他，他自然首肯。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "是这话。你我就像化缘行善的一般，一步一拜，拜到妖怪门上。口称妖怪老爷， 妖怪大王。将我师父布施了罢。"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "你总是呆话。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "看。师父来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐僧急上。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "八戒哪里？"
        },
        {
          "character": "猪悟能、沙悟净",
          "type": "同白",
          "text": "师父吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖哭相思〗。"
        },
        {
          "character": "猪悟能、沙悟净",
          "type": "同白",
          "text": "师父怎么脱了妖魔之手？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "我幸遇宝象国大将军之女，名唤百花羞。她也被妖魔卷去。结为夫妇，住在洞 中。还有一个儒学生员名唤闻道泉，他妻子花香洁也被妖魔卷去，与百花羞共 处一处。蒙她二人慈悲放我，又写家书一封，托我寄回。故此才得脱离虎口。"
        },
        {
          "character": "猪悟能、沙悟净",
          "type": "同白",
          "text": "此乃佛天感应。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "天色已明。快些赶路。"
        },
        {
          "character": "唐僧",
          "type": "唱",
          "text": "休得慢言速前奔， 投向宝象国中行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐僧、猪悟能、沙悟净同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄袍郎上。"
        },
        {
          "character": "黄袍郎",
          "type": "唱",
          "text": "冤仇未报难解怨， 从来莫信夫人言。"
        },
        {
          "character": "黄袍郎",
          "type": "白",
          "text": "我房下瞒了我，将唐僧放了。放了也罢。只是他此去，必从宝象国经过。一定 有书信寄与她父母。这便怎么处？有了。我如今先到宝象国，认那柏大将军为 岳父。才好算计唐僧。去便去了，只是一件。我这副嘴脸，如何出得人前？吓。 是我那样神通，不但自己会变，就那世上的人，要他变猪、变狗、变牛、变 马，只消一口气吹去，立成了畜生也。好计，好计。如今变个美貌书生便了。"
        },
        {
          "character": "黄袍郎",
          "type": "唱",
          "text": "俺本是堂堂上界仙， 神通法力广无边。 按住原身打一变，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "化身上。"
        },
        {
          "character": "化身",
          "type": "唱",
          "text": "变个英俊美少年。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "哈哈，变得像也不像。不免即往宝象国去者。"
        },
        {
          "character": "化身",
          "type": "唱",
          "text": "头上儒巾齐眉岸， 身穿一件绣罗衫。 堪笑世人多昏暗， 怎辨真假黄袍仙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "化身下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "闵氏上。"
        },
        {
          "character": "闵氏",
          "type": "唱",
          "text": "元夕吴女遭磨难， 失去明珠无影还。 幸得东庄英雄汉， 搭救姣儿脱祸端。"
        },
        {
          "character": "闵氏",
          "type": "白",
          "text": "老身闵氏。不幸元宵夜观灯，女儿被虎精卷去。幸得城东碗子山波月庄黄姓之 人，射逐妖虎，救了女儿，收留在家。昨日来府拜见老爷。老爷见他相貌堂堂， 十分欢喜，就认作了女婿。今早带他去朝见国王。主要加他官职。未知上意 如何。待他回来，便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖六么令〗。院子甲、四龙套、柏宪同上。"
        },
        {
          "character": "闵氏",
          "type": "白",
          "text": "老爷。女婿朝见怎么样？"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "夫人，国王喜他人才出众，相貌魁梧，官绶都尉之职。即刻就回来拜谢你我了。"
        },
        {
          "character": "闵氏",
          "type": "白",
          "text": "如此可喜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子乙引化身同上。"
        },
        {
          "character": "化身",
          "type": "出对子",
          "text": "天颜亲近， 感皇恩雨新。 官封都尉品逾尊， 姣婿公明赘将门。 喜气乘龙， 谁识救人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子乙下。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "岳父、岳母请上，容小婿拜谢。"
        },
        {
          "character": "柏宪、闵氏",
          "type": "同白",
          "text": "不消，只行常礼罢了。"
        },
        {
          "character": "化身",
          "type": "念",
          "text": "蒙恩不弃，结丝罗，引见吹王雨露多。"
        },
        {
          "character": "柏宪、闵氏",
          "type": "同念",
          "text": "前世赤绳系定，故令妖虎执仙柯。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "待小婿把盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "设宴入座、捧酒。院子乙上。"
        },
        {
          "character": "院子乙",
          "type": "念",
          "text": "涎脸新夸男入赘，光头慌报女稍书。"
        },
        {
          "character": "院子乙",
          "type": "白",
          "text": "院子禀事：门官传话进来，外面有三个和尚，说亲见小姐，寄得有家书一封。 三人都在外面候见。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "贤婿才到，小姐怎么又托和尚寄书。这是什么缘故？"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "哪有此事。这又奇了！岳父且拿书一看。便知端底。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "说得有理。 取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子乙递书。柏宪看。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "这又奇了。书中之言，我儿千悲万苦。那来人又说亲见女儿寄来的。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "这一定是妖畜，又来做弄小婿。小婿曾受异人传授。能令妖魔，立现原形。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "如此甚好。 院子。吩咐家将弓上弦，刀出鞘，堂前伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子乙下。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "贤婿同去看来。夫人回避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闵氏下。四校尉拿带刀同上，同站门。柏宪归坐，化身站。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "人来传那和尚进来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐僧、猪悟能、沙悟净同上。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "大将军稽首了。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "你这和尚，是哪里来的？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "大将军听禀！"
        },
        {
          "character": "唐僧",
          "type": "唱",
          "text": "贫僧被卷见千金， 令嫒传言奉尊听。 书信之上写得明， 因此特来见将军。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "你这孽畜，卷了府内小姐，被我射伤，饶了你性命。今日又来混扰。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "大将军。贫僧往西天拜佛求经的。路上被妖魔卷去，蒙贵小姐释放，寄书与大 将军。这位的话，好不明白。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "贤婿，听他言词，不像妖魔。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "听他言称贤婿，不要就是那卷去百花羞的妖魔，如今变了形象，反来认丈人了。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "岳父不要听他利口。他变了嘴脸，就要吃人的。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "这是哪里说起。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "妖魔站下些。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "孙子才是妖怪。你是妖怪，反说我们是妖怪。我师父被你掩到洞中，亏得那贤 德的百花羞，放了我师父出来。路上会见了老猪，顺便到此寄信。你莫不是就 黄袍郎么？"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "这两个都是他的羽翼。都是妖怪。岳父切不可信他。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "可惜我师兄孙行者赶去了。他若在这里，先与你一铁箍棒，打翻了你，不怕你 不现原形。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "一派胡言。你浑身都是妖怪的模样。"
        },
        {
          "character": "猪悟能",
          "type": "白",
          "text": "不害羞。我是妖怪，不好撒野。"
        },
        {
          "character": "沙悟净",
          "type": "唱",
          "text": "妖魔硬把东床认， 害得将军眼又昏。"
        },
        {
          "character": "化身",
          "type": "唱",
          "text": "与伊口说无凭准， 现出原形清浊分。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "化身对唐僧喷水，唐僧下，穿虎皮上。猪悟净、沙悟能不敌，猪悟能逃下。"
        },
        {
          "character": "沙悟净",
          "type": "白",
          "text": "呔！你们休得胡为。我乃上界卷帘大将。今我师父被妖精作弄，不知用什么妖 法，变了一只猛虎。我如今在此保护，我看你这妖精，岂奈我师徒何！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同绑沙悟净。"
        },
        {
          "character": "化身",
          "type": "白",
          "text": "你这和尚休得胡说，将虎用囚笼囚了。请岳父入朝，奏知国王，处治这妖怪与 这和尚便了。"
        },
        {
          "character": "柏宪",
          "type": "白",
          "text": "有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同抬虎下，押沙悟净同绕场。"
        },
        {
          "character": "化身、柏宪",
          "type": "同滴溜子",
          "text": "今日个灵符有准， 这孽畜变成虎形。 莫道公然家书传进， 冤家遇对头，岂容蒙混。 解送国王， 听候处分。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}