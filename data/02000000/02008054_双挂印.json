{
  "script_id": "02008054",
  "title": "双挂印",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "穆桂英",
      "hangdang": "旦"
    },
    {
      "name": "白氏",
      "hangdang": "占旦"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "孟良",
      "hangdang": "净"
    },
    {
      "name": "焦赞",
      "hangdang": "净"
    },
    {
      "name": "白天佐",
      "hangdang": "净"
    },
    {
      "name": "丑中军",
      "hangdang": "丑"
    }
  ],
  "plot": "萧邦元帅白天佐部下副将鲁雄，据报宋营派兵来攻，金鼓齐鸣，即向白天佐报告。适白天佐酒醉未醒，中军\n不敢传禀。鲁雄不得已，私自闯进元帅内房将白天佐唤醒。但白天佐仍在醉中，以为系其夫人呼唤。经鲁雄\n说明情由，白天佐不肯深信，因据其夫人报告，曾亲自带兵巡营，一切平静也。乃令中军唤请夫人再行问讯，\n始知其夫人业已出城与宋兵交战，并被生擒。原来其夫人出城交战，系爱杨宗保，而故意被擒者。但宋朝\n元帅为穆桂英，杨宗保只是一先行官。穆桂英问明情由，下令将其斩首。虽经杨宗保一再恳求，穆桂英终不\n允。惟最后由焦赞监斩，绑赴法场时，白天佐亲自带兵前来搭救。终将其夫人救出，并将焦赞俘去云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鲁雄上。"
        },
        {
          "character": "鲁雄",
          "type": "念",
          "text": "虎头燕颈志不凡，龙韬豹略永镇关。萧、宋屡争花世界，挂印将军报国难。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "某，白都督麾下、左营副将鲁雄是也。奉了太后旨意，同都督白天佐夺了洪州， 李汉超已灭。后有杨延昭领兵前来，被我国兵将围困。探马报说，宋王又发 来救兵，为此全身披挂，以备交锋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "军营奉将令，打听二国兵。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "将军在上，探子叩头。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "打听何方军情，报某知道？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "容报！"
        },
        {
          "character": "报子",
          "type": "念",
          "text": "探子报，将军知，将军知：城外杀声如雳霹。 耳听锣鸣战鼓起，霎时收兵卷了旗，霎时收兵卷了旗。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "鲁雄",
          "type": "念",
          "text": "英雄气，吐虹霓，吐虹霓。我营将士未曾通消息，何人胆大把兵提，把兵提？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "小人观见宋营杀声震地，霎时卷旗息鼓，人马回营。不敢隐瞒，特来报知。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "想是都督与宋兵交战。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "小人曾到辕门报知都督。中军老爷言道：都督醉卧不醒，为此转报将军。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "吓，都督醉了么？吓，既是都督酒醉，这是何人与宋兵交战呢，你可看得明白？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "小人不敢近前，远远观见旗帜招展，金鼓齐鸣，霎时收了人马。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "吓，此事令人难解。你且再去打听，某家亲到辕门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子应，下。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "吓，堂口为何无有一人？也罢，待某击鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑中军上。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "呔，何人击鼓？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "是某家。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "原来是将军。为何击鼓？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "请问元帅在哪里？"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "元帅酒醉在床，睡卧不醒。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "吓，这还了得！某闻宋营救兵已到，城外杀声震地。若不早作隄防，倘若打破 城池，如何抵挡？烦你进去禀知元帅。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "酒还未醒，禀也枉然。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "阵前还敢贪杯饮酒，岂不知酒能误事么？"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "他误事自有管事人罚他，与你什么相干？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "与你们无干？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "鲁雄",
          "type": "唱",
          "text": "惟酒害人祸不小， 醉后言狂语蹊跷。 国乱不与主报效， 坐食君禄愧在朝！"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "你这些话，只好对他讲。向我说，我还敢管着他不喝酒么？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "烦你进去，通报一声。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "夫人在上房，我不敢进去。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "你进去不进去？"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "我不敢。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "你不敢，待某亲自去！"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "你也去不得！"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "嗳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁雄下。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "啊呀呀，跌断我的腰。他好大胆，竟跑到老爷上房去了。呵哟哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁雄扯白天佐同上。"
        },
        {
          "character": "鲁雄",
          "type": "唱",
          "text": "大宋兵马围城绕， 元帅早定计良谋。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "元帅醒来，元帅醒来！"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "吓，夫人。某家吃不得了。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "是末将在此。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "吓，原来是将军，怎么到我上房来了？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "不是上房，乃是二堂。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "某家吃得大醉。怎么到二堂来了？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "是末将搀扶出来的。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "吓，你扶我出来作甚？"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "末将闻报，城外杀声震地，一时宁静。想是宋兵设计攻城，末将特来报知。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "嗳，夫人巡城回来道，宋兵并无动静。又劝我吃个太平宴，就把我醉得不省人 事了。怎么宋兵攻城？不要听报人的话，回衙去罢。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "启元帅：探事军马，岂敢谎报？还须上城看个明白！"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "嗳，上城看什么，问夫人就知道了。 中军传话，上房请夫人出堂。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "吓，请夫人出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫头上。"
        },
        {
          "character": "丫头",
          "type": "白",
          "text": "走吓！ 启老爷：夫人不在上房。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "胡说！夫人与我一同饮酒，怎么不在上房？想是她也醉了。快请快请！"
        },
        {
          "character": "丫头",
          "type": "白",
          "text": "陪老爷饮酒之后，夫人就不见了。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "吓，陪我饮酒之后，夫人就不见了？"
        },
        {
          "character": "丫头",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "禀元帅：城外喊杀之声，与宋兵交战。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "夫人从不走私路。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "胡说！速去传四门兵丁来见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑中军应，下。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "丫鬟，想是夫人到花园游玩去了。你速去找寻，我候门军前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫头下。丑中军引四兵丁同上。"
        },
        {
          "character": "丑中军",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "小人们叩头。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "你们可曾见夫人出城？"
        },
        {
          "character": "三兵丁",
          "type": "同白",
          "text": "不曾见。"
        },
        {
          "character": "兵丁甲",
          "type": "白",
          "text": "小人先见夫人巡城回来，后又单人独马出城去了。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "你是哪城门军？"
        },
        {
          "character": "兵丁甲",
          "type": "白",
          "text": "小人是南门的。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "吓，夫人独自一人出城？"
        },
        {
          "character": "兵丁甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "你可曾问她出城作什么？"
        },
        {
          "character": "兵丁甲",
          "type": "白",
          "text": "好像说去找野汉。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "兵丁甲",
          "type": "白",
          "text": "吓，有公干。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "吓，你怎样不来报？"
        },
        {
          "character": "兵丁甲",
          "type": "白",
          "text": "小人要来报知元帅，夫人说是老爷叫她二次巡城。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "吓，说是我叫她去的？"
        },
        {
          "character": "兵丁甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "快去谨守城池。"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "谢元帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵丁同下。丫头上。"
        },
        {
          "character": "丫头",
          "type": "白",
          "text": "报启老爷：夫人不在花园。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "下去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫头下。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "启元帅：夫人定被宋将擒去。快发兵将，出城搭救。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "好。你去齐集人马，到辕门伺候。"
        },
        {
          "character": "鲁雄",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": "鲁雄",
          "type": "唱",
          "text": "俺点齐人和马辕门伺候， 此一战谅宋兵难以回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁雄下。"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "可恼吓可恼！"
        },
        {
          "character": "白天佐",
          "type": "唱",
          "text": "既巡城为什么私行逃走， 不带兵不带将独骑何由？ 今与宋两交兵龙争虎斗， 难道说战场上也有情偷？"
        },
        {
          "character": "白天佐",
          "type": "白",
          "text": "酒误大事！酒误大事！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白天佐下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小军、四女兵、旗夫、孟良、焦赞、穆桂英同上，同挖门。〖吹打〗。穆桂英上高台。"
        },
        {
          "character": "穆桂英",
          "type": "念",
          "text": "奉王旨意出东京，刀枪锐利耀日明。百万军中为总领，代天征讨穆桂英。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "我在阵前擒来番邦女将。为此升帐发落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "报启元帅：番邦女将被擒，请令定夺。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "嗳，别扯燥，是我擒来的，我自有发落，要你巴结什么！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "是元帅命先行看守，不得不报。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "喂哟哟会说话，给你个脸儿罢。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "多谢元帅。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "将她绑进帐来。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "得令。 下面听者：将番邦女将，绑进帐来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刀斧手押白氏同上。"
        },
        {
          "character": "白氏",
          "type": "唱",
          "text": "悔不该贪风花独把营闯， 皆因是爱你好貌似潘郎。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "你也不差。"
        },
        {
          "character": "白氏",
          "type": "唱",
          "text": "到如今被擒来反受捆绑，"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "待我与你放松些。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "白氏",
          "type": "唱",
          "text": "进帐去要将军保我无伤。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "不妨。有我保你无事，只管把胆放大些。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "白氏",
          "type": "唱",
          "text": "壮我胆奴才把愁眉展放，"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "报！番妇进。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "吓，什么番妇番妇的吓？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "吓，女将进！"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "着！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "报，女将进！当面。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "先行站开些。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "白氏",
          "type": "唱",
          "text": "听将台传一令虎视轩昂。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "穆桂英",
          "type": "唱",
          "text": "见本帅不屈膝野性狂妄， 为什么站虎帐得意洋洋？ 想活命该有句乞恩话讲， 难道说你是个泥塑木装？"
        },
        {
          "character": "白氏",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "白氏",
          "type": "唱",
          "text": "你住南奴居北俱是女将， 论奉命调兵将我也刚强。 细看你料不能胜过吕望， 放我回领人马会战一场。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "穆桂英",
          "type": "唱",
          "text": "在帐中不哀告反来嘴犟， 我岂肯放虎归又把人伤。 令传出叫一声孟、焦二将，"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "穆桂英",
          "type": "唱",
          "text": "斩番妇将首级号令营房。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "得令！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "杨宗保",
          "type": "唱",
          "text": "二叔父休得要作事卤莽， 大将军杀一女犹如探囊。 天朝军要挡他兵多将广， 休要听元帅令贻笑番邦。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "先行阻令。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "穆桂英",
          "type": "唱",
          "text": "奴一令出貔貅谁敢违抗， 胆大的先行官言语突唐。 你救她我杀你头献军帐， 再兴兵破洪州班师还乡。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "啊呀，元帅吓！"
        },
        {
          "character": "杨宗保",
          "type": "唱",
          "text": "我头次就与她同会阵上，"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "吓，你头次出兵就败在她手？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "既是她杀败了你，我如今杀她替你报仇雪恨，你为什么反与她讲情呢？唔，你 这内中还有什么缘故么？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "啊呀，元帅吓！"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "你说！"
        },
        {
          "character": "杨宗保",
          "type": "唱",
          "text": "她停刀不杀我要降宋王。 请退帐俺胸中自有主张。"
        },
        {
          "character": "虽则是番邦女情高义广、穆桂英",
          "type": "白",
          "text": "吓，依你说来么，暂且饶她性命？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "穆桂英",
          "type": "白",
          "text": "呣，我知道你的心事了。你将她带至我后营，还是等我发落。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四小军、四女兵、旗夫、孟良、焦赞同下。穆桂英、杨宗保、白氏同转场。"
        },
