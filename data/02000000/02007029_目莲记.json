{
  "script_id": "02007029",
  "title": "目莲记",
  "alias": [
    "罗卜还乡"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "罗卜",
      "hangdang": "生"
    },
    {
      "name": "李老丈",
      "hangdang": "外"
    },
    {
      "name": "刘青提",
      "hangdang": "老旦"
    },
    {
      "name": "金奴",
      "hangdang": "小旦"
    },
    {
      "name": "樵夫",
      "hangdang": "丑"
    }
  ],
  "plot": "罗卜出外经商，倏忽三年，因思母心切，转返故里。途中遇其父执李某，告知其母破戒骂僧等事。罗卜闻听\n之下，不禁晕倒。其母闻子归来，匆忙赶至。见其子晕倒，以为定系李某拨弄是非，将李某大骂。罗卜醒后，\n极力为李某开释，谓见父执如见其父，不禁忧从中来，突然晕倒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗卜上。"
        },
        {
          "character": "罗卜",
          "type": "驻云飞",
          "text": "归去来兮， 路过金刚势险危。 托赖观音庇， 苦难相周济。 嗏此事尚堪疑， 此事尚堪疑。 细思之，听得慈悲，道我亲帏事， 多周折，应促吾曹急急归家里。 因此上三步一拜，拜回家里， 待萱堂资福消灾悔，消灾悔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗卜下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李老丈上。"
        },
        {
          "character": "李老丈",
          "type": "驻云飞",
          "text": "日月如飞，如见梅花三五枝， 正是雪后多佳丽。"
        },
        {
          "character": "李老丈",
          "type": "念",
          "text": "长安有贫者，依瑞不依多。"
        },
        {
          "character": "李老丈",
          "type": "驻云飞",
          "text": "贫者愁衣食。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "嗏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樵夫上。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "老爷子，我上山去砍柴，看见罗卜官人，三步一拜，拜回来来咧。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "是，我晓得了。你且回避了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樵夫下。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李老丈",
          "type": "驻云飞",
          "text": "忽听樵子报因伊， 忽听樵子报因伊， 罗卜回归。 我须是过长堤， 待等他来，劝解伊曹，见彼慈帏， 且自宽心，休得要争闲气。"
        },
        {
          "character": "李老丈",
          "type": "念",
          "text": "不为调和更待谁，不为调和更待谁。 中国京剧戏考 《目莲记》【二本】 2"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗卜上。"
        },
        {
          "character": "罗卜",
          "type": "驻云飞",
          "text": "难报春晖， 定省温情叹久违。 寸草心空系， 百拜身何瘁，嗏。"
        },
        {
          "character": "李老丈",
          "type": "夹白",
          "text": "官人回来了？"
        },
        {
          "character": "罗卜",
          "type": "驻云飞",
          "text": "忽见父相知， 忽见父相知。 公公，家中事儿赖携提。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "贤侄，瞻前无僧，顾后无佛，三步一拜，为着何来？"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "公公！"
        },
        {
          "character": "罗卜",
          "type": "驻云飞",
          "text": "听得慈悲之事， 道我亲帏，把盟誓相欺。 因此上三步一拜，拜回家里， 为慈亲忏悔。 尘缘尽，小侄别母三载今日才回来， 奈我思亲甚切。 归家见老母， 来日登门拜谢公公， 与你不及匆匆话别离， 不及匆匆话别离。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "自从令尊亡故，不能再会遗容。"
        },
        {
          "character": "李老丈",
          "type": "驻云飞",
          "text": "今见你经商买卖回来，如见令尊一般， 贤侄，你且暂立须臾，暂立须臾。 听我一言说你知。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "公公有话请讲。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "自从贤侄去后，令堂在家啊——"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "为何欲言又止？"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "老夫有一言说来，不要吃恼。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "小侄不恼。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "既不吃恼，你且听了！"
        },
        {
          "character": "李老丈",
          "type": "驻云飞",
          "text": "令堂听信谗言语， 便把三官毁。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "嗏。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "哎呀老娘啊！"
        },
        {
          "character": "李老丈",
          "type": "驻云飞",
          "text": "今劝你，慢伤悲，转庭帏， 今劝你，慢伤悲，转庭帏。 拜谒尊前，从容谏取， 母子同心，自有个相依处。"
        },
        {
          "character": "李老丈",
          "type": "念",
          "text": "不用忙忙说是非，不用忙忙说是非。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "哎呀老娘啊！当初父在之时，曾在花台发愿。如今悔却前言，将何解誓？兀的 不痛杀我也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗卜坐。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "贤侄醒来！"
        },
        {
          "character": "罗卜",
          "type": "孝顺歌",
          "text": "闻翁语，自怨嗟，闻翁语，自怨嗟， 叹我不能够供子职。 辜负了老父与孩儿命， 持斋与供佛，如依在时，言犹在耳。 哎呀老娘！ 今日里顿相逢， 痛得我肝肠碎，痛得我肝肠碎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗卜坐。金奴随刘青提同上。"
        },
        {
          "character": "刘青提",
          "type": "孝顺歌",
          "text": "闻儿至，喜上眉，闻儿至，喜上眉， 中国京剧戏考 《目莲记》【二本】 3 他那里三步一拜为母仪。 移步过长堤，移步过长堤， 探取儿消息。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "金奴，前面莫非是李胡子？"
        },
        {
          "character": "金奴",
          "type": "白",
          "text": "是李胡子。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "李公公一向有罪了。"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "可曾见我孩儿？"
        },
        {
          "character": "李老丈",
          "type": "白",
          "text": "那不是！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘青提见罗卜，嚷。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "哈！"
        },
        {
          "character": "刘青提",
          "type": "孝顺歌",
          "text": "罢了我的儿， 因甚的朦倒唤不起？"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "啊，李厚德，我也晓得了！"
        },
        {
          "character": "刘青提",
          "type": "孝顺歌",
          "text": "向日与你言辩一场，你怀恨在心， 今日里访得我孩儿回来，又在途中讲是谈非。 想我孩儿一别三载，今日才回来， 母子相逢，当加喜色，如何闷倒在地？ 不消说了，一定是你撺掇甚么言词， 撺掇甚么言词。 气得我的姣儿死， 气得我的姣儿死。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樵夫上，劝。"
        },
        {
          "character": "樵夫",
          "type": "白",
          "text": "老爷子，三年前管的闲事，如今你老又管闲事。走罢，走罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李老丈作诈关儿。樵夫推李老丈同下。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "我儿醒来。老娘在此。"
        },
        {
          "character": "罗卜",
          "type": "孝顺歌",
          "text": "三魂渺，七魄驰，三魂渺，七魄驰， 非翁谁与我说详细。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "儿吓。岂不闻毋以远间亲，事亲者无失其为亲才是。"
        },
        {
          "character": "刘青提",
          "type": "孝顺歌",
          "text": "今日里离间我娘儿，我娘儿， 儿若疏违我，定然不放你，哼老狗，我定然不放你。 娘到此痛得我珠泪垂， 忽闻儿至，许多欢喜。 今见你闷倒雪地， 顿使我肝肠裂碎了， 儿吓， 可怜我欢喜无几，悲愁又至。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "儿吓，敢是你身体倦了？"
        },
        {
          "character": "罗卜",
          "type": "孝顺歌",
          "text": "非身倦，"
        },
        {
          "character": "刘青提",
          "type": "夹白",
          "text": "想是折了本钱了？"
        },
        {
          "character": "罗卜",
          "type": "孝顺歌",
          "text": "非亏本。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗卜起。"
        },
        {
          "character": "罗卜",
          "type": "孝顺歌",
          "text": "非身倦，非亏本。 因李公说与儿端底。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "他对你讲些什么？"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "他不曾讲些什么。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "既不曾讲些什么，为何闷倒在地？"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "哎呀，老娘啊！"
        },
        {
          "character": "罗卜",
          "type": "孝顺歌",
          "text": "孩儿见父之友，如见老父一般， 因此一痛伤悲。 闷倒在中途里， 闷倒在中途里。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "儿吓！ 中国京剧戏考 《目莲记》【二本】 4"
        },
        {
          "character": "刘青提",
          "type": "念",
          "text": "人言难足信，亲见始为真。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "啊罗卜儿吓！"
        },
        {
          "character": "刘青提",
          "type": "孝顺歌",
          "text": "哼儿吓，你且揾了泪，莫生疑， 益利先自转庭帏。 归家去便知端底， 归家去便知端底。"
        },
        {
          "character": "刘青提",
          "type": "尾声",
          "text": "儿今喜自夫来至， 打破愁肠只自知， 拜谢天地与神祇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘青提、罗卜同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}