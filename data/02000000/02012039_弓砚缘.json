{
  "script_id": "02012039",
  "title": "弓砚缘",
  "alias": [
    "悦来店"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "何玉凤",
      "hangdang": "旦"
    },
    {
      "name": "安骥",
      "hangdang": "小生"
    },
    {
      "name": "白脸狼",
      "hangdang": "丑"
    },
    {
      "name": "黄傻狗",
      "hangdang": "丑"
    }
  ],
  "plot": "淮安县安学海因为得罪于总漕镇，总漕镇就参奏他一本，说他侵吞公款，押在牢中；必定要六千两银子，赔\n偿清楚，才可无事。有一个多年的义仆华忠，连夜奔到京中，报告公子安骥；将家产变卖了三千金先行送去。\n其余的一半，再向亲友借贷。安骥就和华忠动身。不料走到半途，华忠得病，不能行走，暂且住在悦来店\n中养病，安骥只得和驴夫先走。这时十三妹因为母亲有病，想下山来取些银钱，替母亲治病；恰巧听见安公\n子的两个驴夫，商议谋害安公子的话，她就跑到悦来店去，探访这公子，是如何的人。一见安公子是个文弱\n书生，先用言语来打动他，安公子不知道她的用意，终被两个驴夫骗往黑风岗。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安骥上。"
        },
        {
          "character": "安骥",
          "type": "引子",
          "text": "苦读经纶，习孔孟，日夜尽心。"
        },
        {
          "character": "安骥",
          "type": "念",
          "text": "勤学经史攻文章，要图金榜姓名香。但愿际逢风云会，好与皇家做栋梁。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "小生，安骥。父讳学海，母亲佟氏。只生我一人，又无兄弟姊妹。我父蒙圣恩， 职受淮阳县令，我母随往任所，将我留京候考。但愿得名登皇榜，不负我父 世代书香的名望，我这几日，忽觉心神惊恐，不知是何缘故，身体有些不爽， 我且到门首散闷一番便了。"
        },
        {
          "character": "华忠",
          "type": "内白",
          "text": "吓走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华忠上。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "哎呀，公子。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "奶公为何这等光景？"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "哎呀，公子呀！只因为黄河漫口，老爷被参。这有老爷书信，公子观看便知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥看信。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "哎呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥昏去。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "公子醒来。"
        },
        {
          "character": "安骥",
          "type": "西皮导板",
          "text": "观书信吓的我魂飞天外，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥哭。"
        },
        {
          "character": "安骥",
          "type": "西皮摇板",
          "text": "问奶公有何策即早安排。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "只好变卖房产，另无别策。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "事在紧急，哪里去变卖。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "只好到亲友家中商议便了。"
        },
        {
          "character": "安骥",
          "type": "西皮摇板",
          "text": "我父无故遭危险， 思想不由自伤惨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥哭下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "白脸狼、黄傻狗同上。"
        },
        {
          "character": "白脸狼、黄傻狗",
          "type": "同笑",
          "text": "吓哈吓哈吓哈。 中国京剧戏考 《弓砚缘》【三本】 2"
        },
        {
          "character": "白脸狼",
          "type": "念",
          "text": "只恨八字差，"
        },
        {
          "character": "黄傻狗",
          "type": "念",
          "text": "命运也不佳。"
        },
        {
          "character": "白脸狼",
          "type": "念",
          "text": "跟下黄傻狗，"
        },
        {
          "character": "黄傻狗",
          "type": "念",
          "text": "赶脚作生涯。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "在下白脸狼。"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "在下，黄傻狗。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "伙计，咱们自从买了四匹牲口，指望赶脚度口，谁想京城咱们眼生，驮不上买 卖。这两天，闹得人也没有草料吃，牲口也没有饭吃啦，这可怎么好。"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "我说你饿糊涂啦。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "人没有草吃，牲口没有饭吃，这是怎么一句话。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "依你怎么讲。"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "人没有饭吃，牲口没有草料吃。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "是我饿糊涂了。你是什么主意？"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "我有主意，咱们不是四匹牲口么，卖他两匹，留他两匹驮脚，你瞧好不好。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "不好。"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "倘若有出门的买卖，咱们两条腿，跟着四条腿跑么？"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "依你怎么样。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "依着我，咱们拉着牲口，到大街吆喝，有长短的买卖都应着，你瞧好不好？"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "哎，这个主意不错。咱们拉着牲口上街。 吆喝吆喝。有雇驴的没有，烫屁股热驴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白脸狼、黄傻狗同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安骥、华忠同上。"
        },
        {
          "character": "安骥",
          "type": "西皮摇板",
          "text": "堪叹危急无所望， 人情如纸世炎凉。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "吓，奶公。我们这大一处房子，只押三千两银子，我爹爹官项，还缺少一半， 这便如何是好？"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "吓，公子。如今人情淡薄，且将这三千银子，押到任所，再作道理。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "我们怎样前去淮扬？"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "依老奴之见，雇上两匹脚程，待我将行李装在上面，我与公子乘骑，到也爽快。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "如此你雇脚程，待我后面拜辞舅母。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥下。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "待我上街看看可有牲口。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄傻狗、白脸狼同上。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "出来一早起连个打落的都没有。"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "伙计，买卖不在一天，就在一时。你瞧那个老头，直瞧咱们，我们问问。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "小哥你们可是赶脚的？"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "啊，不错，不错，是赶脚。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "可往淮扬去？"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "淮扬？"
        },
        {
          "character": "黄傻狗",
          "type": "白",
          "text": "去的，去的。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "我们讲讲价钱。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "不用讲价，伺候你好，多给酒钱。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "如此好说的。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "牲口人吃都吃你。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "那是自然。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "过桥过河你给钱。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "到了没有？ 中国京剧戏考 《弓砚缘》【三本】 3"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "到了。你们在此等候。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "是了。好大一所房子。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "有请公子。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥上。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "奶公，脚程可曾做妥？"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "现在门外。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "叫他们进来搭行李。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "是。哦，你进来搭行李。"
        },
        {
          "character": "黄傻狗、白脸狼",
          "type": "同白",
          "text": "搭行李也不是我们的事。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "你怎么啦，多给酒钱。"
        },
        {
          "character": "黄傻狗、白脸狼",
          "type": "同白",
          "text": "多给酒钱就行啦。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "好沉重的行李，八成有银子。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "少说话。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "装载好了，你请上牲口吧。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "奶公，你我速速赶行。"
        },
        {
          "character": "安骥",
          "type": "西皮摇板",
          "text": "这一时上了阳关道，"
        },
        {
          "character": "华忠",
          "type": "西皮摇板",
          "text": "意忙心急赶路遥。"
        },
        {
          "character": "安骥",
          "type": "西皮摇板",
          "text": "眼望淮扬何日到，"
        },
        {
          "character": "华忠",
          "type": "西皮摇板",
          "text": "但愿老爷祸早消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤上，趟马。"
        },
        {
          "character": "何玉凤",
          "type": "西皮散板",
          "text": "纪贼害父遭毒手， 不报父仇怎罢休。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "奴家何玉凤。爹爹何杞，在朝供职，自幼习就一身武艺，可恨那年羹尧为他儿 多文，与我爹爹求亲。我父不允，那贼怀恨在心，暗害我父，囚禁天牢，一命 身死。奴本当杀贼与我父报仇，奈因老母年迈，又无所靠，只得暂时忍耐，为 此将玉字拆为十三，改名十三妹。保定我母亲，远逃他乡，多蒙恩师邓九公收 留，将我母女，置在青云山上居住，倒也清静幽雅。不想我母亲染病在床，怎 奈我手内空乏，又不好对师父言讲，无奈只得下山，一来演习武艺。二来若得 机会，与父亲报仇。三来乘便寻些无义之财，也好与我母亲调治病症，就此马 上加鞭。"
        },
        {
          "character": "何玉凤",
          "type": "西皮摇板",
          "text": "红颜薄命多魔障， 爹爹一死心惆怅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安骥、华忠、白脸狼、黄傻狗同上。"
        },
        {
          "character": "安骥",
          "type": "西皮摇板",
          "text": "加鞭催马阳关上，"
        },
        {
          "character": "华忠",
          "type": "西皮摇板",
          "text": "心急一时到淮扬。"
        },
        {
          "character": "安骥",
          "type": "西皮摇板",
          "text": "路旁花柳无心望，"
        },
        {
          "character": "华忠",
          "type": "西皮摇板",
          "text": "眼花又觉心内慌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "华忠跌下。"
        },
        {
          "character": "白脸狼、黄傻狗",
          "type": "同白",
          "text": "老爷子，这是怎么了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "跌下"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "奶公可曾摔着。"
        },
        {
          "character": "华忠",
          "type": "白",
          "text": "心中难过。 中国京剧戏考 《弓砚缘》【三本】 4"
        },
        {
          "character": "白脸狼、黄傻狗",
          "type": "同白",
          "text": "公子。这个样咱们别走啦，我们扶着老爷子，前边有个长安店养息养息，明日 再走吧。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "你们好好的扶着，前边打店。"
        },
        {
          "character": "白脸狼、黄傻狗",
          "type": "同白",
          "text": "咱们扶着走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白脸狼、黄傻狗同扶华忠。"
        },
        {
          "character": "白脸狼、黄傻狗",
          "type": "同白",
          "text": "店家快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "来了。几位是投宿的，请到上房坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同进，同坐。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "店家，你们这里可有行医之家？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "大夫有的。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "烦你快去请来。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我去请大夫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家下。"
        },
        {
          "character": "白脸狼",
          "type": "白",
          "text": "伙计，你同公子扶着老爷子到炕上歇歇去，我去喂牲口去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "白脸狼上。"
        },
        {
          "character": "白脸狼",
          "type": "念",
          "text": "穷人要发财，天上降下来。"
        },
