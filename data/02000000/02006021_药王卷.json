{
  "script_id": "02006021",
  "title": "药王卷",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "孙思邈",
      "hangdang": "老生"
    },
    {
      "name": "唐太宗",
      "hangdang": "老生"
    },
    {
      "name": "唐皇后",
      "hangdang": "旦"
    },
    {
      "name": "徐勣",
      "hangdang": "老生"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    }
  ],
  "plot": "唐太宗皇后得病，徐勣奉旨往黄华山迎接孙思邈诊治。孙思邈到后，用金针灸，生下太子。太宗十分喜悦。\n拟封孙思邈官爵，孙思邈坚辞不受。赏赐金银，孙思邈亦不受。太宗因问官爵及金银，均不收，得非欲为王\n乎，孙思邈乃叩头谢恩。但因天无二日，国无二王。乃封孙思邈为药中之王。孙思邈乃同徒弟二人往二龙山\n修道云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐勣上。"
        },
        {
          "character": "徐勣",
          "type": "引子",
          "text": "善晓阴阳地理，果然妙算神机。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "奉子旨意到黄华，聘请思邈进国家。宫中去治娘娘病，但愿病好谢仙家。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "下官，英国公徐勣。是我奉圣旨，去到黄华山黄华洞，聘请孙思邈进京，与娘 娘调治病体。 人来！"
        },
        {
          "character": "龙套甲",
          "type": "内白",
          "text": "有！"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "车辆伺候。有请先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙套甲内允。〖牌子〗。孙思邈上，过场，众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、唐太宗同上。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "咦咦。"
        },
        {
          "character": "唐太宗",
          "type": "引子",
          "text": "驾坐皇宫院，心神不得安。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "咦咦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐皇后、宫女同暗入帐幔内。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "梓童病体如何？"
        },
        {
          "character": "唐皇后",
          "type": "内白",
          "text": "心内发慌。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "差先生徐勣聘请孙思邈怎么不见到来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启奏万岁：英国公午门候旨。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "宣他带领孙思邈进宫。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 万岁有旨：宣英国公带领孙思邈进宫。"
        },
        {
          "character": "徐勣、孙思邈",
          "type": "内同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、孙思邈同上。"
        },
        {
          "character": "徐勣、孙思邈",
          "type": "同白",
          "text": "（臣徐茂功）（山人孙思邈），叩见吾皇万岁，万岁，万万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "徐勣、孙思邈",
          "type": "同白",
          "text": "谢主隆恩。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "奉旨请得孙思邈，就是此人。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "孙先生。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人在。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "军师言道，先生善治诸般病症，可有仙方，好与娘娘治来。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人启奏万岁，赦臣死罪，启本奏上。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "赦尔无罪，有本奏来。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人与娘娘诊脉，调治病体。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "唔，你娘娘乃金枝玉叶，怎能诊脉。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人自幼曾学八步走线金针取病。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "原来如此。任凭先生。请。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "场上设桌诊脉走线。徐勣暗下。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "哎呀，怪道。"
        },
        {
          "character": "孙思邈",
          "type": "唱",
          "text": "山人候选黄华山， 黄花洞中苦修炼。 仙家妙法我知晓， 金针走线世无传。 在洞中参玄来打坐， 香风一阵到洞间。 早知道娘娘身得病， 金针一下雏龙现。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人启奏吾主：娘娘乃是喜脉。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "可用何药？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "不用药材，只用金针取药便能产下太子。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "依先生调治。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。孙思邈取针下。内小儿啼哭。"
        },
        {
          "character": "宫女",
          "type": "内白",
          "text": "启奏万岁：娘娘产生殿下。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "谢天谢地，宫女回避。"
        },
        {
          "character": "宫女",
          "type": "内白",
          "text": "是。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "我好喜哟。 内侍臣。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "传旨宣孙思邈金殿封官。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐太宗下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "有请孙先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "孙先生，你的针法倒好，一针就生下一位太子。你看咱家的牙疼怎么样？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "牙疼不是病，山人有一丸药，老公公含在口内。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "唔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监吃药。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "好了。"
        },
        {
          "character": "孙思邈",
          "type": "念",
          "text": "弹打无名鸟，药治有缘人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈、大太监同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、秦怀玉、杜如海、程咬金同上。〖点绛唇〗。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "七寸逍遥管，"
        },
        {
          "character": "秦怀玉",
          "type": "念",
          "text": "三分玉兔毫。"
        },
        {
          "character": "杜如海",
          "type": "念",
          "text": "落在文臣手，"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "安邦定天朝。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "下官徐勣。"
        },
        {
          "character": "秦怀玉",
          "type": "白",
          "text": "下官秦怀玉"
        },
        {
          "character": "杜如海",
          "type": "白",
          "text": "下官杜如海。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "下官程咬金。"
        },
        {
          "character": "徐勣、秦怀玉、杜如海、程咬金",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "圣主登殿，你我在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "咦咦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐太宗上。"
        },
        {
          "character": "唐太宗",
          "type": "引子",
          "text": "日出东来照万方，好似长江万里浪。"
        },
        {
          "character": "四太监",
          "type": "同白",
          "text": "咦咦！"
        },
        {
          "character": "唐太宗",
          "type": "念",
          "text": "金殿当头紫阁重，仙人掌上玉芙蓉。太平天子朝元日，五色云中驾六龙。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "寡人，大唐天子贞观在位。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐勣、秦怀玉、杜如海、程咬金同朝参。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "今有孙思邈进宫与娘娘治好病体，朕金殿封官。 内臣，宣孙思邈上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "领旨。 万岁有旨：宣孙思邈上殿。"
        },
        {
          "character": "孙思邈",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈上。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人孙思邈见驾，愿吾皇万岁，万岁，万万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "孙思邈，听朕加封。在宫中治好娘娘病体，朕封你医大夫。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人启奏我主，山野之人，淡泊名利，不愿在朝为官。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "朕赐黄金百两。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人不爱金银。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "封官不做，赐金不受，莫不成你要为王？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "谢主隆恩。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "唔，天无二日，民无二主。你若为王，将寡人置于何处？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "启奏万岁：臣不愿在人间为王，臣愿在药中为王，也就够了。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "朕封你药中为王，四大名山，先生挑拣。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "长安城外数百里，有一座二龙山，可以修行。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "朕赐交天翅、赭黄袍，那里修行去吧，不须再奏。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "谢主隆恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈下。"
        },
        {
          "character": "徐勣、秦怀玉、杜如海、程咬金",
          "type": "同白",
          "text": "臣等恭贺吾皇今生殿下，贺喜万岁，万岁，万万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "传光禄寺大摆筵宴，君臣同饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。安席。孙思邈上。"
        },
        {
          "character": "孙思邈",
          "type": "唱",
          "text": "是僧真是僧， 念念在心经。 进宫来治好了娘娘病， 药王乃是万岁封。 金殿上我的主大摆筵宴， 众国公只吃得喜笑欢腾。 劝你们少听人闲语， 一切当作耳旁风。 劝你们临头百事忍， 忍字为高是上乘。 劝你们休贪荣华富， 为官到头一场空。 劝你们看破红尘苦， 到不如随我去山中。 二龙山炼就仙家体， 学个嘉善矜不能。 列位不信抬头看， 睄一睄孙思邈这等威风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈下，尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "朝堂里封了孙思邈， 不由怒气锁眉头。 急忙忙上殿把本奏， 见了我主问根由。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "臣，尉迟恭见驾，愿吾皇万岁，万岁，万万岁！"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "皇兄有何本奏？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "臣启我主：孙思邈一针之法，救下娘娘，产生太子，为何赐他交天翅、赭黄袍， 药中为王，倘若满朝文武征夺回来，还将江山让与他人不成？"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "依皇兄怎样？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "依臣主意，将交天翅、赭黄袍追回交旨。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "任从皇兄吧。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "臣领旨。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "在金殿领了我主旨， 去到灞桥追先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。"
        },
        {
          "character": "唐太宗",
          "type": "白",
          "text": "满朝文武有事早奏，无事卷帘散朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈上。二弟子同随上。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "二弟子随我来。"
        },
        {
          "character": "孙思邈",
          "type": "唱",
          "text": "师徒们三人出阳关， 扭回头来望长安。 不见唐王金銮殿， 又不见合朝文武官。 进宫去治娘娘病， 唐王爷封我在金銮。 一品官儿我不做， 出家人不把名利贪。 人人都说做官好， 算来名利不如闲。 细想做官无好处， 倒不如深山把身安。 饥了来吃些松柏子， 渴了来饮些涧下水清泉。 热了来打把清凉伞， 冷了来山洞苦参玄。 冬日里到山前观虎斗， 春来时到林中听鸟喧。 正行走心内焦， 不觉眼跳耳发烧。 袖内一占知道了， 果然是尉迟恭赶我到灞桥。 叫声弟子不好了，"
        },
        {
          "character": "二弟子",
          "type": "同白",
          "text": "怎么样了？师父。"
        },
        {
          "character": "孙思邈",
          "type": "唱",
          "text": "尉迟恭赶我到灞桥。 交天翅，忙搬倒， 赭黄袍改换大红袍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈脱袍，坐桥。"
        },
        {
          "character": "孙思邈",
          "type": "唱",
          "text": "师徒们三人坐灞桥， 等候尉迟恭问根苗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵卒、尉迟恭同上。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "在金殿我把圣旨领， 前到灞桥追先生。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "咦，你看孙思邈出得朝来，头戴交天翅，身穿赭黄袍，某家赶到灞桥，交天翅 改作顺天翅。赭黄袍改作大红袍。出家人他有什么外科手段，赶他有什么好处， 众将摆马而回。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "老将军不必如此，山人早已看见了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "既已看见，下马何妨。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "是啊，下马何妨？老将军哪里征斗？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "哪个？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "前来追赶于你。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "追我山人何来？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吃你的药，好不生病。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "一句话不大要紧，又害我山人十余粒药丸。 童儿过来。打药箱取药一十八粒，付于老将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二弟子同允。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "呵老将军，这是丸药一十八粒，送于老将军。征东一十八年，不生疾病。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "多谢先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈、尉迟恭同笑。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "先生何往？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "老将军明知故问。在宫中治好娘娘病症，唐王大喜，封我药中为王，二龙高山 修其真阳。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "咦，先生，神仙还得神仙做，哪有凡人做神仙？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "老将军如若不信，敢与山人击掌？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "击掌为何？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人成不起正果，项上人头输于老将军。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "先生修成正果，我与你站班立帅。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "来，击掌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈、尉迟恭同击掌。"
        },
        {
          "character": "尉迟恭",
          "type": "唱",
          "text": "在灞桥与先生三击掌， 二龙高山修其正阳。 果然成仙得正果， 俺敬德与你站班有何妨。 叫儿郎打马回朝转， 前去交旨面君王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭、四兵卒同下。"
        },
        {
          "character": "孙思邈",
          "type": "唱",
          "text": "老儿此番上了当， 二龙山成仙实寻常。 二弟子随我把山上， 敬德老儿站班如反掌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈、二弟子同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四水卒引龙神同上。"
        },
        {
          "character": "龙神",
          "type": "念",
          "text": "水路行来人怕惊，旱路行来刮怪风。有人问我名和姓，我乃北海老苍龙。"
        },
        {
          "character": "龙神",
          "type": "白",
          "text": "俺，龙神是也。游山遇见毒风，将俺鼻孔吹得头疼脑晕，闻听孙思邈在宫中治 好娘娘病症，产生太子，封他药中为王。游遍四大名山，怎的还不见到来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大水卒上。"
        },
        {
          "character": "大水卒",
          "type": "白",
          "text": "报，启龙神知道，孙思邈过江。"
        },
        {
          "character": "龙神",
          "type": "白",
          "text": "知道了。退下。"
        },
        {
          "character": "大水卒",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大水卒下。"
        },
        {
          "character": "龙神",
          "type": "白",
          "text": "不免变作白衣秀士，调治我的病体。"
        },
        {
          "character": "龙神",
          "type": "唱",
          "text": "我本是北海老苍龙， 游山遇见恶毒风。 将身变作白衣士，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "龙神下，变作小生上。"
        },
        {
          "character": "小生",
          "type": "唱",
          "text": "万石山下等先生。"
        },
        {
          "character": "孙思邈",
          "type": "内西皮导板",
          "text": "出红尘入深山要学高道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈上。"
        },
        {
          "character": "孙思邈",
          "type": "西皮原板",
          "text": "孙思邈抬头瞧一瞧。 黎民百姓两旁站， 细听山人说根苗： 劝你们在家多行善， 作恶之人无下梢。 行善比那作恶好， 行善有金童玉女送过金桥。 作恶的人坐监牢， 恰似阴间走一遭。 哪怕他高官作阁老， 哪怕他驸马在当朝。 若是在阳间多霸道， 阴曹地府俱难逃。 这边瞧来那边瞧， 只见个书生点手把我招。 上前行礼忙问道， 相公唤我为哪条？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "小生",
          "type": "白",
          "text": "先生请了。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "相招吾道，有何见教？"
        },
        {
          "character": "小生",
          "type": "白",
          "text": "特求先生与我调治病症。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "伸过手来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "原来是老苍龙鼻孔受伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小生笑。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "为何耍笑山人。"
        },
        {
          "character": "小生",
          "type": "白",
          "text": "先生手段高明。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "原来龙君鼻孔受伤。"
        },
        {
          "character": "小生",
          "type": "白",
          "text": "真乃不错。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "老龙神，此地有一水洼，变出原形，山人调治。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。小生变，龙虎斗，探龙口，送药，龙神上。"
        },
        {
          "character": "龙神",
          "type": "白",
          "text": "先生请了。多谢先生妙手回春。未知现欲何往？"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "二龙山修其真阳。"
        },
        {
          "character": "龙神",
          "type": "白",
          "text": "原来如此。先生成起正果。俺与你打扫法座。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙思邈笑。孙思邈、龙神同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四力士、四金甲、四龙神、童子、龙虎引孙思邈同上。"
        },
        {
          "character": "孙思邈",
          "type": "唱",
          "text": "二月二来入法台， 思邈得道在古崖。 宫中治好娘娘病， 龙神与我扫花台。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人孙思邈。二龙山成其正果，前有尉迟公在灞桥与我击掌。 力士何在？"
        },
        {
          "character": "四力士",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "去至长安，将尉迟恭三魂取来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四力士同允，同下，四力士引尉迟恭同上。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "老将军，曾记得灞桥击掌之事么？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "某家曾记。有心站班立帅，唐王江山无人可保。"
        },
        {
          "character": "孙思邈",
          "type": "白",
          "text": "山人念你忠心保国，一时三刻送你还朝。"
        },
        {
          "character": "四力士",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四力士、尉迟恭同下。"
        },
        {
          "character": "孙思邈",
          "type": "念",
          "text": "二月二日坐法坛，思邈成功在此间。尉迟站班龙虎门，药王名儿万古传。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}