{
  "script_id": "02001005",
  "title": "风调雨顺",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "释迦牟尼",
      "hangdang": "外"
    },
    {
      "name": "文殊",
      "hangdang": "老生"
    },
    {
      "name": "普贤",
      "hangdang": "末"
    },
    {
      "name": "散花天女",
      "hangdang": "旦"
    },
    {
      "name": "韦护",
      "hangdang": "小生"
    }
  ],
  "plot": "释迦摩尼因圣朝国泰民安，仙岛均沾其惠，特令散花仙女，率众仙女往十州三岛，采奇花献瑞。采齐后，齐\n集极乐坛前，庆贺圣寿无疆。各仙女载歌载舞毕，释迦牟尼始令众仙女各归仙岛。",
  "notes": "全篇虽系歌功诵德之词，惟系由释迦领导。与普通之用玉帝、天官等者，稍有不同。殆系专为信佛者所作。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（韦护上，冲场。用锣鼓下。内吹打。四金刚同舞上，同摆排齐门户。内打吹。十天王、四侍者、释迦牟尼、"
        },
        {
          "character": null,
          "type": "text",
          "text": "文殊、普贤同上。）"
        },
        {
          "character": "释迦牟尼、文殊、普贤",
          "type": "同端正好",
          "text": "隐雷者，西方妙， 亘古来，隐雷者，端的是西方妙。 慧光明照，着那蓬茅， 看彤云遍绕。 红尘道， 正锐器空中落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。释迦牟尼、文殊、普贤同入座。"
        },
        {
          "character": "释迦牟尼",
          "type": "念",
          "text": "海裳春，卿云开处祥光袅。施慧眼，普天皆晓。"
        },
        {
          "character": "文殊",
          "type": "念",
          "text": "物阜与民安，海宇咸恩浩。"
        },
        {
          "character": "普贤",
          "type": "念",
          "text": "昨有散花仙女报道蓬岛奇葩开了，"
        },
        {
          "character": "释迦牟尼、文殊、普贤",
          "type": "同念",
          "text": "试取众花来。齐贺升平兆。"
        },
        {
          "character": "释迦牟尼",
          "type": "白",
          "text": "吾乃释迦摩尼佛是也。"
        },
        {
          "character": "文殊",
          "type": "白",
          "text": "吾乃文殊是也。"
        },
        {
          "character": "普贤",
          "type": "白",
          "text": "吾乃普贤是也。"
        },
        {
          "character": "释迦牟尼",
          "type": "白",
          "text": "方今圣朝德政，国泰民安。恩膏遍及，仙岛均沾其惠。好太平景象也。"
        },
        {
          "character": "十天王、四侍者",
          "type": "同白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "释迦牟尼",
          "type": "滚绣球",
          "text": "敬则敬，君家的恩波天样高， 爱则爱。贤甫弼匡扶贺圣朝。 更喜的四海内万民皆欢乐， 俺可也荷皇家似舜如尧。 因此上散花女，先来报， 报说海岛内众卉娇。 庆丰年，普天下雨顺风调。 这是那贤能文武甫政勤劳。 将得个太平物阜天心顺， 早则是国泰民安圣德昭。 极乐处，呈瑞逍遥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "散花天女上。"
        },
        {
          "character": "散花天女",
          "type": "念",
          "text": "天心永洽呈祥瑞，地发奇葩庆岁华。"
        },
        {
          "character": "散花天女",
          "type": "白",
          "text": "散花女参见佛祖。昨奉敕旨，命众仙女在十州三岛，各取奇花献瑞。今在极乐 坛外，候佛法旨。"
        },
        {
          "character": "释迦牟尼",
          "type": "白",
          "text": "好，就命尔率众仙女到极乐坛来者。"
        },
        {
          "character": "散花天女",
          "type": "白",
          "text": "领佛旨。 我佛法旨：命仙女们进坛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙女同上。"
        },
        {
          "character": "众仙女",
          "type": "同白",
          "text": "众仙女参见佛爷。"
        },
        {
          "character": "释迦牟尼",
          "type": "白",
          "text": "看——"
        },
        {
          "character": "释迦牟尼",
          "type": "念",
          "text": "花芳争艳现祯祥，预报皇家福运长。极乐坛前呈瑞色，万年千载暗生香。"
        },
        {
          "character": "释迦牟尼",
          "type": "白",
          "text": "尔等到坛前庆贺圣寿无疆，然后试呈详瑞。"
        },
        {
          "character": "众仙女",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙女同到台前叩首，同起舞。"
        },
        {
          "character": "散花仙女",
          "type": "泣颜回",
          "text": "四野瑞烟飘， 喜遇芳天晴晓。 奇葩呈瑞，蓬莱取得根苗， 天仙起舞，献君家，只有这春光好。 按新声，歌出阳春， 共与花芳斗巧。 今宵试舞贺皇朝， 端的是万紫千红围绕。 天长地久，喜沾玉露争娇， 风调雨顺，喜年丰物阜。 把琼浆倒， 这时节宛转悠扬，趁霓裳叠奏逍遥。 千秋岁，杏花妖， 间着梨花雪，一点点梅头青小。 瑞草灵芝，瑞草灵芝， 只闻得一阵阵馥馥香飘。 西方路，莲花道， 极乐坛，胜蓬岛。 丰韵真奇妙， 看花枝锦簇，玉貌生娇。"
        },
        {
          "character": "散花仙女",
          "type": "越恁好",
          "text": "紫云深处，紫云深处， 步徐徐长袖招。 结叮当环珮， 趁清风入衡茅。 暖融融香袅， 这步姗姗身低度一捻肢腰。 扑簌簌瑞彩远方尘， 贺圣明，群芳光耀。 羡良辰四季中， 惟有春光好。 向崖前试舞共呈佳兆。"
        },
        {
          "character": "散花仙女",
          "type": "红绣鞋",
          "text": "万花锦灿飘摇，飘摇， 轻盈态度堪描，堪描。 款金莲绣裙招， 香汗透湿鲛绡。 散花仙，撒琼瑶。"
        },
        {
          "character": "众仙女",
          "type": "同白",
          "text": "舞毕。"
        },
        {
          "character": "释迦牟尼",
          "type": "白",
          "text": "尔等各归仙岛，享洞里长春。"
        },
        {
          "character": "众仙女",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙女、散花仙女同下。"
        },
        {
          "character": "释迦牟尼",
          "type": "念",
          "text": "天花灿灿落红尘，"
        },
        {
          "character": "文殊",
          "type": "念",
          "text": "万紫千红满地春。"
        },
        {
          "character": "普贤",
          "type": "念",
          "text": "一曲新歌传盛世，"
        },
        {
          "character": "释迦牟尼、文殊、普贤",
          "type": "同念",
          "text": "年年岁岁贺皇恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "释迦牟尼、文殊、普贤同下。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "众天将",
          "type": "同红绣鞋",
          "text": "春明瑞霭花娇，花娇， 万民共沐恩高，恩高。 临碧落，下青霄， 太平时，好逍遥。 庆年丰，贺皇朝。"
        },
        {
          "character": "众天将",
          "type": "同尾声",
          "text": "风调雨顺，民安乐， 圣德无疆恩最高。 因此上万卉呈祥，"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "佛力昭白散花扬政，法象西垂，普天同享，庆遍地春辉。看此融和风景，正宜 巡视祯祥。 侍从们，各驾祥云，往中华走遭者。"
        },
        {
          "character": "众天将",
          "type": "二犯江儿水",
          "text": "森严法道，隐现处森严法道， 香风云外袅，看中华圣朝，圣德如膏。 到处儿风光好， 春雨润田苗，春风满沐娇。 瑞霭飘摇，瑞烟笼罩，早则见遍地红尘，锦绣绕。 恩波恁高，感穹苍恩波恁高。 兆民共乐，普天下军民共乐， 等闲间。瑞缤纷恩德高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众天将同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}