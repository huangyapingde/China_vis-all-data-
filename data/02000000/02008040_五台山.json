{
  "script_id": "02008040",
  "title": "五台山",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "杨延德",
      "hangdang": "小生"
    },
    {
      "name": "杨继业",
      "hangdang": "外"
    },
    {
      "name": "宋太宗",
      "hangdang": "生"
    },
    {
      "name": "赵德芳",
      "hangdang": "占旦"
    }
  ],
  "plot": "金沙滩之双龙会，杨大郎代替宋王赴会，被长枪刺死。杨二郎、杨三郎，均战死沙场。杨四郎下落不明。杨\n继业闻讯后，悲痛之情，自在意中。宋王除对死者一一追封，对生者如杨五郎、杨六郎、杨七郎，亦均加官\n晋禄。惟杨五郎看破红尘，不受官禄，决意在五台山出家。宋王及其父一再挽留，迄不动摇。宋王及杨继业\n不得已，勉强允准云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宋太宗、赵德芳、杨继业同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "宋太宗"
        },
        {
          "character": null,
          "type": "text",
          "text": "（念） 眼观旌旂起，"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "耳听好消息。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "老将军沙滩赴会，受惊了。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "主公但放宽心，众孩儿回来，便知明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德、杨延昭、杨延嗣同上。"
        },
        {
          "character": "杨继业",
          "type": "stage",
          "text": "杨延嗣"
        },
        {
          "character": "杨继业",
          "type": "同白",
          "text": "主公在上，臣等班师回来。"
        },
        {
          "character": "杨延德、杨延昭、宋太宗",
          "type": "白",
          "text": "有劳众位将军。 杨延嗣"
        },
        {
          "character": "杨延德、杨延昭、宋太宗",
          "type": "同白",
          "text": "爹爹在上，孩儿拜揖。"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "白",
          "text": "罢了。你等回来了？ 杨延嗣"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "同白",
          "text": "回来了。"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "白",
          "text": "大哥呢？"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "大哥长枪刺死。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "二哥呢？ 杨延嗣"
        },
        {
          "character": "杨继业",
          "type": "同白",
          "text": "二哥短剑身亡。"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "白",
          "text": "三哥呢？ 杨延嗣"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "同白",
          "text": "三哥马踏如泥。"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "白",
          "text": "四郎呢？ 杨延嗣"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "同白",
          "text": "四哥失落在番邦。"
        },
        {
          "character": "杨延德、杨延昭、杨继业",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "杨延德、杨延昭、杨延嗣",
          "type": "同白",
          "text": "失落番邦。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "听罢言来我的魂飘荡，"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀，苍天吓。"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "好一似利刃穿胸心痛伤。 二郎短剑把身亡。 四郎失落在番邦。"
        },
        {
          "character": "杨大郎长枪阵前丧、我三郎马踏为肉酱、宋太宗",
          "type": "唱",
          "text": "这一阵吓破了王的胆， 可叹杨家众儿男。 朕封你官上加职，职上加官。 杨继业"
        },
        {
          "character": "杨大郎长枪阵前丧、我三郎马踏为肉酱、宋太宗",
          "type": "唱",
          "text": "老臣亦非嫌官小， 保国忠良无下梢。"
        },
        {
          "character": "老将军休得把孤怨、宋太宗",
          "type": "唱",
          "text": "杨大郎身替孤王死， 朕封他龙华会上神。 朕封他花花太岁神。 朕封他逍遥快活神。 在生封官，死后封神。 杨继业"
        },
        {
          "character": "老将军休得把孤怨、宋太宗",
          "type": "唱",
          "text": "叩头三呼把龙恩谢， 回头来看见众儿郎。 杨七郎一旁泪汪汪。 忽然想起你们的娘。 手扯袍铠暗神伤： 回朝来还我人四双。 拿甚么交还你的娘？ 宋太宗"
        },
        {
          "character": "老将军休得把孤怨、宋太宗",
          "type": "唱",
          "text": "开言就把七郎叫， 五郎、六郎听朕封： 杨七郎朕封你火龙大将军。 封你在朝并肩王。 杨延德"
        },
        {
          "character": "老将军休得把孤怨、宋太宗",
          "type": "唱",
          "text": "杨五郎跪尘埃泪双流， 想起保国的忠良没有下场头。 二哥短剑把身亡； 四哥失落在番邦。 杀来杀去杀自家。 箭箭射的白莲花。 要把这金刀削头发。"
        },
        {
          "character": "老将军休得把孤怨、宋太宗",
          "type": "白",
          "text": "哎呀，万岁爷呀！"
        },
        {
          "character": "老将军休得把孤怨、宋太宗",
          "type": "唱",
          "text": "臣要到五台去出家。"
        },
        {
          "character": "杨二郎短剑伤了命、杨三郎马踏为肉酱、四郎失落无音信、六郎儿在旁双流泪、五郎哭的如酒醉、送出我父子府门外、天波府交与你八员将、弟兄们为国把命丧、杨六郎朕封你三关为总镇、五郎别的官儿不封你、大哥身替宋王死、三哥马踏为肉酱、今日杀来明日杀、刀刀割去心上肉、杨五郎解破其中意、在上面辞别万岁爷的驾、宋太宗",
          "type": "唱",
          "text": "五将军说的哪里话， 说甚么五台去出家。 忍心去了头上发。"
        },
        {
          "character": "你不念父母年高大、杨延德",
          "type": "唱",
          "text": "昔日里庄王求莲华， 相遇一女貌如花。 百雀寺里去出家。 到后来功德圆满作菩萨。 臣要到五台去出家。"
        },
        {
          "character": "她不愿皇宫招驸马、父王劝她心不转、为臣辞别了贤王驾、赵德芳",
          "type": "唱",
          "text": "五将军说话理太差， 说什么五台去出家。 保驾回朝把官加。 杨延德"
        },
        {
          "character": "她不愿皇宫招驸马、父王劝她心不转、为臣辞别了贤王驾、赵德芳",
          "type": "唱",
          "text": "打罢春来又复秋， 夕阳桥下水东流。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唱"
        },
        {
          "character": "她不愿皇宫招驸马、父王劝她心不转、为臣辞别了贤王驾、赵德芳",
          "type": "stage",
          "text": "杨继业"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唱"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": ""
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "唱"
        },
        {
          "character": "杨继业",
          "type": "stage",
          "text": "哪一个为国能到头？ 哎！ 儿要到五台去把禅修。 𠳶 ！ 说什么五台把禅修。 七郎他还是小娃娃。 回到火塘寨上作田家。 天波府哭坏了你的妈。 老将军舍了罢。 叫老臣难以割舍。 犹如那八只虎闯到边关。 死的死走的走三儿命还。 延德儿为甚么又去修禅？ 好比那风前烛瓦上霜能过几年？ 见过你老娘亲再了尘缘。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀，我的儿吓！ 杨延德"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "汉朝有个张子房， 求仙修道细参详。 忠臣良将无下场。 儿在五台渡慈航。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "长老上。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "五台山，众僧伺候了。"
        },
        {
          "character": "众僧人",
          "type": "内同白",
          "text": "哦。 宋太宗"
        },
        {
          "character": "众僧人",
          "type": "白",
          "text": "五台山寺主。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "贫僧在。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "听孤王旨意：五将军，乃是寡人的爱卿，五台山出家，孤王回朝，发库银五十 万，以为功课，金刀落发。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "贫僧领旨。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "五将军出家，受寡人一拜。 杨延嗣"
        },
        {
          "character": "宋太宗",
          "type": "同白",
          "text": "又道君不拜臣。"
        },
        {
          "character": "杨继业、杨延昭、赵德芳",
          "type": "白",
          "text": "小王也有一拜。"
        },
        {
          "character": "杨继业、杨延昭、杨延嗣",
          "type": "同白",
          "text": "大不拜小。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "延德儿，为父也有一拜。 杨延嗣"
        },
        {
          "character": "杨继业",
          "type": "同白",
          "text": "父不拜子。"
        },
        {
          "character": "杨延昭、杨继业",
          "type": "白",
          "text": "六郎，七郎，你们手足之情，多拜几拜。 杨延嗣"
        },
        {
          "character": "杨延昭、杨继业",
          "type": "同白",
          "text": "孩儿知道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、杨延嗣同拜。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "请驾回宫。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "摆驾。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "咦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋太宗、赵德芳同下。"
        },
        {
          "character": "杨延嗣",
          "type": "白",
          "text": "爹爹请转回，到天波府，拜上年迈娘亲，恕孩儿不孝之罪。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "五郎，延德，还记得你的娘亲？若是舍不得母亲，可随为父回去，到天波府， 见过你年迈母亲，再来出家也罢。"
        },
        {
          "character": "杨延嗣",
          "type": "白",
          "text": "自古道出家容易还家难，孩儿有万死之罪。"
        },
        {
          "character": "杨继业",
          "type": "哭",
          "text": "哎儿吓！"
        },
        {
          "character": "杨继业",
          "type": "唱",
          "text": "大海孤舟折了桅， 长大毛羽各自飞。"
        },
        {
          "character": "杨继业",
          "type": "三叫头",
          "text": "五郎！延德！哎，难得见的儿吓！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "六郎，七郎。"
        },
        {
          "character": "断线风筝不得回、燕子衔泥空费力、杨延昭、杨延嗣",
          "type": "同白",
          "text": "爹爹。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "随为父这里来。 杨延嗣"
        },
        {
          "character": "杨继业",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "杨延昭、杨继业",
          "type": "白",
          "text": "哎哎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}