{
  "script_id": "02006025",
  "title": "安天会",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李靖",
      "hangdang": "净"
    },
    {
      "name": "哪吒",
      "hangdang": "武生"
    },
    {
      "name": "杨戬",
      "hangdang": "武生"
    },
    {
      "name": "孙悟空",
      "hangdang": "武生"
    }
  ],
  "plot": "托塔天王李靖奉御旨至花果山水帘洞，擒拿妖猴。天兵天将四面埋伏，并令二郎神杨戬为总先锋。一场鏖战，\n最后将妖猴擒拿，带领至天门请旨。",
  "notes": "按此剧与《闹天宫》最后之一场，大同小异。但单独上演者颇多，故一并收存。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "哪吒上，跳。众神引李靖同上。"
        },
        {
          "character": "李靖",
          "type": "点绛唇",
          "text": "十万熊罴，星辰齐聚，遵天旨，歼灭渠魁，扫尽如斯辈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李靖上高座。"
        },
        {
          "character": "李靖",
          "type": "念",
          "text": "大将桓桓出玉庭，雄兵十万列连营。天罗地网安排定，管取妖猴一命倾。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "某，托塔天王李靖是也。奉御旨前往花果山水帘洞擒拿妖猴。 哪吒！"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "吩咐擂鼓三通，诸天将上台听点。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "得令。 呔！父王有令，擂鼓三通，诸天将上台听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内擂鼓。众天将同上，见礼。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "众天将打躬。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "诸天将，"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "俺奉御旨，率领尔等擒拿妖猴。分班听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众天将同允，分侍。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "俺这里神通奇异， 妖气不与瑞光沸。 俺这里祥天霭霭， 他那里，他那里冷气凄凄。 俺这里一般雄心多智慧， 他那里千般魔力逞机宜。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "马天君！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天君允。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你那里群星呵！"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "在山前迎战施法力，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天君允，下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "赵天君！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵天君允。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你领计都星呵！"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "在山后运动神机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵天君允，下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "温天君！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "温天君允。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你领丧门吊客呵！"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "恁在那山左接战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "温天君允，下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "刘天君！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘天君允。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你领天罡、地煞呵！"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "在山右将他的魂魄追随。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘天君允，下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "二十八宿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四神同允。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "恁将他巢穴倾倒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四神同允，同下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "十二元辰！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四神同允。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "恁可也紧守着罗网周围。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四神同允，同下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "二郎神！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨戬允。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "命你为总先锋，今日之事，全仗于汝。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "遇妖猴紧追紧赶， 休得要半步相离。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨戬下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "哪吒！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "哪吒允。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你领东南西北四渎五岳以为救应。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "必须要齐心努力， 必须要歼灭渠魁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "哪吒允，下。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "俺这里天兵天将施威武， 他那里猴卒妖兵各逞威，只杀得星斗依稀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神同杀。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "好恶妖猴也！"
        },
        {
          "character": "李靖",
          "type": "油葫芦",
          "text": "俺只见雄威赳赳勇如罴， 不枉他，不枉他号天齐。 只见他往来南北，摧退东西， 他那里奔驰一似如儿戏。 俺这里神通广大，恁可也难逃避， 俺与他一会价辨个高低。 昏惨惨四野征云起， 闹垓垓几处的军声沸，恰更似平地上起个轰雷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神同杀。"
        },
        {
          "character": "李靖",
          "type": "天下乐",
          "text": "只见水怪山魈尽挂铁衣， 摇也么旗也却也助军威。 可笑那无知物，恁好迷痴， 这壁厢吹觱篥，那壁厢擂鼓皮。 他怎当俺法力大， 可也尽披靡披靡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神同杀。"
        },
        {
          "character": "李靖",
          "type": "哪吒令",
          "text": "小妖们遍岭沿提奔腾一似飞。 有的妖把角吹， 有的妖把鼓擂。 老妖们头顶盔， 小妖们并着腿。 这山坡聚几堆， 那山坡聚几堆。 笑他们闹嚷嚷， 意欲何为，意欲何为？"
        },
        {
          "character": "李靖",
          "type": "鹊踏枝",
          "text": "满山头天雾黑， 四下里，四下里刀枪密。 眼跟前把暗天昏， 耳边厢鬼哭神啼。 蓦地里山崩海沸， 只杀得紫微垣，斗转星移。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神同杀。"
        },
        {
          "character": "李靖",
          "type": "胜葫芦",
          "text": "这妖王法力果精奇， 不能够把他欺。 又见他狰狞相貌多奇异， 他只是三头六臂铜筋铁骨，吼一声恰似野霹雳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神同列阵。"
        },
        {
          "character": "李靖",
          "type": "幺篇",
          "text": "俺只见六丁六甲显神威， 四面列层围。 恁就是三头六臂休轻敌， 他这里持剑抡枪各逞威。 一对对紧相随， 一对对紧相随。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空、二郎神同入阵。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "杀了半日，并无个对手。你且通个名儿上来。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "妖猴听者。吾乃："
        },
        {
          "character": "杨戬",
          "type": "念",
          "text": "清源妙道二郎神，法力威灵天地闻。玉殿驰名为上将，今朝擒你泼猴狲。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你这些话只好哄别人，孙爷爷跟前岂是你卖弄得的？你且站稳了，听我道来："
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "天地才分育吾身，参详学道拜昆仑。神通广大超三界，要上灵霄为帝君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神赶小猴绕场同下。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "妖猴！你看你那些子孙都被我擒去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空看。啸天犬咬孙悟空，哪吒套。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "罢了，罢了。杀了半日，吃了狗的亏。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "妖猴已擒。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "诸天将，玉帝有旨，将他带领天门，请旨定夺。"
        },
        {
          "character": "李靖",
          "type": "大尾声",
          "text": "恁只夸神通广，怎生法力精， 准备着斩仙榜上留个名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}