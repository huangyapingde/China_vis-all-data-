{
  "script_id": "02007028",
  "title": "目莲记",
  "alias": [
    "罗卜经商"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "罗卜",
      "hangdang": "生"
    },
    {
      "name": "刘青提",
      "hangdang": "老旦"
    },
    {
      "name": "益利",
      "hangdang": "末"
    },
    {
      "name": "金奴",
      "hangdang": "小旦"
    }
  ],
  "plot": "罗卜姓傅，目莲乃其出家后之名。其母刘青提，因吃斋念佛反丧其夫，乃听其兄之言，开荤破戒，以娱晚年。\n但因罗卜，遵从其父遗嘱，信佛甚笃。不但不肯破戒，反劝其母依旧信佛。刘青提不得已，佯称济贫念佛，\n费用浩繁，恐日后无以为继。乃命仆人益利，帮同罗卜出外经商。罗卜虽恪于母命，不得不束装就道，但\n心中则极为忧戚。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗卜上。"
        },
        {
          "character": "罗卜",
          "type": "一剪梅",
          "text": "灵椿一梦赴南柯。 朝泪滂沱，暮泪滂沱。 临终嘱咐事如何。 委念弥陀，遵年弥陀。"
        },
        {
          "character": "罗卜",
          "type": "念",
          "text": "步行灵椿丧九泉，萧萧风木恨无边。孤儿欲绍先人志，念佛看经与坐禅。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "罗卜。自从父亲丧后，只守丧柩，未曾念经。今在佛前，添上炉香，念佛则个。"
        },
        {
          "character": "罗卜",
          "type": "驻马听",
          "text": "香满金炉。 坐拥团团一草蒲。 念几句阿弥陀佛， 修喇娑婆三昧哆哪。 木鱼敲动万灵扶。 真经念处仙护。 灭障消除， 灭障消除。 生门便是菩提路， 生门便是菩提路。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金奴、刘青提同上。"
        },
        {
          "character": "刘青提",
          "type": "驻马听",
          "text": "痛念儿夫。 血泪流残两眼枯。 可怜我形容憔瘦， 筋力衰微，鬓发消疏。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "昨听兄弟之言，劝儿开荤，依从便罢，若不依从，遣他在外经商。 金奴，"
        },
        {
          "character": "金奴",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "小官人佛堂看经，随我前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘青提看。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "我儿，你在此做什么？"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "在此看经。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "儿呀，再不要念经了。"
        },
        {
          "character": "刘青提",
          "type": "唱",
          "text": "想你爹爹在日，洗目焚香， 调念多少经典，赈济多少贫寒。 因甚的未满六旬身丧， 中国京剧戏考 《目莲记》【头本】 2 可见得看经无用， 赈济无功了。 儿，那阴阳神鬼，无些踪影， 倒不如肥甘滋味易菜蔬。 莫使我桑榆暮景成虚度。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "老娘休出此言。"
        },
        {
          "character": "刘青提",
          "type": "唱",
          "text": "儿呀，你未能事人，焉能事鬼。 不用踌躇，不用踌躇。 那秦皇汉武成差误。 不要听他。"
        },
        {
          "character": "罗卜",
          "type": "唱",
          "text": "我父将终， 亲写遗言来嘱咐。 叫儿看经念佛。 戒酒除荤，吃斋把素。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "那都是迂谈。不要听他。"
        },
        {
          "character": "罗卜",
          "type": "唱",
          "text": "休言我父多迂。 娘儿一体承遗嘱。 父有嘉谟，父有嘉谟， 三年无改于其父。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "儿但知三年无改，岂不闻如其道，终身无改可也。如其非道，何待三年？"
        },
        {
          "character": "刘青提",
          "type": "唱",
          "text": "你父敬浮屠。 那佛如何不救助。 我欲待暂开荤酒， 趁此余年，且自欢娱。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "老娘。佛像在堂，休出此言。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "儿呀，娘立心已定，说下断头话来。诸佛神像在上。"
        },
        {
          "character": "刘青提",
          "type": "唱",
          "text": "若要我吃斋把素似当初。 除非是铁树开花，扬子江心生莲藕。 儿呀你何必多忧，你何必多忧。 娘亲作者娘亲受。"
        },
        {
          "character": "罗卜",
          "type": "黄莺儿",
          "text": "听说泪交流。 不由人生怨尤。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "不知母亲听信哪个谗言，改变心肠。是了。舅爷到此，一定是舅爷的言词。舅 爷既念我母手足之情，合将好言劝解才是。"
        },
        {
          "character": "罗卜",
          "type": "黄莺儿",
          "text": "为何劝娘开荤酒。 爹会嘱咐，娘会发咒。 今日开了荤酒呵， 怕神天察，如何救。 苦衷容儿剖。 休学那郗后。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "你起来，劝娘休学郗后之言，如何解说？"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "昔日梁武帝皇后郗氏，不信神明，死后变为蟒蛇。武帝代为忏悔，方才得还人 身。老娘请自详省。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "武帝既能度其妻，吾儿必能度其母。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "老娘还当见贤思齐，因何学不贤之辈？"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "原来我儿志不可。方才所言，亦非劝你开荤。你父亡过，恐你道心不定，特来 试你如何。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "如此，多谢老娘。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "还有一事，母子商量。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "有何事情？"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "只今济僧布施，费用浩大。你可出外做些买卖，生些利息。则前功可继，后用 无穷。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "禀告老娘。孩儿幼依膝下，不惯经商，怎生去得？ 中国京剧戏考 《目莲记》【头本】 3"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "你若去，我着益利作伴，料也无妨。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "孩儿舍不得老娘。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "我今生幸未衰，你正当勇往向前不可达拗。 益利何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "益利上。"
        },
        {
          "character": "益利",
          "type": "念",
          "text": "佛殿烧香犹未毕，高堂有唤又忙来。"
        },
        {
          "character": "益利",
          "type": "白",
          "text": "禀安人有何使命？"
        },
        {
          "character": "刘青提",
          "type": "黄莺儿",
          "text": "佛事虑难周， 我竟遣官人出外州。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "因为时年不丰，求济甚多，唯恐后不应前，令与东人远行贸易，觅些利来，已 为长途之计。"
        },
        {
          "character": "刘青提",
          "type": "黄莺儿",
          "text": "这生财有道方能久。 你把行囊早收，同伊远游。 经营不落他人后。 愿来秋腰缠万贯，得意早回头。"
        },
        {
          "character": "益利",
          "type": "白",
          "text": "老安人年老在堂，小官人经营不惯。伏望思忖，莫遣远行。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "我立心已定谁敢违。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "益利，安人发怒，少不得顺从前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "益利允。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "焚起香来。待我辞别神圣。"
        },
        {
          "character": "罗卜",
          "type": "泣颜回",
          "text": "辞圣离故里， 亲命怎敢辞推。 经商贸易， 家庭事仗神佑持。 程途迢遥， 叹此行难定归来日。 在异乡平安觅利， 但愿得无事无非。 一旦别慈帏， 不由人心不动悲。 况我无兄无弟亲衰老， 谁与扶持，心中思忆。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "思忆何事？"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "孩儿、益利在家，僧济贫，照例实行。孩儿、益利远去他乡，犹恐违却父志， 荒废前功。"
        },
        {
          "character": "罗卜",
          "type": "泣颜回",
          "text": "愿老娘遵守着一念慈悲。 散金资普济僧尼， 诵宝礼念阿弥。"
        },
        {
          "character": "刘青提",
          "type": "泣颜回",
          "text": "叮咛我娇儿， 宽心前去， 不用忧疑。 济僧布施， 娘在家依旧一一施为。 心中忧虑。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "老娘忧虑何来？"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "我儿孝心如是，去到他乡，必然牵挂老娘。 金奴看针线过来。 儿揭起裹襟，待娘缝上几针。早晚见此针线，我儿近远离家，见线如见母，不 用苦忧思。儿今此去，娘心忧虑。"
        },
        {
          "character": "刘青提",
          "type": "泣颜回",
          "text": "怕你在途中早晚有谁调理， 益利你须当仔细。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "小官人年幼，自幼未曾远行。你是年长之人，能知异乡风景，此去逢船过渡， 需要小心着意。 中国京剧戏考 《目莲记》【头本】 4"
        },
        {
          "character": "刘青提",
          "type": "泣颜回",
          "text": "在旅店安歇，迟行早宿， 一路与他相伴同行， 不离了左右。 益利，你谨记我的言词， 你须仔细。 罢了，我的儿， 老娘只生你一人。 若不为着利息， 焉肯舍得你远行， 与益利去到他乡，年节之时， 倘有微资，须念我膝下无儿， 打叠行囊早回程，是必不可迟滞。 儿免娘亲倚定门儿，数着归期。"
        },
        {
          "character": "益利",
          "type": "唱",
          "text": "半担行李受驱驰。 餐风宿水，岂敢推辞。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "好生服侍东人。"
        },
        {
          "character": "益利",
          "type": "唱",
          "text": "奉东人自当协力。 明年捆带儿归。 心中暗疑，员外在日， 要安人吃斋把素，念佛看经。 今日遣子往外经商， 其间必有什么缘故， 必有什么缘故， 好教我心中暗疑虑。 安人心口相违背。 若得他广布阴功。 不枉了远涉天。"
        },
        {
          "character": "益利",
          "type": "尾声",
          "text": "匆匆拜别登程去， 唯愿康健无危。"
        },
        {
          "character": "刘青提",
          "type": "尾声",
          "text": "更愿你钱神子母， 得意早回归。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗卜、刘青提同下。"
        },
        {
          "character": "刘青提",
          "type": "白",
          "text": "金奴，我见小官人去得可怜，是我心中疼痛起来。"
        },
        {
          "character": "金奴",
          "type": "白",
          "text": "有益利相伴，安人放心。"
        },
        {
          "character": "刘青提",
          "type": "尾声",
          "text": "自古人生多别离。 娇儿一去好伤悲。 儿你明朝回首家山远。 一片白云空自飞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘青提、金奴同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "罗卜",
          "type": "内步步娇",
          "text": "野店鸡鸣天方晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗卜上，益利随上。"
        },
        {
          "character": "罗卜",
          "type": "步步娇",
          "text": "人就长安道。 重露湿衣袍。 烟瘴全收，火轮飞照。 回首白云高。 珠泪临风落，珠泪临风落。"
        },
        {
          "character": "罗卜",
          "type": "念",
          "text": "夏日苦炎热，早行须趁凉。"
        },
        {
          "character": "益利",
          "type": "念",
          "text": "竹清风渐爽，荷放露生香。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "益利。"
        },
        {
          "character": "益利",
          "type": "白",
          "text": "小官人。 中国京剧戏考 《目莲记》【头本】 5"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "我奉母亲严命，往外经营。身虽离了家门，心则常在膝下。思念不已，如何是 好？"
        },
        {
          "character": "益利",
          "type": "白",
          "text": "呵小官人。你我奉老安人之命，此去贸易，觅利便归。身在途中，休要嗟叹。 天色尚早，趱行则个。"
        },
        {
          "character": "罗卜",
          "type": "白",
          "text": "言之有理。"
        },
        {
          "character": "罗卜",
          "type": "新水令",
          "text": "绿荫冉冉路漫漫。 听枝头黄鹂声唤。 榴花熏眼媚， 梅子溅牙酸。 回首家山， 惹起我愁无限。"
        },
        {
          "character": "罗卜",
          "type": "驻马听",
          "text": "椿树摧残，椿树摧残。 干无能心自闲。 花景晚。 经商远别意何安。 好叫我恨犹露草肠寸断。 似随风絮飞缭乱。 心自顽，心自顽， 举目把孤云盼。 举目把孤云盼。"
        },
        {
          "character": "益利",
          "type": "川拨掉",
          "text": "盼着那云停处， 心与俱远。 云散后， 魂犹未返。 亲舍远，枉自追思， 客途遥，客途遥， 空成嗟叹。 论世亲孝道多端。 今日里顺亲心抛弃家园。 又何须在膝下承欢。 况分离有日团圆，有日团圆。"
        },
        {
          "character": "罗卜",
          "type": "雁儿落",
          "text": "须则是有日团圆。 苦无奈般伤感。 水带离愁向我悲， 山牵别恨连肠断。"
        },
        {
          "character": "罗卜",
          "type": "得胜令",
          "text": "伤情对景有千般。 如何能，如何能把程途趱。 见山僧竹林下，避暑盘。 正是朝臣待漏五更寒。 铁甲将军夜渡关。 山寺日高僧未起， 算来名利不如闲。 我怎学得那山僧， 那山僧般清闲。 见渔翁柳荫下，执着丝杆。 那渔翁一条丝线，一根杆， 名不贪来利不贪。 醉卧沙堤唤不醒， 江山常在梦中看。 我怎学得那渔翁， 那渔翁般疏散，般疏散。 见牧童牛背上短笛腔翻。 问余何事碧山， 中国京剧戏考 《目莲记》【头本】 6 笑而不答心自闲。 桃花流水杳然去， 别有天地非人间。 我怎学得那牧童恁般逍然，恁般逍然。"
        },
        {
          "character": "益利",
          "type": "挂玉钩",
          "text": "论人生寄在寰。 都只为利索名牵。 受馁寒， 谁能解破这机关恰便似超凡脱俗神仙伴。"
        },
        {
          "character": "罗卜",
          "type": "挂玉钩",
