        {
          "character": "宋江",
          "type": "念",
          "text": "昔日郓城为公人，结交金兰似胞生。梁山尊我为寨主，替天行道宋公明。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "某，宋江。只因李逵误杀白杜山，他有一男一女，名曰天章、月娥。有万夫不 敌之勇。每日觅访豪杰，操练壮丁，意欲破我山寨。亦曾命燕青前去，未见回 报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青上。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "燕青",
          "type": "念",
          "text": "打听风波事，回禀大哥知。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "报，燕青告进。大哥在上，小弟交令。 众位哥哥。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "贤弟回来了？"
