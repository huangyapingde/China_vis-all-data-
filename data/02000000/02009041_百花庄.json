          "character": "宋江",
          "type": "白",
          "text": "打听百花庄一事如何？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "小弟打听白天章他兄妹，真个有万夫不当之勇。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "小弟与他妹子交手几合，那贼呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急三枪〗。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "大哥传下将令，下山生擒哪。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "不可如此。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "大哥命众家哥弟暂时退忠堂，小弟自有计议。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众家兄弟退堂。"
        },
        {
          "character": "众人",
