{
  "script_id": "02009041",
  "title": "百花庄",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "白天章",
      "hangdang": "小生"
    },
    {
      "name": "白月娥",
      "hangdang": "旦"
    },
    {
      "name": "燕青",
      "hangdang": "武生"
    },
    {
      "name": "李逵",
      "hangdang": "净"
    },
    {
      "name": "时迁",
      "hangdang": "武丑"
    },
    {
      "name": "院子",
      "hangdang": "丑"
    }
  ],
  "plot": "白天章之父告老还乡，路过梁山，被李逵打死。白天章及其妹白月娥为报父仇，占据百花庄，操演人马并摆\n下擂台，招揽各地英雄豪杰。宋江闻知为除后患计，乃派燕青、石秀、张顺、施恩、郑天寿等往打擂台。李\n逵因宋江未曾委派，乃私自前往。及至百花庄藉打擂为名，一拥而上，将白天章及其妹白月娥生擒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "燕青、石秀、张顺、施恩、郑天寿同上。"
        },
        {
          "character": "燕青",
          "type": "念",
          "text": "少小英雄本自强，众家豪杰立两厢，奉命打听军情事，扮作乡民探村庄。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "众家哥弟请了。"
        },
        {
          "character": "石秀、张顺、施恩、郑天寿",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你我奉了大哥之命，打听百花庄，闻知他兄妹二人智勇无敌。为此前来探彼虚 实。众家哥弟！"
        },
        {
          "character": "石秀、张顺、施恩、郑天寿",
          "type": "同白",
          "text": "燕小哥。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "你们在村口扎住，待小弟一人前去探庄者。"
        },
        {
          "character": "石秀、张顺、施恩、郑天寿",
          "type": "同白",
          "text": "请哪！"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "燕青",
          "type": "西皮导板",
          "text": "奉命下山探军事，"
        },
        {
          "character": "燕青",
          "type": "唱",
          "text": "众家哥弟听原因。 此一番须要当稳式， 看他武艺能不能。 若有风声切莫惊， 向手拿住休放轻。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "白天章上。"
        },
        {
          "character": "白天章",
          "type": "引子",
          "text": "艳阳天气雨乍晴，春日融融晚风轻。"
        },
        {
          "character": "白天章",
          "type": "念",
          "text": "自幼生来情性刚，懒读诗书演刀枪。吾父朝中为宰相，赫赫威名四海扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子暗上。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "俺，白天章。吾父杜山，在宋主驾前为臣。官拜东阁大学士。告职还乡，路过 梁山。贼寇打劫金帛。父亲身丧。怀恨无比，意欲报仇。怎奈缺少勇士，妹子 月娥，尚未婚配，这也不言。今乃艳阳天气，不免到郊外闲游一回。 来，"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "传家将出来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "大爷吩咐，众家将出来。"
        },
        {
          "character": "众家将",
          "type": "内同白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众家将同上。"
        },
        {
          "character": "众家将",
          "type": "同念",
          "text": "每日府中无别事，惯习拳棒耍刀枪。"
        },
        {
          "character": "众家将",
          "type": "同白",
          "text": "大爷在上，家将叩头。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "众家将",
          "type": "同白",
          "text": "大爷呼唤，有何吩咐？"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "今乃艳阳天气，你我各带器械往郊外打猎一番。"
        },
        {
          "character": "众家将",
          "type": "同白",
          "text": "我等跟随。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "来，带马伺候。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "白天章",
          "type": "唱",
          "text": "四季春光野草花， 绿柏苍松鸟喧哗。 树林层层遮山面， 一所平场真堪夸。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "来此平场之地。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "此地平坦，正好耍拳。家将们，一同耍来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家将同打拳，同下，同上，同打拳。"
        },
        {
          "character": "白天章",
          "type": "唱",
          "text": "太祖立志气轩昂，"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "哪个来？"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "俺来。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "招打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白天章、大家将同打拳。"
        },
        {
          "character": "院子、三家将",
          "type": "同白",
          "text": "哎呀！好厉害呀！"
        },
        {
          "character": "白天章",
          "type": "唱",
          "text": "三拳进步鬼神忙。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "白马，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白天章打。"
        },
        {
          "character": "白天章",
          "type": "唱",
          "text": "白马悬蹄却乱闯， 乌鸦扑地逞豪强。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "青龙，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白天章打。"
        },
        {
          "character": "白天章",
          "type": "唱",
          "text": "青龙出洞人难挡，"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "二郎，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白天章打。"
        },
        {
          "character": "白天章",
          "type": "唱",
          "text": "二郎担山赶太阳。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "狮象，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白天章打。"
        },
        {
          "character": "白天章",
          "type": "唱",
          "text": "狮象把口龙虎门， 猫儿打鼠望月亮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白天章收。"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "招打！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "伙计，你又是这一下了。呀！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "呀呀！不瞒你说，我上下的劲，都在这腰眼上。"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "我不信。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "你不信，你来试试看。"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "咱家。"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "好劲。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "再来呀。"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "哎呀！他妈的松了劲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内虎声。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎形上。白天章打虎。〖风入松〗。白天章三拳打虎。"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "得了老虎，是大爷打死了。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "伙计，你拿着拿着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子三打。"
        },
        {
          "character": "大家将",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "伙计，我喜欢打死虎。"
        },
        {
          "character": "白天章",
          "type": "白",
          "text": "家将们，将虎抬回府去。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊。咱们走哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "白月娥上。"
        },
        {
          "character": "白月娥",
          "type": "引子",
          "text": "闺阁针挑绣，香风上高楼。"
        },
        {
          "character": "白月娥",
          "type": "念",
          "text": "二八佳人上高楼，意懒十二挂银钩。休笑闺阁无志量，要效孙吴法力谋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟暗同上。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "奴家白月娥，兄长天章。只因吾父被梁山贼寇所伤，我同兄长每日在家习练拳 棒，与我父报仇。今仍艳阳佳节，不免转至花园，游戏一番。 众丫鬟！"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "伺候小姐。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "随我到花园去者。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "白月娥",
          "type": "记吾乡",
          "text": "日暖融融， 山花映水红。 看秋高气爽黄莺弄， 粉蝶双双游花园，误入蓬莱洞。 人在画图中， 风景堪依用。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "来此花园。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "上面飞的什么？"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "蝶，蝴蝶。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "将它打下，多者有赏，少者罚跪。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "四丫鬟",
          "type": "同唱",
          "text": "人声齐喝彩，春光艳阳。 正人意徘徊，花柳浓妆。 西园堪赏，参差依没笙簧。 桃花烂漫游客醉， 院宇深沉春昼长。 见十几个粉蝶儿巧妆， 一个映日寻芳， 一个杨柳枝头号晓露。 一个杏花蕊上吸清风， 一个困歇在湖山上。 一个迎风竹径， 一个戏水在池塘。 一个受尽风流相， 一个逐定卖花郎。 一个又被狂童唬得慌。 一个在花上偷眼望。 一个扇粉寻便当。 一个绿杨枝上儿， 金莺不敢轻狂。 一个恋名园桃杏芳， 一个怕晓天停夜凉。 一个要寻周庄梦， 一个戏春风花草香。 一个不成双。 轻轻儿来展放。 背转身飞过了宋家庄。"
        },
        {
          "character": "四丫鬟",
          "type": "白",
          "text": "哈哈哈小姐，扑蝶已毕。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "好，个个有赏。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "谢姑娘。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "将拳演来。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟同演拳。白月娥边打拳便唱。"
        },
        {
          "character": "白月娥",
          "type": "唱",
          "text": "太祖爷力猛强， 红拳便通了小金枪。 进步匆忙， 立时轩昂。 打一个兔儿望月精神爽， 举手赛卞庄， 进步效刘邦， 打个美女懒梳妆。 休笑俺闺中女无志量， 从天降，女姣娃把名扬。 来来来，这的是英雄汉，男儿上。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "小姐我们打完了。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "将枪演来。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "耍枪玩耍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟同下。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "呔，你们演枪上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丫鬟同上，同操枪。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "操枪已毕。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "好。可知破法？"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "我们不知。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "待我教导于你们。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "白月娥",
          "type": "唱",
          "text": "唐朝有个小罗成，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白月娥破打。"
        },
        {
          "character": "白月娥",
          "type": "唱",
          "text": "落地梅花谁不惊， 小金破开连环阵。 万人约敌把功成。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白月娥破打。燕青上。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "耍的好拳，使的好枪。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "哪里壮士口言好拳，莫非会家？ 丫鬟们，"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "请那壮士进来。"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "是。 哟，壮士。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "四丫鬟",
          "type": "同白",
          "text": "我家小姐请你进去。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "有劳了。 啊小姐，这厢有礼了。"
        },
        {
          "character": "白月娥",
          "type": "白",
          "text": "还礼。请问壮士，交手一合。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "承小姐宽让。"
        },
        {
          "character": "白月娥、燕青",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白月娥、燕青同比拳。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "好的，改日再来领教。"
        },
        {
          "character": "白月娥、燕青",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
