  "plot": "",
  "notes": "按此剧与《刘高抢亲》之故事，完全相同，均系出于《五代残唐演义》，特内容穿插不同，彼此重点各异，\n故一并印存，而剧情从略。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四梁卒、四梁将同上。"
        },
        {
          "character": "四梁卒、四梁将",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱义、朱彪同上。"
        },
        {
          "character": "朱义",
          "type": "念",
          "text": "领了兄王命。"
        },
        {
          "character": "朱彪",
          "type": "念",
          "text": "翌州去抬亲。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "孤家朱义。"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "小王朱彪。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "贤侄，今日保你翌州抬亲，花轿可曾齐备？"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "众将官，保定花轿，放炮拔营。"
        },
        {
          "character": "四梁卒、四梁将",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗，〖点绛唇〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐大人上。"
        },
        {
          "character": "徐大人",
          "type": "引子",
          "text": "有事在心头，不由人，双眉愁皱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "念",
          "text": "忙将花轿事，报与老爷知。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "老爷不好了！"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "梁王命二千岁带领世子许多人马，前来抬亲。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "徐大人",
          "type": "唱",
          "text": "听一言来吃一惊， 吓得我三魂少二魂。 后堂快把夫人请，"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐夫人上，丫鬟随上。"
        },
        {
          "character": "徐夫人",
          "type": "唱",
          "text": "老爷缘何放悲声？"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "哎呀夫人哪！不好了！朱温奸贼命二千岁，带领世子许多人马，前来抬亲。"
        },
        {
          "character": "徐夫人",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐夫人哭。"
        },
        {
          "character": "徐夫人",
          "type": "唱",
          "text": "听说花轿已到门， 好比钢刀刺我心。"
        },
        {
          "character": "徐夫人",
          "type": "白",
          "text": "丫鬟，快请小姐、公子。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "有请小姐、公子！（内白）来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐玉环上。"
        },
        {
          "character": "徐玉环",
          "type": "念",
          "text": "忽听二堂放悲声，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐公子上。"
        },
        {
          "character": "徐公子",
          "type": "念",
          "text": "见了爹娘问其情。"
        },
        {
          "character": "徐玉环、徐公子",
          "type": "同白",
          "text": "爹娘为何伤感？"
        },
        {
          "character": "徐夫人",
          "type": "叫头",
          "text": "姣儿！"
        },
        {
          "character": "徐玉环",
          "type": "叫头",
          "text": "亲娘！"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "哎，罢了哇！"
        },
        {
          "character": "徐夫人",
          "type": "唱",
          "text": "将儿断送枉死城。"
        },
        {
          "character": "徐夫人",
          "type": "白",
          "text": "吾儿有所不知：可恨梁王那贼，命二千岁带领世子花轿许多人马，前来抬你。"
        },
        {
          "character": "徐玉环",
          "type": "唱",
          "text": "可恨奸贼太欺心， 分明逼我丧残生。 高堂哭别双亲去， 舍却一命赴幽冥。"
        },
        {
          "character": "徐公子",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "徐公子",
          "type": "唱",
          "text": "姐姐不可自轻生， 还要三思计策行。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "丫鬟",
          "type": "唱",
          "text": "见老爷哭得如酒醉， 二堂上哭坏老夫人。 小姐又要寻自尽， 不由我秋香裂碎心。 祸到临头无计救，"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "丫鬟",
          "type": "唱",
          "text": "舍身代主报答恩。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "启禀老爷、夫人：奴婢现有一计，可救小姐。"
        },
        {
          "character": "徐大人、徐夫人",
          "type": "同白",
          "text": "有何妙计，快些说来。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "目下花轿临门，一时难用别计。奴婢蒙老爷、夫人养育之恩，情愿舍身代替小 姐前去。到了他处，无非一死。"
        },
        {
          "character": "徐玉环",
          "type": "白",
          "text": "奴家只有一死，岂肯连累别人。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "啊，小姐！我秋香还有什么出头之日？你可即速改扮男装，命院公送你至铜台。 待你夫妻团圆，日后兴兵报仇，也不枉我秋香一片代主之心吓！"
        },
        {
          "character": "徐玉环",
          "type": "白",
          "text": "想我玉环，一人做事一身当，怎好连累与你吓！"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "小姐你若执意不从，我秋香留命何用？罢，不免撞死了罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丫鬟碰。徐大人、徐夫人、徐玉环、徐公子同拦。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "且慢。秋香你果然有替主之心？"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "奴婢真心替主。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "好！从今以后，把你认作义女看待。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "只恐奴婢福薄。"
        },
        {
          "character": "徐夫人",
          "type": "白",
          "text": "不必推辞，过来拜见爹爹。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "如此爹娘请上，受孩儿一拜。"
        },
        {
          "character": "丫鬟",
          "type": "唱",
          "text": "多蒙爹娘恩义重， 粉身碎骨报恩情。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "吾儿不必多礼。"
        },
        {
          "character": "徐夫人",
          "type": "唱",
          "text": "用手搀起节义人。"
        },
        {
          "character": "丫鬟",
          "type": "白",
          "text": "姐姐，哥哥，我有一礼。"
        },
        {
          "character": "徐玉环、徐公子",
          "type": "同白",
          "text": "贤妹何须大礼行。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启爷：二千岁、世子到。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "夫人快与义女改妆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐夫人、徐玉环、徐公子、丫鬟同下。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "开门迎接。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内吹打〗。朱义、朱彪同上。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "老姻台请上，受我一拜。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "下官也有一拜。"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "岳父请上，受小婿一拜。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "世子少礼。请坐。"
        },
        {
          "character": "朱义、朱彪",
          "type": "同白",
          "text": "有坐。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "不知千岁、世子二位驾到，有失远迎，望乞恕罪。"
        },
        {
          "character": "朱义、朱彪",
          "type": "同白",
          "text": "岂敢。造次宝关。"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "多多有罪，望乞海涵。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启爷：宴齐。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "看宴。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "又来叨扰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内作乐〗。徐大人安坐。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "二千岁、世子请！"
        },
        {
          "character": "朱义、朱彪",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "徐大人",
          "type": "唱",
          "text": "帅府堂前摆筵宴， 千岁、世子请听言： 愧无美味来敬献， 望乞二位要海涵。"
        },
        {
          "character": "朱义",
          "type": "唱",
          "text": "多蒙姻台酒和宴， 珍馐百味样样鲜。 山中走兽云中雁， 陆地猪羊海底鲜。 满筵荤素数不尽， 却少孤的口头鲜。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "老姻台，你请我吃酒，少了两样。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "哪两样？"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "谁人不晓我朱义最好吃的是螃蟹煮冬瓜，田螺蒸咸虾，天下哪个不知？你如今 少了这两样口味，犹如无有请我一般。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "下官早已预备下了。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "为何不拿来？"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "人来，将二千岁那两样美味献上来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子端菜。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "着哇！有了这两样，就好了。拿酒来。"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "叔王不要多饮了。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "如今有了我这心上的菜，正好吃酒，为什么倒叫我少吃？我偏要多吃些。"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "莫非忘了花轿之事了？"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "蠢才。田螺已有辣椒，又要说忘了花椒。快拿酒来。"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "哎，花轿。不是花椒。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "哦，花轿哇。我只管吃酒，却忘了正事。 人来，将这两样美味，带回府去，待我办了公事，慢慢再吃。"
        },
        {
          "character": "四梁卒",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "姻台。花轿已到许久，请令嫒快快梳妆上轿。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "院子，请小姐梳妆上轿。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请小姐梳妆上轿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内吹打〗。四梁卒同搀扶丫鬟上轿，同下。"
        },
        {
          "character": "朱义、朱彪",
          "type": "同白",
          "text": "告辞了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱义、朱彪同下。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "你看花轿已去。 夫人快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐夫人、徐玉环、徐公子同上。"
        },
        {
          "character": "徐夫人",
          "type": "白",
          "text": "老爷何事？"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "花轿已经出城，快与女儿改妆起来。"
        },
        {
          "character": "徐夫人",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐玉环改男妆。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "老院！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "徐大人",
          "type": "白",
          "text": "你保小姐前到铜台去。一路之上，须要小心。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "徐玉环",
          "type": "白",
          "text": "爹娘请上，受孩儿一拜！"
        },
        {
          "character": "徐大人",
          "type": "叫头",
          "text": "姣儿！"
        },
        {
          "character": "徐玉环",
          "type": "叫头",
          "text": "爹爹！"
        },
        {
          "character": "徐夫人",
          "type": "叫头",
          "text": "玉环！"
        },
        {
          "character": "徐玉环",
          "type": "叫头",
          "text": "亲娘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐大人、徐夫人、徐玉环同哭。院子、徐玉环同下。"
        },
        {
          "character": "徐夫人",
          "type": "哭",
          "text": "哎，我那姣儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐大人、徐夫人、徐公子同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四梁卒、四梁将、朱义、朱彪、花轿同上。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "贤侄，且喜花轿出城，只恐后有追兵。"
        },
        {
          "character": "朱彪",
          "type": "白",
          "text": "叔王保着花轿先行，待侄儿大军断后。"
        },
        {
          "character": "朱义",
          "type": "白",
          "text": "有理。"
        },
        {
