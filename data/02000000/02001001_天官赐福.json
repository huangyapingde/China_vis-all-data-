{
  "script_id": "02001001",
  "title": "天官赐福",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "天官",
      "hangdang": "老生"
    },
    {
      "name": "南极老人",
      "hangdang": "老生"
    },
    {
      "name": "牛郎",
      "hangdang": "小生"
    },
    {
      "name": "织女",
      "hangdang": "旦"
    },
    {
      "name": "张仙",
      "hangdang": "小生"
    },
    {
      "name": "财神",
      "hangdang": "净"
    }
  ],
  "plot": "天上玉帝，因下界福主，乐善好施，阴功浩大。特敕令天官，一称福德星君，邀众位福神，颁赐福禄，以彰\n善行。计邀有南极老人、牛郎、织女、张仙、财神等同至福地，各献礼物。除天官宣敕：进爵一品、位列朝\n班、公侯世代外，其余神仙，亦各有馈赠。如张仙送子、财神赠金等。最后由天官领导，各唱颂词。赐福完\n后，始一同离去，复奏玉帝云。",
  "notes": "按喜庆事宜，照例戏剧开始，先演《天官赐福》。词句中之“圣朝”、“下界福主”即“善门福地”，均系\n泛指之词，演唱时可随时更易。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四云童、四护从、四天将、天官同上。"
        },
        {
          "character": "天官",
          "type": "醉花阴",
          "text": "雨顺风调，万民好， 庆丰年，人人欢乐，似这等民安泰，乐滔滔。 在华胥时，见了些人寿年丰，也不似清时妙， 似这等官不差，民不扰，只俺奉玉旨将福禄褒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "天官归座。"
        },
        {
          "character": "天官",
          "type": "念",
          "text": "瑞霭祥光紫雾腾，人间福主庆长生。欣看四海升平日，共沐恩波享太平。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "吾乃苍帝之子，上元一品，赐福天官是也。人间称为福德星君。所临之地，无 不吉祥如意。今奉玉帝敕旨，因下界福主，乐善好施，阴功浩大，特邀诸位福 神，前往下界，颁赐福禄，以彰积德之报。 护从们，"
        },
        {
          "character": "众神",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "有请诸位星君。"
        },
        {
          "character": "众神",
          "type": "同白",
          "text": "领法旨。 有请诸位星君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "南极老人、牛郎、织女、张仙、财神同上。"
        },
        {
          "character": "南极老人",
          "type": "念",
          "text": "称觞献寿乐荣年，"
        },
        {
          "character": "牛郎、织女",
          "type": "同念",
          "text": "五谷丰登喜事全。"
        },
        {
          "character": "张仙",
          "type": "念",
          "text": "桂子飘香沾雨露，"
        },
        {
          "character": "财神",
          "type": "念",
          "text": "财源永茂福绵绵。"
        },
        {
          "character": "南极老人",
          "type": "白",
          "text": "吾乃南极老人是也。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "吾乃五谷牛郎是也。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "吾乃天孙织女是也。"
        },
        {
          "character": "张仙",
          "type": "白",
          "text": "吾乃送子张仙是也。"
        },
        {
          "character": "财神",
          "type": "白",
          "text": "吾乃增福财神是也。"
        },
        {
          "character": "南极老人",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "南极老人",
          "type": "白",
          "text": "天官相召，一同进见。"
        },
        {
          "character": "牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "天官在上，吾等稽首。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "诸位福神少礼。"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "啊。上圣相召，有何台谕？"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "吾奉玉帝敕旨，因下界福主，乐善好施，阴功浩大，故邀诸位福神，一同前往， 颁赐福禄，以彰积德之报。"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "蒙颁上谕，敢不谨遵。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "护从们，"
        },
        {
          "character": "众神",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "驾起祥云，往福地去者。"
        },
        {
          "character": "众神",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众神同走圆场。"
        },
        {
          "character": "众神",
          "type": "同喜迁莺",
          "text": "只羡他功深德浩，只羡他功深德浩， 因此上赐福天曹逍也么遥。 一门贤孝， 恁看那福自天来，将官品超。 争如为善好， 这的是福禄自造，恁看他寿算弥高，恁看他寿算弥高。"
        },
        {
          "character": "众神",
          "type": "同白",
          "text": "已到福地。"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "请天官登台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。天官上高台。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "妙哇！"
        },
        {
          "character": "天官",
          "type": "念",
          "text": "簇簇花香迎画阁，青青瑞草满阶庭。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "果然好福地也！"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "请天官赐福。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "小圣奉玉帝敕旨，进爵一品，愿位列朝班，公侯世代。"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "天官赐福，正当如此。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "诸位福神，各将福禄赐之。"
        },
        {
          "character": "南极老人",
          "type": "白",
          "text": "老人无以为赠，进献百寿图一轴，愿福寿绵长，筹添海屋。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "小仙敬献年年如意，岁岁平安，愿稻生双穗，五谷丰登。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "织女敬献天丝文锦一缎，愿蚕桑茂盛，丝帛丰盈。"
        },
        {
          "character": "张仙",
          "type": "白",
          "text": "小仙特送麒麟为嗣，愿子孙繁衍，瓜瓞绵绵。"
        },
        {
          "character": "财神",
          "type": "白",
          "text": "俺财神特献黄金万两，愿财源茂盛，积玉堆金。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "妙哇！"
        },
        {
          "character": "众神",
          "type": "同刮地风",
          "text": "哎呀，万千春，享富贵，乐滔滔， 庆长春，酒泛香醪。 看牛郎早报了田丰兆， 织女献丝帛绫绡。 积德的一门寿算，筹添海屋，南极星耀， 福寿弥高，盈仓廪，稷米豆丰满仓廒。 麒麟儿早登廊庙， 佐皇家永享官爵。 财源发，德行昭， 乐善事，福禄根苗。 你看那窦燕山五子登科早， 又只见半空中魁星献的祥云来罩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魁星上，跳舞，下。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "魁星献瑞，万代全福也。"
        },
        {
          "character": "众神",
          "type": "同水仙子",
          "text": "呀呀呀呀福分高， 呀呀呀福分高。 早早早，早佩着玉带金章把鼎鼐调， 羡羡羡，羡文才锦绣好。 看看看，看德门呈祥耀， 贺贺贺，贺百福骈臻妙。 庆庆庆，庆福门千祥照， 道道道，道民乐欢天乐。 拜拜拜，拜福主恩荣耀， 俺俺俺，俺将这喜事儿留与后人标。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。天官下高台，坐。"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "赐福已全。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "一同覆奏上帝去者。"
        },
        {
          "character": "南极老人、牛郎、织女、张仙、财神",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "众神",
          "type": "同煞尾",
          "text": "列旌幢一派仙音绕， 一霎时神州赤县皆游到， 只愿普天下积德的享福禄直到老。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众神同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}