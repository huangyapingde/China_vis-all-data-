{
  "script_id": "02008044",
  "title": "百箭会",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "赵德芳",
      "hangdang": "小生"
    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "宋太宗",
      "hangdang": "老生"
    }
  ],
  "plot": "宋八千岁赵德芳上殿朝王，行至御街上，有一疯人告状。当即令随从带回宫中。及经询问，始知系杨延昭涂\n面装疯，由前线偷回告状，并备述潘仁美在前线谋害杨家将事实。八千岁乃与杨延昭秘密商定，由佘太君出\n名请宋王饮宴。届时将馒首内置一箭头。待宋王发觉，便藉故申诉杨家将被害经过，使宋王了解真相，好将\n潘仁美调回问罪。结果宋王均如八千岁等所拟议者，将潘仁美调回云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四校尉、二大太监、赵德芳同上。"
        },
        {
          "character": "赵德芳",
          "type": "引子",
          "text": "叔王大宋一统，九面剪保立江洪。"
        },
        {
          "character": "赵德芳",
          "type": "念",
          "text": "少年岁月，龙行世界，虽然未登龙凤阙，俺本是金枝玉叶。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "本御赵德芳，三、六、九日上殿朝王。 吩咐校尉，催车。"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "想当年我父王曾在世上， 我叔王起反意谋去家邦。 龙国母领本御金殿以上， 直骂的我叔王羞愧难当。 封我母三宫院由她执掌， 又把本御封为王。 赐我母斩杀宝剑月儿印， 又赐我瓦面金锏保朝堂。 他封我上殿不参王，下殿不辞王， 专打奸臣八代王。 催驹辇来在御街上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上，二军牢同上，过场，杨延昭、二军牢同下。"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "又听人声闹嚷嚷。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "来，去看什么人罗唣？"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "疯魔汉子罗唣。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "绑上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭绑上，跪。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "这一疯魔汉子，有甚么冤枉，有司衙门去告，本御不管民词。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭指。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "观见这一汉子，指天画地，想是有托天冤枉。 将他带了，随辇回官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳带杨延昭同走圆场。"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "三、六、九上殿去参王， 遇见了疯魔汉内有周章。 来在宫门下车辇， 再叫宫人听心间。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳坐。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "将那疯魔汉子带上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上，跪。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "验他脸擦何物？"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "黑墨涂脸。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "领下去净脸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉领杨延昭同下。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "昨晚偶得一梦，梦见一只白额猛虎，口吐人言，上说叫本御搭救。莫非此梦， 应在这疯魔汉子身上？"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "昨夜晚上得一梦， 梦见了白额猛虎闯进宫。 面对本御双膝跪， 叫本御搭救它命残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监上。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "郡马回朝。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "怎么说，郡马来了？快快有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "杨郡马！御妹夫！哎呀，不好了！"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "却怎么口中不应声？ 倒叫本御吃一惊。 出言我把宫人叫， 为王把话对你明。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "宫人验他口含何物？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "口含交马担子。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "上前净口。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牌子。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哎呀千岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牌子。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "平身，落坐。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "千岁驾安。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "罢了。杨郡马，你父子奉王旨意征北，怎么你一人还朝？想必是你临阵脱逃。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "叫臣一言难尽了！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "未开言不由人双目泪掉， 尊一声八贤爷细听根苗： 北国里萧银宗打来战表， 他要夺宋王爷锦绣龙朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭唱斩子经过。"
        },
        {
          "character": "杨延昭",
          "type": "哭头",
          "text": "八贤王啊！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "把我这冤枉事一口诉了， 八贤爷与为臣快把冤消。"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "听他言来怒冲冠， 可恨仁美狗奸谗。 若得奸贼回朝转， 洼面金锏染黄泉。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "郡马你有这大冤仇，为何不告他一状？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "为臣心想告他一状。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "可有状子？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "臣有状子。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "呈来，本御看过。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "臣的状子，又被奸贼搜去了。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哎，郡马你好无才！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "千岁，为臣北国带来一人，名叫王强，此人双手能写梅花篆字，臣的状子是他 写得。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "校尉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二校尉同暗上。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "拿本御白牌一面，提王强进宫回话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二校尉同下。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "郡马！"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "可恨仁美狗奸臣， 苦害郡马为何情？ 倘若老贼回朝转， 洼面金锏打他个血淋淋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二校尉带王强同上。"
        },
        {
          "character": "二校尉",
          "type": "同白",
          "text": "王强提到，交牌。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "带进来。"
        },
        {
          "character": "王强",
          "type": "白",
          "text": "与千岁叩头。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "下跪可是王强？杨家状子，可是你写的？"
        },
        {
          "character": "王强",
          "type": "白",
          "text": "是臣写的。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "好，照样再写一纸。"
        },
        {
          "character": "王强",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "宫人赏他笔砚。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王强脸朝外椅子。牌子。王强双手写。"
        },
        {
          "character": "王强",
          "type": "白",
          "text": "千岁请看。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "王强！"
        },
        {
          "character": "赵德芳",
          "type": "念",
          "text": "但等杨家冤仇报，本御保你在王朝。"
        },
        {
          "character": "王强",
          "type": "白",
          "text": "谢过千岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王强下。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "郡马你看。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "千岁请看。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "“告上状人郡马，杨延昭年卅二岁，状告太师潘洪，勾结辽邦谋篡山河事。” 郡马，状子有了，这个谋篡山河事，也就够老贼受了。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "还仗贤爷。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "你浑身是罪，不能见驾，也是枉然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭跪。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "快与为臣作主。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳坐。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "本御如其不然，与你杨门定一计，名曰百箭会。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "何为百箭会？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "郡马回府，教你母上殿去请圣驾过府饮宴，馒首里边包下箭头，那时节再诉你 杨家冤枉罢。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "尽在千岁。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "你一人回府，本御放心不下。 宫人送郡马回府。"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "叩罢头来谢恩情， 千岁还有这点情。 八王定下百箭会， 我杨家冤枉才能明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "可恨潘洪狗奸佞， 害的杨家甚苦情。 假若将贼擒拿住， 剐尔一刀问一声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二夫人、二彩女、杨洪引佘太君同上。杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "里面哪个在？"
        },
        {
          "character": "杨洪",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "禀知太君：就说六爷回来。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "命他进来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭进。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牌子。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿呀，你父子奉王旨意征北，为何一人还朝？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "母亲，不好了！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "为何慌张？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "只因仁美将我七弟绑在芭蕉树上，射了一百单三箭，七十二支透尸灵，将他射 死了！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "射死了！"
        },
        {
          "character": "佘太君",
          "type": "唱",
          "text": "听一言唬的我三魂不在， 三魂渺渺转回来。 忽然睁睛用目看， 又见全家画痴呆。 恨仁美把我的牙咬坏， 害我举家该不该？ 出言我把六郎叫， 为娘把话说明白。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "儿呀，你七弟一死，我儿怎样回来？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "儿临阵脱逃，又被仁美将儿拿住，黄烛罐黑墨涂脸，行在御史街前，遇见八王 千岁，救了儿的性命，与咱家定下一计，名曰百箭会。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "何谓百箭会？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "馒首里边包下箭头，请圣上过府饮筵，酒席宴前再诉杨家冤枉。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "好。我见下边歇息，待为娘上殿，去请圣驾。正是："
        },
        {
          "character": "佘太君",
          "type": "念",
          "text": "安排打虎牢龙套，"
        },
        {
          "character": "杨延昭、杨洪、二夫人、二彩女",
          "type": "同念",
          "text": "准备金钩钓海鳌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。牌子。四校尉、四太监、二大太监、胡必显、四朝臣、宋太宗、赵德芳、伞夫同上。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "寡人，大宋天子二帝太宗在位。只因太君请我过府饮宴，贤臣保驾。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "催驹。 （四朝臣、四太监同上场斜门。宋太宗、赵德芳同下辇，同进府。四校尉、四太监同挖门。四校尉、二大太 监、赵德芳、宋太宗同进府。佘太君、二夫人、杨八姐、杨九妹、杨洪自下场门同上。宋太宗正场坐，四太 监同陪站，赵德芳下场斜坐，四朝官、二太监同上场门陪坐，佘太君、二夫人同相陪，杨八妹、杨九妹、杨 洪同陪站。）"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "万岁驾安。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "八千岁驾安。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "罢了。太君你好？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "臣妻谢问。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "太君，自古道龙不离潭，凤不离巢，你要摆筵，快些摆宴，圣上饮宴已毕，就 要回宫。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "遵旨。 杨洪酒来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君按杯。杨八姐、杨九妹同下。牌子。杨八姐、杨九妹端馒首同上，同叩头，同摆馒首。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "贤君，他杨家有了反心了。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "馒首里边包的箭头，叫寡人怎下咽喉？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "就有这等事情？待儿臣问过。 太君，圣上待你杨家如何？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "皇恩浩荡。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "却又来。既然待你甚好，因何馒首里边包得箭头，叫圣上怎下咽喉？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "万岁连一个箭头，用它不下？我那七郎孩儿，一百单三箭，七十二支透尸灵， 他怎样受来？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "太君，这话从何说起？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "千岁，你是明知故问。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "只有不知，哪有故问。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "既然不知，千岁听臣道来：只因北国打来连环战表，要夺圣上江山。仁美当殿 挂帅亲讨，我杨家父子，马前先锋。兵行两狼山虎口交牙峪，黄道之日不教他 父子出征交马；黑道之日，教他父子征杀。臣那夫君与胡儿打了一仗，只杀的 大败而回。仁美一见，冲口大怒，将我夫君，推出问斩，多亏满营众将苦苦讲 情，将我夫君死罪赦过，活罪难免，重打四十军棍，赶出营来。臣那夫君，差 了我那七郎孩儿，回朝搬兵，又被仁美诓在芭蕉树上，射了一百单三箭，七十 二支透尸灵，他、他、他是怎样的受来？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "太君，这是边廷事情，你如何得知？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "郡马还朝。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "哦，怎么说，郡马来了？ 胡必显推出去问斩！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "慢着，慢着。贤君你杀郡马为何？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "叔王，他父子奉旨意征北，郡马一人还朝，想必是临阵脱逃，哪里容得！ 胡必显，押下去开刀！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "慢着。问明再斩。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "叔王，他浑身是罪，不能见驾，也是枉然。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "朕赦他无罪。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "太君，快快谢过。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "谢过万岁！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "胡必显，将郡马押上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭绑上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "与万岁叩头！"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "好一大胆延昭。你父子奉王旨意征北，为何你一人还朝？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "臣有血海冤仇禀诉天颜。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "有状无状？"
        },
        {
          "character": "胡必显",
          "type": "白",
          "text": "有状。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "呈上来。 叔王，郡马有状。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "贤君念来，待寡人一听。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "儿臣尊旨。 “告状人郡马杨延昭，状告太师潘洪。” 看锏来！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "慢着。你打郡马为何？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "叔王你当他告着哪个？"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "告着哪个？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "他告的是太师。我想太师乃一人之下，万人之上，文官之头官，武官之领袖， 岂是郡马告的？"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "自古道君不正臣告君，父不正子告父，告得，怎见告不得？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "他也就大胆，敢告皇亲！ “告上状人郡马杨延昭，状告太师潘洪，勾结辽邦谋篡山河事。” 看锏来！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "慢着。你怎么又打起郡马来了？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "叔王，他怎么常常告起太师？我想太师，乃是皇亲，岂是他常常告的？倒不如 儿臣一锏将他打死。哎，与他个斩草除根！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "着！倒不如千岁一锏将他打死，与我杨家斩草除根。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "慢着，慢着。此事不劳贤君，你问郡马，你有甚么冤枉，往上诉来，寡人与你 作主。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "一不告苍天爷不下大雨， 二不告土地上不生苗根。 三不告我的主为君不正， 四不告满朝里文武众卿。 五不告外国的胡儿造反， 六不告边廷上脱逃之军。 七告八告九不告， 十十告的贼潘洪。 万岁爷龙位里听臣告禀，"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "看锏来！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "慢着。你怎么常常打起郡马来了？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "叔王，他怎么常常告起太师来了？"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "寡人有言在先，不劳贤君你管。 郡马有甚么冤枉，自管诉来，寡人与你作主。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "郡马你来看，有甚么冤枉，有圣上与你作主。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳作眼色。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "往上诉。"
        },
        {
          "character": "杨延昭",
          "type": "唱",
          "text": "尊我主在上边侧耳细听： 把我家冤枉事一一陈诉， 我的主与为臣快把冤明！"
        },
        {
          "character": "宋太宗",
          "type": "唱",
          "text": "忽听郡马把冤申， 倒叫寡人痛伤情。 这才是君才哭，"
        },
        {
          "character": "四朝臣",
          "type": "同唱",
          "text": "臣也哭，"
        },
        {
          "character": "宋太宗",
          "type": "唱",
          "text": "寡人落泪，"
        },
        {
          "character": "赵德芳",
          "type": "唱",
          "text": "气得我赵八王咬碎牙根！"
        },
        {
          "character": "赵德芳",
          "type": "梆子尖板",
          "text": "看起来俱是你昏王不正， 黄门官你与我看过金锏。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "无道的昏王！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "哎！贤君，你怎么打起寡人来了？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "无道的昏王，北国银宗打来战表，要夺你昏王的江山，那时节你就该挂杨老将 军为帅，你为何单单挂那仁美为帅？情知他两家有仇，两军阵前公报私仇。这 是你昏王失政，到不如儿臣正法。哎。打死你这昏王！"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "慢着，慢着。仁美在此边廷，苦害杨家，寡人一字不知，寡人即刻去到边廷， 捉拿老贼回来，任凭贤君你发落，你看如何？"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "如此，叔王即刻传旨。"
        },
        {
          "character": "宋太宗",
          "type": "白",
          "text": "启开文房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋太宗写旨，交太监甲下。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "请驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}