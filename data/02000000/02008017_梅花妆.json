{
  "script_id": "02008017",
  "title": "梅花妆",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "寿阳公主",
      "hangdang": "旦"
    },
    {
      "name": "宗悫",
      "hangdang": "小生"
    },
    {
      "name": "傅亮",
      "hangdang": "丑"
    }
  ],
  "plot": "刘裕篡晋，建都建康，国号大宋。有一大臣傅亮，忌新进宗悫之能，乃设计陷害。向宗悫言：皇帝每日在含\n章殿耽饮酒色，不理朝政。宗悫激于忠义，奋勇前往诤谏。惟含章殿乃寿阳公主所住。宗悫入时，适公主在\n玉阶昼睡，梅花片片，落满眉额。宗悫疑系宫人，恐其中寒，将渠叫醒。公主大怒，谓私闯宫殿，理应问斩。\n宗悫大惧，乃告以实情。公主见宗少年英俊，不胜爱慕。乃言少时皇帝问讯时，亦要据实说明。届时宗悫\n据实直言，公主亦从中解释，遂得无罪。适林蛮王阳迈入侵，公主自荐，领兵抗御，并令宗悫为先锋，傅亮\n则隶属先锋部下，一同出发。卒将阳迈击退，凯旋而归。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八蛮兵、四蛮将同上，同站门。阳迈上。"
        },
        {
          "character": "阳迈",
          "type": "点绛唇",
          "text": "虎踞南方，将勇兵强。魏禅晋，刘裕猖狂，看社稷尽归吾掌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阳迈坐高台。"
        },
        {
          "character": "阳迈",
          "type": "念",
          "text": "长在天南地，裹甲一身轻。自从孟获后，谁人似孔明？"
        },
        {
          "character": "阳迈",
          "type": "白",
          "text": "孤，林邑蛮王阳迈是也。自晋朝以来，称强西南。今闻宋王刘裕篡了晋室，称 帝建康，孤家正好乘隙起兵，夺取江南，因恐宋朝兵强将广，孤命力士常风、 石勇择大象一匹，练就象鼻阵，万人莫敌。 众蛮兵，唤常风、石勇带象上来。"
        },
        {
          "character": "八蛮兵",
          "type": "同白",
          "text": "常风、石勇带象上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "常风、石勇带象同上。"
        },
        {
          "character": "常风、石勇",
          "type": "同白",
          "text": "大王验看。"
        },
        {
          "character": "阳迈",
          "type": "白",
          "text": "象吓象，孤家兵夺江南，用你以为前队，须要奋勇当先。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。"
        },
        {
          "character": "阳迈",
          "type": "白",
          "text": "众蛮兵，齐往江南。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "阳迈骑象。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "傅亮上。"
        },
        {
          "character": "傅亮",
          "type": "念",
          "text": "江左尚风流，世乱与民愁。贤王受禅晋，德政播千秋。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "下官，傅亮，官拜侍中。自东晋以来，江左微弱，贼臣迭起，因此乘机扶了宋 王刘裕，勒逼晋帝让位，裕作南宋天子。我不才，也算开国功臣。可恨南阳宗 悫，少年孩童，提剑来投，指天划地。天子见喜，也封侍中，竟与区区同立朝 班，实觉可厌。吓。我想含章殿，乃是寿阳公主时常坐卧之所，不免将他诓了 进去，使公主斩之，以除芒刺。话言之间，小儿谅必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅亮边坐。宗悫官衣上。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "姆，姆。"
        },
        {
          "character": "宗悫",
          "type": "西皮原板",
          "text": "饱奇才习孔孟自夸学问， 黄石略吕望韬文武通神。 这都是寒窗苦埋头发愤， 今方见诗书中不误愚人。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "吓，宗兄来了，请坐。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "我有一事正要请教，兄来得甚好。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "请问何事？"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "方今，北有燕、秦、赵、魏，南有林邑广粤，我南宋区区江左，四海未一，当 将何策，以为久固之计？"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "为臣者鞠躬尽瘁，忠义为心，何愁四海不一？"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "此乃书生之常论也。我傅亮之志，要挟泰山而超北海，作人之所不能，方能定 国。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "哈哈，此乃跋扈将军之言也。我宗悫则不然。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "足下之志如何呢？"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "我之志，欲乘长风破万里巨浪。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "哈哈，好爽快之事，可见足下高明也，果然胜我十倍。只是圣上近日流连花酒， 足下身为侍中，何不谏阻一言？"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓，圣上勤政崇德，何尝贪恋花酒？"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "哎哎，现在含章殿赏花，吩咐守门内侍，一概不许大小文武进见，足下若有忠 君之心，硬闯入内，若能谏止，下官服你之才能也。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓，此事可真？"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "哎，别事可谎，此岂虚言？"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "既然如此，我即修本谏奏，少陪了。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "宗悫",
          "type": "西皮原板",
          "text": "我宗悫虽年少朝堂后进， 怀一膛忠义气贾谊同心。 圣驾在含章殿流连宴饮， 又何防叩龙墀直言谏君？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宗悫下。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "哈哈，妙吓。宗悫小儿，被我激动，诓入含章，自有公主杀他。若是不成，我 还有妙计害他一死。正是："
        },
        {
          "character": "傅亮",
          "type": "念",
          "text": "除却心头恨，方显我才能。"
        },
        {
          "character": "傅亮",
          "type": "白",
          "text": "姆姆，妙哉，妙哉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傅亮下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（八旗夫、八将同上，同跑马，同下。大吹打，锣鼓。四红文堂、四大铠、八旗夫、四女兵、女马夫、女纛、"
        },
        {
          "character": null,
          "type": "text",
          "text": "八将同上，寿阳公主骑马上。）"
        },
        {
          "character": "寿阳公主",
          "type": "念",
          "text": "银河小天孙，文武俱超群。常入含章殿，俊眼看彩云。"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "奴，寿阳公主是也，蒙父王教习文武，以备遣用。今日操演已毕。 众将官，各归各营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人倒脱靴同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。花屏帐，中场桌上花山，山前摆屏，屏前摆梅。平安上。"
        },
        {
          "character": "平安",
          "type": "念",
          "text": "本是庶民种，忽然身随龙。似贵原非贵，好在称公公。"
        },
        {
          "character": "平安",
          "type": "白",
          "text": "咱家，大宋朝穿宫内监平安是也。只因寿阳公主性爱梅花，这含章殿前花开茂 盛，特此检点以备玩赏。呀，乐声一派，公主来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平安下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、四女兵同上。"
        },
        {
          "character": "寿阳公主",
          "type": "内白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寿阳公主上。"
        },
        {
          "character": "寿阳公主",
          "type": "西皮平板",
          "text": "羡鲜明当须潇洒， 但凭春梦到天涯。 红楼日暮流莺去， 愁杀深宫惜落花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "过门。平安上。"
        },
        {
          "character": "平安",
          "type": "白",
          "text": "奴婢接驾。"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "香风扑鼻，梅花盛开，你们各自玩赏，不必在此伺候。"
        },
        {
          "character": "平安",
          "type": "白",
          "text": "是。 众位姐姐，俱随我来。"
        },
        {
          "character": "四宫女、四女兵",
          "type": "同白",
          "text": "公公请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平安、四宫女、四女兵同下。"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "梅花吓，梅花。想我寿阳女子，叨蒙父皇恩养一十五岁，自夸容貌，可与花比， 因甚跨凤无期，不知乘龙有谁吓？"
        },
        {
          "character": "寿阳公主",
          "type": "西皮平板",
          "text": "春风和春色娇艳阳春景， 有心人对梅花无限钟情。 似琼瑶堆玉山翠黛掩映， 比兰麝气幽香却胜几分。 说甚么羡琼楼鸳鸯交颈， 我今日含章殿人在蓬瀛。 倦沉沉似觉得身体欲困， 卧玉阶一任他花片飘零。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寿阳公主靠桌头睡。宗悫上。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "宗悫",
          "type": "唱",
          "text": "急匆匆闯过了数重紫禁，"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "宗悫",
          "type": "唱",
          "text": "含章殿听不见金口龙音。 傅亮言主在此欢乐宴饮，"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "宗悫",
          "type": "唱",
          "text": "闻我来已撤席驾回宫庭。 臣谏君必须要忠心上禀，"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "宗悫",
          "type": "唱",
          "text": "玉阶台睡一女美貌青春。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓，圣驾未见，这玉阶台上睡有一个绝色美女，梅花落了她一额角，竟不知醒， 岂不受了寒气。待我将她唤醒，问问圣驾今在何处。 吓，宫人醒来，醒来！"
        },
        {
          "character": "寿阳公主",
          "type": "西皮导板",
          "text": "睡朦胧只觉得风香体冷，"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "花落满额，不要睡凉了。圣驾今在何处？"
        },
        {
          "character": "寿阳公主",
          "type": "唱",
          "text": "惊醒我瑶台梦又下红尘。 莫不是宫娥们前来相请？"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "醒来，我有话问你。"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "寿阳公主",
          "type": "唱",
          "text": "拂花片睁凤目言语何人？"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "圣驾呢？"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "圣驾在何处？"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "寿阳公主",
          "type": "唱",
          "text": "戴乌纱穿朝衣将奴盘问， 怒冲霄拔宝剑立斩贼臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宗悫、寿阳公主两过合。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "宗悫",
          "type": "唱",
          "text": "我宗悫为宋臣忠心耿耿， 一宫女竟焉敢举剑杀人。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓，我宗悫乃堂堂大臣，有事见驾，你一宫女，何敢杀我么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寿阳公主停剑。"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "吓，你既是大臣宗悫，就该知道朝庭礼仪，何敢私入含章，惊犯公主，岂不该 斩么？"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "吓，公主？却在何处？"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "吾即寿阳公主。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宗悫跪。"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "内侍、宫人何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平安、四宫女自两边分上。"
        },
        {
          "character": "平安、四宫女",
          "type": "同白",
          "text": "公主。"
        },
        {
          "character": "寿阳公主",
          "type": "白",
          "text": "将他绑了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "平安、四宫女同绑宗悫。"
        },
        {
          "character": "平安",
          "type": "白",
          "text": "宗官，你是大大的忠臣，怎么闯到这里来了？好大胆！"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "哎呀，公主吓！"
        },
        {
          "character": "宗悫",
          "type": "唱",
          "text": "我误中牢笼计一时急性， 吓得我心胆碎跪拜埃尘。 惊驾罪该斩首下情告禀，"
        },
        {
          "character": "平安",
          "type": "白",
          "text": "你说实话，公主开恩放你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寿阳公主遮看宗悫。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "哎呀，公主吓！"
        },
        {
          "character": "宗悫",
          "type": "唱",
          "text": "说明这奸贼计死也甘心。"
        },
        {
          "character": "平安",
          "type": "白",
          "text": "有话只管说。"
        },
        {
          "character": "宗悫",
          "type": "白",
          "text": "哎呀，公主吓。臣在朝房，傅亮言道：圣驾每在含章殿饮宴，不理朝政。为臣 忠肝义胆，一时冒昧前来谏奏，岂知中他陷害之计。臣今万死不辞，只求公主 将此委曲，转奏天子，即认罪亦得瞑目九泉也。"
        },
        {
          "character": "平安",
          "type": "白",
          "text": "那傅亮本来就是个坏种。"
        },
        {
          "character": "宗悫",
          "type": "唱",
