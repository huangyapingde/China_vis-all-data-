        },
        {
          "character": "庄姬",
          "type": "唱",
          "text": "赵家与你有何恨， 苦苦害他为何情？ 三百余口俱斩尽， 阴曹地府勾你魂！"
        },
        {
          "character": "屠岸贾",
          "type": "唱",
          "text": "听一言来怒生嗔， 庄姬公主乱胡云。 隐藏孤儿你不报， 论国法就该问斩刑。"
        },
        {
          "character": "太后",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "太后",
          "type": "唱",
          "text": "那晋主本是我的子， 君不君来臣不臣！"
        },
        {
          "character": "屠岸贾",
          "type": "唱",
          "text": "搜孤原本奉主命， 为臣焉敢逆旨行。"
        },
        {
          "character": "太后",
          "type": "唱",
          "text": "任你搜来任你洗， 免得贼子生疑心。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "校尉的，四下搜来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同搜。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "无有。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "啊，起过了。"
        },
        {
          "character": "屠岸贾",
          "type": "唱",
          "text": "搜寻孤儿无踪影， 难道说上天入地去不成？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "且住，搜寻孤儿，不见踪影。想是藏在别家抚养。国太、庄姬，十日之内，有 了孤儿便罢；若是无有，管你碎尸万段。 来呀。打道出宫。 中国京剧戏考 《搜孤救孤》【头本】 9"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、屠岸贾出宫，同下。"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "好奸贼！"
        },
        {
          "character": "庄姬",
          "type": "唱",
          "text": "一见屠贼出宫庭， 咬牙切齿骂几声。 浑身上下难扎挣，"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庄姬倒。"
        },
        {
          "character": "太后",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "太后",
          "type": "唱",
          "text": "见姣儿昏倒在地埃尘。 宫娥速速忙扶定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫娥扶庄姬同下。"
        },
        {
          "character": "太后",
          "type": "唱",
          "text": "这才是平空祸来临。"
        },
        {
          "character": "太后",
          "type": "白",
          "text": "来，传韩厥进宫。"
        },
        {
          "character": "二宫娥",
          "type": "同白",
          "text": "国太有旨：韩厥进宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥上。"
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "忽听国太宣。进宫把驾参。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "韩厥见驾，国太千岁！"
        },
        {
          "character": "太后",
          "type": "白",
          "text": "公主身得重病，请太医院前来诊脉。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥下。"
        },
        {
          "character": "太后",
          "type": "唱",
          "text": "但愿姣儿平安稳， 满斗焚香谢神灵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太后下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}