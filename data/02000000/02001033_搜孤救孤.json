    }
  ],
  "plot": "春秋时，晋国有佞臣屠岸贾，晋景公宠之。屠岸贾与赵氏不睦，诬赵盾以弑君之罪，将赵氏抄斩。赵朔之妻，\n公之庶妹也，怀孕走入宫中，得免。后生赵武，托门客程婴、公孙杵臼，设法保护。屠岸贾为斩草除根计，\n严索孤儿。程婴适生子，公孙杵臼请将婴儿伪作孤儿，应屠岸贾索。程婴许之。公孙杵臼乃抱程婴子藏于\n首阳山边，嘱程婴出首。屠岸贾带校尉搜山，果得公孙杵臼及孤儿，立将孤儿掷死，又命程婴举鞭击公孙杵\n臼，以试虚实，以程婴与公孙杵臼，同为赵氏家客也。程婴忍泪痛击公孙杵臼，屠岸贾乃信，杀公孙杵臼。\n后景公崩，成公立，赵武为上卿，将屠岸贾剐戮。以报昔日之仇。赵武既成立，程婴乃自杀以报公孙杵臼。\n赵武感二客义侠，立位宗庙，配享祖先。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四校尉同上，同站门，屠岸贾上。"
        },
        {
          "character": "屠岸贾",
          "type": "引子",
          "text": "虎穴龙巢谁敢押，晋君独霸朝纲。"
        },
        {
          "character": "屠岸贾",
          "type": "念",
          "text": "眉头一皱千般恨，晋室江山掌中存。若要吾把愁眉展，灭却赵氏方称心。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "老夫屠岸贾。晋室为臣，官居大司马之职。只因赵盾，屡次与老夫结仇。今已 去世。他有一子，名叫赵朔，乃是东床驸马。不免上殿参奏一本，将他斩首， 方消老夫心头之恨。 校尉的，开道上朝。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵同、韩厥、赵括、赵婴齐同上。"
        },
        {
          "character": "赵同、韩厥、赵括、赵婴齐",
          "type": "同点绛唇",
          "text": "扶保君王，忠心朗朗，皇恩荡，定国安邦，位列朝纲上。"
        },
        {
          "character": "赵同",
          "type": "白",
          "text": "老夫赵同。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "下官韩厥。"
        },
        {
          "character": "赵括",
          "type": "白",
          "text": "下官赵括。"
        },
        {
          "character": "赵婴齐",
          "type": "白",
          "text": "下官赵婴齐。"
        },
        {
          "character": "赵同、韩厥、赵括、赵婴齐",
          "type": "同白",
          "text": "列公请了。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "老大人缘何上朝甚早？ 中国京剧戏考 《搜孤救孤》【头本】 2"
        },
        {
          "character": "赵同、赵括、赵婴齐",
          "type": "同白",
          "text": "只因吾兄辞世，朝事繁冗，故尔来得甚早。"
        },
        {
          "character": "赵括",
          "type": "白",
          "text": "兄长辞世，屠贼专权，恐其暗生事端陷害我等，如之奈何。"
        },
        {
          "character": "赵同、赵婴齐",
          "type": "同白",
          "text": "你我弟兄，忠心为国，何惧之有。"
        },
        {
          "character": "赵婴齐",
          "type": "白",
          "text": "虽则如此，还要作个防备才是。"
        },
        {
          "character": "赵同、韩厥、赵括、赵婴齐",
          "type": "同白",
          "text": "香烟缭绕，圣驾临朝，你我分班伺候。请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵同、韩厥、赵括、赵婴齐自两边分下。四小太监同上，同站门。晋景公上。"
        },
        {
          "character": "晋景公",
          "type": "引子",
          "text": "山河锦绣，帝道遐昌。"
        },
        {
          "character": "晋景公",
          "type": "念",
          "text": "尧舜禹汤共桀纣，胜者为王败者休。纷纷列国相争斗，各霸一方统貔貅。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "孤，晋景公。即位以来，倒也兵精粮足。今当早朝。 内侍，展放龙门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "屠岸贾上。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "走。"
        },
        {
          "character": "屠岸贾",
          "type": "念",
          "text": "要除心头恨，思拔眼中钉。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "臣屠岸贾见驾，大王千岁！"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "大司马平身，赐座。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "谢千岁！"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "大司马上殿，有何本奏？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "臣有本章一道，请大王龙目观看。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "呈上来待孤一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "大司马，当初桃园弑君，今已年深日久，还提他则甚？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "启奏大王：想桃园弑君，乃是赵家满门之过。宣驸马赵朔，上殿一问，便知明 白。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "好。 内臣，宣驸马上殿。"
        },
        {
          "character": "小太监甲",
          "type": "白",
          "text": "大王有旨：宣驸马赵朔上殿。"
        },
        {
          "character": "赵朔",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵朔上。"
        },
        {
          "character": "赵朔",
          "type": "唱",
          "text": "忽听得一声声金牌召下， 想必是哪国中动了杀法。 老严亲为国家命归泉下， 一家人守灵前带孝披麻。 未尽孝先尽忠去见王驾， 那一厢坐的是对头寃家。"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "臣赵朔见驾，大王千岁！"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "千千岁！宣臣上殿，有何国事议论？"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "孤来问你：想当初桃园弑君，可是你赵家之过？"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "想桃园弑君，乃是反贼赵穿之过。那时臣父，不在朝中。千岁还提他则甚？"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "是吓！ 大司马，桃园弑君，乃是反贼赵穿之过，况且他父不在朝中，还提他则甚哪？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "启奏大王：他父虽逃，归朝之时，未曾讨贼，岂不是有意同谋？"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "着哇！ 你父虽逃，回朝未曾讨贼，岂不是有意同谋？"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "虽是臣父，未曾讨贼，已经辞世。大王何必追究？"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "着哇！ 大司马，他父今已辞世，孤王何必追究？ 中国京剧戏考 《搜孤救孤》【头本】 3"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "想大王乃一国之主，后来国中无事便罢；倘若有事，他岂不是要照样而行？这 等不忠之臣，理当斩首。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "着哇！此言越发有理。想孤乃一国之主，后来国中无事便罢；倘若有事，岂不 是要照样而行？这等不忠之臣，留他终为后患。 金瓜武士，推出斩了。"
        },
        {
          "character": "赵朔",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "赵朔",
          "type": "唱",
          "text": "君王殿上旨下就， 要将本宫斩人头。 大骂奸贼是禽兽， 巧言惑主报私仇。 悲悲切切下殿走， 霎时之间命难留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士押赵朔同下。赵同、赵括、赵婴齐同上。"
        },
        {
          "character": "赵同、赵括、赵婴齐",
          "type": "同白",
          "text": "刀下留人！"
        },
        {
          "character": "赵同",
          "type": "唱",
          "text": "这才是从空降祸事来到，"
        },
        {
          "character": "赵括",
          "type": "唱",
          "text": "想必是狗奸贼朦胧当朝。"
        },
        {
          "character": "赵婴齐",
          "type": "唱",
          "text": "我三人齐上殿去把本保，"
        },
        {
          "character": "赵同",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "赵同",
          "type": "唱",
          "text": "生和死吉和凶就在今朝。"
        },
        {
          "character": "赵同、赵括、赵婴齐",
          "type": "同白",
          "text": "臣等见驾，大王千岁！"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "卿等上殿，有何本奏？"
        },
        {
          "character": "赵同、赵括、赵婴齐",
          "type": "同白",
          "text": "赵朔身犯何罪，推出问斩。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "当初桃园弑君，乃是你赵家满门之过。"
        },
        {
          "character": "赵同、赵括、赵婴齐",
          "type": "同白",
          "text": "桃园弑君，乃是反贼赵穿之过，与臣等无干。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "大司马，他等保奏如何？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "依臣之见，将他等一齐斩首。这等不忠的臣子，留他何来？"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "武士们，将他等一齐斩首。"
        },
        {
          "character": "赵同、赵括、赵婴齐",
          "type": "同白",
          "text": "不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四武士押赵同、赵括、赵婴齐同下。韩厥上。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "韩厥",
          "type": "唱",
          "text": "听说是赵家人一齐斩首， 唬得我老韩厥浑身汗流。 急忙忙上金殿去把本奏， 想必是狗奸贼公报私仇。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "臣韩厥见驾，大王千岁！"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "大夫上殿，有何本奏？"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "赵家满门，身犯何罪，一齐斩首。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "桃园弑君，故尔斩首。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "当初之事，乃是赵穿之过，与他等无干。望求大王详察。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "大司马，大夫保奏如何吓？"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "既是韩大夫保奏，将他等打入天牢。过了七日，一齐正法。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "既是韩大夫保奏，将他等打入天牢。过了七日，一齐正法。韩大夫，下殿去罢。"
        },
        {
          "character": "韩厥",
          "type": "白",
          "text": "嗐！ 中国京剧戏考 《搜孤救孤》【头本】 4"
        },
        {
          "character": "韩厥",
          "type": "念",
          "text": "忠良遭毒害，叫人泪满腮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩厥下。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "大司马，赵家兵权，付与你掌管，要用心保孤的江山。"
        },
        {
          "character": "屠岸贾",
          "type": "白",
          "text": "谢大王！请驾回宫。"
        },
        {
          "character": "晋景公",
          "type": "白",
          "text": "摆驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "天有不测风云，人有旦夕祸福。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "卑人程婴，昔为赵家门客。驸马不知身犯何罪，打入天牢。不免报与公主知道 便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "庄姬上。"
        },
        {
          "character": "庄姬",
          "type": "念",
          "text": "眼跳心惊，坐卧不宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程婴上。"
        },
        {
          "character": "程婴",
          "type": "念",
          "text": "忙将驸马事，报与公主知。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "公主，大事不好了！"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "吓，何事惊慌？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "驸马不知身犯何罪，打入天牢。"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "庄姬",
          "type": "唱",
          "text": "听说驸马遭冤横， 好似钢刀刺在心。 回头我把程婴问， 有何良计救他身？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "公主不必啼哭。去到天牢，问过驸马，便知明白。"
        },
        {
          "character": "庄姬",
          "type": "白",
          "text": "言得极是。前面带路。"
        },
        {
          "character": "庄姬",
          "type": "唱",
          "text": "程婴与我把路引， 鞋弓袜小步难行。 忍悲含泪往前进， 去到天牢看夫君。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "开监。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "禁子上。"
        },
        {
          "character": "禁子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "公主来了。"
        },
        {
          "character": "禁子",
          "type": "白",
          "text": "待我开监。"
        },
        {
          "character": "程婴",
          "type": "白",
          "text": "请驸马。"
        },
        {
