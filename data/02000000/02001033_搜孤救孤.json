      "hangdang": "老生"
    },
    {
      "name": "韩厥",
      "hangdang": "武生"
    },
    {
      "name": "太后",
      "hangdang": "老旦"
    },
    {
      "name": "屠岸贾",
      "hangdang": "净"
    },
    {
      "name": "晋景公",
