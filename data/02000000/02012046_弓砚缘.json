    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤、张金凤同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《弓砚缘》【十本】 7"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同念",
          "text": "夫君上朝房，姐妹挂心旁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥上，坐。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "圣上又有何旨？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "圣上因边外反了众家王子，恐我年幼，另差他人前去。将我改放山东学政。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "但不知边外众家王子，因甚造反？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "边报上说得明白：乃纪献唐之子纪多文，勾引他们造反。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "纪多文。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "好贼子！"
        },
        {
          "character": "何玉凤",
          "type": "唱",
          "text": "只说纪贼断灭了， 谁知还有祸根苗。 切齿深仇不能报，"
        },
        {
          "character": "何玉凤",
          "type": "哭头",
          "text": "爹娘吓！"
        },
        {
          "character": "何玉凤",
          "type": "唱",
          "text": "养女不如养儿曹。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "当年与岳父大人结仇，乃是纪献唐老贼，你为何恨他逆子？"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "两家根由，从他逆子纪多文而起。眼前恨我手无兵权，若有兵权，去至沙漠， 定擒纪多文。一来为国除害，二来为父报仇。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "也罢，待下官先替你修下诉冤本章，然后自讨兵权，立此大功可好？"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "若得如此，妾身面谢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤拜。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "且慢，此事须禀告公婆。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "姐姐言得极是，我等前去便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤、张金凤同下。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "研墨修本章，上写微官安骥呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。何玉凤、张金凤同上。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "我爹娘怎道？"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "公婆言道：圣上若准本章，须同师父邓九公一同前去。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "言之有理。下官上朝去了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥下。张金凤暗下。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "有请师父！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓九公上。"
        },
        {
          "character": "邓九公",
          "type": "念",
          "text": "年高八十有谋勇，要与皇家立大功。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "师父请上，受弟子一拜！"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "你如今乃是皇家诰命夫人，老朽焉敢当你此拜？"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "弟子有事奉求，故有此拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤拜。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "请道其详。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "弟子切齿仇人纪多文，逃至边外，勾动众家王子，反过边关。儿夫替我修下诉 冤表本，又上殿自讨兵权，圣上若准本章，公婆意欲请师父同往。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "老朽正有此意，且候圣旨定夺。 且慢，老朽年过八旬，焉能受得风霜之苦？也罢，可命褚一官夫妻二人帮助与 你，大功必成。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "多谢师父！"
        },
        {
          "character": "安骥",
          "type": "内白",
          "text": "圣旨下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。安骥上。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "何玉凤听旨下跪。"
        },
        {
          "character": "何玉凤、邓九公",
          "type": "同白",
          "text": "臣。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "皇帝诏曰：安骥本奏妻室何玉凤，乃总兵何杞之女，何杞被纪献唐害死，皆由 逆子纪多文。如今纪多文勾动番王，反过边界，何玉凤为国为父，情愿从戎， 今封安骥为钦差大臣，妻室何玉凤封为女将军，带兵十万，再提五路总兵官， 剿灭纪贼。邓振彪，经安骥保奏武艺超群，亦授总兵之职，随军征战。就命安 中国京剧戏考 《弓砚缘》【十本】 8 骥奉旨宣读，钦哉谢恩。"
        },
        {
          "character": "何玉凤、邓九公",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "圣上如此传旨，大人何日起程？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "圣上言道，边报紧急，不日就要启行。"
        },
        {
